# Channel switches
ENABLE_TELEGRAM=true

# Telegram
# 填你的 Bot Token。不要把真实 token 提交到仓库。
TELEGRAM_BOT_TOKEN=
# ALLOWED_USER_IDS 留空 = 不限制用户ID（任何能访问你 Bot 的用户都可用）
# 建议生产环境填写，例如: ALLOWED_USER_IDS=12345678,99887766
ALLOWED_USER_IDS=

# CodeBuddy CLI
CODEBUDDY_BIN=codebuddy
CODEBUDDY_PERMISSION_FLAG=-y
CODEBUDDY_ECHO_STDIO=true
CODEBUDDY_HEARTBEAT_MS=15000
# 可选：覆盖文件发送安全根目录（逗号分隔绝对路径）。留空则用默认值。
TELEGRAM_FILE_ALLOWED_ROOTS=
# 可选：覆盖文件候选搜索目录（逗号分隔绝对路径）。留空则用默认值。
TELEGRAM_FILE_CANDIDATE_DIRS=
REQUEST_TIMEOUT_MS=120000
MAX_PROMPT_CHARS=8000
MAX_HISTORY_TURNS=10

# Web management panel
WEB_HOST=127.0.0.1
WEB_PORT=8787

# System operation permissions (DANGEROUS, use whitelist)
ENABLE_SYSTEM_EXEC=false
ALLOWED_COMMAND_PREFIXES=ls,pwd,open,codebuddy,node,npm,python3
SYSTEM_EXEC_TIMEOUT_MS=60000

# Pipeline infra
PIPELINE_PROJECT_ROOT=
PIPELINE_DIR=
FEATURE_LIST_PATH=feature-list.json
BUG_FIX_LIST_PATH=bug-fix-list.json
MAX_RETRIES=3
SESSION_TIMEOUT=0
HEARTBEAT_INTERVAL=30
AI_CLI=cbc
PRIZMKIT_PLATFORM=codebuddy

# Logging
LOG_LEVEL=info

# F-006: Safety and Permission Guard
# USER_PERMISSIONS format: userId:role,userId:role (roles: admin, operator, viewer)
# Example: USER_PERMISSIONS=123456789:admin,987654321:operator
USER_PERMISSIONS=
# Allow admin users to skip confirmation for high-risk commands
ALLOW_ADMIN_SKIP_CONFIRM=true
# Audit log configuration
AUDIT_LOG_DIR=logs
AUDIT_LOG_MAX_SIZE_MB=10
AUDIT_LOG_MAX_FILES=5
