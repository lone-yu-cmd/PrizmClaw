# Pipeline daemon log (large, runtime-only)
state/pipeline-daemon.log
bugfix-state/pipeline-daemon.log

# PID files
*.pid

# Python cache
__pycache__/
*.pyc

# NOTE: state/ and bugfix-state/ directories are intentionally tracked.
# They contain feature status, session metadata, and bootstrap prompts
# which are valuable for auditing pipeline history and debugging sessions.
