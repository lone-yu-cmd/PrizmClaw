{"type":"user","uuid":"01fafab9-1d23-46b3-9c08-5b57fd989841","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29ee8619eb4fc28d89c0eae8e2","content":[{"type":"text","text":"   1→#!/usr/bin/env python3\n   2→\"\"\"Path policy utilities for pipeline infrastructure.\n   3→\n   4→This module provides path calculation and validation functions that mirror\n   5→the JavaScript implementation in src/pipeline-infra/path-policy.js.\n   6→\n   7→Maintains exact behavioral parity with the JS version for cross-language compatibility.\n   8→\"\"\"\n   9→\n  10→import os\n  11→import re\n  12→\n  13→SAFE_SEGMENT_PATTERN = re.compile(r'^[A-Za-z0-9._-]+$')\n  14→\n  15→\n  16→def _assert_safe_segment(value, label):\n  17→    \"\"\"Validate that a path segment is safe.\n  18→\n  19→    Args:\n  20→        value: The value to validate\n  21→        label: Label for error messages\n  22→\n  23→    Returns:\n  24→        The normalized, validated string\n  25→\n  26→    Raises:\n  27→        ValueError: If the segment is invalid\n  28→    \"\"\"\n  29→    normalized = str(value or '').strip()\n  30→    if not normalized or not SAFE_SEGMENT_PATTERN.match(normalized) or '..' in normalized:\n  31→        raise ValueError('Invalid path segment for {}: {}'.format(label, value))\n  32→    return normalized\n  33→\n  34→\n  35→def compute_feature_slug(feature_id, title):\n  36→    \"\"\"Compute a feature slug from ID and title.\n  37→\n  38→    Args:\n  39→        feature_id: Feature ID like 'F-001'\n  40→        title: Feature title\n  41→\n  42→    Returns:\n  43→        Slug string like '001-feature-name'\n  44→    \"\"\"\n  45→    normalized_feature_id = _assert_safe_segment(feature_id, 'featureId')\n  46→    # Remove 'F-' prefix (case-insensitive), strip leading zeros, pad to 3 digits\n  47→    numeric = re.sub(r'^F-', '', normalized_feature_id, flags=re.IGNORECASE)\n  48→    numeric = numeric.lstrip('0') or '0'\n  49→    numeric = numeric.zfill(3)\n  50→\n  51→    raw_title = str(title or '').lower()\n  52→    # Remove non-alphanumeric chars except spaces and hyphens\n  53→    cleaned_title = re.sub(r'[^a-z0-9\\s-]', '', raw_title)\n  54→    cleaned_title = cleaned_title.strip()\n  55→    # Replace whitespace with hyphens\n  56→    cleaned_title = re.sub(r'\\s+', '-', cleaned_title)\n  57→    # Collapse multiple hyphens\n  58→    cleaned_title = re.sub(r'-+', '-', cleaned_title)\n  59→\n  60→    safe_title = cleaned_title or 'feature'\n  61→    return '{}-{}'.format(numeric, safe_title)\n  62→\n  63→\n  64→def resolve_feature_paths(project_root, feature_id, title, session_id):\n  65→    \"\"\"Resolve all paths related to a feature.\n  66→\n  67→    Args:\n  68→        project_root: Project root directory\n  69→        feature_id: Feature ID like 'F-001'\n  70→        title: Feature title (for slug computation)\n  71→        session_id: Session ID\n  72→\n  73→    Returns:\n  74→        Dict with featureSlug, specsDir, sessionDir, sessionLog, sessionStatus\n  75→    \"\"\"\n  76→    resolved_root = os.path.abspath(str(project_root or ''))\n  77→    validated_feature_id = _assert_safe_segment(feature_id, 'featureId')\n  78→    validated_session_id = _assert_safe_segment(session_id, 'sessionId')\n  79→    feature_slug = compute_feature_slug(feature_id, title or '')\n  80→\n  81→    specs_dir = os.path.join(resolved_root, '.prizmkit', 'specs', feature_slug)\n  82→    session_dir = os.path.join(\n  83→        resolved_root, 'dev-pipeline', 'state', 'features',\n  84→        validated_feature_id, 'sessions', validated_session_id\n  85→    )\n  86→\n  87→    return {\n  88→        'featureSlug': feature_slug,\n  89→        'specsDir': specs_dir,\n  90→        'sessionDir': session_dir,\n  91→        'sessionLog': os.path.join(session_dir, 'logs', 'session.log'),\n  92→        'sessionStatus': os.path.join(session_dir, 'session-status.json')\n  93→    }\n  94→\n  95→\n  96→def resolve_bug_paths(project_root, bug_id, session_id):\n  97→    \"\"\"Resolve all paths related to a bug fix.\n  98→\n  99→    Args:\n 100→        project_root: Project root directory\n 101→        bug_id: Bug ID like 'B-100'\n 102→        session_id: Session ID\n 103→\n 104→    Returns:\n 105→        Dict with bugDir, sessionDir, sessionLog, sessionStatus\n 106→    \"\"\"\n 107→    resolved_root = os.path.abspath(str(project_root or ''))\n 108→    validated_bug_id = _assert_safe_segment(bug_id, 'bugId')\n 109→    validated_session_id = _assert_safe_segment(session_id, 'sessionId')\n 110→\n 111→    bug_dir = os.path.join(resolved_root, 'dev-pipeline', 'bugfix-state', 'bugs', validated_bug_id)\n 112→    session_dir = os.path.join(bug_dir, 'sessions', validated_session_id)\n 113→\n 114→    return {\n 115→        'bugDir': bug_dir,\n 116→        'sessionDir': session_dir,\n 117→        'sessionLog': os.path.join(session_dir, 'logs', 'session.log'),\n 118→        'sessionStatus': os.path.join(session_dir, 'session-status.json')\n 119→    }\n 120→\n 121→\n 122→def resolve_daemon_log_paths(project_root):\n 123→    \"\"\"Resolve daemon log file paths.\n 124→\n 125→    Args:\n 126→        project_root: Project root directory\n 127→\n 128→    Returns:\n 129→        Dict with featureDaemonLog, bugfixDaemonLog\n 130→    \"\"\"\n 131→    resolved_root = os.path.abspath(str(project_root or ''))\n 132→\n 133→    return {\n 134→        'featureDaemonLog': os.path.join(resolved_root, 'dev-pipeline', 'state', 'pipeline-daemon.log'),\n 135→        'bugfixDaemonLog': os.path.join(resolved_root, 'dev-pipeline', 'bugfix-state', 'pipeline-daemon.log')\n 136→    }\n 137→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:17.392Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"ba0dd7d0-1045-400c-9bcb-4ff6203f51de","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29f05fa182e9b55648fb518e6f","content":[{"type":"text","text":"   1→{\n   2→  \"compilerOptions\": {\n   3→    \"target\": \"ES2022\",\n   4→    \"module\": \"NodeNext\",\n   5→    \"moduleResolution\": \"NodeNext\",\n   6→    \"allowJs\": true,\n   7→    \"checkJs\": true,\n   8→    \"noEmit\": true,\n   9→    \"strict\": false,\n  10→    \"resolveJsonModule\": true,\n  11→    \"esModuleInterop\": true,\n  12→    \"skipLibCheck\": true,\n  13→    \"types\": [\"node\"]\n  14→  },\n  15→  \"include\": [\n  16→    \"src/pipeline-infra/**/*.js\",\n  17→    \"src/services/pipeline-control-service.js\"\n  18→  ],\n  19→  \"exclude\": [\n  20→    \"node_modules\",\n  21→    \"dev-pipeline/state\",\n  22→    \"dev-pipeline/bugfix-state\"\n  23→  ]\n  24→}\n  25→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:17.393Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"fecb8fe0-ea08-471e-af81-9ad33617fd2d","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29f20361c0dd579dfd7cb67a7c","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→\n   4→import {\n   5→  INFRA_ERROR_CODES,\n   6→  createInfraError,\n   7→  isInfraErrorCode\n   8→} from '../../src/pipeline-infra/error-codes.js';\n   9→\n  10→test('INFRA_ERROR_CODES should include required categories', () => {\n  11→  assert.equal(INFRA_ERROR_CODES.CONFIG_MISSING, 'CONFIG_MISSING');\n  12→  assert.equal(INFRA_ERROR_CODES.CONFIG_INVALID, 'CONFIG_INVALID');\n  13→  assert.equal(INFRA_ERROR_CODES.PATH_INVALID, 'PATH_INVALID');\n  14→  assert.equal(INFRA_ERROR_CODES.SCRIPT_NOT_FOUND, 'SCRIPT_NOT_FOUND');\n  15→  assert.equal(INFRA_ERROR_CODES.EXEC_TIMEOUT, 'EXEC_TIMEOUT');\n  16→  assert.equal(INFRA_ERROR_CODES.EXEC_FAILED, 'EXEC_FAILED');\n  17→});\n  18→\n  19→test('isInfraErrorCode should validate known error code values', () => {\n  20→  assert.equal(isInfraErrorCode('CONFIG_MISSING'), true);\n  21→  assert.equal(isInfraErrorCode('NOT_REAL'), false);\n  22→});\n  23→\n  24→test('createInfraError should produce serializable error objects', () => {\n  25→  const err = createInfraError('CONFIG_MISSING', 'Missing env var', {\n  26→    hint: 'Set MY_ENV in .env',\n  27→    context: { field: 'MY_ENV' }\n  28→  });\n  29→\n  30→  assert.deepEqual(err, {\n  31→    code: 'CONFIG_MISSING',\n  32→    message: 'Missing env var',\n  33→    hint: 'Set MY_ENV in .env',\n  34→    context: { field: 'MY_ENV' }\n  35→  });\n  36→\n  37→  assert.doesNotThrow(() => JSON.stringify(err));\n  38→});\n  39→\n  40→test('createInfraError should reject unknown error codes', () => {\n  41→  assert.throws(() => {\n  42→    createInfraError('UNKNOWN', 'oops');\n  43→  }, /Unknown infra error code/i);\n  44→});\n  45→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:17.394Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
