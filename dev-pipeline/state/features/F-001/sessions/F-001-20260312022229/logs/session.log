2→\n  63→  return parsed;\n  64→}\n  65→\n  66→function throwInfraError({ code, field, message, hint, context = undefined }) {\n  67→  const infraError = createInfraError(code, message, {\n  68→    hint,\n  69→    context: {\n  70→      ...(context ?? {}),\n  71→      field\n  72→    }\n  73→  });\n  74→\n  75→  const err = new Error(`${infraError.message} (field: ${field}, hint: ${hint ?? 'n/a'})`);\n  76→  const mutableError = /** @type {any} */ (err);\n  77→  mutableError.code = infraError.code;\n  78→  mutableError.hint = infraError.hint;\n  79→  mutableError.context = infraError.context;\n  80→  mutableError.infraError = infraError;\n  81→  throw mutableError;\n  82→}\n  83→\n  84→function ensureDirectoryExists(dirPath, field) {\n  85→  if (!fs.existsSync(dirPath)) {\n  86→    throwInfraError({\n  87→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n  88→      field,\n  89→      message: `${field} does not exist: ${dirPath}`,\n  90→      hint: 'Ensure project root points to a repository containing dev-pipeline/'\n  91→    });\n  92→  }\n  93→}\n  94→\n  95→export function loadPipelineInfraConfig(input = {}) {\n  96→  const env = input.env ?? process.env;\n  97→  const argv = input.argv ?? [];\n  98→  const cwd = input.cwd ?? process.cwd();\n  99→  const argMap = toArgMap(argv);\n 100→\n 101→  const projectRootRaw = argMap.get('project-root') ?? env.PIPELINE_PROJECT_ROOT ?? cwd;\n 102→  const projectRoot = toAbsolutePath(projectRootRaw, cwd);\n 103→\n 104→  if (!projectRoot) {\n 105→    throwInfraError({\n 106→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 107→      field: 'projectRoot',\n 108→      message: 'projectRoot is required',\n 109→      hint: 'Set --project-root or PIPELINE_PROJECT_ROOT, or provide cwd input'\n 110→    });\n 111→  }\n 112→\n 113→  const pipelineDir = toAbsolutePath(\n 114→    argMap.get('pipeline-dir') ?? env.PIPELINE_DIR ?? path.join(projectRoot, 'dev-pipeline'),\n 115→    projectRoot\n 116→  );\n 117→\n 118→  ensureDirectoryExists(pipelineDir, 'pipelineDir');\n 119→\n 120→  const featureListPath = toAbsolutePath(\n 121→    argMap.get('feature-list') ?? env.FEATURE_LIST_PATH ?? path.join(projectRoot, 'feature-list.json'),\n 122→    projectRoot\n 123→  );\n 124→\n 125→  const bugFixListPath = toAbsolutePath(\n 126→    argMap.get('bug-fix-list') ?? env.BUG_FIX_LIST_PATH ?? path.join(projectRoot, 'bug-fix-list.json'),\n 127→    projectRoot\n 128→  );\n 129→\n 130→  const maxRetries = parseInteger({\n 131→    raw: argMap.get('max-retries') ?? env.MAX_RETRIES ?? 3,\n 132→    field: 'MAX_RETRIES',\n 133→    min: 1,\n 134→    hint: 'Set MAX_RETRIES to a positive integer'\n 135→  });\n 136→\n 137→  const sessionTimeoutSec = parseInteger({\n 138→    raw: argMap.get('session-timeout') ?? env.SESSION_TIMEOUT ?? 0,\n 139→    field: 'SESSION_TIMEOUT',\n 140→    min: 0,\n 141→    hint: 'Set SESSION_TIMEOUT to 0 or a positive integer (seconds)'\n 142→  });\n 143→\n 144→  const heartbeatIntervalSec = parseInteger({\n 145→    raw: argMap.get('heartbeat-interval') ?? env.HEARTBEAT_INTERVAL ?? 30,\n 146→    field: 'HEARTBEAT_INTERVAL',\n 147→    min: 1,\n 148→    hint: 'Set HEARTBEAT_INTERVAL to a positive integer (seconds)'\n 149→  });\n 150→\n 151→  const aiCli = String(argMap.get('ai-cli') ?? env.AI_CLI ?? env.CODEBUDDY_CLI ?? 'cbc').trim();\n 152→  if (!aiCli) {\n 153→    throwInfraError({\n 154→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 155→      field: 'AI_CLI',\n 156→      message: 'AI_CLI is required',\n 157→      hint: 'Set AI_CLI or CODEBUDDY_CLI to a CLI command name'\n 158→    });\n 159→  }\n 160→\n 161→  const platformRaw = String(\n 162→    argMap.get('platform') ?? env.PRIZMKIT_PLATFORM ?? (aiCli.includes('claude') ? 'claude' : 'codebuddy')\n 163→  ).trim();\n 164→\n 165→  if (platformRaw !== 'codebuddy' && platformRaw !== 'claude') {\n 166→    throwInfraError({\n 167→      code: INFRA_ERROR_CODES.CONFIG_INVALID,\n 168→      field: 'PRIZMKIT_PLATFORM',\n 169→      message: `Unsupported platform: ${platformRaw}`,\n 170→      hint: \"Use 'codebuddy' or 'claude'\"\n 171→    });\n 172→  }\n 173→\n 174→  return Object.freeze({\n 175→    projectRoot,\n 176→    pipelineDir,\n 177→    featureListPath,\n 178→    bugFixListPath,\n 179→    stateDir: path.join(pipelineDir, 'state'),\n 180→    bugfixStateDir: path.join(pipelineDir, 'bugfix-state'),\n 181→    maxRetries,\n 182→    sessionTimeoutSec,\n 183→    heartbeatIntervalSec,\n 184→    aiCli,\n 185→    platform: platformRaw\n 186→  });\n 187→}\n 188→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:07.847Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"818fb3bb-2ea5-420f-bbb1-1f8eac1ca1c6","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29c65ba9c0d26650a0dfce5fe8","content":[{"type":"text","text":"   1→import path from 'node:path';\n   2→\n   3→const SAFE_SEGMENT_PATTERN = /^[A-Za-z0-9._-]+$/;\n   4→\n   5→function assertSafeSegment(value, label) {\n   6→  const normalized = String(value ?? '').trim();\n   7→  if (!normalized || !SAFE_SEGMENT_PATTERN.test(normalized) || normalized.includes('..')) {\n   8→    throw new Error(`Invalid path segment for ${label}: ${value}`);\n   9→  }\n  10→\n  11→  return normalized;\n  12→}\n  13→\n  14→export function computeFeatureSlug(featureId, title) {\n  15→  const normalizedFeatureId = assertSafeSegment(featureId, 'featureId');\n  16→  const numeric = normalizedFeatureId.replace(/^F-/i, '').replace(/^0+/, '').padStart(3, '0');\n  17→\n  18→  const rawTitle = String(title ?? '').toLowerCase();\n  19→  const cleanedTitle = rawTitle\n  20→    .replace(/[^a-z0-9\\s-]/g, '')\n  21→    .trim()\n  22→    .replace(/[\\s]+/g, '-')\n  23→    .replace(/-+/g, '-');\n  24→\n  25→  const safeTitle = cleanedTitle || 'feature';\n  26→  return `${numeric}-${safeTitle}`;\n  27→}\n  28→\n  29→export function resolveFeaturePaths(input) {\n  30→  const projectRoot = path.resolve(String(input?.projectRoot ?? ''));\n  31→  const featureId = assertSafeSegment(input?.featureId, 'featureId');\n  32→  const sessionId = assertSafeSegment(input?.sessionId, 'sessionId');\n  33→  const featureSlug = computeFeatureSlug(featureId, input?.title ?? '');\n  34→\n  35→  const specsDir = path.join(projectRoot, '.prizmkit/specs', featureSlug);\n  36→  const sessionDir = path.join(projectRoot, 'dev-pipeline/state/features', featureId, 'sessions', sessionId);\n  37→\n  38→  return {\n  39→    featureSlug,\n  40→    specsDir,\n  41→    sessionDir,\n  42→    sessionLog: path.join(sessionDir, 'logs/session.log'),\n  43→    sessionStatus: path.join(sessionDir, 'session-status.json')\n  44→  };\n  45→}\n  46→\n  47→export function resolveBugPaths(input) {\n  48→  const projectRoot = path.resolve(String(input?.projectRoot ?? ''));\n  49→  const bugId = assertSafeSegment(input?.bugId, 'bugId');\n  50→  const sessionId = assertSafeSegment(input?.sessionId, 'sessionId');\n  51→\n  52→  const bugDir = path.join(projectRoot, 'dev-pipeline/bugfix-state/bugs', bugId);\n  53→  const sessionDir = path.join(bugDir, 'sessions', sessionId);\n  54→\n  55→  return {\n  56→    bugDir,\n  57→    sessionDir,\n  58→    sessionLog: path.join(sessionDir, 'logs/session.log'),\n  59→    sessionStatus: path.join(sessionDir, 'session-status.json')\n  60→  };\n  61→}\n  62→\n  63→export function resolveDaemonLogPaths(projectRoot) {\n  64→  const resolvedRoot = path.resolve(String(projectRoot ?? ''));\n  65→\n  66→  return {\n  67→    featureDaemonLog: path.join(resolvedRoot, 'dev-pipeline/state/pipeline-daemon.log'),\n  68→    bugfixDaemonLog: path.join(resolvedRoot, 'dev-pipeline/bugfix-state/pipeline-daemon.log')\n  69→  };\n  70→}\n  71→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:07.847Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"bfad91f9-6027-4654-8042-d517506e4ce9","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29c8234c4f4df5e506630fdae9","content":[{"type":"text","text":"   1→export const INFRA_ERROR_CODES = Object.freeze({\n   2→  CONFIG_MISSING: 'CONFIG_MISSING',\n   3→  CONFIG_INVALID: 'CONFIG_INVALID',\n   4→  PATH_INVALID: 'PATH_INVALID',\n   5→  SCRIPT_NOT_FOUND: 'SCRIPT_NOT_FOUND',\n   6→  EXEC_TIMEOUT: 'EXEC_TIMEOUT',\n   7→  EXEC_FAILED: 'EXEC_FAILED'\n   8→});\n   9→\n  10→const ERROR_CODE_SET = new Set(Object.values(INFRA_ERROR_CODES));\n  11→\n  12→export function isInfraErrorCode(code) {\n  13→  return ERROR_CODE_SET.has(code);\n  14→}\n  15→\n  16→export function createInfraError(code, message, options = {}) {\n  17→  if (!isInfraErrorCode(code)) {\n  18→    throw new Error(`Unknown infra error code: ${code}`);\n  19→  }\n  20→\n  21→  return {\n  22→    code,\n  23→    message: String(message ?? ''),\n  24→    ...(options.hint ? { hint: String(options.hint) } : {}),\n  25→    ...(options.context ? { context: options.context } : {})\n  26→  };\n  27→}\n  28→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:07.848Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"5fe44a6e-b163-4919-8aa7-a29b5366208f","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29c9db890613786f7a0b924742","content":[{"type":"text","text":"   1→import { spawn } from 'node:child_process';\n   2→import fs from 'node:fs';\n   3→import path from 'node:path';\n   4→\n   5→import { INFRA_ERROR_CODES } from './error-codes.js';\n   6→import { loadPipelineInfraConfig } from './config-loader.js';\n   7→\n   8→const PIPELINE_TYPES = new Set(['feature', 'bugfix']);\n   9→const PIPELINE_ACTIONS = new Set(['run', 'status', 'stop', 'logs', 'retry', 'reset']);\n  10→\n  11→function ensureValidRequest(req) {\n  12→  if (!PIPELINE_TYPES.has(req?.pipelineType)) {\n  13→    throw new Error(`Invalid pipelineType: ${req?.pipelineType}`);\n  14→  }\n  15→  if (!PIPELINE_ACTIONS.has(req?.action)) {\n  16→    throw new Error(`Invalid action: ${req?.action}`);\n  17→  }\n  18→}\n  19→\n  20→function ensureTargetId(targetId, action) {\n  21→  const normalized = String(targetId ?? '').trim();\n  22→  if (!normalized) {\n  23→    throw new Error(`targetId is required for action '${action}'`);\n  24→  }\n  25→  return normalized;\n  26→}\n  27→\n  28→function withOptionalList(args, listPath) {\n  29→  if (listPath) {\n  30→    args.push(listPath);\n  31→  }\n  32→  return args;\n  33→}\n  34→\n  35→export function buildPipelineCommand(req, config) {\n  36→  ensureValidRequest(req);\n  37→\n  38→  const pipelineDir = config.pipelineDir;\n  39→  const featureListPath = req.listPath || config.featureListPath;\n  40→  const bugFixListPath = req.listPath || config.bugFixListPath;\n  41→\n  42→  if (req.pipelineType === 'feature') {\n  43→    switch (req.action) {\n  44→      case 'run': {\n  45→        const args = ['run'];\n  46→        if (req.targetId) {\n  47→          args.push(req.targetId);\n  48→        }\n  49→        return { command: path.join(pipelineDir, 'run.sh'), args: withOptionalList(args, featureListPath) };\n  50→      }\n  51→      case 'status':\n  52→        return {\n  53→          command: path.join(pipelineDir, 'run.sh'),\n  54→          args: withOptionalList(['status'], featureListPath)\n  55→        };\n  56→      case 'stop':\n  57→        return { command: path.join(pipelineDir, 'launch-daemon.sh'), args: ['stop'] };\n  58→      case 'logs':\n  59→        return { command: path.join(pipelineDir, 'launch-daemon.sh'), args: ['logs'] };\n  60→      case 'retry': {\n  61→        const targetId = ensureTargetId(req.targetId, req.action);\n  62→        return {\n  63→          command: path.join(pipelineDir, 'retry-feature.sh'),\n  64→          args: withOptionalList([targetId], featureListPath)\n  65→        };\n  66→      }\n  67→      case 'reset': {\n  68→        if (req.targetId) {\n  69→          const targetId = ensureTargetId(req.targetId, req.action);\n  70→          return {\n  71→            command: path.join(pipelineDir, 'reset-feature.sh'),\n  72→            args: withOptionalList([targetId, '--clean'], featureListPath)\n  73→          };\n  74→        }\n  75→\n  76→        return { command: path.join(pipelineDir, 'run.sh'), args: ['reset'] };\n  77→      }\n  78→      default:\n  79→        throw new Error(`Unsupported feature action: ${req.action}`);\n  80→    }\n  81→  }\n  82→\n  83→  switch (req.action) {\n  84→    case 'run': {\n  85→      const args = ['run'];\n  86→      if (req.targetId) {\n  87→        args.push(req.targetId);\n  88→      }\n  89→      return { command: path.join(pipelineDir, 'run-bugfix.sh'), args: withOptionalList(args, bugFixListPath) };\n  90→    }\n  91→    case 'status':\n  92→      return {\n  93→        command: path.join(pipelineDir, 'run-bugfix.sh'),\n  94→        args: withOptionalList(['status'], bugFixListPath)\n  95→      };\n  96→    case 'stop':\n  97→      return { command: path.join(pipelineDir, 'launch-bugfix-daemon.sh'), args: ['stop'] };\n  98→    case 'logs':\n  99→      return { command: path.join(pipelineDir, 'launch-bugfix-daemon.sh'), args: ['logs'] };\n 100→    case 'retry': {\n 101→      const targetId = ensureTargetId(req.targetId, req.action);\n 102→      return {\n 103→        command: path.join(pipelineDir, 'retry-bug.sh'),\n 104→        args: withOptionalList([targetId], bugFixListPath)\n 105→      };\n 106→    }\n 107→    case 'reset': {\n 108→      if (req.targetId) {\n 109→        const targetId = ensureTargetId(req.targetId, req.action);\n 110→        const listPath = req.listPath || config.bugFixListPath;\n 111→        return {\n 112→          command: path.join(pipelineDir, 'scripts/update-bug-status.py'),\n 113→          args: [\n 114→            '--bug-list',\n 115→            listPath,\n 116→            '--state-dir',\n 117→            path.join(pipelineDir, 'bugfix-state'),\n 118→            '--bug-id',\n 119→            targetId,\n 120→            '--project-root',\n 121→            config.projectRoot,\n 122→            '--action',\n 123→            'clean'\n 124→          ]\n 125→        };\n 126→      }\n 127→\n 128→      return { command: path.join(pipelineDir, 'run-bugfix.sh'), args: ['reset'] };\n 129→    }\n 130→    default:\n 131→      throw new Error(`Unsupported bugfix action: ${req.action}`);\n 132→  }\n 133→}\n 134→\n 135→export function normalizePipelineResult({ exitCode, signal, stdout, stderr, timedOut = false }) {\n 136→  let normalizedStatus = 'failed';\n 137→  let errorCode;\n 138→\n 139→  if (timedOut || exitCode === 124) {\n 140→    normalizedStatus = 'timed_out';\n 141→    errorCode = INFRA_ERROR_CODES.EXEC_TIMEOUT;\n 142→  } else if (signal) {\n 143→    normalizedStatus = 'crashed';\n 144→    errorCode = INFRA_ERROR_CODES.EXEC_FAILED;\n 145→  } else if (exitCode === 0) {\n 146→    normalizedStatus = 'success';\n 147→  } else {\n 148→    normalizedStatus = 'failed';\n 149→    errorCode = INFRA_ERROR_CODES.EXEC_FAILED;\n 150→  }\n 151→\n 152→  return {\n 153→    ok: normalizedStatus === 'success',\n 154→    exitCode: Number.isInteger(exitCode) ? exitCode : 1,\n 155→    signal: signal || undefined,\n 156→    stdout: stdout ?? '',\n 157→    stderr: stderr ?? '',\n 158→    normalizedStatus,\n 159→    errorCode\n 160→  };\n 161→}\n 162→\n 163→function runCommand({ command, args, env, timeoutMs }) {\n 164→  return new Promise((resolve, reject) => {\n 165→    let stdout = '';\n 166→    let stderr = '';\n 167→    let timedOut = false;\n 168→\n 169→    const child = spawn(command, args, {\n 170→      env,\n 171→      stdio: ['ignore', 'pipe', 'pipe']\n 172→    });\n 173→\n 174→    const timer = timeoutMs && timeoutMs > 0\n 175→      ? setTimeout(() => {\n 176→          timedOut = true;\n 177→          child.kill('SIGTERM');\n 178→        }, timeoutMs)\n 179→      : null;\n 180→\n 181→    child.stdout.on('data', (chunk) => {\n 182→      stdout += chunk.toString();\n 183→    });\n 184→\n 185→    child.stderr.on('data', (chunk) => {\n 186→      stderr += chunk.toString();\n 187→    });\n 188→\n 189→    child.on('error', (error) => {\n 190→      if (timer) {\n 191→        clearTimeout(timer);\n 192→      }\n 193→      reject(error);\n 194→    });\n 195→\n 196→    child.on('close', (exitCode, signal) => {\n 197→      if (timer) {\n 198→        clearTimeout(timer);\n 199→      }\n 200→      resolve({ exitCode: exitCode ?? (timedOut ? 124 : 1), signal, stdout, stderr, timedOut });\n 201→    });\n 202→  });\n 203→}\n 204→\n 205→function scriptExists(commandPath) {\n 206→  if (commandPath === 'python3' || commandPath === 'node') {\n 207→    return true;\n 208→  }\n 209→  return fs.existsSync(commandPath);\n 210→}\n 211→\n 212→export async function executePipelineCommand(req) {\n 213→  const config = loadPipelineInfraConfig();\n 214→  const commandRequest = {\n 215→    ...req,\n 216→    listPath:\n 217→      req.listPath || (req.pipelineType === 'feature' ? config.featureListPath : config.bugFixListPath)\n 218→  };\n 219→\n 220→  let command;\n 221→  let args;\n 222→\n 223→  try {\n 224→    ({ command, args } = buildPipelineCommand(commandRequest, config));\n 225→  } catch (error) {\n 226→    return {\n 227→      ok: false,\n 228→      exitCode: 1,\n 229→      stdout: '',\n 230→      stderr: error instanceof Error ? error.message : String(error),\n 231→      normalizedStatus: 'failed',\n 232→      errorCode: INFRA_ERROR_CODES.EXEC_FAILED\n 233→    };\n 234→  }\n 235→\n 236→  if (!scriptExists(command)) {\n 237→    return {\n 238→      ok: false,\n 239→      exitCode: 127,\n 240→      stdout: '',\n 241→      stderr: `Command not found: ${command}`,\n 242→      normalizedStatus: 'failed',\n 243→      errorCode: INFRA_ERROR_CODES.SCRIPT_NOT_FOUND\n 244→    };\n 245→  }\n 246→\n 247→  try {\n 248→    const raw = await runCommand({\n 249→      command,\n 250→      args,\n 251→      timeoutMs: req.timeoutMs,\n 252→      env: {\n 253→        ...process.env,\n 254→        ...(req.envOverrides ?? {})\n 255→      }\n 256→    });\n 257→\n 258→    return normalizePipelineResult(raw);\n 259→  } catch (error) {\n 260→    const message = error instanceof Error ? error.message : String(error);\n 261→\n 262→    if (error && error.code === 'ENOENT') {\n 263→      return {\n 264→        ok: false,\n 265→        exitCode: 127,\n 266→        stdout: '',\n 267→        stderr: message,\n 268→        normalizedStatus: 'failed',\n 269→        errorCode: INFRA_ERROR_CODES.SCRIPT_NOT_FOUND\n 270→      };\n 271→    }\n 272→\n 273→    return {\n 274→      ok: false,\n 275→      exitCode: 1,\n 276→      stdout: '',\n 277→      stderr: message,\n 278→      normalizedStatus: 'failed',\n 279→      errorCode: INFRA_ERROR_CODES.EXEC_FAILED\n 280→    };\n 281→  }\n 282→}\n 283→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:07.848Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"e66c6f4e-345a-4a49-9107-8d688d9bdbec","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29cb9248786e4d3bc672b736ee","content":[{"type":"text","text":"   1→import { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2→\n   3→function buildRequest(params = {}, action) {\n   4→  return {\n   5→    pipelineType: params.pipelineType ?? 'feature',\n   6→    action,\n   7→    ...(params.targetId ? { targetId: params.targetId } : {}),\n   8→    ...(params.listPath ? { listPath: params.listPath } : {}),\n   9→    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  10→    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  11→  };\n  12→}\n  13→\n  14→export function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  15→  return {\n  16→    runner,\n  17→    async startPipeline(params) {\n  18→      return runner(buildRequest(params, 'run'));\n  19→    },\n  20→    async getPipelineStatus(params) {\n  21→      return runner(buildRequest(params, 'status'));\n  22→    },\n  23→    async stopPipeline(params) {\n  24→      return runner(buildRequest(params, 'stop'));\n  25→    },\n  26→    async retryTarget(params) {\n  27→      return runner(buildRequest(params, 'retry'));\n  28→    },\n  29→    async getPipelineLogs(params) {\n  30→      return runner(buildRequest(params, 'logs'));\n  31→    },\n  32→    async resetTarget(params) {\n  33→      return runner(buildRequest(params, 'reset'));\n  34→    }\n  35→  };\n  36→}\n  37→\n  38→const defaultService = createPipelineControlService();\n  39→\n  40→export async function startPipeline(params) {\n  41→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  42→  return service.startPipeline(params);\n  43→}\n  44→\n  45→export async function getPipelineStatus(params) {\n  46→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  47→  return service.getPipelineStatus(params);\n  48→}\n  49→\n  50→export async function stopPipeline(params) {\n  51→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  52→  return service.stopPipeline(params);\n  53→}\n  54→\n  55→export async function retryTarget(params) {\n  56→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  57→  return service.retryTarget(params);\n  58→}\n  59→\n  60→export async function getPipelineLogs(params) {\n  61→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  62→  return service.getPipelineLogs(params);\n  63→}\n  64→\n  65→export async function resetTarget(params) {\n  66→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  67→  return service.resetTarget(params);\n  68→}\n  69→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:07.849Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"8ed0c524-8092-4d07-a6aa-d52dd11bc73a","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29cd2d77b44f504ce7d29da029","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info')\n  26→});\n  27→\n  28→const parsed = schema.parse(process.env);\n  29→\n  30→function parseAllowedUserIds(input) {\n  31→  return new Set(\n  32→    input\n  33→      .split(',')\n  34→      .map((id) => id.trim())\n  35→      .filter(Boolean)\n  36→  );\n  37→}\n  38→\n  39→function parseCsvList(input) {\n  40→  return input\n  41→    .split(',')\n  42→    .map((item) => item.trim())\n  43→    .filter(Boolean);\n  44→}\n  45→\n  46→function parseBoolean(input) {\n  47→  const normalized = (input ?? '').trim().toLowerCase();\n  48→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  49→}\n  50→\n  51→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n  52→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n  53→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n  54→}\n  55→\n  56→const pipelineInfra = loadPipelineInfraConfig({\n  57→  env: process.env,\n  58→  argv: process.argv.slice(2),\n  59→  cwd: process.cwd()\n  60→});\n  61→\n  62→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n  63→\n  64→export const config = Object.freeze({\n  65→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n  66→  enableTelegram,\n  67→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n  68→  codebuddyBin: parsed.CODEBUDDY_BIN,\n  69→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n  70→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n  71→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n  72→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n  73→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n  74→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n  75→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n  76→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n  77→  webHost: parsed.WEB_HOST,\n  78→  webPort: parsed.WEB_PORT,\n  79→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n  80→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n  81→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n  82→  logLevel: parsed.LOG_LEVEL,\n  83→  pipelineInfra: Object.freeze({\n  84→    ...pipelineInfra,\n  85→    daemonLogPaths\n  86→  })\n  87→});\n  88→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:07.849Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
