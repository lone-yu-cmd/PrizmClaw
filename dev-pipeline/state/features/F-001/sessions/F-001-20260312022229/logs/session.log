{"type":"user","uuid":"db023a22-10a4-4464-9f46-a0bbecef3504","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29d77d287b4903fa8cc3a31408","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import os from 'node:os';\n   4→import path from 'node:path';\n   5→import fs from 'node:fs';\n   6→\n   7→import { loadPipelineInfraConfig } from '../../src/pipeline-infra/config-loader.js';\n   8→\n   9→function createTempProjectRoot() {\n  10→  const root = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-infra-'));\n  11→  fs.mkdirSync(path.join(root, 'dev-pipeline'), { recursive: true });\n  12→  return root;\n  13→}\n  14→\n  15→test('loadPipelineInfraConfig should load defaults from cwd', () => {\n  16→  const projectRoot = createTempProjectRoot();\n  17→  const config = loadPipelineInfraConfig({ env: {}, cwd: projectRoot, argv: [] });\n  18→\n  19→  assert.equal(config.projectRoot, projectRoot);\n  20→  assert.equal(config.pipelineDir, path.join(projectRoot, 'dev-pipeline'));\n  21→  assert.equal(config.featureListPath, path.join(projectRoot, 'feature-list.json'));\n  22→  assert.equal(config.bugFixListPath, path.join(projectRoot, 'bug-fix-list.json'));\n  23→  assert.equal(config.stateDir, path.join(projectRoot, 'dev-pipeline/state'));\n  24→  assert.equal(config.bugfixStateDir, path.join(projectRoot, 'dev-pipeline/bugfix-state'));\n  25→  assert.equal(config.maxRetries, 3);\n  26→  assert.equal(config.sessionTimeoutSec, 0);\n  27→  assert.equal(config.heartbeatIntervalSec, 30);\n  28→  assert.equal(config.aiCli, 'cbc');\n  29→  assert.equal(config.platform, 'codebuddy');\n  30→});\n  31→\n  32→test('loadPipelineInfraConfig should parse env and argv overrides', () => {\n  33→  const projectRoot = createTempProjectRoot();\n  34→  const config = loadPipelineInfraConfig({\n  35→    cwd: '/should-not-be-used',\n  36→    argv: ['--project-root', projectRoot, '--heartbeat-interval', '15'],\n  37→    env: {\n  38→      FEATURE_LIST_PATH: '/tmp/custom-feature-list.json',\n  39→      BUG_FIX_LIST_PATH: '/tmp/custom-bug-list.json',\n  40→      MAX_RETRIES: '7',\n  41→      SESSION_TIMEOUT: '120',\n  42→      AI_CLI: 'claude'\n  43→    }\n  44→  });\n  45→\n  46→  assert.equal(config.projectRoot, projectRoot);\n  47→  assert.equal(config.featureListPath, '/tmp/custom-feature-list.json');\n  48→  assert.equal(config.bugFixListPath, '/tmp/custom-bug-list.json');\n  49→  assert.equal(config.maxRetries, 7);\n  50→  assert.equal(config.sessionTimeoutSec, 120);\n  51→  assert.equal(config.heartbeatIntervalSec, 15);\n  52→  assert.equal(config.aiCli, 'claude');\n  53→  assert.equal(config.platform, 'claude');\n  54→});\n  55→\n  56→test('loadPipelineInfraConfig should throw readable errors for invalid values', () => {\n  57→  const projectRoot = createTempProjectRoot();\n  58→\n  59→  assert.throws(\n  60→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: { MAX_RETRIES: '0' } }),\n  61→    (error) => {\n  62→      assert.match(error.message, /MAX_RETRIES/);\n  63→      assert.match(error.message, /hint/i);\n  64→      assert.equal(error.code, 'CONFIG_INVALID');\n  65→      return true;\n  66→    }\n  67→  );\n  68→\n  69→  assert.throws(\n  70→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: { PRIZMKIT_PLATFORM: 'invalid' } }),\n  71→    (error) => {\n  72→      assert.match(error.message, /PRIZMKIT_PLATFORM/);\n  73→      assert.equal(error.code, 'CONFIG_INVALID');\n  74→      return true;\n  75→    }\n  76→  );\n  77→});\n  78→\n  79→test('loadPipelineInfraConfig should fail when dev-pipeline directory is missing', () => {\n  80→  const projectRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-no-pipeline-'));\n  81→\n  82→  assert.throws(\n  83→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: {}, argv: [] }),\n  84→    (error) => {\n  85→      assert.match(error.message, /dev-pipeline/);\n  86→      assert.equal(error.code, 'CONFIG_MISSING');\n  87→      return true;\n  88→    }\n  89→  );\n  90→});\n  91→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:13.092Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
{"type":"user","uuid":"2044609f-9e08-4c73-a72e-28fd19baed82","session_id":"7d08652e-4d6f-459a-a10d-c983fbe8d044","message":{"content":[{"type":"tool_result","tool_use_id":"019cde29d94cdfb705b070c6313fae33","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import path from 'node:path';\n   4→\n   5→import {\n   6→  computeFeatureSlug,\n   7→  resolveFeaturePaths,\n   8→  resolveBugPaths,\n   9→  resolveDaemonLogPaths\n  10→} from '../../src/pipeline-infra/path-policy.js';\n  11→\n  12→test('computeFeatureSlug should normalize id and title', () => {\n  13→  const slug = computeFeatureSlug('F-1', 'Project Infrastructure Setup!');\n  14→  assert.equal(slug, '001-project-infrastructure-setup');\n  15→});\n  16→\n  17→test('resolveFeaturePaths should return standardized feature paths', () => {\n  18→  const projectRoot = '/tmp/prizmclaw';\n  19→  const paths = resolveFeaturePaths({\n  20→    projectRoot,\n  21→    featureId: 'F-001',\n  22→    title: 'Project Infrastructure Setup',\n  23→    sessionId: 'F-001-20260310010101'\n  24→  });\n  25→\n  26→  assert.equal(paths.featureSlug, '001-project-infrastructure-setup');\n  27→  assert.equal(paths.specsDir, path.join(projectRoot, '.prizmkit/specs/001-project-infrastructure-setup'));\n  28→  assert.equal(\n  29→    paths.sessionDir,\n  30→    path.join(projectRoot, 'dev-pipeline/state/features/F-001/sessions/F-001-20260310010101')\n  31→  );\n  32→  assert.equal(paths.sessionLog, path.join(paths.sessionDir, 'logs/session.log'));\n  33→  assert.equal(paths.sessionStatus, path.join(paths.sessionDir, 'session-status.json'));\n  34→});\n  35→\n  36→test('resolveBugPaths should return standardized bug paths', () => {\n  37→  const projectRoot = '/tmp/prizmclaw';\n  38→  const paths = resolveBugPaths({\n  39→    projectRoot,\n  40→    bugId: 'B-011',\n  41→    sessionId: 'B-011-20260310010101'\n  42→  });\n  43→\n  44→  assert.equal(paths.bugDir, path.join(projectRoot, 'dev-pipeline/bugfix-state/bugs/B-011'));\n  45→  assert.equal(\n  46→    paths.sessionDir,\n  47→    path.join(projectRoot, 'dev-pipeline/bugfix-state/bugs/B-011/sessions/B-011-20260310010101')\n  48→  );\n  49→  assert.equal(paths.sessionLog, path.join(paths.sessionDir, 'logs/session.log'));\n  50→  assert.equal(paths.sessionStatus, path.join(paths.sessionDir, 'session-status.json'));\n  51→});\n  52→\n  53→test('resolveDaemonLogPaths should include explicit daemon log policy', () => {\n  54→  const paths = resolveDaemonLogPaths('/tmp/prizmclaw');\n  55→\n  56→  assert.equal(paths.featureDaemonLog, '/tmp/prizmclaw/dev-pipeline/state/pipeline-daemon.log');\n  57→  assert.equal(paths.bugfixDaemonLog, '/tmp/prizmclaw/dev-pipeline/bugfix-state/pipeline-daemon.log');\n  58→});\n  59→\n  60→test('path resolvers should reject unsafe path segments', () => {\n  61→  assert.throws(() => {\n  62→    resolveFeaturePaths({\n  63→      projectRoot: '/tmp/prizmclaw',\n  64→      featureId: '../F-001',\n  65→      title: 'X',\n  66→      sessionId: 'bad'\n  67→    });\n  68→  }, /invalid path segment/i);\n  69→\n  70→  assert.throws(() => {\n  71→    resolveBugPaths({\n  72→      projectRoot: '/tmp/prizmclaw',\n  73→      bugId: 'B-001',\n  74→      sessionId: '../../escape'\n  75→    });\n  76→  }, /invalid path segment/i);\n  77→});\n  78→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde2985465d8cea7a8ebbd95f4776","__timestamp":"2026-03-11T18:30:13.092Z","_requestId":"678379debffb49b699e7d6685b86f8c3"}
