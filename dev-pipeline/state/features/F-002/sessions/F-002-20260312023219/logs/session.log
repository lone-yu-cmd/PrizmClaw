            if (stage === 'running') {\n 520→              ctx.sendChatAction('typing').catch(() => undefined);\n 521→            }\n 522→          },\n 523→          onAssistantChunk: ({ text }) => {\n 524→            streamPublisher.push(text);\n 525→          }\n 526→        }\n 527→      });\n 528→\n 529→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 530→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 531→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 532→\n 533→      streamPublisher.setFinalText(finalText);\n 534→      const streamed = await streamPublisher.finish();\n 535→      if (streamed.outputLength === 0) {\n 536→        await replyLargeText(ctx, finalText);\n 537→      }\n 538→\n 539→      if (fileRefs.length > 0) {\n 540→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 541→        const failed = fileSendResults.filter((item) => !item.sent);\n 542→\n 543→        if (failed.length === 0) {\n 544→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 545→        } else {\n 546→          const failedList = failed\n 547→            .map((item) => {\n 548→              const reason =\n 549→                item.reason === 'relative_path_not_allowed'\n 550→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 551→                  : item.reason === 'not_found'\n 552→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 553→                    : item.reason;\n 554→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 555→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 556→            })\n 557→            .join('\\n');\n 558→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 559→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 560→        }\n 561→      }\n 562→    } catch (error) {\n 563→      const message = error instanceof Error ? error.message : String(error);\n 564→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 565→      await safeReply(ctx, `处理失败：${message}`);\n 566→    } finally {\n 567→      if (typingTimer) {\n 568→        clearInterval(typingTimer);\n 569→      }\n 570→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde33ed3f9bdc09c71e868513fe14","__timestamp":"2026-03-11T18:49:54.353Z","_requestId":"8512c899584843ddbcfa3594c4781204"}
