{"type":"user","uuid":"1b0afd5d-cf34-4cce-93ee-e57a84b9e135","session_id":"06446b54-c9c4-4e1f-adc2-3985ece3f255","message":{"content":[{"type":"tool_result","tool_use_id":"019cde44472a1909d75f2629f97492e3","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import { handlePipeline, pipelineMeta } from '../../../../src/bot/commands/handlers/pipeline.js';\n   4→import { handleBugfix, bugfixMeta } from '../../../../src/bot/commands/handlers/bugfix.js';\n   5→import { handleStatus, statusMeta } from '../../../../src/bot/commands/handlers/status.js';\n   6→import { handleLogs, logsMeta } from '../../../../src/bot/commands/handlers/logs.js';\n   7→import { handleStop, stopMeta } from '../../../../src/bot/commands/handlers/stop.js';\n   8→import { handlePlanner, plannerMeta } from '../../../../src/bot/commands/handlers/planner.js';\n   9→\n  10→// Mock pipeline-control-service\n  11→const createMockService = () => {\n  12→  const calls = [];\n  13→  return {\n  14→    calls,\n  15→    startPipeline: async (params) => {\n  16→      calls.push({ method: 'startPipeline', params });\n  17→      return { ok: true, exitCode: 0 };\n  18→    },\n  19→    getPipelineStatus: async (params) => {\n  20→      calls.push({ method: 'getPipelineStatus', params });\n  21→      return { ok: true, pipelines: [] };\n  22→    },\n  23→    stopPipeline: async (params) => {\n  24→      calls.push({ method: 'stopPipeline', params });\n  25→      return { ok: true };\n  26→    },\n  27→    getPipelineLogs: async (params) => {\n  28→      calls.push({ method: 'getPipelineLogs', params });\n  29→      return { ok: true, stdout: 'log content' };\n  30→    }\n  31→  };\n  32→};\n  33→\n  34→const createMockContext = () => {\n  35→  const replies = [];\n  36→  return {\n  37→    replies,\n  38→    ctx: {\n  39→      from: { id: 12345 },\n  40→      message: { text: '' },\n  41→      reply: async (text) => { replies.push(text); }\n  42→    },\n  43→    reply: async (text) => { replies.push(text); },\n  44→    replyFile: async (content, filename) => { replies.push(`[FILE: ${filename}]`); }\n  45→  };\n  46→};\n  47→\n  48→test('pipelineMeta has correct metadata', () => {\n  49→  assert.equal(pipelineMeta.name, 'pipeline');\n  50→  assert.deepEqual(pipelineMeta.aliases, ['p']);\n  51→  assert.ok(pipelineMeta.subcommands.length > 0);\n  52→});\n  53→\n  54→test('handlePipeline with run subcommand calls startPipeline', async () => {\n  55→  const mock = createMockService();\n  56→  const mockCtx = createMockContext();\n  57→\n  58→  await handlePipeline({\n  59→    ctx: mockCtx.ctx,\n  60→    parsed: { command: 'pipeline', subcommand: 'run', args: ['my-feature'], options: {} },\n  61→    params: { type: 'feature', _args: ['my-feature'] },\n  62→    reply: mockCtx.reply,\n  63→    replyFile: mockCtx.replyFile\n  64→  });\n  65→\n  66→  // Verify behavior through replies\n  67→  assert.ok(mockCtx.replies.length > 0);\n  68→});\n  69→\n  70→test('handlePipeline with status subcommand shows status', async () => {\n  71→  const mock = createMockService();\n  72→  const mockCtx = createMockContext();\n  73→\n  74→  await handlePipeline({\n  75→    ctx: mockCtx.ctx,\n  76→    parsed: { command: 'pipeline', subcommand: 'status', args: [], options: {} },\n  77→    params: {},\n  78→    reply: mockCtx.reply,\n  79→    replyFile: mockCtx.replyFile\n  80→  });\n  81→\n  82→  assert.ok(mockCtx.replies.length > 0);\n  83→});\n  84→\n  85→test('handleBugfix requires target parameter', async () => {\n  86→  const mockCtx = createMockContext();\n  87→\n  88→  await handleBugfix({\n  89→    ctx: mockCtx.ctx,\n  90→    parsed: { command: 'bugfix', args: [], options: {} },\n  91→    params: {},\n  92→    reply: mockCtx.reply,\n  93→    replyFile: mockCtx.replyFile\n  94→  });\n  95→\n  96→  assert.ok(mockCtx.replies[0].includes('缺少'));\n  97→});\n  98→\n  99→test('handleBugfix calls pipeline with type=bugfix', async () => {\n 100→  const mockCtx = createMockContext();\n 101→\n 102→  await handleBugfix({\n 103→    ctx: mockCtx.ctx,\n 104→    parsed: { command: 'bugfix', args: ['session-123'], options: {} },\n 105→    params: { _args: ['session-123'] },\n 106→    reply: mockCtx.reply,\n 107→    replyFile: mockCtx.replyFile\n 108→  });\n 109→\n 110→  assert.ok(mockCtx.replies.length > 0);\n 111→});\n 112→\n 113→test('bugfixMeta has correct metadata', () => {\n 114→  assert.equal(bugfixMeta.name, 'bugfix');\n 115→  assert.deepEqual(bugfixMeta.aliases, ['b']);\n 116→  assert.equal(bugfixMeta.params[0].required, true);\n 117→});\n 118→\n 119→test('handleStatus returns status message', async () => {\n 120→  const mockCtx = createMockContext();\n 121→\n 122→  await handleStatus({\n 123→    ctx: mockCtx.ctx,\n 124→    parsed: { command: 'status', args: [], options: {} },\n 125→    params: {},\n 126→    reply: mockCtx.reply\n 127→  });\n 128→\n 129→  assert.ok(mockCtx.replies.length > 0);\n 130→  assert.ok(mockCtx.replies[0].includes('管道'));\n 131→});\n 132→\n 133→test('statusMeta has correct metadata', () => {\n 134→  assert.equal(statusMeta.name, 'status');\n 135→  assert.deepEqual(statusMeta.aliases, ['s']);\n 136→});\n 137→\n 138→test('handleLogs returns logs', async () => {\n 139→  const mockCtx = createMockContext();\n 140→\n 141→  await handleLogs({\n 142→    ctx: mockCtx.ctx,\n 143→    parsed: { command: 'logs', args: [], options: {} },\n 144→    params: {},\n 145→    reply: mockCtx.reply,\n 146→    replyFile: mockCtx.replyFile\n 147→  });\n 148→\n 149→  assert.ok(mockCtx.replies.length > 0);\n 150→});\n 151→\n 152→test('logsMeta has correct metadata', () => {\n 153→  assert.equal(logsMeta.name, 'logs');\n 154→  assert.deepEqual(logsMeta.aliases, ['l']);\n 155→});\n 156→\n 157→test('handleStop returns confirmation', async () => {\n 158→  const mockCtx = createMockContext();\n 159→\n 160→  await handleStop({\n 161→    ctx: mockCtx.ctx,\n 162→    parsed: { command: 'stop', args: [], options: {} },\n 163→    params: {},\n 164→    reply: mockCtx.reply\n 165→  });\n 166→\n 167→  assert.ok(mockCtx.replies.length > 0);\n 168→});\n 169→\n 170→test('stopMeta has correct metadata', () => {\n 171→  assert.equal(stopMeta.name, 'stop');\n 172→});\n 173→\n 174→test('handlePlanner uses pipeline with type=planner', async () => {\n 175→  const mockCtx = createMockContext();\n 176→\n 177→  await handlePlanner({\n 178→    ctx: mockCtx.ctx,\n 179→    parsed: { command: 'planner', subcommand: 'status', args: [], options: {} },\n 180→    params: { type: 'planner' },\n 181→    reply: mockCtx.reply,\n 182→    replyFile: mockCtx.replyFile\n 183→  });\n 184→\n 185→  assert.ok(mockCtx.replies.length > 0);\n 186→});\n 187→\n 188→test('plannerMeta has correct metadata', () => {\n 189→  assert.equal(plannerMeta.name, 'planner');\n 190→  assert.deepEqual(plannerMeta.aliases, []);\n 191→});\n 192→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_2a5873e6e13843ea95e60863","__timestamp":"2026-03-11T18:59:04.174Z","_requestId":"f5856da8b3ac40a4846aae39444a8108"}
{"type":"user","uuid":"389f28cf-cd9d-470f-a6c4-e8f1c24ee63e","session_id":"06446b54-c9c4-4e1f-adc2-3985ece3f255","message":{"content":[{"type":"tool_result","tool_use_id":"019cde44492f4471f60e463d478a73ef","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import { routeCommand, registerCommand } from '../../src/bot/commands/index.js';\n   4→import { clearRegistry } from '../../src/bot/commands/registry.js';\n   5→import { pipelineMeta } from '../../src/bot/commands/handlers/pipeline.js';\n   6→import { statusMeta } from '../../src/bot/commands/handlers/status.js';\n   7→\n   8→test.beforeEach(() => {\n   9→  clearRegistry();\n  10→});\n  11→\n  12→const createMockContext = (text) => ({\n  13→  from: { id: 12345 },\n  14→  message: { text },\n  15→  reply: async (msg) => msg,\n  16→  replyWithDocument: async () => {}\n  17→});\n  18→\n  19→test('routeCommand returns false for non-command text', async () => {\n  20→  const ctx = createMockContext('hello world');\n  21→  const result = await routeCommand(ctx);\n  22→  assert.equal(result, false);\n  23→});\n  24→\n  25→test('routeCommand returns true for command text', async () => {\n  26→  // Register a test command\n  27→  registerCommand(statusMeta, async () => {});\n  28→\n  29→  const ctx = createMockContext('/status');\n  30→  const result = await routeCommand(ctx);\n  31→  assert.equal(result, true);\n  32→});\n  33→\n  34→test('routeCommand handles unknown command', async () => {\n  35→  const ctx = createMockContext('/unknown');\n  36→  const result = await routeCommand(ctx);\n  37→  assert.equal(result, true); // Command was handled (with error message)\n  38→});\n  39→\n  40→test('routeCommand handles command with subcommand', async () => {\n  41→  registerCommand(pipelineMeta, async () => {});\n  42→\n  43→  const ctx = createMockContext('/pipeline status');\n  44→  const result = await routeCommand(ctx);\n  45→  assert.equal(result, true);\n  46→});\n  47→\n  48→test('routeCommand applies alias mapping', async () => {\n  49→  registerCommand(pipelineMeta, async () => {});\n  50→\n  51→  const ctx = createMockContext('/p status');\n  52→  const result = await routeCommand(ctx);\n  53→  assert.equal(result, true);\n  54→});\n  55→\n  56→test('routeCommand validates parameters', async () => {\n  57→  registerCommand({\n  58→    name: 'test',\n  59→    params: [{ name: 'target', required: true, description: 'Target' }],\n  60→    requiresAuth: true,\n  61→    helpText: 'Test'\n  62→  }, async () => {});\n  63→\n  64→  const ctx = createMockContext('/test');\n  65→  const result = await routeCommand(ctx);\n  66→  assert.equal(result, true); // Handled with validation error\n  67→});\n  68→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_2a5873e6e13843ea95e60863","__timestamp":"2026-03-11T18:59:04.174Z","_requestId":"f5856da8b3ac40a4846aae39444a8108"}
{"type":"user","uuid":"8ac3ea1f-003a-48fd-aec2-1a5fbd1d7d11","session_id":"06446b54-c9c4-4e1f-adc2-3985ece3f255","message":{"content":[{"type":"tool_result","tool_use_id":"019cde444b1549865e14bb09a47e51a1","content":[{"type":"text","text":"   1→/**\n   2→ * F-002 Integration Tests: Telegram Pipeline Command Router\n   3→ * Comprehensive tests covering all 7 user stories from spec.md\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { routeCommand, registerCommand } from '../../src/bot/commands/index.js';\n   9→import { clearRegistry, getCommand } from '../../src/bot/commands/registry.js';\n  10→import { parseCommand } from '../../src/bot/commands/parser.js';\n  11→import { validateCommand } from '../../src/bot/commands/validator.js';\n  12→import { formatError, ErrorCodes } from '../../src/bot/commands/formatter.js';\n  13→import { generateHelp } from '../../src/bot/commands/help.js';\n  14→\n  15→// Import all handlers and metadata\n  16→import { pipelineMeta, handlePipeline } from '../../src/bot/commands/handlers/pipeline.js';\n  17→import { bugfixMeta, handleBugfix } from '../../src/bot/commands/handlers/bugfix.js';\n  18→import { plannerMeta, handlePlanner } from '../../src/bot/commands/handlers/planner.js';\n  19→import { statusMeta, handleStatus } from '../../src/bot/commands/handlers/status.js';\n  20→import { logsMeta, handleLogs } from '../../src/bot/commands/handlers/logs.js';\n  21→import { stopMeta, handleStop } from '../../src/bot/commands/handlers/stop.js';\n  22→\n  23→// Mock pipeline-control-service responses\n  24→const createMockPipelineService = () => {\n  25→  const calls = [];\n  26→  return {\n  27→    calls,\n  28→    reset: () => { calls.length = 0; },\n  29→    startPipeline: async (params) => {\n  30→      calls.push({ method: 'startPipeline', params });\n  31→      return { ok: true, exitCode: 0, pipelineId: 'test-pipeline-123' };\n  32→    },\n  33→    getPipelineStatus: async (params) => {\n  34→      calls.push({ method: 'getPipelineStatus', params });\n  35→      return {\n  36→        ok: true,\n  37→        pipelines: [\n  38→          { type: 'feature', target: 'my-feature', status: 'running', startTime: '2026-03-12T10:00:00Z' }\n  39→        ]\n  40→      };\n  41→    },\n  42→    stopPipeline: async (params) => {\n  43→      calls.push({ method: 'stopPipeline', params });\n  44→      return { ok: true, stoppedCount: 1 };\n  45→    },\n  46→    getPipelineLogs: async (params) => {\n  47→      calls.push({ method: 'getPipelineLogs', params });\n  48→      return { ok: true, stdout: 'Log line 1\\nLog line 2\\nLog line 3' };\n  49→    }\n  50→  };\n  51→};\n  52→\n  53→// Create mock Telegram context\n  54→const createMockCtx = (text, userId = 12345) => {\n  55→  const replies = [];\n  56→  const files = [];\n  57→  return {\n  58→    replies,\n  59→    files,\n  60→    from: { id: userId },\n  61→    message: { text },\n  62→    reply: async (msg) => {\n  63→      replies.push(msg);\n  64→      return msg;\n  65→    },\n  66→    replyWithDocument: async (opts) => {\n  67→      files.push(opts);\n  68→      return opts;\n  69→    }\n  70→  };\n  71→};\n  72→\n  73→// Register all commands for testing\n  74→function registerAllCommands() {\n  75→  clearRegistry();\n  76→  registerCommand(pipelineMeta, handlePipeline);\n  77→  registerCommand(bugfixMeta, handleBugfix);\n  78→  registerCommand(plannerMeta, handlePlanner);\n  79→  registerCommand(statusMeta, handleStatus);\n  80→  registerCommand(logsMeta, handleLogs);\n  81→  registerCommand(stopMeta, handleStop);\n  82→}\n  83→\n  84→// ============================================\n  85→// US-1: Pipeline Command\n  86→// ============================================\n  87→\n  88→test('US-1: /pipeline run starts a pipeline', async () => {\n  89→  registerAllCommands();\n  90→  const ctx = createMockCtx('/pipeline run my-feature');\n  91→  \n  92→  const handled = await routeCommand(ctx);\n  93→  \n  94→  assert.equal(handled, true, 'Command should be handled');\n  95→  assert.ok(ctx.replies.length > 0, 'Should have reply');\n  96→});\n  97→\n  98→test('US-1: /pipeline status shows pipeline status', async () => {\n  99→  registerAllCommands();\n 100→  const ctx = createMockCtx('/pipeline status');\n 101→  \n 102→  const handled = await routeCommand(ctx);\n 103→  \n 104→  assert.equal(handled, true);\n 105→  assert.ok(ctx.replies.length > 0);\n 106→});\n 107→\n 108→test('US-1: /pipeline logs shows logs', async () => {\n 109→  registerAllCommands();\n 110→  const ctx = createMockCtx('/pipeline logs my-feature');\n 111→  \n 112→  const handled = await routeCommand(ctx);\n 113→  \n 114→  assert.equal(handled, true);\n 115→  assert.ok(ctx.replies.length > 0);\n 116→});\n 117→\n 118→test('US-1: /pipeline stop stops pipeline', async () => {\n 119→  registerAllCommands();\n 120→  const ctx = createMockCtx('/pipeline stop my-feature');\n 121→  \n 122→  const handled = await routeCommand(ctx);\n 123→  \n 124→  assert.equal(handled, true);\n 125→  assert.ok(ctx.replies.length > 0);\n 126→});\n 127→\n 128→test('US-1: /pipeline with invalid subcommand shows help', async () => {\n 129→  registerAllCommands();\n 130→  const ctx = createMockCtx('/pipeline xyz');\n 131→  \n 132→  const handled = await routeCommand(ctx);\n 133→  \n 134→  assert.equal(handled, true);\n 135→  assert.ok(ctx.replies[0].includes('未知子命令') || ctx.replies[0].includes('可用'));\n 136→});\n 137→\n 138→test('US-1: /pipeline supports --type option', async () => {\n 139→  const aliasMap = { p: 'pipeline' };\n 140→  const parsed = parseCommand('/pipeline run my-feature --type=bugfix', aliasMap);\n 141→  \n 142→  assert.equal(parsed.command, 'pipeline');\n 143→  assert.equal(parsed.subcommand, 'run');\n 144→  assert.equal(parsed.options.type, 'bugfix');\n 145→});\n 146→\n 147→test('US-1: /pipeline target is optional (defaults to cwd)', async () => {\n 148→  registerAllCommands();\n 149→  const ctx = createMockCtx('/pipeline run');\n 150→  \n 151→  const handled = await routeCommand(ctx);\n 152→  \n 153→  assert.equal(handled, true);\n 154→  // Should not error - target is optional\n 155→});\n 156→\n 157→// ============================================\n 158→// US-2: Bugfix Command\n 159→// ============================================\n 160→\n 161→test('US-2: /bugfix starts bugfix pipeline', async () => {\n 162→  registerAllCommands();\n 163→  const ctx = createMockCtx('/bugfix session-123');\n 164→  \n 165→  const handled = await routeCommand(ctx);\n 166→  \n 167→  assert.equal(handled, true);\n 168→  assert.ok(ctx.replies.length > 0);\n 169→});\n 170→\n 171→test('US-2: /bugfix without target shows usage', async () => {\n 172→  registerAllCommands();\n 173→  const ctx = createMockCtx('/bugfix');\n 174→  \n 175→  const handled = await routeCommand(ctx);\n 176→  \n 177→  assert.equal(handled, true);\n 178→  assert.ok(ctx.replies[0].includes('缺少') || ctx.replies[0].includes('用法'));\n 179→});\n 180→\n 181→test('US-2: /bugfix is equivalent to /pipeline run --type=bugfix', async () => {\n 182→  // Verify bugfixMeta defines correct parameters\n 183→  assert.equal(bugfixMeta.name, 'bugfix');\n 184→  assert.equal(bugfixMeta.params[0].name, 'target');\n 185→  assert.equal(bugfixMeta.params[0].required, true);\n 186→  \n 187→  // Verify handler delegates correctly by checking metadata\n 188→  const bugfixEntry = getCommand('bugfix');\n 189→  assert.ok(bugfixEntry, 'bugfix command should be registered');\n 190→});\n 191→\n 192→test('US-2: /b alias works for /bugfix', async () => {\n 193→  const aliasMap = { b: 'bugfix' };\n 194→  const parsed = parseCommand('/b session-123', aliasMap);\n 195→  \n 196→  assert.equal(parsed.command, 'bugfix');\n 197→});\n 198→\n 199→// ============================================\n 200→// US-3: Status Query\n 201→// ============================================\n 202→\n 203→test('US-3: /status shows running pipelines', async () => {\n 204→  registerAllCommands();\n 205→  const ctx = createMockCtx('/status');\n 206→  \n 207→  const handled = await routeCommand(ctx);\n 208→  \n 209→  assert.equal(handled, true);\n 210→  assert.ok(ctx.replies.length > 0);\n 211→  // Response should mention pipelines\n 212→  assert.ok(\n 213→    ctx.replies[0].includes('管道') || \n 214→    ctx.replies[0].includes('pipeline') ||\n 215→    ctx.replies[0].includes('运行中')\n 216→  );\n 217→});\n 218→\n 219→test('US-3: /status when no pipelines shows appropriate message', async () => {\n 220→  // This is tested through the handler's formatStatusOutput function\n 221→  // which shows \"当前没有运行中的管道\" when pipelines array is empty\n 222→  registerAllCommands();\n 223→  \n 224→  const statusMeta = {\n 225→    name: 'status',\n 226→    aliases: ['s'],\n 227→    description: '查看管道状态',\n 228→    params: [],\n 229→    requiresAuth: true,\n 230→    helpText: '/status - 查看所有运行中的管道'\n 231→  };\n 232→  \n 233→  // Verify statusMeta is correct\n 234→  assert.equal(statusMeta.name, 'status');\n 235→  assert.deepEqual(statusMeta.aliases, ['s']);\n 236→});\n 237→\n 238→test('US-3: /s alias works for /status', async () => {\n 239→  const aliasMap = { s: 'status' };\n 240→  const parsed = parseCommand('/s', aliasMap);\n 241→  \n 242→  assert.equal(parsed.command, 'status');\n 243→});\n 244→\n 245→// ============================================\n 246→// US-4: Logs Query\n 247→// ============================================\n 248→\n 249→test('US-4: /logs shows pipeline logs', async () => {\n 250→  registerAllCommands();\n 251→  const ctx = createMockCtx('/logs');\n 252→  \n 253→  const handled = await routeCommand(ctx);\n 254→  \n 255→  assert.equal(handled, true);\n 256→  assert.ok(ctx.replies.length > 0);\n 257→});\n 258→\n 259→test('US-4: /logs with target shows specific logs', async () => {\n 260→  registerAllCommands();\n 261→  const ctx = createMockCtx('/logs my-feature');\n 262→  \n 263→  const handled = await routeCommand(ctx);\n 264→  \n 265→  assert.equal(handled, true);\n 266→  assert.ok(ctx.replies.length > 0);\n 267→});\n 268→\n 269→test('US-4: Long logs (>= 4000 chars) sent as file', async () => {\n 270→  // Verify the threshold is set correctly in logsMeta\n 271→  assert.equal(logsMeta.name, 'logs');\n 272→  \n 273→  // The implementation in logs.js uses FILE_THRESHOLD = 4000\n 274→  // and sends logs >= 4000 chars as a file\n 275→  // This is verified by checking the handler code structure\n 276→  const logsEntry = getCommand('logs');\n 277→  assert.ok(logsEntry, 'logs command should be registered');\n 278→});\n 279→\n 280→test('US-4: /l alias works for /logs', async () => {\n 281→  const aliasMap = { l: 'logs' };\n 282→  const parsed = parseCommand('/l my-feature', aliasMap);\n 283→  \n 284→  assert.equal(parsed.command, 'logs');\n 285→});\n 286→\n 287→// ============================================\n 288→// US-5: Stop Pipeline\n 289→// ============================================\n 290→\n 291→test('US-5: /stop stops pipeline', async () => {\n 292→  registerAllCommands();\n 293→  const ctx = createMockCtx('/stop');\n 294→  \n 295→  const handled = await routeCommand(ctx);\n 296→  \n 297→  assert.equal(handled, true);\n 298→  assert.ok(ctx.replies.length > 0);\n 299→});\n 300→\n 301→test('US-5: /stop with target stops specific pipeline', async () => {\n 302→  registerAllCommands();\n 303→  const ctx = createMockCtx('/stop my-feature');\n 304→  \n 305→  const handled = await routeCommand(ctx);\n 306→  \n 307→  assert.equal(handled, true);\n 308→  assert.ok(ctx.replies.length > 0);\n 309→});\n 310→\n 311→test('US-5: /stop returns confirmation message', async () => {\n 312→  registerAllCommands();\n 313→  const ctx = createMockCtx('/stop my-feature');\n 314→  \n 315→  await routeCommand(ctx);\n 316→  \n 317→  // Response should include confirmation\n 318→  assert.ok(\n 319→    ctx.replies.some(r => r.includes('停止') || r.includes('stopped')),\n 320→    'Should include stop confirmation'\n 321→  );\n 322→});\n 323→\n 324→// ============================================\n 325→// US-6: Error Guidance\n 326→// ============================================\n 327→\n 328→test('US-6: Unknown command shows helpful error', async () => {\n 329→  registerAllCommands();\n 330→  const ctx = createMockCtx('/xyz');\n 331→  \n 332→  const handled = await routeCommand(ctx);\n 333→  \n 334→  assert.equal(handled, true);\n 335→  assert.ok(ctx.replies[0].includes('未知命令'));\n 336→  assert.ok(ctx.replies[0].includes('/help'));\n 337→});\n 338→\n 339→test('US-6: Unknown subcommand shows available options', async () => {\n 340→  registerAllCommands();\n 341→  const ctx = createMockCtx('/pipeline xyz');\n 342→  \n 343→  const handled = await routeCommand(ctx);\n 344→  \n 345→  assert.equal(handled, true);\n 346→  // Should show available subcommands\n 347→  assert.ok(\n 348→    ctx.replies[0].includes('run') || \n 349→    ctx.replies[0].includes('status') ||\n 350→    ctx.replies[0].includes('logs') ||\n 351→    ctx.replies[0].includes('stop')\n 352→  );\n 353→});\n 354→\n 355→test('US-6: Missing required parameter shows usage', async () => {\n 356→  registerAllCommands();\n 357→  const ctx = createMockCtx('/bugfix');\n 358→  \n 359→  const handled = await routeCommand(ctx);\n 360→  \n 361→  assert.equal(handled, true);\n 362→  assert.ok(ctx.replies[0].includes('缺少') || ctx.replies[0].includes('用法'));\n 363→});\n 364→\n 365→test('US-6: Invalid enum value shows valid options', () => {\n 366→  const parsed = { command: 'pipeline', subcommand: 'run', args: [], options: { type: 'invalid' } };\n 367→  const meta = {\n 368→    name: 'pipeline',\n 369→    subcommands: [{ name: 'run', description: 'Run' }],\n 370→    params: [{ name: 'type', type: 'enum', enum: ['feature', 'bugfix', 'planner'], description: 'Type' }],\n 371→    requiresAuth: true\n 372→  };\n 373→  \n 374→  const result = validateCommand(parsed, meta);\n 375→  \n 376→  assert.equal(result.valid, false);\n 377→  assert.ok(result.errors[0].suggestion.includes('feature'));\n 378→  assert.ok(result.errors[0].suggestion.includes('bugfix'));\n 379→  assert.ok(result.errors[0].suggestion.includes('planner'));\n 380→});\n 381→\n 382→test('US-6: Error messages include suggestion', () => {\n 383→  const error = formatError(ErrorCodes.UNKNOWN_SUBCOMMAND, {\n 384→    subcommand: 'xyz',\n 385→    available: ['run', 'status', 'logs', 'stop']\n 386→  });\n 387→  \n 388→  assert.ok(error.message.includes('未知子命令'));\n 389→  assert.ok(error.suggestion.includes('run'));\n 390→  assert.ok(error.suggestion.includes('status'));\n 391→});\n 392→\n 393→// ============================================\n 394→// US-7: Authorization Guard\n 395→// ============================================\n 396→\n 397→test('US-7: Unauthorized user receives rejection message', async () => {\n 398→  registerAllCommands();\n 399→  // Use a user ID that's not in allowed list (assuming 99999 is not allowed)\n 400→  const ctx = createMockCtx('/status', 99999);\n 401→  \n 402→  const handled = await routeCommand(ctx);\n 403→  \n 404→  assert.equal(handled, true);\n 405→  // Should show unauthorized message\n 406→  assert.ok(ctx.replies[0].includes('未被授权'));\n 407→});\n 408→\n 409→test('US-7: All pipeline commands require authorization', () => {\n 410→  // Verify all command metadata has requiresAuth: true\n 411→  assert.equal(pipelineMeta.requiresAuth, true, 'pipeline should require auth');\n 412→  assert.equal(bugfixMeta.requiresAuth, true, 'bugfix should require auth');\n 413→  assert.equal(plannerMeta.requiresAuth, true, 'planner should require auth');\n 414→  assert.equal(statusMeta.requiresAuth, true, 'status should require auth');\n 415→  assert.equal(logsMeta.requiresAuth, true, 'logs should require auth');\n 416→  assert.equal(stopMeta.requiresAuth, true, 'stop should require auth');\n 417→});\n 418→\n 419→test('US-7: Unauthorized message does not expose sensitive info', () => {\n 420→  const error = formatError(ErrorCodes.UNAUTHORIZED, {});\n 421→  \n 422→  // Should not include user IDs, tokens, or internal details\n 423→  assert.ok(!error.message.includes('12345'));\n 424→  assert.ok(!error.message.includes('token'));\n 425→  assert.ok(!error.message.includes('internal'));\n 426→  assert.ok(error.message.includes('授权'));\n 427→});\n 428→\n 429→// ============================================\n 430→// NFR Tests: Extensibility\n 431→// ============================================\n 432→\n 433→test('NFR-1: Can register new commands dynamically', () => {\n 434→  clearRegistry();\n 435→  \n 436→  const customMeta = {\n 437→    name: 'custom',\n 438→    description: 'Custom command',\n 439→    params: [],\n 440→    requiresAuth: true,\n 441→    helpText: 'Custom help'\n 442→  };\n 443→  \n 444→  registerCommand(customMeta, async () => {});\n 445→  \n 446→  const entry = getCommand('custom');\n 447→  assert.ok(entry);\n 448→  assert.equal(entry.meta.name, 'custom');\n 449→});\n 450→\n 451→test('NFR-1: Parser supports extensibility through aliasMap', () => {\n 452→  const aliasMap = { c: 'custom', x: 'xyz' };\n 453→  \n 454→  const parsed1 = parseCommand('/c run', aliasMap);\n 455→  assert.equal(parsed1.command, 'custom');\n 456→  \n 457→  const parsed2 = parseCommand('/x status', aliasMap);\n 458→  assert.equal(parsed2.command, 'xyz');\n 459→});\n 460→\n 461→// ============================================\n 462→// NFR Tests: Testability\n 463→// ============================================\n 464→\n 465→test('NFR-2: Handler interface can be mocked', async () => {\n 466→  const mockHandler = async (handlerCtx) => {\n 467→    await handlerCtx.reply('Mocked response');\n 468→  };\n 469→  \n 470→  const mockMeta = {\n 471→    name: 'mock',\n 472→    description: 'Mock command',\n 473→    params: [],\n 474→    requiresAuth: true,\n 475→    helpText: 'Mock'\n 476→  };\n 477→  \n 478→  clearRegistry();\n 479→  registerCommand(mockMeta, mockHandler);\n 480→  \n 481→  const ctx = createMockCtx('/mock');\n 482→  await routeCommand(ctx);\n 483→  \n 484→  assert.ok(ctx.replies.includes('Mocked response'));\n 485→});\n 486→\n 487→test('NFR-2: Authorization check can be mocked', () => {\n 488→  // The isAuthorized function in index.js calls isAllowedUser from guard.js\n 489→  // This can be mocked by modifying the guard module or using dependency injection\n 490→  // For now, we verify the interface exists\n 491→  assert.ok(typeof routeCommand === 'function');\n 492→});\n 493→\n 494→// ============================================\n 495→// NFR Tests: Performance\n 496→// ============================================\n 497→\n 498→test('NFR-3: Command parsing is fast (< 50ms)', () => {\n 499→  const start = performance.now();\n 500→  \n 501→  for (let i = 0; i < 1000; i++) {\n 502→    parseCommand('/pipeline run my-feature --type=bugfix --verbose', { p: 'pipeline' });\n 503→  }\n 504→  \n 505→  const elapsed = performance.now() - start;\n 506→  const avgTime = elapsed / 1000;\n 507→  \n 508→  assert.ok(avgTime < 50, `Average parse time should be < 50ms, got ${avgTime.toFixed(3)}ms`);\n 509→});\n 510→\n 511→test('NFR-3: Router does not block on long operations', async () => {\n 512→  // The router uses async handlers, so it doesn't block\n 513→  // This test verifies the async nature\n 514→  registerAllCommands();\n 515→  const ctx = createMockCtx('/status');\n 516→  \n 517→  const start = performance.now();\n 518→  const handled = await routeCommand(ctx);\n 519→  const elapsed = performance.now() - start;\n 520→  \n 521→  assert.equal(handled, true);\n 522→  // Should return quickly (the actual work is delegated to handlers)\n 523→  assert.ok(elapsed < 5000, 'Router should return within reasonable time');\n 524→});\n 525→\n 526→// ============================================\n 527→// Alias Mapping Tests (from spec.md)\n 528→// ============================================\n 529→\n 530→test('Alias /p maps to /pipeline', () => {\n 531→  const aliasMap = { p: 'pipeline' };\n 532→  const parsed = parseCommand('/p run', aliasMap);\n 533→  assert.equal(parsed.command, 'pipeline');\n 534→});\n 535→\n 536→test('Alias /b maps to /bugfix', () => {\n 537→  const aliasMap = { b: 'bugfix' };\n 538→  const parsed = parseCommand('/b session-123', aliasMap);\n 539→  assert.equal(parsed.command, 'bugfix');\n 540→});\n 541→\n 542→test('Alias /s maps to /status', () => {\n 543→  const aliasMap = { s: 'status' };\n 544→  const parsed = parseCommand('/s', aliasMap);\n 545→  assert.equal(parsed.command, 'status');\n 546→});\n 547→\n 548→test('Alias /l maps to /logs', () => {\n 549→  const aliasMap = { l: 'logs' };\n 550→  const parsed = parseCommand('/l my-feature', aliasMap);\n 551→  assert.equal(parsed.command, 'logs');\n 552→});\n 553→\n 554→// ============================================\n 555→// Decision D1, D2, D3 Tests\n 556→// ============================================\n 557→\n 558→test('D1: /planner is independent pipeline type with type=planner', () => {\n 559→  assert.equal(plannerMeta.name, 'planner');\n 560→  assert.deepEqual(plannerMeta.aliases, []);\n 561→  assert.ok(plannerMeta.subcommands.some(s => s.name === 'run'));\n 562→  assert.ok(plannerMeta.subcommands.some(s => s.name === 'status'));\n 563→  assert.ok(plannerMeta.subcommands.some(s => s.name === 'logs'));\n 564→});\n 565→\n 566→test('D2: Authorization uses existing isAllowedUser()', async () => {\n 567→  // The router calls isAuthorized() which calls isAllowedUser()\n 568→  // This is verified by checking the import in index.js\n 569→  // and the behavior in US-7 tests\n 570→  registerAllCommands();\n 571→  const ctx = createMockCtx('/status', 99999);\n 572→  \n 573→  await routeCommand(ctx);\n 574→  \n 575→  // If isAllowedUser was called, unauthorized user should be rejected\n 576→  assert.ok(ctx.replies[0].includes('未被授权'));\n 577→});\n 578→\n 579→test('D3: Logs threshold is 4000 characters', () => {\n 580→  // This is implemented in logs.js with FILE_THRESHOLD = 4000\n 581→  // and sendLogsInChunks with CHUNK_SIZE = 3800\n 582→  // The spec says: \"日志 < 4000 字符分块发送，>= 4000 字符发送为文件\"\n 583→  assert.ok(true, 'D3 implementation verified in logs.js');\n 584→});\n 585→\n 586→// ============================================\n 587→// Help System Tests\n 588→// ============================================\n 589→\n 590→test('Help shows all registered commands', () => {\n 591→  registerAllCommands();\n 592→  \n 593→  const help = generateHelp();\n 594→  \n 595→  assert.ok(help.includes('可用命令'));\n 596→  assert.ok(help.includes('/pipeline'));\n 597→  assert.ok(help.includes('/bugfix'));\n 598→  assert.ok(help.includes('/status'));\n 599→  assert.ok(help.includes('/logs'));\n 600→  assert.ok(help.includes('/stop'));\n 601→});\n 602→\n 603→test('Help for specific command shows details', () => {\n 604→  registerAllCommands();\n 605→  \n 606→  const help = generateHelp('pipeline');\n 607→  \n 608→  assert.ok(help.includes('/pipeline'));\n 609→  assert.ok(help.includes('run'));\n 610→  assert.ok(help.includes('status'));\n 611→  assert.ok(help.includes('logs'));\n 612→  assert.ok(help.includes('stop'));\n 613→});\n 614→\n 615→test('Help shows aliases', () => {\n 616→  registerAllCommands();\n 617→  \n 618→  const help = generateHelp('pipeline');\n 619→  \n 620→  assert.ok(help.includes('/p'));\n 621→});\n 622→\n 623→// ============================================\n 624→// Edge Cases\n 625→// ============================================\n 626→\n 627→test('Handles @bot suffix in command', () => {\n 628→  const parsed = parseCommand('/pipeline@mybot run');\n 629→  \n 630→  assert.equal(parsed.command, 'pipeline');\n 631→  assert.equal(parsed.subcommand, 'run');\n 632→});\n 633→\n 634→test('Handles case-insensitive commands', () => {\n 635→  const parsed = parseCommand('/PIPELINE RUN');\n 636→  \n 637→  assert.equal(parsed.command, 'pipeline');\n 638→  assert.equal(parsed.subcommand, 'run');\n 639→});\n 640→\n 641→test('Handles multiple spaces between tokens', 