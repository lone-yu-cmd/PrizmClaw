{"type":"user","uuid":"cdff5d41-79c9-4a22-bbba-3e8b9d20654a","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_8bac193970274931a0d58ca6","content":[{"type":"text","text":"Command: cd /Users/loneyu/SelfProjects/PrizmClaw && npm test 2>&1 | tail -50\nStdout: \n> prizmclaw@0.1.0 test\n> node --test tests/**/*.test.js\n\n(node:80035) Warning: node:test run() is being called recursively within a test file. skipping running files.\n(Use `node --trace-warnings ...` to show where the warning was created)\n\nStderr: (empty)\nExit Code: 0\nSignal: (none)"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:17:39.401Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
{"type":"user","uuid":"82aecdf0-7385-4de1-bbaa-b4644823343c","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_06fd1766a19049088622fa68","content":[{"type":"text","text":"   1→/**\n   2→ * Error Formatter\n   3→ * Formats error messages for user-friendly display.\n   4→ */\n   5→\n   6→/**\n   7→ * Error codes for command errors.\n   8→ */\n   9→export const ErrorCodes = {\n  10→  UNKNOWN_COMMAND: 'UNKNOWN_COMMAND',\n  11→  UNKNOWN_SUBCOMMAND: 'UNKNOWN_SUBCOMMAND',\n  12→  MISSING_PARAM: 'MISSING_PARAM',\n  13→  INVALID_PARAM: 'INVALID_PARAM',\n  14→  UNAUTHORIZED: 'UNAUTHORIZED',\n  15→  INTERNAL_ERROR: 'INTERNAL_ERROR'\n  16→};\n  17→\n  18→/**\n  19→ * @typedef {Object} ErrorResponse\n  20→ * @property {string} code - Error code\n  21→ * @property {string} message - User-friendly error message\n  22→ * @property {string} [suggestion] - Correction suggestion\n  23→ * @property {string} [usage] - Correct usage example\n  24→ */\n  25→\n  26→/**\n  27→ * Format an error for display to the user.\n  28→ * @param {string} code - Error code\n  29→ * @param {Object} context - Error context\n  30→ * @param {string} [context.command] - Command name\n  31→ * @param {string} [context.subcommand] - Subcommand name\n  32→ * @param {string} [context.param] - Parameter name\n  33→ * @param {string} [context.value] - Invalid value\n  34→ * @param {string} [context.reason] - Error reason\n  35→ * @param {string} [context.suggestion] - Custom suggestion\n  36→ * @param {string} [context.usage] - Correct usage\n  37→ * @param {string[]} [context.available] - Available options\n  38→ * @returns {ErrorResponse} Formatted error\n  39→ */\n  40→export function formatError(code, context = {}) {\n  41→  switch (code) {\n  42→    case ErrorCodes.UNKNOWN_COMMAND:\n  43→      return {\n  44→        code,\n  45→        message: `未知命令 '${context.command || ''}'。`,\n  46→        suggestion: '输入 /help 查看可用命令。'\n  47→      };\n  48→\n  49→    case ErrorCodes.UNKNOWN_SUBCOMMAND:\n  50→      return {\n  51→        code,\n  52→        message: `未知子命令 '${context.subcommand || ''}'。`,\n  53→        suggestion: context.available ? `可用: ${context.available.join(', ')}` : undefined,\n  54→        usage: context.usage\n  55→      };\n  56→\n  57→    case ErrorCodes.MISSING_PARAM:\n  58→      return {\n  59→        code,\n  60→        message: `缺少参数 '${context.param || ''}'。`,\n  61→        suggestion: context.suggestion || `请提供 ${context.param} 参数`,\n  62→        usage: context.usage\n  63→      };\n  64→\n  65→    case ErrorCodes.INVALID_PARAM:\n  66→      return {\n  67→        code,\n  68→        message: `参数 '${context.param || ''}' 无效: ${context.reason || ''}`,\n  69→        suggestion: context.suggestion,\n  70→        usage: context.usage\n  71→      };\n  72→\n  73→    case ErrorCodes.UNAUTHORIZED:\n  74→      return {\n  75→        code,\n  76→        message: '当前账号未被授权使用该命令。',\n  77→        suggestion: '请联系管理员获取授权。'\n  78→      };\n  79→\n  80→    case ErrorCodes.INTERNAL_ERROR:\n  81→      return {\n  82→        code,\n  83→        message: '内部错误，请稍后重试。',\n  84→        suggestion: context.reason ? `错误: ${context.reason}` : undefined\n  85→      };\n  86→\n  87→    default:\n  88→      return {\n  89→        code: ErrorCodes.INTERNAL_ERROR,\n  90→        message: '未知错误。'\n  91→      };\n  92→  }\n  93→}\n  94→\n  95→/**\n  96→ * Format validation errors into a single message.\n  97→ * @param {import('./validator.js').ValidationError[]} errors - Validation errors\n  98→ * @param {string} [usage] - Usage hint\n  99→ * @returns {string} Formatted error message\n 100→ */\n 101→export function formatValidationErrors(errors, usage) {\n 102→  if (!errors || errors.length === 0) {\n 103→    return '';\n 104→  }\n 105→\n 106→  const lines = [];\n 107→\n 108→  for (const error of errors) {\n 109→    lines.push(`❌ ${error.message}`);\n 110→    if (error.suggestion) {\n 111→      lines.push(`   建议: ${error.suggestion}`);\n 112→    }\n 113→  }\n 114→\n 115→  if (usage) {\n 116→    lines.push(`\\n用法: ${usage}`);\n 117→  }\n 118→\n 119→  return lines.join('\\n');\n 120→}\n 121→\n 122→/**\n 123→ * Format an error response into a display string.\n 124→ * @param {ErrorResponse} error - Error response\n 125→ * @returns {string} Formatted string\n 126→ */\n 127→export function formatErrorResponse(error) {\n 128→  const lines = [`❌ ${error.message}`];\n 129→\n 130→  if (error.suggestion) {\n 131→    lines.push(`💡 ${error.suggestion}`);\n 132→  }\n 133→\n 134→  if (error.usage) {\n 135→    lines.push(`用法: ${error.usage}`);\n 136→  }\n 137→\n 138→  return lines.join('\\n');\n 139→}\n 140→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:17:39.406Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
{"type":"user","uuid":"5a9e1174-3a02-443c-8de2-b973447a0972","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_dbc5b8ad28354936be1e1036","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} helpText - Help text for the command\n  34→ */\n  35→\n  36→/**\n  37→ * @typedef {Object} CommandEntry\n  38→ * @property {CommandMeta} meta - Command metadata\n  39→ * @property {Function} handler - Command handler function\n  40→ */\n  41→\n  42→/**\n  43→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  44→ */\n  45→\n  46→// Internal registry storage\n  47→const commands = new Map();\n  48→const aliasToCommand = new Map();\n  49→\n  50→/**\n  51→ * Register a command with its metadata and handler.\n  52→ * @param {CommandMeta} meta - Command metadata\n  53→ * @param {Function} handler - Command handler function\n  54→ * @throws {Error} If command already registered\n  55→ */\n  56→export function registerCommand(meta, handler) {\n  57→  if (!meta || !meta.name) {\n  58→    throw new Error('Command meta must have a name');\n  59→  }\n  60→\n  61→  // Normalize meta with lowercase name\n  62→  const normalizedMeta = {\n  63→    ...meta,\n  64→    name: meta.name.toLowerCase()\n  65→  };\n  66→  const name = normalizedMeta.name;\n  67→\n  68→  if (commands.has(name)) {\n  69→    throw new Error(`Command \"${name}\" is already registered`);\n  70→  }\n  71→\n  72→  // Register command\n  73→  commands.set(name, { meta: normalizedMeta, handler });\n  74→\n  75→  // Register aliases\n  76→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  77→    for (const alias of meta.aliases) {\n  78→      const aliasLower = alias.toLowerCase();\n  79→      if (aliasToCommand.has(aliasLower)) {\n  80→        throw new Error(`Alias \"${alias}\" is already registered`);\n  81→      }\n  82→      aliasToCommand.set(aliasLower, name);\n  83→    }\n  84→  }\n  85→}\n  86→\n  87→/**\n  88→ * Get a command entry by name or alias.\n  89→ * @param {string} name - Command name or alias\n  90→ * @returns {CommandEntry | null} Command entry or null\n  91→ */\n  92→export function getCommand(name) {\n  93→  if (!name || typeof name !== 'string') {\n  94→    return null;\n  95→  }\n  96→\n  97→  const nameLower = name.toLowerCase();\n  98→\n  99→  // Try direct lookup\n 100→  if (commands.has(nameLower)) {\n 101→    return commands.get(nameLower);\n 102→  }\n 103→\n 104→  // Try alias lookup\n 105→  const resolvedName = aliasToCommand.get(nameLower);\n 106→  if (resolvedName && commands.has(resolvedName)) {\n 107→    return commands.get(resolvedName);\n 108→  }\n 109→\n 110→  return null;\n 111→}\n 112→\n 113→/**\n 114→ * Check if a name is a registered alias.\n 115→ * @param {string} name - Name to check\n 116→ * @returns {boolean} True if name is an alias\n 117→ */\n 118→export function isAlias(name) {\n 119→  if (!name || typeof name !== 'string') {\n 120→    return false;\n 121→  }\n 122→  return aliasToCommand.has(name.toLowerCase());\n 123→}\n 124→\n 125→/**\n 126→ * Get all registered commands.\n 127→ * @returns {CommandEntry[]} All command entries\n 128→ */\n 129→export function getAllCommands() {\n 130→  return Array.from(commands.values());\n 131→}\n 132→\n 133→/**\n 134→ * Generate help text for a specific command or all commands.\n 135→ * @param {string} [commandName] - Optional command name for specific help\n 136→ * @returns {string} Help text\n 137→ */\n 138→export function getHelpText(commandName) {\n 139→  if (commandName) {\n 140→    const entry = getCommand(commandName);\n 141→    if (!entry) {\n 142→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 143→    }\n 144→    return formatCommandHelp(entry.meta);\n 145→  }\n 146→\n 147→  // Generate general help\n 148→  const commandList = getAllCommands()\n 149→    .map((entry) => {\n 150→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 151→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 152→    })\n 153→    .sort();\n 154→\n 155→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 156→}\n 157→\n 158→/**\n 159→ * Format detailed help for a single command.\n 160→ * @param {CommandMeta} meta - Command metadata\n 161→ * @returns {string} Formatted help text\n 162→ */\n 163→function formatCommandHelp(meta) {\n 164→  const lines = [`/${meta.name} - ${meta.description}`];\n 165→\n 166→  if (meta.aliases?.length) {\n 167→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 168→  }\n 169→\n 170→  if (meta.usage) {\n 171→    lines.push(`用法: ${meta.usage}`);\n 172→  }\n 173→\n 174→  if (meta.subcommands?.length) {\n 175→    lines.push('\\n子命令:');\n 176→    for (const sub of meta.subcommands) {\n 177→      lines.push(`  ${sub.name} - ${sub.description}`);\n 178→    }\n 179→  }\n 180→\n 181→  if (meta.params?.length) {\n 182→    lines.push('\\n参数:');\n 183→    for (const param of meta.params) {\n 184→      const required = param.required ? '(必填)' : '(可选)';\n 185→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 186→    }\n 187→  }\n 188→\n 189→  if (meta.examples?.length) {\n 190→    lines.push('\\n示例:');\n 191→    for (const example of meta.examples) {\n 192→      lines.push(`  ${example}`);\n 193→    }\n 194→  }\n 195→\n 196→  return lines.join('\\n');\n 197→}\n 198→\n 199→/**\n 200→ * Clear the registry (for testing).\n 201→ */\n 202→export function clearRegistry() {\n 203→  commands.clear();\n 204→  aliasToCommand.clear();\n 205→}\n 206→\n 207→/**\n 208→ * Get the alias map for parser usage.\n 209→ * @returns {Record<string, string>} Alias to command name mapping\n 210→ */\n 211→export function getAliasMap() {\n 212→  const map = {};\n 213→  for (const [alias, command] of aliasToCommand) {\n 214→    map[alias] = command;\n 215→  }\n 216→  return map;\n 217→}\n 218→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:17:39.416Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
