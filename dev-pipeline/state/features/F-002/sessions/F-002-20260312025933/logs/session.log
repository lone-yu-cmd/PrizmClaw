{"type":"user","uuid":"d9266566-8e4a-4cf5-8695-7989b45185f2","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_bd95468908494e55a878d81f","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ */\n   5→\n   6→import {\n   7→  startPipeline,\n   8→  getPipelineStatus,\n   9→  stopPipeline,\n  10→  getPipelineLogs\n  11→} from '../../../services/pipeline-control-service.js';\n  12→import { formatValidationErrors, formatError, ErrorCodes } from '../formatter.js';\n  13→\n  14→/**\n  15→ * Pipeline command metadata.\n  16→ */\n  17→export const pipelineMeta = {\n  18→  name: 'pipeline',\n  19→  aliases: ['p'],\n  20→  description: '管理管道任务',\n  21→  usage: '/pipeline <action> [target] [--type=<type>]',\n  22→  examples: [\n  23→    '/pipeline run my-feature',\n  24→    '/pipeline run my-feature --type=bugfix',\n  25→    '/pipeline status',\n  26→    '/pipeline logs my-feature',\n  27→    '/pipeline stop my-feature'\n  28→  ],\n  29→  subcommands: [\n  30→    { name: 'run', description: '启动管道' },\n  31→    { name: 'status', description: '查询状态' },\n  32→    { name: 'logs', description: '查看日志' },\n  33→    { name: 'stop', description: '停止管道' }\n  34→  ],\n  35→  params: [\n  36→    {\n  37→      name: 'target',\n  38→      type: 'string',\n  39→      required: false,\n  40→      description: '目标标识符'\n  41→    },\n  42→    {\n  43→      name: 'type',\n  44→      type: 'enum',\n  45→      enum: ['feature', 'bugfix', 'planner'],\n  46→      required: false,\n  47→      default: 'feature',\n  48→      description: '管道类型'\n  49→    }\n  50→  ],\n  51→  requiresAuth: true,\n  52→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  53→};\n  54→\n  55→/**\n  56→ * Handle pipeline command.\n  57→ * @param {Object} handlerCtx - Handler context\n  58→ * @param {Object} handlerCtx.ctx - Telegraf context\n  59→ * @param {Object} handlerCtx.parsed - Parsed command\n  60→ * @param {Object} handlerCtx.params - Normalized parameters\n  61→ * @param {Function} handlerCtx.reply - Reply function\n  62→ */\n  63→export async function handlePipeline(handlerCtx) {\n  64→  const { ctx, parsed, params, reply } = handlerCtx;\n  65→\n  66→  // Determine action from subcommand or default to status\n  67→  const action = parsed.subcommand || 'status';\n  68→\n  69→  switch (action) {\n  70→    case 'run':\n  71→      return handleRun(handlerCtx);\n  72→    case 'status':\n  73→      return handleStatus(handlerCtx);\n  74→    case 'logs':\n  75→      return handleLogs(handlerCtx);\n  76→    case 'stop':\n  77→      return handleStop(handlerCtx);\n  78→    default:\n  79→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop`);\n  80→  }\n  81→}\n  82→\n  83→/**\n  84→ * Handle run subcommand.\n  85→ */\n  86→async function handleRun({ params, reply, parsed }) {\n  87→  const target = params._args?.[0] || params.target;\n  88→  const pipelineType = params.type || 'feature';\n  89→\n  90→  try {\n  91→    const result = await startPipeline({\n  92→      pipelineType,\n  93→      targetId: target\n  94→    });\n  95→\n  96→    if (result.ok) {\n  97→      await reply(`✅ 已启动 ${pipelineType} 管道${target ? `: ${target}` : ''}`);\n  98→    } else {\n  99→      await reply(`❌ 启动失败: ${result.stderr || result.error || '未知错误'}`);\n 100→    }\n 101→  } catch (error) {\n 102→    await reply(`❌ 启动失败: ${error.message}`);\n 103→  }\n 104→}\n 105→\n 106→/**\n 107→ * Handle status subcommand.\n 108→ */\n 109→async function handleStatus({ params, reply }) {\n 110→  try {\n 111→    const result = await getPipelineStatus({});\n 112→\n 113→    if (result.ok) {\n 114→      const status = formatStatusOutput(result);\n 115→      await reply(status);\n 116→    } else {\n 117→      await reply(`❌ 查询失败: ${result.stderr || result.error || '未知错误'}`);\n 118→    }\n 119→  } catch (error) {\n 120→    await reply(`❌ 查询失败: ${error.message}`);\n 121→  }\n 122→}\n 123→\n 124→/**\n 125→ * Handle logs subcommand.\n 126→ */\n 127→async function handleLogs({ params, reply, replyFile, parsed }) {\n 128→  const target = params._args?.[0] || params.target;\n 129→\n 130→  try {\n 131→    const result = await getPipelineLogs({ targetId: target });\n 132→\n 133→    if (result.ok) {\n 134→      const logs = result.stdout || result.logs || '';\n 135→\n 136→      if (logs.length >= 4000) {\n 137→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n 138→      } else {\n 139→        await reply(logs || '暂无日志');\n 140→      }\n 141→    } else {\n 142→      await reply(`❌ 获取日志失败: ${result.stderr || result.error || '未知错误'}`);\n 143→    }\n 144→  } catch (error) {\n 145→    await reply(`❌ 获取日志失败: ${error.message}`);\n 146→  }\n 147→}\n 148→\n 149→/**\n 150→ * Handle stop subcommand.\n 151→ */\n 152→async function handleStop({ params, reply, parsed }) {\n 153→  const target = params._args?.[0] || params.target;\n 154→\n 155→  try {\n 156→    const result = await stopPipeline({ targetId: target });\n 157→\n 158→    if (result.ok) {\n 159→      await reply(`✅ 已停止管道${target ? `: ${target}` : ''}`);\n 160→    } else {\n 161→      await reply(`❌ 停止失败: ${result.stderr || result.error || '未知错误'}`);\n 162→    }\n 163→  } catch (error) {\n 164→    await reply(`❌ 停止失败: ${error.message}`);\n 165→  }\n 166→}\n 167→\n 168→/**\n 169→ * Format status output.\n 170→ * @param {Object} result - Status result\n 171→ * @returns {string} Formatted status\n 172→ */\n 173→function formatStatusOutput(result) {\n 174→  if (!result.pipelines || result.pipelines.length === 0) {\n 175→    return '当前没有运行中的管道。';\n 176→  }\n 177→\n 178→  const lines = ['运行中的管道：', ''];\n 179→\n 180→  for (const p of result.pipelines) {\n 181→    lines.push(`• ${p.type || 'pipeline'}: ${p.target || 'unknown'}`);\n 182→    lines.push(`  状态: ${p.status || 'running'}`);\n 183→    if (p.startTime) {\n 184→      lines.push(`  开始: ${p.startTime}`);\n 185→    }\n 186→    lines.push('');\n 187→  }\n 188→\n 189→  return lines.join('\\n');\n 190→}\n 191→\n 192→export default handlePipeline;\n 193→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:17:32.512Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
