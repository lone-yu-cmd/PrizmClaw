{"type":"user","uuid":"e336efaa-313e-49c0-a593-06781e85501a","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_c84076792f064835bf4a783a","content":[{"type":"text","text":"   1→/**\n   2→ * Command Parser\n   3→ * Parses Telegram message text into structured ParsedCommand object.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParsedCommand\n   8→ * @property {string} command - The command name (e.g., \"pipeline\")\n   9→ * @property {string} [subcommand] - Optional subcommand (e.g., \"run\")\n  10→ * @property {string[]} args - Positional arguments\n  11→ * @property {Record<string, string>} options - Key-value options (--key=value)\n  12→ * @property {string} raw - Original message text\n  13→ */\n  14→\n  15→/**\n  16→ * Parse Telegram message text into a structured command object.\n  17→ * @param {string} text - The message text to parse\n  18→ * @param {Object} [aliasMap={}] - Map of aliases to command names\n  19→ * @returns {ParsedCommand | null} Parsed command or null if not a command\n  20→ */\n  21→export function parseCommand(text, aliasMap = {}) {\n  22→  if (!text || typeof text !== 'string') {\n  23→    return null;\n  24→  }\n  25→\n  26→  const trimmed = text.trim();\n  27→\n  28→  // Must start with /\n  29→  if (!trimmed.startsWith('/')) {\n  30→    return null;\n  31→  }\n  32→\n  33→  // Extract command (first token after /)\n  34→  const tokens = trimmed.slice(1).split(/\\s+/);\n  35→  if (tokens.length === 0 || !tokens[0]) {\n  36→    return null;\n  37→  }\n  38→\n  39→  let command = tokens[0].toLowerCase();\n  40→  const rest = tokens.slice(1);\n  41→\n  42→  // Handle @bot suffix (e.g., /command@mybot)\n  43→  const atIndex = command.indexOf('@');\n  44→  if (atIndex !== -1) {\n  45→    command = command.slice(0, atIndex);\n  46→  }\n  47→\n  48→  // Apply alias mapping\n  49→  if (aliasMap[command]) {\n  50→    command = aliasMap[command];\n  51→  }\n  52→\n  53→  const args = [];\n  54→  const options = {};\n  55→  let subcommand = undefined;\n  56→\n  57→  for (const token of rest) {\n  58→    // Parse --key=value options\n  59→    if (token.startsWith('--')) {\n  60→      const optionText = token.slice(2);\n  61→      const eqIndex = optionText.indexOf('=');\n  62→      if (eqIndex !== -1) {\n  63→        const key = optionText.slice(0, eqIndex).toLowerCase();\n  64→        const value = optionText.slice(eqIndex + 1);\n  65→        options[key] = value;\n  66→      } else {\n  67→        // Boolean flag --flag\n  68→        options[optionText.toLowerCase()] = 'true';\n  69→      }\n  70→    } else if (token.includes('=')) {\n  71→      // Parse key=value (without --)\n  72→      const eqIndex = token.indexOf('=');\n  73→      const key = token.slice(0, eqIndex).toLowerCase();\n  74→      const value = token.slice(eqIndex + 1);\n  75→      options[key] = value;\n  76→    } else if (subcommand === undefined && !token.startsWith('-') && args.length === 0) {\n  77→      // First non-option token is subcommand if it looks like one\n  78→      // This will be validated by the registry\n  79→      subcommand = token.toLowerCase();\n  80→    } else {\n  81→      // Positional argument\n  82→      args.push(token);\n  83→    }\n  84→  }\n  85→\n  86→  return {\n  87→    command,\n  88→    subcommand,\n  89→    args,\n  90→    options,\n  91→    raw: text\n  92→  };\n  93→}\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:16:16.149Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
{"type":"user","uuid":"6b25d4d1-06f6-494c-b3c7-4fea76f92bed","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_39a9e291a4124bd894ff155b","content":[{"type":"text","text":"   1→/**\n   2→ * Bugfix Command Handler\n   3→ * Handles /bugfix shortcut command.\n   4→ */\n   5→\n   6→import { handlePipeline, pipelineMeta } from './pipeline.js';\n   7→\n   8→/**\n   9→ * Bugfix command metadata.\n  10→ */\n  11→export const bugfixMeta = {\n  12→  name: 'bugfix',\n  13→  aliases: ['b'],\n  14→  description: '启动 bugfix 管道',\n  15→  usage: '/bugfix <target>',\n  16→  examples: ['/bugfix session-123', '/bugfix F-001-login-bug'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: true,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/bugfix <target> - 快捷启动 bugfix 管道'\n  27→};\n  28→\n  29→/**\n  30→ * Handle bugfix command.\n  31→ * Delegates to pipeline handler with type=bugfix.\n  32→ * @param {Object} handlerCtx - Handler context\n  33→ */\n  34→export async function handleBugfix(handlerCtx) {\n  35→  const { parsed, params } = handlerCtx;\n  36→\n  37→  // Get target from positional args or params\n  38→  const target = params._args?.[0] || params.target;\n  39→\n  40→  if (!target) {\n  41→    await handlerCtx.reply('❌ 缺少参数 \\'target\\'。\\n用法: /bugfix <target>');\n  42→    return;\n  43→  }\n  44→\n  45→  // Delegate to pipeline handler with type=bugfix\n  46→  const modifiedCtx = {\n  47→    ...handlerCtx,\n  48→    parsed: {\n  49→      ...parsed,\n  50→      subcommand: 'run'\n  51→    },\n  52→    params: {\n  53→      ...params,\n  54→      type: 'bugfix',\n  55→      target\n  56→    }\n  57→  };\n  58→\n  59→  return handlePipeline(modifiedCtx);\n  60→}\n  61→\n  62→export default handleBugfix;\n  63→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:16:16.149Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
{"type":"user","uuid":"0d514d2e-a08c-4c1a-b9ea-82cf5416270d","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_0e5df1c9225e453f8ca443dd","content":[{"type":"text","text":"   1→/**\n   2→ * Logs Command Handler\n   3→ * Handles /logs command to retrieve pipeline logs.\n   4→ */\n   5→\n   6→import { getPipelineLogs } from '../../../services/pipeline-control-service.js';\n   7→\n   8→/**\n   9→ * Logs command metadata.\n  10→ */\n  11→export const logsMeta = {\n  12→  name: 'logs',\n  13→  aliases: ['l'],\n  14→  description: '查看管道日志',\n  15→  usage: '/logs [target]',\n  16→  examples: ['/logs', '/logs my-feature'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: false,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/logs [target] - 查看管道日志'\n  27→};\n  28→\n  29→/** Character threshold for sending logs as file */\n  30→const FILE_THRESHOLD = 4000;\n  31→\n  32→/**\n  33→ * Handle logs command.\n  34→ * @param {Object} handlerCtx - Handler context\n  35→ */\n  36→export async function handleLogs(handlerCtx) {\n  37→  const { params, reply, replyFile, parsed } = handlerCtx;\n  38→\n  39→  // Get target from positional args or params\n  40→  const target = params._args?.[0] || params.target;\n  41→\n  42→  try {\n  43→    const result = await getPipelineLogs({ targetId: target });\n  44→\n  45→    if (result.ok) {\n  46→      const logs = result.stdout || result.logs || '';\n  47→\n  48→      if (!logs.trim()) {\n  49→        await reply('📭 暂无日志。');\n  50→        return;\n  51→      }\n  52→\n  53→      // Send as file if too long\n  54→      if (logs.length >= FILE_THRESHOLD) {\n  55→        const filename = `pipeline-logs-${target || 'latest'}.txt`;\n  56→        await replyFile(logs, filename);\n  57→        await reply(`📄 日志已发送为文件 (${logs.length} 字符)`);\n  58→      } else {\n  59→        // Send in chunks if moderately long\n  60→        await sendLogsInChunks(reply, logs);\n  61→      }\n  62→    } else {\n  63→      await reply(`❌ 获取日志失败: ${result.stderr || result.error || '未知错误'}`);\n  64→    }\n  65→  } catch (error) {\n  66→    await reply(`❌ 获取日志失败: ${error.message}`);\n  67→  }\n  68→}\n  69→\n  70→/**\n  71→ * Send logs in chunks to avoid Telegram message limits.\n  72→ * @param {Function} reply - Reply function\n  73→ * @param {string} logs - Log content\n  74→ */\n  75→async function sendLogsInChunks(reply, logs) {\n  76→  const CHUNK_SIZE = 3800;\n  77→\n  78→  if (logs.length <= CHUNK_SIZE) {\n  79→    await reply(`📋 日志:\\n\\`\\`\\`\\n${logs}\\n\\`\\`\\``);\n  80→    return;\n  81→  }\n  82→\n  83→  // Split into chunks\n  84→  const chunks = [];\n  85→  for (let i = 0; i < logs.length; i += CHUNK_SIZE) {\n  86→    chunks.push(logs.slice(i, i + CHUNK_SIZE));\n  87→  }\n  88→\n  89→  await reply(`📋 日志 (${logs.length} 字符, 分 ${chunks.length} 段):`);\n  90→\n  91→  for (let i = 0; i < chunks.length; i++) {\n  92→    await reply(`\\`\\`\\`\\n${chunks[i]}\\n\\`\\`\\``);\n  93→  }\n  94→}\n  95→\n  96→export default handleLogs;\n  97→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:16:16.149Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
{"type":"user","uuid":"bbe15d52-e678-41d2-b141-49667a7dd8b4","session_id":"c7a56f37-52f8-4378-9a28-e0cf90afeea0","message":{"content":[{"type":"tool_result","tool_use_id":"call_339db0be804648bab3355b8f","content":[{"type":"text","text":"   1→/**\n   2→ * Stop Command Handler\n   3→ * Handles /stop command to stop running pipelines.\n   4→ */\n   5→\n   6→import { stopPipeline } from '../../../services/pipeline-control-service.js';\n   7→\n   8→/**\n   9→ * Stop command metadata.\n  10→ */\n  11→export const stopMeta = {\n  12→  name: 'stop',\n  13→  aliases: [],\n  14→  description: '停止运行中的管道',\n  15→  usage: '/stop [target]',\n  16→  examples: ['/stop', '/stop my-feature'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: false,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/stop [target] - 停止运行中的管道'\n  27→};\n  28→\n  29→/**\n  30→ * Handle stop command.\n  31→ * @param {Object} handlerCtx - Handler context\n  32→ */\n  33→export async function handleStop(handlerCtx) {\n  34→  const { params, reply, parsed } = handlerCtx;\n  35→\n  36→  // Get target from positional args or params\n  37→  const target = params._args?.[0] || params.target;\n  38→\n  39→  try {\n  40→    const result = await stopPipeline({ targetId: target });\n  41→\n  42→    if (result.ok) {\n  43→      if (target) {\n  44→        await reply(`✅ 已停止管道: ${target}`);\n  45→      } else {\n  46→        await reply('✅ 已停止当前管道。');\n  47→      }\n  48→\n  49→      // Show additional info if available\n  50→      if (result.stoppedCount !== undefined) {\n  51→        await reply(`共停止 ${result.stoppedCount} 个管道。`);\n  52→      }\n  53→    } else {\n  54→      // Check if it's a \"not found\" type error\n  55→      const error = result.stderr || result.error || '';\n  56→      if (error.includes('not found') || error.includes('没有') || error.includes('no pipeline')) {\n  57→        await reply('⚠️ 没有找到运行中的管道。');\n  58→      } else {\n  59→        await reply(`❌ 停止失败: ${error || '未知错误'}`);\n  60→      }\n  61→    }\n  62→  } catch (error) {\n  63→    await reply(`❌ 停止失败: ${error.message}`);\n  64→  }\n  65→}\n  66→\n  67→export default handleStop;\n  68→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde534b4a280ed48c1d7bb99ac931","__timestamp":"2026-03-11T19:16:16.150Z","_requestId":"33c1fe9f6f094d499ac61721329a98f3"}
