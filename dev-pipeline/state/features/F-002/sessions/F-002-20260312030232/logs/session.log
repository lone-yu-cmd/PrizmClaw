{"type":"user","uuid":"4cd33db1-54e7-455e-aa00-e8aa0cb77803","session_id":"1d2d8267-2c0d-47e7-bff0-9a3d28a3cbdc","message":{"content":[{"type":"tool_result","tool_use_id":"019cde4843048d462d952ea88e12d823","content":[{"type":"text","text":"   1→import { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2→\n   3→function buildRequest(params = {}, action) {\n   4→  return {\n   5→    pipelineType: params.pipelineType ?? 'feature',\n   6→    action,\n   7→    ...(params.targetId ? { targetId: params.targetId } : {}),\n   8→    ...(params.listPath ? { listPath: params.listPath } : {}),\n   9→    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  10→    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  11→  };\n  12→}\n  13→\n  14→export function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  15→  return {\n  16→    runner,\n  17→    async startPipeline(params) {\n  18→      return runner(buildRequest(params, 'run'));\n  19→    },\n  20→    async getPipelineStatus(params) {\n  21→      return runner(buildRequest(params, 'status'));\n  22→    },\n  23→    async stopPipeline(params) {\n  24→      return runner(buildRequest(params, 'stop'));\n  25→    },\n  26→    async retryTarget(params) {\n  27→      return runner(buildRequest(params, 'retry'));\n  28→    },\n  29→    async getPipelineLogs(params) {\n  30→      return runner(buildRequest(params, 'logs'));\n  31→    },\n  32→    async resetTarget(params) {\n  33→      return runner(buildRequest(params, 'reset'));\n  34→    }\n  35→  };\n  36→}\n  37→\n  38→const defaultService = createPipelineControlService();\n  39→\n  40→export async function startPipeline(params) {\n  41→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  42→  return service.startPipeline(params);\n  43→}\n  44→\n  45→export async function getPipelineStatus(params) {\n  46→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  47→  return service.getPipelineStatus(params);\n  48→}\n  49→\n  50→export async function stopPipeline(params) {\n  51→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  52→  return service.stopPipeline(params);\n  53→}\n  54→\n  55→export async function retryTarget(params) {\n  56→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  57→  return service.retryTarget(params);\n  58→}\n  59→\n  60→export async function getPipelineLogs(params) {\n  61→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  62→  return service.getPipelineLogs(params);\n  63→}\n  64→\n  65→export async function resetTarget(params) {\n  66→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  67→  return service.resetTarget(params);\n  68→}\n  69→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde47c4c2a40781ac14ef9fd27fd0","__timestamp":"2026-03-11T19:03:24.927Z","_requestId":"64ee86a8c26142b1a672413fdc3c1eb2"}
