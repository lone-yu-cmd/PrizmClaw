{"type":"user","uuid":"d3b24bbb-e499-47e7-b636-e1d9a28a0821","session_id":"7bf91201-6528-470c-bfa4-e2217c84d56d","message":{"content":[{"type":"tool_result","tool_use_id":"019cde4b1eb31582af025364b5172cac","content":[{"type":"text","text":"   1вҶ’import { Telegraf } from 'telegraf';\n   2вҶ’import { createReadStream } from 'node:fs';\n   3вҶ’import { access, stat } from 'node:fs/promises';\n   4вҶ’import os from 'node:os';\n   5вҶ’import path from 'node:path';\n   6вҶ’import { config } from '../config.js';\n   7вҶ’import { logger } from '../utils/logger.js';\n   8вҶ’import { isAllowedUser } from '../security/guard.js';\n   9вҶ’import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10вҶ’import { captureScreenshot } from '../services/screenshot-service.js';\n  11вҶ’import { executeSystemCommand } from '../services/system-exec-service.js';\n  12вҶ’import { registerCommand } from './commands/index.js';\n  13вҶ’import { routeCommand } from './commands/index.js';\n  14вҶ’import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  15вҶ’import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  16вҶ’import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  17вҶ’import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  18вҶ’import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  19вҶ’import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  20вҶ’import { generateHelp } from './commands/help.js';\n  21вҶ’\n  22вҶ’const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  23вҶ’const STREAM_MIN_CHARS = 220;\n  24вҶ’const STREAM_FLUSH_INTERVAL_MS = 1200;\n  25вҶ’const TYPING_INTERVAL_MS = 3500;\n  26вҶ’const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  27вҶ’const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  28вҶ’const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  29вҶ’const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  30вҶ’const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  31вҶ’const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  32вҶ’const TMP_DIR = path.resolve(os.tmpdir());\n  33вҶ’const HOME_DIR = path.resolve(os.homedir());\n  34вҶ’const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  35вҶ’const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  36вҶ’const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  37вҶ’const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  38вҶ’\n  39вҶ’function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  40вҶ’  const normalized = configuredDirs\n  41вҶ’    .map((dir) => String(dir ?? '').trim())\n  42вҶ’    .filter(Boolean)\n  43вҶ’    .map((dir) => path.resolve(dir));\n  44вҶ’\n  45вҶ’  if (normalized.length > 0) {\n  46вҶ’    return [...new Set(normalized)];\n  47вҶ’  }\n  48вҶ’\n  49вҶ’  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  50вҶ’}\n  51вҶ’\n  52вҶ’const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  53вҶ’const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  54вҶ’\n  55вҶ’function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  56вҶ’  const chunks = [];\n  57вҶ’  for (let i = 0; i < text.length; i += chunkSize) {\n  58вҶ’    chunks.push(text.slice(i, i + chunkSize));\n  59вҶ’  }\n  60вҶ’  return chunks;\n  61вҶ’}\n  62вҶ’\n  63вҶ’function sanitizeMarkerPath(raw) {\n  64вҶ’  return String(raw ?? '')\n  65вҶ’    .trim()\n  66вҶ’    .replace(/^['\"`]+/, '')\n  67вҶ’    .replace(/['\"`]+$/, '');\n  68вҶ’}\n  69вҶ’\n  70вҶ’function extractFileMarkers(text = '') {\n  71вҶ’  const fileRefs = [];\n  72вҶ’\n  73вҶ’  const withSendFileRemoved = text.replace(\n  74вҶ’    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  75вҶ’    (_full, rawRef) => {\n  76вҶ’      const ref = sanitizeMarkerPath(rawRef);\n  77вҶ’      if (ref) {\n  78вҶ’        fileRefs.push(ref);\n  79вҶ’      }\n  80вҶ’      return '\\n';\n  81вҶ’    }\n  82вҶ’  );\n  83вҶ’\n  84вҶ’  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  85вҶ’    const ref = sanitizeMarkerPath(rawRef);\n  86вҶ’    if (ref) {\n  87вҶ’      fileRefs.push(ref);\n  88вҶ’    }\n  89вҶ’    return '';\n  90вҶ’  });\n  91вҶ’\n  92вҶ’  const withBacktickPathRemoved = withImageRemoved.replace(\n  93вҶ’    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n  94вҶ’    (_full, rawRef) => {\n  95вҶ’      const ref = sanitizeMarkerPath(rawRef);\n  96вҶ’      if (ref) {\n  97вҶ’        fileRefs.push(ref);\n  98вҶ’      }\n  99вҶ’      return '';\n 100вҶ’    }\n 101вҶ’  );\n 102вҶ’\n 103вҶ’  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 104вҶ’    /(?:ж–Үд»¶и·Ҝеҫ„|path)\\s*[:пјҡ]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 105вҶ’    (_full, rawRef) => {\n 106вҶ’      const ref = sanitizeMarkerPath(rawRef);\n 107вҶ’      if (ref) {\n 108вҶ’        fileRefs.push(ref);\n 109вҶ’      }\n 110вҶ’      return '';\n 111вҶ’    }\n 112вҶ’  );\n 113вҶ’\n 114вҶ’  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 115вҶ’    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 116вҶ’    (_full, rawRef) => {\n 117вҶ’      const ref = sanitizeMarkerPath(rawRef);\n 118вҶ’      if (ref) {\n 119вҶ’        fileRefs.push(ref);\n 120вҶ’      }\n 121вҶ’      return '\\n';\n 122вҶ’    }\n 123вҶ’  );\n 124вҶ’\n 125вҶ’  return {\n 126вҶ’    fileRefs: [...new Set(fileRefs)],\n 127вҶ’    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 128вҶ’  };\n 129вҶ’}\n 130вҶ’\n 131вҶ’function isPathWithinRoot(targetPath, rootPath) {\n 132вҶ’  const relative = path.relative(rootPath, targetPath);\n 133вҶ’  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 134вҶ’}\n 135вҶ’\n 136вҶ’function isAllowedFilePath(filePath) {\n 137вҶ’  const resolved = path.resolve(filePath);\n 138вҶ’  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 139вҶ’}\n 140вҶ’\n 141вҶ’function buildFileCandidates(normalizedPath) {\n 142вҶ’  if (path.isAbsolute(normalizedPath)) {\n 143вҶ’    return [normalizedPath];\n 144вҶ’  }\n 145вҶ’\n 146вҶ’  const baseName = path.basename(normalizedPath);\n 147вҶ’  const candidates = [\n 148вҶ’    path.resolve(process.cwd(), normalizedPath),\n 149вҶ’    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 150вҶ’  ];\n 151вҶ’\n 152вҶ’  return [...new Set(candidates)];\n 153вҶ’}\n 154вҶ’\n 155вҶ’async function resolveLocalFilePath(fileRef) {\n 156вҶ’  const normalized = sanitizeMarkerPath(fileRef);\n 157вҶ’  if (!normalized) {\n 158вҶ’    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 159вҶ’  }\n 160вҶ’\n 161вҶ’  if (!path.isAbsolute(normalized)) {\n 162вҶ’    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 163вҶ’  }\n 164вҶ’\n 165вҶ’  const candidates = buildFileCandidates(normalized);\n 166вҶ’\n 167вҶ’  for (const candidate of candidates) {\n 168вҶ’    try {\n 169вҶ’      await access(candidate);\n 170вҶ’      return { filePath: candidate, triedPaths: candidates };\n 171вҶ’    } catch {\n 172вҶ’      // ignore\n 173вҶ’    }\n 174вҶ’  }\n 175вҶ’\n 176вҶ’  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 177вҶ’}\n 178вҶ’\n 179вҶ’async function validateFileForTelegram(filePath) {\n 180вҶ’  const resolvedPath = path.resolve(filePath);\n 181вҶ’  if (!isAllowedFilePath(resolvedPath)) {\n 182вҶ’    return { ok: false, reason: `и·Ҝеҫ„дёҚеңЁе…Ғи®ёиҢғеӣҙпјҡ${resolvedPath}` };\n 183вҶ’  }\n 184вҶ’\n 185вҶ’  const ext = path.extname(resolvedPath).toLowerCase();\n 186вҶ’  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 187вҶ’    return { ok: false, reason: `дёҚж”ҜжҢҒзҡ„ж–Үд»¶зұ»еһӢпјҡ${ext || '(unknown)'}` };\n 188вҶ’  }\n 189вҶ’\n 190вҶ’  const fileStat = await stat(resolvedPath);\n 191вҶ’  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 192вҶ’  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 193вҶ’\n 194вҶ’  if (fileStat.size > maxSize) {\n 195вҶ’    return {\n 196вҶ’      ok: false,\n 197вҶ’      reason: `ж–Үд»¶иҝҮеӨ§пјҡ${Math.ceil(fileStat.size / 1024 / 1024)}MBпјҢйҷҗеҲ¶ ${Math.floor(maxSize / 1024 / 1024)}MB`\n 198вҶ’    };\n 199вҶ’  }\n 200вҶ’\n 201вҶ’  return { ok: true, isPhoto, resolvedPath };\n 202вҶ’}\n 203вҶ’\n 204вҶ’function isTimeoutLikeError(message = '') {\n 205вҶ’  const normalized = String(message).toLowerCase();\n 206вҶ’  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 207вҶ’}\n 208вҶ’\n 209вҶ’function sleep(ms) {\n 210вҶ’  return new Promise((resolve) => setTimeout(resolve, ms));\n 211вҶ’}\n 212вҶ’\n 213вҶ’async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 214вҶ’  if (isPhoto) {\n 215вҶ’    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 216вҶ’    return;\n 217вҶ’  }\n 218вҶ’\n 219вҶ’  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 220вҶ’}\n 221вҶ’\n 222вҶ’async function replyFiles(ctx, fileRefs = []) {\n 223вҶ’  const results = [];\n 224вҶ’\n 225вҶ’  for (const fileRef of fileRefs) {\n 226вҶ’    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 227вҶ’    if (!filePath) {\n 228вҶ’      const reason = rejectReason || 'not_found';\n 229вҶ’      results.push({ fileRef, sent: false, reason, triedPaths });\n 230вҶ’      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 231вҶ’      continue;\n 232вҶ’    }\n 233вҶ’\n 234вҶ’    try {\n 235вҶ’      const validation = await validateFileForTelegram(filePath);\n 236вҶ’      if (!validation.ok) {\n 237вҶ’        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 238вҶ’        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 239вҶ’        continue;\n 240вҶ’      }\n 241вҶ’\n 242вҶ’      const actualPath = validation.resolvedPath;\n 243вҶ’      let sent = false;\n 244вҶ’      let lastReason = '';\n 245вҶ’\n 246вҶ’      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 247вҶ’        try {\n 248вҶ’          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 249вҶ’          sent = true;\n 250вҶ’          logger.info(\n 251вҶ’            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 252вҶ’            'Telegram file sent'\n 253вҶ’          );\n 254вҶ’          break;\n 255вҶ’        } catch (error) {\n 256вҶ’          lastReason = error instanceof Error ? error.message : String(error);\n 257вҶ’          logger.warn(\n 258вҶ’            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 259вҶ’            'Telegram file send attempt failed'\n 260вҶ’          );\n 261вҶ’\n 262вҶ’          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 263вҶ’            await sleep(600);\n 264вҶ’            continue;\n 265вҶ’          }\n 266вҶ’\n 267вҶ’          break;\n 268вҶ’        }\n 269вҶ’      }\n 270вҶ’\n 271вҶ’      if (!sent) {\n 272вҶ’        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 273вҶ’        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 274вҶ’        continue;\n 275вҶ’      }\n 276вҶ’\n 277вҶ’      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 278вҶ’    } catch (error) {\n 279вҶ’      const reason = error instanceof Error ? error.message : String(error);\n 280вҶ’      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 281вҶ’      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 282вҶ’    }\n 283вҶ’  }\n 284вҶ’\n 285вҶ’  return results;\n 286вҶ’}\n 287вҶ’\n 288вҶ’async function safeReply(ctx, text) {\n 289вҶ’  try {\n 290вҶ’    await ctx.reply(text);\n 291вҶ’    return true;\n 292вҶ’  } catch (error) {\n 293вҶ’    const reason = error instanceof Error ? error.message : String(error);\n 294вҶ’    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 295вҶ’    return false;\n 296вҶ’  }\n 297вҶ’}\n 298вҶ’\n 299вҶ’async function replyLargeText(ctx, text) {\n 300вҶ’  const chunks = splitMessage(text);\n 301вҶ’  for (const chunk of chunks) {\n 302вҶ’    const ok = await safeReply(ctx, chunk);\n 303вҶ’    if (!ok) {\n 304вҶ’      break;\n 305вҶ’    }\n 306вҶ’  }\n 307вҶ’}\n 308вҶ’\n 309вҶ’async function safeEditMessageText(ctx, messageId, text) {\n 310вҶ’  const nextText = text && text.trim() ? text : ' ';\n 311вҶ’\n 312вҶ’  try {\n 313вҶ’    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 314вҶ’  } catch (error) {\n 315вҶ’    const message = error instanceof Error ? error.message : String(error);\n 316вҶ’    if (message.includes('message is not modified')) {\n 317вҶ’      return;\n 318вҶ’    }\n 319вҶ’    throw error;\n 320вҶ’  }\n 321вҶ’}\n 322вҶ’\n 323вҶ’function createEditableStreamPublisher(ctx) {\n 324вҶ’  let fullText = '';\n 325вҶ’  let renderedText = '';\n 326вҶ’  let pendingChars = 0;\n 327вҶ’  let lastFlushAt = 0;\n 328вҶ’  let flushChain = Promise.resolve();\n 329вҶ’  let activeMessage = null;\n 330вҶ’  let activeSegmentIndex = 0;\n 331вҶ’  let publishedMessageCount = 0;\n 332вҶ’\n 333вҶ’  async function ensureActiveMessage() {\n 334вҶ’    if (activeMessage) {\n 335вҶ’      return;\n 336вҶ’    }\n 337вҶ’    activeMessage = await ctx.reply('еӨ„зҗҶдёӯ...');\n 338вҶ’    activeSegmentIndex = 0;\n 339вҶ’    publishedMessageCount += 1;\n 340вҶ’  }\n 341вҶ’\n 342вҶ’  async function render(force = false) {\n 343вҶ’    const now = Date.now();\n 344вҶ’\n 345вҶ’    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 346вҶ’      return;\n 347вҶ’    }\n 348вҶ’\n 349вҶ’    if (fullText === renderedText) {\n 350вҶ’      pendingChars = 0;\n 351вҶ’      return;\n 352вҶ’    }\n 353вҶ’\n 354вҶ’    await ensureActiveMessage();\n 355вҶ’\n 356вҶ’    const segments = splitMessage(fullText);\n 357вҶ’    const targetLastIndex = Math.max(segments.length - 1, 0);\n 358вҶ’\n 359вҶ’    while (activeSegmentIndex < targetLastIndex) {\n 360вҶ’      const text = segments[activeSegmentIndex] ?? ' ';\n 361вҶ’      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 362вҶ’\n 363вҶ’      activeMessage = await ctx.reply('з»§з»ӯиҫ“еҮәдёӯ...');\n 364вҶ’      activeSegmentIndex += 1;\n 365вҶ’      publishedMessageCount += 1;\n 366вҶ’    }\n 367вҶ’\n 368вҶ’    const activeText = segments[targetLastIndex] ?? ' ';\n 369вҶ’    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 370вҶ’\n 371вҶ’    renderedText = fullText;\n 372вҶ’    pendingChars = 0;\n 373вҶ’    lastFlushAt = now;\n 374вҶ’  }\n 375вҶ’\n 376вҶ’  function enqueueRender(force = false) {\n 377вҶ’    flushChain = flushChain.then(() => render(force));\n 378вҶ’  }\n 379вҶ’\n 380вҶ’  return {\n 381вҶ’    push(text) {\n 382вҶ’      const appendText = text ?? '';\n 383вҶ’      if (!appendText) {\n 384вҶ’        return;\n 385вҶ’      }\n 386вҶ’      fullText += appendText;\n 387вҶ’      pendingChars += appendText.length;\n 388вҶ’      enqueueRender(false);\n 389вҶ’    },\n 390вҶ’    setFinalText(text) {\n 391вҶ’      fullText = text ?? '';\n 392вҶ’      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 393вҶ’      enqueueRender(true);\n 394вҶ’    },\n 395вҶ’    async finish() {\n 396вҶ’      enqueueRender(true);\n 397вҶ’      await flushChain;\n 398вҶ’      return {\n 399вҶ’        outputLength: renderedText.length,\n 400вҶ’        messageCount: publishedMessageCount\n 401вҶ’      };\n 402вҶ’    }\n 403вҶ’  };\n 404вҶ’}\n 405вҶ’\n 406вҶ’function buildSessionId(ctx) {\n 407вҶ’  return String(ctx.chat.id);\n 408вҶ’}\n 409вҶ’\n 410вҶ’function ensureAllowed(ctx) {\n 411вҶ’  const userId = ctx.from?.id;\n 412вҶ’  if (!isAllowedUser(userId)) {\n 413вҶ’    throw new Error('еҪ“еүҚиҙҰеҸ·жңӘиў«жҺҲжқғдҪҝз”ЁиҜҘжңәеҷЁдәәгҖӮ');\n 414вҶ’  }\n 415вҶ’}\n 416вҶ’\n 417вҶ’/**\n 418вҶ’ * Register all pipeline-related commands.\n 419вҶ’ */\n 420вҶ’function registerPipelineCommands() {\n 421вҶ’  registerCommand(pipelineMeta, handlePipeline);\n 422вҶ’  registerCommand(bugfixMeta, handleBugfix);\n 423вҶ’  registerCommand(plannerMeta, handlePlanner);\n 424вҶ’  registerCommand(statusMeta, handleStatus);\n 425вҶ’  registerCommand(logsMeta, handleLogs);\n 426вҶ’  registerCommand(stopMeta, handleStop);\n 427вҶ’}\n 428вҶ’\n 429вҶ’export function createTelegramBot() {\n 430вҶ’  const bot = new Telegraf(config.telegramBotToken, {\n 431вҶ’    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 432вҶ’  });\n 433вҶ’\n 434вҶ’  // Register pipeline commands\n 435вҶ’  registerPipelineCommands();\n 436вҶ’\n 437вҶ’  bot.catch((error, ctx) => {\n 438вҶ’    const message = error instanceof Error ? error.message : String(error);\n 439вҶ’    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 440вҶ’  });\n 441вҶ’\n 442вҶ’  bot.start(async (ctx) => {\n 443вҶ’    await ctx.reply('PrizmClaw е·ІеҗҜеҠЁгҖӮеҸҜзӣҙжҺҘиҒҠеӨ©пјҢд№ҹеҸҜз”Ё /help жҹҘзңӢеҸҜз”Ёе‘Ҫд»ӨгҖӮ');\n 444вҶ’  });\n 445вҶ’\n 446вҶ’  bot.help(async (ctx) => {\n 447вҶ’    const helpText = generateHelp();\n 448вҶ’    await ctx.reply(helpText);\n 449вҶ’  });\n 450вҶ’\n 451вҶ’  bot.command('reset', async (ctx) => {\n 452вҶ’    try {\n 453вҶ’      ensureAllowed(ctx);\n 454вҶ’      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 455вҶ’      await ctx.reply('е·Іжё…з©әеҪ“еүҚдјҡиҜқдёҠдёӢж–ҮгҖӮ');\n 456вҶ’    } catch (error) {\n 457вҶ’      await ctx.reply(error instanceof Error ? error.message : String(error));\n 458вҶ’    }\n 459вҶ’  });\n 460вҶ’\n 461вҶ’  bot.command('screenshot', async (ctx) => {\n 462вҶ’    try {\n 463вҶ’      ensureAllowed(ctx);\n 464вҶ’      await ctx.reply('жӯЈеңЁиҺ·еҸ–жҲӘеӣҫгҖӮ');\n 465вҶ’      const { buffer } = await captureScreenshot();\n 466вҶ’      await ctx.replyWithPhoto({ source: buffer }, { caption: 'еҪ“еүҚжң¬ең°еұҸе№•жҲӘеӣҫ' });\n 467вҶ’    } catch (error) {\n 468вҶ’      const message = error instanceof Error ? error.message : String(error);\n 469вҶ’      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 470вҶ’      await ctx.reply(`жҲӘеӣҫеӨұиҙҘпјҡ${message}`);\n 471вҶ’    }\n 472вҶ’  });\n 473вҶ’\n 474вҶ’  bot.command('exec', async (ctx) => {\n 475вҶ’    try {\n 476вҶ’      ensureAllowed(ctx);\n 477вҶ’      const payload = ctx.message.text.replace('/exec', '').trim();\n 478вҶ’      if (!payload) {\n 479вҶ’        await ctx.reply('иҜ·жҸҗдҫӣе‘Ҫд»ӨпјҢдҫӢеҰӮ /exec pwd');\n 480вҶ’        return;\n 481вҶ’      }\n 482вҶ’\n 483вҶ’      await ctx.reply('жӯЈеңЁжү§иЎҢе‘Ҫд»ӨгҖӮ');\n 484вҶ’      const result = await executeSystemCommand(payload);\n 485вҶ’      const output = [\n 486вҶ’        `exitCode: ${result.exitCode}`,\n 487вҶ’        result.stdout ? `stdout:\\n${result.stdout}` : 'stdout: (empty)',\n 488вҶ’        result.stderr ? `stderr:\\n${result.stderr}` : 'stderr: (empty)'\n 489вҶ’      ].join('\\n\\n');\n 490вҶ’\n 491вҶ’      await replyLargeText(ctx, output);\n 492вҶ’    } catch (error) {\n 493вҶ’      const message = error instanceof Error ? error.message : String(error);\n 494вҶ’      logger.error({ err: message }, 'Failed to exec command in telegram');\n 495вҶ’      await ctx.reply(`жү§иЎҢеӨұиҙҘпјҡ${message}`);\n 496вҶ’    }\n 497вҶ’  });\n 498вҶ’\n 499вҶ’  bot.on('text', async (ctx) => {\n 500вҶ’    // Check for pipeline commands first\n 501вҶ’    const handled = await routeCommand(ctx);\n 502вҶ’    if (handled) {\n 503вҶ’      return;\n 504вҶ’    }\n 505вҶ’\n 506вҶ’    const sessionId = buildSessionId(ctx);\n 507вҶ’\n 508вҶ’    let typingTimer = null;\n 509вҶ’\n 510вҶ’    try {\n 511вҶ’      ensureAllowed(ctx);\n 512вҶ’      await ctx.sendChatAction('typing');\n 513вҶ’\n 514вҶ’      const streamPublisher = createEditableStreamPublisher(ctx);\n 515вҶ’      typingTimer = setInterval(() => {\n 516вҶ’        ctx.sendChatAction('typing').catch(() => undefined);\n 517вҶ’      }, TYPING_INTERVAL_MS);\n 518вҶ’\n 519вҶ’      const reply = await chatWithSession({\n 520вҶ’        channel: 'telegram',\n 521вҶ’        sessionId,\n 522вҶ’        message: ctx.message.text,\n 523вҶ’        realtimeHooks: {\n 524вҶ’          onStatus: ({ stage }) => {\n 525вҶ’            if (stage === 'running') {\n 526вҶ’              ctx.sendChatAction('typing').catch(() => undefined);\n 527вҶ’            }\n 528вҶ’          },\n 529вҶ’          onAssistantChunk: ({ text }) => {\n 530вҶ’            streamPublisher.push(text);\n 531вҶ’          }\n 532вҶ’        }\n 533вҶ’      });\n 534вҶ’\n 535вҶ’      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 536вҶ’      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 537вҶ’      const finalText = cleanedText || (fileRefs.length > 0 ? 'е·Іжү§иЎҢпјҢжӯЈеңЁеҸ‘йҖҒж–Үд»¶гҖӮ' : 'е·Іжү§иЎҢгҖӮ');\n 538вҶ’\n 539вҶ’      streamPublisher.setFinalText(finalText);\n 540вҶ’      const streamed = await streamPublisher.finish();\n 541вҶ’      if (streamed.outputLength === 0) {\n 542вҶ’        await replyLargeText(ctx, finalText);\n 543вҶ’      }\n 544вҶ’\n 545вҶ’      if (fileRefs.length > 0) {\n 546вҶ’        const fileSendResults = await replyFiles(ctx, fileRefs);\n 547вҶ’        const failed = fileSendResults.filter((item) => !item.sent);\n 548вҶ’\n 549вҶ’        if (failed.length === 0) {\n 550вҶ’          await safeReply(ctx, `е·ІеҸ‘йҖҒ ${fileSendResults.length} дёӘж–Үд»¶гҖӮ`);\n 551вҶ’        } else {\n 552вҶ’          const failedList = failed\n 553вҶ’            .map((item) => {\n 554вҶ’              const reason =\n 555вҶ’                item.reason === 'relative_path_not_allowed'\n 556вҶ’                  ? 'д»…е…Ғи®ёз»қеҜ№и·Ҝеҫ„пјҢжӢ’з»қзӣёеҜ№и·Ҝеҫ„пјҲиҜ·дҪҝз”Ё SEND_FILE:/var/folders/.../xxx.pngпјү'\n 557вҶ’                  : item.reason === 'not_found'\n 558вҶ’                    ? 'ж–Үд»¶дёҚеӯҳеңЁжҲ–дёҚеҸҜи®ҝй—®пјҲе»әи®®иҝ”еӣһз»қеҜ№и·Ҝеҫ„пјҢдҫӢеҰӮ SEND_FILE:/var/folders/.../xxx.pngпјү'\n 559вҶ’                    : item.reason;\n 560вҶ’              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `пјӣе°қиҜ•и·Ҝеҫ„пјҡ${item.triedPaths.join(' | ')}` : '';\n 561вҶ’              return `- SEND_FILE:${item.fileRef}${reason ? `пјҲ${reason}пјү` : ''}${tried}`;\n 562вҶ’            })\n 563вҶ’            .join('\\n');\n 564вҶ’          await safeReply(ctx, `д»ҘдёӢж–Үд»¶еҸ‘йҖҒеӨұиҙҘпјҢе·Ійҷ„еӣһеҺҹе§Ӣеј•з”Ёпјҡ\\n${failedList}`);\n 565вҶ’          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 566вҶ’        }\n 567вҶ’      }\n 568вҶ’    } catch (error) {\n 569вҶ’      const message = error instanceof Error ? error.message : String(error);\n 570вҶ’      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 571вҶ’      await safeReply(ctx, `еӨ„зҗҶеӨұиҙҘпјҡ${message}`);\n 572вҶ’    } finally {\n 573вҶ’      if (typingTimer) {\n 574вҶ’        clearInterval(typingTimer);\n 575вҶ’      }\n 576вҶ’    }\n 577вҶ’  });\n 578вҶ’\n 579вҶ’  return bot;\n 580вҶ’}\n 581вҶ’"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde4a927cad823de88d83a3b65383","__timestamp":"2026-03-11T19:06:32.298Z","_requestId":"d5751c68510146c3a3ea5dbb4d6e54b2"}
