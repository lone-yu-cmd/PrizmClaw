{"type":"user","uuid":"0ba1884d-83db-4b5a-96da-3f5680a5426f","session_id":"7bf91201-6528-470c-bfa4-e2217c84d56d","message":{"content":[{"type":"tool_result","tool_use_id":"019cde4b21eb1b76d96c6e3106f2bfc0","content":[{"type":"text","text":"   1вҶ’import { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2вҶ’\n   3вҶ’function buildRequest(params = {}, action) {\n   4вҶ’  return {\n   5вҶ’    pipelineType: params.pipelineType ?? 'feature',\n   6вҶ’    action,\n   7вҶ’    ...(params.targetId ? { targetId: params.targetId } : {}),\n   8вҶ’    ...(params.listPath ? { listPath: params.listPath } : {}),\n   9вҶ’    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  10вҶ’    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  11вҶ’  };\n  12вҶ’}\n  13вҶ’\n  14вҶ’export function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  15вҶ’  return {\n  16вҶ’    runner,\n  17вҶ’    async startPipeline(params) {\n  18вҶ’      return runner(buildRequest(params, 'run'));\n  19вҶ’    },\n  20вҶ’    async getPipelineStatus(params) {\n  21вҶ’      return runner(buildRequest(params, 'status'));\n  22вҶ’    },\n  23вҶ’    async stopPipeline(params) {\n  24вҶ’      return runner(buildRequest(params, 'stop'));\n  25вҶ’    },\n  26вҶ’    async retryTarget(params) {\n  27вҶ’      return runner(buildRequest(params, 'retry'));\n  28вҶ’    },\n  29вҶ’    async getPipelineLogs(params) {\n  30вҶ’      return runner(buildRequest(params, 'logs'));\n  31вҶ’    },\n  32вҶ’    async resetTarget(params) {\n  33вҶ’      return runner(buildRequest(params, 'reset'));\n  34вҶ’    }\n  35вҶ’  };\n  36вҶ’}\n  37вҶ’\n  38вҶ’const defaultService = createPipelineControlService();\n  39вҶ’\n  40вҶ’export async function startPipeline(params) {\n  41вҶ’  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  42вҶ’  return service.startPipeline(params);\n  43вҶ’}\n  44вҶ’\n  45вҶ’export a