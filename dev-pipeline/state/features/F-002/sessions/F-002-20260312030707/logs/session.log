{"type":"user","uuid":"c509ba75-d604-4ad1-b384-595de6ae77d9","session_id":"0f417c3a-586b-4d95-85f1-7addd373f935","message":{"content":[{"type":"tool_result","tool_use_id":"call_e7807b828b324c8b9aa45420","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { captureScreenshot } from '../services/screenshot-service.js';\n  11→import { executeSystemCommand } from '../services/system-exec-service.js';\n  12→import { registerCommand } from './commands/index.js';\n  13→import { routeCommand } from './commands/index.js';\n  14→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  15→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  16→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  17→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  18→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  19→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  20→import { generateHelp } from './commands/help.js';\n  21→\n  22→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  23→const STREAM_MIN_CHARS = 220;\n  24→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  25→const TYPING_INTERVAL_MS = 3500;\n  26→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  27→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  28→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  29→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  30→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  31→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  32→const TMP_DIR = path.resolve(os.tmpdir());\n  33→const HOME_DIR = path.resolve(os.homedir());\n  34→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  35→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  36→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  37→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  38→\n  39→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  40→  const normalized = configuredDirs\n  41→    .map((dir) => String(dir ?? '').trim())\n  42→    .filter(Boolean)\n  43→    .map((dir) => path.resolve(dir));\n  44→\n  45→  if (normalized.length > 0) {\n  46→    return [...new Set(normalized)];\n  47→  }\n  48→\n  49→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  50→}\n  51→\n  52→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  53→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  54→\n  55→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  56→  const chunks = [];\n  57→  for (let i = 0; i < text.length; i += chunkSize) {\n  58→    chunks.push(text.slice(i, i + chunkSize));\n  59→  }\n  60→  return chunks;\n  61→}\n  62→\n  63→function sanitizeMarkerPath(raw) {\n  64→  return String(raw ?? '')\n  65→    .trim()\n  66→    .replace(/^['\"`]+/, '')\n  67→    .replace(/['\"`]+$/, '');\n  68→}\n  69→\n  70→function extractFileMarkers(text = '') {\n  71→  const fileRefs = [];\n  72→\n  73→  const withSendFileRemoved = text.replace(\n  74→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  75→    (_full, rawRef) => {\n  76→      const ref = sanitizeMarkerPath(rawRef);\n  77→      if (ref) {\n  78→        fileRefs.push(ref);\n  79→      }\n  80→      return '\\n';\n  81→    }\n  82→  );\n  83→\n  84→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  85→    const ref = sanitizeMarkerPath(rawRef);\n  86→    if (ref) {\n  87→      fileRefs.push(ref);\n  88→    }\n  89→    return '';\n  90→  });\n  91→\n  92→  const withBacktickPathRemoved = withImageRemoved.replace(\n  93→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n  94→    (_full, rawRef) => {\n  95→      const ref = sanitizeMarkerPath(rawRef);\n  96→      if (ref) {\n  97→        fileRefs.push(ref);\n  98→      }\n  99→      return '';\n 100→    }\n 101→  );\n 102→\n 103→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 104→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 105→    (_full, rawRef) => {\n 106→      const ref = sanitizeMarkerPath(rawRef);\n 107→      if (ref) {\n 108→        fileRefs.push(ref);\n 109→      }\n 110→      return '';\n 111→    }\n 112→  );\n 113→\n 114→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 115→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 116→    (_full, rawRef) => {\n 117→      const ref = sanitizeMarkerPath(rawRef);\n 118→      if (ref) {\n 119→        fileRefs.push(ref);\n 120→      }\n 121→      return '\\n';\n 122→    }\n 123→  );\n 124→\n 125→  return {\n 126→    fileRefs: [...new Set(fileRefs)],\n 127→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 128→  };\n 129→}\n 130→\n 131→function isPathWithinRoot(targetPath, rootPath) {\n 132→  const relative = path.relative(rootPath, targetPath);\n 133→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 134→}\n 135→\n 136→function isAllowedFilePath(filePath) {\n 137→  const resolved = path.resolve(filePath);\n 138→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 139→}\n 140→\n 141→function buildFileCandidates(normalizedPath) {\n 142→  if (path.isAbsolute(normalizedPath)) {\n 143→    return [normalizedPath];\n 144→  }\n 145→\n 146→  const baseName = path.basename(normalizedPath);\n 147→  const candidates = [\n 148→    path.resolve(process.cwd(), normalizedPath),\n 149→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 150→  ];\n 151→\n 152→  return [...new Set(candidates)];\n 153→}\n 154→\n 155→async function resolveLocalFilePath(fileRef) {\n 156→  const normalized = sanitizeMarkerPath(fileRef);\n 157→  if (!normalized) {\n 158→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 159→  }\n 160→\n 161→  if (!path.isAbsolute(normalized)) {\n 162→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 163→  }\n 164→\n 165→  const candidates = buildFileCandidates(normalized);\n 166→\n 167→  for (const candidate of candidates) {\n 168→    try {\n 169→      await access(candidate);\n 170→      return { filePath: candidate, triedPaths: candidates };\n 171→    } catch {\n 172→      // ignore\n 173→    }\n 174→  }\n 175→\n 176→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 177→}\n 178→\n 179→async function validateFileForTelegram(filePath) {\n 180→  const resolvedPath = path.resolve(filePath);\n 181→  if (!isAllowedFilePath(resolvedPath)) {\n 182→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 183→  }\n 184→\n 185→  const ext = path.extname(resolvedPath).toLowerCase();\n 186→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 187→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 188→  }\n 189→\n 190→  const fileStat = await stat(resolvedPath);\n 191→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 192→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 193→\n 194→  if (fileStat.size > maxSize) {\n 195→    return {\n 196→      ok: false,\n 197→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 198→    };\n 199→  }\n 200→\n 201→  return { ok: true, isPhoto, resolvedPath };\n 202→}\n 203→\n 204→function isTimeoutLikeError(message = '') {\n 205→  const normalized = String(message).toLowerCase();\n 206→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 207→}\n 208→\n 209→function sleep(ms) {\n 210→  return new Promise((resolve) => setTimeout(resolve, ms));\n 211→}\n 212→\n 213→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 214→  if (isPhoto) {\n 215→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 216→    return;\n 217→  }\n 218→\n 219→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 220→}\n 221→\n 222→async function replyFiles(ctx, fileRefs = []) {\n 223→  const results = [];\n 224→\n 225→  for (const fileRef of fileRefs) {\n 226→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 227→    if (!filePath) {\n 228→      const reason = rejectReason || 'not_found';\n 229→      results.push({ fileRef, sent: false, reason, triedPaths });\n 230→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 231→      continue;\n 232→    }\n 233→\n 234→    try {\n 235→      const validation = await validateFileForTelegram(filePath);\n 236→      if (!validation.ok) {\n 237→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 238→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 239→        continue;\n 240→      }\n 241→\n 242→      const actualPath = validation.resolvedPath;\n 243→      let sent = false;\n 244→      let lastReason = '';\n 245→\n 246→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 247→        try {\n 248→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 249→          sent = true;\n 250→          logger.info(\n 251→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 252→            'Telegram file sent'\n 253→          );\n 254→          break;\n 255→        } catch (error) {\n 256→          lastReason = error instanceof Error ? error.message : String(error);\n 257→          logger.warn(\n 258→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 259→            'Telegram file send attempt failed'\n 260→          );\n 261→\n 262→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 263→            await sleep(600);\n 264→            continue;\n 265→          }\n 266→\n 267→          break;\n 268→        }\n 269→      }\n 270→\n 271→      if (!sent) {\n 272→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 273→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 274→        continue;\n 275→      }\n 276→\n 277→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 278→    } catch (error) {\n 279→      const reason = error instanceof Error ? error.message : String(error);\n 280→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 281→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 282→    }\n 283→  }\n 284→\n 285→  return results;\n 286→}\n 287→\n 288→async function safeReply(ctx, text) {\n 289→  try {\n 290→    await ctx.reply(text);\n 291→    return true;\n 292→  } catch (error) {\n 293→    const reason = error instanceof Error ? error.message : String(error);\n 294→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 295→    return false;\n 296→  }\n 297→}\n 298→\n 299→async function replyLargeText(ctx, text) {\n 300→  const chunks = splitMessage(text);\n 301→  for (const chunk of chunks) {\n 302→    const ok = await safeReply(ctx, chunk);\n 303→    if (!ok) {\n 304→      break;\n 305→    }\n 306→  }\n 307→}\n 308→\n 309→async function safeEditMessageText(ctx, messageId, text) {\n 310→  const nextText = text && text.trim() ? text : ' ';\n 311→\n 312→  try {\n 313→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 314→  } catch (error) {\n 315→    const message = error instanceof Error ? error.message : String(error);\n 316→    if (message.includes('message is not modified')) {\n 317→      return;\n 318→    }\n 319→    throw error;\n 320→  }\n 321→}\n 322→\n 323→function createEditableStreamPublisher(ctx) {\n 324→  let fullText = '';\n 325→  let renderedText = '';\n 326→  let pendingChars = 0;\n 327→  let lastFlushAt = 0;\n 328→  let flushChain = Promise.resolve();\n 329→  let activeMessage = null;\n 330→  let activeSegmentIndex = 0;\n 331→  let publishedMessageCount = 0;\n 332→\n 333→  async function ensureActiveMessage() {\n 334→    if (activeMessage) {\n 335→      return;\n 336→    }\n 337→    activeMessage = await ctx.reply('处理中...');\n 338→    activeSegmentIndex = 0;\n 339→    publishedMessageCount += 1;\n 340→  }\n 341→\n 342→  async function render(force = false) {\n 343→    const now = Date.now();\n 344→\n 345→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 346→      return;\n 347→    }\n 348→\n 349→    if (fullText === renderedText) {\n 350→      pendingChars = 0;\n 351→      return;\n 352→    }\n 353→\n 354→    await ensureActiveMessage();\n 355→\n 356→    const segments = splitMessage(fullText);\n 357→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 358→\n 359→    while (activeSegmentIndex < targetLastIndex) {\n 360→      const text = segments[activeSegmentIndex] ?? ' ';\n 361→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 362→\n 363→      activeMessage = await ctx.reply('继续输出中...');\n 364→      activeSegmentIndex += 1;\n 365→      publishedMessageCount += 1;\n 366→    }\n 367→\n 368→    const activeText = segments[targetLastIndex] ?? ' ';\n 369→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 370→\n 371→    renderedText = fullText;\n 372→    pendingChars = 0;\n 373→    lastFlushAt = now;\n 374→  }\n 375→\n 376→  function enqueueRender(force = false) {\n 377→    flushChain = flushChain.then(() => render(force));\n 378→  }\n 379→\n 380→  return {\n 381→    push(text) {\n 382→      const appendText = text ?? '';\n 383→      if (!appendText) {\n 384→        return;\n 385→      }\n 386→      fullText += appendText;\n 387→      pendingChars += appendText.length;\n 388→      enqueueRender(false);\n 389→    },\n 390→    setFinalText(text) {\n 391→      fullText = text ?? '';\n 392→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 393→      enqueueRender(true);\n 394→    },\n 395→    async finish() {\n 396→      enqueueRender(true);\n 397→      await flushChain;\n 398→      return {\n 399→        outputLength: renderedText.length,\n 400→        messageCount: publishedMessageCount\n 401→      };\n 402→    }\n 403→  };\n 404→}\n 405→\n 406→function buildSessionId(ctx) {\n 407→  return String(ctx.chat.id);\n 408→}\n 409→\n 410→function ensureAllowed(ctx) {\n 411→  const userId = ctx.from?.id;\n 412→  if (!isAllowedUser(userId)) {\n 413→    throw new Error('当前账号未被授权使用该机器人。');\n 414→  }\n 415→}\n 416→\n 417→/**\n 418→ * Register all pipeline-related commands.\n 419→ */\n 420→function registerPipelineCommands() {\n 421→  registerCommand(pipelineMeta, handlePipeline);\n 422→  registerCommand(bugfixMeta, handleBugfix);\n 423→  registerCommand(plannerMeta, handlePlanner);\n 424→  registerCommand(statusMeta, handleStatus);\n 425→  registerCommand(logsMeta, handleLogs);\n 426→  registerCommand(stopMeta, handleStop);\n 427→}\n 428→\n 429→export function createTelegramBot() {\n 430→  const bot = new Telegraf(config.telegramBotToken, {\n 431→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 432→  });\n 433→\n 434→  // Register pipeline commands\n 435→  registerPipelineCommands();\n 436→\n 437→  bot.catch((error, ctx) => {\n 438→    const message = error instanceof Error ? error.message : String(error);\n 439→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 440→  });\n 441→\n 442→  bot.start(async (ctx) => {\n 443→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 444→  });\n 445→\n 446→  bot.help(async (ctx) => {\n 447→    const helpText = generateHelp();\n 448→    await ctx.reply(helpText);\n 449→  });\n 450→\n 451→  bot.command('reset', async (ctx) => {\n 452→    try {\n 453→      ensureAllowed(ctx);\n 454→      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 455→      await ctx.reply('已清空当前会话上下文。');\n 456→    } catch (error) {\n 457→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 458→    }\n 459→  });\n 460→\n 461→  bot.command('screenshot', async (ctx) => {\n 462→    try {\n 463→      ensureAllowed(ctx);\n 464→      await ctx.reply('正在获取截图。');\n 465→      const { buffer } = await captureScreenshot();\n 466→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 467→    } catch (error) {\n 468→      const message = error instanceof Error ? error.message : String(error);\n 469→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 470→      await ctx.reply(`截图失败：${message}`);\n 471→    }\n 472→  });\n 473→\n 474→  bot.command('exec', async (ctx) => {\n 475→    try {\n 476→      ensureAllowed(ctx);\n 477→      const payload = ctx.message.text.replace('/exec', '').trim();\n 478→      if (!payload) {\n 479→        await ctx.reply('请提供命令，例如 /exec pwd');\n 480→        return;\n 481→      }\n 482→\n 483→      await ctx.reply('正在执行命令。');\n 484→      const result = await executeSystemCommand(payload);\n 485→      const output = [\n 486→        `exitCode: ${result.exitCode}`,\n 487→        result.stdout ? `stdout:\\n${result.stdout}` : 'stdout: (empty)',\n 488→        result.stderr ? `stderr:\\n${result.stderr}` : 'stderr: (empty)'\n 489→      ].join('\\n\\n');\n 490→\n 491→      await replyLargeText(ctx, output);\n 492→    } catch (error) {\n 493→      const message = error instanceof Error ? error.message : String(error);\n 494→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 495→      await ctx.reply(`执行失败：${message}`);\n 496→    }\n 497→  });\n 498→\n 499→  bot.on('text', async (ctx) => {\n 500→    // Check for pipeline commands first\n 501→    const handled = await routeCommand(ctx);\n 502→    if (handled) {\n 503→      return;\n 504→    }\n 505→\n 506→    const sessionId = buildSessionId(ctx);\n 507→\n 508→    let typingTimer = null;\n 509→\n 510→    try {\n 511→      ensureAllowed(ctx);\n 512→      await ctx.sendChatAction('typing');\n 513→\n 514→      const streamPublisher = createEditableStreamPublisher(ctx);\n 515→      typingTimer = setInterval(() => {\n 516→        ctx.sendChatAction('typing').catch(() => undefined);\n 517→      }, TYPING_INTERVAL_MS);\n 518→\n 519→      const reply = await chatWithSession({\n 520→        channel: 'telegram',\n 521→        sessionId,\n 522→        message: ctx.message.text,\n 523→        realtimeHooks: {\n 524→          onStatus: ({ stage }) => {\n 525→            if (stage === 'running') {\n 526→              ctx.sendChatAction('typing').catch(() => undefined);\n 527→            }\n 528→          },\n 529→          onAssistantChunk: ({ text }) => {\n 530→            streamPublisher.push(text);\n 531→          }\n 532→        }\n 533→      });\n 534→\n 535→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 536→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 537→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 538→\n 539→      streamPublisher.setFinalText(finalText);\n 540→      const streamed = await streamPublisher.finish();\n 541→      if (streamed.outputLength === 0) {\n 542→        await replyLargeText(ctx, finalText);\n 543→      }\n 544→\n 545→      if (fileRefs.length > 0) {\n 546→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 547→        const failed = fileSendResults.filter((item) => !item.sent);\n 548→\n 549→        if (failed.length === 0) {\n 550→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 551→        } else {\n 552→          const failedList = failed\n 553→            .map((item) => {\n 554→              const reason =\n 555→                item.reason === 'relative_path_not_allowed'\n 556→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 557→                  : item.reason === 'not_found'\n 558→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 559→                    : item.reason;\n 560→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 561→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 562→            })\n 563→            .join('\\n');\n 564→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 565→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 566→        }\n 567→      }\n 568→    } catch (error) {\n 569→      const message = error instanceof Error ? error.message : String(error);\n 570→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 571→      await safeReply(ctx, `处理失败：${message}`);\n 572→    } finally {\n 573→      if (typingTimer) {\n 574→        clearInterval(typingTimer);\n 575→      }\n 576→    }\n 577→  });\n 578→\n 579→  return bot;\n 580→}\n 581→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde4bfd019ea78fd92536fc7b2011","__timestamp":"2026-03-11T19:08:12.363Z","_requestId":"4b990aef1ee94c0d9951653ca0a8a1f1"}
