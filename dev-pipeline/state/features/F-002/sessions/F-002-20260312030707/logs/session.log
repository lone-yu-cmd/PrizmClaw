{"type":"user","uuid":"71091070-eabc-4459-a2e8-c49644c1889a","session_id":"0f417c3a-586b-4d95-85f1-7addd373f935","message":{"content":[{"type":"tool_result","tool_use_id":"call_0955563e9d4742dfaaa72c8b","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import { formatError, formatValidationErrors, formatErrorResponse, ErrorCodes } from '../../../src/bot/commands/formatter.js';\n   4→\n   5→test('formatError UNKNOWN_COMMAND', () => {\n   6→  const error = formatError(ErrorCodes.UNKNOWN_COMMAND, { command: 'xyz' });\n   7→  assert.equal(error.code, ErrorCodes.UNKNOWN_COMMAND);\n   8→  assert.ok(error.message.includes('未知命令'));\n   9→  assert.ok(error.message.includes('xyz'));\n  10→  assert.ok(error.suggestion.includes('/help'));\n  11→});\n  12→\n  13→test('formatError UNKNOWN_SUBCOMMAND', () => {\n  14→  const error = formatError(ErrorCodes.UNKNOWN_SUBCOMMAND, {\n  15→    subcommand: 'xyz',\n  16→    available: ['run', 'status']\n  17→  });\n  18→  assert.equal(error.code, ErrorCodes.UNKNOWN_SUBCOMMAND);\n  19→  assert.ok(error.message.includes('未知子命令'));\n  20→  assert.ok(error.suggestion.includes('run'));\n  21→});\n  22→\n  23→test('formatError MISSING_PARAM', () => {\n  24→  const error = formatError(ErrorCodes.MISSING_PARAM, { param: 'target' });\n  25→  assert.equal(error.code, ErrorCodes.MISSING_PARAM);\n  26→  assert.ok(error.message.includes('缺少参数'));\n  27→  assert.ok(error.message.includes('target'));\n  28→});\n  29→\n  30→test('formatError INVALID_PARAM', () => {\n  31→  const error = formatError(ErrorCodes.INVALID_PARAM, {\n  32→    param: 'type',\n  33→    reason: '无效值',\n  34→    suggestion: '可选: feature, bugfix'\n  35→  });\n  36→  assert.equal(error.code, ErrorCodes.INVALID_PARAM);\n  37→  assert.ok(error.message.includes('无效'));\n  38→  assert.ok(error.suggestion.includes('feature'));\n  39→});\n  40→\n  41→test('formatError UNAUTHORIZED', () => {\n  42→  const error = formatError(ErrorCodes.UNAUTHORIZED, {});\n  43→  assert.equal(error.code, ErrorCodes.UNAUTHORIZED);\n  44→  assert.ok(error.message.includes('未被授权'));\n  45→});\n  46→\n  47→test('formatError INTERNAL_ERROR', () => {\n  48→  const error = formatError(ErrorCodes.INTERNAL_ERROR, { reason: 'Connection failed' });\n  49→  assert.equal(error.code, ErrorCodes.INTERNAL_ERROR);\n  50→  assert.ok(error.message.includes('内部错误'));\n  51→});\n  52→\n  53→test('formatValidationErrors formats multiple errors', () => {\n  54→  const errors = [\n  55→    { param: 'target', message: '缺少参数 target', suggestion: '请提供 target' },\n  56→    { param: 'type', message: '无效类型', suggestion: '可选: feature, bugfix' }\n  57→  ];\n  58→\n  59→  const result = formatValidationErrors(errors, '/pipeline run <target>');\n  60→  assert.ok(result.includes('缺少参数'));\n  61→  assert.ok(result.includes('建议'));\n  62→  assert.ok(result.includes('用法'));\n  63→});\n  64→\n  65→test('formatValidationErrors returns empty for no errors', () => {\n  66→  const result = formatValidationErrors([], '/usage');\n  67→  assert.equal(result, '');\n  68→});\n  69→\n  70→test('formatErrorResponse formats complete error', () => {\n  71→  const error = {\n  72→    code: ErrorCodes.MISSING_PARAM,\n  73→    message: '缺少参数 target',\n  74→    suggestion: '请提供 target 参数',\n  75→    usage: '/bugfix <target>'\n  76→  };\n  77→\n  78→  const result = formatErrorResponse(error);\n  79→  assert.ok(result.includes('❌'));\n  80→  assert.ok(result.includes('💡'));\n  81→  assert.ok(result.includes('用法'));\n  82→});\n  83→\n  84→test('formatErrorResponse handles minimal error', () => {\n  85→  const error = {\n  86→    code: ErrorCodes.INTERNAL_ERROR,\n  87→    message: 'Unknown error'\n  88→  };\n  89→\n  90→  const result = formatErrorResponse(error);\n  91→  assert.ok(result.includes('❌'));\n  92→  assert.ok(!result.includes('💡'));\n  93→});\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde4bfd019ea78fd92536fc7b2011","__