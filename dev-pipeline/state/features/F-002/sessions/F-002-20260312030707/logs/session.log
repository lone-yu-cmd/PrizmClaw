e({ runner: params?.runner ?? defaultService.runner });\n  47→  return service.getPipelineStatus(params);\n  48→}\n  49→\n  50→export async function stopPipeline(params) {\n  51→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  52→  return service.stopPipeline(params);\n  53→}\n  54→\n  55→export async function retryTarget(params) {\n  56→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  57→  return service.retryTarget(params);\n  58→}\n  59→\n  60→export async function getPipelineLogs(params) {\n  61→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  62→  return service.getPipelineLogs(params);\n  63→}\n  64→\n  65→export async function resetTarget(params) {\n  66→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  67→  return service.resetTarget(params);\n  68→}\n  69→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde4bfd019ea78fd92536fc7b2011","__timestamp":"2026-03-11T19:08:12.383Z","_requestId":"4b990aef1ee94c0d9951653ca0a8a1f1"}
