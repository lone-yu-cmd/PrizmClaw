ommand('/pipeline run --type=feature --verbose');\n  46→  assert.deepEqual(result.options, { type: 'feature', verbose: 'true' });\n  47→});\n  48→\n  49→test('parseCommand parses key=value without --', () => {\n  50→  const result = parseCommand('/pipeline run type=bugfix');\n  51→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_dae094f5af2049e0834a0ebc","__timestamp":"2026-03-11T19:09:13.927Z","_requestId":"113f70e8b8db40048c3e94b0d4e91182"}
