{"type":"user","uuid":"a286a820-4ad9-4c23-a309-e3fce819caba","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde60f100ec7b099e7e005d9ab69b","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import { handlePipeline, pipelineMeta } from '../../../../src/bot/commands/handlers/pipeline.js';\n   4→import { handleBugfix, bugfixMeta } from '../../../../src/bot/commands/handlers/bugfix.js';\n   5→import { handleStatus, statusMeta } from '../../../../src/bot/commands/handlers/status.js';\n   6→import { handleLogs, logsMeta } from '../../../../src/bot/commands/handlers/logs.js';\n   7→import { handleStop, stopMeta } from '../../../../src/bot/commands/handlers/stop.js';\n   8→import { handlePlanner, plannerMeta } from '../../../../src/bot/commands/handlers/planner.js';\n   9→\n  10→// Mock pipeline-control-service\n  11→const createMockService = () => {\n  12→  const calls = [];\n  13→  return {\n  14→    calls,\n  15→    startPipeline: async (params) => {\n  16→      calls.push({ method: 'startPipeline', params });\n  17→      return { ok: true, exitCode: 0 };\n  18→    },\n  19→    getPipelineStatus: async (params) => {\n  20→      calls.push({ method: 'getPipelineStatus', params });\n  21→      return { ok: true, pipelines: [] };\n  22→    },\n  23→    stopPipeline: async (params) => {\n  24→      calls.push({ method: 'stopPipeline', params });\n  25→      return { ok: true };\n  26→    },\n  27→    getPipelineLogs: async (params) => {\n  28→      calls.push({ method: 'getPipelineLogs', params });\n  29→      return { ok: true, stdout: 'log content' };\n  30→    }\n  31→  };\n  32→};\n  33→\n  34→const createMockContext = () => {\n  35→  const replies = [];\n  36→  return {\n  37→    replies,\n  38→    ctx: {\n  39→      from: { id: 12345 },\n  40→      message: { text: '' },\n  41→      reply: async (text) => { replies.push(text); }\n  42→    },\n  43→    reply: async (text) => { replies.push(text); },\n  44→    replyFile: async (content, filename) => { replies.push(`[FILE: ${filename}]`); }\n  45→  };\n  46→};\n  47→\n  48→test('pipelineMeta has correct metadata', () => {\n  49→  assert.equal(pipelineMeta.name, 'pipeline');\n  50→  assert.deepEqual(pipelineMeta.aliases, ['p']);\n  51→  assert.ok(pipelineMeta.subcommands.length > 0);\n  52→});\n  53→\n  54→test('handlePipeline with run subcommand calls startPipeline', async () => {\n  55→  const mock = createMockService();\n  56→  const mockCtx = createMockContext();\n  57→\n  58→  await handlePipeline({\n  59→    ctx: mockCtx.ctx,\n  60→    parsed: { command: 'pipeline', subcommand: 'run', args: ['my-feature'], options: {} },\n  61→    params: { type: 'feature', _args: ['my-feature'] },\n  62→    reply: mockCtx.reply,\n  63→    replyFile: mockCtx.replyFile\n  64→  });\n  65→\n  66→  // Verify behavior through replies\n  67→  assert.ok(mockCtx.replies.length > 0);\n  68→});\n  69→\n  70→test('handlePipeline with status subcommand shows status', async () => {\n  71→  const mock = createMockService();\n  72→  const mockCtx = createMockContext();\n  73→\n  74→  await handlePipeline({\n  75→    ctx: mockCtx.ctx,\n  76→    parsed: { command: 'pipeline', subcommand: 'status', args: [], options: {} },\n  77→    params: {},\n  78→    reply: mockCtx.reply,\n  79→    replyFile: mockCtx.replyFile\n  80→  });\n  81→\n  82→  assert.ok(mockCtx.replies.length > 0);\n  83→});\n  84→\n  85→test('handleBugfix requires target parameter', async () => {\n  86→  const mockCtx = createMockContext();\n  87→\n  88→  await handleBugfix({\n  89→    ctx: mockCtx.ctx,\n  90→    parsed: { command: 'bugfix', args: [], options: {} },\n  91→    params: {},\n  92→    reply: mockCtx.reply,\n  93→    replyFile: mockCtx.replyFile\n  94→  });\n  95→\n  96→  assert.ok(mockCtx.replies[0].includes('缺少'));\n  97→});\n  98→\n  99→test('handleBugfix calls pipeline with type=bugfix', async () => {\n 100→  const mockCtx = createMockContext();\n 101→\n 102→  await handleBugfix({\n 103→    ctx: mockCtx.ctx,\n 104→    parsed: { command: 'bugfix', args: ['session-123'], options: {} },\n 105→    params: { _args: ['session-123'] },\n 106→    reply: mockCtx.reply,\n 107→    replyFile: mockCtx.replyFile\n 108→  });\n 109→\n 110→  assert.ok(mockCtx.replies.length > 0);\n 111→});\n 112→\n 113→test('bugfixMeta has correct metadata', () => {\n 114→  assert.equal(bugfixMeta.name, 'bugfix');\n 115→  assert.deepEqual(bugfixMeta.aliases, ['b']);\n 116→  assert.equal(bugfixMeta.params[0].required, true);\n 117→});\n 118→\n 119→test('handleStatus returns status message', async () => {\n 120→  const mockCtx = createMockContext();\n 121→\n 122→  await handleStatus({\n 123→    ctx: mockCtx.ctx,\n 124→    parsed: { command: 'status', args: [], options: {} },\n 125→    params: {},\n 126→    reply: mockCtx.reply\n 127→  });\n 128→\n 129→  assert.ok(mockCtx.replies.length > 0);\n 130→  assert.ok(mockCtx.replies[0].includes('管道'));\n 131→});\n 132→\n 133→test('statusMeta has correct metadata', () => {\n 134→  assert.equal(statusMeta.name, 'status');\n 135→  assert.deepEqual(statusMeta.aliases, ['s']);\n 136→});\n 137→\n 138→test('handleLogs returns logs', async () => {\n 139→  const mockCtx = createMockContext();\n 140→\n 141→  await handleLogs({\n 142→    ctx: mockCtx.ctx,\n 143→    parsed: { command: 'logs', args: [], options: {} },\n 144→    params: {},\n 145→    reply: mockCtx.reply,\n 146→    replyFile: mockCtx.replyFile\n 147→  });\n 148→\n 149→  assert.ok(mockCtx.replies.length > 0);\n 150→});\n 151→\n 152→test('logsMeta has correct metadata', () => {\n 153→  assert.equal(logsMeta.name, 'logs');\n 154→  assert.deepEqual(logsMeta.aliases, ['l']);\n 155→});\n 156→\n 157→test('handleStop returns confirmation', async () => {\n 158→  const mockCtx = createMockContext();\n 159→\n 160→  await handleStop({\n 161→    ctx: mockCtx.ctx,\n 162→    parsed: { command: 'stop', args: [], options: {} },\n 163→    params: {},\n 164→    reply: mockCtx.reply\n 165→  });\n 166→\n 167→  assert.ok(mockCtx.replies.length > 0);\n 168→});\n 169→\n 170→test('stopMeta has correct metadata', () => {\n 171→  assert.equal(stopMeta.name, 'stop');\n 172→});\n 173→\n 174→test('handlePlanner uses pipeline with type=planner', async () => {\n 175→  const mockCtx = createMockContext();\n 176→\n 177→  await handlePlanner({\n 178→    ctx: mockCtx.ctx,\n 179→    parsed: { command: 'planner', subcommand: 'status', args: [], options: {} },\n 180→    params: { type: 'planner' },\n 181→    reply: mockCtx.reply,\n 182→    replyFile: mockCtx.replyFile\n 183→  });\n 184→\n 185→  assert.ok(mockCtx.replies.length > 0);\n 186→});\n 187→\n 188→test('plannerMeta has correct metadata', () => {\n 189→  assert.equal(plannerMeta.name, 'planner');\n 190→  assert.deepEqual(plannerMeta.aliases, []);\n 191→});\n 192→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:30:21.662Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
