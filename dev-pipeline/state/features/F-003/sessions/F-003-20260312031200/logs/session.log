{"type":"assistant","uuid":"20260312032101eb509f4084554653","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"id":"20260312032101eb509f4084554653","content":[{"type":"tool_use","id":"019cde58705bb379b80aeae14db28a44","name":"Write","input":{"content":"/**\n * Plan Ingestion Service\n * Handles plan file validation, versioning, and registry management.\n *\n * Implements:\n * - T-010: Schema Loader\n * - T-011: Plan Validator\n * - T-012: Version Manager\n * - T-013: Plan Registry\n * - T-014: Error Formatting\n */\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport Ajv from 'ajv';\n\n// Schema type constants\nconst SCHEMA_TYPES = {\n  FEATURE_LIST: 'feature-list',\n  BUG_FIX_LIST: 'bug-fix-list'\n};\n\n// Schema identifier constants from the schema files\nconst SCHEMA_IDENTIFIERS = {\n  'dev-pipeline-feature-list-v1': SCHEMA_TYPES.FEATURE_LIST,\n  'dev-pipeline-bug-fix-list-v1': SCHEMA_TYPES.BUG_FIX_LIST\n};\n\n/**\n * Create plan ingestion service.\n * @param {Object} options - Configuration options\n * @param {string} options.projectRoot - Project root directory\n * @param {string} [options.plansDir] - Plans directory (defaults to projectRoot/plans)\n * @returns {Object} Plan ingestion service\n */\nexport function createPlanIngestionService(options = {}) {\n  const { projectRoot, plansDir } = options;\n  const actualPlansDir = plansDir || path.join(projectRoot || process.cwd(), 'plans');\n  const pipelineDir = projectRoot ? path.join(projectRoot, 'dev-pipeline') : null;\n\n  // Cache for compiled schemas\n  const schemaCache = new Map();\n\n  // Initialize Ajv instance\n  const ajv = new Ajv({ allErrors: true, strict: false });\n\n  /**\n   * T-010: Load and compile schema by type.\n   * @param {string} type - Schema type ('feature-list' or 'bug-fix-list')\n   * @returns {Object} Compiled schema\n   */\n  function loadSchema(type) {\n    if (schemaCache.has(type)) {\n      return schemaCache.get(type);\n    }\n\n    if (!pipelineDir) {\n      throw new Error(`Cannot load schema: projectRoot not provided`);\n    }\n\n    const schemaFile = type === SCHEMA_TYPES.FEATURE_LIST\n      ? 'feature-list-schema.json'\n      : type === SCHEMA_TYPES.BUG_FIX_LIST\n        ? 'bug-fix-list-schema.json'\n        : null;\n\n    if (!schemaFile) {\n      throw new Error(`Unknown schema type: ${type}`);\n    }\n\n    const schemaPath = path.join(pipelineDir, 'templates', schemaFile);\n\n    if (!fs.existsSync(schemaPath)) {\n      throw new Error(`Schema file not found: ${schemaPath}`);\n    }\n\n    const schemaContent = JSON.parse(fs.readFileSync(schemaPath, 'utf-8'));\n    const compiled = ajv.compile(schemaContent);\n    schemaCache.set(type, compiled);\n\n    return compiled;\n  }\n\n  /**\n   * Detect plan type from $schema field.\n   * @param {Object} parsed - Parsed JSON object\n   * @returns {string|null} Plan type or null if unknown\n   */\n  function detectType(parsed) {\n    if (!parsed || typeof parsed.$schema !== 'string') {\n      return null;\n    }\n    return SCHEMA_IDENTIFIERS[parsed.$schema] || null;\n  }\n\n  /**\n   * Generate summary from validated content.\n   * @param {string} type - Plan type\n   * @param {Object} parsed - Parsed JSON object\n   * @returns {Object} Summary object\n   */\n  function generateSummary(type, parsed) {\n    const items = type === SCHEMA_TYPES.FEATURE_LIST\n      ? parsed.features || []\n      : parsed.bugs || [];\n\n    const statusBreakdown = {};\n    for (const item of items) {\n      const status = item.status || 'unknown';\n      statusBreakdown[status] = (statusBreakdown[status] || 0) + 1;\n    }\n\n    return {\n      type,\n      name: type === SCHEMA_TYPES.FEATURE_LIST\n        ? parsed.app_name || 'Unknown'\n        : parsed.project_name || 'Unknown',\n      itemCount: items.length,\n      statusBreakdown\n    };\n  }\n\n  /**\n   * T-011: Validate plan file content.\n   * @param {string} content - JSON string content\n   * @returns {Object} Validation result\n   */\n  function validate(content) {\n    // Try to parse JSON\n    let parsed;\n    try {\n      parsed = JSON.parse(content);\n    } catch (e) {\n      return {\n        valid: false,\n        type: 'unknown',\n        errors: [{\n          path: '',\n          message: `JSON 解析失败: ${e.message}`\n        }],\n        summary: null\n      };\n    }\n\n    // Detect type\n    const type = detectType(parsed);\n    if (!type) {\n      return {\n        valid: false,\n        type: 'unknown',\n        errors: [{\n          path: '$schema',\n          message: '无法识别的 schema 类型，必须是 dev-pipeline-feature-list-v1 或 dev-pipeline-bug-fix-list-v1'\n        }],\n        summary: null\n      };\n    }\n\n    // Load and validate against schema\n    const schema = loadSchema(type);\n    const valid = schema(parsed);\n\n    if (valid) {\n      return {\n        valid: true,\n        type,\n        errors: [],\n        summary: generateSummary(type, parsed)\n      };\n    }\n\n    // Convert Ajv errors to user-friendly format\n    const errors = (schema.errors || []).map(err => ({\n      path: err.instancePath || err.schemaPath || '',\n      message: formatAjvError(err)\n    }));\n\n    return {\n      valid: false,\n      type,\n      errors,\n      summary: null\n    };\n  }\n\n  /**\n   * Format a single Ajv error to user-friendly message.\n   * @param {Object} err - Ajv error object\n   * @returns {string} Formatted message\n   */\n  function formatAjvError(err) {\n    const path = err.instancePath || '';\n    const keyword = err.keyword;\n    const message = err.message || '';\n\n    switch (keyword) {\n      case 'required':\n        return `缺少必填字段 ${err.params?.missingProperty || ''}`;\n      case 'pattern':\n        return `格式不正确，期望: ${err.params?.pattern || ''}`;\n      case 'minimum':\n        return `值必须 >= ${err.params?.limit || 0}`;\n      case 'enum':\n        return `必须是以下值之一: ${(err.params?.allowedValues || []).join(', ')}`;\n      case 'minItems':\n        return `至少需要 ${err.params?.limit || 1} 个元素`;\n      case 'minLength':\n        return `长度至少为 ${err.params?.limit || 1}`;\n      default:\n        return message || '校验失败';\n    }\n  }\n\n  /**\n   * T-014: Format validation errors for display.\n   * @param {Array} errors - Array of error objects\n   * @returns {string} Formatted error string\n   */\n  function formatValidationErrors(errors) {\n    const lines = ['❌ 校验失败:', ''];\n\n    for (const err of errors) {\n      const pathDisplay = err.path ? `${err.path}: ` : '';\n      lines.push(`• ${pathDisplay}${err.message}`);\n    }\n\n    return lines.join('\\n');\n  }\n\n  /**\n   * Generate version string from timestamp.\n   * @returns {string} Version string like 'v20260312-143052'\n   */\n  function generateVersion() {\n    const now = new Date();\n    const year = now.getFullYear();\n    const month = String(now.getMonth() + 1).padStart(2, '0');\n    const day = String(now.getDate()).padStart(2, '0');\n    const hour = String(now.getHours()).padStart(2, '0');\n    const minute = String(now.getMinutes()).padStart(2, '0');\n    const second = String(now.getSeconds()).padStart(2, '0');\n    return `v${year}${month}${day}-${hour}${minute}${second}`;\n  }\n\n  /**\n   * T-012: Save plan version.\n   * @param {string} type - Plan type\n   * @param {string} content - JSON content\n   * @param {Object} meta - Metadata (uploadedBy, etc.)\n   * @returns {Promise<Object>} Save result\n   */\n  async function save(type, content, meta = {}) {\n    const version = generateVersion();\n    const typeDir = path.join(actualPlansDir, type);\n\n    // Ensure directory exists\n    fs.mkdirSync(typeDir, { recursive: true });\n\n    const filePath = path.join(typeDir, `${version}.json`);\n\n    // Add metadata header\n    const parsed = JSON.parse(content);\n    const versionedContent = {\n      _version: version,\n      _timestamp: new Date().toISOString(),\n      _uploadedBy: meta.uploadedBy || null,\n      ...parsed\n    };\n\n    fs.writeFileSync(filePath, JSON.stringify(versionedContent, null, 2), 'utf-8');\n\n    return {\n      success: true,\n      version\n    };\n  }\n\n  /**\n   * T-012: List all versions for a plan type.\n   * @param {string} type - Plan type\n   * @returns {Promise<Array>} Version list\n   */\n  async function listVersions(type) {\n    const typeDir = path.join(actualPlansDir, type);\n\n    if (!fs.existsSync(typeDir)) {\n      return [];\n    }\n\n    const files = fs.readdirSync(typeDir)\n      .filter(f => f.match(/^v\\d{8}-\\d{6}\\.json$/))\n      .sort()\n      .reverse(); // Most recent first\n\n    return files.map(f => {\n      const filePath = path.join(typeDir, f);\n      const stat = fs.statSync(filePath);\n      const version = f.replace('.json', '');\n\n      // Try to read itemCount from file\n      let itemCount = 0;\n      try {\n        const content = JSON.parse(fs.readFileSync(filePath, 'utf-8'));\n        itemCount = content.features?.length || content.bugs?.length || 0;\n      } catch {\n        // Ignore parse errors\n      }\n\n      return {\n        version,\n        timestamp: stat.mtime,\n        size: stat.size,\n        itemCount\n      };\n    });\n  }\n\n  /**\n   * T-012: Get content of a specific version.\n   * @param {string} type - Plan type\n   * @param {string} version - Version string\n   * @returns {Promise<string|null>} Content or null if not found\n   */\n  async function getVersion(type, version) {\n    const filePath = path.join(actualPlansDir, type, `${version}.json`);\n\n    if (!fs.existsSync(filePath)) {\n      return null;\n    }\n\n    return fs.readFileSync(filePath, 'utf-8');\n  }\n\n  /**\n   * Get path to _current.json file.\n   * @param {string} type - Plan type\n   * @returns {string} Path to _current.json\n   */\n  function getCurrentFilePath(type) {\n    return path.join(actualPlansDir, type, '_current.json');\n  }\n\n  /**\n   * T-013: Set current version.\n   * @param {string} type - Plan type\n   * @param {string} version - Version to set as current\n   * @returns {Promise<boolean>} Success\n   */\n  async function setCurrent(type, version) {\n    const filePath = path.join(actualPlansDir, type, `${version}.json`);\n\n    if (!fs.existsSync(filePath)) {\n      return false;\n    }\n\n    const currentPath = getCurrentFilePath(type);\n    const currentData = {\n      version,\n      activatedAt: new Date().toISOString(),\n      path: filePath\n    };\n\n    fs.writeFileSync(currentPath, JSON.stringify(currentData, null, 2), 'utf-8');\n\n    return true;\n  }\n\n  /**\n   * T-013: Get current version info.\n   * @param {string} type - Plan type\n   * @returns {Promise<Object|null>} Current version info or null\n   */\n  async function getCurrent(type) {\n    const currentPath = getCurrentFilePath(type);\n\n    if (!fs.existsSync(currentPath)) {\n      return null;\n    }\n\n    try {\n      const data = JSON.parse(fs.readFileSync(currentPath, 'utf-8'));\n      return data;\n    } catch {\n      return null;\n    }\n  }\n\n  /**\n   * T-013: Rollback to previous version.\n   * @param {string} type - Plan type\n   * @returns {Promise<Object|null>} Rollback result or null if no previous\n   */\n  async function rollback(type) {\n    const versions = await listVersions(type);\n    const current = await getCurrent(type);\n\n    if (!current || versions.length < 2) {\n      return null;\n    }\n\n    // Find current version index\n    const currentIndex = versions.findIndex(v => v.version === current.version);\n\n    if (currentIndex === -1 || currentIndex >= versions.length - 1) {\n      return null;\n    }\n\n    // Get previous version\n    const previousVersion = versions[currentIndex + 1];\n    const success = await setCurrent(type, previousVersion.version);\n\n    if (!success) {\n      return null;\n    }\n\n    return {\n      previousVersion: current.version,\n      currentVersion: previousVersion.version\n    };\n  }\n\n  /**\n   * T-013: Get active plan file path.\n   * @param {string} type - Plan type\n   * @returns {string|null} Path to active plan file\n   */\n  function getActivePath(type) {\n    const currentPath = getCurrentFilePath(type);\n\n    if (!fs.existsSync(currentPath)) {\n      return null;\n    }\n\n    try {\n      const data = JSON.parse(fs.readFileSync(currentPath, 'utf-8'));\n      return data.path || null;\n    } catch {\n      return null;\n    }\n  }\n\n  return {\n    // T-010: Schema loader\n    loadSchema,\n\n    // T-011: Validator\n    validate,\n\n    // T-014: Error formatting\n    formatValidationErrors,\n\n    // T-012: Version manager\n    save,\n    listVersions,\n    getVersion,\n\n    // T-013: Plan registry\n    setCurrent,\n    getCurrent,\n    rollback,\n    getActivePath\n  };\n}\n\n// Create default instance with project root\nconst defaultProjectRoot = process.cwd();\nconst defaultService = createPlanIngestionService({ projectRoot: defaultProjectRoot });\n\n// Export convenience functions that use default service\nexport function validatePlanFile(content) {\n  return defaultService.validate(content);\n}\n\nexport function formatValidationErrors(errors) {\n  return defaultService.formatValidationErrors(errors);\n}\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/plan-ingestion-service.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":57525,"output_tokens":3165,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_755432d442994e7e934f6334","__timestamp":"2026-03-11T19:21:49.544Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
