peline/);\n  86→      assert.equal(error.code, 'CONFIG_MISSING');\n  87→      return true;\n  88→    }\n  89→  );\n  90→});\n  91→\n  92→// T-003: plansDir configuration tests\n  93→test('loadPipelineInfraConfig should include plansDir with default value', () => {\n  94→  const projectRoot = createTempProjectRoot();\n  95→  const config = loadPipelineInfraConfig({ env: {}, cwd: projectRoot, argv: [] });\n  96→\n  97→  assert.equal(config.plansDir, path.join(projectRoot, 'plans'));\n  98→});\n  99→\n 100→test('loadPipelineInfraConfig should support PLANS_DIR env override', () => {\n 101→  const projectRoot = createTempProjectRoot();\n 102→  const config = loadPipelineInfraConfig({\n 103→    cwd: projectRoot,\n 104→    env: { PLANS_DIR: '/custom/plans' },\n 105→    argv: []\n 106→  });\n 107→\n 108→  assert.equal(config.plansDir, '/custom/plans');\n 109→});\n 110→\n 111→test('loadPipelineInfraConfig should support --plans-dir argv override', () => {\n 112→  const projectRoot = createTempProjectRoot();\n 113→  const config = loadPipelineInfraConfig({\n 114→    cwd: projectRoot,\n 115→    env: {},\n 116→    argv: ['--plans-dir', '/argv/plans']\n 117→  });\n 118→\n 119→  assert.equal(config.plansDir, '/argv/plans');\n 120→});\n 121→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_755432d442994e7e934f6334","__timestamp":"2026-03-11T19:19:17.104Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
