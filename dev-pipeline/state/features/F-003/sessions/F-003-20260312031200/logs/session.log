{"type":"user","uuid":"6c27c6cb-ceaf-4e49-82b2-eee1cbde2b1e","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde61046b2df211ac1c2d56feb3ce","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import os from 'node:os';\n   4→import path from 'node:path';\n   5→import fs from 'node:fs';\n   6→\n   7→import { loadPipelineInfraConfig } from '../../src/pipeline-infra/config-loader.js';\n   8→\n   9→function createTempProjectRoot() {\n  10→  const root = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-infra-'));\n  11→  fs.mkdirSync(path.join(root, 'dev-pipeline'), { recursive: true });\n  12→  return root;\n  13→}\n  14→\n  15→test('loadPipelineInfraConfig should load defaults from cwd', () => {\n  16→  const projectRoot = createTempProjectRoot();\n  17→  const config = loadPipelineInfraConfig({ env: {}, cwd: projectRoot, argv: [] });\n  18→\n  19→  assert.equal(config.projectRoot, projectRoot);\n  20→  assert.equal(config.pipelineDir, path.join(projectRoot, 'dev-pipeline'));\n  21→  assert.equal(config.featureListPath, path.join(projectRoot, 'feature-list.json'));\n  22→  assert.equal(config.bugFixListPath, path.join(projectRoot, 'bug-fix-list.json'));\n  23→  assert.equal(config.stateDir, path.join(projectRoot, 'dev-pipeline/state'));\n  24→  assert.equal(config.bugfixStateDir, path.join(projectRoot, 'dev-pipeline/bugfix-state'));\n  25→  assert.equal(config.maxRetries, 3);\n  26→  assert.equal(config.sessionTimeoutSec, 0);\n  27→  assert.equal(config.heartbeatIntervalSec, 30);\n  28→  assert.equal(config.aiCli, 'cbc');\n  29→  assert.equal(config.platform, 'codebuddy');\n  30→});\n  31→\n  32→test('loadPipelineInfraConfig should parse env and argv overrides', () => {\n  33→  const projectRoot = createTempProjectRoot();\n  34→  const config = loadPipelineInfraConfig({\n  35→    cwd: '/should-not-be-used',\n  36→    argv: ['--project-root', projectRoot, '--heartbeat-interval', '15'],\n  37→    env: {\n  38→      FEATURE_LIST_PATH: '/tmp/custom-feature-list.json',\n  39→      BUG_FIX_LIST_PATH: '/tmp/custom-bug-list.json',\n  40→      MAX_RETRIES: '7',\n  41→      SESSION_TIMEOUT: '120',\n  42→      AI_CLI: 'claude'\n  43→    }\n  44→  });\n  45→\n  46→  assert.equal(config.projectRoot, projectRoot);\n  47→  assert.equal(config.featureListPath, '/tmp/custom-feature-list.json');\n  48→  assert.equal(config.bugFixListPath, '/tmp/custom-bug-list.json');\n  49→  assert.equal(config.maxRetries, 7);\n  50→  assert.equal(config.sessionTimeoutSec, 120);\n  51→  assert.equal(config.heartbeatIntervalSec, 15);\n  52→  assert.equal(config.aiCli, 'claude');\n  53→  assert.equal(config.platform, 'claude');\n  54→});\n  55→\n  56→test('loadPipelineInfraConfig should throw readable errors for invalid values', () => {\n  57→  const projectRoot = createTempProjectRoot();\n  58→\n  59→  assert.throws(\n  60→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: { MAX_RETRIES: '0' } }),\n  61→    (error) => {\n  62→      assert.match(error.message, /MAX_RETRIES/);\n  63→      assert.match(error.message, /hint/i);\n  64→      assert.equal(error.code, 'CONFIG_INVALID');\n  65→      return true;\n  66→    }\n  67→  );\n  68→\n  69→  assert.throws(\n  70→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: { PRIZMKIT_PLATFORM: 'invalid' } }),\n  71→    (error) => {\n  72→      assert.match(error.message, /PRIZMKIT_PLATFORM/);\n  73→      assert.equal(error.code, 'CONFIG_INVALID');\n  74→      return true;\n  75→    }\n  76→  );\n  77→});\n  78→\n  79→test('loadPipelineInfraConfig should fail when dev-pipeline directory is missing', () => {\n  80→  const projectRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-no-pipeline-'));\n  81→\n  82→  assert.throws(\n  83→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: {}, argv: [] }),\n  84→    (error) => {\n  85→      assert.match(error.message, /dev-pipeline/);\n  86→      assert.equal(error.code, 'CONFIG_MISSING');\n  87→      return true;\n  88→    }\n  89→  );\n  90→});\n  91→\n  92→// T-003: plansDir configuration tests\n  93→test('loadPipelineInfraConfig should include plansDir with default value', () => {\n  94→  const projectRoot = createTempProjectRoot();\n  95→  const config = loadPipelineInfraConfig({ env: {}, cwd: projectRoot, argv: [] });\n  96→\n  97→  assert.equal(config.plansDir, path.join(projectRoot, 'plans'));\n  98→});\n  99→\n 100→test('loadPipelineInfraConfig should support PLANS_DIR env override', () => {\n 101→  const projectRoot = createTempProjectRoot();\n 102→  const config = loadPipelineInfraConfig({\n 103→    cwd: projectRoot,\n 104→    env: { PLANS_DIR: '/custom/plans' },\n 105→    argv: []\n 106→  });\n 107→\n 108→  assert.equal(config.plansDir, '/custom/plans');\n 109→});\n 110→\n 111→test('loadPipelineInfraConfig should support --plans-dir argv override', () => {\n 112→  const projectRoot = createTempProjectRoot();\n 113→  const config = loadPipelineInfraConfig({\n 114→    cwd: projectRoot,\n 115→    env: {},\n 116→    argv: ['--plans-dir', '/argv/plans']\n 117→  });\n 118→\n 119→  assert.equal(config.plansDir, '/argv/plans');\n 120→});\n 121→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:30:26.746Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
