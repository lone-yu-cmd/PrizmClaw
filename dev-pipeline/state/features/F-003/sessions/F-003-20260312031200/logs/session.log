{"type":"user","uuid":"65399020-e09a-48ad-87d1-e98fd1e06389","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde5f78ac8aa393e7b5c71f7293c7","content":[{"type":"text","text":"   1→/**\n   2→ * Plan Ingestion Service\n   3→ * Manages plan file validation, versioning, and registry.\n   4→ * Implements T-010 to T-014 for F-003.\n   5→ */\n   6→\n   7→import fs from 'node:fs';\n   8→import path from 'node:path';\n   9→import Ajv from 'ajv';\n  10→\n  11→/**\n  12→ * Schema type identifiers\n  13→ * @typedef {'feature-list' | 'bug-fix-list'} PlanType\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} ValidationResult\n  18→ * @property {boolean} valid - Whether validation passed\n  19→ * @property {PlanType | 'unknown'} type - Detected plan type\n  20→ * @property {ValidationError[]} errors - Validation errors\n  21→ * @property {PlanSummary} [summary] - Content summary if valid\n  22→ */\n  23→\n  24→/**\n  25→ * @typedef {Object} ValidationError\n  26→ * @property {string} path - JSON path to the error\n  27→ * @property {string} message - Human-readable error message\n  28→ * @property {string} [keyword] - JSON Schema keyword\n  29→ */\n  30→\n  31→/**\n  32→ * @typedef {Object} PlanSummary\n  33→ * @property {PlanType} type - Plan type\n  34→ * @property {string} name - App/project name\n  35→ * @property {number} itemCount - Number of features/bugs\n  36→ * @property {Record<string, number>} statusBreakdown - Status counts\n  37→ */\n  38→\n  39→/**\n  40→ * @typedef {Object} VersionInfo\n  41→ * @property {string} version - Version identifier\n  42→ * @property {Date} timestamp - Creation timestamp\n  43→ * @property {number} size - File size in bytes\n  44→ * @property {number} itemCount - Number of items\n  45→ * @property {boolean} isValid - Whether file is valid\n  46→ */\n  47→\n  48→/**\n  49→ * @typedef {Object} SaveResult\n  50→ * @property {boolean} success - Whether save succeeded\n  51→ * @property {string} [version] - Version identifier\n  52→ * @property {string} [error] - Error message\n  53→ */\n  54→\n  55→/**\n  56→ * @typedef {Object} ActiveMeta\n  57→ * @property {string} version - Current version\n  58→ * @property {string} path - Path to current version file\n  59→ * @property {Date} lastModified - Last modification time\n  60→ * @property {number} itemCount - Number of items\n  61→ */\n  62→\n  63→/**\n  64→ * @typedef {Object} RollbackResult\n  65→ * @property {string} previousVersion - Version we rolled back from\n  66→ * @property {string} currentVersion - Version we rolled back to\n  67→ */\n  68→\n  69→/**\n  70→ * Schema mapping from $schema value to type\n  71→ */\n  72→const SCHEMA_TYPE_MAP = {\n  73→  'dev-pipeline-feature-list-v1': 'feature-list',\n  74→  'dev-pipeline-bug-fix-list-v1': 'bug-fix-list'\n  75→};\n  76→\n  77→/**\n  78→ * Schema file paths relative to project root\n  79→ */\n  80→const SCHEMA_PATHS = {\n  81→  'feature-list': 'dev-pipeline/templates/feature-list-schema.json',\n  82→  'bug-fix-list': 'dev-pipeline/templates/bug-fix-list-schema.json'\n  83→};\n  84→\n  85→/**\n  86→ * Create plan ingestion service.\n  87→ * @param {Object} config - Service configuration\n  88→ * @param {string} [config.projectRoot] - Project root directory\n  89→ * @param {string} [config.plansDir] - Plans directory (overrides projectRoot)\n  90→ * @returns {Object} Service instance\n  91→ */\n  92→export function createPlanIngestionService(config = {}) {\n  93→  const projectRoot = config.projectRoot || process.cwd();\n  94→  const plansDir = config.plansDir || path.join(projectRoot, 'plans');\n  95→\n  96→  // Cached Ajv instance and compiled schemas\n  97→  const ajv = new Ajv({ allErrors: true, strict: false });\n  98→  const compiledSchemaCache = new Map();\n  99→\n 100→  /**\n 101→   * Load and compile schema by type.\n 102→   * @param {PlanType} type - Schema type\n 103→   * @returns {Object} Schema object\n 104→   */\n 105→  function loadSchema(type) {\n 106→    // Check if we have a valid schema type first\n 107→    if (!SCHEMA_PATHS[type]) {\n 108→      throw new Error(`Unknown schema type: ${type}`);\n 109→    }\n 110→\n 111→    const schemaPath = path.join(projectRoot, SCHEMA_PATHS[type]);\n 112→    if (!fs.existsSync(schemaPath)) {\n 113→      throw new Error(`Schema file not found for type: ${type}`);\n 114→    }\n 115→\n 116→    const schemaContent = fs.readFileSync(schemaPath, 'utf-8');\n 117→    return JSON.parse(schemaContent);\n 118→  }\n 119→\n 120→  /**\n 121→   * Get compiled validator for schema type (internal).\n 122→   * @param {PlanType} type - Schema type\n 123→   * @returns {Function} Compiled validator function\n 124→   */\n 125→  function getCompiledValidator(type) {\n 126→    if (compiledSchemaCache.has(type)) {\n 127→      return compiledSchemaCache.get(type);\n 128→    }\n 129→\n 130→    const schema = loadSchema(type);\n 131→    const compiled = ajv.compile(schema);\n 132→    compiledSchemaCache.set(type, compiled);\n 133→    return compiled;\n 134→  }\n 135→\n 136→  /**\n 137→   * Detect plan type from $schema field.\n 138→   * @param {Object} parsed - Parsed JSON content\n 139→   * @returns {PlanType | 'unknown'}\n 140→   */\n 141→  function detectType(parsed) {\n 142→    if (!parsed || typeof parsed !== 'object') {\n 143→      return 'unknown';\n 144→    }\n 145→\n 146→    const schemaValue = parsed.$schema;\n 147→    if (typeof schemaValue !== 'string') {\n 148→      return 'unknown';\n 149→    }\n 150→\n 151→    return SCHEMA_TYPE_MAP[schemaValue] || 'unknown';\n 152→  }\n 153→\n 154→  /**\n 155→   * Generate summary from parsed content.\n 156→   * @param {PlanType} type - Plan type\n 157→   * @param {Object} parsed - Parsed content\n 158→   * @returns {PlanSummary}\n 159→   */\n 160→  function generateSummary(type, parsed) {\n 161→    const name = type === 'feature-list' ? parsed.app_name : parsed.project_name;\n 162→    const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 163→    const itemCount = Array.isArray(items) ? items.length : 0;\n 164→\n 165→    const statusBreakdown = {};\n 166→    if (Array.isArray(items)) {\n 167→      for (const item of items) {\n 168→        const status = item.status || 'unknown';\n 169→        statusBreakdown[status] = (statusBreakdown[status] || 0) + 1;\n 170→      }\n 171→    }\n 172→\n 173→    return { type, name: name || 'Unknown', itemCount, statusBreakdown };\n 174→  }\n 175→\n 176→  /**\n 177→   * Convert Ajv errors to ValidationError format.\n 178→   * @param {Array} ajvErrors - Ajv error objects\n 179→   * @returns {ValidationError[]}\n 180→   */\n 181→  function convertAjvErrors(ajvErrors) {\n 182→    if (!Array.isArray(ajvErrors)) {\n 183→      return [];\n 184→    }\n 185→\n 186→    return ajvErrors.map((err) => ({\n 187→      path: err.instancePath || err.schemaPath || '/',\n 188→      message: err.message || 'Validation error',\n 189→      keyword: err.keyword\n 190→    }));\n 191→  }\n 192→\n 193→  /**\n 194→   * Validate plan content.\n 195→   * @param {string} content - JSON string content\n 196→   * @returns {ValidationResult}\n 197→   */\n 198→  function validate(content) {\n 199→    // Try to parse JSON\n 200→    let parsed;\n 201→    try {\n 202→      parsed = JSON.parse(content);\n 203→    } catch (e) {\n 204→      return {\n 205→        valid: false,\n 206→        type: 'unknown',\n 207→        errors: [{ path: '/', message: `Invalid JSON: ${e.message}` }]\n 208→      };\n 209→    }\n 210→\n 211→    // Detect type\n 212→    const type = detectType(parsed);\n 213→    if (type === 'unknown') {\n 214→      return {\n 215→        valid: false,\n 216→        type: 'unknown',\n 217→        errors: [{ path: '/$schema', message: 'Unknown or missing $schema field' }]\n 218→      };\n 219→    }\n 220→\n 221→    // Load and run schema validation\n 222→    const validator = getCompiledValidator(type);\n 223→    const valid = validator(parsed);\n 224→\n 225→    if (!valid) {\n 226→      return {\n 227→        valid: false,\n 228→        type,\n 229→        errors: convertAjvErrors(validator.errors)\n 230→      };\n 231→    }\n 232→\n 233→    // Generate summary\n 234→    const summary = generateSummary(type, parsed);\n 235→\n 236→    return { valid: true, type, errors: [], summary };\n 237→  }\n 238→\n 239→  /**\n 240→   * Format validation errors for display.\n 241→   * @param {ValidationError[]} errors - Validation errors\n 242→   * @returns {string} Formatted error message\n 243→   */\n 244→  function formatValidationErrors(errors) {\n 245→    if (!Array.isArray(errors) || errors.length === 0) {\n 246→      return '';\n 247→    }\n 248→\n 249→    const lines = ['\\u274c \\u6821\\u9a8c\\u5931\\u8d25:'];\n 250→\n 251→    for (const error of errors) {\n 252→      const path = error.path || '/';\n 253→      const message = error.message || 'Unknown error';\n 254→      lines.push(`\\u2022 ${path}: ${message}`);\n 255→    }\n 256→\n 257→    return lines.join('\\n');\n 258→  }\n 259→\n 260→  /**\n 261→   * Get type directory path.\n 262→   * @param {PlanType} type - Plan type\n 263→   * @returns {string}\n 264→   */\n 265→  function getTypeDir(type) {\n 266→    return path.join(plansDir, type);\n 267→  }\n 268→\n 269→  /**\n 270→   * Generate version string from timestamp.\n 271→   * @param {Date} date - Timestamp\n 272→   * @returns {string} Version string like v20260312-143052\n 273→   */\n 274→  function generateVersion(date = new Date()) {\n 275→    const pad = (n) => String(n).padStart(2, '0');\n 276→    const year = date.getFullYear();\n 277→    const month = pad(date.getMonth() + 1);\n 278→    const day = pad(date.getDate());\n 279→    const hour = pad(date.getHours());\n 280→    const minute = pad(date.getMinutes());\n 281→    const second = pad(date.getSeconds());\n 282→    return `v${year}${month}${day}-${hour}${minute}${second}`;\n 283→  }\n 284→\n 285→  /**\n 286→   * Ensure type directory exists.\n 287→   * @param {PlanType} type - Plan type\n 288→   */\n 289→  function ensureTypeDir(type) {\n 290→    const typeDir = getTypeDir(type);\n 291→    fs.mkdirSync(typeDir, { recursive: true });\n 292→  }\n 293→\n 294→  /**\n 295→   * Save plan content as new version.\n 296→   * @param {PlanType} type - Plan type\n 297→   * @param {string} content - JSON content\n 298→   * @param {Object} meta - Upload metadata\n 299→   * @param {number} meta.uploadedBy - User ID who uploaded\n 300→   * @returns {Promise<SaveResult>}\n 301→   */\n 302→  async function save(type, content, meta = {}) {\n 303→    try {\n 304→      ensureTypeDir(type);\n 305→\n 306→      const version = generateVersion();\n 307→      const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 308→\n 309→      // Count items\n 310→      let itemCount = 0;\n 311→      try {\n 312→        const parsed = JSON.parse(content);\n 313→        const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 314→        itemCount = Array.isArray(items) ? items.length : 0;\n 315→      } catch {\n 316→        // Ignore parse errors, already validated\n 317→      }\n 318→\n 319→      // Write file\n 320→      fs.writeFileSync(versionPath, content, 'utf-8');\n 321→\n 322→      return { success: true, version };\n 323→    } catch (e) {\n 324→      return { success: false, error: e.message };\n 325→    }\n 326→  }\n 327→\n 328→  /**\n 329→   * List all versions for a plan type.\n 330→   * @param {PlanType} type - Plan type\n 331→   * @returns {Promise<VersionInfo[]>}\n 332→   */\n 333→  async function listVersions(type) {\n 334→    const typeDir = getTypeDir(type);\n 335→    if (!fs.existsSync(typeDir)) {\n 336→      return [];\n 337→    }\n 338→\n 339→    const files = fs.readdirSync(typeDir);\n 340→    const versions = [];\n 341→\n 342→    for (const file of files) {\n 343→      if (!file.endsWith('.json') || file === '_current.json') {\n 344→        continue;\n 345→      }\n 346→\n 347→      const match = file.match(/^(v\\d{8}-\\d{6})\\.json$/);\n 348→      if (!match) {\n 349→        continue;\n 350→      }\n 351→\n 352→      const version = match[1];\n 353→      const filePath = path.join(typeDir, file);\n 354→      const stat = fs.statSync(filePath);\n 355→\n 356→      // Try to read and count items\n 357→      let itemCount = 0;\n 358→      let isValid = true;\n 359→      try {\n 360→        const content = fs.readFileSync(filePath, 'utf-8');\n 361→        const parsed = JSON.parse(content);\n 362→        const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 363→        itemCount = Array.isArray(items) ? items.length : 0;\n 364→      } catch {\n 365→        isValid = false;\n 366→      }\n 367→\n 368→      versions.push({\n 369→        version,\n 370→        timestamp: stat.mtime,\n 371→        size: stat.size,\n 372→        itemCount,\n 373→        isValid\n 374→      });\n 375→    }\n 376→\n 377→    // Sort by version descending (newest first)\n 378→    versions.sort((a, b) => b.version.localeCompare(a.version));\n 379→\n 380→    return versions;\n 381→  }\n 382→\n 383→  /**\n 384→   * Get content of a specific version.\n 385→   * @param {PlanType} type - Plan type\n 386→   * @param {string} version - Version identifier\n 387→   * @returns {Promise<string | null>}\n 388→   */\n 389→  async function getVersion(type, version) {\n 390→    const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 391→    if (!fs.existsSync(versionPath)) {\n 392→      return null;\n 393→    }\n 394→    return fs.readFileSync(versionPath, 'utf-8');\n 395→  }\n 396→\n 397→  /**\n 398→   * Get path to _current.json file.\n 399→   * @param {PlanType} type - Plan type\n 400→   * @returns {string}\n 401→   */\n 402→  function getCurrentMetaPath(type) {\n 403→    return path.join(getTypeDir(type), '_current.json');\n 404→  }\n 405→\n 406→  /**\n 407→   * Set the current active version.\n 408→   * @param {PlanType} type - Plan type\n 409→   * @param {string} version - Version to activate\n 410→   * @returns {Promise<boolean>}\n 411→   */\n 412→  async function setCurrent(type, version) {\n 413→    // Verify version exists\n 414→    const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 415→    if (!fs.existsSync(versionPath)) {\n 416→      return false;\n 417→    }\n 418→\n 419→    // Read content to get item count\n 420→    let itemCount = 0;\n 421→    try {\n 422→      const content = fs.readFileSync(versionPath, 'utf-8');\n 423→      const parsed = JSON.parse(content);\n 424→      const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 425→      itemCount = Array.isArray(items) ? items.length : 0;\n 426→    } catch {\n 427→      // Ignore\n 428→    }\n 429→\n 430→    // Write _current.json\n 431→    const currentMeta = {\n 432→      version,\n 433→      activatedAt: new Date().toISOString(),\n 434→      path: versionPath,\n 435→      itemCount\n 436→    };\n 437→\n 438→    const currentMetaPath = getCurrentMetaPath(type);\n 439→    fs.writeFileSync(currentMetaPath, JSON.stringify(currentMeta, null, 2), 'utf-8');\n 440→\n 441→    return true;\n 442→  }\n 443→\n 444→  /**\n 445→   * Get current active version metadata.\n 446→   * @param {PlanType} type - Plan type\n 447→   * @returns {Promise<ActiveMeta | null>}\n 448→   */\n 449→  async function getCurrent(type) {\n 450→    const currentMetaPath = getCurrentMetaPath(type);\n 451→    if (!fs.existsSync(currentMetaPath)) {\n 452→      return null;\n 453→    }\n 454→\n 455→    try {\n 456→      const content = fs.readFileSync(currentMetaPath, 'utf-8');\n 457→      const meta = JSON.parse(content);\n 458→\n 459→      return {\n 460→        version: meta.version,\n 461→        path: meta.path,\n 462→        lastModified: new Date(meta.activatedAt),\n 463→        itemCount: meta.itemCount || 0\n 464→      };\n 465→    } catch {\n 466→      return null;\n 467→    }\n 468→  }\n 469→\n 470→  /**\n 471→   * Get path to the current active version file.\n 472→   * @param {PlanType} type - Plan type\n 473→   * @returns {string | null}\n 474→   */\n 475→  function getActivePath(type) {\n 476→    const currentMetaPath = getCurrentMetaPath(type);\n 477→    if (!fs.existsSync(currentMetaPath)) {\n 478→      return null;\n 479→    }\n 480→\n 481→    try {\n 482→      const content = fs.readFileSync(currentMetaPath, 'utf-8');\n 483→      const meta = JSON.parse(content);\n 484→      return meta.path || null;\n 485→    } catch {\n 486→      return null;\n 487→    }\n 488→  }\n 489→\n 490→  /**\n 491→   * Rollback to previous version.\n 492→   * @param {PlanType} type - Plan type\n 493→   * @returns {Promise<RollbackResult | null>}\n 494→   */\n 495→  async function rollback(type) {\n 496→    const versions = await listVersions(type);\n 497→    if (versions.length < 2) {\n 498→      return null;\n 499→    }\n 500→\n 501→    const current = await getCurrent(type);\n 502→    if (!current) {\n 503→      return null;\n 504→    }\n 505→\n 506→    // Find current version index\n 507→    const currentIndex = versions.findIndex((v) => v.version === current.version);\n 508→    if (currentIndex === -1 || currentIndex >= versions.length - 1) {\n 509→      return null;\n 510→    }\n 511→\n 512→    // Get previous version\n 513→    const previousVersion = versions[currentIndex + 1];\n 514→    if (!previousVersion) {\n 515→      return null;\n 516→    }\n 517→\n 518→    // Set previous as current\n 519→    const success = await setCurrent(type, previousVersion.version);\n 520→    if (!success) {\n 521→      return null;\n 522→    }\n 523→\n 524→    return {\n 525→      previousVersion: current.version,\n 526→      currentVersion: previousVersion.version\n 527→    };\n 528→  }\n 529→\n 530→  return {\n 531→    loadSchema,\n 532→    validate,\n 533→    formatValidationErrors,\n 534→    save,\n 535→    listVersions,\n 536→    getVersion,\n 537→    setCurrent,\n 538→    getCurrent,\n 539→    getActivePath,\n 540→    rollback\n 541→  };\n 542→}\n 543→\n 544→export default createPlanIngestionService;\n 545→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:28:46.928Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
{"type":"user","uuid":"820c13c4-7d78-41f6-848b-228f31422ab6","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde5f7a5f5e256d8287087e36494f","content":[{"type":"text","text":"   1→/**\n   2→ * Plan Command Handler\n   3→ * Handles /plan command with status/versions/use/rollback/validate subcommands.\n   4→ *\n   5→ * Implements:\n   6→ * - T-101: /plan upload hint\n   7→ * - T-102: /plan versions command\n   8→ * - T-103: /plan use command\n   9→ * - T-104: /plan status command\n  10→ * - T-105: /plan rollback command\n  11→ * - T-106: /plan validate command\n  12→ */\n  13→\n  14→import { createPlanIngestionService } from '../../../services/plan-ingestion-service.js';\n  15→import { loadPipelineInfraConfig } from '../../../pipeline-infra/config-loader.js';\n  16→\n  17→// Valid plan types\n  18→const PLAN_TYPES = ['feature-list', 'bug-fix-list'];\n  19→\n  20→/**\n  21→ * Get plan service instance.\n  22→ * @returns {Object} Plan ingestion service\n  23→ */\n  24→function getPlanService() {\n  25→  const config = loadPipelineInfraConfig();\n  26→  return createPlanIngestionService({ plansDir: config.plansDir });\n  27→}\n  28→\n  29→/**\n  30→ * Validate and normalize plan type.\n  31→ * @param {string} type - Input type string\n  32→ * @returns {string|null} Normalized type or null if invalid\n  33→ */\n  34→function normalizePlanType(type) {\n  35→  if (!type) return null;\n  36→  const normalized = type.toLowerCase().trim();\n  37→  if (normalized === 'feature' || normalized === 'feature-list') return 'feature-list';\n  38→  if (normalized === 'bug' || normalized === 'bugfix' || normalized === 'bug-fix-list') return 'bug-fix-list';\n  39→  return null;\n  40→}\n  41→\n  42→/**\n  43→ * Format version info for display.\n  44→ * @param {Object} version - Version info object\n  45→ * @param {string} currentVersion - Current active version\n  46→ * @returns {string} Formatted string\n  47→ */\n  48→function formatVersionInfo(version, currentVersion) {\n  49→  const isCurrent = version.version === currentVersion;\n  50→  const marker = isCurrent ? ' ← 当前' : '';\n  51→  const time = version.timestamp?.toLocaleString?.() || version.version;\n  52→  return `• ${version.version}${marker} (${version.itemCount} 项)`;\n  53→}\n  54→\n  55→/**\n  56→ * Plan command metadata.\n  57→ */\n  58→export const planMeta = {\n  59→  name: 'plan',\n  60→  aliases: ['p'],\n  61→  description: '管理计划文件',\n  62→  usage: '/plan <action> [type] [version]',\n  63→  examples: [\n  64→    '/plan status',\n  65→    '/plan status feature-list',\n  66→    '/plan versions feature-list',\n  67→    '/plan use feature-list v20260312-143052',\n  68→    '/plan rollback feature-list'\n  69→  ],\n  70→  subcommands: [\n  71→    { name: 'status', description: '查看计划状态' },\n  72→    { name: 'versions', description: '列出历史版本' },\n  73→    { name: 'use', description: '切换到指定版本' },\n  74→    { name: 'rollback', description: '回滚到上一版本' },\n  75→    { name: 'validate', description: '校验计划文件' }\n  76→  ],\n  77→  params: [\n  78→    {\n  79→      name: 'type',\n  80→      type: 'enum',\n  81→      enum: ['feature-list', 'bug-fix-list'],\n  82→      required: false,\n  83→      description: '计划类型'\n  84→    },\n  85→    {\n  86→      name: 'version',\n  87→      type: 'string',\n  88→      required: false,\n  89→      description: '版本号'\n  90→    }\n  91→  ],\n  92→  requiresAuth: true,\n  93→  helpText: '/plan <action> [type] [version] - 管理计划文件'\n  94→};\n  95→\n  96→/**\n  97→ * Handle plan command.\n  98→ * @param {Object} handlerCtx - Handler context\n  99→ */\n 100→export async function handlePlan(handlerCtx) {\n 101→  const { ctx, parsed, params, reply } = handlerCtx;\n 102→\n 103→  // Determine action from subcommand or default to help (T-101)\n 104→  const action = parsed.subcommand || null;\n 105→\n 106→  switch (action) {\n 107→    case 'status':\n 108→      return handleStatus(handlerCtx);\n 109→    case 'versions':\n 110→      return handleVersions(handlerCtx);\n 111→    case 'use':\n 112→      return handleUse(handlerCtx);\n 113→    case 'rollback':\n 114→      return handleRollback(handlerCtx);\n 115→    case 'validate':\n 116→      return handleValidate(handlerCtx);\n 117→    default:\n 118→      // T-101: Show upload hint\n 119→      await reply([\n 120→        '📋 计划文件管理',\n 121→        '',\n 122→        '上传计划文件：',\n 123→        '直接发送 JSON 文件到本对话即可自动识别并保存。',\n 124→        '',\n 125→        '可用命令：',\n 126→        '• /plan status [type] - 查看当前计划状态',\n 127→        '• /plan versions <type> - 列出历史版本',\n 128→        '• /plan use <type> <version> - 切换到指定版本',\n 129→        '• /plan rollback <type> - 回滚到上一版本',\n 130→        '• /plan validate - 校验当前发送的文件'\n 131→      ].join('\\n'));\n 132→  }\n 133→}\n 134→\n 135→/**\n 136→ * T-104: Handle status subcommand.\n 137→ */\n 138→async function handleStatus({ params, reply, parsed }) {\n 139→  const service = getPlanService();\n 140→  const typeArg = params._args?.[0] || params.type;\n 141→  const type = normalizePlanType(typeArg);\n 142→\n 143→  // If no type specified, show both\n 144→  if (!type) {\n 145→    const featureStatus = await getStatusForType(service, 'feature-list');\n 146→    const bugStatus = await getStatusForType(service, 'bug-fix-list');\n 147→\n 148→    const lines = ['📋 计划文件状态', ''];\n 149→    lines.push('【特性列表】');\n 150→    lines.push(featureStatus);\n 151→    lines.push('');\n 152→    lines.push('【Bug修复列表】');\n 153→    lines.push(bugStatus);\n 154→\n 155→    await reply(lines.join('\\n'));\n 156→    return;\n 157→  }\n 158→\n 159→  // Show specific type\n 160→  const status = await getStatusForType(service, type);\n 161→  await reply(`📋 ${type === 'feature-list' ? '特性列表' : 'Bug修复列表'} 状态\\n\\n${status}`);\n 162→}\n 163→\n 164→/**\n 165→ * Get status string for a plan type.\n 166→ */\n 167→async function getStatusForType(service, type) {\n 168→  const current = await service.getCurrent(type);\n 169→\n 170→  if (!current) {\n 171→    return '暂无激活的计划文件';\n 172→  }\n 173→\n 174→  const versions = await service.listVersions(type);\n 175→  const versionInfo = versions.find(v => v.version === current.version);\n 176→\n 177→  const lines = [\n 178→    `版本: ${current.version}`,\n 179→    `项目数: ${versionInfo?.itemCount || '未知'}`,\n 180→    `激活时间: ${current.activatedAt || '未知'}`\n 181→  ];\n 182→\n 183→  return lines.join('\\n');\n 184→}\n 185→\n 186→/**\n 187→ * T-102: Handle versions subcommand.\n 188→ */\n 189→async function handleVersions({ params, reply, parsed }) {\n 190→  const service = getPlanService();\n 191→  const typeArg = params._args?.[0] || params.type;\n 192→  const type = normalizePlanType(typeArg);\n 193→\n 194→  if (!type) {\n 195→    await reply('❌ 请指定计划类型: /plan versions <feature-list|bug-fix-list>');\n 196→    return;\n 197→  }\n 198→\n 199→  const versions = await service.listVersions(type);\n 200→  const current = await service.getCurrent(type);\n 201→  const currentVersion = current?.version;\n 202→\n 203→  if (versions.length === 0) {\n 204→    await reply(`暂无历史版本。请上传 ${type === 'feature-list' ? '特性列表' : 'Bug修复列表'} JSON 文件。`);\n 205→    return;\n 206→  }\n 207→\n 208→  const lines = [\n 209→    `📜 ${type === 'feature-list' ? '特性列表' : 'Bug修复列表'} 历史版本`,\n 210→    ''\n 211→  ];\n 212→\n 213→  for (const v of versions) {\n 214→    lines.push(formatVersionInfo(v, currentVersion));\n 215→  }\n 216→\n 217→  lines.push('');\n 218→  lines.push(`共 ${versions.length} 个版本`);\n 219→\n 220→  await reply(lines.join('\\n'));\n 221→}\n 222→\n 223→/**\n 224→ * T-103: Handle use subcommand.\n 225→ */\n 226→async function handleUse({ params, reply, parsed }) {\n 227→  const service = getPlanService();\n 228→  const args = params._args || [];\n 229→\n 230→  const typeArg = args[0] || params.type;\n 231→  const versionArg = args[1] || params.version;\n 232→\n 233→  const type = normalizePlanType(typeArg);\n 234→\n 235→  if (!type) {\n 236→    await reply('❌ 用法: /plan use <feature-list|bug-fix-list> <version>');\n 237→    return;\n 238→  }\n 239→\n 240→  if (!versionArg) {\n 241→    await reply('❌ 请指定版本号。例如: /plan use feature-list v20260312-143052');\n 242→    return;\n 243→  }\n 244→\n 245→  // Normalize version (add v prefix if missing)\n 246→  const version = versionArg.startsWith('v') ? versionArg : `v${versionArg}`;\n 247→\n 248→  // Check if version exists\n 249→  const content = await service.getVersion(type, version);\n 250→  if (!content) {\n 251→    await reply(`❌ 版本 ${version} 不存在。使用 /plan versions ${type} 查看可用版本。`);\n 252→    return;\n 253→  }\n 254→\n 255→  // Set as current\n 256→  const success = await service.setCurrent(type, version);\n 257→\n 258→  if (!success) {\n 259→    await reply('❌ 切换版本失败。');\n 260→    return;\n 261→  }\n 262→\n 263→  // Parse content to get summary\n 264→  const parsedContent = JSON.parse(content);\n 265→  const itemCount = parsedContent.features?.length || parsedContent.bugs?.length || 0;\n 266→  const name = parsedContent.app_name || parsedContent.project_name || '未知';\n 267→\n 268→  await reply([\n 269→    `✅ 已切换到版本 ${version}`,\n 270→    `类型: ${type === 'feature-list' ? '特性列表' : 'Bug修复列表'}`,\n 271→    `名称: ${name}`,\n 272→    `项目数: ${itemCount}`\n 273→  ].join('\\n'));\n 274→}\n 275→\n 276→/**\n 277→ * T-105: Handle rollback subcommand.\n 278→ * Maps to US-3 Version Management.\n 279→ */\n 280→async function handleRollback({ params, reply, parsed }) {\n 281→  const service = getPlanService();\n 282→  const typeArg = params._args?.[0] || params.type;\n 283→  const type = normalizePlanType(typeArg);\n 284→\n 285→  if (!type) {\n 286→    await reply('❌ 用法: /plan rollback <feature-list|bug-fix-list>');\n 287→    return;\n 288→  }\n 289→\n 290→  const result = await service.rollback(type);\n 291→\n 292→  if (!result) {\n 293→    await reply('❌ 无法回滚：没有可回滚的上一版本。');\n 294→    return;\n 295→  }\n 296→\n 297→  await reply([\n 298→    '✅ 已回滚到上一版本',\n 299→    `原版本: ${result.previousVersion}`,\n 300→    `当前版本: ${result.currentVersion}`\n 301→  ].join('\\n'));\n 302→}\n 303→\n 304→/**\n 305→ * T-106: Handle validate subcommand.\n 306→ * Note: This is a placeholder - actual validation happens when user sends a file.\n 307→ */\n 308→async function handleValidate({ params, reply, parsed, ctx }) {\n 309→  await reply([\n 310→    '🔍 计划文件校验',\n 311→    '',\n 312→    '发送 JSON 文件到本对话即可自动校验。',\n 313→    '校验通过会显示文件摘要，校验失败会显示具体错误信息。',\n 314→    '',\n 315→    '支持的 schema 类型：',\n 316→    '• dev-pipeline-feature-list-v1',\n 317→    '• dev-pipeline-bug-fix-list-v1'\n 318→  ].join('\\n'));\n 319→}\n 320→\n 321→export default handlePlan;\n 322→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:28:46.929Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
{"type":"user","uuid":"2c23c5a6-4da3-4eae-b69d-409c7c3d6edf","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde5f7c1fb30514550a067790db20","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { captureScreenshot } from '../services/screenshot-service.js';\n  11→import { executeSystemCommand } from '../services/system-exec-service.js';\n  12→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  13→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  14→import { registerCommand } from './commands/index.js';\n  15→import { routeCommand } from './commands/index.js';\n  16→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  17→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  18→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  19→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  20→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  21→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  22→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  23→import { generateHelp } from './commands/help.js';\n  24→\n  25→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  26→const STREAM_MIN_CHARS = 220;\n  27→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  28→const TYPING_INTERVAL_MS = 3500;\n  29→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  30→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  31→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  32→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  33→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  34→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  35→const TMP_DIR = path.resolve(os.tmpdir());\n  36→const HOME_DIR = path.resolve(os.homedir());\n  37→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  38→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  39→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  40→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  41→\n  42→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  43→  const normalized = configuredDirs\n  44→    .map((dir) => String(dir ?? '').trim())\n  45→    .filter(Boolean)\n  46→    .map((dir) => path.resolve(dir));\n  47→\n  48→  if (normalized.length > 0) {\n  49→    return [...new Set(normalized)];\n  50→  }\n  51→\n  52→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  53→}\n  54→\n  55→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  56→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  57→\n  58→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  59→  const chunks = [];\n  60→  for (let i = 0; i < text.length; i += chunkSize) {\n  61→    chunks.push(text.slice(i, i + chunkSize));\n  62→  }\n  63→  return chunks;\n  64→}\n  65→\n  66→function sanitizeMarkerPath(raw) {\n  67→  return String(raw ?? '')\n  68→    .trim()\n  69→    .replace(/^['\"`]+/, '')\n  70→    .replace(/['\"`]+$/, '');\n  71→}\n  72→\n  73→function extractFileMarkers(text = '') {\n  74→  const fileRefs = [];\n  75→\n  76→  const withSendFileRemoved = text.replace(\n  77→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  78→    (_full, rawRef) => {\n  79→      const ref = sanitizeMarkerPath(rawRef);\n  80→      if (ref) {\n  81→        fileRefs.push(ref);\n  82→      }\n  83→      return '\\n';\n  84→    }\n  85→  );\n  86→\n  87→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  88→    const ref = sanitizeMarkerPath(rawRef);\n  89→    if (ref) {\n  90→      fileRefs.push(ref);\n  91→    }\n  92→    return '';\n  93→  });\n  94→\n  95→  const withBacktickPathRemoved = withImageRemoved.replace(\n  96→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n  97→    (_full, rawRef) => {\n  98→      const ref = sanitizeMarkerPath(rawRef);\n  99→      if (ref) {\n 100→        fileRefs.push(ref);\n 101→      }\n 102→      return '';\n 103→    }\n 104→  );\n 105→\n 106→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 107→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 108→    (_full, rawRef) => {\n 109→      const ref = sanitizeMarkerPath(rawRef);\n 110→      if (ref) {\n 111→        fileRefs.push(ref);\n 112→      }\n 113→      return '';\n 114→    }\n 115→  );\n 116→\n 117→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 118→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 119→    (_full, rawRef) => {\n 120→      const ref = sanitizeMarkerPath(rawRef);\n 121→      if (ref) {\n 122→        fileRefs.push(ref);\n 123→      }\n 124→      return '\\n';\n 125→    }\n 126→  );\n 127→\n 128→  return {\n 129→    fileRefs: [...new Set(fileRefs)],\n 130→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 131→  };\n 132→}\n 133→\n 134→function isPathWithinRoot(targetPath, rootPath) {\n 135→  const relative = path.relative(rootPath, targetPath);\n 136→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 137→}\n 138→\n 139→function isAllowedFilePath(filePath) {\n 140→  const resolved = path.resolve(filePath);\n 141→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 142→}\n 143→\n 144→function buildFileCandidates(normalizedPath) {\n 145→  if (path.isAbsolute(normalizedPath)) {\n 146→    return [normalizedPath];\n 147→  }\n 148→\n 149→  const baseName = path.basename(normalizedPath);\n 150→  const candidates = [\n 151→    path.resolve(process.cwd(), normalizedPath),\n 152→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 153→  ];\n 154→\n 155→  return [...new Set(candidates)];\n 156→}\n 157→\n 158→async function resolveLocalFilePath(fileRef) {\n 159→  const normalized = sanitizeMarkerPath(fileRef);\n 160→  if (!normalized) {\n 161→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 162→  }\n 163→\n 164→  if (!path.isAbsolute(normalized)) {\n 165→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 166→  }\n 167→\n 168→  const candidates = buildFileCandidates(normalized);\n 169→\n 170→  for (const candidate of candidates) {\n 171→    try {\n 172→      await access(candidate);\n 173→      return { filePath: candidate, triedPaths: candidates };\n 174→    } catch {\n 175→      // ignore\n 176→    }\n 177→  }\n 178→\n 179→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 180→}\n 181→\n 182→async function validateFileForTelegram(filePath) {\n 183→  const resolvedPath = path.resolve(filePath);\n 184→  if (!isAllowedFilePath(resolvedPath)) {\n 185→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 186→  }\n 187→\n 188→  const ext = path.extname(resolvedPath).toLowerCase();\n 189→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 190→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 191→  }\n 192→\n 193→  const fileStat = await stat(resolvedPath);\n 194→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 195→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 196→\n 197→  if (fileStat.size > maxSize) {\n 198→    return {\n 199→      ok: false,\n 200→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 201→    };\n 202→  }\n 203→\n 204→  return { ok: true, isPhoto, resolvedPath };\n 205→}\n 206→\n 207→function isTimeoutLikeError(message = '') {\n 208→  const normalized = String(message).toLowerCase();\n 209→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 210→}\n 211→\n 212→function sleep(ms) {\n 213→  return new Promise((resolve) => setTimeout(resolve, ms));\n 214→}\n 215→\n 216→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 217→  if (isPhoto) {\n 218→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 219→    return;\n 220→  }\n 221→\n 222→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 223→}\n 224→\n 225→async function replyFiles(ctx, fileRefs = []) {\n 226→  const results = [];\n 227→\n 228→  for (const fileRef of fileRefs) {\n 229→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 230→    if (!filePath) {\n 231→      const reason = rejectReason || 'not_found';\n 232→      results.push({ fileRef, sent: false, reason, triedPaths });\n 233→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 234→      continue;\n 235→    }\n 236→\n 237→    try {\n 238→      const validation = await validateFileForTelegram(filePath);\n 239→      if (!validation.ok) {\n 240→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 241→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 242→        continue;\n 243→      }\n 244→\n 245→      const actualPath = validation.resolvedPath;\n 246→      let sent = false;\n 247→      let lastReason = '';\n 248→\n 249→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 250→        try {\n 251→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 252→          sent = true;\n 253→          logger.info(\n 254→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 255→            'Telegram file sent'\n 256→          );\n 257→          break;\n 258→        } catch (error) {\n 259→          lastReason = error instanceof Error ? error.message : String(error);\n 260→          logger.warn(\n 261→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 262→            'Telegram file send attempt failed'\n 263→          );\n 264→\n 265→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 266→            await sleep(600);\n 267→            continue;\n 268→          }\n 269→\n 270→          break;\n 271→        }\n 272→      }\n 273→\n 274→      if (!sent) {\n 275→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 276→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 277→        continue;\n 278→      }\n 279→\n 280→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 281→    } catch (error) {\n 282→      const reason = error instanceof Error ? error.message : String(error);\n 283→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 284→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 285→    }\n 286→  }\n 287→\n 288→  return results;\n 289→}\n 290→\n 291→async function safeReply(ctx, text) {\n 292→  try {\n 293→    await ctx.reply(text);\n 294→    return true;\n 295→  } catch (error) {\n 296→    const reason = error instanceof Error ? error.message : String(error);\n 297→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 298→    return false;\n 299→  }\n 300→}\n 301→\n 302→async function replyLargeText(ctx, text) {\n 303→  const chunks = splitMessage(text);\n 304→  for (const chunk of chunks) {\n 305→    const ok = await safeReply(ctx, chunk);\n 306→    if (!ok) {\n 307→      break;\n 308→    }\n 309→  }\n 310→}\n 311→\n 312→async function safeEditMessageText(ctx, messageId, text) {\n 313→  const nextText = text && text.trim() ? text : ' ';\n 314→\n 315→  try {\n 316→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 317→  } catch (error) {\n 318→    const message = error instanceof Error ? error.message : String(error);\n 319→    if (message.includes('message is not modified')) {\n 320→      return;\n 321→    }\n 322→    throw error;\n 323→  }\n 324→}\n 325→\n 326→function createEditableStreamPublisher(ctx) {\n 327→  let fullText = '';\n 328→  let renderedText = '';\n 329→  let pendingChars = 0;\n 330→  let lastFlushAt = 0;\n 331→  let flushChain = Promise.resolve();\n 332→  let activeMessage = null;\n 333→  let activeSegmentIndex = 0;\n 334→  let publishedMessageCount = 0;\n 335→\n 336→  async function ensureActiveMessage() {\n 337→    if (activeMessage) {\n 338→      return;\n 339→    }\n 340→    activeMessage = await ctx.reply('处理中...');\n 341→    activeSegmentIndex = 0;\n 342→    publishedMessageCount += 1;\n 343→  }\n 344→\n 345→  async function render(force = false) {\n 346→    const now = Date.now();\n 347→\n 348→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 349→      return;\n 350→    }\n 351→\n 352→    if (fullText === renderedText) {\n 353→      pendingChars = 0;\n 354→      return;\n 355→    }\n 356→\n 357→    await ensureActiveMessage();\n 358→\n 359→    const segments = splitMessage(fullText);\n 360→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 361→\n 362→    while (activeSegmentIndex < targetLastIndex) {\n 363→      const text = segments[activeSegmentIndex] ?? ' ';\n 364→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 365→\n 366→      activeMessage = await ctx.reply('继续输出中...');\n 367→      activeSegmentIndex += 1;\n 368→      publishedMessageCount += 1;\n 369→    }\n 370→\n 371→    const activeText = segments[targetLastIndex] ?? ' ';\n 372→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 373→\n 374→    renderedText = fullText;\n 375→    pendingChars = 0;\n 376→    lastFlushAt = now;\n 377→  }\n 378→\n 379→  function enqueueRender(force = false) {\n 380→    flushChain = flushChain.then(() => render(force));\n 381→  }\n 382→\n 383→  return {\n 384→    push(text) {\n 385→      const appendText = text ?? '';\n 386→      if (!appendText) {\n 387→        return;\n 388→      }\n 389→      fullText += appendText;\n 390→      pendingChars += appendText.length;\n 391→      enqueueRender(false);\n 392→    },\n 393→    setFinalText(text) {\n 394→      fullText = text ?? '';\n 395→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 396→      enqueueRender(true);\n 397→    },\n 398→    async finish() {\n 399→      enqueueRender(true);\n 400→      await flushChain;\n 401→      return {\n 402→        outputLength: renderedText.length,\n 403→        messageCount: publishedMessageCount\n 404→      };\n 405→    }\n 406→  };\n 407→}\n 408→\n 409→function buildSessionId(ctx) {\n 410→  return String(ctx.chat.id);\n 411→}\n 412→\n 413→function ensureAllowed(ctx) {\n 414→  const userId = ctx.from?.id;\n 415→  if (!isAllowedUser(userId)) {\n 416→    throw new Error('当前账号未被授权使用该机器人。');\n 417→  }\n 418→}\n 419→\n 420→/**\n 421→ * Register all pipeline-related commands.\n 422→ */\n 423→function registerPipelineCommands() {\n 424→  registerCommand(pipelineMeta, handlePipeline);\n 425→  registerCommand(bugfixMeta, handleBugfix);\n 426→  registerCommand(plannerMeta, handlePlanner);\n 427→  registerCommand(statusMeta, handleStatus);\n 428→  registerCommand(logsMeta, handleLogs);\n 429→  registerCommand(stopMeta, handleStop);\n 430→  registerCommand(planMeta, handlePlan);\n 431→}\n 432→\n 433→export function createTelegramBot() {\n 434→  const bot = new Telegraf(config.telegramBotToken, {\n 435→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 436→  });\n 437→\n 438→  // Register pipeline commands\n 439→  registerPipelineCommands();\n 440→\n 441→  bot.catch((error, ctx) => {\n 442→    const message = error instanceof Error ? error.message : String(error);\n 443→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 444→  });\n 445→\n 446→  bot.start(async (ctx) => {\n 447→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 448→  });\n 449→\n 450→  bot.help(async (ctx) => {\n 451→    const helpText = generateHelp();\n 452→    await ctx.reply(helpText);\n 453→  });\n 454→\n 455→  bot.command('reset', async (ctx) => {\n 456→    try {\n 457→      ensureAllowed(ctx);\n 458→      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 459→      await ctx.reply('已清空当前会话上下文。');\n 460→    } catch (error) {\n 461→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 462→    }\n 463→  });\n 464→\n 465→  bot.command('screenshot', async (ctx) => {\n 466→    try {\n 467→      ensureAllowed(ctx);\n 468→      await ctx.reply('正在获取截图。');\n 469→      const { buffer } = await captureScreenshot();\n 470→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 471→    } catch (error) {\n 472→      const message = error instanceof Error ? error.message : String(error);\n 473→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 474→      await ctx.reply(`截图失败：${message}`);\n 475→    }\n 476→  });\n 477→\n 478→  bot.command('exec', async (ctx) => {\n 479→    try {\n 480→      ensureAllowed(ctx);\n 481→      const payload = ctx.message.text.replace('/exec', '').trim();\n 482→      if (!payload) {\n 483→        await ctx.reply('请提供命令，例如 /exec pwd');\n 484→        return;\n 485→      }\n 486→\n 487→      await ctx.reply('正在执行命令。');\n 488→      const result = await executeSystemCommand(payload);\n 489→      const output = [\n 490→        `exitCode: ${result.exitCode}`,\n 491→        result.stdout ? `stdout:\\n${result.stdout}` : 'stdout: (empty)',\n 492→        result.stderr ? `stderr:\\n${result.stderr}` : 'stderr: (empty)'\n 493→      ].join('\\n\\n');\n 494→\n 495→      await replyLargeText(ctx, output);\n 496→    } catch (error) {\n 497→      const message = error instanceof Error ? error.message : String(error);\n 498→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 499→      await ctx.reply(`执行失败：${message}`);\n 500→    }\n 501→  });\n 502→\n 503→  // T-100: Document upload handler for plan files\n 504→  bot.on('document', async (ctx) => {\n 505→    try {\n 506→      ensureAllowed(ctx);\n 507→\n 508→      const document = ctx.message?.document;\n 509→      if (!document) {\n 510→        return;\n 511→      }\n 512→\n 513→      // Check file extension\n 514→      const fileName = document.file_name || '';\n 515→      const ext = path.extname(fileName).toLowerCase();\n 516→\n 517→      if (ext !== '.json') {\n 518→        // Not a JSON file, ignore silently (other handlers may process it)\n 519→        return;\n 520→      }\n 521→\n 522→      // Check file size\n 523→      const fileSize = document.file_size || 0;\n 524→      if (fileSize > 1024 * 1024) { // 1MB limit\n 525→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 526→        return;\n 527→      }\n 528→\n 529→      await ctx.reply('正在处理上传的计划文件...');\n 530→\n 531→      // Download file content\n 532→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 533→      const fileUrl = fileLink.href || fileLink.toString();\n 534→\n 535→      const response = await fetch(fileUrl);\n 536→      if (!response.ok) {\n 537→        throw new Error(`下载文件失败: ${response.status}`);\n 538→      }\n 539→\n 540→      const content = await response.text();\n 541→\n 542→      // Validate and save using plan-ingestion-service\n 543→      const infraConfig = loadPipelineInfraConfig();\n 544→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 545→\n 546→      const validationResult = planService.validate(content);\n 547→\n 548→      if (!validationResult.valid) {\n 549→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 550→        await ctx.reply(errorMsg);\n 551→        return;\n 552→      }\n 553→\n 554→      // Save the plan\n 555→      const saveResult = await planService.save(\n 556→        validationResult.type,\n 557→        content,\n 558→        { uploadedBy: ctx.from?.id }\n 559→      );\n 560→\n 561→      if (!saveResult.success) {\n 562→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 563→        return;\n 564→      }\n 565→\n 566→      // Set as current version\n 567→      await planService.setCurrent(validationResult.type, saveResult.version);\n 568→\n 569→      // Format success message\n 570→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 571→      const summary = validationResult.summary;\n 572→\n 573→      await ctx.reply([\n 574→        `✅ ${typeDisplay}已保存并激活`,\n 575→        `版本: ${saveResult.version}`,\n 576→        `名称: ${summary?.name || '未知'}`,\n 577→        `项目数: ${summary?.itemCount || 0}`,\n 578→        '',\n 579→        summary?.statusBreakdown ? '状态分布:' : '',\n 580→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 581→      ].filter(Boolean).join('\\n'));\n 582→\n 583→    } catch (error) {\n 584→      const message = error instanceof Error ? error.message : String(error);\n 585→      logger.error({ err: message }, 'Failed to process document upload');\n 586→      await ctx.reply(`❌ 处理失败：${message}`);\n 587→    }\n 588→  });\n 589→\n 590→  bot.on('text', async (ctx) => {\n 591→    // Check for pipeline commands first\n 592→    const handled = await routeCommand(ctx);\n 593→    if (handled) {\n 594→      return;\n 595→    }\n 596→\n 597→    const sessionId = buildSessionId(ctx);\n 598→\n 599→    let typingTimer = null;\n 600→\n 601→    try {\n 602→      ensureAllowed(ctx);\n 603→      await ctx.sendChatAction('typing');\n 604→\n 605→      const streamPublisher = createEditableStreamPublisher(ctx);\n 606→      typingTimer = setInterval(() => {\n 607→        ctx.sendChatAction('typing').catch(() => undefined);\n 608→      }, TYPING_INTERVAL_MS);\n 609→\n 610→      const reply = await chatWithSession({\n 611→        channel: 'telegram',\n 612→        sessionId,\n 613→        message: ctx.message.text,\n 614→        realtimeHooks: {\n 615→          onStatus: ({ stage }) => {\n 616→            if (stage === 'running') {\n 617→              ctx.sendChatAction('typing').catch(() => undefined);\n 618→            }\n 619→          },\n 620→          onAssistantChunk: ({ text }) => {\n 621→            streamPublisher.push(text);\n 622→          }\n 623→        }\n 624→      });\n 625→\n 626→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 627→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 628→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 629→\n 630→      streamPublisher.setFinalText(finalText);\n 631→      const streamed = await streamPublisher.finish();\n 632→      if (streamed.outputLength === 0) {\n 633→        await replyLargeText(ctx, finalText);\n 634→      }\n 635→\n 636→      if (fileRefs.length > 0) {\n 637→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 638→        const failed = fileSendResults.filter((item) => !item.sent);\n 639→\n 640→        if (failed.length === 0) {\n 641→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 642→        } else {\n 643→          const failedList = failed\n 644→            .map((item) => {\n 645→              const reason =\n 646→                item.reason === 'relative_path_not_allowed'\n 647→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 648→                  : item.reason === 'not_found'\n 649→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 650→                    : item.reason;\n 651→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 652→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 653→            })\n 654→            .join('\\n');\n 655→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 656→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 657→        }\n 658→      }\n 659→    } catch (error) {\n 660→      const message = error instanceof Error ? error.message : String(error);\n 661→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 662→      await safeReply(ctx, `处理失败：${message}`);\n 663→    } finally {\n 664→      if (typingTimer) {\n 665→        clearInterval(typingTimer);\n 666→      }\n 667→    }\n 668→  });\n 669→\n 670→  return bot;\n 671→}\n 672→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:28:46.930Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
{"type":"user","uuid":"1f75d36f-27a0-490c-ae75-d378a9d3af7a","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde5f7da7b54d21d45ca3a87f9ded","content":[{"type":"text","text":"   1→import { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2→import { createPlanIngestionService } from './plan-ingestion-service.js';\n   3→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   4→\n   5→function buildRequest(params = {}, action) {\n   6→  return {\n   7→    pipelineType: params.pipelineType ?? 'feature',\n   8→    action,\n   9→    ...(params.targetId ? { targetId: params.targetId } : {}),\n  10→    ...(params.listPath ? { listPath: params.listPath } : {}),\n  11→    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  12→    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  13→  };\n  14→}\n  15→\n  16→/**\n  17→ * T-015: Resolve list path for plan type and optional version.\n  18→ * @param {Object} options - Options\n  19→ * @param {string} options.planType - 'feature-list' or 'bug-fix-list'\n  20→ * @param {string} [options.version] - Optional version string\n  21→ * @param {Object} [options.config] - Optional config (will load if not provided)\n  22→ * @param {Object} [options.planService] - Optional plan service instance\n  23→ * @returns {Promise<string|null>} Resolved path or null\n  24→ */\n  25→export async function resolvePlanListPath({ planType, version, config, planService }) {\n  26→  const actualConfig = config ?? loadPipelineInfraConfig();\n  27→  const service = planService ?? createPlanIngestionService({ plansDir: actualConfig.plansDir });\n  28→\n  29→  // If version is specified, get that specific version\n  30→  if (version) {\n  31→    return service.getVersion(planType, version).then(content => {\n  32→      if (!content) return null;\n  33→      // Return the path to the version file\n  34→      const plansDir = actualConfig.plansDir;\n  35→      return `${plansDir}/${planType}/v${version.replace(/^v/, '')}.json`;\n  36→    });\n  37→  }\n  38→\n  39→  // Otherwise, use the active path from registry\n  40→  return service.getActivePath(planType);\n  41→}\n  42→\n  43→export function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  44→  return {\n  45→    runner,\n  46→    async startPipeline(params) {\n  47→      return runner(buildRequest(params, 'run'));\n  48→    },\n  49→    async getPipelineStatus(params) {\n  50→      return runner(buildRequest(params, 'status'));\n  51→    },\n  52→    async stopPipeline(params) {\n  53→      return runner(buildRequest(params, 'stop'));\n  54→    },\n  55→    async retryTarget(params) {\n  56→      return runner(buildRequest(params, 'retry'));\n  57→    },\n  58→    async getPipelineLogs(params) {\n  59→      return runner(buildRequest(params, 'logs'));\n  60→    },\n  61→    async resetTarget(params) {\n  62→      return runner(buildRequest(params, 'reset'));\n  63→    }\n  64→  };\n  65→}\n  66→\n  67→const defaultService = createPipelineControlService();\n  68→\n  69→export async function startPipeline(params) {\n  70→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  71→  return service.startPipeline(params);\n  72→}\n  73→\n  74→export async function getPipelineStatus(params) {\n  75→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  76→  return service.getPipelineStatus(params);\n  77→}\n  78→\n  79→export async function stopPipeline(params) {\n  80→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  81→  return service.stopPipeline(params);\n  82→}\n  83→\n  84→export async function retryTarget(params) {\n  85→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  86→  return service.retryTarget(params);\n  87→}\n  88→\n  89→export async function getPipelineLogs(params) {\n  90→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  91→  return service.getPipelineLogs(params);\n  92→}\n  93→\n  94→export async function resetTarget(params) {\n  95→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  96→  return service.resetTarget(params);\n  97→}\n  98→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:28:46.931Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
{"type":"user","uuid":"5c460a0d-a0e3-4b91-bd13-7222a6773c62","session_id":"45f4067c-7723-49aa-b1cf-9e2f92230067","message":{"content":[{"type":"tool_result","tool_use_id":"019cde5f7f43b388de538a0ae1bc1c13","content":[{"type":"text","text":"   1→import fs from 'node:fs';\n   2→import path from 'node:path';\n   3→\n   4→import { createInfraError, INFRA_ERROR_CODES } from './error-codes.js';\n   5→\n   6→function toArgMap(argv = []) {\n   7→  const args = Array.isArray(argv) ? argv : [];\n   8→  const map = new Map();\n   9→\n  10→  for (let i = 0; i < args.length; i += 1) {\n  11→    const token = String(args[i] ?? '');\n  12→    if (!token.startsWith('--')) {\n  13→      continue;\n  14→    }\n  15→\n  16→    const normalized = token.slice(2);\n  17→    if (!normalized) {\n  18→      continue;\n  19→    }\n  20→\n  21→    if (normalized.includes('=')) {\n  22→      const [key, ...rest] = normalized.split('=');\n  23→      map.set(key, rest.join('='));\n  24→      continue;\n  25→    }\n  26→\n  27→    const next = args[i + 1];\n  28→    if (typeof next === 'string' && !next.startsWith('--')) {\n  29→      map.set(normalized, next);\n  30→      i += 1;\n  31→    } else {\n  32→      map.set(normalized, 'true');\n  33→    }\n  34→  }\n  35→\n  36→  return map;\n  37→}\n  38→\n  39→function toAbsolutePath(raw, projectRoot) {\n  40→  const value = String(raw ?? '').trim();\n  41→  if (!value) {\n  42→    return '';\n  43→  }\n  44→\n  45→  if (path.isAbsolute(value)) {\n  46→    return path.normalize(value);\n  47→  }\n  48→\n  49→  return path.resolve(projectRoot, value);\n  50→}\n  51→\n  52→function parseInteger({ raw, field, min, code = INFRA_ERROR_CODES.CONFIG_INVALID, hint }) {\n  53→  const parsed = Number.parseInt(String(raw ?? ''), 10);\n  54→  if (!Number.isInteger(parsed) || parsed < min) {\n  55→    throwInfraError({\n  56→      code,\n  57→      field,\n  58→      message: `${field} must be an integer >= ${min}`,\n  59→      hint\n  60→    });\n  61→  }\n  62→\n  63→  return parsed;\n  64→}\n  65→\n  66→function throwInfraError({ code, field, message, hint, context = undefined }) {\n  67→  const infraError = createInfraError(code, message, {\n  68→    hint,\n  69→    context: {\n  70→      ...(context ?? {}),\n  71→      field\n  72→    }\n  73→  });\n  74→\n  75→  const err = new Error(`${infraError.message} (field: ${field}, hint: ${hint ?? 'n/a'})`);\n  76→  const mutableError = /** @type {any} */ (err);\n  77→  mutableError.code = infraError.code;\n  78→  mutableError.hint = infraError.hint;\n  79→  mutableError.context = infraError.context;\n  80→  mutableError.infraError = infraError;\n  81→  throw mutableError;\n  82→}\n  83→\n  84→function ensureDirectoryExists(dirPath, field) {\n  85→  if (!fs.existsSync(dirPath)) {\n  86→    throwInfraError({\n  87→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n  88→      field,\n  89→      message: `${field} does not exist: ${dirPath}`,\n  90→      hint: 'Ensure project root points to a repository containing dev-pipeline/'\n  91→    });\n  92→  }\n  93→}\n  94→\n  95→export function loadPipelineInfraConfig(input = {}) {\n  96→  const env = input.env ?? process.env;\n  97→  const argv = input.argv ?? [];\n  98→  const cwd = input.cwd ?? process.cwd();\n  99→  const argMap = toArgMap(argv);\n 100→\n 101→  const projectRootRaw = argMap.get('project-root') ?? env.PIPELINE_PROJECT_ROOT ?? cwd;\n 102→  const projectRoot = toAbsolutePath(projectRootRaw, cwd);\n 103→\n 104→  if (!projectRoot) {\n 105→    throwInfraError({\n 106→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 107→      field: 'projectRoot',\n 108→      message: 'projectRoot is required',\n 109→      hint: 'Set --project-root or PIPELINE_PROJECT_ROOT, or provide cwd input'\n 110→    });\n 111→  }\n 112→\n 113→  const pipelineDir = toAbsolutePath(\n 114→    argMap.get('pipeline-dir') ?? env.PIPELINE_DIR ?? path.join(projectRoot, 'dev-pipeline'),\n 115→    projectRoot\n 116→  );\n 117→\n 118→  ensureDirectoryExists(pipelineDir, 'pipelineDir');\n 119→\n 120→  const featureListPath = toAbsolutePath(\n 121→    argMap.get('feature-list') ?? env.FEATURE_LIST_PATH ?? path.join(projectRoot, 'feature-list.json'),\n 122→    projectRoot\n 123→  );\n 124→\n 125→  const bugFixListPath = toAbsolutePath(\n 126→    argMap.get('bug-fix-list') ?? env.BUG_FIX_LIST_PATH ?? path.join(projectRoot, 'bug-fix-list.json'),\n 127→    projectRoot\n 128→  );\n 129→\n 130→  // T-003: plansDir for versioned plan files\n 131→  const plansDir = toAbsolutePath(\n 132→    argMap.get('plans-dir') ?? env.PLANS_DIR ?? path.join(projectRoot, 'plans'),\n 133→    projectRoot\n 134→  );\n 135→\n 136→  const maxRetries = parseInteger({\n 137→    raw: argMap.get('max-retries') ?? env.MAX_RETRIES ?? 3,\n 138→    field: 'MAX_RETRIES',\n 139→    min: 1,\n 140→    hint: 'Set MAX_RETRIES to a positive integer'\n 141→  });\n 142→\n 143→  const sessionTimeoutSec = parseInteger({\n 144→    raw: argMap.get('session-timeout') ?? env.SESSION_TIMEOUT ?? 0,\n 145→    field: 'SESSION_TIMEOUT',\n 146→    min: 0,\n 147→    hint: 'Set SESSION_TIMEOUT to 0 or a positive integer (seconds)'\n 148→  });\n 149→\n 150→  const heartbeatIntervalSec = parseInteger({\n 151→    raw: argMap.get('heartbeat-interval') ?? env.HEARTBEAT_INTERVAL ?? 30,\n 152→    field: 'HEARTBEAT_INTERVAL',\n 153→    min: 1,\n 154→    hint: 'Set HEARTBEAT_INTERVAL to a positive integer (seconds)'\n 155→  });\n 156→\n 157→  const aiCli = String(argMap.get('ai-cli') ?? env.AI_CLI ?? env.CODEBUDDY_CLI ?? 'cbc').trim();\n 158→  if (!aiCli) {\n 159→    throwInfraError({\n 160→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 161→      field: 'AI_CLI',\n 162→      message: 'AI_CLI is required',\n 163→      hint: 'Set AI_CLI or CODEBUDDY_CLI to a CLI command name'\n 164→    });\n 165→  }\n 166→\n 167→  const platformRaw = String(\n 168→    argMap.get('platform') ?? env.PRIZMKIT_PLATFORM ?? (aiCli.includes('claude') ? 'claude' : 'codebuddy')\n 169→  ).trim();\n 170→\n 171→  if (platformRaw !== 'codebuddy' && platformRaw !== 'claude') {\n 172→    throwInfraError({\n 173→      code: INFRA_ERROR_CODES.CONFIG_INVALID,\n 174→      field: 'PRIZMKIT_PLATFORM',\n 175→      message: `Unsupported platform: ${platformRaw}`,\n 176→      hint: \"Use 'codebuddy' or 'claude'\"\n 177→    });\n 178→  }\n 179→\n 180→  return Object.freeze({\n 181→    projectRoot,\n 182→    pipelineDir,\n 183→    featureListPath,\n 184→    bugFixListPath,\n 185→    plansDir,\n 186→    stateDir: path.join(pipelineDir, 'state'),\n 187→    bugfixStateDir: path.join(pipelineDir, 'bugfix-state'),\n 188→    maxRetries,\n 189→    sessionTimeoutSec,\n 190→    heartbeatIntervalSec,\n 191→    aiCli,\n 192→    platform: platformRaw\n 193→  });\n 194→}\n 195→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_03dcce57ec5042688458a665","__timestamp":"2026-03-11T19:28:46.932Z","_requestId":"553c6d77d2214d40857e104dd24ea2b3"}
