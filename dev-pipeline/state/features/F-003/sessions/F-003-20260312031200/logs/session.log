oot', projectRoot, '--heartbeat-interval', '15'],\n  37→    env: {\n  38→      FEATURE_LIST_PATH: '/tmp/custom-feature-list.json',\n  39→      BUG_FIX_LIST_PATH: '/tmp/custom-bug-list.json',\n  40→      MAX_RETRIES: '7',\n  41→      SESSION_TIMEOUT: '120',\n  42→      AI_CLI: 'claude'\n  43→    }\n  44→  });\n  45→\n  46→  assert.equal(config.projectRoot, projectRoot);\n  47→  assert.equal(config.featureListPath, '/tmp/custom-feature-list.json');\n  48→  assert.equal(config.bugFixListPath, '/tmp/custom-bug-list.json');\n  49→  assert.equal(config.maxRetries, 7);\n  50→  assert.equal(config.sessionTimeoutSec, 120);\n  51→  assert.equal(config.heartbeatIntervalSec, 15);\n  52→  assert.equal(config.aiCli, 'claude');\n  53→  assert.equal(config.platform, 'claude');\n  54→});\n  55→\n  56→test('loadPipelineInfraConfig should throw readable errors for invalid values', () => {\n  57→  const projectRoot = createTempProjectRoot();\n  58→\n  59→  assert.throws(\n  60→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: { MAX_RETRIES: '0' } }),\n  61→    (error) => {\n  62→      assert.match(error.message, /MAX_RETRIES/);\n  63→      assert.match(error.message, /hint/i);\n  64→      assert.equal(error.code, 'CONFIG_INVALID');\n  65→      return true;\n  66→    }\n  67→  );\n  68→\n  69→  assert.throws(\n  70→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: { PRIZMKIT_PLATFORM: 'invalid' } }),\n  71→    (error) => {\n  72→      assert.match(error.message, /PRIZMKIT_PLATFORM/);\n  73→      assert.equal(error.code, 'CONFIG_INVALID');\n  74→      return true;\n  75→    }\n  76→  );\n  77→});\n  78→\n  79→test('loadPipelineInfraConfig should fail when dev-pipeline directory is missing', () => {\n  80→  const projectRoot = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-no-pipeline-'));\n  81→\n  82→  assert.throws(\n  83→    () => loadPipelineInfraConfig({ cwd: projectRoot, env: {}, argv: [] }),\n  84→    (error) => {\n  85→      assert.match(error.message, /dev-pi