{"type":"user","uuid":"edb057a5-0955-4784-9343-00a101fcce75","session_id":"652c262b-723d-40ce-86a3-383fcc2d8e4b","message":{"content":[{"type":"tool_result","tool_use_id":"call_89cddea5fc034012bea587ba","content":[{"type":"text","text":"   1→/**\n   2→ * Error Formatter\n   3→ * Formats error messages for user-friendly display.\n   4→ */\n   5→\n   6→/**\n   7→ * Error codes for command errors.\n   8→ */\n   9→export const ErrorCodes = {\n  10→  UNKNOWN_COMMAND: 'UNKNOWN_COMMAND',\n  11→  UNKNOWN_SUBCOMMAND: 'UNKNOWN_SUBCOMMAND',\n  12→  MISSING_PARAM: 'MISSING_PARAM',\n  13→  INVALID_PARAM: 'INVALID_PARAM',\n  14→  UNAUTHORIZED: 'UNAUTHORIZED',\n  15→  INTERNAL_ERROR: 'INTERNAL_ERROR'\n  16→};\n  17→\n  18→/**\n  19→ * @typedef {Object} ErrorResponse\n  20→ * @property {string} code - Error code\n  21→ * @property {string} message - User-friendly error message\n  22→ * @property {string} [suggestion] - Correction suggestion\n  23→ * @property {string} [usage] - Correct usage example\n  24→ */\n  25→\n  26→/**\n  27→ * Format an error for display to the user.\n  28→ * @param {string} code - Error code\n  29→ * @param {Object} context - Error context\n  30→ * @param {string} [context.command] - Command name\n  31→ * @param {string} [context.subcommand] - Subcommand name\n  32→ * @param {string} [context.param] - Parameter name\n  33→ * @param {string} [context.value] - Invalid value\n  34→ * @param {string} [context.reason] - Error reason\n  35→ * @param {string} [context.suggestion] - Custom suggestion\n  36→ * @param {string} [context.usage] - Correct usage\n  37→ * @param {string[]} [context.available] - Available options\n  38→ * @returns {ErrorResponse} Formatted error\n  39→ */\n  40→export function formatError(code, context = {}) {\n  41→  switch (code) {\n  42→    case ErrorCodes.UNKNOWN_COMMAND:\n  43→      return {\n  44→        code,\n  45→        message: `未知命令 '${context.command || ''}'。`,\n  46→        suggestion: '输入 /help 查看可用命令。'\n  47→      };\n  48→\n  49→    case ErrorCodes.UNKNOWN_SUBCOMMAND:\n  50→      return {\n  51→        code,\n  52→        message: `未知子命令 '${context.subcommand || ''}'。`,\n  53→        suggestion: context.available ? `可用: ${context.available.join(', ')}` : undefined,\n  54→        usage: context.usage\n  55→      };\n  56→\n  57→    case ErrorCodes.MISSING_PARAM:\n  58→      return {\n  59→        code,\n  60→        message: `缺少参数 '${context.param || ''}'。`,\n  61→        suggestion: context.suggestion || `请提供 ${context.param} 参数`,\n  62→        usage: context.usage\n  63→      };\n  64→\n  65→    case ErrorCodes.INVALID_PARAM:\n  66→      return {\n  67→        code,\n  68→        message: `参数 '${context.param || ''}' 无效: ${context.reason || ''}`,\n  69→        suggestion: context.suggestion,\n  70→        usage: context.usage\n  71→      };\n  72→\n  73→    case ErrorCodes.UNAUTHORIZED:\n  74→      return {\n  75→        code,\n  76→        message: '当前账号未被授权使用该命令。',\n  77→        suggestion: '请联系管理员获取授权。'\n  78→      };\n  79→\n  80→    case ErrorCodes.INTERNAL_ERROR:\n  81→      return {\n  82→        code,\n  83→        message: '内部错误，请稍后重试。',\n  84→        suggestion: context.reason ? `错误: ${context.reason}` : undefined\n  85→      };\n  86→\n  87→    default:\n  88→      return {\n  89→        code: ErrorCodes.INTERNAL_ERROR,\n  90→        message: '未知错误。'\n  91→      };\n  92→  }\n  93→}\n  94→\n  95→/**\n  96→ * Format validation errors into a single message.\n  97→ * @param {import('./validator.js').ValidationError[]} errors - Validation errors\n  98→ * @param {string} [usage] - Usage hint\n  99→ * @returns {string} Formatted error message\n 100→ */\n 101→export function formatValidationErrors(errors, usage) {\n 102→  if (!errors || errors.length === 0) {\n 103→    return '';\n 104→  }\n 105→\n 106→  const lines = [];\n 107→\n 108→  for (const error of errors) {\n 109→    lines.push(`❌ ${error.message}`);\n 110→    if (error.suggestion) {\n 111→      lines.push(`   建议: ${error.suggestion}`);\n 112→    }\n 113→  }\n 114→\n 115→  if (usage) {\n 116→    lines.push(`\\n用法: ${usage}`);\n 117→  }\n 118→\n 119→  return lines.join('\\n');\n 120→}\n 121→\n 122→/**\n 123→ * Format an error response into a display string.\n 124→ * @param {ErrorResponse} error - Error response\n 125→ * @returns {string} Formatted string\n 126→ */\n 127→export function formatErrorResponse(error) {\n 128→  const lines = [`❌ ${error.message}`];\n 129→\n 130→  if (error.suggestion) {\n 131→    lines.push(`💡 ${error.suggestion}`);\n 132→  }\n 133→\n 134→  if (error.usage) {\n 135→    lines.push(`用法: ${error.usage}`);\n 136→  }\n 137→\n 138→  return lines.join('\\n');\n 139→}\n 140→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_482b0a22801a47668b3565b0","__timestamp":"2026-03-11T19:21:09.571Z","_requestId":"50df4b32644a4c9c94330fdd421fef57"}
