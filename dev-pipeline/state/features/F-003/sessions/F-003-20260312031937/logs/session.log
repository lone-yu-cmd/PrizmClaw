{"type":"user","uuid":"ba1759ab-b905-4dad-bcc7-db356ce29ac5","session_id":"652c262b-723d-40ce-86a3-383fcc2d8e4b","message":{"content":[{"type":"tool_result","tool_use_id":"call_d99bfd29b677465096d2764d","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for plan-ingestion-service.js\n   3→ * Covers T-010 (schema loader), T-011 (plan validator), T-012 (version manager),\n   4→ * T-013 (plan registry), T-014 (error formatting)\n   5→ */\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import os from 'node:os';\n   9→import path from 'node:path';\n  10→import fs from 'node:fs';\n  11→import { fileURLToPath } from 'node:url';\n  12→\n  13→const __dirname = path.dirname(fileURLToPath(import.meta.url));\n  14→const PROJECT_ROOT = path.resolve(__dirname, '../..');\n  15→\n  16→// We'll import dynamically after setup\n  17→let createPlanIngestionService;\n  18→\n  19→function createTempPlansDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-plans-'));\n  21→  fs.mkdirSync(path.join(tempDir, 'feature-list'), { recursive: true });\n  22→  fs.mkdirSync(path.join(tempDir, 'bug-fix-list'), { recursive: true });\n  23→  return tempDir;\n  24→}\n  25→\n  26→function createValidFeatureList() {\n  27→  return JSON.stringify({\n  28→    $schema: 'dev-pipeline-feature-list-v1',\n  29→    app_name: 'TestApp',\n  30→    app_description: 'A test application',\n  31→    features: [\n  32→      {\n  33→        id: 'F-001',\n  34→        title: 'Test Feature',\n  35→        description: 'A test feature',\n  36→        priority: 1,\n  37→        dependencies: [],\n  38→        acceptance_criteria: ['AC1: Test passes'],\n  39→        status: 'pending'\n  40→      }\n  41→    ]\n  42→  });\n  43→}\n  44→\n  45→function createValidBugFixList() {\n  46→  return JSON.stringify({\n  47→    $schema: 'dev-pipeline-bug-fix-list-v1',\n  48→    project_name: 'TestProject',\n  49→    bugs: [\n  50→      {\n  51→        id: 'B-001',\n  52→        title: 'Test Bug',\n  53→        description: 'A test bug',\n  54→        severity: 'medium',\n  55→        error_source: { type: 'user_report' },\n  56→        verification_type: 'manual',\n  57→        acceptance_criteria: ['AC1: Bug is fixed'],\n  58→        status: 'pending'\n  59→      }\n  60→    ]\n  61→  });\n  62→}\n  63→\n  64→// ============================================================\n  65→// T-010: Schema Loader Tests\n  66→// ============================================================\n  67→test('T-010: loadSchema should load feature-list schema', async () => {\n  68→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  69→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  70→\n  71→  const schema = service.loadSchema('feature-list');\n  72→  assert.ok(schema);\n  73→  assert.equal(typeof schema, 'object');\n  74→});\n  75→\n  76→test('T-010: loadSchema should load bug-fix-list schema', async () => {\n  77→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  78→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  79→\n  80→  const schema = service.loadSchema('bug-fix-list');\n  81→  assert.ok(schema);\n  82→  assert.equal(typeof schema, 'object');\n  83→});\n  84→\n  85→test('T-010: loadSchema should throw for unknown schema type', async () => {\n  86→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  87→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  88→\n  89→  assert.throws(\n  90→    () => service.loadSchema('unknown-type'),\n  91→    /unknown.*schema/i\n  92→  );\n  93→});\n  94→\n  95→// ============================================================\n  96→// T-011: Plan Validator Tests\n  97→// ============================================================\n  98→test('T-011: validate should identify feature-list type', async () => {\n  99→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 100→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 101→\n 102→  const result = service.validate(createValidFeatureList());\n 103→\n 104→  assert.equal(result.valid, true);\n 105→  assert.equal(result.type, 'feature-list');\n 106→  assert.ok(result.summary);\n 107→  assert.equal(result.summary.name, 'TestApp');\n 108→  assert.equal(result.summary.itemCount, 1);\n 109→});\n 110→\n 111→test('T-011: validate should identify bug-fix-list type', async () => {\n 112→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 113→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 114→\n 115→  const result = service.validate(createValidBugFixList());\n 116→\n 117→  assert.equal(result.valid, true);\n 118→  assert.equal(result.type, 'bug-fix-list');\n 119→  assert.ok(result.summary);\n 120→  assert.equal(result.summary.name, 'TestProject');\n 121→  assert.equal(result.summary.itemCount, 1);\n 122→});\n 123→\n 124→test('T-011: validate should return unknown type for missing schema', async () => {\n 125→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 126→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 127→\n 128→  const result = service.validate(JSON.stringify({ foo: 'bar' }));\n 129→\n 130→  assert.equal(result.valid, false);\n 131→  assert.equal(result.type, 'unknown');\n 132→});\n 133→\n 134→test('T-011: validate should return field-level errors', async () => {\n 135→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 136→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 137→\n 138→  const invalidContent = JSON.stringify({\n 139→    $schema: 'dev-pipeline-feature-list-v1',\n 140→    app_name: 'TestApp',\n 141→    features: [\n 142→      {\n 143→        id: 'INVALID-ID', // Should match F-\\\\d{3}\n 144→        title: 'Test',\n 145→        description: 'Test',\n 146→        priority: -1, // Should be >= 1\n 147→        dependencies: [],\n 148→        acceptance_criteria: [],\n 149→        status: 'invalid-status'\n 150→      }\n 151→    ]\n 152→  });\n 153→\n 154→  const result = service.validate(invalidContent);\n 155→\n 156→  assert.equal(result.valid, false);\n 157→  assert.ok(result.errors.length > 0);\n 158→  // Check that errors have path and message\n 159→  for (const error of result.errors) {\n 160→    assert.ok(error.path, 'Error should have path');\n 161→    assert.ok(error.message, 'Error should have message');\n 162→  }\n 163→});\n 164→\n 165→test('T-011: validate should return status breakdown in summary', async () => {\n 166→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 167→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 168→\n 169→  const content = JSON.stringify({\n 170→    $schema: 'dev-pipeline-feature-list-v1',\n 171→    app_name: 'TestApp',\n 172→    features: [\n 173→      { id: 'F-001', title: 'A', description: 'A', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' },\n 174→      { id: 'F-002', title: 'B', description: 'B', priority: 2, dependencies: [], acceptance_criteria: ['AC'], status: 'in_progress' },\n 175→      { id: 'F-003', title: 'C', description: 'C', priority: 3, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 176→    ]\n 177→  });\n 178→\n 179→  const result = service.validate(content);\n 180→\n 181→  assert.equal(result.valid, true);\n 182→  assert.deepEqual(result.summary.statusBreakdown, { pending: 2, in_progress: 1 });\n 183→});\n 184→\n 185→test('T-011: validate should handle invalid JSON', async () => {\n 186→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 187→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 188→\n 189→  const result = service.validate('not valid json');\n 190→\n 191→  assert.equal(result.valid, false);\n 192→  assert.equal(result.type, 'unknown');\n 193→  assert.ok(result.errors.length > 0);\n 194→  assert.match(result.errors[0].message, /json/i);\n 195→});\n 196→\n 197→// ============================================================\n 198→// T-014: Error Formatting Tests\n 199→// ============================================================\n 200→test('T-014: formatValidationErrors should format errors with field paths', async () => {\n 201→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 202→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 203→\n 204→  const errors = [\n 205→    { path: 'features[0].id', message: 'Invalid ID format' },\n 206→    { path: 'features[1].priority', message: 'Must be positive' }\n 207→  ];\n 208→\n 209→  const formatted = service.formatValidationErrors(errors);\n 210→\n 211→  assert.match(formatted, /features\\[0\\].id/);\n 212→  assert.match(formatted, /Invalid ID format/);\n 213→  assert.match(formatted, /features\\[1\\].priority/);\n 214→  assert.match(formatted, /Must be positive/);\n 215→});\n 216→\n 217→// ============================================================\n 218→// T-012: Version Manager Tests\n 219→// ============================================================\n 220→test('T-012: save should create versioned file', async () => {\n 221→  const plansDir = createTempPlansDir();\n 222→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 223→  const service = createPlanIngestionService({ plansDir });\n 224→\n 225→  const result = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 226→\n 227→  assert.equal(result.success, true);\n 228→  assert.ok(result.version);\n 229→  assert.match(result.version, /^v\\d{8}-\\d{6}$/);\n 230→\n 231→  // Cleanup\n 232→  fs.rmSync(plansDir, { recursive: true, force: true });\n 233→});\n 234→\n 235→test('T-012: listVersions should return version list', async () => {\n 236→  const plansDir = createTempPlansDir();\n 237→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 238→  const service = createPlanIngestionService({ plansDir });\n 239→\n 240→  // Save two versions\n 241→  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 242→  await new Promise(r => setTimeout(r, 1100)); // Ensure different timestamp\n 243→  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 244→\n 245→  const versions = await service.listVersions('feature-list');\n 246→\n 247→  assert.equal(versions.length, 2);\n 248→  assert.ok(versions[0].version);\n 249→  assert.ok(versions[0].timestamp);\n 250→  assert.ok(versions[0].itemCount);\n 251→\n 252→  // Cleanup\n 253→  fs.rmSync(plansDir, { recursive: true, force: true });\n 254→});\n 255→\n 256→test('T-012: getVersion should return content', async () => {\n 257→  const plansDir = createTempPlansDir();\n 258→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 259→  const service = createPlanIngestionService({ plansDir });\n 260→\n 261→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 262→  const content = await service.getVersion('feature-list', saved.version);\n 263→\n 264→  assert.ok(content);\n 265→  const parsed = JSON.parse(content);\n 266→  assert.equal(parsed.app_name, 'TestApp');\n 267→\n 268→  // Cleanup\n 269→  fs.rmSync(plansDir, { recursive: true, force: true });\n 270→});\n 271→\n 272→test('T-012: getVersion should return null for non-existent version', async () => {\n 273→  const plansDir = createTempPlansDir();\n 274→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 275→  const service = createPlanIngestionService({ plansDir });\n 276→\n 277→  const content = await service.getVersion('feature-list', 'v99999999-999999');\n 278→\n 279→  assert.equal(content, null);\n 280→\n 281→  // Cleanup\n 282→  fs.rmSync(plansDir, { recursive: true, force: true });\n 283→});\n 284→\n 285→// ============================================================\n 286→// T-013: Plan Registry Tests\n 287→// ============================================================\n 288→test('T-013: setCurrent should update _current.json', async () => {\n 289→  const plansDir = createTempPlansDir();\n 290→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 291→  const service = createPlanIngestionService({ plansDir });\n 292→\n 293→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 294→  const success = await service.setCurrent('feature-list', saved.version);\n 295→\n 296→  assert.equal(success, true);\n 297→\n 298→  const current = await service.getCurrent('feature-list');\n 299→  assert.ok(current);\n 300→  assert.equal(current.version, saved.version);\n 301→\n 302→  // Cleanup\n 303→  fs.rmSync(plansDir, { recursive: true, force: true });\n 304→});\n 305→\n 306→test('T-013: getActivePath should return path to current version', async () => {\n 307→  const plansDir = createTempPlansDir();\n 308→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 309→  const service = createPlanIngestionService({ plansDir });\n 310→\n 311→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 312→  await service.setCurrent('feature-list', saved.version);\n 313→\n 314→  const activePath = service.getActivePath('feature-list');\n 315→\n 316→  assert.ok(activePath);\n 317→  assert.match(activePath, /feature-list/);\n 318→  assert.match(activePath, new RegExp(saved.version));\n 319→\n 320→  // Cleanup\n 321→  fs.rmSync(plansDir, { recursive: true, force: true });\n 322→});\n 323→\n 324→test('T-013: rollback should switch to previous version', async () => {\n 325→  const plansDir = createTempPlansDir();\n 326→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 327→  const service = createPlanIngestionService({ plansDir });\n 328→\n 329→  // Save and set first version\n 330→  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 331→  await service.setCurrent('feature-list', v1.version);\n 332→\n 333→  // Save and set second version\n 334→  await new Promise(r => setTimeout(r, 1100));\n 335→  const v2 = await service.save('feature-list', JSON.stringify({\n 336→    $schema: 'dev-pipeline-feature-list-v1',\n 337→    app_name: 'TestApp2',\n 338→    features: [\n 339→      { id: 'F-001', title: 'Test', description: 'Test', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 340→    ]\n 341→  }), { uploadedBy: 12345 });\n 342→  await service.setCurrent('feature-list', v2.version);\n 343→\n 344→  // Rollback\n 345→  const result = await service.rollback('feature-list');\n 346→\n 347→  assert.ok(result);\n 348→  assert.equal(result.previousVersion, v2.version);\n 349→  assert.equal(result.currentVersion, v1.version);\n 350→\n 351→  // Cleanup\n 352→  fs.rmSync(plansDir, { recursive: true, force: true });\n 353→});\n 354→\n 355→test('T-013: rollback should return null when no previous version', async () => {\n 356→  const plansDir = createTempPlansDir();\n 357→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 358→  const service = createPlanIngestionService({ plansDir });\n 359→\n 360→  // Only one version\n 361→  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 362→  await service.setCurrent('feature-list', v1.version);\n 363→\n 364→  const result = await service.rollback('feature-list');\n 365→\n 366→  assert.equal(result, null);\n 367→\n 368→  // Cleanup\n 369→  fs.rmSync(plansDir, { recursive: true, force: true });\n 370→});\n 371→\n 372→test('T-013: getCurrent should return null when no version set', async () => {\n 373→  const plansDir = createTempPlansDir();\n 374→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 375→  const service = createPlanIngestionService({ plansDir });\n 376→\n 377→  const current = await service.getCurrent('feature-list');\n 378→\n 379→  assert.equal(current, null);\n 380→\n 381→  // Cleanup\n 382→  fs.rmSync(plansDir, { recursive: true, force: true });\n 383→});\n 384→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_482b0a22801a47668b3565b0","__timestamp":"2026-03-11T19:21:15.618Z","_requestId":"50df4b32644a4c9c94330fdd421fef57"}
