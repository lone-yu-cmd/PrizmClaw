2→    },\n  43→    reply: async (text) => { replies.push(text); },\n  44→    replyFile: async (content, filename) => { replies.push(`[FILE: ${filename}]`); }\n  45→  };\n  46→};\n  47→\n  48→test('pipelineMeta has correct metadata', () => {\n  49→  assert.equal(pipelineMeta.name, 'pipeline');\n  50→  assert.deepEqual(pipelineMeta.aliases, ['p']);\n  51→  assert.ok(pipelineMeta.subcommands.length > 0);\n  52→});\n  53→\n  54→test('handlePipeline with run subcommand calls startPipeline', async () => {\n  55→  const mock = createMockService();\n  56→  const mockCtx = createMockContext();\n  57→\n  58→  await handlePipeline({\n  59→    ctx: mockCtx.ctx,\n  60→    parsed: { command: 'pipeline', subcommand: 'run', args: ['my-feature'], options: {} },\n  61→    params: { type: 'feature', _args: ['my-feature'] },\n  62→    reply: mockCtx.reply,\n  63→    replyFile: mockCtx.replyFile\n  64→  });\n  65→\n  66→  // Verify behavior through replies\n  67→  assert.ok(mockCtx.replies.length > 0);\n  68→});\n  69→\n  70→test('handlePipeline with status subcommand shows status', async () => {\n  71→  const mock = createMockService();\n  72→  const mockCtx = createMockContext();\n  73→\n  74→  await handlePipeline({\n  75→    ctx: mockCtx.ctx,\n  76→    parsed: { command: 'pipeline', subcommand: 'status', args: [], options: {} },\n  77→    params: {},\n  78→    reply: mockCtx.reply,\n  79→    replyFile: mockCtx.replyFile\n  80→  });\n  81→\n  82→  assert.ok(mockCtx.replies.length > 0);\n  83→});\n  84→\n  85→test('handleBugfix requires target parameter', async () => {\n  86→  const mockCtx = createMockContext();\n  87→\n  88→  await handleBugfix({\n  89→    ctx: mockCtx.ctx,\n  90→    parsed: { command: 'bugfix', args: [], options: {} },\n  91→    params: {},\n  92→    reply: mockCtx.reply,\n  93→    replyFile: mockCtx.replyFile\n  94→  });\n  95→\n  96→  assert.ok(mockCtx.replies[0].includes('缺少'));\n  97→});\n  98→\n  99→test('handleBugfix calls pipeline with type=bugfix', async ()