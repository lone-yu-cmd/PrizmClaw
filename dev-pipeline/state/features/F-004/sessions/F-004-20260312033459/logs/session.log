{"type":"user","uuid":"a67ffdf7-ba7b-4204-af51-3b9c5ff4a2c4","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde7951a2cba273775d92f494a19d","content":[{"type":"text","text":"   1→DOC_LEVEL: L1\n   2→MODULE: runtime\n   3→PATH: src/**\n   4→DESCRIPTION: telegram + web request handling + sessioned CodeBuddy bridge\n   5→\n   6→ENTRYPOINT:\n   7→- src/index.js -> createHttpServer + optional Telegram bot launch\n   8→\n   9→KEY_FILES:\n  10→- src/config.js\n  11→- src/http/server.js\n  12→- src/routes/api-routes.js\n  13→- src/services/chat-service.js\n  14→- src/services/pipeline-control-service.js\n  15→- src/services/plan-ingestion-service.js\n  16→- src/pipeline-infra/config-loader.js\n  17→- src/pipeline-infra/script-runner.js\n  18→- src/adapters/codebuddy.js\n  19→- src/bot/telegram.js\n  20→- src/bot/commands/handlers/plan.js\n  21→- src/services/system-exec-service.js\n  22→\n  23→SUBDIRS:\n  24→- src/adapters -> (lazy) .prizm-docs/runtime/adapters.prizm\n  25→- src/bot -> (lazy) .prizm-docs/runtime/bot.prizm\n  26→- src/http -> (lazy) .prizm-docs/runtime/http.prizm\n  27→- src/routes -> (lazy) .prizm-docs/runtime/routes.prizm\n  28→- src/security -> (lazy) .prizm-docs/runtime/security.prizm\n  29→- src/services -> .prizm-docs/runtime/services.prizm\n  30→- src/pipeline-infra -> .prizm-docs/runtime/pipeline-infra.prizm\n  31→- src/utils -> (lazy) .prizm-docs/runtime/utils.prizm\n  32→\n  33→INTERFACES:\n  34→- HTTP: /healthz, /api/events(SSE), /api/chat, /api/chat/reset, /api/screenshot, /api/system/exec\n  35→- Telegram: /start, /help, /reset, /screenshot, /exec, /pipeline, /bugfix, /planner, /status, /logs, /stop, /plan, text message relay\n  36→\n  37→TRAPS:\n  38→- ENABLE_TELEGRAM=true requires TELEGRAM_BOT_TOKEN\n  39→- system exec is disabled unless ENABLE_SYSTEM_EXEC=true\n  40→- system exec requires ALLOWED_COMMAND_PREFIXES whitelist\n  41→- chat is serialized per session via chat-queue\n  42→\n  43→DECISIONS:\n  44→- 2026-03-09 | runtime-doc-init | model first-pass runtime map from source + API surface\n  45→- 2026-03-10 | runtime-infra-f001 | expose pipeline infra config in src/config.js and pipeline-control-service API for feature/bugfix run/status/stop/retry/logs/reset\n  46→- 2026-03-12 | runtime-f002 | add command routing layer for pipeline commands (/pipeline, /bugfix, /planner, /status, /logs, /stop)\n  47→- 2026-03-12 | runtime-f003 | add plan ingestion service for feature-list/bug-fix-list upload, validation, version management, and /plan command\n  48→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:00.818Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"110344e5-692c-4819-9c02-85351b55a596","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde795346a2af4e7a33a096a46bf1","content":[{"type":"text","text":"   1→DOC_LEVEL: L1\n   2→MODULE: pipeline\n   3→PATH: dev-pipeline/**\n   4→DESCRIPTION: automation scripts + templates for feature/bugfix pipelines\n   5→\n   6→KEY_FILES:\n   7→- dev-pipeline/run.sh\n   8→- dev-pipeline/run-bugfix.sh\n   9→- dev-pipeline/launch-daemon.sh\n  10→- dev-pipeline/launch-bugfix-daemon.sh\n  11→- dev-pipeline/retry-feature.sh\n  12→- dev-pipeline/retry-bug.sh\n  13→- dev-pipeline/reset-feature.sh\n  14→- dev-pipeline/scripts/path_policy.py\n  15→- dev-pipeline/scripts/*.py\n  16→- dev-pipeline/templates/*\n  17→\n  18→STATE_PATHS:\n  19→- dev-pipeline/state/\n  20→- dev-pipeline/bugfix-state/\n  21→\n  22→DAEMON_LOG_POLICY:\n  23→- feature daemon log -> dev-pipeline/state/pipeline-daemon.log\n  24→- bugfix daemon log -> dev-pipeline/bugfix-state/pipeline-daemon.log\n  25→\n  26→TRAPS:\n  27→- several large operational scripts (>500 lines) require cautious edits\n  28→- TODO density is concentrated in this module\n  29→\n  30→SUBDIRS:\n  31→- dev-pipeline/scripts -> .prizm-docs/pipeline/scripts.prizm\n  32→\n  33→DECISIONS:\n  34→- 2026-03-09 | pipeline-doc-init | treat shell+python pipeline as independent module\n  35→- 2026-03-10 | f001-path-policy-shared | centralize feature/bug/session/session-status/daemon-log paths via scripts/path_policy.py and JS mirror module\n  36→- 2026-03-10 | f001-us3-scope | include logs/reset in runner+service API surface using daemon wrappers and clean reset commands\n  37→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:00.819Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"10b1cad8-010b-473d-8679-4448a417265d","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde7955051850c1efb91684587201","content":[{"type":"text","text":"   1→/**\n   2→ * Lock Manager\n   3→ *\n   4→ * F-004: Pipeline Process Controller - US-7 Concurrency Protection\n   5→ *\n   6→ * Provides file-based lock management with PID validation for preventing\n   7→ * concurrent pipeline operations of the same type.\n   8→ *\n   9→ * Design Decisions:\n  10→ * - D1: File lock + PID validation (no external dependencies)\n  11→ * - Atomic write via temp file + rename\n  12→ * - Stale lock cleanup when holder process is dead\n  13→ */\n  14→\n  15→import fs from 'node:fs';\n  16→import path from 'node:path';\n  17→import os from 'node:os';\n  18→\n  19→import { loadPipelineInfraConfig } from './config-loader.js';\n  20→import { getStatePaths } from './path-policy.js';\n  21→\n  22→/**\n  23→ * @typedef {'feature' | 'bugfix'} PipelineType\n  24→ */\n  25→\n  26→/**\n  27→ * @typedef {Object} LockInfo\n  28→ * @property {number} pid - Process ID holding the lock\n  29→ * @property {string} acquiredAt - ISO timestamp when lock was acquired\n  30→ * @property {PipelineType} type - Pipeline type\n  31→ * @property {string} hostname - Hostname where lock was acquired\n  32→ */\n  33→\n  34→/**\n  35→ * @typedef {Object} LockResult\n  36→ * @property {boolean} ok - Whether operation succeeded\n  37→ * @property {string} lockPath - Path to lock file\n  38→ * @property {string} [errorCode] - Error code if failed\n  39→ * @property {LockInfo} [currentHolder] - Current lock holder if locked\n  40→ */\n  41→\n  42→/**\n  43→ * Check if a process is alive.\n  44→ * @param {number} pid - Process ID to check\n  45→ * @returns {boolean} True if process is alive\n  46→ */\n  47→function isProcessAlive(pid) {\n  48→  try {\n  49→    process.kill(pid, 0);\n  50→    return true;\n  51→  } catch (error) {\n  52→    return error.code !== 'ESRCH';\n  53→  }\n  54→}\n  55→\n  56→/**\n  57→ * Create a lock manager instance.\n  58→ * @param {Object} [options] - Options\n  59→ * @param {Object} [options.config] - Pipeline config (will load if not provided)\n  60→ * @returns {Object} Lock manager instance\n  61→ */\n  62→export function createLockManager(options = {}) {\n  63→  const config = options.config ?? loadPipelineInfraConfig();\n  64→\n  65→  /**\n  66→   * Get lock file path for pipeline type.\n  67→   * @param {PipelineType} type - Pipeline type\n  68→   * @returns {string} Lock file path\n  69→   */\n  70→  function getLockPath(type) {\n  71→    const paths = getStatePaths(config.projectRoot, type);\n  72→    return paths.lockFile;\n  73→  }\n  74→\n  75→  /**\n  76→   * Read lock file if exists.\n  77→   * @param {PipelineType} type - Pipeline type\n  78→   * @returns {LockInfo | null} Lock info or null\n  79→   */\n  80→  function readLockFile(type) {\n  81→    const lockPath = getLockPath(type);\n  82→    try {\n  83→      const content = fs.readFileSync(lockPath, 'utf8');\n  84→      return JSON.parse(content);\n  85→    } catch {\n  86→      return null;\n  87→    }\n  88→  }\n  89→\n  90→  /**\n  91→   * Write lock file atomically.\n  92→   * @param {PipelineType} type - Pipeline type\n  93→   * @param {LockInfo} lockInfo - Lock info to write\n  94→   * @returns {string} Lock file path\n  95→   */\n  96→  function writeLockFile(type, lockInfo) {\n  97→    const lockPath = getLockPath(type);\n  98→    const dir = path.dirname(lockPath);\n  99→\n 100→    // Ensure directory exists\n 101→    if (!fs.existsSync(dir)) {\n 102→      fs.mkdirSync(dir, { recursive: true });\n 103→    }\n 104→\n 105→    // Write to temp file first, then rename for atomicity\n 106→    const tempPath = `${lockPath}.${process.pid}.${Date.now()}.tmp`;\n 107→    fs.writeFileSync(tempPath, JSON.stringify(lockInfo, null, 2));\n 108→    fs.renameSync(tempPath, lockPath);\n 109→\n 110→    return lockPath;\n 111→  }\n 112→\n 113→  /**\n 114→   * Remove lock file.\n 115→   * @param {PipelineType} type - Pipeline type\n 116→   */\n 117→  function removeLockFile(type) {\n 118→    const lockPath = getLockPath(type);\n 119→    try {\n 120→      fs.unlinkSync(lockPath);\n 121→    } catch {\n 122→      // Ignore if file doesn't exist\n 123→    }\n 124→  }\n 125→\n 126→  /**\n 127→   * Acquire lock for pipeline type.\n 128→   * @param {PipelineType} type - Pipeline type\n 129→   * @param {number} [pid] - PID to use (default: process.pid)\n 130→   * @returns {Promise<LockResult>} Lock result\n 131→   */\n 132→  async function acquireLock(type, pid = process.pid) {\n 133→    const lockPath = getLockPath(type);\n 134→\n 135→    // Check existing lock\n 136→    const existingLock = readLockFile(type);\n 137→    if (existingLock) {\n 138→      // Check if holder is still alive\n 139→      if (isProcessAlive(existingLock.pid)) {\n 140→        return {\n 141→          ok: false,\n 142→          lockPath,\n 143→          errorCode: 'LOCK_ACQUISITION_FAILED',\n 144→          currentHolder: existingLock\n 145→        };\n 146→      }\n 147→      // Stale lock - will be cleaned up below\n 148→    }\n 149→\n 150→    // Acquire lock\n 151→    const lockInfo = {\n 152→      pid,\n 153→      acquiredAt: new Date().toISOString(),\n 154→      type,\n 155→      hostname: os.hostname()\n 156→    };\n 157→\n 158→    try {\n 159→      writeLockFile(type, lockInfo);\n 160→      return { ok: true, lockPath };\n 161→    } catch (error) {\n 162→      return {\n 163→        ok: false,\n 164→        lockPath,\n 165→        errorCode: 'LOCK_ACQUISITION_FAILED'\n 166→      };\n 167→    }\n 168→  }\n 169→\n 170→  /**\n 171→   * Release lock for pipeline type.\n 172→   * @param {PipelineType} type - Pipeline type\n 173→   * @param {number} [pid] - PID that holds the lock (default: process.pid)\n 174→   * @returns {Promise<{ok: boolean}>} Release result\n 175→   */\n 176→  async function releaseLock(type, pid = process.pid) {\n 177→    const existingLock = readLockFile(type);\n 178→\n 179→    // Only release if we own the lock\n 180→    if (existingLock && existingLock.pid === pid) {\n 181→      removeLockFile(type);\n 182→    }\n 183→\n 184→    return { ok: true };\n 185→  }\n 186→\n 187→  /**\n 188→   * Check if lock is held for pipeline type.\n 189→   * @param {PipelineType} type - Pipeline type\n 190→   * @returns {Promise<boolean>} True if locked\n 191→   */\n 192→  async function isLocked(type) {\n 193→    const lockInfo = readLockFile(type);\n 194→    if (!lockInfo) {\n 195→      return false;\n 196→    }\n 197→    return isProcessAlive(lockInfo.pid);\n 198→  }\n 199→\n 200→  /**\n 201→   * Validate lock and return lock info.\n 202→   * @param {PipelineType} type - Pipeline type\n 203→   * @returns {Promise<LockInfo | null>} Lock info if valid, null otherwise\n 204→   */\n 205→  async function validateLock(type) {\n 206→    const lockInfo = readLockFile(type);\n 207→    if (!lockInfo) {\n 208→      return null;\n 209→    }\n 210→    if (!isProcessAlive(lockInfo.pid)) {\n 211→      return null;\n 212→    }\n 213→    return lockInfo;\n 214→  }\n 215→\n 216→  /**\n 217→   * Force unlock for pipeline type (admin operation).\n 218→   * @param {PipelineType} type - Pipeline type\n 219→   * @returns {Promise<{ok: boolean, previousPid?: number}>} Force unlock result\n 220→   */\n 221→  async function forceUnlock(type) {\n 222→    const lockInfo = readLockFile(type);\n 223→    const previousPid = lockInfo?.pid;\n 224→    removeLockFile(type);\n 225→    return { ok: true, previousPid };\n 226→  }\n 227→\n 228→  /**\n 229→   * Get lock info for pipeline type.\n 230→   * @param {PipelineType} type - Pipeline type\n 231→   * @returns {Promise<LockInfo | null>} Lock info or null\n 232→   */\n 233→  async function getLockInfo(type) {\n 234→    return readLockFile(type);\n 235→  }\n 236→\n 237→  return {\n 238→    acquireLock,\n 239→    releaseLock,\n 240→    isLocked,\n 241→    validateLock,\n 242→    forceUnlock,\n 243→    getLockInfo\n 244→  };\n 245→}\n 246→\n 247→// Default instance\n 248→let defaultManager = null;\n 249→\n 250→/**\n 251→ * Get default lock manager instance.\n 252→ * @returns {Object} Default lock manager\n 253→ */\n 254→export function getDefaultLockManager() {\n 255→  if (!defaultManager) {\n 256→    defaultManager = createLockManager();\n 257→  }\n 258→  return defaultManager;\n 259→}\n 260→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:00.819Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"1ed6ca32-0fe9-4ec4-940b-a64e2ed428d8","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde7956a3ab5e8a0dcaec800a241f","content":[{"type":"text","text":"   1→/**\n   2→ * State Manager\n   3→ *\n   4→ * F-004: Pipeline Process Controller - US-5 Status Query, US-6 Logs Query\n   5→ *\n   6→ * Manages reading and writing pipeline state files including:\n   7→ * - Daemon meta (.pipeline-meta.json)\n   8→ * - Pipeline state (pipeline.json)\n   9→ * - Current session (current-session.json)\n  10→ * - Last result (.last-result.json)\n  11→ *\n  12→ * Design Decisions:\n  13→ * - D3: Reuse existing state files (backward compatible)\n  14→ * - D6: Last result stored in separate file\n  15→ */\n  16→\n  17→import fs from 'node:fs';\n  18→import path from 'node:path';\n  19→\n  20→import { loadPipelineInfraConfig } from './config-loader.js';\n  21→import { getStatePaths } from './path-policy.js';\n  22→\n  23→/**\n  24→ * @typedef {'feature' | 'bugfix'} PipelineType\n  25→ */\n  26→\n  27→/**\n  28→ * @typedef {Object} DaemonMeta\n  29→ * @property {number} pid - Daemon process ID\n  30→ * @property {string} started_at - ISO timestamp when daemon started\n  31→ * @property {string} feature_list - Path to feature list\n  32→ * @property {string} env_overrides - Environment overrides string\n  33→ * @property {string} log_file - Path to log file\n  34→ */\n  35→\n  36→/**\n  37→ * @typedef {Object} PipelineState\n  38→ * @property {string} run_id - Unique run identifier\n  39→ * @property {string} status - Pipeline status (running/paused/completed/failed)\n  40→ * @property {string} feature_list_path - Path to feature list\n  41→ * @property {string} created_at - ISO timestamp when created\n  42→ * @property {number} total_features - Total features to process\n  43→ * @property {number} completed_features - Number of completed features\n  44→ * @property {string} [paused_at] - ISO timestamp when paused\n  45→ */\n  46→\n  47→/**\n  48→ * @typedef {Object} LastResult\n  49→ * @property {string} runId - Run identifier\n  50→ * @property {string} completedAt - ISO timestamp when completed\n  51→ * @property {'success' | 'failed' | 'partial'} status - Completion status\n  52→ * @property {number} featuresTotal - Total features\n  53→ * @property {number} featuresCompleted - Completed features count\n  54→ * @property {number} [exitCode] - Exit code\n  55→ * @property {string} [message] - Result message\n  56→ */\n  57→\n  58→/**\n  59→ * Safely read and parse a JSON file.\n  60→ * @param {string} filePath - File path\n  61→ * @returns {Object | null} Parsed JSON or null if file doesn't exist\n  62→ */\n  63→function readJsonFile(filePath) {\n  64→  try {\n  65→    const content = fs.readFileSync(filePath, 'utf8');\n  66→    return JSON.parse(content);\n  67→  } catch {\n  68→    return null;\n  69→  }\n  70→}\n  71→\n  72→/**\n  73→ * Write JSON to file atomically.\n  74→ * @param {string} filePath - File path\n  75→ * @param {Object} data - Data to write\n  76→ */\n  77→function writeJsonFile(filePath, data) {\n  78→  const dir = path.dirname(filePath);\n  79→  if (!fs.existsSync(dir)) {\n  80→    fs.mkdirSync(dir, { recursive: true });\n  81→  }\n  82→\n  83→  const tempPath = `${filePath}.${Date.now()}.tmp`;\n  84→  fs.writeFileSync(tempPath, JSON.stringify(data, null, 2));\n  85→  fs.renameSync(tempPath, filePath);\n  86→}\n  87→\n  88→/**\n  89→ * Check if a process is alive.\n  90→ * @param {number} pid - Process ID to check\n  91→ * @returns {boolean} True if process is alive\n  92→ */\n  93→function isProcessAlive(pid) {\n  94→  try {\n  95→    process.kill(pid, 0);\n  96→    return true;\n  97→  } catch (error) {\n  98→    return error.code !== 'ESRCH';\n  99→  }\n 100→}\n 101→\n 102→/**\n 103→ * Create a state manager instance.\n 104→ * @param {Object} [options] - Options\n 105→ * @param {Object} [options.config] - Pipeline config (will load if not provided)\n 106→ * @returns {Object} State manager instance\n 107→ */\n 108→export function createStateManager(options = {}) {\n 109→  const config = options.config ?? loadPipelineInfraConfig();\n 110→\n 111→  /**\n 112→   * Get state paths for pipeline type.\n 113→   * @param {PipelineType} type - Pipeline type\n 114→   * @returns {Object} State paths\n 115→   */\n 116→  function getPaths(type) {\n 117→    return getStatePaths(config.projectRoot, type);\n 118→  }\n 119→\n 120→  /**\n 121→   * Read daemon meta file.\n 122→   * @param {PipelineType} type - Pipeline type\n 123→   * @returns {Promise<DaemonMeta | null>} Daemon meta or null\n 124→   */\n 125→  async function readDaemonMeta(type) {\n 126→    const paths = getPaths(type);\n 127→    return readJsonFile(paths.daemonMetaFile);\n 128→  }\n 129→\n 130→  /**\n 131→   * Read pipeline state file.\n 132→   * @param {PipelineType} type - Pipeline type\n 133→   * @returns {Promise<PipelineState | null>} Pipeline state or null\n 134→   */\n 135→  async function readPipelineState(type) {\n 136→    const paths = getPaths(type);\n 137→    return readJsonFile(paths.pipelineStateFile);\n 138→  }\n 139→\n 140→  /**\n 141→   * Read current session file.\n 142→   * @param {PipelineType} type - Pipeline type\n 143→   * @returns {Promise<Object | null>} Current session or null\n 144→   */\n 145→  async function readCurrentSession(type) {\n 146→    const paths = getPaths(type);\n 147→    return readJsonFile(paths.currentSessionFile);\n 148→  }\n 149→\n 150→  /**\n 151→   * Get last result.\n 152→   * @param {PipelineType} type - Pipeline type\n 153→   * @returns {Promise<LastResult | null>} Last result or null\n 154→   */\n 155→  async function getLastResult(type) {\n 156→    const paths = getPaths(type);\n 157→    return readJsonFile(paths.lastResultFile);\n 158→  }\n 159→\n 160→  /**\n 161→   * Write daemon meta file.\n 162→   * @param {PipelineType} type - Pipeline type\n 163→   * @param {DaemonMeta} meta - Daemon meta to write\n 164→   * @returns {Promise<void>}\n 165→   */\n 166→  async function writeDaemonMeta(type, meta) {\n 167→    const paths = getPaths(type);\n 168→    writeJsonFile(paths.daemonMetaFile, meta);\n 169→  }\n 170→\n 171→  /**\n 172→   * Write last result file.\n 173→   * @param {PipelineType} type - Pipeline type\n 174→   * @param {LastResult} result - Last result to write\n 175→   * @returns {Promise<void>}\n 176→   */\n 177→  async function writeLastResult(type, result) {\n 178→    const paths = getPaths(type);\n 179→    writeJsonFile(paths.lastResultFile, result);\n 180→  }\n 181→\n 182→  /**\n 183→   * Check if daemon is running.\n 184→   * @param {PipelineType} type - Pipeline type\n 185→   * @returns {Promise<boolean>} True if daemon is running\n 186→   */\n 187→  async function isDaemonRunning(type) {\n 188→    const meta = await readDaemonMeta(type);\n 189→    if (!meta || !meta.pid) {\n 190→      return false;\n 191→    }\n 192→    return isProcessAlive(meta.pid);\n 193→  }\n 194→\n 195→  /**\n 196→   * Get daemon PID.\n 197→   * @param {PipelineType} type - Pipeline type\n 198→   * @returns {Promise<number | null>} Daemon PID or null\n 199→   */\n 200→  async function getDaemonPid(type) {\n 201→    const meta = await readDaemonMeta(type);\n 202→    return meta?.pid ?? null;\n 203→  }\n 204→\n 205→  /**\n 206→   * Read log file with line limit.\n 207→   * @param {PipelineType} type - Pipeline type\n 208→   * @param {number} [lines] - Number of lines (default: 100)\n 209→   * @returns {Promise<{logs: string, logPath: string, lines: number}>}\n 210→   */\n 211→  async function readLogs(type, lines = 100) {\n 212→    const paths = getPaths(type);\n 213→    const logPath = paths.daemonLogFile;\n 214→\n 215→    if (!fs.existsSync(logPath)) {\n 216→      return { logs: '', logPath, lines: 0 };\n 217→    }\n 218→\n 219→    try {\n 220→      const content = fs.readFileSync(logPath, 'utf8');\n 221→      const allLines = content.split('\\n');\n 222→      const selectedLines = allLines.slice(-lines);\n 223→      return {\n 224→        logs: selectedLines.join('\\n'),\n 225→        logPath,\n 226→        lines: selectedLines.filter(l => l.trim()).length\n 227→      };\n 228→    } catch {\n 229→      return { logs: '', logPath, lines: 0 };\n 230→    }\n 231→  }\n 232→\n 233→  return {\n 234→    readDaemonMeta,\n 235→    readPipelineState,\n 236→    readCurrentSession,\n 237→    getLastResult,\n 238→    writeDaemonMeta,\n 239→    writeLastResult,\n 240→    isDaemonRunning,\n 241→    getDaemonPid,\n 242→    readLogs\n 243→  };\n 244→}\n 245→\n 246→// Default instance\n 247→let defaultManager = null;\n 248→\n 249→/**\n 250→ * Get default state manager instance.\n 251→ * @returns {Object} Default state manager\n 252→ */\n 253→export function getDefaultStateManager() {\n 254→  if (!defaultManager) {\n 255→    defaultManager = createStateManager();\n 256→  }\n 257→  return defaultManager;\n 258→}\n 259→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:00.820Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"e6aa3147-586b-406d-8121-41e11b6f7174","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde79583ba57ddea5e80523357ced","content":[{"type":"text","text":"   1→import fs from 'node:fs';\n   2→import { createLockManager, getDefaultLockManager } from '../pipeline-infra/lock-manager.js';\n   3→import { createStateManager, getDefaultStateManager } from '../pipeline-infra/state-manager.js';\n   4→import { executePipelineCommand, buildPipelineCommand } from '../pipeline-infra/script-runner.js';\n   5→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   6→import { resolveDaemonLogPaths } from '../pipeline-infra/path-policy.js';\n   7→import { INFRA_ERROR_CODES } from '../pipeline-infra/error-codes.js';\n   8→\n   9→const DEFAULT_LOG_LINES = 100;\n  10→const DEFAULT_STOP_TIMEOUT_MS = 10000;\n  11→\n  12→/**\n  13→ * Build an error result object.\n  14→ * @param {string} errorCode - Error code\n  15→ * @param {string} message - Error message\n  16→ * @param {Object} [options] - Additional options\n  17→ * @param {string} [options.hint] - Hint for resolving the error\n  18→ * @param {Object} [options.context] - Additional context\n  19→ * @returns {Object} Error result\n  20→ */\n  21→function buildError(errorCode, message, options = {}) {\n  22→  return {\n  23→    ok: false,\n  24→    errorCode,\n  25→    message,\n  26→    ...(options.hint ? { hint: options.hint } : {}),\n  27→    ...(options.context ? { context: options.context } : {})\n  28→  };\n  29→}\n  30→\n  31→/**\n  32→ * Build a success result object.\n  33→ * @param {string} message - Success message\n  34→ * @param {Object} [extra] - Additional fields\n  35→ * @returns {Object} Success result\n  36→ */\n  37→function buildResult(message, extra = {}) {\n  38→  return {\n  39→    ok: true,\n  40→    message,\n  41→    ...extra\n  42→  };\n  43→}\n  44→\n  45→/**\n  46→ * Generate a unique run ID.\n  47→ * @returns {string} Run ID\n  48→ */\n  49→function generateRunId() {\n  50→  const now = new Date();\n  51→  const timestamp = now.toISOString().replace(/[-:T]/g, '').slice(0, 15);\n  52→  return `run-${timestamp}`;\n  53→}\n  54→\n  55→/**\n  56→ * Read last N lines from a file.\n  57→ * @param {string} filePath - Path to file\n  58→ * @param {number} lines - Number of lines to read\n  59→ * @returns {string} File content\n  60→ */\n  61→function readLastLines(filePath, lines) {\n  62→  try {\n  63→    const content = fs.readFileSync(filePath, 'utf8');\n  64→    const allLines = content.split('\\n');\n  65→    const selectedLines = allLines.slice(-lines);\n  66→    return selectedLines.join('\\n');\n  67→  } catch {\n  68→    return '';\n  69→  }\n  70→}\n  71→\n  72→/**\n  73→ * Create a pipeline controller instance.\n  74→ * @param {Object} options - Options\n  75→ * @param {Object} [options.lockManager] - Lock manager instance\n  76→ * @param {Object} [options.stateManager] - State manager instance\n  77→ * @param {Function} [options.scriptRunner] - Script runner function\n  78→ * @param {Object} [options.config] - Pipeline config\n  79→ * @returns {Object} Pipeline controller interface\n  80→ */\n  81→export function createPipelineController(options = {}) {\n  82→  const lockManager = options.lockManager || getDefaultLockManager();\n  83→  const stateManager = options.stateManager || getDefaultStateManager();\n  84→  const scriptRunner = options.scriptRunner || executePipelineCommand;\n  85→  const config = options.config || loadPipelineInfraConfig();\n  86→\n  87→  /**\n  88→   * Internal: Acquire lock and return result.\n  89→   * @param {string} type - Pipeline type\n  90→   * @returns {Promise<Object|null>} Lock result or null on success\n  91→   */\n  92→  async function _acquireLock(type) {\n  93→    const lockResult = await lockManager.acquireLock(type);\n  94→    if (!lockResult.ok) {\n  95→      return buildError(\n  96→        INFRA_ERROR_CODES.LOCK_ACQUISITION_FAILED,\n  97→        `Pipeline ${type} is already running`,\n  98→        {\n  99→          hint: 'Stop the current pipeline first or use forceUnlock',\n 100→          context: { currentHolder: lockResult.currentHolder }\n 101→        }\n 102→      );\n 103→    }\n 104→    return null;\n 105→  }\n 106→\n 107→  /**\n 108→   * Internal: Release lock.\n 109→   * @param {string} type - Pipeline type\n 110→   */\n 111→  async function _releaseLock(type) {\n 112→    await lockManager.releaseLock(type);\n 113→  }\n 114→\n 115→  return {\n 116→    // Internal methods (exposed for testing)\n 117→    _acquireLock,\n 118→    _releaseLock,\n 119→\n 120→    /**\n 121→     * Start a pipeline.\n 122→     * @param {Object} params - Parameters\n 123→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 124→     * @param {string} [params.targetId] - Optional target ID to start with\n 125→     * @param {string} [params.listPath] - Optional list path\n 126→     * @param {boolean} [params.daemon=true] - Run in daemon mode\n 127→     * @param {Object} [params.envOverrides] - Environment overrides\n 128→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 129→     * @returns {Promise<Object>} Start result\n 130→     */\n 131→    async startPipeline(params) {\n 132→      const { type = 'feature', targetId, listPath, daemon = true, envOverrides, timeoutMs } = params;\n 133→\n 134→      // Acquire lock\n 135→      const lockError = await _acquireLock(type);\n 136→      if (lockError) {\n 137→        return lockError;\n 138→      }\n 139→\n 140→      // Build and execute command\n 141→      const runId = generateRunId();\n 142→\n 143→      try {\n 144→        const result = await scriptRunner({\n 145→          pipelineType: type,\n 146→          action: 'run',\n 147→          targetId,\n 148→          listPath,\n 149→          envOverrides,\n 150→          timeoutMs\n 151→        });\n 152→\n 153→        if (!result.ok) {\n 154→          // Release lock on failure\n 155→          await _releaseLock(type);\n 156→          return buildError(\n 157→            result.errorCode || INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 158→            result.stderr || 'Failed to start pipeline',\n 159→            { context: { exitCode: result.exitCode } }\n 160→          );\n 161→        }\n 162→\n 163→        return buildResult(`Pipeline ${type} started successfully`, {\n 164→          runId,\n 165→          pid: daemon ? process.pid : undefined,\n 166→          stdout: result.stdout\n 167→        });\n 168→      } catch (error) {\n 169→        await _releaseLock(type);\n 170→        return buildError(\n 171→          INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 172→          error.message,\n 173→          { hint: 'Check pipeline scripts and configuration' }\n 174→        );\n 175→      }\n 176→    },\n 177→\n 178→    /**\n 179→     * Stop a pipeline.\n 180→     * @param {Object} params - Parameters\n 181→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 182→     * @param {number} [params.timeoutMs=10000] - Timeout in milliseconds\n 183→     * @returns {Promise<Object>} Stop result\n 184→     */\n 185→    async stopPipeline(params) {\n 186→      const { type = 'feature', timeoutMs = DEFAULT_STOP_TIMEOUT_MS } = params;\n 187→\n 188→      // Check if daemon is running\n 189→      const isRunning = await stateManager.isDaemonRunning(type);\n 190→      const previousPid = await stateManager.getDaemonPid(type);\n 191→\n 192→      if (!isRunning) {\n 193→        // Already stopped\n 194→        return buildResult(`Pipeline ${type} is not running`, {\n 195→          errorCode: INFRA_ERROR_CODES.ALREADY_STOPPED,\n 196→          previousPid\n 197→        });\n 198→      }\n 199→\n 200→      try {\n 201→        // Execute stop command\n 202→        const result = await scriptRunner({\n 203→          pipelineType: type,\n 204→          action: 'stop',\n 205→          timeoutMs\n 206→        });\n 207→\n 208→        // Release lock\n 209→        await _releaseLock(type);\n 210→\n 211→        if (!result.ok) {\n 212→          return buildError(\n 213→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 214→            result.stderr || 'Failed to stop pipeline',\n 215→            { context: { previousPid } }\n 216→          );\n 217→        }\n 218→\n 219→        return buildResult(`Pipeline ${type} stopped successfully`, {\n 220→          previousPid\n 221→        });\n 222→      } catch (error) {\n 223→        // Still release lock on error\n 224→        await _releaseLock(type);\n 225→        return buildError(\n 226→          INFRA_ERROR_CODES.EXEC_FAILED,\n 227→          error.message,\n 228→          { context: { previousPid } }\n 229→        );\n 230→      }\n 231→    },\n 232→\n 233→    /**\n 234→     * Retry a target.\n 235→     * @param {Object} params - Parameters\n 236→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 237→     * @param {string} params.targetId - Target ID to retry\n 238→     * @param {string} [params.listPath] - Optional list path\n 239→     * @param {boolean} [params.daemon=false] - Run in daemon mode\n 240→     * @param {Object} [params.envOverrides] - Environment overrides\n 241→     * @returns {Promise<Object>} Retry result\n 242→     */\n 243→    async retryTarget(params) {\n 244→      const { type = 'feature', targetId, listPath, daemon = false, envOverrides } = params;\n 245→\n 246→      // Validate targetId\n 247→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 248→        return buildError(\n 249→          INFRA_ERROR_CODES.INVALID_TARGET,\n 250→          'targetId is required for retry',\n 251→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 252→        );\n 253→      }\n 254→\n 255→      // For daemon mode, acquire lock\n 256→      if (daemon) {\n 257→        const lockError = await _acquireLock(type);\n 258→        if (lockError) {\n 259→          return lockError;\n 260→        }\n 261→      }\n 262→\n 263→      try {\n 264→        const result = await scriptRunner({\n 265→          pipelineType: type,\n 266→          action: 'retry',\n 267→          targetId: targetId.trim(),\n 268→          listPath,\n 269→          envOverrides\n 270→        });\n 271→\n 272→        if (daemon) {\n 273→          await _releaseLock(type);\n 274→        }\n 275→\n 276→        if (!result.ok) {\n 277→          return buildError(\n 278→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 279→            result.stderr || `Failed to retry target ${targetId}`,\n 280→            { context: { targetId } }\n 281→          );\n 282→        }\n 283→\n 284→        return buildResult(`Target ${targetId} retry completed`, {\n 285→          targetId,\n 286→          stdout: result.stdout\n 287→        });\n 288→      } catch (error) {\n 289→        if (daemon) {\n 290→          await _releaseLock(type);\n 291→        }\n 292→        return buildError(\n 293→          INFRA_ERROR_CODES.EXEC_FAILED,\n 294→          error.message,\n 295→          { context: { targetId } }\n 296→        );\n 297→      }\n 298→    },\n 299→\n 300→    /**\n 301→     * Run a single target without affecting pipeline state.\n 302→     * @param {Object} params - Parameters\n 303→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 304→     * @param {string} params.targetId - Target ID to run\n 305→     * @param {string} [params.listPath] - Optional list path\n 306→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 307→     * @param {Object} [params.envOverrides] - Environment overrides\n 308→     * @returns {Promise<Object>} Run result\n 309→     */\n 310→    async runSingle(params) {\n 311→      const { type = 'feature', targetId, listPath, timeoutMs, envOverrides } = params;\n 312→\n 313→      // Validate targetId\n 314→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 315→        return buildError(\n 316→          INFRA_ERROR_CODES.INVALID_TARGET,\n 317→          'targetId is required for runSingle',\n 318→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 319→        );\n 320→      }\n 321→\n 322→      // Note: runSingle does NOT acquire lock (independent execution per D5)\n 323→\n 324→      try {\n 325→        const result = await scriptRunner({\n 326→          pipelineType: type,\n 327→          action: 'run',\n 328→          targetId: targetId.trim(),\n 329→          listPath,\n 330→          timeoutMs,\n 331→          envOverrides\n 332→        });\n 333→\n 334→        return {\n 335→          ok: result.ok,\n 336→          targetId,\n 337→          message: result.ok\n 338→            ? `Target ${targetId} completed successfully`\n 339→            : `Target ${targetId} failed`,\n 340→          stdout: result.stdout,\n 341→          stderr: result.stderr,\n 342→          exitCode: result.exitCode,\n 343→          errorCode: result.errorCode\n 344→        };\n 345→      } catch (error) {\n 346→        return buildError(\n 347→          INFRA_ERROR_CODES.EXEC_FAILED,\n 348→          error.message,\n 349→          { context: { targetId } }\n 350→        );\n 351→      }\n 352→    },\n 353→\n 354→    /**\n 355→     * Get pipeline status.\n 356→     * @param {Object} params - Parameters\n 357→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 358→     * @returns {Promise<Object>} Status result\n 359→     */\n 360→    async getStatus(params) {\n 361→      const { type = 'feature' } = params;\n 362→\n 363→      const isRunning = await stateManager.isDaemonRunning(type);\n 364→      const pid = await stateManager.getDaemonPid(type);\n 365→      const pipelineState = await stateManager.readPipelineState(type);\n 366→      const currentSession = await stateManager.readCurrentSession(type);\n 367→      const lastResult = await stateManager.getLastResult(type);\n 368→      const lockInfo = await lockManager.getLockInfo(type);\n 369→\n 370→      const result = {\n 371→        ok: true,\n 372→        isRunning,\n 373→        pid: isRunning ? pid : undefined,\n 374→        message: isRunning\n 375→          ? `Pipeline ${type} is running`\n 376→          : `Pipeline ${type} is not running`\n 377→      };\n 378→\n 379→      // Add current feature info if running\n 380→      if (isRunning && currentSession) {\n 381→        result.currentFeature = currentSession.feature_id;\n 382→        result.startedAt = currentSession.started_at;\n 383→      }\n 384→\n 385→      // Add last result if not running\n 386→      if (!isRunning && lastResult) {\n 387→        result.lastResult = lastResult;\n 388→      }\n 389→\n 390→      // Add lock info\n 391→      if (lockInfo) {\n 392→        result.lockInfo = lockInfo;\n 393→      }\n 394→\n 395→      return result;\n 396→    },\n 397→\n 398→    /**\n 399→     * Get pipeline logs.\n 400→     * @param {Object} params - Parameters\n 401→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 402→     * @param {number} [params.lines=100] - Number of lines to read\n 403→     * @returns {Promise<Object>} Logs result\n 404→     */\n 405→    async getLogs(params) {\n 406→      const { type = 'feature', lines = DEFAULT_LOG_LINES } = params;\n 407→\n 408→      const logPaths = resolveDaemonLogPaths(config.projectRoot);\n 409→      const logPath = type === 'feature'\n 410→        ? logPaths.featureDaemonLog\n 411→        : logPaths.bugfixDaemonLog;\n 412→\n 413→      const logs = readLastLines(logPath, lines);\n 414→\n 415→      return buildResult(`Retrieved ${lines} lines from ${type} log`, {\n 416→        logs,\n 417→        logPath,\n 418→        lines\n 419→      });\n 420→    },\n 421→\n 422→    /**\n 423→     * Force unlock a pipeline (admin operation).\n 424→     * @param {Object} params - Parameters\n 425→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 426→     * @returns {Promise<Object>} Unlock result\n 427→     */\n 428→    async forceUnlock(params) {\n 429→      const { type = 'feature' } = params;\n 430→\n 431→      const result = await lockManager.forceUnlock(type);\n 432→\n 433→      return buildResult(`Lock released for ${type} pipeline`, {\n 434→        previousPid: result.previousPid\n 435→      });\n 436→    }\n 437→  };\n 438→}\n 439→\n 440→// Default instance\n 441→let defaultController = null;\n 442→\n 443→/**\n 444→ * Get the default pipeline controller instance.\n 445→ * @returns {Object} Pipeline controller instance\n 446→ */\n 447→export function getDefaultPipelineController() {\n 448→  if (!defaultController) {\n 449→    defaultController = createPipelineController();\n 450→  }\n 451→  return defaultController;\n 452→}\n 453→\n 454→// Export convenience methods that use default controller\n 455→export async function startPipeline(params) {\n 456→  return getDefaultPipelineController().startPipeline(params);\n 457→}\n 458→\n 459→export async function stopPipeline(params) {\n 460→  return getDefaultPipelineController().stopPipeline(params);\n 461→}\n 462→\n 463→export async function retryTarget(params) {\n 464→  return getDefaultPipelineController().retryTarget(params);\n 465→}\n 466→\n 467→export async function runSingle(params) {\n 468→  return getDefaultPipelineController().runSingle(params);\n 469→}\n 470→\n 471→export async function getStatus(params) {\n 472→  return getDefaultPipelineController().getStatus(params);\n 473→}\n 474→\n 475→export async function getLogs(params) {\n 476→  return getDefaultPipelineController().getLogs(params);\n 477→}\n 478→\n 479→export async function forceUnlock(params) {\n 480→  return getDefaultPipelineController().forceUnlock(params);\n 481→}\n 482→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:00.821Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
