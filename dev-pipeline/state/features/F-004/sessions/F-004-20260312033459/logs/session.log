0] Create pipeline-controller.js with factory function — file: src/services/pipeline-controller.js\n  51→- [ ] [T-051] Implement dependency injection in createPipelineController — file: src/services/pipeline-controller.js\n  52→- [ ] [T-052] Implement _acquireLock internal method — file: src/services/pipeline-controller.js\n  53→- [ ] [T-053] Implement _releaseLock internal method — file: src/services/pipeline-controller.js\n  54→- [ ] [T-054] Add buildError helper for consistent error formatting — file: src/services/pipeline-controller.js\n  55→- [ ] [T-055] Add buildResult helper for success responses — file: src/services/pipeline-controller.js\n  56→- [ ] [T-056] Export default service instance — file: src/services/pipeline-controller.js\n  57→- [ ] [T-057] [P] Write unit tests for factory and helpers — file: tests/services/pipeline-controller.test.js\n  58→\n  59→---\n  60→\n  61→## Phase 3: User Stories (T-100+)\n  62→\n  63→### US-1: Unified Pipeline Start (T-100 ~ T-119)\n  64→\n  65→- [ ] [T-100] Implement startPipeline skeleton — file: src/services/pipeline-controller.js\n  66→- [ ] [T-101] Add lock acquisition in startPipeline — file: src/services/pipeline-controller.js\n  67→- [ ] [T-102] Implement daemon mode start (launch-daemon.sh) — file: src/services/pipeline-controller.js\n  68→- [ ] [T-103] Implement foreground mode start (run.sh) — file: src/services/pipeline-controller.js\n  69→- [ ] [T-104] Add targetId support in startPipeline — file: src/services/pipeline-controller.js\n  70→- [ ] [T-105] Return structured result with runId/pid — file: src/services/pipeline-controller.js\n  71→- [ ] [T-106] Handle LOCK_ACQUISITION_FAILED error — file: src/services/pipeline-controller.js\n  72→- [ ] [T-107] [P] Write unit tests for startPipeline daemon mode — file: tests/services/pipeline-controller.test.js\n  73→- [ ] [T-108] [P] Write unit tests for startPipeline foreground mode — file: tests/services/pipeline-controller.test.js\n  74→- [ ] [T-109] Write inte