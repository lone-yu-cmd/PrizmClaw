teStateManager({ config });\n 412→\n 413→    const result = await manager.readLogs('feature');\n 414→    assert.equal(result.logs, '');\n 415→    assert.equal(result.lines, 0);\n 416→  } finally {\n 417→    cleanup();\n 418→  }\n 419→});\n 420→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:20.205Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"bf525f8a-c84b-467e-806a-bd1d5dce4dbd","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde79a3aa43391096eec76b60c9d3","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Controller Unit Tests\n   3→ * Tests for src/services/pipeline-controller.js\n   4→ *\n   5→ * F-004: Pipeline Process Controller - All User Stories\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createPipelineController } from '../../src/services/pipeline-controller.js';\n  15→import { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n  16→import { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  17→\n  18→/**\n  19→ * Helper to create temp directory for test state\n  20→ */\n  21→function createTempStateDir() {\n  22→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'pipeline-controller-test-'));\n  23→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  24→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  25→  fs.mkdirSync(stateDir, { recursive: true });\n  26→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  27→  return {\n  28→    tempDir,\n  29→    stateDir,\n  30→    bugfixStateDir,\n  31→    cleanup: () => {\n  32→      fs.rmSync(tempDir, { recursive: true, force: true });\n  33→    }\n  34→  };\n  35→}\n  36→\n  37→/**\n  38→ * Helper to create a mock config\n  39→ */\n  40→function createMockConfig(stateDir, bugfixStateDir) {\n  41→  const projectRoot = path.dirname(path.dirname(stateDir));\n  42→  return {\n  43→    projectRoot,\n  44→    stateDir,\n  45→    bugfixStateDir\n  46→  };\n  47→}\n  48→\n  49→/**\n  50→ * Helper to create a mock script runner\n  51→ */\n  52→function createMockScriptRunner() {\n  53→  return async (req) => ({\n  54→    ok: true,\n  55→    exitCode: 0,\n  56→    stdout: 'Mock output',\n  57→    stderr: '',\n  58→    normalizedStatus: 'success'\n  59→  });\n  60→}\n  61→\n  62→// ============================================================\n  63→// Factory Tests\n  64→// ============================================================\n  65→\n  66→test('createPipelineController should be a factory function', () => {\n  67→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  68→  try {\n  69→    const config = createMockConfig(stateDir, bugfixStateDir);\n  70→    const controller = createPipelineController({\n  71→      config,\n  72→      lockManager: createLockManager({ config }),\n  73→      stateManager: createStateManager({ config }),\n  74→      scriptRunner: createMockScriptRunner()\n  75→    });\n  76→\n  77→    assert.equal(typeof controller.startPipeline, 'function');\n  78→    assert.equal(typeof controller.stopPipeline, 'function');\n  79→    assert.equal(typeof controller.retryTarget, 'function');\n  80→    assert.equal(typeof controller.runSingle, 'function');\n  81→    assert.equal(typeof controller.getStatus, 'function');\n  82→    assert.equal(typeof controller.getLogs, 'function');\n  83→    assert.equal(typeof controller.forceUnlock, 'function');\n  84→    assert.equal(typeof controller._acquireLock, 'function');\n  85→    assert.equal(typeof controller._releaseLock, 'function');\n  86→  } finally {\n  87→    cleanup();\n  88→  }\n  89→});\n  90→\n  91→test('createPipelineController should accept dependency injection', () => {\n  92→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  93→  try {\n  94→    const config = createMockConfig(stateDir, bugfixStateDir);\n  95→    const lockManager = createLockManager({ config });\n  96→    const stateManager = createStateManager({ config });\n  97→    const scriptRunner = createMockScriptRunner();\n  98→\n  99→    const controller = createPipelineController({\n 100→      lockManager,\n 101→      stateManager,\n 102→      scriptRunner,\n 103→      config\n 104→    });\n 105→\n 106→    assert.ok(controller);\n 107→  } finally {\n 108→    cleanup();\n 109→  }\n 110→});\n 111→\n 112→// ============================================================\n 113→// US-1: startPipeline Tests\n 114→// ============================================================\n 115→\n 116→test('startPipeline should acquire lock before starting daemon', async () => {\n 117→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 118→  try {\n 119→    const config = createMockConfig(stateDir, bugfixStateDir);\n 120→    const lockManager = createLockManager({ config });\n 121→    const stateManager = createStateManager({ config });\n 122→    const scriptRunner = createMockScriptRunner();\n 123→\n 124→    const controller = createPipelineController({\n 125→      lockManager,\n 126→      stateManager,\n 127→      scriptRunner,\n 128→      config\n 129→    });\n 130→\n 131→    const result = await controller.startPipeline({ type: 'feature' });\n 132→    assert.equal(result.ok, true);\n 133→\n 134→    // Lock should be held\n 135→    const isLocked = await lockManager.isLocked('feature');\n 136→    assert.equal(isLocked, true);\n 137→  } finally {\n 138→    cleanup();\n 139→  }\n 140→});\n 141→\n 142→test('startPipeline should handle LOCK_ACQUISITION_FAILED error', async () => {\n 143→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 144→  try {\n 145→    const config = createMockConfig(stateDir, bugfixStateDir);\n 146→    const lockManager = createLockManager({ config });\n 147→    const stateManager = createStateManager({ config });\n 148→    const scriptRunner = createMockScriptRunner();\n 149→\n 150→    const controller = createPipelineController({\n 151→      lockManager,\n 152→      stateManager,\n 153→      scriptRunner,\n 154→      config\n 155→    });\n 156→\n 157→    // Acquire lock first\n 158→    await lockManager.acquireLock('feature', process.pid);\n 159→\n 160→    // Try to start again\n 161→    const result = await controller.startPipeline({ type: 'feature' });\n 162→    assert.equal(result.ok, false);\n 163→    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n 164→    assert.ok(result.hint);\n 165→    assert.ok(result.context);\n 166→  } finally {\n 167→    cleanup();\n 168→  }\n 169→});\n 170→\n 171→test('startPipeline should support daemon mode (default)', async () => {\n 172→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 173→  try {\n 174→    const config = createMockConfig(stateDir, bugfixStateDir);\n 175→    const lockManager = createLockManager({ config });\n 176→    const stateManager = createStateManager({ config });\n 177→    const scriptRunner = createMockScriptRunner();\n 178→\n 179→    const controller = createPipelineController({\n 180→      lockManager,\n 181→      stateManager,\n 182→      scriptRunner,\n 183→      config\n 184→    });\n 185→\n 186→    const result = await controller.startPipeline({ type: 'feature' });\n 187→    assert.equal(result.ok, true);\n 188→    assert.ok(result.runId);\n 189→  } finally {\n 190→    cleanup();\n 191→  }\n 192→});\n 193→\n 194→test('startPipeline should support targetId parameter', async () => {\n 195→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 196→  try {\n 197→    const config = createMockConfig(stateDir, bugfixStateDir);\n 198→    const lockManager = createLockManager({ config });\n 199→    const stateManager = createStateManager({ config });\n 200→\n 201→    let capturedTargetId = null;\n 202→    const scriptRunner = async (req) => {\n 203→      capturedTargetId = req.targetId;\n 204→      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n 205→    };\n 206→\n 207→    const controller = createPipelineController({\n 208→      lockManager,\n 209→      stateManager,\n 210→      scriptRunner,\n 211→      config\n 212→    });\n 213→\n 214→    const result = await controller.startPipeline({ type: 'feature', targetId: 'F-001' });\n 215→    assert.equal(result.ok, true);\n 216→    assert.equal(capturedTargetId, 'F-001');\n 217→  } finally {\n 218→    cleanup();\n 219→  }\n 220→});\n 221→\n 222→test('startPipeline should work for both feature and bugfix types', async () => {\n 223→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 224→  try {\n 225→    const config = createMockConfig(stateDir, bugfixStateDir);\n 226→    const lockManager = createLockManager({ config });\n 227→    const stateManager = createStateManager({ config });\n 228→    const scriptRunner = createMockScriptRunner();\n 229→\n 230→    const controller = createPipelineController({\n 231→      lockManager,\n 232→      stateManager,\n 233→      scriptRunner,\n 234→      config\n 235→    });\n 236→\n 237→    const featureResult = await controller.startPipeline({ type: 'feature' });\n 238→    assert.equal(featureResult.ok, true);\n 239→\n 240→    const bugfixResult = await controller.startPipeline({ type: 'bugfix' });\n 241→    assert.equal(bugfixResult.ok, true);\n 242→  } finally {\n 243→    cleanup();\n 244→  }\n 245→});\n 246→\n 247→// ============================================================\n 248→// US-2: stopPipeline Tests\n 249→// ============================================================\n 250→\n 251→test('stopPipeline should release lock after stop', async () => {\n 252→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 253→  try {\n 254→    const config = createMockConfig(stateDir, bugfixStateDir);\n 255→    const lockManager = createLockManager({ config });\n 256→    const stateManager = createStateManager({ config });\n 257→    const scriptRunner = createMockScriptRunner();\n 258→\n 259→    const controller = createPipelineController({\n 260→      lockManager,\n 261→      stateManager,\n 262→      scriptRunner,\n 263→      config\n 264→    });\n 265→\n 266→    // Start first (this acquires the lock)\n 267→    await controller.startPipeline({ type: 'feature' });\n 268→    assert.equal(await lockManager.isLocked('feature'), true);\n 269→\n 270→    // Write daemon meta to simulate running daemon\n 271→    await stateManager.writeDaemonMeta('feature', {\n 272→      pid: process.pid,\n 273→      started_at: new Date().toISOString(),\n 274→      feature_list: '/path/to/list.json',\n 275→      env_overrides: '',\n 276→      log_file: '/path/to/log'\n 277→    });\n 278→\n 279→    // Stop\n 280→    const result = await controller.stopPipeline({ type: 'feature' });\n 281→    assert.equal(result.ok, true);\n 282→    assert.equal(await lockManager.isLocked('feature'), false);\n 283→  } finally {\n 284→    cleanup();\n 285→  }\n 286→});\n 287→\n 288→test('stopPipeline should return ALREADY_STOPPED if not running', async () => {\n 289→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 290→  try {\n 291→    const config = createMockConfig(stateDir, bugfixStateDir);\n 292→    const lockManager = createLockManager({ config });\n 293→    const stateManager = createStateManager({ config });\n 294→    const scriptRunner = createMockScriptRunner();\n 295→\n 296→    const controller = createPipelineController({\n 297→      lockManager,\n 298→      stateManager,\n 299→      scriptRunner,\n 300→      config\n 301→    });\n 302→\n 303→    // Stop without starting\n 304→    const result = await controller.stopPipeline({ type: 'feature' });\n 305→    assert.equal(result.ok, true);\n 306→    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 307→  } finally {\n 308→    cleanup();\n 309→  }\n 310→});\n 311→\n 312→// ============================================================\n 313→// US-3: retryTarget Tests\n 314→// ============================================================\n 315→\n 316→test('retryTarget should validate targetId is provided', async () => {\n 317→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 318→  try {\n 319→    const config = createMockConfig(stateDir, bugfixStateDir);\n 320→    const lockManager = createLockManager({ config });\n 321→    const stateManager = createStateManager({ config });\n 322→    const scriptRunner = createMockScriptRunner();\n 323→\n 324→    const controller = createPipelineController({\n 325→      lockManager,\n 326→      stateManager,\n 327→      scriptRunner,\n 328→      config\n 329→    });\n 330→\n 331→    const result = await controller.retryTarget({ type: 'feature' });\n 332→    assert.equal(result.ok, false);\n 333→    assert.equal(result.errorCode, 'INVALID_TARGET');\n 334→    assert.ok(result.hint);\n 335→  } finally {\n 336→    cleanup();\n 337→  }\n 338→});\n 339→\n 340→test('retryTarget should support foreground mode (default)', async () => {\n 341→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 342→  try {\n 343→    const config = createMockConfig(stateDir, bugfixStateDir);\n 344→    const lockManager = createLockManager({ config });\n 345→    const stateManager = createStateManager({ config });\n 346→    const scriptRunner = createMockScriptRunner();\n 347→\n 348→    const controller = createPipelineController({\n 349→      lockManager,\n 350→      stateManager,\n 351→      scriptRunner,\n 352→      config\n 353→    });\n 354→\n 355→    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n 356→    assert.equal(result.ok, true);\n 357→    assert.equal(result.targetId, 'F-001');\n 358→\n 359→    // Should not hold lock (foreground mode)\n 360→    assert.equal(await lockManager.isLocked('feature'), false);\n 361→  } finally {\n 362→    cleanup();\n 363→  }\n 364→});\n 365→\n 366→// ============================================================\n 367→// US-4: runSingle Tests\n 368→// ============================================================\n 369→\n 370→test('runSingle should NOT acquire lock', async () => {\n 371→  const { cleanup, stateDir, bugfixStateDir } = createTempStateD