{"type":"user","uuid":"2c765b3e-ec3c-4379-865f-6c6316763e9a","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde799e2fa20b6874a53c20808362","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import fs from 'node:fs';\n   4→import path from 'node:path';\n   5→import os from 'node:os';\n   6→\n   7→import { createPipelineController } from '../../src/services/pipeline-controller.js';\n   8→import { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n   9→import { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  10→import { loadPipelineInfraConfig } from '../../src/pipeline-infra/config-loader.js';\n  11→\n  12→async function withTempDir(fn) {\n  13→  const tempDir = await fs.promises.mkdtemp(path.join(os.tmpdir(), 'f004-integration-test-'));\n  14→  try {\n  15→    await fn(tempDir);\n  16→  } finally {\n  17→    await fs.promises.rm(tempDir, { recursive: true, force: true });\n  18→  }\n  19→}\n  20→\n  21→function createTestConfig(tempDir) {\n  22→  return {\n  23→    stateDir: path.join(tempDir, 'state'),\n  24→    bugfixStateDir: path.join(tempDir, 'bugfix-state'),\n  25→    pipelineDir: path.join(tempDir, 'dev-pipeline'),\n  26→    projectRoot: tempDir\n  27→  };\n  28→}\n  29→\n  30→async function setupStateFiles(tempDir, type = 'feature') {\n  31→  const stateDir = type === 'feature'\n  32→    ? path.join(tempDir, 'state')\n  33→    : path.join(tempDir, 'bugfix-state');\n  34→\n  35→  await fs.promises.mkdir(stateDir, { recursive: true });\n  36→\n  37→  // Create minimal daemon log\n  38→  await fs.promises.writeFile(\n  39→    path.join(stateDir, 'pipeline-daemon.log'),\n  40→    'Integration test log line 1\\nIntegration test log line 2\\n'\n  41→  );\n  42→\n  43→  return stateDir;\n  44→}\n  45→\n  46→// US-1: Unified Pipeline Start\n  47→test('US-1: Full lifecycle startPipeline with daemon mode', async () => {\n  48→  await withTempDir(async (tempDir) => {\n  49→    const config = createTestConfig(tempDir);\n  50→    await setupStateFiles(tempDir, 'feature');\n  51→\n  52→    const lockManager = createLockManager({ config });\n  53→    const stateManager = createStateManager({ config });\n  54→\n  55→    // Mock script runner for daemon start\n  56→    let runnerCalled = false;\n  57→    const mockRunner = async (req) => {\n  58→      runnerCalled = true;\n  59→      return { ok: true, exitCode: 0, stdout: 'Daemon started', stderr: '' };\n  60→    };\n  61→\n  62→    const controller = createPipelineController({\n  63→      lockManager,\n  64→      stateManager,\n  65→      scriptRunner: mockRunner,\n  66→      config\n  67→    });\n  68→\n  69→    const result = await controller.startPipeline({ type: 'feature', daemon: true });\n  70→\n  71→    assert.equal(result.ok, true);\n  72→    assert.ok(result.runId);\n  73→    assert.equal(runnerCalled, true);\n  74→  });\n  75→});\n  76→\n  77→test('US-1: startPipeline with foreground mode', async () => {\n  78→  await withTempDir(async (tempDir) => {\n  79→    const config = createTestConfig(tempDir);\n  80→\n  81→    const lockManager = createLockManager({ config });\n  82→    const stateManager = createStateManager({ config });\n  83→\n  84→    const mockRunner = async (req) => ({\n  85→      ok: true,\n  86→      exitCode: 0,\n  87→      stdout: 'Foreground run completed',\n  88→      stderr: ''\n  89→    });\n  90→\n  91→    const controller = createPipelineController({\n  92→      lockManager,\n  93→      stateManager,\n  94→      scriptRunner: mockRunner,\n  95→      config\n  96→    });\n  97→\n  98→    const result = await controller.startPipeline({ type: 'feature', daemon: false });\n  99→\n 100→    assert.equal(result.ok, true);\n 101→  });\n 102→});\n 103→\n 104→// US-2: Pipeline Stop\n 105→test('US-2: stopPipeline should stop running daemon', async () => {\n 106→  await withTempDir(async (tempDir) => {\n 107→    const config = createTestConfig(tempDir);\n 108→    await setupStateFiles(tempDir, 'feature');\n 109→\n 110→    const lockManager = createLockManager({ config });\n 111→    const stateManager = createStateManager({ config });\n 112→\n 113→    // Simulate running daemon\n 114→    await stateManager.writeDaemonMeta('feature', {\n 115→      pid: process.pid,\n 116→      started_at: new Date().toISOString()\n 117→    });\n 118→\n 119→    const mockRunner = async (req) => ({\n 120→      ok: true,\n 121→      exitCode: 0,\n 122→      stdout: 'Daemon stopped',\n 123→      stderr: ''\n 124→    });\n 125→\n 126→    const controller = createPipelineController({\n 127→      lockManager,\n 128→      stateManager,\n 129→      scriptRunner: mockRunner,\n 130→      config\n 131→    });\n 132→\n 133→    const result = await controller.stopPipeline({ type: 'feature' });\n 134→\n 135→    assert.equal(result.ok, true);\n 136→  });\n 137→});\n 138→\n 139→test('US-2: stopPipeline should return ALREADY_STOPPED when not running', async () => {\n 140→  await withTempDir(async (tempDir) => {\n 141→    const config = createTestConfig(tempDir);\n 142→\n 143→    const lockManager = createLockManager({ config });\n 144→    const stateManager = createStateManager({ config });\n 145→\n 146→    const controller = createPipelineController({\n 147→      lockManager,\n 148→      stateManager,\n 149→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 150→      config\n 151→    });\n 152→\n 153→    const result = await controller.stopPipeline({ type: 'feature' });\n 154→\n 155→    assert.equal(result.ok, true);\n 156→    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 157→  });\n 158→});\n 159→\n 160→// US-3: Target Retry\n 161→test('US-3: retryTarget should retry a failed target', async () => {\n 162→  await withTempDir(async (tempDir) => {\n 163→    const config = createTestConfig(tempDir);\n 164→\n 165→    const lockManager = createLockManager({ config });\n 166→    const stateManager = createStateManager({ config });\n 167→\n 168→    const mockRunner = async (req) => ({\n 169→      ok: true,\n 170→      exitCode: 0,\n 171→      stdout: 'Retry successful',\n 172→      stderr: ''\n 173→    });\n 174→\n 175→    const controller = createPipelineController({\n 176→      lockManager,\n 177→      stateManager,\n 178→      scriptRunner: mockRunner,\n 179→      config\n 180→    });\n 181→\n 182→    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n 183→\n 184→    assert.equal(result.ok, true);\n 185→    assert.equal(result.targetId, 'F-001');\n 186→  });\n 187→});\n 188→\n 189→// US-4: Run Single Feature\n 190→test('US-4: runSingle should execute single target without lock', async () => {\n 191→  await withTempDir(async (tempDir) => {\n 192→    const config = createTestConfig(tempDir);\n 193→\n 194→    const lockManager = createLockManager({ config });\n 195→    const stateManager = createStateManager({ config });\n 196→\n 197→    const mockRunner = async (req) => ({\n 198→      ok: true,\n 199→      exitCode: 0,\n 200→      stdout: 'Single run completed',\n 201→      stderr: ''\n 202→    });\n 203→\n 204→    const controller = createPipelineController({\n 205→      lockManager,\n 206→      stateManager,\n 207→      scriptRunner: mockRunner,\n 208→      config\n 209→    });\n 210→\n 211→    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 212→\n 213→    assert.equal(result.ok, true);\n 214→    assert.equal(result.targetId, 'F-001');\n 215→    assert.equal(result.stdout, 'Single run completed');\n 216→\n 217→    // Verify lock was not acquired\n 218→    assert.equal(await lockManager.isLocked('feature'), false);\n 219→  });\n 220→});\n 221→\n 222→// US-5: Status Query\n 223→test('US-5: getStatus should return complete status', async () => {\n 224→  await withTempDir(async (tempDir) => {\n 225→    const config = createTestConfig(tempDir);\n 226→    await setupStateFiles(tempDir, 'feature');\n 227→\n 228→    const lockManager = createLockManager({ config });\n 229→    const stateManager = createStateManager({ config });\n 230→\n 231→    // Write some state\n 232→    await stateManager.writeDaemonMeta('feature', {\n 233→      pid: process.pid,\n 234→      started_at: new Date().toISOString()\n 235→    });\n 236→\n 237→    await stateManager.writeLastResult('feature', {\n 238→      runId: 'run-001',\n 239→      completedAt: new Date().toISOString(),\n 240→      status: 'success',\n 241→      featuresTotal: 5,\n 242→      featuresCompleted: 5\n 243→    });\n 244→\n 245→    const controller = createPipelineController({\n 246→      lockManager,\n 247→      stateManager,\n 248→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 249→      config\n 250→    });\n 251→\n 252→    const result = await controller.getStatus({ type: 'feature' });\n 253→\n 254→    assert.equal(result.ok, true);\n 255→    assert.equal(result.isRunning, true);\n 256→    assert.ok(result.pid);\n 257→  });\n 258→});\n 259→\n 260→// US-6: Logs Query\n 261→test('US-6: getLogs should return daemon logs', async () => {\n 262→  await withTempDir(async (tempDir) => {\n 263→    const config = createTestConfig(tempDir);\n 264→    await setupStateFiles(tempDir, 'feature');\n 265→\n 266→    const lockManager = createLockManager({ config });\n 267→    const stateManager = createStateManager({ config });\n 268→\n 269→    const controller = createPipelineController({\n 270→      lockManager,\n 271→      stateManager,\n 272→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 273→      config\n 274→    });\n 275→\n 276→    const result = await controller.getLogs({ type: 'feature' });\n 277→\n 278→    assert.equal(result.ok, true);\n 279→    assert.ok(result.logs.includes('Integration test log'));\n 280→    assert.ok(result.logPath);\n 281→  });\n 282→});\n 283→\n 284→// US-7: Concurrency Protection\n 285→test('US-7: Concurrent start attempts should fail second attempt', async () => {\n 286→  await withTempDir(async (tempDir) => {\n 287→    const config = createTestConfig(tempDir);\n 288→\n 289→    const lockManager = createLockManager({ config });\n 290→    const stateManager = createStateManager({ config });\n 291→\n 292→    const mockRunner = async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' });\n 293→\n 294→    const controller = createPipelineController({\n 295→      lockManager,\n 296→      stateManager,\n 297→      scriptRunner: mockRunner,\n 298→      config\n 299→    });\n 300→\n 301→    // First start should succeed\n 302→    const result1 = await controller.startPipeline({ type: 'feature', daemon: true });\n 303→    assert.equal(result1.ok, true);\n 304→\n 305→    // Second start should fail due to lock\n 306→    const result2 = await controller.startPipeline({ type: 'feature', daemon: true });\n 307→    assert.equal(result2.ok, false);\n 308→    assert.equal(result2.errorCode, 'LOCK_ACQUISITION_FAILED');\n 309→  });\n 310→});\n 311→\n 312→test('US-7: forceUnlock should release stuck lock', async () => {\n 313→  await withTempDir(async (tempDir) => {\n 314→    const config = createTestConfig(tempDir);\n 315→\n 316→    const lockManager = createLockManager({ config });\n 317→    const stateManager = createStateManager({ config });\n 318→\n 319→    const mockRunner = async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' });\n 320→\n 321→    const controller = createPipelineController({\n 322→      lockManager,\n 323→      stateManager,\n 324→      scriptRunner: mockRunner,\n 325→      config\n 326→    });\n 327→\n 328→    // Start pipeline\n 329→    await controller.startPipeline({ type: 'feature', daemon: true });\n 330→    assert.equal(await lockManager.isLocked('feature'), true);\n 331→\n 332→    // Force unlock\n 333→    const result = await controller.forceUnlock({ type: 'feature' });\n 334→    assert.equal(result.ok, true);\n 335→    assert.equal(await lockManager.isLocked('feature'), false);\n 336→  });\n 337→});\n 338→\n 339→// US-8: Error Mapping\n 340→test('US-8: All errors should have structured error codes', async () => {\n 341→  await withTempDir(async (tempDir) => {\n 342→    const config = createTestConfig(tempDir);\n 343→\n 344→    const lockManager = createLockManager({ config });\n 345→    const stateManager = createStateManager({ config });\n 346→\n 347→    const controller = createPipelineController({\n 348→      lockManager,\n 349→      stateManager,\n 350→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 351→      config\n 352→    });\n 353→\n 354→    // Test error without targetId\n 355→    const result = await controller.retryTarget({ type: 'feature' });\n 356→\n 357→    assert.equal(result.ok, false);\n 358→    assert.ok(result.errorCode);\n 359→    assert.ok(result.message);\n 360→\n 361→    // Error should be JSON serializable\n 362→    const serialized = JSON.stringify(result);\n 363→    assert.ok(serialized);\n 364→  });\n 365→});\n 366→\n 367→// US-9: Telegram Handler Integration\n 368→test('US-9: All results should be JSON serializable for Telegram', async () => {\n 369→  await withTempDir(async (tempDir) => {\n 370→    const config = createTestConfig(tempDir);\n 371→    await setupStateFiles(tempDir, 'feature');\n 372→    await setupStateFiles(tempDir, 'bugfix');\n 373→\n 374→    const lockManager = createLockManager({ config });\n 375→    const stateManager = createStateManager({ config });\n 376→\n 377→    const mockRunner = async () => ({\n 378→      ok: true,\n 379→      exitCode: 0,\n 380→      stdout: 'Test output',\n 381→      stderr: ''\n 382→    });\n 383→\n 384→    const controller = createPipelineController({\n 385→      lockManager,\n 386→      stateManager,\n 387→      scriptRunner: mockRunner,\n 388→      config\n 389→    });\n 390→\n 391→    const results = {\n 392→      start: await controller.startPipeline({ type: 'feature' }),\n 393→      stop: await controller.stopPipeline({ type: 'feature' }),\n 394→      retry: await controller.retryTarget({ type: 'feature', targetId: 'F-001' }),\n 395→      single: await controller.runSingle({ type: 'feature', targetId: 'F-001' }),\n 396→      status: await controller.getStatus({ type: 'feature' }),\n 397→      logs: await controller.getLogs({ type: 'feature' }),\n 398→      unlock: await controller.forceUnlock({ type: 'feature' })\n 399→    };\n 400→\n 401→    for (const [key, result] of Object.entries(results)) {\n 402→      const serialized = JSON.stringify(result);\n 403→      assert.ok(serialized, `${key} result should be JSON serializable`);\n 404→\n 405→      const parsed = JSON.parse(serialized);\n 406→      assert.ok(parsed.ok !== undefined, `${key} result should have ok field`);\n 407→      assert.ok(parsed.message !== undefined, `${key} result should have message field`);\n 408→    }\n 409→  });\n 410→});\n 411→\n 412→// Full lifecycle test\n 413→test('Full lifecycle: start -> status -> stop', async () => {\n 414→  await withTempDir(async (tempDir) => {\n 415→    const config = createTestConfig(tempDir);\n 416→    await setupStateFiles(tempDir, 'feature');\n 417→\n 418→    const lockManager = createLockManager({ config });\n 419→    const stateManager = createStateManager({ config });\n 420→\n 421→    const mockRunner = async (req) => ({\n 422→      ok: true,\n 423→      exitCode: 0,\n 424→      stdout: `${req.action} completed`,\n 425→      stderr: ''\n 426→    });\n 427→\n 428→    const controller = createPipelineController({\n 429→      lockManager,\n 430→      stateManager,\n 431→      scriptRunner: mockRunner,\n 432→      config\n 433→    });\n 434→\n 435→    // Start\n 436→    const startResult = await controller.startPipeline({ type: 'feature', daemon: true });\n 437→    assert.equal(startResult.ok, true);\n 438→\n 439→    // Status (should be running)\n 440→    const statusResult = await controller.getStatus({ type: 'feature' });\n 441→    assert.equal(statusResult.ok, true);\n 442→\n 443→    // Stop\n 444→    const stopResult = await controller.stopPipeline({ type: 'feature' });\n 445→    assert.equal(stopResult.ok, true);\n 446→\n 447→    // Status (should not be running)\n 448→    const finalStatus = await controller.getStatus({ type: 'feature' });\n 449→    assert.equal(finalStatus.ok, true);\n 450→    assert.equal(finalStatus.isRunning, false);\n 451→  });\n 452→});\n 453→\n 454→// H-2: Integration test for forceUnlock (US-7)\n 455→test('H-2: forceUnlock should work even when lock is stale', async () => {\n 456→  await withTempDir(async (tempDir) => {\n 457→    const config = createTestConfig(tempDir);\n 458→\n 459→    const lockManager = createLockManager({ config });\n 460→    const stateManager = createStateManager({ config });\n 461→\n 462→    // Create a stale lock with a dead PID\n 463→    await lockManager.acquireLock('feature', 99999999);\n 464→\n 465→    const controller = createPipelineController({\n 466→      lockManager,\n 467→      stateManager,\n 468→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 469→      config\n 470→    });\n 471→\n 472→    // Force unlock should work\n 473→    const result = await controller.forceUnlock({ type: 'feature' });\n 474→    assert.equal(result.ok, true);\n 475→\n 476→    // Should now be able to start\n 477→    const startResult = await controller.startPipeline({ type: 'feature' });\n 478→    assert.equal(startResult.ok, true);\n 479→  });\n 480→});\n 481→\n 482→// H-5: Error code verification across operations\n 483→test('H-5: Error codes should be consistent across all operations', async () => {\n 484→  await withTempDir(async (tempDir) => {\n 485→    const config = createTestConfig(tempDir);\n 486→\n 487→    const lockManager = createLockManager({ config });\n 488→    const stateManager = createStateManager({ config });\n 489→\n 490→    const controller = createPipelineController({\n 491→      lockManager,\n 492→      stateManager,\n 493→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 494→      config\n 495→    });\n 496→\n 497→    // Test INVALID_TARGET for missing targetId\n 498→    const retryResult = await controller.retryTarget({ type: 'feature' });\n 499→    assert.equal(retryResult.errorCode, 'INVALID_TARGET');\n 500→\n 501→    const singleResult = await controller.runSingle({ type: 'feature' });\n 502→    assert.equal(singleResult.errorCode, 'INVALID_TARGET');\n 503→\n 504→    // Test LOCK_ACQUISITION_FAILED\n 505→    await controller.startPipeline({ type: 'feature' });\n 506→    const secondStart = await controller.startPipeline({ type: 'feature' });\n 507→    assert.equal(secondStart.errorCode, 'LOCK_ACQUISITION_FAILED');\n 508→\n 509→    // Verify all error codes are in the known set\n 510→    const knownCodes = [\n 511→      'LOCK_ACQUISITION_FAILED',\n 512→      'ALREADY_STOPPED',\n 513→      'PIPELINE_NOT_RUNNING',\n 514→      'INVALID_TARGET',\n 515→      'TARGET_NOT_RETRYABLE',\n 516→      'DAEMON_START_FAILED'\n 517→    ];\n 518→\n 519→    for (const code of knownCodes) {\n 520→      assert.ok(typeof code === 'string', `Error code ${code} should be a string`);\n 521→    }\n 522→  });\n 523→});\n 524→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:20.203Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"d8dcb396-f9ed-45c9-afa0-8a75d2a922e1","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde79a000816bae7678ff44d1228f","content":[{"type":"text","text":"   1→/**\n   2→ * Lock Manager Unit Tests\n   3→ * Tests for src/pipeline-infra/lock-manager.js\n   4→ *\n   5→ * F-004: Pipeline Process Controller - US-7 Concurrency Protection\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n  15→\n  16→/**\n  17→ * Helper to create temp directory for test state\n  18→ */\n  19→function createTempStateDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'lock-manager-test-'));\n  21→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  22→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  23→  fs.mkdirSync(stateDir, { recursive: true });\n  24→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  25→  return {\n  26→    tempDir,\n  27→    stateDir,\n  28→    bugfixStateDir,\n  29→    cleanup: () => {\n  30→      fs.rmSync(tempDir, { recursive: true, force: true });\n  31→    }\n  32→  };\n  33→}\n  34→\n  35→/**\n  36→ * Helper to create a mock config\n  37→ */\n  38→function createMockConfig(stateDir, bugfixStateDir) {\n  39→  const projectRoot = path.dirname(path.dirname(stateDir));\n  40→  return {\n  41→    projectRoot,\n  42→    stateDir,\n  43→    bugfixStateDir\n  44→  };\n  45→}\n  46→\n  47→test('createLockManager should be a factory function', () => {\n  48→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  49→  try {\n  50→    const config = createMockConfig(stateDir, bugfixStateDir);\n  51→    const manager = createLockManager({ config });\n  52→    assert.equal(typeof manager.acquireLock, 'function');\n  53→    assert.equal(typeof manager.releaseLock, 'function');\n  54→    assert.equal(typeof manager.isLocked, 'function');\n  55→    assert.equal(typeof manager.validateLock, 'function');\n  56→    assert.equal(typeof manager.forceUnlock, 'function');\n  57→    assert.equal(typeof manager.getLockInfo, 'function');\n  58→  } finally {\n  59→    cleanup();\n  60→  }\n  61→});\n  62→\n  63→test('acquireLock should create lock file with PID and timestamp', async () => {\n  64→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  65→  try {\n  66→    const config = createMockConfig(stateDir, bugfixStateDir);\n  67→    const manager = createLockManager({ config });\n  68→\n  69→    const result = await manager.acquireLock('feature', 12345);\n  70→\n  71→    assert.equal(result.ok, true);\n  72→    assert.ok(result.lockPath.endsWith('.pipeline.lock'));\n  73→\n  74→    // Verify lock file contents\n  75→    const lockContent = JSON.parse(fs.readFileSync(result.lockPath, 'utf8'));\n  76→    assert.equal(lockContent.pid, 12345);\n  77→    assert.ok(lockContent.acquiredAt);\n  78→    assert.equal(lockContent.type, 'feature');\n  79→    assert.ok(lockContent.hostname);\n  80→  } finally {\n  81→    cleanup();\n  82→  }\n  83→});\n  84→\n  85→test('acquireLock should fail if lock already held by live process', async () => {\n  86→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  87→  try {\n  88→    const config = createMockConfig(stateDir, bugfixStateDir);\n  89→    const manager = createLockManager({ config });\n  90→\n  91→    // First acquire with current process PID (guaranteed alive)\n  92→    const result1 = await manager.acquireLock('feature', process.pid);\n  93→    assert.equal(result1.ok, true);\n  94→\n  95→    // Try to acquire again with different PID\n  96→    const result2 = await manager.acquireLock('feature', 99999);\n  97→    assert.equal(result2.ok, false);\n  98→    assert.equal(result2.errorCode, 'LOCK_ACQUISITION_FAILED');\n  99→    assert.ok(result2.currentHolder);\n 100→    assert.equal(result2.currentHolder.pid, process.pid);\n 101→  } finally {\n 102→    cleanup();\n 103→  }\n 104→});\n 105→\n 106→test('acquireLock should succeed if lock held by dead process (stale lock)', async () => {\n 107→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 108→  try {\n 109→    const config = createMockConfig(stateDir, bugfixStateDir);\n 110→    const manager = createLockManager({ config });\n 111→\n 112→    // Create a stale lock with a non-existent PID\n 113→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 114→    const staleLock = {\n 115→      pid: 99999999, // Very unlikely to exist\n 116→      acquiredAt: new Date().toISOString(),\n 117→      type: 'feature',\n 118→      hostname: 'test'\n 119→    };\n 120→    fs.writeFileSync(lockPath, JSON.stringify(staleLock));\n 121→\n 122→    // Should succeed because stale lock\n 123→    const result = await manager.acquireLock('feature', process.pid);\n 124→    assert.equal(result.ok, true);\n 125→  } finally {\n 126→    cleanup();\n 127→  }\n 128→});\n 129→\n 130→test('releaseLock should remove lock file', async () => {\n 131→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 132→  try {\n 133→    const config = createMockConfig(stateDir, bugfixStateDir);\n 134→    const manager = createLockManager({ config });\n 135→\n 136→    // Acquire lock\n 137→    await manager.acquireLock('feature', process.pid);\n 138→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 139→    assert.ok(fs.existsSync(lockPath));\n 140→\n 141→    // Release lock\n 142→    await manager.releaseLock('feature', process.pid);\n 143→    assert.ok(!fs.existsSync(lockPath));\n 144→  } finally {\n 145→    cleanup();\n 146→  }\n 147→});\n 148→\n 149→test('releaseLock should only release lock owned by current PID', async () => {\n 150→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 151→  try {\n 152→    const config = createMockConfig(stateDir, bugfixStateDir);\n 153→    const manager = createLockManager({ config });\n 154→\n 155→    // Acquire lock with specific PID\n 156→    await manager.acquireLock('feature', process.pid);\n 157→\n 158→    // Try to release with different PID\n 159→    await manager.releaseLock('feature', 99999);\n 160→\n 161→    // Lock should still exist\n 162→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 163→    assert.ok(fs.existsSync(lockPath));\n 164→  } finally {\n 165→    cleanup();\n 166→  }\n 167→});\n 168→\n 169→test('isLocked should return true when lock exists and holder is alive', async () => {\n 170→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 171→  try {\n 172→    const config = createMockConfig(stateDir, bugfixStateDir);\n 173→    const manager = createLockManager({ config });\n 174→\n 175→    await manager.acquireLock('feature', process.pid);\n 176→    const locked = await manager.isLocked('feature');\n 177→    assert.equal(locked, true);\n 178→  } finally {\n 179→    cleanup();\n 180→  }\n 181→});\n 182→\n 183→test('isLocked should return false when no lock exists', async () => {\n 184→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 185→  try {\n 186→    const config = createMockConfig(stateDir, bugfixStateDir);\n 187→    const manager = createLockManager({ config });\n 188→\n 189→    const locked = await manager.isLocked('feature');\n 190→    assert.equal(locked, false);\n 191→  } finally {\n 192→    cleanup();\n 193→  }\n 194→});\n 195→\n 196→test('isLocked should return false when lock held by dead process', async () => {\n 197→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 198→  try {\n 199→    const config = createMockConfig(stateDir, bugfixStateDir);\n 200→    const manager = createLockManager({ config });\n 201→\n 202→    // Create a stale lock\n 203→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 204→    const staleLock = {\n 205→      pid: 99999999,\n 206→      acquiredAt: new Date().toISOString(),\n 207→      type: 'feature',\n 208→      hostname: 'test'\n 209→    };\n 210→    fs.writeFileSync(lockPath, JSON.stringify(staleLock));\n 211→\n 212→    const locked = await manager.isLocked('feature');\n 213→    assert.equal(locked, false);\n 214→  } finally {\n 215→    cleanup();\n 216→  }\n 217→});\n 218→\n 219→test('validateLock should return lock info if valid', async () => {\n 220→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 221→  try {\n 222→    const config = createMockConfig(stateDir, bugfixStateDir);\n 223→    const manager = createLockManager({ config });\n 224→\n 225→    await manager.acquireLock('feature', process.pid);\n 226→    const lockInfo = await manager.validateLock('feature');\n 227→\n 228→    assert.ok(lockInfo);\n 229→    assert.equal(lockInfo.pid, process.pid);\n 230→    assert.ok(lockInfo.acquiredAt);\n 231→    assert.equal(lockInfo.type, 'feature');\n 232→  } finally {\n 233→    cleanup();\n 234→  }\n 235→});\n 236→\n 237→test('validateLock should return null if lock invalid or missing', async () => {\n 238→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 239→  try {\n 240→    const config = createMockConfig(stateDir, bugfixStateDir);\n 241→    const manager = createLockManager({ config });\n 242→\n 243→    const lockInfo = await manager.validateLock('feature');\n 244→    assert.equal(lockInfo, null);\n 245→  } finally {\n 246→    cleanup();\n 247→  }\n 248→});\n 249→\n 250→test('forceUnlock should remove lock regardless of owner', async () => {\n 251→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 252→  try {\n 253→    const config = createMockConfig(stateDir, bugfixStateDir);\n 254→    const manager = createLockManager({ config });\n 255→\n 256→    // Create a lock with a different PID\n 257→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 258→    const lock = {\n 259→      pid: 88888,\n 260→      acquiredAt: new Date().toISOString(),\n 261→      type: 'feature',\n 262→      hostname: 'test'\n 263→    };\n 264→    fs.writeFileSync(lockPath, JSON.stringify(lock));\n 265→\n 266→    // Force unlock\n 267→    const result = await manager.forceUnlock('feature');\n 268→    assert.equal(result.ok, true);\n 269→    assert.equal(result.previousPid, 88888);\n 270→    assert.ok(!fs.existsSync(lockPath));\n 271→  } finally {\n 272→    cleanup();\n 273→  }\n 274→});\n 275→\n 276→test('getLockInfo should return lock details', async () => {\n 277→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 278→  try {\n 279→    const config = createMockConfig(stateDir, bugfixStateDir);\n 280→    const manager = createLockManager({ config });\n 281→\n 282→    await manager.acquireLock('feature', process.pid);\n 283→    const lockInfo = await manager.getLockInfo('feature');\n 284→\n 285→    assert.ok(lockInfo);\n 286→    assert.equal(lockInfo.pid, process.pid);\n 287→    assert.ok(lockInfo.acquiredAt);\n 288→    assert.equal(lockInfo.type, 'feature');\n 289→    assert.ok(lockInfo.hostname);\n 290→  } finally {\n 291→    cleanup();\n 292→  }\n 293→});\n 294→\n 295→test('lock operations should work for both feature and bugfix types', async () => {\n 296→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 297→  try {\n 298→    const config = createMockConfig(stateDir, bugfixStateDir);\n 299→    const manager = createLockManager({ config });\n 300→\n 301→    // Acquire both locks\n 302→    const featureResult = await manager.acquireLock('feature', process.pid);\n 303→    const bugfixResult = await manager.acquireLock('bugfix', process.pid);\n 304→\n 305→    assert.equal(featureResult.ok, true);\n 306→    assert.equal(bugfixResult.ok, true);\n 307→\n 308→    // Both should be locked\n 309→    assert.equal(await manager.isLocked('feature'), true);\n 310→    assert.equal(await manager.isLocked('bugfix'), true);\n 311→\n 312→    // Release one should not affect the other\n 313→    await manager.releaseLock('feature', process.pid);\n 314→    assert.equal(await manager.isLocked('feature'), false);\n 315→    assert.equal(await manager.isLocked('bugfix'), true);\n 316→  } finally {\n 317→    cleanup();\n 318→  }\n 319→});\n 320→\n 321→test('lock file should be written atomically', async () => {\n 322→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 323→  try {\n 324→    const config = createMockConfig(stateDir, bugfixStateDir);\n 325→    const manager = createLockManager({ config });\n 326→\n 327→    const result = await manager.acquireLock('feature', process.pid);\n 328→    assert.equal(result.ok, true);\n 329→\n 330→    // Verify no temp files left\n 331→    const lockDir = stateDir;\n 332→    const files = fs.readdirSync(lockDir);\n 333→    const tempFiles = files.filter(f => f.includes('.tmp'));\n 334→    assert.equal(tempFiles.length, 0);\n 335→  } finally {\n 336→    cleanup();\n 337→  }\n 338→});\n 339→\n 340→test('lock file should include hostname for debugging', async () => {\n 341→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 342→  try {\n 343→    const config = createMockConfig(stateDir, bugfixStateDir);\n 344→    const manager = createLockManager({ config });\n 345→\n 346→    await manager.acquireLock('feature', process.pid);\n 347→    const lockInfo = await manager.getLockInfo('feature');\n 348→\n 349→    assert.equal(lockInfo.hostname, os.hostname());\n 350→  } finally {\n 351→    cleanup();\n 352→  }\n 353→});\n 354→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde79226b7f9284963f7a13e6c2d6","__timestamp":"2026-03-11T19:57:20.204Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"e9a120e4-f980-4698-acf0-2819d2669c39","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde79a1ec1a78d35db2def9326ca9","content":[{"type":"text","text":"   1→/**\n   2→ * State Manager Unit Tests\n   3→ * Tests for src/pipeline-infra/state-manager.js\n   4→ *\n   5→ * F-004: Pipeline Process Controller - US-5 Status Query, US-6 Logs Query\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  15→\n  16→/**\n  17→ * Helper to create temp directory for test state\n  18→ */\n  19→function createTempStateDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'state-manager-test-'));\n  21→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  22→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  23→  fs.mkdirSync(stateDir, { recursive: true });\n  24→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  25→  return {\n  26→    tempDir,\n  27→    stateDir,\n  28→    bugfixStateDir,\n  29→    cleanup: () => {\n  30→      fs.rmSync(tempDir, { recursive: true, force: true });\n  31→    }\n  32→  };\n  33→}\n  34→\n  35→/**\n  36→ * Helper to create a mock config\n  37→ */\n  38→function createMockConfig(stateDir, bugfixStateDir) {\n  39→  const projectRoot = path.dirname(path.dirname(stateDir));\n  40→  return {\n  41→    projectRoot,\n  42→    stateDir,\n  43→    bugfixStateDir\n  44→  };\n  45→}\n  46→\n  47→/**\n  48→ * Helper to create sample daemon meta\n  49→ */\n  50→function createSampleDaemonMeta() {\n  51→  return {\n  52→    pid: 12345,\n  53→    started_at: '2026-03-12T10:30:00Z',\n  54→    feature_list: '/path/to/feature-list.json',\n  55→    env_overrides: '',\n  56→    log_file: '/path/to/pipeline-daemon.log'\n  57→  };\n  58→}\n  59→\n  60→/**\n  61→ * Helper to create sample pipeline state\n  62→ */\n  63→function createSamplePipelineState() {\n  64→  return {\n  65→    run_id: 'run-20260312-103000',\n  66→    status: 'running',\n  67→    feature_list_path: '/path/to/feature-list.json',\n  68→    created_at: '2026-03-12T10:30:00Z',\n  69→    total_features: 8,\n  70→    completed_features: 3\n  71→  };\n  72→}\n  73→\n  74→test('createStateManager should be a factory function', () => {\n  75→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  76→  try {\n  77→    const config = createMockConfig(stateDir, bugfixStateDir);\n  78→    const manager = createStateManager({ config });\n  79→    assert.equal(typeof manager.readDaemonMeta, 'function');\n  80→    assert.equal(typeof manager.readPipelineState, 'function');\n  81→    assert.equal(typeof manager.readCurrentSession, 'function');\n  82→    assert.equal(typeof manager.getLastResult, 'function');\n  83→    assert.equal(typeof manager.writeDaemonMeta, 'function');\n  84→    assert.equal(typeof manager.writeLastResult, 'function');\n  85→    assert.equal(typeof manager.isDaemonRunning, 'function');\n  86→    assert.equal(typeof manager.getDaemonPid, 'function');\n  87→    assert.equal(typeof manager.readLogs, 'function');\n  88→  } finally {\n  89→    cleanup();\n  90→  }\n  91→});\n  92→\n  93→test('readDaemonMeta should return parsed daemon meta JSON', async () => {\n  94→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  95→  try {\n  96→    const config = createMockConfig(stateDir, bugfixStateDir);\n  97→    const manager = createStateManager({ config });\n  98→\n  99→    // Write daemon meta\n 100→    const meta = createSampleDaemonMeta();\n 101→    fs.writeFileSync(path.join(stateDir, '.pipeline-meta.json'), JSON.stringify(meta));\n 102→\n 103→    const result = await manager.readDaemonMeta('feature');\n 104→    assert.deepEqual(result, meta);\n 105→  } finally {\n 106→    cleanup();\n 107→  }\n 108→});\n 109→\n 110→test('readDaemonMeta should return null if file does not exist', async () => {\n 111→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 112→  try {\n 113→    const config = createMockConfig(stateDir, bugfixStateDir);\n 114→    const manager = createStateManager({ config });\n 115→\n 116→    const result = await manager.readDaemonMeta('feature');\n 117→    assert.equal(result, null);\n 118→  } finally {\n 119→    cleanup();\n 120→  }\n 121→});\n 122→\n 123→test('readPipelineState should return parsed pipeline state JSON', async () => {\n 124→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 125→  try {\n 126→    const config = createMockConfig(stateDir, bugfixStateDir);\n 127→    const manager = createStateManager({ config });\n 128→\n 129→    // Write pipeline state\n 130→    const state = createSamplePipelineState();\n 131→    fs.writeFileSync(path.join(stateDir, 'pipeline.json'), JSON.stringify(state));\n 132→\n 133→    const result = await manager.readPipelineState('feature');\n 134→    assert.deepEqual(result, state);\n 135→  } finally {\n 136→    cleanup();\n 137→  }\n 138→});\n 139→\n 140→test('readPipelineState should return null if file does not exist', async () => {\n 141→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 142→  try {\n 143→    const config = createMockConfig(stateDir, bugfixStateDir);\n 144→    const manager = createStateManager({ config });\n 145→\n 146→    const result = await manager.readPipelineState('feature');\n 147→    assert.equal(result, null);\n 148→  } finally {\n 149→    cleanup();\n 150→  }\n 151→});\n 152→\n 153→test('readCurrentSession should return current session info', async () => {\n 154→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 155→  try {\n 156→    const config = createMockConfig(stateDir, bugfixStateDir);\n 157→    const manager = createStateManager({ config });\n 158→\n 159→    // Write current session\n 160→    const session = { feature_id: 'F-001', started_at: '2026-03-12T10:30:00Z' };\n 161→    fs.writeFileSync(path.join(stateDir, 'current-session.json'), JSON.stringify(session));\n 162→\n 163→    const result = await manager.readCurrentSession('feature');\n 164→    assert.deepEqual(result, session);\n 165→  } finally {\n 166→    cleanup();\n 167→  }\n 168→});\n 169→\n 170→test('getLastResult should return last result JSON', async () => {\n 171→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 172→  try {\n 173→    const config = createMockConfig(stateDir, bugfixStateDir);\n 174→    const manager = createStateManager({ config });\n 175→\n 176→    // Write last result\n 177→    const lastResult = {\n 178→      runId: 'run-20260312-103000',\n 179→      completedAt: '2026-03-12T12:45:00Z',\n 180→      status: 'success',\n 181→      featuresTotal: 8,\n 182→      featuresCompleted: 8\n 183→    };\n 184→    fs.writeFileSync(path.join(stateDir, '.last-result.json'), JSON.stringify(lastResult));\n 185→\n 186→    const result = await manager.getLastResult('feature');\n 187→    assert.deepEqual(result, lastResult);\n 188→  } finally {\n 189→    cleanup();\n 190→  }\n 191→});\n 192→\n 193→test('getLastResult should return null if no last result exists', async () => {\n 194→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 195→  try {\n 196→    const config = createMockConfig(stateDir, bugfixStateDir);\n 197→    const manager = createStateManager({ config });\n 198→\n 199→    const result = await manager.getLastResult('feature');\n 200→    assert.equal(result, null);\n 201→  } finally {\n 202→    cleanup();\n 203→  }\n 204→});\n 205→\n 206→test('writeDaemonMeta should write daemon meta to file', async () => {\n 207→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 208→  try {\n 209→    const config = createMockConfig(stateDir, bugfixStateDir);\n 210→    const manager = createStateManager({ config });\n 211→\n 212→    const meta = createSampleDaemonMeta();\n 213→    await manager.writeDaemonMeta('feature', meta);\n 214→\n 215→    const filePath = path.join(stateDir, '.pipeline-meta.json');\n 216→    assert.ok(fs.existsSync(filePath));\n 217→\n 218→    const written = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n 219→    assert.deepEqual(written, meta);\n 220→  } finally {\n 221→    cleanup();\n 222→  }\n 223→});\n 224→\n 225→test('writeLastResult should write last result to file', async () => {\n 226→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 227→  try {\n 228→    const config = createMockConfig(stateDir, bugfixStateDir);\n 229→    const manager = createStateManager({ config });\n 230→\n 231→    const lastResult = {\n 232→      runId: 'run-test',\n 233→      completedAt: '2026-03-12T12:45:00Z',\n 234→      status: 'success',\n 235→      featuresTotal: 8,\n 236→      featuresCompleted: 8\n 237→    };\n 238→    await manager.writeLastResult('feature', lastResult);\n 239→\n 240→    const filePath = path.join(stateDir, '.last-result.json');\n 241→    assert.ok(fs.existsSync(filePath));\n 242→\n 243→    const written = JSON.parse(fs.readFileSync(filePath, 'utf8'));\n 244→    assert.deepEqual(written, lastResult);\n 245→  } finally {\n 246→    cleanup();\n 247→  }\n 248→});\n 249→\n 250→test('isDaemonRunning should return true if PID is alive', async () => {\n 251→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 252→  try {\n 253→    const config = createMockConfig(stateDir, bugfixStateDir);\n 254→    const manager = createStateManager({ config });\n 255→\n 256→    // Write daemon meta with current process PID (guaranteed alive)\n 257→    const meta = { ...createSampleDaemonMeta(), pid: process.pid };\n 258→    fs.writeFileSync(path.join(stateDir, '.pipeline-meta.json'), JSON.stringify(meta));\n 259→\n 260→    const result = await manager.isDaemonRunning('feature');\n 26