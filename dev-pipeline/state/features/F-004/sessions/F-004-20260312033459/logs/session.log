{"type":"assistant","uuid":"202603120335339544e6310c4544d3","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"id":"202603120335339544e6310c4544d3","content":[{"type":"tool_use","id":"019cde65cb4073c6e87f31b359cb5c59","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/dev-pipeline/run-bugfix.sh"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":17433,"output_tokens":341,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:39.581Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"366bd3f8-b7d5-48cf-a706-4748c610f820","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65c6ca2433148b5f0513f18dde","content":[{"type":"text","text":"   1→import { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2→import { createPlanIngestionService } from './plan-ingestion-service.js';\n   3→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   4→\n   5→function buildRequest(params = {}, action) {\n   6→  return {\n   7→    pipelineType: params.pipelineType ?? 'feature',\n   8→    action,\n   9→    ...(params.targetId ? { targetId: params.targetId } : {}),\n  10→    ...(params.listPath ? { listPath: params.listPath } : {}),\n  11→    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  12→    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  13→  };\n  14→}\n  15→\n  16→/**\n  17→ * T-015: Resolve list path for plan type and optional version.\n  18→ * @param {Object} options - Options\n  19→ * @param {string} options.planType - 'feature-list' or 'bug-fix-list'\n  20→ * @param {string} [options.version] - Optional version string\n  21→ * @param {Object} [options.config] - Optional config (will load if not provided)\n  22→ * @param {Object} [options.planService] - Optional plan service instance\n  23→ * @returns {Promise<string|null>} Resolved path or null\n  24→ */\n  25→export async function resolvePlanListPath({ planType, version, config, planService }) {\n  26→  const actualConfig = config ?? loadPipelineInfraConfig();\n  27→  const service = planService ?? createPlanIngestionService({ plansDir: actualConfig.plansDir });\n  28→\n  29→  // If version is specified, get that specific version\n  30→  if (version) {\n  31→    return service.getVersion(planType, version).then(content => {\n  32→      if (!content) return null;\n  33→      // Return the path to the version file\n  34→      const plansDir = actualConfig.plansDir;\n  35→      return `${plansDir}/${planType}/v${version.replace(/^v/, '')}.json`;\n  36→    });\n  37→  }\n  38→\n  39→  // Otherwise, use the active path from registry\n  40→  return service.getActivePath(planType);\n  41→}\n  42→\n  43→export function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  44→  return {\n  45→    runner,\n  46→    async startPipeline(params) {\n  47→      return runner(buildRequest(params, 'run'));\n  48→    },\n  49→    async getPipelineStatus(params) {\n  50→      return runner(buildRequest(params, 'status'));\n  51→    },\n  52→    async stopPipeline(params) {\n  53→      return runner(buildRequest(params, 'stop'));\n  54→    },\n  55→    async retryTarget(params) {\n  56→      return runner(buildRequest(params, 'retry'));\n  57→    },\n  58→    async getPipelineLogs(params) {\n  59→      return runner(buildRequest(params, 'logs'));\n  60→    },\n  61→    async resetTarget(params) {\n  62→      return runner(buildRequest(params, 'reset'));\n  63→    }\n  64→  };\n  65→}\n  66→\n  67→const defaultService = createPipelineControlService();\n  68→\n  69→export async function startPipeline(params) {\n  70→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  71→  return service.startPipeline(params);\n  72→}\n  73→\n  74→export async function getPipelineStatus(params) {\n  75→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  76→  return service.getPipelineStatus(params);\n  77→}\n  78→\n  79→export async function stopPipeline(params) {\n  80→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  81→  return service.stopPipeline(params);\n  82→}\n  83→\n  84→export async function retryTarget(params) {\n  85→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  86→  return service.retryTarget(params);\n  87→}\n  88→\n  89→export async function getPipelineLogs(params) {\n  90→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  91→  return service.getPipelineLogs(params);\n  92→}\n  93→\n  94→export async function resetTarget(params) {\n  95→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  96→  return service.resetTarget(params);\n  97→}\n  98→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:39.582Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"12b5c3c7-30db-4371-8c12-2b1867e57474","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65c842dcea2cbc2ac47109d840","content":[{"type":"text","text":"   1→import { spawn } from 'node:child_process';\n   2→import fs from 'node:fs';\n   3→import path from 'node:path';\n   4→\n   5→import { INFRA_ERROR_CODES } from './error-codes.js';\n   6→import { loadPipelineInfraConfig } from './config-loader.js';\n   7→\n   8→const PIPELINE_TYPES = new Set(['feature', 'bugfix']);\n   9→const PIPELINE_ACTIONS = new Set(['run', 'status', 'stop', 'logs', 'retry', 'reset']);\n  10→\n  11→function ensureValidRequest(req) {\n  12→  if (!PIPELINE_TYPES.has(req?.pipelineType)) {\n  13→    throw new Error(`Invalid pipelineType: ${req?.pipelineType}`);\n  14→  }\n  15→  if (!PIPELINE_ACTIONS.has(req?.action)) {\n  16→    throw new Error(`Invalid action: ${req?.action}`);\n  17→  }\n  18→}\n  19→\n  20→function ensureTargetId(targetId, action) {\n  21→  const normalized = String(targetId ?? '').trim();\n  22→  if (!normalized) {\n  23→    throw new Error(`targetId is required for action '${action}'`);\n  24→  }\n  25→  return normalized;\n  26→}\n  27→\n  28→function withOptionalList(args, listPath) {\n  29→  if (listPath) {\n  30→    args.push(listPath);\n  31→  }\n  32→  return args;\n  33→}\n  34→\n  35→export function buildPipelineCommand(req, config) {\n  36→  ensureValidRequest(req);\n  37→\n  38→  const pipelineDir = config.pipelineDir;\n  39→  const featureListPath = req.listPath || config.featureListPath;\n  40→  const bugFixListPath = req.listPath || config.bugFixListPath;\n  41→\n  42→  if (req.pipelineType === 'feature') {\n  43→    switch (req.action) {\n  44→      case 'run': {\n  45→        const args = ['run'];\n  46→        if (req.targetId) {\n  47→          args.push(req.targetId);\n  48→        }\n  49→        return { command: path.join(pipelineDir, 'run.sh'), args: withOptionalList(args, featureListPath) };\n  50→      }\n  51→      case 'status':\n  52→        return {\n  53→          command: path.join(pipelineDir, 'run.sh'),\n  54→          args: withOptionalList(['status'], featureListPath)\n  55→        };\n  56→      case 'stop':\n  57→        return { command: path.join(pipelineDir, 'launch-daemon.sh'), args: ['stop'] };\n  58→      case 'logs':\n  59→        return { command: path.join(pipelineDir, 'launch-daemon.sh'), args: ['logs'] };\n  60→      case 'retry': {\n  61→        const targetId = ensureTargetId(req.targetId, req.action);\n  62→        return {\n  63→          command: path.join(pipelineDir, 'retry-feature.sh'),\n  64→          args: withOptionalList([targetId], featureListPath)\n  65→        };\n  66→      }\n  67→      case 'reset': {\n  68→        if (req.targetId) {\n  69→          const targetId = ensureTargetId(req.targetId, req.action);\n  70→          return {\n  71→            command: path.join(pipelineDir, 'reset-feature.sh'),\n  72→            args: withOptionalList([targetId, '--clean'], featureListPath)\n  73→          };\n  74→        }\n  75→\n  76→        return { command: path.join(pipelineDir, 'run.sh'), args: ['reset'] };\n  77→      }\n  78→      default:\n  79→        throw new Error(`Unsupported feature action: ${req.action}`);\n  80→    }\n  81→  }\n  82→\n  83→  switch (req.action) {\n  84→    case 'run': {\n  85→      const args = ['run'];\n  86→      if (req.targetId) {\n  87→        args.push(req.targetId);\n  88→      }\n  89→      return { command: path.join(pipelineDir, 'run-bugfix.sh'), args: withOptionalList(args, bugFixListPath) };\n  90→    }\n  91→    case 'status':\n  92→      return {\n  93→        command: path.join(pipelineDir, 'run-bugfix.sh'),\n  94→        args: withOptionalList(['status'], bugFixListPath)\n  95→      };\n  96→    case 'stop':\n  97→      return { command: path.join(pipelineDir, 'launch-bugfix-daemon.sh'), args: ['stop'] };\n  98→    case 'logs':\n  99→      return { command: path.join(pipelineDir, 'launch-bugfix-daemon.sh'), args: ['logs'] };\n 100→    case 'retry': {\n 101→      const targetId = ensureTargetId(req.targetId, req.action);\n 102→      return {\n 103→        command: path.join(pipelineDir, 'retry-bug.sh'),\n 104→        args: withOptionalList([targetId], bugFixListPath)\n 105→      };\n 106→    }\n 107→    case 'reset': {\n 108→      if (req.targetId) {\n 109→        const targetId = ensureTargetId(req.targetId, req.action);\n 110→        const listPath = req.listPath || config.bugFixListPath;\n 111→        return {\n 112→          command: path.join(pipelineDir, 'scripts/update-bug-status.py'),\n 113→          args: [\n 114→            '--bug-list',\n 115→            listPath,\n 116→            '--state-dir',\n 117→            path.join(pipelineDir, 'bugfix-state'),\n 118→            '--bug-id',\n 119→            targetId,\n 120→            '--project-root',\n 121→            config.projectRoot,\n 122→            '--action',\n 123→            'clean'\n 124→          ]\n 125→        };\n 126→      }\n 127→\n 128→      return { command: path.join(pipelineDir, 'run-bugfix.sh'), args: ['reset'] };\n 129→    }\n 130→    default:\n 131→      throw new Error(`Unsupported bugfix action: ${req.action}`);\n 132→  }\n 133→}\n 134→\n 135→export function normalizePipelineResult({ exitCode, signal, stdout, stderr, timedOut = false }) {\n 136→  let normalizedStatus = 'failed';\n 137→  let errorCode;\n 138→\n 139→  if (timedOut || exitCode === 124) {\n 140→    normalizedStatus = 'timed_out';\n 141→    errorCode = INFRA_ERROR_CODES.EXEC_TIMEOUT;\n 142→  } else if (signal) {\n 143→    normalizedStatus = 'crashed';\n 144→    errorCode = INFRA_ERROR_CODES.EXEC_FAILED;\n 145→  } else if (exitCode === 0) {\n 146→    normalizedStatus = 'success';\n 147→  } else {\n 148→    normalizedStatus = 'failed';\n 149→    errorCode = INFRA_ERROR_CODES.EXEC_FAILED;\n 150→  }\n 151→\n 152→  return {\n 153→    ok: normalizedStatus === 'success',\n 154→    exitCode: Number.isInteger(exitCode) ? exitCode : 1,\n 155→    signal: signal || undefined,\n 156→    stdout: stdout ?? '',\n 157→    stderr: stderr ?? '',\n 158→    normalizedStatus,\n 159→    errorCode\n 160→  };\n 161→}\n 162→\n 163→function runCommand({ command, args, env, timeoutMs }) {\n 164→  return new Promise((resolve, reject) => {\n 165→    let stdout = '';\n 166→    let stderr = '';\n 167→    let timedOut = false;\n 168→\n 169→    const child = spawn(command, args, {\n 170→      env,\n 171→      stdio: ['ignore', 'pipe', 'pipe']\n 172→    });\n 173→\n 174→    const timer = timeoutMs && timeoutMs > 0\n 175→      ? setTimeout(() => {\n 176→          timedOut = true;\n 177→          child.kill('SIGTERM');\n 178→        }, timeoutMs)\n 179→      : null;\n 180→\n 181→    child.stdout.on('data', (chunk) => {\n 182→      stdout += chunk.toString();\n 183→    });\n 184→\n 185→    child.stderr.on('data', (chunk) => {\n 186→      stderr += chunk.toString();\n 187→    });\n 188→\n 189→    child.on('error', (error) => {\n 190→      if (timer) {\n 191→        clearTimeout(timer);\n 192→      }\n 193→      reject(error);\n 194→    });\n 195→\n 196→    child.on('close', (exitCode, signal) => {\n 197→      if (timer) {\n 198→        clearTimeout(timer);\n 199→      }\n 200→      resolve({ exitCode: exitCode ?? (timedOut ? 124 : 1), signal, stdout, stderr, timedOut });\n 201→    });\n 202→  });\n 203→}\n 204→\n 205→function scriptExists(commandPath) {\n 206→  if (commandPath === 'python3' || commandPath === 'node') {\n 207→    return true;\n 208→  }\n 209→  return fs.existsSync(commandPath);\n 210→}\n 211→\n 212→export async function executePipelineCommand(req) {\n 213→  const config = loadPipelineInfraConfig();\n 214→  const commandRequest = {\n 215→    ...req,\n 216→    listPath:\n 217→      req.listPath || (req.pipelineType === 'feature' ? config.featureListPath : config.bugFixListPath)\n 218→  };\n 219→\n 220→  let command;\n 221→  let args;\n 222→\n 223→  try {\n 224→    ({ command, args } = buildPipelineCommand(commandRequest, config));\n 225→  } catch (error) {\n 226→    return {\n 227→      ok: false,\n 228→      exitCode: 1,\n 229→      stdout: '',\n 230→      stderr: error instanceof Error ? error.message : String(error),\n 231→      normalizedStatus: 'failed',\n 232→      errorCode: INFRA_ERROR_CODES.EXEC_FAILED\n 233→    };\n 234→  }\n 235→\n 236→  if (!scriptExists(command)) {\n 237→    return {\n 238→      ok: false,\n 239→      exitCode: 127,\n 240→      stdout: '',\n 241→      stderr: `Command not found: ${command}`,\n 242→      normalizedStatus: 'failed',\n 243→      errorCode: INFRA_ERROR_CODES.SCRIPT_NOT_FOUND\n 244→    };\n 245→  }\n 246→\n 247→  try {\n 248→    const raw = await runCommand({\n 249→      command,\n 250→      args,\n 251→      timeoutMs: req.timeoutMs,\n 252→      env: {\n 253→        ...process.env,\n 254→        ...(req.envOverrides ?? {})\n 255→      }\n 256→    });\n 257→\n 258→    return normalizePipelineResult(raw);\n 259→  } catch (error) {\n 260→    const message = error instanceof Error ? error.message : String(error);\n 261→\n 262→    if (error && error.code === 'ENOENT') {\n 263→      return {\n 264→        ok: false,\n 265→        exitCode: 127,\n 266→        stdout: '',\n 267→        stderr: message,\n 268→        normalizedStatus: 'failed',\n 269→        errorCode: INFRA_ERROR_CODES.SCRIPT_NOT_FOUND\n 270→      };\n 271→    }\n 272→\n 273→    return {\n 274→      ok: false,\n 275→      exitCode: 1,\n 276→      stdout: '',\n 277→      stderr: message,\n 278→      normalizedStatus: 'failed',\n 279→      errorCode: INFRA_ERROR_CODES.EXEC_FAILED\n 280→    };\n 281→  }\n 282→}\n 283→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:39.582Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"a14dcd80-9737-4731-8acd-926d1b17c11e","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65c9cadc471f440104245d5983","content":[{"type":"text","text":"   1→#!/usr/bin/env bash\n   2→set -euo pipefail\n   3→\n   4→# ============================================================\n   5→# dev-pipeline/run.sh - Autonomous Dev Pipeline Runner\n   6→#\n   7→# Drives the prizm-dev-team multi-agent team through iterative\n   8→# AI CLI sessions (CodeBuddy or Claude Code) to build a complete app\n   9→# from a feature list.\n  10→#\n  11→# Usage:\n  12→#   ./run.sh run [feature-list.json]            Run all features\n  13→#   ./run.sh run <feature-id> [options]         Run a single feature\n  14→#   ./run.sh status [feature-list.json]         Show pipeline status\n  15→#   ./run.sh reset                              Clear all state\n  16→#\n  17→# Environment Variables:\n  18→#   MAX_RETRIES           Max retries per feature (default: 3)\n  19→#   SESSION_TIMEOUT       Session timeout in seconds (default: 0 = no limit)\n  20→#   AI_CLI                AI CLI command name (auto-detected: cbc or claude)\n  21→#   CODEBUDDY_CLI         Legacy alias for AI_CLI (deprecated, use AI_CLI instead)\n  22→#   PRIZMKIT_PLATFORM     Force platform: 'codebuddy' or 'claude' (auto-detected)\n  23→#   VERBOSE               Set to 1 to enable --verbose on AI CLI (shows subagent output)\n  24→#   HEARTBEAT_INTERVAL    Heartbeat log interval in seconds (default: 30)\n  25→#   HEARTBEAT_STALE_THRESHOLD  Heartbeat stale threshold in seconds (default: 600)\n  26→# ============================================================\n  27→\n  28→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n  29→STATE_DIR=\"$SCRIPT_DIR/state\"\n  30→SCRIPTS_DIR=\"$SCRIPT_DIR/scripts\"\n  31→\n  32→# Configuration (override via environment variables)\n  33→MAX_RETRIES=${MAX_RETRIES:-3}\n  34→SESSION_TIMEOUT=${SESSION_TIMEOUT:-0}\n  35→HEARTBEAT_STALE_THRESHOLD=${HEARTBEAT_STALE_THRESHOLD:-600}\n  36→HEARTBEAT_INTERVAL=${HEARTBEAT_INTERVAL:-30}\n  37→VERBOSE=${VERBOSE:-0}\n  38→\n  39→# AI CLI detection: AI_CLI > CODEBUDDY_CLI > auto-detect > error\n  40→if [[ -n \"${AI_CLI:-}\" ]]; then\n  41→    CLI_CMD=\"$AI_CLI\"\n  42→elif [[ -n \"${CODEBUDDY_CLI:-}\" ]]; then\n  43→    CLI_CMD=\"$CODEBUDDY_CLI\"\n  44→elif command -v cbc &>/dev/null; then\n  45→    CLI_CMD=\"cbc\"\n  46→elif command -v claude &>/dev/null; then\n  47→    CLI_CMD=\"claude\"\n  48→else\n  49→    echo \"ERROR: No AI CLI found. Install CodeBuddy (cbc) or Claude Code (claude).\" >&2\n  50→    exit 1\n  51→fi\n  52→\n  53→# Platform detection\n  54→if [[ -n \"${PRIZMKIT_PLATFORM:-}\" ]]; then\n  55→    PLATFORM=\"$PRIZMKIT_PLATFORM\"\n  56→elif [[ \"$CLI_CMD\" == *\"claude\"* ]]; then\n  57→    PLATFORM=\"claude\"\n  58→else\n  59→    PLATFORM=\"codebuddy\"\n  60→fi\n  61→\n  62→export PRIZMKIT_PLATFORM=\"$PLATFORM\"\n  63→\n  64→# Source shared heartbeat library\n  65→source \"$SCRIPT_DIR/lib/heartbeat.sh\"\n  66→\n  67→# Detect stream-json support\n  68→detect_stream_json_support \"$CLI_CMD\"\n  69→\n  70→# Feature list path (set in main, used by cleanup trap)\n  71→FEATURE_LIST=\"\"\n  72→\n  73→# Colors for output\n  74→RED='\\033[0;31m'\n  75→GREEN='\\033[0;32m'\n  76→YELLOW='\\033[1;33m'\n  77→BLUE='\\033[0;34m'\n  78→BOLD='\\033[1m'\n  79→NC='\\033[0m'\n  80→\n  81→log_info()    { echo -e \"${BLUE}[INFO]${NC}    $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  82→log_warn()    { echo -e \"${YELLOW}[WARN]${NC}    $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  83→log_error()   { echo -e \"${RED}[ERROR]${NC}   $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  84→log_success() { echo -e \"${GREEN}[SUCCESS]${NC} $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  85→\n  86→# ============================================================\n  87→# Shared: Spawn an AI CLI session and wait for result\n  88→# ============================================================\n  89→\n  90→# Spawns an AI CLI session with heartbeat + timeout, waits for completion,\n  91→# checks session status, and updates feature status.\n  92→#\n  93→# Arguments:\n  94→#   $1 - feature_id\n  95→#   $2 - feature_list (absolute path)\n  96→#   $3 - session_id\n  97→#   $4 - bootstrap_prompt (path)\n  98→#   $5 - session_dir\n  99→#   $6 - max_retries (for status update)\n 100→spawn_and_wait_session() {\n 101→    local feature_id=\"$1\"\n 102→    local feature_list=\"$2\"\n 103→    local session_id=\"$3\"\n 104→    local bootstrap_prompt=\"$4\"\n 105→    local session_dir=\"$5\"\n 106→    local max_retries=\"$6\"\n 107→\n 108→    local session_log=\"$session_dir/logs/session.log\"\n 109→    local progress_json=\"$session_dir/logs/progress.json\"\n 110→\n 111→    # Spawn AI CLI session\n 112→    local verbose_flag=\"\"\n 113→    if [[ \"$VERBOSE\" == \"1\" ]]; then\n 114→        verbose_flag=\"--verbose\"\n 115→    fi\n 116→\n 117→    local stream_json_flag=\"\"\n 118→    if [[ \"$USE_STREAM_JSON\" == \"true\" ]]; then\n 119→        stream_json_flag=\"--output-format stream-json\"\n 120→    fi\n 121→\n 122→    case \"$CLI_CMD\" in\n 123→        *claude*)\n 124→            # Claude Code: prompt via -p argument, --yes for auto-accept\n 125→            \"$CLI_CMD\" \\\n 126→                --print \\\n 127→                -p \"$(cat \"$bootstrap_prompt\")\" \\\n 128→                --yes \\\n 129→                $verbose_flag \\\n 130→                $stream_json_flag \\\n 131→                > \"$session_log\" 2>&1 &\n 132→            ;;\n 133→        *)\n 134→            # CodeBuddy (cbc) and others: prompt via stdin\n 135→            \"$CLI_CMD\" \\\n 136→                --print \\\n 137→                -y \\\n 138→                $verbose_flag \\\n 139→                $stream_json_flag \\\n 140→                < \"$bootstrap_prompt\" \\\n 141→                > \"$session_log\" 2>&1 &\n 142→            ;;\n 143→    esac\n 144→    local cbc_pid=$!\n 145→\n 146→    # Start progress parser (no-op if stream-json not supported)\n 147→    start_progress_parser \"$session_log\" \"$progress_json\" \"$SCRIPTS_DIR\"\n 148→    local parser_pid=\"${_PARSER_PID:-}\"\n 149→\n 150→    # Timeout watchdog (only if SESSION_TIMEOUT > 0)\n 151→    local watcher_pid=\"\"\n 152→    if [[ $SESSION_TIMEOUT -gt 0 ]]; then\n 153→        ( sleep \"$SESSION_TIMEOUT\" && kill -TERM \"$cbc_pid\" 2>/dev/null ) &\n 154→        watcher_pid=$!\n 155→    fi\n 156→\n 157→    # Heartbeat monitor (reads progress.json when available, falls back to tail)\n 158→    start_heartbeat \"$cbc_pid\" \"$session_log\" \"$progress_json\" \"$HEARTBEAT_INTERVAL\"\n 159→    local heartbeat_pid=\"${_HEARTBEAT_PID:-}\"\n 160→\n 161→    # Wait for AI CLI to finish\n 162→    local exit_code=0\n 163→    if wait \"$cbc_pid\" 2>/dev/null; then\n 164→        exit_code=0\n 165→    else\n 166→        exit_code=$?\n 167→    fi\n 168→\n 169→    # Clean up watcher, heartbeat, and parser\n 170→    [[ -n \"$watcher_pid\" ]] && kill \"$watcher_pid\" 2>/dev/null || true\n 171→    stop_heartbeat \"$heartbeat_pid\"\n 172→    stop_progress_parser \"$parser_pid\"\n 173→    [[ -n \"$watcher_pid\" ]] && wait \"$watcher_pid\" 2>/dev/null || true\n 174→\n 175→    # Map SIGTERM (143) to timeout code 124\n 176→    if [[ $exit_code -eq 143 ]]; then\n 177→        exit_code=124\n 178→    fi\n 179→\n 180→    # Show final session summary\n 181→    if [[ -f \"$session_log\" ]]; then\n 182→        local final_size=$(wc -c < \"$session_log\" 2>/dev/null | tr -d ' ')\n 183→        local final_lines=$(wc -l < \"$session_log\" 2>/dev/null | tr -d ' ')\n 184→        log_info \"Session log: $final_lines lines, $((final_size / 1024))KB\"\n 185→    fi\n 186→\n 187→    # Check session outcome\n 188→    local session_status_file=\"$session_dir/session-status.json\"\n 189→    local session_status\n 190→\n 191→    if [[ $exit_code -eq 124 ]]; then\n 192→        log_warn \"Session timed out after ${SESSION_TIMEOUT}s\"\n 193→        session_status=\"timed_out\"\n 194→    elif [[ -f \"$session_status_file\" ]]; then\n 195→        session_status=$(python3 \"$SCRIPTS_DIR/check-session-status.py\" \\\n 196→            --status-file \"$session_status_file\" 2>/dev/null) || session_status=\"crashed\"\n 197→    else\n 198→        log_warn \"Session ended without status file — treating as crashed\"\n 199→        session_status=\"crashed\"\n 200→    fi\n 201→\n 202→    log_info \"Session result: $session_status\"\n 203→\n 204→    # Update feature status\n 205→    python3 \"$SCRIPTS_DIR/update-feature-status.py\" \\\n 206→        --feature-list \"$feature_list\" \\\n 207→        --state-dir \"$STATE_DIR\" \\\n 208→        --feature-id \"$feature_id\" \\\n 209→        --session-status \"$session_status\" \\\n 210→        --session-id \"$session_id\" \\\n 211→        --max-retries \"$max_retries\" \\\n 212→        --action update >/dev/null 2>&1 || true\n 213→\n 214→    # Return status via global variable (avoids $() swallowing stdout)\n 215→    _SPAWN_RESULT=\"$session_status\"\n 216→}\n 217→\n 218→# ============================================================\n 219→# Graceful Shutdown\n 220→# ============================================================\n 221→\n 222→cleanup() {\n 223→    echo \"\"\n 224→    log_warn \"Received interrupt signal. Saving state...\"\n 225→\n 226→    if [[ -n \"$FEATURE_LIST\" && -f \"$FEATURE_LIST\" ]]; then\n 227→        python3 \"$SCRIPTS_DIR/update-feature-status.py\" \\\n 228→            --feature-list \"$FEATURE_LIST\" \\\n 229→            --state-dir \"$STATE_DIR\" \\\n 230→            --action pause 2>/dev/null || true\n 231→    fi\n 232→\n 233→    log_info \"Pipeline paused. Run './run.sh run' to resume.\"\n 234→    exit 130\n 235→}\n 236→trap cleanup SIGINT SIGTERM\n 237→\n 238→# ============================================================\n 239→# Dependency Check\n 240→# ============================================================\n 241→\n 242→check_dependencies() {\n 243→    # Check for jq\n 244→    if ! command -v jq &>/dev/null; then\n 245→        log_error \"jq is required but not installed. Install with: brew install jq\"\n 246→        exit 1\n 247→    fi\n 248→\n 249→    # Check for python3\n 250→    if ! command -v python3 &>/dev/null; then\n 251→        log_error \"python3 is required but not installed.\"\n 252→        exit 1\n 253→    fi\n 254→\n 255→    # Check for AI CLI\n 256→    if ! command -v \"$CLI_CMD\" &>/dev/null; then\n 257→        log_warn \"AI CLI '$CLI_CMD' not found in PATH.\"\n 258→        log_warn \"Set AI_CLI environment variable to the correct command.\"\n 259→        log_warn \"Continuing anyway (will fail when spawning sessions)...\"\n 260→    fi\n 261→}\n 262→\n 263→# ============================================================\n 264→# run-one: Run a single feature with full control\n 265→# ============================================================\n 266→\n 267→run_one() {\n 268→    local feature_id=\"\"\n 269→    local feature_list=\"\"\n 270→    local dry_run=false\n 271→    local resume_phase=\"\"\n 272→    local mode_override=\"\"\n 273→    local do_clean=false\n 274→    local no_reset=false\n 275→\n 276→    # Parse arguments\n 277→    while [[ $# -gt 0 ]]; do\n 278→        case \"$1\" in\n 279→            --dry-run)\n 280→                dry_run=true\n 281→                shift\n 282→                ;;\n 283→            --resume-phase)\n 284→                shift\n 285→                if [[ $# -eq 0 ]]; then\n 286→                    log_error \"--resume-phase requires a value\"\n 287→                    exit 1\n 288→                fi\n 289→                resume_phase=\"$1\"\n 290→                shift\n 291→                ;;\n 292→            --mode)\n 293→                shift\n 294→                if [[ $# -eq 0 ]]; then\n 295→                    log_error \"--mode requires a value (lite|standard|full)\"\n 296→                    exit 1\n 297→                fi\n 298→                case \"$1\" in\n 299→                    lite|standard|full)\n 300→                        mode_override=\"$1\"\n 301→                        ;;\n 302→                    *)\n 303→                        log_error \"Invalid mode: $1 (must be lite, standard, or full)\"\n 304→                        exit 1\n 305→                        ;;\n 306→                esac\n 307→                shift\n 308→                ;;\n 309→            --clean)\n 310→                do_clean=true\n 311→                shift\n 312→                ;;\n 313→            --no-reset)\n 314→                no_reset=true\n 315→                shift\n 316→                ;;\n 317→            --timeout)\n 318→                shift\n 319→                if [[ $# -eq 0 ]]; then\n 320→                    log_error \"--timeout requires a value in seconds\"\n 321→                    exit 1\n 322→                fi\n 323→                SESSION_TIMEOUT=\"$1\"\n 324→                shift\n 325→                ;;\n 326→            F-*|f-*)\n 327→                feature_id=\"$1\"\n 328→                shift\n 329→                ;;\n 330→            *)\n 331→                feature_list=\"$1\"\n 332→                shift\n 333→                ;;\n 334→        esac\n 335→    done\n 336→\n 337→    # Validate required args\n 338→    if [[ -z \"$feature_id\" ]]; then\n 339→        log_error \"Feature ID is required (e.g. F-007)\"\n 340→        echo \"\"\n 341→        show_help\n 342→        exit 1\n 343→    fi\n 344→\n 345→    # Default feature list\n 346→    if [[ -z \"$feature_list\" ]]; then\n 347→        feature_list=\"feature-list.json\"\n 348→    fi\n 349→\n 350→    # Resolve to absolute path\n 351→    if [[ ! \"$feature_list\" = /* ]]; then\n 352→        feature_list=\"$(pwd)/$feature_list\"\n 353→    fi\n 354→\n 355→    FEATURE_LIST=\"$feature_list\"\n 356→\n 357→    # Default resume phase\n 358→    if [[ -z \"$resume_phase\" ]]; then\n 359→        resume_phase=\"null\"\n 360→    fi\n 361→\n 362→    # Validation\n 363→    if [[ ! -f \"$feature_list\" ]]; then\n 364→        log_error \"Feature list not found: $feature_list\"\n 365→        exit 1\n 366→    fi\n 367→\n 368→    if [[ ! -f \"$STATE_DIR/pipeline.json\" ]]; then\n 369→        log_error \"No pipeline state found. Run './run.sh run' first to initialize.\"\n 370→        exit 1\n 371→    fi\n 372→\n 373→    check_dependencies\n 374→\n 375→    # Verify feature exists\n 376→    local feature_title\n 377→    feature_title=$(python3 -c \"\n 378→import json, sys\n 379→feature_list_path, fid = sys.argv[1], sys.argv[2]\n 380→with open(feature_list_path) as f:\n 381→    data = json.load(f)\n 382→for feat in data.get('features', []):\n 383→    if feat.get('id') == fid:\n 384→        print(feat.get('title', ''))\n 385→        sys.exit(0)\n 386→sys.exit(1)\n 387→\" \"$feature_list\" \"$feature_id\" 2>/dev/null) || {\n 388→        log_error \"Feature $feature_id not found in $feature_list\"\n 389→        exit 1\n 390→    }\n 391→\n 392→    # Optional Clean\n 393→    if [[ \"$do_clean\" == true ]]; then\n 394→        if [[ \"$dry_run\" == true ]]; then\n 395→            log_warn \"Dry-run mode: --clean ignored (no artifacts will be deleted)\"\n 396→        else\n 397→            log_info \"Cleaning artifacts for $feature_id...\"\n 398→\n 399→            local feature_slug\n 400→            feature_slug=$(python3 -c \"\n 401→import json, re, sys\n 402→feature_list_path, fid = sys.argv[1], sys.argv[2]\n 403→with open(feature_list_path) as f:\n 404→    data = json.load(f)\n 405→for feat in data.get('features', []):\n 406→    if feat.get('id') == fid:\n 407→        fnum = feat['id'].replace('F-', '').replace('f-', '').zfill(3)\n 408→        title = feat.get('title', '').lower()\n 409→        title = re.sub(r'[^a-z0-9\\s-]', '', title)\n 410→        title = re.sub(r'[\\s]+', '-', title.strip())\n 411→        title = re.sub(r'-+', '-', title).strip('-')\n 412→        print(f'{fnum}-{title}')\n 413→        sys.exit(0)\n 414→sys.exit(1)\n 415→\" \"$feature_list\" \"$feature_id\" 2>/dev/null) || {\n 416→                log_warn \"Could not determine feature slug for cleanup\"\n 417→                feature_slug=\"\"\n 418→            }\n 419→\n 420→            local project_root\n 421→            project_root=\"$(cd \"$SCRIPT_DIR/..\" && pwd)\"\n 422→\n 423→            if [[ -n \"$feature_slug\" ]]; then\n 424→                local specs_dir=\"$project_root/.prizmkit/specs/$feature_slug\"\n 425→                if [[ -d \"$specs_dir\" ]]; then\n 426→                    rm -rf \"$specs_dir\"\n 427→                    log_info \"Removed $specs_dir\"\n 428→                fi\n 429→            fi\n 430→\n 431→            local dev_team_dir=\"$project_root/.dev-team\"\n 432→            if [[ -d \"$dev_team_dir\" ]]; then\n 433→                rm -rf \"$dev_team_dir\"\n 434→                log_info \"Removed $dev_team_dir\"\n 435→            fi\n 436→\n 437→            local feature_state_dir=\"$STATE_DIR/features/$feature_id\"\n 438→            if [[ -d \"$feature_state_dir\" ]]; then\n 439→                rm -rf \"$feature_state_dir\"\n 440→                log_info \"Removed $feature_state_dir\"\n 441→            fi\n 442→        fi\n 443→    fi\n 444→\n 445→    # Reset Status\n 446→    if [[ \"$no_reset\" == false && \"$dry_run\" == false ]]; then\n 447→        log_info \"Resetting $feature_id status...\"\n 448→        python3 \"$SCRIPTS_DIR/update-feature-status.py\" \\\n 449→            --feature-list \"$feature_list\" \\\n 450→            --state-dir \"$STATE_DIR\" \\\n 451→            --feature-id \"$feature_id\" \\\n 452→            --action reset >/dev/null 2>&1 || {\n 453→            log_warn \"Failed to reset feature status (may already be pending)\"\n 454→        }\n 455→    elif [[ \"$dry_run\" == true && \"$no_reset\" == false ]]; then\n 456→        log_info \"Dry-run mode: skipping status reset\"\n 457→    fi\n 458→\n 459→    # Generate Bootstrap Prompt\n 460→    local run_id session_id session_dir bootstrap_prompt\n 461→    run_id=$(jq -r '.run_id' \"$STATE_DIR/pipeline.json\")\n 462→    session_id=\"${feature_id}-$(date +%Y%m%d%H%M%S)\"\n 463→    session_dir=\"$STATE_DIR/features/$feature_id/sessions/$session_id\"\n 464→    mkdir -p \"$session_dir/logs\"\n 465→\n 466→    bootstrap_prompt=\"$session_dir/bootstrap-prompt.md\"\n 467→\n 468→    local prompt_args=(\n 469→        --feature-list \"$feature_list\"\n 470→        --feature-id \"$feature_id\"\n 471→        --session-id \"$session_id\"\n 472→        --run-id \"$run_id\"\n 473→        --retry-count 0\n 474→        --resume-phase \"$resume_phase\"\n 475→        --state-dir \"$STATE_DIR\"\n 476→        --output \"$bootstrap_prompt\"\n 477→    )\n 478→\n 479→    if [[ -n \"$mode_override\" ]]; then\n 480→        prompt_args+=(--mode \"$mode_override\")\n 481→    fi\n 482→\n 483→    log_info \"Generating bootstrap prompt...\"\n 484→    python3 \"$SCRIPTS_DIR/generate-bootstrap-prompt.py\" \"${prompt_args[@]}\" >/dev/null 2>&1\n 485→\n 486→    # Dry-Run: Print info and exit\n 487→    if [[ \"$dry_run\" == true ]]; then\n 488→        echo \"\"\n 489→        echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 490→        echo -e \"${BOLD}  Dry Run: $feature_id — $feature_title${NC}\"\n 491→        echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 492→        echo \"\"\n 493→        log_info \"Session ID:    $session_id\"\n 494→        log_info \"Resume Phase:  $resume_phase\"\n 495→        if [[ -n \"$mode_override\" ]]; then\n 496→            log_info \"Mode Override: $mode_override\"\n 497→        else\n 498→            log_info \"Mode:          auto-detect (from complexity)\"\n 499→        fi\n 500→        echo \"\"\n 501→        log_info \"Bootstrap prompt written to:\"\n 502→        echo \"  $bootstrap_prompt\"\n 503→        echo \"\"\n 504→\n 505→        local prompt_lines\n 506→        prompt_lines=$(wc -l < \"$bootstrap_prompt\" | tr -d ' ')\n 507→        log_info \"Prompt: $prompt_lines lines\"\n 508→        echo \"\"\n 509→        echo -e \"${BOLD}--- Session Context (from prompt) ---${NC}\"\n 510→        sed -n '/^## Session Context/,/^##[^#]/p' \"$bootstrap_prompt\" | head -20\n 511→        echo -e \"${BOLD}--- end ---${NC}\"\n 512→        echo \"\"\n 513→\n 514→        log_success \"Dry run complete. Inspect full prompt with:\"\n 515→        echo \"  cat $bootstrap_prompt\"\n 516→        return 0\n 517→    fi\n 518→\n 519→    # Spawn AI CLI Session\n 520→    echo \"\"\n 521→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 522→    echo -e \"${BOLD}  Run: $feature_id — $feature_title${NC}\"\n 523→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 524→    log_info \"Session ID: $session_id\"\n 525→    log_info \"Resume Phase: $resume_phase\"\n 526→    if [[ -n \"$mode_override\" ]]; then\n 527→        log_info \"Mode Override: $mode_override\"\n 528→    fi\n 529→    if [[ $SESSION_TIMEOUT -gt 0 ]]; then\n 530→        log_info \"Session timeout: ${SESSION_TIMEOUT}s\"\n 531→    else\n 532→        log_info \"Session timeout: none\"\n 533→    fi\n 534→    log_info \"Prompt: $bootstrap_prompt\"\n 535→    log_info \"Log: $session_dir/logs/session.log\"\n 536→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 537→    echo \"\"\n 538→\n 539→    # Override cleanup trap for single-feature mode\n 540→    cleanup() {\n 541→        echo \"\"\n 542→        log_warn \"Interrupted. Killing session...\"\n 543→        # Kill all child processes\n 544→        kill 0 2>/dev/null || true\n 545→        log_info \"Session log: $session_dir/logs/session.log\"\n 546→        exit 130\n 547→    }\n 548→    trap cleanup SIGINT SIGTERM\n 549→\n 550→    _SPAWN_RESULT=\"\"\n 551→    spawn_and_wait_session \\\n 552→        \"$feature_id\" \"$feature_list\" \"$session_id\" \\\n 553→        \"$bootstrap_prompt\" \"$session_dir\" 999\n 554→    local session_status=\"$_SPAWN_RESULT\"\n 555→\n 556→    echo \"\"\n 557→    if [[ \"$session_status\" == \"success\" ]]; then\n 558→        log_success \"════════════════════════════════════════════════════\"\n 559→        log_success \"  $feature_id completed successfully!\"\n 560→        log_success \"════════════════════════════════════════════════════\"\n 561→    else\n 562→        log_error \"════════════════════════════════════════════════════\"\n 563→        log_error \"  $feature_id result: $session_status\"\n 564→        log_error \"  Review log: $session_dir/logs/session.log\"\n 565→        log_error \"════════════════════════════════════════════════════\"\n 566→    fi\n 567→}\n 568→\n 569→# ============================================================\n 570→# Main Loop: Run all features\n 571→# ============================================================\n 572→\n 573→main() {\n 574→    local feature_list=\"${1:-feature-list.json}\"\n 575→\n 576→    # Resolve to absolute path\n 577→    if [[ ! \"$feature_list\" = /* ]]; then\n 578→        feature_list=\"$(pwd)/$feature_list\"\n 579→    fi\n 580→\n 581→    FEATURE_LIST=\"$feature_list\"\n 582→\n 583→    # Validate feature list exists\n 584→    if [[ ! -f \"$feature_list\" ]]; then\n 585→        log_error \"Feature list not found: $feature_list\"\n 586→        log_info \"Create a feature list first using the app-planner skill,\"\n 587→        log_info \"or provide a path: ./run.sh run <path-to-feature-list.json>\"\n 588→        exit 1\n 589→    fi\n 590→\n 591→    check_dependencies\n 592→\n 593→    # Initialize pipeline state if needed\n 594→    if [[ ! -f \"$STATE_DIR/pipeline.json\" ]]; then\n 595→        log_info \"Initializing pipeline state...\"\n 596→        local init_result\n 597→        init_result=$(python3 \"$SCRIPTS_DIR/init-pipeline.py\" \\\n 598→            --feature-list \"$feature_list\" \\\n 599→            --state-dir \"$STATE_DIR\" 2>&1)\n 600→\n 601→        local init_valid\n 602→        init_valid=$(echo \"$init_result\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('valid', False))\" 2>/dev/null || echo \"False\")\n 603→\n 604→        if [[ \"$init_valid\" != \"True\" ]]; then\n 605→            log_error \"Pipeline initialization failed:\"\n 606→            echo \"$init_result\"\n 607→            exit 1\n 608→        fi\n 609→\n 610→        local features_count\n 611→        features_count=$(echo \"$init_result\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('features_count', 0))\" 2>/dev/null || echo \"0\")\n 612→        log_success \"Pipeline initialized with $features_count features\"\n 613→    else\n 614→        log_info \"Resuming existing pipeline...\"\n 615→    fi\n 616→\n 617→    # Print header\n 618→    echo \"\"\n 619→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 620→    echo -e \"${BOLD}          Dev-Pipeline Runner Started${NC}\"\n 621→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 622→    log_info \"Feature list: $feature_list\"\n 623→    log_info \"Max retries per feature: $MAX_RETRIES\"\n 624→    if [[ $SESSION_TIMEOUT -gt 0 ]]; then\n 625→        log_info \"Session timeout: ${SESSION_TIMEOUT}s\"\n 626→    else\n 627→        log_info \"Session timeout: none\"\n 628→    fi\n 629→    log_info \"AI CLI: $CLI_CMD (platform: $PLATFORM)\"\n 630→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 631→    echo \"\"\n 632→\n 633→    # Main processing loop\n 634→    local session_count=0\n 635→\n 636→    while true; do\n 637→        # Check for stuck features\n 638→        local stuck_result\n 639→        stuck_result=$(python3 \"$SCRIPTS_DIR/detect-stuck.py\" \\\n 640→            --state-dir \"$STATE_DIR\" \\\n 641→            --feature-list \"$FEATURE_LIST\" \\\n 642→            --max-retries \"$MAX_RETRIES\" \\\n 643→            --stale-threshold \"$HEARTBEAT_STALE_THRESHOLD\" 2>/dev/null || echo '{\"stuck_count\": 0}')\n 644→\n 645→        local stuck_count\n 646→        stuck_count=$(echo \"$stuck_result\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('stuck_count', 0))\" 2>/dev/null || echo \"0\")\n 647→\n 648→        if [[ \"$stuck_count\" -gt 0 ]]; then\n 649→            log_warn \"Detected $stuck_count stuck feature(s):\"\n 650→            echo \"$stuck_result\" | python3 -c \"\n 651→import sys, json\n 652→data = json.load(sys.stdin)\n 653→for f in data.get('stuck_features', []):\n 654→    print(f'  - {f[\\\"feature_id\\\"]}: {f[\\\"reason\\\"]} — {f[\\\"suggestion\\\"]}')\n 655→\" 2>/dev/null || true\n 656→        fi\n 657→\n 658→        # Find next feature to process\n 659→        local next_feature\n 660→        next_feature=$(python3 \"$SCRIPTS_DIR/update-feature-status.py\" \\\n 661→            --feature-list \"$feature_list\" \\\n 662→            --state-dir \"$STATE_DIR\" \\\n 663→            --max-retries \"$MAX_RETRIES\" \\\n 664→            --action get_next 2>/dev/null) || true\n 665→\n 666→        if [[ \"$next_feature\" == \"PIPELINE_COMPLETE\" ]]; then\n 667→            echo \"\"\n 668→            log_success \"════════════════════════════════════════════════════\"\n 669→            log_success \"  All features completed! Pipeline finished.\"\n 670→            log_success \"  Total sessions: $session_count\"\n 671→            log_success \"════════════════════════════════════════════════════\"\n 672→            break\n 673→        fi\n 674→\n 675→        if [[ \"$next_feature\" == \"PIPELINE_BLOCKED\" ]]; then\n 676→            log_warn \"All remaining features are blocked by dependencies or failed.\"\n 677→            log_warn \"Run './run.sh status' to see details.\"\n 678→            log_warn \"Waiting 60s before re-checking... (Ctrl+C to stop)\"\n 679→            sleep 60\n 680→            continue\n 681→        fi\n 682→\n 683→        # Parse feature info\n 684→        local feature_id feature_title retry_count resume_phase\n 685→        feature_id=$(echo \"$next_feature\" | jq -r '.feature_id')\n 686→        feature_title=$(echo \"$next_feature\" | jq -r '.title')\n 687→        retry_count=$(echo \"$next_feature\" | jq -r '.retry_count // 0')\n 688→        resume_phase=$(echo \"$next_feature\" | jq -r '.resume_from_phase // \"null\"')\n 689→\n 690→        echo \"\"\n 691→        echo -e \"${BOLD}────────────────────────────────────────────────────${NC}\"\n 692→        log_info \"Feature: ${BOLD}$feature_id${NC} — $feature_title\"\n 693→        log_info \"Retry: $retry_count / $MAX_RETRIES\"\n 694→        if [[ \"$resume_phase\" != \"null\" ]]; then\n 695→            log_info \"Resuming from Phase $resume_phase\"\n 696→        fi\n 697→        echo -e \"${BOLD}────────────────────────────────────────────────────${NC}\"\n 698→\n 699→        # Generate session ID and bootstrap prompt\n 700→        local session_id run_id\n 701→        run_id=$(jq -r '.run_id' \"$STATE_DIR/pipeline.json\")\n 702→        session_id=\"${feature_id}-$(date +%Y%m%d%H%M%S)\"\n 703→\n 704→        local session_dir=\"$STATE_DIR/features/$feature_id/sessions/$session_id\"\n 705→        mkdir -p \"$session_dir/logs\"\n 706→\n 707→        local bootstrap_prompt=\"$session_dir/bootstrap-prompt.md\"\n 708→        python3 \"$SCRIPTS_DIR/generate-bootstrap-prompt.py\" \\\n 709→            --feature-list \"$feature_list\" \\\n 710→            --feature-id \"$feature_id\" \\\n 711→            --session-id \"$session_id\" \\\n 712→            --run-id \"$run_id\" \\\n 713→            --retry-count \"$retry_count\" \\\n 714→            --resume-phase \"$resume_phase\" \\\n 715→            --state-dir \"$STATE_DIR\" \\\n 716→            --output \"$bootstrap_prompt\" >/dev/null 2>&1\n 717→\n 718→        # Update current session tracking\n 719→        python3 -c \"\n 720→import json, sys, os\n 721→from datetime import datetime\n 722→feature_id, session_id, state_dir = sys.argv[1], sys.argv[2], sys.argv[3]\n 723→data = {\n 724→    'feature_id': feature_id,\n 725→    'session_id': session_id,\n 726→    'started_at': datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\n 727→}\n 728→with open(os.path.join(state_dir, 'current-session.json'), 'w') as f:\n 729→    json.dump(data, f, indent=2)\n 730→\" \"$feature_id\" \"$session_id\" \"$STATE_DIR\"\n 731→\n 732→        # Spawn session and wait\n 733→        log_info \"Spawning AI CLI session: $session_id\"\n 734→        _SPAWN_RESULT=\"\"\n 735→        spawn_and_wait_session \\\n 736→            \"$feature_id\" \"$feature_list\" \"$session_id\" \\\n 737→            \"$bootstrap_prompt\" \"$session_dir\" \"$MAX_RETRIES\"\n 738→        local session_status=\"$_SPAWN_RESULT\"\n 739→\n 740→        session_count=$((session_count + 1))\n 741→\n 742→        # Brief pause before next iteration\n 743→        log_info \"Pausing 5s before next feature...\"\n 744→        sleep 5\n 745→    done\n 746→}\n 747→\n 748→# ============================================================\n 749→# Entry Point\n 750→# ============================================================\n 751→\n 752→show_help() {\n 753→    echo \"Usage: $0 <command> [options]\"\n 754→    echo \"\"\n 755→    echo \"Commands:\"\n 756→    echo \"  run [feature-list.json]                 Run all features sequentially\"\n 757→    echo \"  run <feature-id> [options]              Run a single feature\"\n 758→    echo \"  status [feature-list.json]               Show pipeline status\"\n 759→    echo \"  reset                                    Clear all state and start fresh\"\n 760→    echo \"  help                                     Show this help message\"\n 761→    echo \"\"\n 762→    echo \"Single Feature Options (run <feature-id>):\"\n 763→    echo \"  --dry-run                   Generate bootstrap prompt only, don't spawn session\"\n 764→    echo \"  --resume-phase N            Override resume phase (default: auto-detect)\"\n 765→    echo \"  --mode <lite|standard|full> Override pipeline mode (bypasses estimated_complexity)\"\n 766→    echo \"  --clean                     Delete artifacts and reset before running\"\n 767→    echo \"  --no-reset                  Skip feature status reset step\"\n 768→    echo \"  --timeout N                 Session timeout in seconds (default: 0 = no limit)\"\n 769→    echo \"\"\n 770→    echo \"Environment Variables:\"\n 771→    echo \"  MAX_RETRIES           Max retries per feature (default: 3)\"\n 772→    echo \"  SESSION_TIMEOUT       Session timeout in seconds (default: 0 = no limit)\"\n 773→    echo \"  AI_CLI                AI CLI command name (auto-detected: cbc or claude)\"\n 774→    echo \"  HEARTBEAT_INTERVAL    Heartbeat log interval in seconds (default: 30)\"\n 775→    echo \"  HEARTBEAT_STALE_THRESHOLD  Heartbeat stale threshold in seconds (default: 600)\"\n 776→    echo \"\"\n 777→    echo \"Examples:\"\n 778→    echo \"  ./run.sh run                                         # Run all features\"\n 779→    echo \"  ./run.sh run F-007 --dry-run                          # Inspect generated prompt\"\n 780→    echo \"  ./run.sh run F-007 --dry-run --mode lite               # Test lite mode\"\n 781→    echo \"  ./run.sh run F-007 --resume-phase 6                    # Skip to implementation\"\n 782→    echo \"  ./run.sh run F-007 --mode full --timeout 3600          # Full mode, 1h timeout\"\n 783→    echo \"  ./run.sh run F-007 --clean --mode standard             # Clean + run standard\"\n 784→    echo \"  ./run.sh status                                        # Show pipeline status\"\n 785→    echo \"  MAX_RETRIES=5 SESSION_TIMEOUT=7200 ./run.sh run        # Custom config\"\n 786→}\n 787→\n 788→case \"${1:-run}\" in\n 789→    run|resume)\n 790→        shift || true\n 791→        # Check if first arg is a feature ID (F-xxx pattern)\n 792→        if [[ \"${1:-}\" =~ ^[Ff]-[0-9]+ ]]; then\n 793→            run_one \"$@\"\n 794→        else\n 795→            main \"${1:-feature-list.json}\"\n 796→        fi\n 797→        ;;\n 798→    status)\n 799→        check_dependencies\n 800→        if [[ ! -f \"$STATE_DIR/pipeline.json\" ]]; then\n 801→            log_error \"No pipeline state found. Run './run.sh run' first.\"\n 802→            exit 1\n 803→        fi\n 804→        python3 \"$SCRIPTS_DIR/update-feature-status.py\" \\\n 805→            --feature-list \"${2:-feature-list.json}\" \\\n 806→            --state-dir \"$STATE_DIR\" \\\n 807→            --action status\n 808→        ;;\n 809→    reset)\n 810→        log_warn \"Resetting pipeline state...\"\n 811→        rm -rf \"$STATE_DIR\"\n 812→        log_success \"State cleared. Run './run.sh run' to start fresh.\"\n 813→        ;;\n 814→    help|--help|-h)\n 815→        show_help\n 816→        ;;\n 817→    *)\n 818→        log_error \"Unknown command: $1\"\n 819→        show_help\n 820→        exit 1\n 821→        ;;\n 822→esac\n 823→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:39.583Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"372a53e6-a114-4050-b95b-b4cd04e20755","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65cb4073c6e87f31b359cb5c59","content":[{"type":"text","text":"   1→#!/usr/bin/env bash\n   2→set -euo pipefail\n   3→\n   4→# ============================================================\n   5→# dev-pipeline/run-bugfix.sh - Autonomous Bug Fix Pipeline Runner\n   6→#\n   7→# Drives the prizm-dev-team through iterative AI CLI sessions to\n   8→# fix bugs from a bug-fix-list.json specification.\n   9→#\n  10→# Usage:\n  11→#   ./run-bugfix.sh run [bug-fix-list.json]          Run all bugs\n  12→#   ./run-bugfix.sh run <bug-id> [options]            Run a single bug\n  13→#   ./run-bugfix.sh status [bug-fix-list.json]        Show pipeline status\n  14→#   ./run-bugfix.sh reset                             Clear all state\n  15→#\n  16→# Environment Variables:\n  17→#   MAX_RETRIES           Max retries per bug (default: 3)\n  18→#   SESSION_TIMEOUT       Session timeout in seconds (default: 0 = no limit)\n  19→#   AI_CLI                AI CLI command name (auto-detected: cbc or claude)\n  20→#   VERBOSE               Set to 1 to enable --verbose on AI CLI\n  21→#   HEARTBEAT_INTERVAL    Heartbeat log interval in seconds (default: 30)\n  22→#   HEARTBEAT_STALE_THRESHOLD  Heartbeat stale threshold in seconds (default: 600)\n  23→# ============================================================\n  24→\n  25→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n  26→STATE_DIR=\"$SCRIPT_DIR/bugfix-state\"\n  27→SCRIPTS_DIR=\"$SCRIPT_DIR/scripts\"\n  28→\n  29→# Configuration\n  30→MAX_RETRIES=${MAX_RETRIES:-3}\n  31→SESSION_TIMEOUT=${SESSION_TIMEOUT:-0}\n  32→HEARTBEAT_STALE_THRESHOLD=${HEARTBEAT_STALE_THRESHOLD:-600}\n  33→HEARTBEAT_INTERVAL=${HEARTBEAT_INTERVAL:-30}\n  34→VERBOSE=${VERBOSE:-0}\n  35→\n  36→# AI CLI detection\n  37→if [[ -n \"${AI_CLI:-}\" ]]; then\n  38→    CLI_CMD=\"$AI_CLI\"\n  39→elif [[ -n \"${CODEBUDDY_CLI:-}\" ]]; then\n  40→    CLI_CMD=\"$CODEBUDDY_CLI\"\n  41→elif command -v cbc &>/dev/null; then\n  42→    CLI_CMD=\"cbc\"\n  43→elif command -v claude &>/dev/null; then\n  44→    CLI_CMD=\"claude\"\n  45→else\n  46→    echo \"ERROR: No AI CLI found. Install CodeBuddy (cbc) or Claude Code (claude).\" >&2\n  47→    exit 1\n  48→fi\n  49→\n  50→# Platform detection\n  51→if [[ -n \"${PRIZMKIT_PLATFORM:-}\" ]]; then\n  52→    PLATFORM=\"$PRIZMKIT_PLATFORM\"\n  53→elif [[ \"$CLI_CMD\" == *\"claude\"* ]]; then\n  54→    PLATFORM=\"claude\"\n  55→else\n  56→    PLATFORM=\"codebuddy\"\n  57→fi\n  58→export PRIZMKIT_PLATFORM=\"$PLATFORM\"\n  59→\n  60→# Source shared heartbeat library\n  61→source \"$SCRIPT_DIR/lib/heartbeat.sh\"\n  62→\n  63→# Detect stream-json support\n  64→detect_stream_json_support \"$CLI_CMD\"\n  65→\n  66→# Bug list path (set in main, used by cleanup trap)\n  67→BUG_LIST=\"\"\n  68→\n  69→# Colors\n  70→RED='\\033[0;31m'\n  71→GREEN='\\033[0;32m'\n  72→YELLOW='\\033[1;33m'\n  73→BLUE='\\033[0;34m'\n  74→MAGENTA='\\033[0;35m'\n  75→BOLD='\\033[1m'\n  76→NC='\\033[0m'\n  77→\n  78→log_info()    { echo -e \"${BLUE}[INFO]${NC}    $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  79→log_warn()    { echo -e \"${YELLOW}[WARN]${NC}    $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  80→log_error()   { echo -e \"${RED}[ERROR]${NC}   $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  81→log_success() { echo -e \"${GREEN}[SUCCESS]${NC} $(date '+%Y-%m-%d %H:%M:%S') $*\"; }\n  82→\n  83→# ============================================================\n  84→# Shared: Spawn AI CLI session and wait for result\n  85→# ============================================================\n  86→\n  87→spawn_and_wait_session() {\n  88→    local bug_id=\"$1\"\n  89→    local bug_list=\"$2\"\n  90→    local session_id=\"$3\"\n  91→    local bootstrap_prompt=\"$4\"\n  92→    local session_dir=\"$5\"\n  93→    local max_retries=\"$6\"\n  94→\n  95→    local session_log=\"$session_dir/logs/session.log\"\n  96→    local progress_json=\"$session_dir/logs/progress.json\"\n  97→\n  98→    local verbose_flag=\"\"\n  99→    if [[ \"$VERBOSE\" == \"1\" ]]; then\n 100→        verbose_flag=\"--verbose\"\n 101→    fi\n 102→\n 103→    local stream_json_flag=\"\"\n 104→    if [[ \"$USE_STREAM_JSON\" == \"true\" ]]; then\n 105→        stream_json_flag=\"--output-format stream-json\"\n 106→    fi\n 107→\n 108→    case \"$CLI_CMD\" in\n 109→        *claude*)\n 110→            \"$CLI_CMD\" \\\n 111→                --print \\\n 112→                -p \"$(cat \"$bootstrap_prompt\")\" \\\n 113→                --yes \\\n 114→                $verbose_flag \\\n 115→                $stream_json_flag \\\n 116→                > \"$session_log\" 2>&1 &\n 117→            ;;\n 118→        *)\n 119→            \"$CLI_CMD\" \\\n 120→                --print \\\n 121→                -y \\\n 122→                $verbose_flag \\\n 123→                $stream_json_flag \\\n 124→                < \"$bootstrap_prompt\" \\\n 125→                > \"$session_log\" 2>&1 &\n 126→            ;;\n 127→    esac\n 128→    local cli_pid=$!\n 129→\n 130→    # Start progress parser (no-op if stream-json not supported)\n 131→    start_progress_parser \"$session_log\" \"$progress_json\" \"$SCRIPTS_DIR\"\n 132→    local parser_pid=\"${_PARSER_PID:-}\"\n 133→\n 134→    # Timeout watchdog\n 135→    local watcher_pid=\"\"\n 136→    if [[ $SESSION_TIMEOUT -gt 0 ]]; then\n 137→        ( sleep \"$SESSION_TIMEOUT\" && kill -TERM \"$cli_pid\" 2>/dev/null ) &\n 138→        watcher_pid=$!\n 139→    fi\n 140→\n 141→    # Heartbeat monitor\n 142→    start_heartbeat \"$cli_pid\" \"$session_log\" \"$progress_json\" \"$HEARTBEAT_INTERVAL\"\n 143→    local heartbeat_pid=\"${_HEARTBEAT_PID:-}\"\n 144→\n 145→    # Wait for AI CLI to finish\n 146→    local exit_code=0\n 147→    if wait \"$cli_pid\" 2>/dev/null; then\n 148→        exit_code=0\n 149→    else\n 150→        exit_code=$?\n 151→    fi\n 152→\n 153→    # Cleanup\n 154→    [[ -n \"$watcher_pid\" ]] && kill \"$watcher_pid\" 2>/dev/null || true\n 155→    stop_heartbeat \"$heartbeat_pid\"\n 156→    stop_progress_parser \"$parser_pid\"\n 157→    [[ -n \"$watcher_pid\" ]] && wait \"$watcher_pid\" 2>/dev/null || true\n 158→\n 159→    [[ $exit_code -eq 143 ]] && exit_code=124\n 160→\n 161→    # Session summary\n 162→    if [[ -f \"$session_log\" ]]; then\n 163→        local final_size=$(wc -c < \"$session_log\" 2>/dev/null | tr -d ' ')\n 164→        local final_lines=$(wc -l < \"$session_log\" 2>/dev/null | tr -d ' ')\n 165→        log_info \"Session log: $final_lines lines, $((final_size / 1024))KB\"\n 166→    fi\n 167→\n 168→    # Check session outcome\n 169→    local session_status_file=\"$session_dir/session-status.json\"\n 170→    local session_status\n 171→\n 172→    if [[ $exit_code -eq 124 ]]; then\n 173→        log_warn \"Session timed out after ${SESSION_TIMEOUT}s\"\n 174→        session_status=\"timed_out\"\n 175→    elif [[ -f \"$session_status_file\" ]]; then\n 176→        session_status=$(python3 \"$SCRIPTS_DIR/check-session-status.py\" \\\n 177→            --status-file \"$session_status_file\" 2>/dev/null) || session_status=\"crashed\"\n 178→    else\n 179→        log_warn \"Session ended without status file — treating as crashed\"\n 180→        session_status=\"crashed\"\n 181→    fi\n 182→\n 183→    log_info \"Session result: $session_status\"\n 184→\n 185→    # Update bug status\n 186→    python3 \"$SCRIPTS_DIR/update-bug-status.py\" \\\n 187→        --bug-list \"$bug_list\" \\\n 188→        --state-dir \"$STATE_DIR\" \\\n 189→        --bug-id \"$bug_id\" \\\n 190→        --session-status \"$session_status\" \\\n 191→        --session-id \"$session_id\" \\\n 192→        --max-retries \"$max_retries\" \\\n 193→        --action update >/dev/null 2>&1 || true\n 194→\n 195→    _SPAWN_RESULT=\"$session_status\"\n 196→}\n 197→\n 198→# ============================================================\n 199→# Graceful Shutdown\n 200→# ============================================================\n 201→\n 202→cleanup() {\n 203→    echo \"\"\n 204→    log_warn \"Received interrupt signal. Saving state...\"\n 205→\n 206→    if [[ -n \"$BUG_LIST\" && -f \"$BUG_LIST\" ]]; then\n 207→        python3 \"$SCRIPTS_DIR/update-bug-status.py\" \\\n 208→            --bug-list \"$BUG_LIST\" \\\n 209→            --state-dir \"$STATE_DIR\" \\\n 210→            --action pause 2>/dev/null || true\n 211→    fi\n 212→\n 213→    log_info \"Bug fix pipeline paused. Run './run-bugfix.sh run' to resume.\"\n 214→    exit 130\n 215→}\n 216→trap cleanup SIGINT SIGTERM\n 217→\n 218→# ============================================================\n 219→# Dependency Check\n 220→# ============================================================\n 221→\n 222→check_dependencies() {\n 223→    if ! command -v jq &>/dev/null; then\n 224→        log_error \"jq is required but not installed. Install with: brew install jq\"\n 225→        exit 1\n 226→    fi\n 227→    if ! command -v python3 &>/dev/null; then\n 228→        log_error \"python3 is required but not installed.\"\n 229→        exit 1\n 230→    fi\n 231→}\n 232→\n 233→# ============================================================\n 234→# run-one: Run a single bug fix\n 235→# ============================================================\n 236→\n 237→run_one() {\n 238→    local bug_id=\"\"\n 239→    local bug_list=\"\"\n 240→    local dry_run=false\n 241→\n 242→    while [[ $# -gt 0 ]]; do\n 243→        case \"$1\" in\n 244→            --dry-run) dry_run=true; shift ;;\n 245→            --timeout) shift; SESSION_TIMEOUT=\"${1:-0}\"; shift ;;\n 246→            B-*|b-*) bug_id=\"$1\"; shift ;;\n 247→            *) bug_list=\"$1\"; shift ;;\n 248→        esac\n 249→    done\n 250→\n 251→    if [[ -z \"$bug_id\" ]]; then\n 252→        log_error \"Bug ID is required (e.g. B-001)\"\n 253→        echo \"\"\n 254→        show_help\n 255→        exit 1\n 256→    fi\n 257→\n 258→    if [[ -z \"$bug_list\" ]]; then\n 259→        bug_list=\"bug-fix-list.json\"\n 260→    fi\n 261→    if [[ ! \"$bug_list\" = /* ]]; then\n 262→        bug_list=\"$(pwd)/$bug_list\"\n 263→    fi\n 264→    BUG_LIST=\"$bug_list\"\n 265→\n 266→    if [[ ! -f \"$bug_list\" ]]; then\n 267→        log_error \"Bug fix list not found: $bug_list\"\n 268→        exit 1\n 269→    fi\n 270→\n 271→    check_dependencies\n 272→\n 273→    # Initialize state if needed\n 274→    if [[ ! -f \"$STATE_DIR/pipeline.json\" ]]; then\n 275→        log_info \"Initializing bugfix pipeline state...\"\n 276→        python3 \"$SCRIPTS_DIR/init-bugfix-pipeline.py\" \\\n 277→            --bug-list \"$bug_list\" \\\n 278→            --state-dir \"$STATE_DIR\" >/dev/null 2>&1 || {\n 279→            log_error \"Failed to initialize bugfix pipeline state\"\n 280→            exit 1\n 281→        }\n 282→    fi\n 283→\n 284→    # Verify bug exists\n 285→    local bug_title\n 286→    bug_title=$(python3 -c \"\n 287→import json, sys\n 288→with open('$bug_list') as f:\n 289→    data = json.load(f)\n 290→for bug in data.get('bugs', []):\n 291→    if bug.get('id') == '$bug_id':\n 292→        print(bug.get('title', ''))\n 293→        sys.exit(0)\n 294→sys.exit(1)\n 295→\" 2>/dev/null) || {\n 296→        log_error \"Bug $bug_id not found in $bug_list\"\n 297→        exit 1\n 298→    }\n 299→\n 300→    local bug_severity\n 301→    bug_severity=$(python3 -c \"\n 302→import json, sys\n 303→with open('$bug_list') as f:\n 304→    data = json.load(f)\n 305→for bug in data.get('bugs', []):\n 306→    if bug.get('id') == '$bug_id':\n 307→        print(bug.get('severity', 'medium'))\n 308→        sys.exit(0)\n 309→sys.exit(1)\n 310→\" 2>/dev/null) || bug_severity=\"medium\"\n 311→\n 312→    # Reset bug status\n 313→    python3 \"$SCRIPTS_DIR/update-bug-status.py\" \\\n 314→        --bug-list \"$bug_list\" \\\n 315→        --state-dir \"$STATE_DIR\" \\\n 316→        --bug-id \"$bug_id\" \\\n 317→        --action reset >/dev/null 2>&1 || true\n 318→\n 319→    # Generate bootstrap prompt\n 320→    local run_id session_id session_dir bootstrap_prompt\n 321→    run_id=$(jq -r '.run_id' \"$STATE_DIR/pipeline.json\")\n 322→    session_id=\"${bug_id}-$(date +%Y%m%d%H%M%S)\"\n 323→    session_dir=\"$STATE_DIR/bugs/$bug_id/sessions/$session_id\"\n 324→    mkdir -p \"$session_dir/logs\"\n 325→\n 326→    bootstrap_prompt=\"$session_dir/bootstrap-prompt.md\"\n 327→\n 328→    log_info \"Generating bugfix bootstrap prompt...\"\n 329→    python3 \"$SCRIPTS_DIR/generate-bugfix-prompt.py\" \\\n 330→        --bug-list \"$bug_list\" \\\n 331→        --bug-id \"$bug_id\" \\\n 332→        --session-id \"$session_id\" \\\n 333→        --run-id \"$run_id\" \\\n 334→        --retry-count 0 \\\n 335→        --resume-phase \"null\" \\\n 336→        --state-dir \"$STATE_DIR\" \\\n 337→        --output \"$bootstrap_prompt\" >/dev/null 2>&1\n 338→\n 339→    if [[ \"$dry_run\" == true ]]; then\n 340→        echo \"\"\n 341→        echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 342→        echo -e \"${BOLD}  Dry Run: $bug_id — $bug_title${NC}\"\n 343→        echo -e \"${BOLD}  Severity: $bug_severity${NC}\"\n 344→        echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 345→        echo \"\"\n 346→        log_info \"Bootstrap prompt written to:\"\n 347→        echo \"  $bootstrap_prompt\"\n 348→        echo \"\"\n 349→        log_success \"Dry run complete. Inspect full prompt with:\"\n 350→        echo \"  cat $bootstrap_prompt\"\n 351→        return 0\n 352→    fi\n 353→\n 354→    echo \"\"\n 355→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 356→    echo -e \"${BOLD}  Bug Fix: $bug_id — $bug_title${NC}\"\n 357→    echo -e \"${BOLD}  Severity: $bug_severity${NC}\"\n 358→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 359→    log_info \"Session ID: $session_id\"\n 360→    log_info \"Prompt: $bootstrap_prompt\"\n 361→    log_info \"Log: $session_dir/logs/session.log\"\n 362→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 363→    echo \"\"\n 364→\n 365→    cleanup() {\n 366→        echo \"\"\n 367→        log_warn \"Interrupted. Killing session...\"\n 368→        kill 0 2>/dev/null || true\n 369→        log_info \"Session log: $session_dir/logs/session.log\"\n 370→        exit 130\n 371→    }\n 372→    trap cleanup SIGINT SIGTERM\n 373→\n 374→    _SPAWN_RESULT=\"\"\n 375→    spawn_and_wait_session \\\n 376→        \"$bug_id\" \"$bug_list\" \"$session_id\" \\\n 377→        \"$bootstrap_prompt\" \"$session_dir\" 999\n 378→    local session_status=\"$_SPAWN_RESULT\"\n 379→\n 380→    echo \"\"\n 381→    if [[ \"$session_status\" == \"success\" ]]; then\n 382→        log_success \"════════════════════════════════════════════════════\"\n 383→        log_success \"  $bug_id fixed successfully!\"\n 384→        log_success \"════════════════════════════════════════════════════\"\n 385→    else\n 386→        log_error \"════════════════════════════════════════════════════\"\n 387→        log_error \"  $bug_id result: $session_status\"\n 388→        log_error \"  Review log: $session_dir/logs/session.log\"\n 389→        log_error \"════════════════════════════════════════════════════\"\n 390→    fi\n 391→}\n 392→\n 393→# ============================================================\n 394→# Main Loop: Run all bugs\n 395→# ============================================================\n 396→\n 397→main() {\n 398→    local bug_list=\"${1:-bug-fix-list.json}\"\n 399→\n 400→    if [[ ! \"$bug_list\" = /* ]]; then\n 401→        bug_list=\"$(pwd)/$bug_list\"\n 402→    fi\n 403→    BUG_LIST=\"$bug_list\"\n 404→\n 405→    if [[ ! -f \"$bug_list\" ]]; then\n 406→        log_error \"Bug fix list not found: $bug_list\"\n 407→        log_info \"Create a bug fix list first using the bug-planner skill,\"\n 408→        log_info \"or provide a path: ./run-bugfix.sh run <path-to-bug-fix-list.json>\"\n 409→        exit 1\n 410→    fi\n 411→\n 412→    check_dependencies\n 413→\n 414→    # Initialize pipeline state if needed\n 415→    if [[ ! -f \"$STATE_DIR/pipeline.json\" ]]; then\n 416→        log_info \"Initializing bugfix pipeline state...\"\n 417→        local init_result\n 418→        init_result=$(python3 \"$SCRIPTS_DIR/init-bugfix-pipeline.py\" \\\n 419→            --bug-list \"$bug_list\" \\\n 420→            --state-dir \"$STATE_DIR\" 2>&1)\n 421→\n 422→        local init_valid\n 423→        init_valid=$(echo \"$init_result\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('valid', False))\" 2>/dev/null || echo \"False\")\n 424→\n 425→        if [[ \"$init_valid\" != \"True\" ]]; then\n 426→            log_error \"Bugfix pipeline initialization failed:\"\n 427→            echo \"$init_result\"\n 428→            exit 1\n 429→        fi\n 430→\n 431→        local bugs_count\n 432→        bugs_count=$(echo \"$init_result\" | python3 -c \"import sys,json; print(json.load(sys.stdin).get('bugs_count', 0))\" 2>/dev/null || echo \"0\")\n 433→        log_success \"Bugfix pipeline initialized with $bugs_count bugs\"\n 434→    else\n 435→        log_info \"Resuming existing bugfix pipeline...\"\n 436→    fi\n 437→\n 438→    # Print header\n 439→    echo \"\"\n 440→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 441→    echo -e \"${BOLD}        Bug-Fix Pipeline Runner Started${NC}\"\n 442→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 443→    log_info \"Bug fix list: $bug_list\"\n 444→    log_info \"Max retries per bug: $MAX_RETRIES\"\n 445→    if [[ $SESSION_TIMEOUT -gt 0 ]]; then\n 446→        log_info \"Session timeout: ${SESSION_TIMEOUT}s\"\n 447→    else\n 448→        log_info \"Session timeout: none\"\n 449→    fi\n 450→    log_info \"AI CLI: $CLI_CMD (platform: $PLATFORM)\"\n 451→    echo -e \"${BOLD}════════════════════════════════════════════════════${NC}\"\n 452→    echo \"\"\n 453→\n 454→    local session_count=0\n 455→\n 456→    while true; do\n 457→        # Find next bug to process\n 458→        local next_bug\n 459→        next_bug=$(python3 \"$SCRIPTS_DIR/update-bug-status.py\" \\\n 460→            --bug-list \"$bug_list\" \\\n 461→            --state-dir \"$STATE_DIR\" \\\n 462→            --max-retries \"$MAX_RETRIES\" \\\n 463→            --action get_next 2>/dev/null) || true\n 464→\n 465→        if [[ \"$next_bug\" == \"PIPELINE_COMPLETE\" ]]; then\n 466→            echo \"\"\n 467→            log_success \"════════════════════════════════════════════════════\"\n 468→            log_success \"  All bugs processed! Bug fix pipeline finished.\"\n 469→            log_success \"  Total sessions: $session_count\"\n 470→            log_success \"════════════════════════════════════════════════════\"\n 471→            break\n 472→        fi\n 473→\n 474→        if [[ \"$next_bug\" == \"PIPELINE_BLOCKED\" ]]; then\n 475→            log_warn \"All remaining bugs are blocked (needs_info/failed).\"\n 476→            log_warn \"Run './run-bugfix.sh status' to see details.\"\n 477→            log_warn \"Waiting 60s before re-checking... (Ctrl+C to stop)\"\n 478→            sleep 60\n 479→            continue\n 480→        fi\n 481→\n 482→        # Parse bug info\n 483→        local bug_id bug_title bug_severity retry_count resume_phase\n 484→        bug_id=$(echo \"$next_bug\" | jq -r '.bug_id')\n 485→        bug_title=$(echo \"$next_bug\" | jq -r '.title')\n 486→        bug_severity=$(echo \"$next_bug\" | jq -r '.severity')\n 487→        retry_count=$(echo \"$next_bug\" | jq -r '.retry_count // 0')\n 488→        resume_phase=$(echo \"$next_bug\" | jq -r '.resume_from_phase // \"null\"')\n 489→\n 490→        echo \"\"\n 491→        echo -e \"${BOLD}────────────────────────────────────────────────────${NC}\"\n 492→        log_info \"Bug: ${BOLD}$bug_id${NC} — $bug_title\"\n 493→        log_info \"Severity: $bug_severity | Retry: $retry_count / $MAX_RETRIES\"\n 494→        if [[ \"$resume_phase\" != \"null\" ]]; then\n 495→            log_info \"Resuming from Phase $resume_phase\"\n 496→        fi\n 497→        echo -e \"${BOLD}────────────────────────────────────────────────────${NC}\"\n 498→\n 499→        # Generate session\n 500→        local session_id run_id\n 501→        run_id=$(jq -r '.run_id' \"$STATE_DIR/pipeline.json\")\n 502→        session_id=\"${bug_id}-$(date +%Y%m%d%H%M%S)\"\n 503→\n 504→        local session_dir=\"$STATE_DIR/bugs/$bug_id/sessions/$session_id\"\n 505→        mkdir -p \"$session_dir/logs\"\n 506→\n 507→        local bootstrap_prompt=\"$session_dir/bootstrap-prompt.md\"\n 508→        python3 \"$SCRIPTS_DIR/generate-bugfix-prompt.py\" \\\n 509→            --bug-list \"$bug_list\" \\\n 510→            --bug-id \"$bug_id\" \\\n 511→            --session-id \"$session_id\" \\\n 512→            --run-id \"$run_id\" \\\n 513→            --retry-count \"$retry_count\" \\\n 514→            --resume-phase \"$resume_phase\" \\\n 515→            --state-dir \"$STATE_DIR\" \\\n 516→            --output \"$bootstrap_prompt\" >/dev/null 2>&1\n 517→\n 518→        # Track current session\n 519→        python3 -c \"\n 520→import json\n 521→from datetime import datetime\n 522→data = {\n 523→    'bug_id': '$bug_id',\n 524→    'session_id': '$session_id',\n 525→    'started_at': datetime.utcnow().strftime('%Y-%m-%dT%H:%M:%SZ')\n 526→}\n 527→with open('$STATE_DIR/current-session.json', 'w') as f:\n 528→    json.dump(data, f, indent=2)\n 529→\"\n 530→\n 531→        # Spawn session\n 532→        log_info \"Spawning AI CLI session: $session_id\"\n 533→        _SPAWN_RESULT=\"\"\n 534→        spawn_and_wait_session \\\n 535→            \"$bug_id\" \"$bug_list\" \"$session_id\" \\\n 536→            \"$bootstrap_prompt\" \"$session_dir\" \"$MAX_RETRIES\"\n 537→\n 538→        session_count=$((session_count + 1))\n 539→\n 540→        log_info \"Pausing 5s before next bug...\"\n 541→        sleep 5\n 542→    done\n 543→}\n 544→\n 545→# ============================================================\n 546→# Entry Point\n 547→# ============================================================\n 548→\n 549→show_help() {\n 550→    echo \"Usage: $0 <command> [options]\"\n 551→    echo \"\"\n 552→    echo \"Commands:\"\n 553→    echo \"  run [bug-fix-list.json]                 Run all bugs by severity/priority order\"\n 554→    echo \"  run <bug-id> [options]                   Run a single bug fix\"\n 555→    echo \"  status [bug-fix-list.json]               Show bug fix pipeline status\"\n 556→    echo \"  reset                                    Clear all bugfix state\"\n 557→    echo \"  help                                     Show this help message\"\n 558→    echo \"\"\n 559→    echo \"Single Bug Options (run <bug-id>):\"\n 560→    echo \"  --dry-run                   Generate bootstrap prompt only, don't spawn session\"\n 561→    echo \"  --timeout N                 Session timeout in seconds (default: 0 = no limit)\"\n 562→    echo \"\"\n 563→    echo \"Environment Variables:\"\n 564→    echo \"  MAX_RETRIES           Max retries per bug (default: 3)\"\n 565→    echo \"  SESSION_TIMEOUT       Session timeout in seconds (default: 0 = no limit)\"\n 566→    echo \"  AI_CLI                AI CLI command name (auto-detected: cbc or claude)\"\n 567→    echo \"  VERBOSE               Set to 1 for verbose AI CLI output\"\n 568→    echo \"  HEARTBEAT_INTERVAL    Heartbeat log interval in seconds (default: 30)\"\n 569→    echo \"\"\n 570→    echo \"Examples:\"\n 571→    echo \"  ./run-bugfix.sh run                                    # Run all bugs\"\n 572→    echo \"  ./run-bugfix.sh run bug-fix-list.json                  # Custom bug list\"\n 573→    echo \"  ./run-bugfix.sh run B-001 --dry-run                    # Inspect generated prompt\"\n 574→    echo \"  ./run-bugfix.sh run B-001 --timeout 3600               # 1h timeout\"\n 575→    echo \"  ./run-bugfix.sh status                                 # Show status\"\n 576→    echo \"  MAX_RETRIES=5 ./run-bugfix.sh run                      # Custom retries\"\n 577→}\n 578→\n 579→case \"${1:-run}\" in\n 580→    run|resume)\n 581→        shift || true\n 582→        if [[ \"${1:-}\" =~ ^[Bb]-[0-9]+ ]]; then\n 583→            run_one \"$@\"\n 584→        else\n 585→            main \"${1:-bug-fix-list.json}\"\n 586→        fi\n 587→        ;;\n 588→    status)\n 589→        check_dependencies\n 590→        if [[ ! -f \"$STATE_DIR/pipeline.json\" ]]; then\n 591→            log_error \"No bugfix pipeline state found. Run './run-bugfix.sh run' first.\"\n 592→            exit 1\n 593→        fi\n 594→        python3 \"$SCRIPTS_DIR/update-bug-status.py\" \\\n 595→            --bug-list \"${2:-bug-fix-list.json}\" \\\n 596→            --state-dir \"$STATE_DIR\" \\\n 597→            --action status\n 598→        ;;\n 599→    reset)\n 600→        log_warn \"Resetting bugfix pipeline state...\"\n 601→        rm -rf \"$STATE_DIR\"\n 602→        log_success \"Bugfix state cleared. Run './run-bugfix.sh run' to start fresh.\"\n 603→        ;;\n 604→    help|--help|-h)\n 605→        show_help\n 606→        ;;\n 607→    *)\n 608→        log_error \"Unknown command: $1\"\n 609→        show_help\n 610→        exit 1\n 611→        ;;\n 612→esac\n 613→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:39.585Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
