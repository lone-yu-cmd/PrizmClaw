{"type":"assistant","uuid":"202603120344481b612f4f618541d0","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"id":"202603120344481b612f4f618541d0","content":[{"type":"tool_use","id":"call_a64567da428d464f812015d8","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/stop.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":36414,"output_tokens":271,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:55.685Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"550e87fa-4f4f-4df6-9734-ad213c513ebb","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_1509065077c544c78084f20b","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ */\n   5→\n   6→import {\n   7→  startPipeline,\n   8→  getPipelineStatus,\n   9→  stopPipeline,\n  10→  getPipelineLogs\n  11→} from '../../../services/pipeline-control-service.js';\n  12→import { formatValidationErrors, formatError, ErrorCodes } from '../formatter.js';\n  13→\n  14→/**\n  15→ * Pipeline command metadata.\n  16→ */\n  17→export const pipelineMeta = {\n  18→  name: 'pipeline',\n  19→  aliases: ['p'],\n  20→  description: '管理管道任务',\n  21→  usage: '/pipeline <action> [target] [--type=<type>]',\n  22→  examples: [\n  23→    '/pipeline run my-feature',\n  24→    '/pipeline run my-feature --type=bugfix',\n  25→    '/pipeline status',\n  26→    '/pipeline logs my-feature',\n  27→    '/pipeline stop my-feature'\n  28→  ],\n  29→  subcommands: [\n  30→    { name: 'run', description: '启动管道' },\n  31→    { name: 'status', description: '查询状态' },\n  32→    { name: 'logs', description: '查看日志' },\n  33→    { name: 'stop', description: '停止管道' }\n  34→  ],\n  35→  params: [\n  36→    {\n  37→      name: 'target',\n  38→      type: 'string',\n  39→      required: false,\n  40→      description: '目标标识符'\n  41→    },\n  42→    {\n  43→      name: 'type',\n  44→      type: 'enum',\n  45→      enum: ['feature', 'bugfix', 'planner'],\n  46→      required: false,\n  47→      default: 'feature',\n  48→      description: '管道类型'\n  49→    }\n  50→  ],\n  51→  requiresAuth: true,\n  52→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  53→};\n  54→\n  55→/**\n  56→ * Handle pipeline command.\n  57→ * @param {Object} handlerCtx - Handler context\n  58→ * @param {Object} handlerCtx.ctx - Telegraf context\n  59→ * @param {Object} handlerCtx.parsed - Parsed command\n  60→ * @param {Object} handlerCtx.params - Normalized parameters\n  61→ * @param {Function} handlerCtx.reply - Reply function\n  62→ */\n  63→export async function handlePipeline(handlerCtx) {\n  64→  const { ctx, parsed, params, reply } = handlerCtx;\n  65→\n  66→  // Determine action from subcommand or default to status\n  67→  const action = parsed.subcommand || 'status';\n  68→\n  69→  switch (action) {\n  70→    case 'run':\n  71→      return handleRun(handlerCtx);\n  72→    case 'status':\n  73→      return handleStatus(handlerCtx);\n  74→    case 'logs':\n  75→      return handleLogs(handlerCtx);\n  76→    case 'stop':\n  77→      return handleStop(handlerCtx);\n  78→    default:\n  79→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop`);\n  80→  }\n  81→}\n  82→\n  83→/**\n  84→ * Handle run subcommand.\n  85→ */\n  86→async function handleRun({ params, reply, parsed }) {\n  87→  const target = params._args?.[0] || params.target;\n  88→  const pipelineType = params.type || 'feature';\n  89→\n  90→  try {\n  91→    const result = await startPipeline({\n  92→      pipelineType,\n  93→      targetId: target\n  94→    });\n  95→\n  96→    if (result.ok) {\n  97→      await reply(`✅ 已启动 ${pipelineType} 管道${target ? `: ${target}` : ''}`);\n  98→    } else {\n  99→      await reply(`❌ 启动失败: ${result.stderr || result.error || '未知错误'}`);\n 100→    }\n 101→  } catch (error) {\n 102→    await reply(`❌ 启动失败: ${error.message}`);\n 103→  }\n 104→}\n 105→\n 106→/**\n 107→ * Handle status subcommand.\n 108→ */\n 109→async function handleStatus({ params, reply }) {\n 110→  try {\n 111→    const result = await getPipelineStatus({});\n 112→\n 113→    if (result.ok) {\n 114→      const status = formatStatusOutput(result);\n 115→      await reply(status);\n 116→    } else {\n 117→      await reply(`❌ 查询失败: ${result.stderr || result.error || '未知错误'}`);\n 118→    }\n 119→  } catch (error) {\n 120→    await reply(`❌ 查询失败: ${error.message}`);\n 121→  }\n 122→}\n 123→\n 124→/**\n 125→ * Handle logs subcommand.\n 126→ */\n 127→async function handleLogs({ params, reply, replyFile, parsed }) {\n 128→  const target = params._args?.[0] || params.target;\n 129→\n 130→  try {\n 131→    const result = await getPipelineLogs({ targetId: target });\n 132→\n 133→    if (result.ok) {\n 134→      const logs = result.stdout || result.logs || '';\n 135→\n 136→      if (logs.length >= 4000) {\n 137→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n 138→      } else {\n 139→        await reply(logs || '暂无日志');\n 140→      }\n 141→    } else {\n 142→      await reply(`❌ 获取日志失败: ${result.stderr || result.error || '未知错误'}`);\n 143→    }\n 144→  } catch (error) {\n 145→    await reply(`❌ 获取日志失败: ${error.message}`);\n 146→  }\n 147→}\n 148→\n 149→/**\n 150→ * Handle stop subcommand.\n 151→ */\n 152→async function handleStop({ params, reply, parsed }) {\n 153→  const target = params._args?.[0] || params.target;\n 154→\n 155→  try {\n 156→    const result = await stopPipeline({ targetId: target });\n 157→\n 158→    if (result.ok) {\n 159→      await reply(`✅ 已停止管道${target ? `: ${target}` : ''}`);\n 160→    } else {\n 161→      await reply(`❌ 停止失败: ${result.stderr || result.error || '未知错误'}`);\n 162→    }\n 163→  } catch (error) {\n 164→    await reply(`❌ 停止失败: ${error.message}`);\n 165→  }\n 166→}\n 167→\n 168→/**\n 169→ * Format status output.\n 170→ * @param {Object} result - Status result\n 171→ * @returns {string} Formatted status\n 172→ */\n 173→function formatStatusOutput(result) {\n 174→  if (!result.pipelines || result.pipelines.length === 0) {\n 175→    return '当前没有运行中的管道。';\n 176→  }\n 177→\n 178→  const lines = ['运行中的管道：', ''];\n 179→\n 180→  for (const p of result.pipelines) {\n 181→    lines.push(`• ${p.type || 'pipeline'}: ${p.target || 'unknown'}`);\n 182→    lines.push(`  状态: ${p.status || 'running'}`);\n 183→    if (p.startTime) {\n 184→      lines.push(`  开始: ${p.startTime}`);\n 185→    }\n 186→    lines.push('');\n 187→  }\n 188→\n 189→  return lines.join('\\n');\n 190→}\n 191→\n 192→export default handlePipeline;\n 193→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:55.686Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"f5351d90-abe0-429f-8d1f-ff6ae7b2e8a4","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_87b1730c5ec8426bac728f2a","content":[{"type":"text","text":"   1→/**\n   2→ * Status Command Handler\n   3→ * Handles /status command to show all running pipelines.\n   4→ */\n   5→\n   6→import { getPipelineStatus } from '../../../services/pipeline-control-service.js';\n   7→\n   8→/**\n   9→ * Status command metadata.\n  10→ */\n  11→export const statusMeta = {\n  12→  name: 'status',\n  13→  aliases: ['s'],\n  14→  description: '查看管道状态',\n  15→  usage: '/status',\n  16→  examples: ['/status'],\n  17→  params: [],\n  18→  requiresAuth: true,\n  19→  helpText: '/status - 查看所有运行中的管道'\n  20→};\n  21→\n  22→/**\n  23→ * Handle status command.\n  24→ * @param {Object} handlerCtx - Handler context\n  25→ */\n  26→export async function handleStatus(handlerCtx) {\n  27→  const { reply } = handlerCtx;\n  28→\n  29→  try {\n  30→    const result = await getPipelineStatus({});\n  31→\n  32→    if (result.ok) {\n  33→      const status = formatStatusOutput(result);\n  34→      await reply(status);\n  35→    } else {\n  36→      await reply(`❌ 查询失败: ${result.stderr || result.error || '未知错误'}`);\n  37→    }\n  38→  } catch (error) {\n  39→    await reply(`❌ 查询失败: ${error.message}`);\n  40→  }\n  41→}\n  42→\n  43→/**\n  44→ * Format status output.\n  45→ * @param {Object} result - Status result\n  46→ * @returns {string} Formatted status\n  47→ */\n  48→function formatStatusOutput(result) {\n  49→  // Check if there are any pipelines\n  50→  const pipelines = result.pipelines || [];\n  51→\n  52→  if (pipelines.length === 0) {\n  53→    return '✅ 当前没有运行中的管道。';\n  54→  }\n  55→\n  56→  const lines = ['📊 运行中的管道：', ''];\n  57→\n  58→  for (const p of pipelines) {\n  59→    const icon = getStatusIcon(p.status);\n  60→    lines.push(`${icon} ${p.type || 'pipeline'}: ${p.target || 'unknown'}`);\n  61→    lines.push(`   状态: ${p.status || 'running'}`);\n  62→    if (p.startTime) {\n  63→      lines.push(`   开始: ${p.startTime}`);\n  64→    }\n  65→    lines.push('');\n  66→  }\n  67→\n  68→  lines.push(`共 ${pipelines.length} 个管道运行中。`);\n  69→\n  70→  return lines.join('\\n');\n  71→}\n  72→\n  73→/**\n  74→ * Get status icon.\n  75→ * @param {string} status - Pipeline status\n  76→ * @returns {string} Icon\n  77→ */\n  78→function getStatusIcon(status) {\n  79→  switch (status) {\n  80→    case 'running':\n  81→      return '🔄';\n  82→    case 'pending':\n  83→      return '⏳';\n  84→    case 'success':\n  85→      return '✅';\n  86→    case 'failed':\n  87→      return '❌';\n  88→    default:\n  89→      return '📦';\n  90→  }\n  91→}\n  92→\n  93→export default handleStatus;\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:55.687Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"a9d2f1ab-a7be-464b-9060-8dc50b3e33d9","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_901e1671143e411794387119","content":[{"type":"text","text":"   1→/**\n   2→ * Logs Command Handler\n   3→ * Handles /logs command to retrieve pipeline logs.\n   4→ */\n   5→\n   6→import { getPipelineLogs } from '../../../services/pipeline-control-service.js';\n   7→\n   8→/**\n   9→ * Logs command metadata.\n  10→ */\n  11→export const logsMeta = {\n  12→  name: 'logs',\n  13→  aliases: ['l'],\n  14→  description: '查看管道日志',\n  15→  usage: '/logs [target]',\n  16→  examples: ['/logs', '/logs my-feature'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: false,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/logs [target] - 查看管道日志'\n  27→};\n  28→\n  29→/** Character threshold for sending logs as file */\n  30→const FILE_THRESHOLD = 4000;\n  31→\n  32→/**\n  33→ * Handle logs command.\n  34→ * @param {Object} handlerCtx - Handler context\n  35→ */\n  36→export async function handleLogs(handlerCtx) {\n  37→  const { params, reply, replyFile, parsed } = handlerCtx;\n  38→\n  39→  // Get target from positional args or params\n  40→  const target = params._args?.[0] || params.target;\n  41→\n  42→  try {\n  43→    const result = await getPipelineLogs({ targetId: target });\n  44→\n  45→    if (result.ok) {\n  46→      const logs = result.stdout || result.logs || '';\n  47→\n  48→      if (!logs.trim()) {\n  49→        await reply('📭 暂无日志。');\n  50→        return;\n  51→      }\n  52→\n  53→      // Send as file if too long\n  54→      if (logs.length >= FILE_THRESHOLD) {\n  55→        const filename = `pipeline-logs-${target || 'latest'}.txt`;\n  56→        await replyFile(logs, filename);\n  57→        await reply(`📄 日志已发送为文件 (${logs.length} 字符)`);\n  58→      } else {\n  59→        // Send in chunks if moderately long\n  60→        await sendLogsInChunks(reply, logs);\n  61→      }\n  62→    } else {\n  63→      await reply(`❌ 获取日志失败: ${result.stderr || result.error || '未知错误'}`);\n  64→    }\n  65→  } catch (error) {\n  66→    await reply(`❌ 获取日志失败: ${error.message}`);\n  67→  }\n  68→}\n  69→\n  70→/**\n  71→ * Send logs in chunks to avoid Telegram message limits.\n  72→ * @param {Function} reply - Reply function\n  73→ * @param {string} logs - Log content\n  74→ */\n  75→async function sendLogsInChunks(reply, logs) {\n  76→  const CHUNK_SIZE = 3800;\n  77→\n  78→  if (logs.length <= CHUNK_SIZE) {\n  79→    await reply(`📋 日志:\\n\\`\\`\\`\\n${logs}\\n\\`\\`\\``);\n  80→    return;\n  81→  }\n  82→\n  83→  // Split into chunks\n  84→  const chunks = [];\n  85→  for (let i = 0; i < logs.length; i += CHUNK_SIZE) {\n  86→    chunks.push(logs.slice(i, i + CHUNK_SIZE));\n  87→  }\n  88→\n  89→  await reply(`📋 日志 (${logs.length} 字符, 分 ${chunks.length} 段):`);\n  90→\n  91→  for (let i = 0; i < chunks.length; i++) {\n  92→    await reply(`\\`\\`\\`\\n${chunks[i]}\\n\\`\\`\\``);\n  93→  }\n  94→}\n  95→\n  96→export default handleLogs;\n  97→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:55.687Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"31266544-3dc8-4c4d-9f4d-4c426edfde07","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_a64567da428d464f812015d8","content":[{"type":"text","text":"   1→/**\n   2→ * Stop Command Handler\n   3→ * Handles /stop command to stop running pipelines.\n   4→ */\n   5→\n   6→import { stopPipeline } from '../../../services/pipeline-control-service.js';\n   7→\n   8→/**\n   9→ * Stop command metadata.\n  10→ */\n  11→export const stopMeta = {\n  12→  name: 'stop',\n  13→  aliases: [],\n  14→  description: '停止运行中的管道',\n  15→  usage: '/stop [target]',\n  16→  examples: ['/stop', '/stop my-feature'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: false,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/stop [target] - 停止运行中的管道'\n  27→};\n  28→\n  29→/**\n  30→ * Handle stop command.\n  31→ * @param {Object} handlerCtx - Handler context\n  32→ */\n  33→export async function handleStop(handlerCtx) {\n  34→  const { params, reply, parsed } = handlerCtx;\n  35→\n  36→  // Get target from positional args or params\n  37→  const target = params._args?.[0] || params.target;\n  38→\n  39→  try {\n  40→    const result = await stopPipeline({ targetId: target });\n  41→\n  42→    if (result.ok) {\n  43→      if (target) {\n  44→        await reply(`✅ 已停止管道: ${target}`);\n  45→      } else {\n  46→        await reply('✅ 已停止当前管道。');\n  47→      }\n  48→\n  49→      // Show additional info if available\n  50→      if (result.stoppedCount !== undefined) {\n  51→        await reply(`共停止 ${result.stoppedCount} 个管道。`);\n  52→      }\n  53→    } else {\n  54→      // Check if it's a \"not found\" type error\n  55→      const error = result.stderr || result.error || '';\n  56→      if (error.includes('not found') || error.includes('没有') || error.includes('no pipeline')) {\n  57→        await reply('⚠️ 没有找到运行中的管道。');\n  58→      } else {\n  59→        await reply(`❌ 停止失败: ${error || '未知错误'}`);\n  60→      }\n  61→    }\n  62→  } catch (error) {\n  63→    await reply(`❌ 停止失败: ${error.message}`);\n  64→  }\n  65→}\n  66→\n  67→export default handleStop;\n  68→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:55.687Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
