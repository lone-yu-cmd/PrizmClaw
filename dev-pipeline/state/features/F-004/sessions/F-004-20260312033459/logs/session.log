{"type":"user","uuid":"fdf26a1f-95be-43dc-b671-84bd79eac774","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_da8d02b1b77340989003b0e2","content":[{"type":"text","text":"   1→import { createLockManager, getDefaultLockManager } from '../pipeline-infra/lock-manager.js';\n   2→import { createStateManager, getDefaultStateManager } from '../pipeline-infra/state-manager.js';\n   3→import { executePipelineCommand, buildPipelineCommand } from '../pipeline-infra/script-runner.js';\n   4→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from '../pipeline-infra/path-policy.js';\n   6→import { INFRA_ERROR_CODES } from '../pipeline-infra/error-codes.js';\n   7→\n   8→const DEFAULT_LOG_LINES = 100;\n   9→const DEFAULT_STOP_TIMEOUT_MS = 10000;\n  10→\n  11→/**\n  12→ * Build an error result object.\n  13→ * @param {string} errorCode - Error code\n  14→ * @param {string} message - Error message\n  15→ * @param {Object} [options] - Additional options\n  16→ * @param {string} [options.hint] - Hint for resolving the error\n  17→ * @param {Object} [options.context] - Additional context\n  18→ * @returns {Object} Error result\n  19→ */\n  20→function buildError(errorCode, message, options = {}) {\n  21→  return {\n  22→    ok: false,\n  23→    errorCode,\n  24→    message,\n  25→    ...(options.hint ? { hint: options.hint } : {}),\n  26→    ...(options.context ? { context: options.context } : {})\n  27→  };\n  28→}\n  29→\n  30→/**\n  31→ * Build a success result object.\n  32→ * @param {string} message - Success message\n  33→ * @param {Object} [extra] - Additional fields\n  34→ * @returns {Object} Success result\n  35→ */\n  36→function buildResult(message, extra = {}) {\n  37→  return {\n  38→    ok: true,\n  39→    message,\n  40→    ...extra\n  41→  };\n  42→}\n  43→\n  44→/**\n  45→ * Generate a unique run ID.\n  46→ * @returns {string} Run ID\n  47→ */\n  48→function generateRunId() {\n  49→  const now = new Date();\n  50→  const timestamp = now.toISOString().replace(/[-:T]/g, '').slice(0, 15);\n  51→  return `run-${timestamp}`;\n  52→}\n  53→\n  54→/**\n  55→ * Read last N lines from a file.\n  56→ * @param {string} filePath - Path to file\n  57→ * @param {number} lines - Number of lines to read\n  58→ * @returns {string} File content\n  59→ */\n  60→function readLastLines(filePath, lines) {\n  61→  try {\n  62→    const content = require('fs').readFileSync(filePath, 'utf8');\n  63→    const allLines = content.split('\\n');\n  64→    const selectedLines = allLines.slice(-lines);\n  65→    return selectedLines.join('\\n');\n  66→  } catch {\n  67→    return '';\n  68→  }\n  69→}\n  70→\n  71→/**\n  72→ * Create a pipeline controller instance.\n  73→ * @param {Object} options - Options\n  74→ * @param {Object} [options.lockManager] - Lock manager instance\n  75→ * @param {Object} [options.stateManager] - State manager instance\n  76→ * @param {Function} [options.scriptRunner] - Script runner function\n  77→ * @param {Object} [options.config] - Pipeline config\n  78→ * @returns {Object} Pipeline controller interface\n  79→ */\n  80→export function createPipelineController(options = {}) {\n  81→  const lockManager = options.lockManager || getDefaultLockManager();\n  82→  const stateManager = options.stateManager || getDefaultStateManager();\n  83→  const scriptRunner = options.scriptRunner || executePipelineCommand;\n  84→  const config = options.config || loadPipelineInfraConfig();\n  85→\n  86→  /**\n  87→   * Internal: Acquire lock and return result.\n  88→   * @param {string} type - Pipeline type\n  89→   * @returns {Promise<Object|null>} Lock result or null on success\n  90→   */\n  91→  async function _acquireLock(type) {\n  92→    const lockResult = await lockManager.acquireLock(type);\n  93→    if (!lockResult.ok) {\n  94→      return buildError(\n  95→        INFRA_ERROR_CODES.LOCK_ACQUISITION_FAILED,\n  96→        `Pipeline ${type} is already running`,\n  97→        {\n  98→          hint: 'Stop the current pipeline first or use forceUnlock',\n  99→          context: { currentHolder: lockResult.currentHolder }\n 100→        }\n 101→      );\n 102→    }\n 103→    return null;\n 104→  }\n 105→\n 106→  /**\n 107→   * Internal: Release lock.\n 108→   * @param {string} type - Pipeline type\n 109→   */\n 110→  async function _releaseLock(type) {\n 111→    await lockManager.releaseLock(type);\n 112→  }\n 113→\n 114→  return {\n 115→    // Internal methods (exposed for testing)\n 116→    _acquireLock,\n 117→    _releaseLock,\n 118→\n 119→    /**\n 120→     * Start a pipeline.\n 121→     * @param {Object} params - Parameters\n 122→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 123→     * @param {string} [params.targetId] - Optional target ID to start with\n 124→     * @param {string} [params.listPath] - Optional list path\n 125→     * @param {boolean} [params.daemon=true] - Run in daemon mode\n 126→     * @param {Object} [params.envOverrides] - Environment overrides\n 127→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 128→     * @returns {Promise<Object>} Start result\n 129→     */\n 130→    async startPipeline(params) {\n 131→      const { type = 'feature', targetId, listPath, daemon = true, envOverrides, timeoutMs } = params;\n 132→\n 133→      // Acquire lock\n 134→      const lockError = await _acquireLock(type);\n 135→      if (lockError) {\n 136→        return lockError;\n 137→      }\n 138→\n 139→      // Build and execute command\n 140→      const runId = generateRunId();\n 141→\n 142→      try {\n 143→        const result = await scriptRunner({\n 144→          pipelineType: type,\n 145→          action: 'run',\n 146→          targetId,\n 147→          listPath,\n 148→          envOverrides,\n 149→          timeoutMs\n 150→        });\n 151→\n 152→        if (!result.ok) {\n 153→          // Release lock on failure\n 154→          await _releaseLock(type);\n 155→          return buildError(\n 156→            result.errorCode || INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 157→            result.stderr || 'Failed to start pipeline',\n 158→            { context: { exitCode: result.exitCode } }\n 159→          );\n 160→        }\n 161→\n 162→        return buildResult(`Pipeline ${type} started successfully`, {\n 163→          runId,\n 164→          pid: daemon ? process.pid : undefined,\n 165→          stdout: result.stdout\n 166→        });\n 167→      } catch (error) {\n 168→        await _releaseLock(type);\n 169→        return buildError(\n 170→          INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 171→          error.message,\n 172→          { hint: 'Check pipeline scripts and configuration' }\n 173→        );\n 174→      }\n 175→    },\n 176→\n 177→    /**\n 178→     * Stop a pipeline.\n 179→     * @param {Object} params - Parameters\n 180→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 181→     * @param {number} [params.timeoutMs=10000] - Timeout in milliseconds\n 182→     * @returns {Promise<Object>} Stop result\n 183→     */\n 184→    async stopPipeline(params) {\n 185→      const { type = 'feature', timeoutMs = DEFAULT_STOP_TIMEOUT_MS } = params;\n 186→\n 187→      // Check if daemon is running\n 188→      const isRunning = await stateManager.isDaemonRunning(type);\n 189→      const previousPid = await stateManager.getDaemonPid(type);\n 190→\n 191→      if (!isRunning) {\n 192→        // Already stopped\n 193→        return buildResult(`Pipeline ${type} is not running`, {\n 194→          errorCode: INFRA_ERROR_CODES.ALREADY_STOPPED,\n 195→          previousPid\n 196→        });\n 197→      }\n 198→\n 199→      try {\n 200→        // Execute stop command\n 201→        const result = await scriptRunner({\n 202→          pipelineType: type,\n 203→          action: 'stop',\n 204→          timeoutMs\n 205→        });\n 206→\n 207→        // Release lock\n 208→        await _releaseLock(type);\n 209→\n 210→        if (!result.ok) {\n 211→          return buildError(\n 212→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 213→            result.stderr || 'Failed to stop pipeline',\n 214→            { context: { previousPid } }\n 215→          );\n 216→        }\n 217→\n 218→        return buildResult(`Pipeline ${type} stopped successfully`, {\n 219→          previousPid\n 220→        });\n 221→      } catch (error) {\n 222→        // Still release lock on error\n 223→        await _releaseLock(type);\n 224→        return buildError(\n 225→          INFRA_ERROR_CODES.EXEC_FAILED,\n 226→          error.message,\n 227→          { context: { previousPid } }\n 228→        );\n 229→      }\n 230→    },\n 231→\n 232→    /**\n 233→     * Retry a target.\n 234→     * @param {Object} params - Parameters\n 235→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 236→     * @param {string} params.targetId - Target ID to retry\n 237→     * @param {string} [params.listPath] - Optional list path\n 238→     * @param {boolean} [params.daemon=false] - Run in daemon mode\n 239→     * @param {Object} [params.envOverrides] - Environment overrides\n 240→     * @returns {Promise<Object>} Retry result\n 241→     */\n 242→    async retryTarget(params) {\n 243→      const { type = 'feature', targetId, listPath, daemon = false, envOverrides } = params;\n 244→\n 245→      // Validate targetId\n 246→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 247→        return buildError(\n 248→          INFRA_ERROR_CODES.INVALID_TARGET,\n 249→          'targetId is required for retry',\n 250→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 251→        );\n 252→      }\n 253→\n 254→      // For daemon mode, acquire lock\n 255→      if (daemon) {\n 256→        const lockError = await _acquireLock(type);\n 257→        if (lockError) {\n 258→          return lockError;\n 259→        }\n 260→      }\n 261→\n 262→      try {\n 263→        const result = await scriptRunner({\n 264→          pipelineType: type,\n 265→          action: 'retry',\n 266→          targetId: targetId.trim(),\n 267→          listPath,\n 268→          envOverrides\n 269→        });\n 270→\n 271→        if (daemon) {\n 272→          await _releaseLock(type);\n 273→        }\n 274→\n 275→        if (!result.ok) {\n 276→          return buildError(\n 277→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 278→            result.stderr || `Failed to retry target ${targetId}`,\n 279→            { context: { targetId } }\n 280→          );\n 281→        }\n 282→\n 283→        return buildResult(`Target ${targetId} retry completed`, {\n 284→          targetId,\n 285→          stdout: result.stdout\n 286→        });\n 287→      } catch (error) {\n 288→        if (daemon) {\n 289→          await _releaseLock(type);\n 290→        }\n 291→        return buildError(\n 292→          INFRA_ERROR_CODES.EXEC_FAILED,\n 293→          error.message,\n 294→          { context: { targetId } }\n 295→        );\n 296→      }\n 297→    },\n 298→\n 299→    /**\n 300→     * Run a single target without affecting pipeline state.\n 301→     * @param {Object} params - Parameters\n 302→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 303→     * @param {string} params.targetId - Target ID to run\n 304→     * @param {string} [params.listPath] - Optional list path\n 305→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 306→     * @param {Object} [params.envOverrides] - Environment overrides\n 307→     * @returns {Promise<Object>} Run result\n 308→     */\n 309→    async runSingle(params) {\n 310→      const { type = 'feature', targetId, listPath, timeoutMs, envOverrides } = params;\n 311→\n 312→      // Validate targetId\n 313→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 314→        return buildError(\n 315→          INFRA_ERROR_CODES.INVALID_TARGET,\n 316→          'targetId is required for runSingle',\n 317→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 318→        );\n 319→      }\n 320→\n 321→      // Note: runSingle does NOT acquire lock (independent execution per D5)\n 322→\n 323→      try {\n 324→        const result = await scriptRunner({\n 325→          pipelineType: type,\n 326→          action: 'run',\n 327→          targetId: targetId.trim(),\n 328→          listPath,\n 329→          timeoutMs,\n 330→          envOverrides\n 331→        });\n 332→\n 333→        return {\n 334→          ok: result.ok,\n 335→          targetId,\n 336→          message: result.ok\n 337→            ? `Target ${targetId} completed successfully`\n 338→            : `Target ${targetId} failed`,\n 339→          stdout: result.stdout,\n 340→          stderr: result.stderr,\n 341→          exitCode: result.exitCode,\n 342→          errorCode: result.errorCode\n 343→        };\n 344→      } catch (error) {\n 345→        return buildError(\n 346→          INFRA_ERROR_CODES.EXEC_FAILED,\n 347→          error.message,\n 348→          { context: { targetId } }\n 349→        );\n 350→      }\n 351→    },\n 352→\n 353→    /**\n 354→     * Get pipeline status.\n 355→     * @param {Object} params - Parameters\n 356→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 357→     * @returns {Promise<Object>} Status result\n 358→     */\n 359→    async getStatus(params) {\n 360→      const { type = 'feature' } = params;\n 361→\n 362→      const isRunning = await stateManager.isDaemonRunning(type);\n 363→      const pid = await stateManager.getDaemonPid(type);\n 364→      const pipelineState = await stateManager.readPipelineState(type);\n 365→      const currentSession = await stateManager.readCurrentSession(type);\n 366→      const lastResult = await stateManager.getLastResult(type);\n 367→      const lockInfo = await lockManager.getLockInfo(type);\n 368→\n 369→      const result = {\n 370→        ok: true,\n 371→        isRunning,\n 372→        pid: isRunning ? pid : undefined,\n 373→        message: isRunning\n 374→          ? `Pipeline ${type} is running`\n 375→          : `Pipeline ${type} is not running`\n 376→      };\n 377→\n 378→      // Add current feature info if running\n 379→      if (isRunning && currentSession) {\n 380→        result.currentFeature = currentSession.feature_id;\n 381→        result.startedAt = currentSession.started_at;\n 382→      }\n 383→\n 384→      // Add last result if not running\n 385→      if (!isRunning && lastResult) {\n 386→        result.lastResult = lastResult;\n 387→      }\n 388→\n 389→      // Add lock info\n 390→      if (lockInfo) {\n 391→        result.lockInfo = lockInfo;\n 392→      }\n 393→\n 394→      return result;\n 395→    },\n 396→\n 397→    /**\n 398→     * Get pipeline logs.\n 399→     * @param {Object} params - Parameters\n 400→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 401→     * @param {number} [params.lines=100] - Number of lines to read\n 402→     * @returns {Promise<Object>} Logs result\n 403→     */\n 404→    async getLogs(params) {\n 405→      const { type = 'feature', lines = DEFAULT_LOG_LINES } = params;\n 406→\n 407→      const logPaths = resolveDaemonLogPaths(config.projectRoot);\n 408→      const logPath = type === 'feature'\n 409→        ? logPaths.featureDaemonLog\n 410→        : logPaths.bugfixDaemonLog;\n 411→\n 412→      const logs = readLastLines(logPath, lines);\n 413→\n 414→      return buildResult(`Retrieved ${lines} lines from ${type} log`, {\n 415→        logs,\n 416→        logPath,\n 417→        lines\n 418→      });\n 419→    },\n 420→\n 421→    /**\n 422→     * Force unlock a pipeline (admin operation).\n 423→     * @param {Object} params - Parameters\n 424→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 425→     * @returns {Promise<Object>} Unlock result\n 426→     */\n 427→    async forceUnlock(params) {\n 428→      const { type = 'feature' } = params;\n 429→\n 430→      const result = await lockManager.forceUnlock(type);\n 431→\n 432→      return buildResult(`Lock released for ${type} pipeline`, {\n 433→        previousPid: result.previousPid\n 434→      });\n 435→    }\n 436→  };\n 437→}\n 438→\n 439→// Default instance\n 440→let defaultController = null;\n 441→\n 442→/**\n 443→ * Get the default pipeline controller instance.\n 444→ * @returns {Object} Pipeline controller instance\n 445→ */\n 446→export function getDefaultPipelineController() {\n 447→  if (!defaultController) {\n 448→    defaultController = createPipelineController();\n 449→  }\n 450→  return defaultController;\n 451→}\n 452→\n 453→// Export convenience methods that use default controller\n 454→export async function startPipeline(params) {\n 455→  return getDefaultPipelineController().startPipeline(params);\n 456→}\n 457→\n 458→export async function stopPipeline(params) {\n 459→  return getDefaultPipelineController().stopPipeline(params);\n 460→}\n 461→\n 462→export async function retryTarget(params) {\n 463→  return getDefaultPipelineController().retryTarget(params);\n 464→}\n 465→\n 466→export async function runSingle(params) {\n 467→  return getDefaultPipelineController().runSingle(params);\n 468→}\n 469→\n 470→export async function getStatus(params) {\n 471→  return getDefaultPipelineController().getStatus(params);\n 472→}\n 473→\n 474→export async function getLogs(params) {\n 475→  return getDefaultPipelineController().getLogs(params);\n 476→}\n 477→\n 478→export async function forceUnlock(params) {\n 479→  return getDefaultPipelineController().forceUnlock(params);\n 480→}\n 481→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:51:49.741Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
