{"type":"user","uuid":"a2e54257-337f-49fb-b56d-9c7ad01b806a","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_ab9eb0d9b0014fcfa6f0a40d","content":[{"type":"text","text":"   1→export const INFRA_ERROR_CODES = Object.freeze({\n   2→  // Existing codes\n   3→  CONFIG_MISSING: 'CONFIG_MISSING',\n   4→  CONFIG_INVALID: 'CONFIG_INVALID',\n   5→  PATH_INVALID: 'PATH_INVALID',\n   6→  SCRIPT_NOT_FOUND: 'SCRIPT_NOT_FOUND',\n   7→  EXEC_TIMEOUT: 'EXEC_TIMEOUT',\n   8→  EXEC_FAILED: 'EXEC_FAILED',\n   9→\n  10→  // F-004: Pipeline Process Controller\n  11→  LOCK_ACQUISITION_FAILED: 'LOCK_ACQUISITION_FAILED',\n  12→  ALREADY_STOPPED: 'ALREADY_STOPPED',\n  13→  PIPELINE_NOT_RUNNING: 'PIPELINE_NOT_RUNNING',\n  14→  INVALID_TARGET: 'INVALID_TARGET',\n  15→  TARGET_NOT_RETRYABLE: 'TARGET_NOT_RETRYABLE',\n  16→  DAEMON_START_FAILED: 'DAEMON_START_FAILED'\n  17→});\n  18→\n  19→const ERROR_CODE_SET = new Set(Object.values(INFRA_ERROR_CODES));\n  20→\n  21→export function isInfraErrorCode(code) {\n  22→  return ERROR_CODE_SET.has(code);\n  23→}\n  24→\n  25→export function createInfraError(code, message, options = {}) {\n  26→  if (!isInfraErrorCode(code)) {\n  27→    throw new Error(`Unknown infra error code: ${code}`);\n  28→  }\n  29→\n  30→  return {\n  31→    code,\n  32→    message: String(message ?? ''),\n  33→    ...(options.hint ? { hint: String(options.hint) } : {}),\n  34→    ...(options.context ? { context: options.context } : {})\n  35→  };\n  36→}\n  37→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:36.522Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
