{"type":"user","uuid":"32a118b1-c486-40d8-8fca-c6905221aeed","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65ebbfe5d3006ac9c99e72e615","content":[{"type":"text","text":"   1→#!/usr/bin/env bash\n   2→set -euo pipefail\n   3→\n   4→# ============================================================\n   5→# dev-pipeline/launch-daemon.sh - Daemon wrapper for run.sh\n   6→#\n   7→# Manages run.sh as a background daemon process with PID tracking,\n   8→# log consolidation, and lifecycle commands.\n   9→#\n  10→# Usage:\n  11→#   ./launch-daemon.sh start [feature-list.json] [--env \"KEY=VAL ...\"]\n  12→#   ./launch-daemon.sh stop\n  13→#   ./launch-daemon.sh status\n  14→#   ./launch-daemon.sh logs [--lines N] [--follow]\n  15→#   ./launch-daemon.sh restart [feature-list.json] [--env \"KEY=VAL ...\"]\n  16→#\n  17→# NOTE:\n  18→#   In AI skill sessions, always use this daemon wrapper.\n  19→#   Do NOT call `run.sh run ...` directly, because foreground sessions may be killed by CLI timeout.\n  20→#\n  21→# Files managed:\n  22→#   state/.pipeline.pid          - PID of the background run.sh process\n  23→#   state/pipeline-daemon.log    - Consolidated stdout+stderr from run.sh\n  24→# ============================================================\n  25→\n  26→SCRIPT_DIR=\"$(cd \"$(dirname \"${BASH_SOURCE[0]}\")\" && pwd)\"\n  27→STATE_DIR=\"$SCRIPT_DIR/state\"\n  28→PID_FILE=\"$STATE_DIR/.pipeline.pid\"\n  29→LOG_FILE=\"$STATE_DIR/pipeline-daemon.log\"\n  30→RUN_SCRIPT=\"$SCRIPT_DIR/run.sh\"\n  31→\n  32→# Colors\n  33→RED='\\033[0;31m'\n  34→GREEN='\\033[0;32m'\n  35→YELLOW='\\033[1;33m'\n  36→BLUE='\\033[0;34m'\n  37→BOLD='\\033[1m'\n  38→NC='\\033[0m'\n  39→\n  40→log_info()    { echo -e \"${BLUE}[INFO]${NC}    $*\" >&2; }\n  41→log_warn()    { echo -e \"${YELLOW}[WARN]${NC}    $*\" >&2; }\n  42→log_error()   { echo -e \"${RED}[ERROR]${NC}   $*\" >&2; }\n  43→log_success() { echo -e \"${GREEN}[OK]${NC}      $*\" >&2; }\n  44→\n  45→# ============================================================\n  46→# Helpers\n  47→# ============================================================\n  48→\n  49→# Check if pipeline process is alive\n  50→# Returns 0 if alive, 1 if dead/no PID file\n  51→is_running() {\n  52→    if [[ ! -f \"$PID_FILE\" ]]; then\n  53→        return 1\n  54→    fi\n  55→    local pid\n  56→    pid=$(cat \"$PID_FILE\" 2>/dev/null) || return 1\n  57→    if [[ -z \"$pid\" ]]; then\n  58→        return 1\n  59→    fi\n  60→    if kill -0 \"$pid\" 2>/dev/null; then\n  61→        return 0\n  62→    else\n  63→        return 1\n  64→    fi\n  65→}\n  66→\n  67→# Get PID from file (or empty string)\n  68→get_pid() {\n  69→    if [[ -f \"$PID_FILE\" ]]; then\n  70→        cat \"$PID_FILE\" 2>/dev/null || echo \"\"\n  71→    else\n  72→        echo \"\"\n  73→    fi\n  74→}\n  75→\n  76→# Clean stale PID file\n  77→clean_stale_pid() {\n  78→    if [[ -f \"$PID_FILE\" ]]; then\n  79→        local pid\n  80→        pid=$(get_pid)\n  81→        if [[ -n \"$pid\" ]] && ! kill -0 \"$pid\" 2>/dev/null; then\n  82→            rm -f \"$PID_FILE\"\n  83→            log_warn \"Cleaned stale PID file (process $pid no longer running)\"\n  84→        fi\n  85→    fi\n  86→}\n  87→\n  88→# ============================================================\n  89→# start: Launch run.sh in background\n  90→# ============================================================\n  91→\n  92→cmd_start() {\n  93→    local feature_list=\"\"\n  94→    local env_overrides=\"\"\n  95→\n  96→    # Parse arguments\n  97→    while [[ $# -gt 0 ]]; do\n  98→        case \"$1\" in\n  99→            --env)\n 100→                shift\n 101→                if [[ $# -eq 0 ]]; then\n 102→                    log_error \"--env requires a value (e.g. --env \\\"MAX_RETRIES=5 SESSION_TIMEOUT=3600\\\")\"\n 103→                    exit 1\n 104→                fi\n 105→                env_overrides=\"$1\"\n 106→                shift\n 107→                ;;\n 108→            *)\n 109→                feature_list=\"$1\"\n 110→                shift\n 111→                ;;\n 112→        esac\n 113→    done\n 114→\n 115→    # Default feature list\n 116→    if [[ -z \"$feature_list\" ]]; then\n 117→        feature_list=\"feature-list.json\"\n 118→    fi\n 119→\n 120→    # Resolve to absolute path\n 121→    if [[ ! \"$feature_list\" = /* ]]; then\n 122→        feature_list=\"$(cd \"$(dirname \"$feature_list\")\" 2>/dev/null && pwd)/$(basename \"$feature_list\")\"\n 123→    fi\n 124→\n 125→    # Validate feature list\n 126→    if [[ ! -f \"$feature_list\" ]]; then\n 127→        log_error \"Feature list not found: $feature_list\"\n 128→        log_error \"Run the app-planner skill first to generate feature-list.json\"\n 129→        exit 2\n 130→    fi\n 131→\n 132→    # Validate run.sh exists\n 133→    if [[ ! -x \"$RUN_SCRIPT\" ]]; then\n 134→        log_error \"run.sh not found or not executable: $RUN_SCRIPT\"\n 135→        exit 2\n 136→    fi\n 137→\n 138→    # Clean stale PID if needed\n 139→    clean_stale_pid\n 140→\n 141→    # Check if already running\n 142→    if is_running; then\n 143→        local pid\n 144→        pid=$(get_pid)\n 145→        log_error \"Pipeline is already running (PID: $pid)\"\n 146→        log_error \"Use './launch-daemon.sh stop' first, or './launch-daemon.sh restart'\"\n 147→        exit 1\n 148→    fi\n 149→\n 150→    # Ensure state directory exists\n 151→    mkdir -p \"$STATE_DIR\"\n 152→\n 153→    # Build environment prefix\n 154→    local env_cmd=\"\"\n 155→    if [[ -n \"$env_overrides\" ]]; then\n 156→        env_cmd=\"env $env_overrides\"\n 157→    fi\n 158→\n 159→    # Record start time\n 160→    local start_time\n 161→    start_time=$(date -u '+%Y-%m-%dT%H:%M:%SZ')\n 162→\n 163→    # Launch run.sh in background, fully detached\n 164→    log_info \"Launching pipeline...\"\n 165→    log_info \"Feature list: $feature_list\"\n 166→    log_info \"Log file: $LOG_FILE\"\n 167→    if [[ -n \"$env_overrides\" ]]; then\n 168→        log_info \"Environment overrides: $env_overrides\"\n 169→    fi\n 170→\n 171→    # Write a separator to the log file\n 172→    {\n 173→        echo \"\"\n 174→        echo \"================================================================\"\n 175→        echo \"  Pipeline Daemon Started: $start_time\"\n 176→        echo \"  Feature list: $feature_list\"\n 177→        if [[ -n \"$env_overrides\" ]]; then\n 178→            echo \"  Environment: $env_overrides\"\n 179→        fi\n 180→        echo \"================================================================\"\n 181→        echo \"\"\n 182→    } >> \"$LOG_FILE\"\n 183→\n 184→    # Launch with nohup + disown for full detachment\n 185→    if [[ -n \"$env_cmd\" ]]; then\n 186→        nohup $env_cmd \"$RUN_SCRIPT\" run \"$feature_list\" >> \"$LOG_FILE\" 2>&1 &\n 187→    else\n 188→        nohup \"$RUN_SCRIPT\" run \"$feature_list\" >> \"$LOG_FILE\" 2>&1 &\n 189→    fi\n 190→    local pipeline_pid=$!\n 191→    disown \"$pipeline_pid\" 2>/dev/null || true\n 192→\n 193→    # Write PID file\n 194→    echo \"$pipeline_pid\" > \"$PID_FILE\"\n 195→\n 196→    # Write start metadata\n 197→    python3 -c \"\n 198→import json, sys, os\n 199→pid, started_at, feature_list, env_overrides, log_file, state_dir = int(sys.argv[1]), sys.argv[2], sys.argv[3], sys.argv[4], sys.argv[5], sys.argv[6]\n 200→data = {\n 201→    'pid': pid,\n 202→    'started_at': started_at,\n 203→    'feature_list': feature_list,\n 204→    'env_overrides': env_overrides,\n 205→    'log_file': log_file\n 206→}\n 207→with open(os.path.join(state_dir, '.pipeline-meta.json'), 'w') as f:\n 208→    json.dump(data, f, indent=2)\n 209→\" \"$pipeline_pid\" \"$start_time\" \"$feature_list\" \"$env_overrides\" \"$LOG_FILE\" \"$STATE_DIR\" 2>/dev/null || true\n 210→\n 211→    # Wait briefly and verify\n 212→    sleep 2\n 213→    if is_running; then\n 214→        log_success \"Pipeline started successfully (PID: $pipeline_pid)\"\n 215→        log_info \"Monitor logs: ./launch-daemon.sh logs --follow\"\n 216→        log_info \"Check status: ./launch-daemon.sh status\"\n 217→\n 218→        # Output JSON on stdout for programmatic consumption\n 219→        echo \"{\\\"success\\\": true, \\\"pid\\\": $pipeline_pid, \\\"log_file\\\": \\\"$LOG_FILE\\\", \\\"started_at\\\": \\\"$start_time\\\"}\"\n 220→    else\n 221→        log_error \"Pipeline process died immediately after launch\"\n 222→        log_error \"Check log for errors: tail -20 $LOG_FILE\"\n 223→        rm -f \"$PID_FILE\"\n 224→        exit 1\n 225→    fi\n 226→}\n 227→\n 228→# ============================================================\n 229→# stop: Gracefully stop the pipeline\n 230→# ============================================================\n 231→\n 232→cmd_stop() {\n 233→    if [[ ! -f \"$PID_FILE\" ]]; then\n 234→        log_info \"Pipeline is not running (no PID file)\"\n 235→        echo '{\"success\": true, \"message\": \"not running\"}'\n 236→        return 0\n 237→    fi\n 238→\n 239→    local pid\n 240→    pid=$(get_pid)\n 241→\n 242→    if [[ -z \"$pid\" ]]; then\n 243→        log_info \"Pipeline is not running (empty PID file)\"\n 244→        rm -f \"$PID_FILE\"\n 245→        echo '{\"success\": true, \"message\": \"not running\"}'\n 246→        return 0\n 247→    fi\n 248→\n 249→    if ! kill -0 \"$pid\" 2>/dev/null; then\n 250→        log_info \"Pipeline is not running (process $pid already exited)\"\n 251→        rm -f \"$PID_FILE\"\n 252→        echo '{\"success\": true, \"message\": \"already exited\"}'\n 253→        return 0\n 254→    fi\n 255→\n 256→    log_info \"Stopping pipeline (PID: $pid)...\"\n 257→\n 258→    # Send SIGTERM for graceful shutdown (triggers run.sh cleanup trap)\n 259→    kill -TERM \"$pid\" 2>/dev/null || true\n 260→\n 261→    # Wait up to 30 seconds for graceful exit\n 262→    local waited=0\n 263→    while [[ $waited -lt 30 ]]; do\n 264→        if ! kill -0 \"$pid\" 2>/dev/null; then\n 265→            break\n 266→        fi\n 267→        sleep 1\n 268→        waited=$((waited + 1))\n 269→    done\n 270→\n 271→    # Force kill if still alive\n 272→    if kill -0 \"$pid\" 2>/dev/null; then\n 273→        log_warn \"Process did not exit after 30s, sending SIGKILL...\"\n 274→        kill -9 \"$pid\" 2>/dev/null || true\n 275→        sleep 1\n 276→    fi\n 277→\n 278→    rm -f \"$PID_FILE\"\n 279→\n 280→    if ! kill -0 \"$pid\" 2>/dev/null; then\n 281→        log_success \"Pipeline stopped\"\n 282→        echo \"{\\\"success\\\": true, \\\"pid\\\": $pid, \\\"message\\\": \\\"stopped\\\"}\"\n 283→    else\n 284→        log_error \"Failed to stop pipeline (PID: $pid)\"\n 285→        echo \"{\\\"success\\\": false, \\\"pid\\\": $pid, \\\"message\\\": \\\"failed to stop\\\"}\"\n 286→        exit 1\n 287→    fi\n 288→}\n 289→\n 290→# ============================================================\n 291→# status: Check pipeline status\n 292→# ============================================================\n 293→\n 294→cmd_status() {\n 295→    clean_stale_pid\n 296→\n 297→    if ! is_running; then\n 298→        log_info \"Pipeline is not running\"\n 299→\n 300→        # Check if log file exists for last run info\n 301→        if [[ -f \"$LOG_FILE\" ]]; then\n 302→            local log_size\n 303→            log_size=$(wc -c < \"$LOG_FILE\" 2>/dev/null | tr -d ' ')\n 304→            log_info \"Last log: $LOG_FILE ($((log_size / 1024))KB)\"\n 305→        fi\n 306→\n 307→        # Show feature-level progress from last run if metadata exists\n 308→        if [[ -f \"$STATE_DIR/.pipeline-meta.json\" ]]; then\n 309→            local last_feature_list\n 310→            last_feature_list=$(python3 -c \"\n 311→import json, sys\n 312→with open(sys.argv[1]) as f:\n 313→    print(json.load(f).get('feature_list', ''))\n 314→\" \"$STATE_DIR/.pipeline-meta.json\" 2>/dev/null || echo \"\")\n 315→\n 316→            if [[ -n \"$last_feature_list\" && -f \"$last_feature_list\" ]]; then\n 317→                echo \"\" >&2\n 318→                log_info \"Last run feature progress:\"\n 319→                python3 \"$SCRIPT_DIR/scripts/update-feature-status.py\" \\\n 320→                    --feature-list \"$last_feature_list\" \\\n 321→                    --state-dir \"$STATE_DIR\" \\\n 322→                    --action status >&2 2>/dev/null || true\n 323→                echo \"\" >&2\n 324→            fi\n 325→        fi\n 326→\n 327→        echo '{\"running\": false}'\n 328→        return 1\n 329→    fi\n 330→\n 331→    local pid\n 332→    pid=$(get_pid)\n 333→\n 334→    # Gather metadata\n 335→    local log_size_kb=0\n 336→    if [[ -f \"$LOG_FILE\" ]]; then\n 337→        local log_size\n 338→        log_size=$(wc -c < \"$LOG_FILE\" 2>/dev/null | tr -d ' ')\n 339→        log_size_kb=$((log_size / 1024))\n 340→    fi\n 341→\n 342→    local started_at=\"\"\n 343→    local feature_list_path=\"\"\n 344→    if [[ -f \"$STATE_DIR/.pipeline-meta.json\" ]]; then\n 345→        started_at=$(python3 -c \"\n 346→import json, sys\n 347→with open(sys.argv[1]) as f:\n 348→    print(json.load(f).get('started_at', ''))\n 349→\" \"$STATE_DIR/.pipeline-meta.json\" 2>/dev/null || echo \"\")\n 350→        feature_list_path=$(python3 -c \"\n 351→import json, sys\n 352→with open(sys.argv[1]) as f:\n 353→    print(json.load(f).get('feature_list', ''))\n 354→\" \"$STATE_DIR/.pipeline-meta.json\" 2>/dev/null || echo \"\")\n 355→    fi\n 356→\n 357→    log_success \"Pipeline is running (PID: $pid)\"\n 358→    if [[ -n \"$started_at\" ]]; then\n 359→        log_info \"Started at: $started_at\"\n 360→    fi\n 361→    if [[ -n \"$feature_list_path\" ]]; then\n 362→        log_info \"Feature list: $feature_list_path\"\n 363→    fi\n 364→    log_info \"Log file: $LOG_FILE (${log_size_kb}KB)\"\n 365→\n 366→    # Show feature-level progress if feature list is available\n 367→    if [[ -n \"$feature_list_path\" && -f \"$feature_list_path\" ]]; then\n 368→        echo \"\" >&2\n 369→        python3 \"$SCRIPT_DIR/scripts/update-feature-status.py\" \\\n 370→            --feature-list \"$feature_list_path\" \\\n 371→            --state-dir \"$STATE_DIR\" \\\n 372→            --action status >&2 2>/dev/null || true\n 373→        echo \"\" >&2\n 374→    fi\n 375→\n 376→    # Show last few log lines\n 377→    if [[ -f \"$LOG_FILE\" ]]; then\n 378→        log_info \"--- Last 5 log lines ---\"\n 379→        tail -5 \"$LOG_FILE\" >&2 || true\n 380→        echo \"\" >&2\n 381→    fi\n 382→\n 383→    # JSON output on stdout (enhanced with progress info)\n 384→    local progress_json=\"\"\n 385→    if [[ -n \"$feature_list_path\" && -f \"$feature_list_path\" ]]; then\n 386→        progress_json=$(python3 -c \"\n 387→import json, sys, os\n 388→\n 389→def load_json(p):\n 390→    with open(p, 'r') as f:\n 391→        return json.load(f)\n 392→\n 393→feature_list_path, state_dir = sys.argv[1], sys.argv[2]\n 394→fl = load_json(feature_list_path)\n 395→features = fl.get('features', [])\n 396→total = len(features)\n 397→counts = {'completed': 0, 'in_progress': 0, 'failed': 0, 'pending': 0, 'skipped': 0}\n 398→for feat in features:\n 399→    fid = feat.get('id', '')\n 400→    sp = os.path.join(state_dir, 'features', fid, 'status.json')\n 401→    if os.path.isfile(sp):\n 402→        fs = load_json(sp)\n 403→        st = fs.get('status', 'pending')\n 404→    else:\n 405→        st = 'pending'\n 406→    if st in counts:\n 407→        counts[st] += 1\n 408→    else:\n 409→        counts['pending'] += 1\n 410→\n 411→pct = round(counts['completed'] / total * 100, 1) if total > 0 else 0\n 412→print(json.dumps({\n 413→    'total': total,\n 414→    'completed': counts['completed'],\n 415→    'in_progress': counts['in_progress'],\n 416→    'failed': counts['failed'],\n 417→    'pending': counts['pending'],\n 418→    'percent': pct\n 419→}))\n 420→\" \"$feature_list_path\" \"$STATE_DIR\" 2>/dev/null || echo \"\")\n 421→    fi\n 422→\n 423→    if [[ -n \"$progress_json\" ]]; then\n 424→        # Merge progress into the main JSON output\n 425→        cat <<EOF\n 426→{\"running\": true, \"pid\": $pid, \"log_file\": \"$LOG_FILE\", \"log_size_kb\": $log_size_kb, \"started_at\": \"$started_at\", \"feature_list\": \"$feature_list_path\", \"progress\": $progress_json}\n 427→EOF\n 428→    else\n 429→        cat <<EOF\n 430→{\"running\": true, \"pid\": $pid, \"log_file\": \"$LOG_FILE\", \"log_size_kb\": $log_size_kb, \"started_at\": \"$started_at\", \"feature_list\": \"$feature_list_path\"}\n 431→EOF\n 432→    fi\n 433→}\n 434→\n 435→# ============================================================\n 436→# logs: View or follow pipeline logs\n 437→# ============================================================\n 438→\n 439→cmd_logs() {\n 440→    local lines=50\n 441→    local follow=false\n 442→\n 443→    while [[ $# -gt 0 ]]; do\n 444→        case \"$1\" in\n 445→            --lines|-n)\n 446→                shift\n 447→                if [[ $# -eq 0 ]]; then\n 448→                    log_error \"--lines requires a number\"\n 449→                    exit 1\n 450→                fi\n 451→                lines=\"$1\"\n 452→                shift\n 453→                ;;\n 454→            --follow|-f)\n 455→                follow=true\n 456→                shift\n 457→                ;;\n 458→            *)\n 459→                log_error \"Unknown option: $1\"\n 460→                exit 1\n 461→                ;;\n 462→        esac\n 463→    done\n 464→\n 465→    if [[ ! -f \"$LOG_FILE\" ]]; then\n 466→        log_info \"No log file found at $LOG_FILE\"\n 467→        log_info \"Pipeline has not been started yet\"\n 468→        exit 0\n 469→    fi\n 470→\n 471→    if [[ \"$follow\" == true ]]; then\n 472→        log_info \"Following $LOG_FILE (Ctrl+C to stop)...\"\n 473→        echo \"\" >&2\n 474→        tail -f \"$LOG_FILE\"\n 475→    else\n 476→        tail -\"$lines\" \"$LOG_FILE\"\n 477→    fi\n 478→}\n 479→\n 480→# ============================================================\n 481→# restart: Stop + Start\n 482→# ============================================================\n 483→\n 484→cmd_restart() {\n 485→    cmd_stop 2>/dev/null || true\n 486→    sleep 1\n 487→    cmd_start \"$@\"\n 488→}\n 489→\n 490→# ============================================================\n 491→# Entry point\n 492→# ============================================================\n 493→\n 494→show_help() {\n 495→    cat <<'HELP'\n 496→Usage: launch-daemon.sh <command> [options]\n 497→\n 498→Commands:\n 499→  start [feature-list.json] [--env \"K=V ...\"]   Start pipeline in background\n 500→  stop                                            Gracefully stop pipeline\n 501→  status                                          Check if pipeline is running\n 502→  logs [--lines N] [--follow]                     View pipeline logs\n 503→  restart [feature-list.json] [--env \"K=V ...\"]  Stop + start pipeline\n 504→  help                                            Show this help\n 505→\n 506→Examples:\n 507→  ./launch-daemon.sh start                        # Start with default feature-list.json\n 508→  ./launch-daemon.sh start my-features.json       # Start with custom feature list\n 509→  ./launch-daemon.sh start --env \"MAX_RETRIES=5 SESSION_TIMEOUT=7200\"\n 510→  ./launch-daemon.sh status                       # Check if running (JSON on stdout)\n 511→  ./launch-daemon.sh logs --follow                # Live log tailing\n 512→  ./launch-daemon.sh logs --lines 100             # Last 100 lines\n 513→  ./launch-daemon.sh stop                         # Graceful shutdown\n 514→  ./launch-daemon.sh restart                      # Stop + start\n 515→\n 516→Environment Variables (pass via --env):\n 517→  MAX_RETRIES           Max retries per feature (default: 3)\n 518→  SESSION_TIMEOUT       Session timeout in seconds (default: 0 = no limit)\n 519→  VERBOSE               Set to 1 for verbose AI CLI output\n 520→  HEARTBEAT_INTERVAL    Heartbeat log interval in seconds (default: 30)\n 521→HELP\n 522→}\n 523→\n 524→case \"${1:-help}\" in\n 525→    start)\n 526→        shift\n 527→        cmd_start \"$@\"\n 528→        ;;\n 529→    stop)\n 530→        cmd_stop\n 531→        ;;\n 532→    status)\n 533→        cmd_status\n 534→        ;;\n 535→    logs|log)\n 536→        shift\n 537→        cmd_logs \"$@\"\n 538→        ;;\n 539→    restart)\n 540→        shift\n 541→        cmd_restart \"$@\"\n 542→        ;;\n 543→    help|--help|-h)\n 544→        show_help\n 545→        ;;\n 546→    *)\n 547→        log_error \"Unknown command: $1\"\n 548→        echo \"\" >&2\n 549→        show_help\n 550→        exit 1\n 551→        ;;\n 552→esac\n 553→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:48.712Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"5996ed7d-affb-4a2e-a538-5edb4752e727","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65ed50752c241124ac1053c094","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ */\n   5→\n   6→import {\n   7→  startPipeline,\n   8→  getPipelineStatus,\n   9→  stopPipeline,\n  10→  getPipelineLogs\n  11→} from '../../../services/pipeline-control-service.js';\n  12→import { formatValidationErrors, formatError, ErrorCodes } from '../formatter.js';\n  13→\n  14→/**\n  15→ * Pipeline command metadata.\n  16→ */\n  17→export const pipelineMeta = {\n  18→  name: 'pipeline',\n  19→  aliases: ['p'],\n  20→  description: '管理管道任务',\n  21→  usage: '/pipeline <action> [target] [--type=<type>]',\n  22→  examples: [\n  23→    '/pipeline run my-feature',\n  24→    '/pipeline run my-feature --type=bugfix',\n  25→    '/pipeline status',\n  26→    '/pipeline logs my-feature',\n  27→    '/pipeline stop my-feature'\n  28→  ],\n  29→  subcommands: [\n  30→    { name: 'run', description: '启动管道' },\n  31→    { name: 'status', description: '查询状态' },\n  32→    { name: 'logs', description: '查看日志' },\n  33→    { name: 'stop', description: '停止管道' }\n  34→  ],\n  35→  params: [\n  36→    {\n  37→      name: 'target',\n  38→      type: 'string',\n  39→      required: false,\n  40→      description: '目标标识符'\n  41→    },\n  42→    {\n  43→      name: 'type',\n  44→      type: 'enum',\n  45→      enum: ['feature', 'bugfix', 'planner'],\n  46→      required: false,\n  47→      default: 'feature',\n  48→      description: '管道类型'\n  49→    }\n  50→  ],\n  51→  requiresAuth: true,\n  52→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  53→};\n  54→\n  55→/**\n  56→ * Handle pipeline command.\n  57→ * @param {Object} handlerCtx - Handler context\n  58→ * @param {Object} handlerCtx.ctx - Telegraf context\n  59→ * @param {Object} handlerCtx.parsed - Parsed command\n  60→ * @param {Object} handlerCtx.params - Normalized parameters\n  61→ * @param {Function} handlerCtx.reply - Reply function\n  62→ */\n  63→export async function handlePipeline(handlerCtx) {\n  64→  const { ctx, parsed, params, reply } = handlerCtx;\n  65→\n  66→  // Determine action from subcommand or default to status\n  67→  const action = parsed.subcommand || 'status';\n  68→\n  69→  switch (action) {\n  70→    case 'run':\n  71→      return handleRun(handlerCtx);\n  72→    case 'status':\n  73→      return handleStatus(handlerCtx);\n  74→    case 'logs':\n  75→      return handleLogs(handlerCtx);\n  76→    case 'stop':\n  77→      return handleStop(handlerCtx);\n  78→    default:\n  79→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop`);\n  80→  }\n  81→}\n  82→\n  83→/**\n  84→ * Handle run subcommand.\n  85→ */\n  86→async function handleRun({ params, reply, parsed }) {\n  87→  const target = params._args?.[0] || params.target;\n  88→  const pipelineType = params.type || 'feature';\n  89→\n  90→  try {\n  91→    const result = await startPipeline({\n  92→      pipelineType,\n  93→      targetId: target\n  94→    });\n  95→\n  96→    if (result.ok) {\n  97→      await reply(`✅ 已启动 ${pipelineType} 管道${target ? `: ${target}` : ''}`);\n  98→    } else {\n  99→      await reply(`❌ 启动失败: ${result.stderr || result.error || '未知错误'}`);\n 100→    }\n 101→  } catch (error) {\n 102→    await reply(`❌ 启动失败: ${error.message}`);\n 103→  }\n 104→}\n 105→\n 106→/**\n 107→ * Handle status subcommand.\n 108→ */\n 109→async function handleStatus({ params, reply }) {\n 110→  try {\n 111→    const result = await getPipelineStatus({});\n 112→\n 113→    if (result.ok) {\n 114→      const status = formatStatusOutput(result);\n 115→      await reply(status);\n 116→    } else {\n 117→      await reply(`❌ 查询失败: ${result.stderr || result.error || '未知错误'}`);\n 118→    }\n 119→  } catch (error) {\n 120→    await reply(`❌ 查询失败: ${error.message}`);\n 121→  }\n 122→}\n 123→\n 124→/**\n 125→ * Handle logs subcommand.\n 126→ */\n 127→async function handleLogs({ params, reply, replyFile, parsed }) {\n 128→  const target = params._args?.[0] || params.target;\n 129→\n 130→  try {\n 131→    const result = await getPipelineLogs({ targetId: target });\n 132→\n 133→    if (result.ok) {\n 134→      const logs = result.stdout || result.logs || '';\n 135→\n 136→      if (logs.length >= 4000) {\n 137→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n 138→      } else {\n 139→        await reply(logs || '暂无日志');\n 140→      }\n 141→    } else {\n 142→      await reply(`❌ 获取日志失败: ${result.stderr || result.error || '未知错误'}`);\n 143→    }\n 144→  } catch (error) {\n 145→    await reply(`❌ 获取日志失败: ${error.message}`);\n 146→  }\n 147→}\n 148→\n 149→/**\n 150→ * Handle stop subcommand.\n 151→ */\n 152→async function handleStop({ params, reply, parsed }) {\n 153→  const target = params._args?.[0] || params.target;\n 154→\n 155→  try {\n 156→    const result = await stopPipeline({ targetId: target });\n 157→\n 158→    if (result.ok) {\n 159→      await reply(`✅ 已停止管道${target ? `: ${target}` : ''}`);\n 160→    } else {\n 161→      await reply(`❌ 停止失败: ${result.stderr || result.error || '未知错误'}`);\n 162→    }\n 163→  } catch (error) {\n 164→    await reply(`❌ 停止失败: ${error.message}`);\n 165→  }\n 166→}\n 167→\n 168→/**\n 169→ * Format status output.\n 170→ * @param {Object} result - Status result\n 171→ * @returns {string} Formatted status\n 172→ */\n 173→function formatStatusOutput(result) {\n 174→  if (!result.pipelines || result.pipelines.length === 0) {\n 175→    return '当前没有运行中的管道。';\n 176→  }\n 177→\n 178→  const lines = ['运行中的管道：', ''];\n 179→\n 180→  for (const p of result.pipelines) {\n 181→    lines.push(`• ${p.type || 'pipeline'}: ${p.target || 'unknown'}`);\n 182→    lines.push(`  状态: ${p.status || 'running'}`);\n 183→    if (p.startTime) {\n 184→      lines.push(`  开始: ${p.startTime}`);\n 185→    }\n 186→    lines.push('');\n 187→  }\n 188→\n 189→  return lines.join('\\n');\n 190→}\n 191→\n 192→export default handlePipeline;\n 193→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:48.721Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
{"type":"user","uuid":"6cdd87b6-7be0-44da-a4ea-6224a63af9f6","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"019cde65ef0975fe4d592aaae6812e13","content":[{"type":"text","text":"   1→export const INFRA_ERROR_CODES = Object.freeze({\n   2→  CONFIG_MISSING: 'CONFIG_MISSING',\n   3→  CONFIG_INVALID: 'CONFIG_INVALID',\n   4→  PATH_INVALID: 'PATH_INVALID',\n   5→  SCRIPT_NOT_FOUND: 'SCRIPT_NOT_FOUND',\n   6→  EXEC_TIMEOUT: 'EXEC_TIMEOUT',\n   7→  EXEC_FAILED: 'EXEC_FAILED'\n   8→});\n   9→\n  10→const ERROR_CODE_SET = new Set(Object.values(INFRA_ERROR_CODES));\n  11→\n  12→export function isInfraErrorCode(code) {\n  13→  return ERROR_CODE_SET.has(code);\n  14→}\n  15→\n  16→export function createInfraError(code, message, options = {}) {\n  17→  if (!isInfraErrorCode(code)) {\n  18→    throw new Error(`Unknown infra error code: ${code}`);\n  19→  }\n  20→\n  21→  return {\n  22→    code,\n  23→    message: String(message ?? ''),\n  24→    ...(options.hint ? { hint: String(options.hint) } : {}),\n  25→    ...(options.context ? { context: options.context } : {})\n  26→  };\n  27→}\n  28→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6577e9eae8544138813e12684b","__timestamp":"2026-03-11T19:35:48.721Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
