({\n      lockManager,\n      stateManager,\n      scriptRunner,\n      config\n    });\n\n    // Start first\n    await controller.startPipeline({ type: 'feature' });\n    assert.equal(await lockManager.isLocked('feature'), true);\n\n    // Stop\n    await controller.stopPipeline({ type: 'feature' });\n    assert.equal(await lockManager.isLocked('feature'), false);\n  } finally {\n    cleanup();\n  }\n});"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":98188,"output_tokens":648,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:53:45.381Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
