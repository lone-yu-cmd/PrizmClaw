14→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 315→  try {\n 316→    const config = createMockConfig(stateDir, bugfixStateDir);\n 317→    const manager = createStateManager({ config });\n 318→\n 319→    const result = await manager.getDaemonPid('feature');\n 320→    assert.equal(result, null);\n 321→  } finally {\n 322→    cleanup();\n 323→  }\n 324→});\n 325→\n 326→test('state operations should work for both feature and bugfix types', async () => {\n 327→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 328→  try {\n 329→    const config = createMockConfig(stateDir, bugfixStateDir);\n 330→    const manager = createStateManager({ config });\n 331→\n 332→    // Write different daemon metas\n 333→    const featureMeta = { ...createSampleDaemonMeta(), pid: 11111 };\n 334→    const bugfixMeta = { ...createSampleDaemonMeta(), pid: 22222 };\n 335→\n 336→    fs.writeFileSync(path.join(stateDir, '.pipeline-meta.json'), JSON.stringify(featureMeta));\n 337→    fs.writeFileSync(path.join(bugfixStateDir, '.pipeline-meta.json'), JSON.stringify(bugfixMeta));\n 338→\n 339→    const featurePid = await manager.getDaemonPid('feature');\n 340→    const bugfixPid = await manager.getDaemonPid('bugfix');\n 341→\n 342→    assert.equal(featurePid, 11111);\n 343→    assert.equal(bugfixPid, 22222);\n 344→  } finally {\n 345→    cleanup();\n 346→  }\n 347→});\n 348→\n 349→test('readDaemonMeta should handle corrupted JSON gracefully', async () => {\n 350→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 351→  try {\n 352→    const config = createMockConfig(stateDir, bugfixStateDir);\n 353→    const manager = createStateManager({ config });\n 354→\n 355→    // Write invalid JSON\n 356→    fs.writeFileSync(path.join(stateDir, '.pipeline-meta.json'), 'not valid json {{{');\n 357→\n 358→    const result = await manager.readDaemonMeta('feature');\n 359→    assert.equal(result, null);\n 360→  } finally {\n 361→    cleanup();\n 3