'),\n      bugFixListPath: path.join(this.tempDir, 'bug-fix-list.json')\n    };\n  }\n\n  createMockScript(name, content) {\n    const scriptPath = path.join(this.pipelineDir, name);\n    fs.writeFileSync(scriptPath, content, { mode: 0o755 });\n    return scriptPath;\n  }\n\n  writeStateFile(type, filename, content) {\n    const dir = type === 'feature' ? this.stateDir : this.bugfixStateDir;\n    fs.writeFileSync(path.join(dir, filename), JSON.stringify(content, null, 2));\n  }\n\n  readStateFile(type, filename) {\n    const dir = type === 'feature' ? this.stateDir : this.bugfixStateDir;\n    const filePath = path.join(dir, filename);\n    if (!fs.existsSync(filePath)) return null;\n    return JSON.parse(fs.readFileSync(filePath, 'utf8'));\n  }\n\n  cleanup() {\n    fs.rmSync(this.tempDir, { recursive: true, force: true });\n  }\n}\n\n// ============================================================\n// US-1: Unified Pipeline Start Integration Tests\n// ============================================================\n\ntest('US-1: Full lifecycle - startPipeline -> getStatus -> stopPipeline', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-1 lifecycle test');\n});\n\ntest('US-1: startPipeline should create daemon process', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-1 daemon start test');\n});\n\ntest('US-1: startPipeline with targetId should start from specific target', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-1 targetId test');\n});\n\n// ============================================================\n// US-2: Pipeline Stop Integration Tests\n// ============================================================\n\ntest('US-2: stopPipeline should stop running daemon', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-2 stop test');\n});\n\ntest('US-2: stopPipeline should return ALREADY_STOPPED when not running', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-2 already stopped test');\n});\n\n// ============================================================\n// US-3: Target Retry Integration Tests\n// ============================================================\n\ntest('US-3: retryTarget should execute retry script for valid target', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-3 retry test');\n});\n\ntest('US-3: retryTarget should return INVALID_TARGET for unknown target', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-3 invalid target test');\n});\n\n// ============================================================\n// US-4: Run Single Feature Integration Tests\n// ============================================================\n\ntest('US-4: runSingle should execute without lock acquisition', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-4 runSingle test');\n});\n\ntest('US-4: runSingle should return full execution details', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-4 details test');\n});\n\n// ============================================================\n// US-5: Status Query Integration Tests\n// ============================================================\n\ntest('US-5: getStatus should return comprehensive status', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-5 status test');\n});\n\ntest('US-5: getStatus should include lockInfo', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-5 lockInfo test');\n});\n\ntest('US-5: getStatus should include lastResult when not running', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-5 lastResult test');\n});\n\n// ============================================================\n// US-6: Logs Query Integration Tests\n// ============================================================\n\ntest('US-6: getLogs should return log content', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-6 logs test');\n});\n\ntest('US-6: getLogs should handle missing log file', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-6 missing file test');\n});\n\n// ============================================================\n// US-7: Concurrency Protection Integration Tests\n// ============================================================\n\ntest('US-7: Concurrent start attempts should fail with LOCK_ACQUISITION_FAILED', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-7 concurrent test');\n});\n\ntest('US-7: Lock should be released on stopPipeline', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-7 lock release test');\n});\n\ntest('US-7: forceUnlock should clear stale lock', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-7 forceUnlock test');\n});\n\n// ============================================================\n// US-8: Error Mapping Integration Tests\n// ============================================================\n\ntest('US-8: All errors should include code, message, hint, context', async () => {\n  // Placeholder test - will be updated after implementation\n  assert.ok(true, 'Placeholder for US-8 error mapping test');\n});\n\n// =========================