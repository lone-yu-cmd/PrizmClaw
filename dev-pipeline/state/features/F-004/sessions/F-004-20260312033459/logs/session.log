67→    await controller.startPipeline({ type: 'feature' });\n 268→    assert.equal(await lockManager.isLocked('feature'), true);\n 269→\n 270→    // Stop\n 271→    await controller.stopPipeline({ type: 'feature' });\n 272→    assert.equal(await lockManager.isLocked('feature'), false);\n 273→  } finally {\n 274→    cleanup();\n 275→  }\n 276→});\n 277→\n 278→test('stopPipeline should return ALREADY_STOPPED if not running', async () => {\n 279→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 280→  try {\n 281→    const config = createMockConfig(stateDir, bugfixStateDir);\n 282→    const lockManager = createLockManager({ config });\n 283→    const stateManager = createStateManager({ config });\n 284→    const scriptRunner = createMockScriptRunner();\n 285→\n 286→    const controller = createPipelineController({\n 287→      lockManager,\n 288→      stateManager,\n 289→      scriptRunner,\n 290→      config\n 291→    });\n 292→\n 293→    // Stop without starting\n 294→    const result = await controller.stopPipeline({ type: 'feature' });\n 295→    assert.equal(result.ok, true);\n 296→    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 297→  } finally {\n 298→    cleanup();\n 299→  }\n 300→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:53:29.996Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
