{"type":"user","uuid":"bb399118-ac0c-414f-b66c-3f235fe20cbc","session_id":"e8c5e130-cc78-4ab4-9f64-924bbfd756be","message":{"content":[{"type":"tool_result","tool_use_id":"call_6cf1b92684104f63a7dc9095","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→\n   4→import {\n   5→  INFRA_ERROR_CODES,\n   6→  createInfraError,\n   7→  isInfraErrorCode\n   8→} from '../../src/pipeline-infra/error-codes.js';\n   9→\n  10→test('INFRA_ERROR_CODES should include required categories', () => {\n  11→  // Existing codes\n  12→  assert.equal(INFRA_ERROR_CODES.CONFIG_MISSING, 'CONFIG_MISSING');\n  13→  assert.equal(INFRA_ERROR_CODES.CONFIG_INVALID, 'CONFIG_INVALID');\n  14→  assert.equal(INFRA_ERROR_CODES.PATH_INVALID, 'PATH_INVALID');\n  15→  assert.equal(INFRA_ERROR_CODES.SCRIPT_NOT_FOUND, 'SCRIPT_NOT_FOUND');\n  16→  assert.equal(INFRA_ERROR_CODES.EXEC_TIMEOUT, 'EXEC_TIMEOUT');\n  17→  assert.equal(INFRA_ERROR_CODES.EXEC_FAILED, 'EXEC_FAILED');\n  18→\n  19→  // F-004: Pipeline Process Controller codes\n  20→  assert.equal(INFRA_ERROR_CODES.LOCK_ACQUISITION_FAILED, 'LOCK_ACQUISITION_FAILED');\n  21→  assert.equal(INFRA_ERROR_CODES.ALREADY_STOPPED, 'ALREADY_STOPPED');\n  22→  assert.equal(INFRA_ERROR_CODES.PIPELINE_NOT_RUNNING, 'PIPELINE_NOT_RUNNING');\n  23→  assert.equal(INFRA_ERROR_CODES.INVALID_TARGET, 'INVALID_TARGET');\n  24→  assert.equal(INFRA_ERROR_CODES.TARGET_NOT_RETRYABLE, 'TARGET_NOT_RETRYABLE');\n  25→  assert.equal(INFRA_ERROR_CODES.DAEMON_START_FAILED, 'DAEMON_START_FAILED');\n  26→});\n  27→\n  28→test('isInfraErrorCode should validate known error code values', () => {\n  29→  assert.equal(isInfraErrorCode('CONFIG_MISSING'), true);\n  30→  assert.equal(isInfraErrorCode('NOT_REAL'), false);\n  31→\n  32→  // F-004 new codes\n  33→  assert.equal(isInfraErrorCode('LOCK_ACQUISITION_FAILED'), true);\n  34→  assert.equal(isInfraErrorCode('ALREADY_STOPPED'), true);\n  35→  assert.equal(isInfraErrorCode('PIPELINE_NOT_RUNNING'), true);\n  36→  assert.equal(isInfraErrorCode('INVALID_TARGET'), true);\n  37→  assert.equal(isInfraErrorCode('TARGET_NOT_RETRYABLE'), true);\n  38→  assert.equal(isInfraErrorCode('DAEMON_START_FAILED'), true);\n  39→});\n  40→\n  41→test('createInfraError should produce serializable error objects', () => {\n  42→  const err = createInfraError('CONFIG_MISSING', 'Missing env var', {\n  43→    hint: 'Set MY_ENV in .env',\n  44→    context: { field: 'MY_ENV' }\n  45→  });\n  46→\n  47→  assert.deepEqual(err, {\n  48→    code: 'CONFIG_MISSING',\n  49→    message: 'Missing env var',\n  50→    hint: 'Set MY_ENV in .env',\n  51→    context: { field: 'MY_ENV' }\n  52→  });\n  53→\n  54→  assert.doesNotThrow(() => JSON.stringify(err));\n  55→});\n  56→\n  57→test('createInfraError should reject unknown error codes', () => {\n  58→  assert.throws(() => {\n  59→    createInfraError('UNKNOWN', 'oops');\n  60→  }, /Unknown infra error code/i);\n  61→});\n  62→\n  63→// F-004: Test new error codes with createInfraError\n  64→test('createInfraError should accept F-004 error codes', () => {\n  65→  const lockError = createInfraError('LOCK_ACQUISITION_FAILED', 'Pipeline already running', {\n  66→    hint: 'Stop the current pipeline first',\n  67→    context: { currentPid: 12345 }\n  68→  });\n  69→\n  70→  assert.equal(lockError.code, 'LOCK_ACQUISITION_FAILED');\n  71→  assert.equal(lockError.message, 'Pipeline already running');\n  72→  assert.equal(lockError.hint, 'Stop the current pipeline first');\n  73→  assert.deepEqual(lockError.context, { currentPid: 12345 });\n  74→  assert.doesNotThrow(() => JSON.stringify(lockError));\n  75→});\n  76→\n  77→test('createInfraError should create ALREADY_STOPPED error', () => {\n  78→  const err = createInfraError('ALREADY_STOPPED', 'Pipeline is not running');\n  79→  assert.equal(err.code, 'ALREADY_STOPPED');\n  80→  assert.equal(err.message, 'Pipeline is not running');\n  81→});\n  82→\n  83→test('createInfraError should create INVALID_TARGET error with hint', () => {\n  84→  const err = createInfraError('INVALID_TARGET', 'Target not found', {\n  85→    hint: 'Check the target ID in the feature list',\n  86→    context: { targetId: 'F-999' }\n  87→  });\n  88→  assert.equal(err.code, 'INVALID_TARGET');\n  89→  assert.equal(err.hint, 'Check the target ID in the feature list');\n  90→  assert.deepEqual(err.context, { targetId: 'F-999' });\n  91→});\n  92→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde6da49815e71514cd1d7dc7d1dd","__timestamp":"2026-03-11T19:44:48.076Z","_requestId":"e21d0cf101524861bfec5442101833c9"}
