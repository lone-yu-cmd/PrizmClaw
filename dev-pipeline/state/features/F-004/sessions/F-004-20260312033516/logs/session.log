  }\n 363→});\n 364→\n 365→test('readLogs should return log content', async () => {\n 366→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 367→  try {\n 368→    const config = createMockConfig(stateDir, bugfixStateDir);\n 369→    const manager = createStateManager({ config });\n 370→\n 371→    // Write log file\n 372→    const logContent = 'Line 1\\nLine 2\\nLine 3\\n';\n 373→    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), logContent);\n 374→\n 375→    const result = await manager.readLogs('feature', 10);\n 376→    assert.ok(result.logs.includes('Line 1'));\n 377→    assert.ok(result.logs.includes('Line 2'));\n 378→    assert.ok(result.logs.includes('Line 3'));\n 379→    assert.ok(result.logPath.endsWith('pipeline-daemon.log'));\n 380→  } finally {\n 381→    cleanup();\n 382→  }\n 383→});\n 384→\n 385→test('readLogs should limit lines', async () => {\n 386→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 387→  try {\n 388→    const config = createMockConfig(stateDir, bugfixStateDir);\n 389→    const manager = createStateManager({ config });\n 390→\n 391→    // Write log file with many lines\n 392→    const lines = [];\n 393→    for (let i = 1; i <= 200; i++) {\n 394→      lines.push(`Line ${i}`);\n 395→    }\n 396→    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), lines.join('\\n'));\n 397→\n 398→    const result = await manager.readLogs('feature', 50);\n 399→    const resultLines = result.logs.split('\\n').filter(l => l.trim());\n 400→    assert.ok(resultLines.length <= 50);\n 401→    assert.ok(result.logs.includes('Line 200')); // Should include last line\n 402→  } finally {\n 403→    cleanup();\n 404→  }\n 405→});\n 406→\n 407→test('readLogs should handle missing log file gracefully', async () => {\n 408→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 409→  try {\n 410→    const config = createMockConfig(stateDir, bugfixStateDir);\n 411→    const manager = createStateManager({ config });\n 412→\n 413→    const result = await manager.readLogs('feature');\n 414→    assert.equal(result.logs, '');\n 415→    assert.equal(result.lines, 0);\n 416→  } finally {\n 417→    cleanup();\n 418→  }\n 419→});\n 420→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_8e7f968efcfb4733ba37e0dc","__timestamp":"2026-03-11T19:57:58.543Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
{"type":"user","uuid":"66cea164-c5c0-40b7-acb5-f62e5a2e2463","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_84428db0598a4a84984e8ccd","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Controller Unit Tests\n   3→ * Tests for src/services/pipeline-controller.js\n   4→ *\n   5→ * F-004: Pipeline Process Controller - All User Stories\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createPipelineController } from '../../src/services/pipeline-controller.js';\n  15→import { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n  16→import { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  17→\n  18→/**\n  19→ * Helper to create temp directory for test state\n  20→ */\n  21→function createTempStateDir() {\n  22→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'pipeline-controller-test-'));\n  23→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  24→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  25→  fs.mkdirSync(stateDir, { recursive: true });\n  26→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  27→  return {\n  28→    tempDir,\n  29→    stateDir,\n  30→    bugfixStateDir,\n  31→    cleanup: () => {\n  32→      fs.rmSync(tempDir, { recursive: true, force: true });\n  33→    }\n  34→  };\n  35→}\n  36→\n  37→/**\n  38→ * Helper to create a mock config\n  39→ */\n  40→function createMockConfig(stateDir, bugfixStateDir) {\n  41→  const projectRoot = path.dirname(path.dirname(stateDir));\n  42→  return {\n  43→    projectRoot,\n  44→    stateDir,\n  45→    bugfixStateDir\n  46→  };\n  47→}\n  48→\n  49→/**\n  50→ * Helper to create a mock script runner\n  51→ */\n  52→function createMockScriptRunner() {\n  53→  return async (req) => ({\n  54→    ok: true,\n  55→    exitCode: 0,\n  56→    stdout: 'Mock output',\n  57→    stderr: '',\n  58→    normalizedStatus: 'success'\n  59→  });\n  60→}\n  61→\n  62→// ============================================================\n  63→// Factory Tests\n  64→// ============================================================\n  65→\n  66→test('createPipelineController should be a factory function', () => {\n  67→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  68→  try {\n  69→    const config = createMockConfig(stateDir, bugfixStateDir);\n  70→    const controller = createPipelineController({\n  71→      config,\n  72→      lockManager: createLockManager({ config }),\n  73→      stateManager: createStateManager({ config }),\n  74→      scriptRunner: createMockScriptRunner()\n  75→    });\n  76→\n  77→    assert.equal(typeof controller.startPipeline, 'function');\n  78→    assert.equal(typeof controller.stopPipeline, 'function');\n  79→    assert.equal(typeof controller.retryTarget, 'function');\n  80→    assert.equal(typeof controller.runSingle, 'function');\n  81→    assert.equal(typeof controller.getStatus, 'function');\n  82→    assert.equal(typeof controller.getLogs, 'function');\n  83→    assert.equal(typeof controller.forceUnlock, 'function');\n  84→    assert.equal(typeof controller._acquireLock, 'function');\n  85→    assert.equal(typeof controller._releaseLock, 'function');\n  86→  } finally {\n  87→    cleanup();\n  88→  }\n  89→});\n  90→\n  91→test('createPipelineController should accept dependency injection', () => {\n  92→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  93→  try {\n  94→    const config = createMockConfig(stateDir, bugfixStateDir);\n  95→    const lockManager = createLockManager({ config });\n  96→    const stateManager = createStateManager({ config });\n  97→    const scriptRunner = createMockScriptRunner();\n  98→\n  99→    const controller = createPipelineController({\n 100→      lockManager,\n 101→      stateManager,\n 102→      scriptRunner,\n 103→      config\n 104→    });\n 105→\n 106→    assert.ok(controller);\n 107→  } finally {\n 108→    cleanup();\n 109→  }\n 110→});\n 111→\n 112→// ============================================================\n 113→// US-1: startPipeline Tests\n 114→// ============================================================\n 115→\n 116→test('startPipeline should acquire lock before starting daemon', async () => {\n 117→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 118→  try {\n 119→    const config = createMockConfig(stateDir, bugfixStateDir);\n 120→    const lockManager = createLockManager({ config });\n 121→    const stateManager = createStateManager({ config });\n 122→    const scriptRunner = createMockScriptRunner();\n 123→\n 124→    const controller = createPipelineController({\n 125→      lockManager,\n 126→      stateManager,\n 127→      scriptRunner,\n 128→      config\n 129→    });\n 130→\n 131→    const result = await controller.startPipeline({ type: 'feature' });\n 132→    assert.equal(result.ok, true);\n 133→\n 134→    // Lock should be held\n 135→    const isLocked = await lockManager.isLocked('feature');\n 136→    assert.equal(isLocked, true);\n 137→  } finally {\n 138→    cleanup();\n 139→  }\n 140→});\n 141→\n 142→test('startPipeline should handle LOCK_ACQUISITION_FAILED error', async () => {\n 143→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 144→  try {\n 145→    const config = createMockConfig(stateDir, bugfixStateDir);\n 146→    const lockManager = createLockManager({ config });\n 147→    const stateManager = createStateManager({ config });\n 148→    const scriptRunner = createMockScriptRunner();\n 149→\n 150→    const controller = createPipelineController({\n 151→      lockManager,\n 152→      stateManager,\n 153→      scriptRunner,\n 154→      config\n 155→    });\n 156→\n 157→    // Acquire lock first\n 158→    await lockManager.acquireLock('feature', process.pid);\n 159→\n 160→    // Try to start again\n 161→    const result = await controller.startPipeline({ type: 'feature' });\n 162→    assert.equal(result.ok, false);\n 163→    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n 164→    assert.ok(result.hint);\n 165→    assert.ok(result.context);\n 166→  } finally {\n 167→    cleanup();\n 168→  }\n 169→});\n 170→\n 171→test('startPipeline should support daemon mode (default)', async () => {\n 172→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 173→  try {\n 174→    const config = createMockConfig(stateDir, bugfixStateDir);\n 175→    const lockManager = createLockManager({ config });\n 176→    const stateManager = createStateManager({ config });\n 177→    const scriptRunner = createMockScriptRunner();\n 178→\n 179→    const controller = createPipelineController({\n 180→      lockManager,\n 181→      stateManager,\n 182→      scriptRunner,\n 183→      config\n 184→    });\n 185→\n 186→    const result = await controller.startPipeline({ type: 'feature' });\n 187→    assert.equal(result.ok, true);\n 188→    assert.ok(result.runId);\n 189→  } finally {\n 190→    cleanup();\n 191→  }\n 192→});\n 193→\n 194→test('startPipeline should support targetId parameter', async () => {\n 195→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 196→  try {\n 197→    const config = createMockConfig(stateDir, bugfixStateDir);\n 198→    const lockManager = createLockManager({ config });\n 199→    const stateManager = createStateManager({ config });\n 200→\n 201→    let capturedTargetId = null;\n 202→    const scriptRunner = async (req) => {\n 203→      capturedTargetId = req.targetId;\n 204→      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n 205→    };\n 206→\n 207→    const controller = createPipelineController({\n 208→      lockManager,\n 209→      stateManager,\n 210→      scriptRunner,\n 211→      config\n 212→    });\n 213→\n 214→    const result = await controller.startPipeline({ type: 'feature', targetId: 'F-001' });\n 215→    assert.equal(result.ok, true);\n 216→    assert.equal(capturedTargetId, 'F-001');\n 217→  } finally {\n 218→    cleanup();\n 219→  }\n 220→});\n 221→\n 222→test('startPipeline should work for both feature and bugfix types', async () => {\n 223→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 224→  try {\n 225→    const config = createMockConfig(stateDir, bugfixStateDir);\n 226→    const lockManager = createLockManager({ config });\n 227→    const stateManager = createStateManager({ config });\n 228→    const scriptRunner = createMockScriptRunner();\n 229→\n 230→    const controller = createPipelineController({\n 231→      lockManager,\n 232→      stateManager,\n 233→      scriptRunner,\n 234→      config\n 235→    });\n 236→\n 237→    const featureResult = await controller.startPipeline({ type: 'feature' });\n 238→    assert.equal(featureResult.ok, true);\n 239→\n 240→    const bugfixResult = await controller.startPipeline({ type: 'bugfix' });\n 241→    assert.equal(bugfixResult.ok, true);\n 242→  } finally {\n 243→    cleanup();\n 244→  }\n 245→});\n 246→\n 247→// ============================================================\n 248→// US-2: stopPipeline Tests\n 249→// ============================================================\n 250→\n 251→test('stopPipeline should release lock after stop', async () => {\n 252→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 253→  try {\n 254→    const config = createMockConfig(stateDir, bugfixStateDir);\n 255→    const lockManager = createLockManager({ config });\n 256→    const stateManager = createStateManager({ config });\n 257→    const scriptRunner = createMockScriptRunner();\n 258→\n 259→    const controller = createPipelineController({\n 260→      lockManager,\n 261→      stateManager,\n 262→      scriptRunner,\n 263→      config\n 264→    });\n 265→\n 266→    // Start first (this acquires the lock)\n 267→    await controller.startPipeline({ type: 'feature' });\n 268→    assert.equal(await lockManager.isLocked('feature'), true);\n 269→\n 270→    // Write daemon meta to simulate running daemon\n 271→    await stateManager.writeDaemonMeta('feature', {\n 272→      pid: process.pid,\n 273→      started_at: new Date().toISOString(),\n 274→      feature_list: '/path/to/list.json',\n 275→      env_overrides: '',\n 276→      log_file: '/path/to/log'\n 277→    });\n 278→\n 279→    // Stop\n 280→    const result = await controller.stopPipeline({ type: 'feature' });\n 281→    assert.equal(result.ok, true);\n 282→    assert.equal(await lockManager.isLocked('feature'), false);\n 283→  } finally {\n 284→    cleanup();\n 285→  }\n 286→});\n 287→\n 288→test('stopPipeline should return ALREADY_STOPPED if not running', async () => {\n 289→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 290→  try {\n 291→    const config = createMockConfig(stateDir, bugfixStateDir);\n 292→    const lockManager = createLockManager({ config });\n 293→    const stateManager = createStateManager({ config });\n 294→    const scriptRunner = createMockScriptRunner();\n 295→\n 296→    const controller = createPipelineController({\n 297→      lockManager,\n 298→      stateManager,\n 299→      scriptRunner,\n 300→      config\n 301→    });\n 302→\n 303→    // Stop without starting\n 304→    const result = await controller.stopPipeline({ type: 'feature' });\n 305→    assert.equal(result.ok, true);\n 306→    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 307→  } finally {\n 308→    cleanup();\n 309→  }\n 310→});\n 311→\n 312→// ============================================================\n 313→// US-3: retryTarget Tests\n 314→// ============================================================\n 315→\n 316→test('retryTarget should validate targetId is provided', async () => {\n 317→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 318→  try {\n 319→    const config = createMockConfig(stateDir, bugfixStateDir);\n 320→    const lockManager = createLockManager({ config });\n 321→    const stateManager = createStateManager({ config });\n 322→    const scriptRunner = createMockScriptRunner();\n 323→\n 324→    const controller = createPipelineController({\n 325→      lockManager,\n 326→      stateManager,\n 327→      scriptRunner,\n 328→      config\n 329→    });\n 330→\n 331→    const result = await controller.retryTarget({ type: 'feature' });\n 332→    assert.equal(result.ok, false);\n 333→    assert.equal(result.errorCode, 'INVALID_TARGET');\n 334→    assert.ok(result.hint);\n 335→  } finally {\n 336→    cleanup();\n 337→  }\n 338→});\n 339→\n 340→test('retryTarget should support foreground mode (default)', async () => {\n 341→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 342→  try {\n 343→    const config = createMockConfig(stateDir, bugfixStateDir);\n 344→    const lockManager = createLockManager({ config });\n 345→    const stateManager = createStateManager({ config });\n 346→    const scriptRunner = createMockScriptRunner();\n 347→\n 348→    const controller = createPipelineController({\n 349→      lockManager,\n 350→      stateManager,\n 351→      scriptRunner,\n 352→      config\n 353→    });\n 354→\n 355→    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n 356→    assert.equal(result.ok, true);\n 357→    assert.equal(result.targetId, 'F-001');\n 358→\n 359→    // Should not hold lock (foreground mode)\n 360→    assert.equal(await lockManager.isLocked('feature'), false);\n 361→  } finally {\n 362→    cleanup();\n 363→  }\n 364→});\n 365→\n 366→// ============================================================\n 367→// US-4: runSingle Tests\n 368→// ============================================================\n 369→\n 370→test('runSingle should NOT acquire lock', async () => {\n 371→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 372→  try {\n 373→    const config = createMockConfig(stateDir, bugfixStateDir);\n 374→    const lockManager = createLockManager({ config });\n 375→    const stateManager = createStateManager({ config });\n 376→    const scriptRunner = createMockScriptRunner();\n 377→\n 378→    const controller = createPipelineController({\n 379→      lockManager,\n 380→      stateManager,\n 381→      scriptRunner,\n 382→      config\n 383→    });\n 384→\n 385→    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 386→    assert.equal(result.ok, true);\n 387→\n 388→    // Should not hold lock\n 389→    assert.equal(await lockManager.isLocked('feature'), false);\n 390→  } finally {\n 391→    cleanup();\n 392→  }\n 393→});\n 394→\n 395→test('runSingle should return full execution details', async () => {\n 396→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 397→  try {\n 398→    const config = createMockConfig(stateDir, bugfixStateDir);\n 399→    const lockManager = createLockManager({ config });\n 400→    const stateManager = createStateManager({ config });\n 401→\n 402→    const scriptRunner = async () => ({\n 403→      ok: true,\n 404→      exitCode: 0,\n 405→      stdout: 'Test stdout',\n 406→      stderr: 'Test stderr',\n 407→      normalizedStatus: 'success'\n 408→    });\n 409→\n 410→    const controller = createPipelineController({\n 411→      lockManager,\n 412→      stateManager,\n 413→      scriptRunner,\n 414→      config\n 415→    });\n 416→\n 417→    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 418→    assert.equal(result.ok, true);\n 419→    assert.equal(result.targetId, 'F-001');\n 420→    assert.equal(result.stdout, 'Test stdout');\n 421→    assert.equal(result.stderr, 'Test stderr');\n 422→    assert.equal(result.exitCode, 0);\n 423→  } finally {\n 424→    cleanup();\n 425→  }\n 426→});\n 427→\n 428→test('runSingle should validate targetId', async () => {\n 429→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 430→  try {\n 431→    const config = createMockConfig(stateDir, bugfixStateDir);\n 432→    const lockManager = createLockManager({ config });\n 433→    const stateManager = createStateManager({ config });\n 434→    const scriptRunner = createMockScriptRunner();\n 435→\n 436→    const controller = createPipelineController({\n 437→      lockManager,\n 438→      stateManager,\n 439→      scriptRunner,\n 440→      config\n 441→    });\n 442→\n 443→    const result = await controller.runSingle({ type: 'feature' });\n 444→    assert.equal(result.ok, false);\n 445→    assert.equal(result.errorCode, 'INVALID_TARGET');\n 446→  } finally {\n 447→    cleanup();\n 448→  }\n 449→});\n 450→\n 451→// ============================================================\n 452→// US-5: getStatus Tests\n 453→// ============================================================\n 454→\n 455→test('getStatus should return isRunning boolean', async () => {\n 456→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 457→  try {\n 458→    const config = createMockConfig(stateDir, bugfixStateDir);\n 459→    const lockManager = createLockManager({ config });\n 460→    const stateManager = createStateManager({ config });\n 461→    const scriptRunner = createMockScriptRunner();\n 462→\n 463→    const controller = createPipelineController({\n 464→      lockManager,\n 465→      stateManager,\n 466→      scriptRunner,\n 467→      config\n 468→    });\n 469→\n 470→    const result = await controller.getStatus({ type: 'feature' });\n 471→    assert.equal(result.ok, true);\n 472→    assert.equal(typeof result.isRunning, 'boolean');\n 473→  } finally {\n 474→    cleanup();\n 475→  }\n 476→});\n 477→\n 478→test('getStatus should return lastResult when not running', async () => {\n 479→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 480→  try {\n 481→    const config = createMockConfig(stateDir, bugfixStateDir);\n 482→    const lockManager = createLockManager({ config });\n 483→    const stateManager = createStateManager({ config });\n 484→    const scriptRunner = createMockScriptRunner();\n 485→\n 486→    // Write last result\n 487→    const lastResult = {\n 488→      runId: 'run-test',\n 489→      completedAt: new Date().toISOString(),\n 490→      status: 'success',\n 491→      featuresTotal: 8,\n 492→      featuresCompleted: 8\n 493→    };\n 494→    await stateManager.writeLastResult('feature', lastResult);\n 495→\n 496→    const controller = createPipelineController({\n 497→      lockManager,\n 498→      stateManager,\n 499→      scriptRunner,\n 500→      config\n 501→    });\n 502→\n 503→    const result = await controller.getStatus({ type: 'feature' });\n 504→    assert.equal(result.ok, true);\n 505→    assert.deepEqual(result.lastResult, lastResult);\n 506→  } finally {\n 507→    cleanup();\n 508→  }\n 509→});\n 510→\n 511→test('getStatus should return lockInfo', async () => {\n 512→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 513→  try {\n 514→    const config = createMockConfig(stateDir, bugfixStateDir);\n 515→    const lockManager = createLockManager({ config });\n 516→    const stateManager = createStateManager({ config });\n 517→    const scriptRunner = createMockScriptRunner();\n 518→\n 519→    // Acquire lock\n 520→    await lockManager.acquireLock('feature', 12345);\n 521→\n 522→    const controller = createPipelineController({\n 523→      lockManager,\n 524→      stateManager,\n 525→      scriptRunner,\n 526→      config\n 527→    });\n 528→\n 529→    const result = await controller.getStatus({ type: 'feature' });\n 530→    assert.equal(result.ok, true);\n 531→    assert.ok(result.lockInfo);\n 532→    assert.equal(result.lockInfo.pid, 12345);\n 533→  } finally {\n 534→    cleanup();\n 535→  }\n 536→});\n 537→\n 538→// ============================================================\n 539→// US-6: getLogs Tests\n 540→// ============================================================\n 541→\n 542→test('getLogs should return log content', async () => {\n 543→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 544→  try {\n 545→    const config = createMockConfig(stateDir, bugfixStateDir);\n 546→    const lockManager = createLockManager({ config });\n 547→    const stateManager = createStateManager({ config });\n 548→    const scriptRunner = createMockScriptRunner();\n 549→\n 550→    // Write log file\n 551→    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), 'Line 1\\nLine 2\\nLine 3');\n 552→\n 553→    const controller = createPipelineController({\n 554→      lockManager,\n 555→      stateManager,\n 556→      scriptRunner,\n 557→      config\n 558→    });\n 559→\n 560→    const result = await controller.getLogs({ type: 'feature', lines: 10 });\n 561→    assert.equal(result.ok, true);\n 562→    assert.ok(result.logs);\n 563→    assert.ok(result.logPath);\n 564→    assert.ok(result.lines);\n 565→  } finally {\n 566→    cleanup();\n 567→  }\n 568→});\n 569→\n 570→test('getLogs should handle missing log file gracefully', async () => {\n 571→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 572→  try {\n 573→    const config = createMockConfig(stateDir, bugfixStateDir);\n 574→    const lockManager = createLockManager({ config });\n 575→    const stateManager = createStateManager({ config });\n 576→    const scriptRunner = createMockScriptRunner();\n 577→\n 578→    const controller = createPipelineController({\n 579→      lockManager,\n 580→      stateManager,\n 581→      scriptRunner,\n 582→      config\n 583→    });\n 584→\n 585→    const result = await controller.getLogs({ type: 'feature' });\n 586→    assert.equal(result.ok, true);\n 587→    assert.equal(result.logs, '');\n 588→  } finally {\n 589→    cleanup();\n 590→  }\n 591→});\n 592→\n 593→// ============================================================\n 594→// US-7: forceUnlock Tests\n 595→// ============================================================\n 596→\n 597→test('forceUnlock should remove lock regardless of owner', async () => {\n 598→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 599→  try {\n 600→    const config = createMockConfig(stateDir, bugfixStateDir);\n 601→    const lockManager = createLockManager({ config });\n 602→    const stateManager = createStateManager({ config });\n 603→    const scriptRunner = createMockScriptRunner();\n 604→\n 605→    // Create a lock with a different PID\n 606→    await lockManager.acquireLock('feature', 99999);\n 607→\n 608→    const controller = createPipelineController({\n 609→      lockManager,\n 610→      stateManager,\n 611→      scriptRunner,\n 612→      config\n 613→    });\n 614→\n 615→    const result = await controller.forceUnlock({ type: 'feature' });\n 616→    assert.equal(result.ok, true);\n 617→    assert.equal(result.previousPid, 99999);\n 618→\n 619→    // Lock should be released\n 620→    assert.equal(await lockManager.isLocked('feature'), false);\n 621→  } finally {\n 622→    cleanup();\n 623→  }\n 624→});\n 625→\n 626→// ============================================================\n 627→// US-8: Error Mapping Tests\n 628→// ============================================================\n 629→\n 630→test('all methods should return JSON-serializable results', async () => {\n 631→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 632→  try {\n 633→    const config = createMockConfig(stateDir, bugfixStateDir);\n 634→    const lockManager = createLockManager({ config });\n 635→    const stateManager = createStateManager({ config });\n 636→    const scriptRunner = createMockScriptRunner();\n 637→\n 638→    const controller = createPipelineController({\n 639→      lockManager,\n 640→      stateManager,\n 641→      scriptRunner,\n 642→      config\n 643→    });\n 644→\n 645→    const results = await Promise.all([\n 646→      controller.startPipeline({ 