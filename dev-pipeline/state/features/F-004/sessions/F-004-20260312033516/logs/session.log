{"type":"assistant","uuid":"2026031203441921c6edf492b64f33","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"id":"2026031203441921c6edf492b64f33","content":[{"type":"tool_use","id":"call_09725f3ffefd42c8acddf963","name":"Write","input":{"content":"import test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nimport { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n\nconst PIPELINE_TYPES = ['feature', 'bugfix'];\n\nasync function withTempDir(fn) {\n  const tempDir = await fs.promises.mkdtemp(path.join(os.tmpdir(), 'lock-manager-test-'));\n  try {\n    await fn(tempDir);\n  } finally {\n    await fs.promises.rm(tempDir, { recursive: true, force: true });\n  }\n}\n\nfunction createMockConfig(tempDir) {\n  return {\n    stateDir: path.join(tempDir, 'state'),\n    bugfixStateDir: path.join(tempDir, 'bugfix-state')\n  };\n}\n\ntest('createLockManager should return lock manager interface', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    assert.equal(typeof manager.acquireLock, 'function');\n    assert.equal(typeof manager.releaseLock, 'function');\n    assert.equal(typeof manager.isLocked, 'function');\n    assert.equal(typeof manager.validateLock, 'function');\n    assert.equal(typeof manager.forceUnlock, 'function');\n    assert.equal(typeof manager.getLockInfo, 'function');\n  });\n});\n\n// T-018: Tests for acquireLock/releaseLock\ntest('acquireLock should create lock file atomically', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const result = await manager.acquireLock('feature');\n\n    assert.equal(result.ok, true);\n    assert.ok(result.lockPath);\n    assert.ok(fs.existsSync(result.lockPath));\n  });\n});\n\ntest('acquireLock should fail when lock already held', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    await manager.acquireLock('feature');\n    const result = await manager.acquireLock('feature');\n\n    assert.equal(result.ok, false);\n    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n    assert.ok(result.currentHolder);\n  });\n});\n\ntest('acquireLock should allow different pipeline types independently', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const featureResult = await manager.acquireLock('feature');\n    const bugfixResult = await manager.acquireLock('bugfix');\n\n    assert.equal(featureResult.ok, true);\n    assert.equal(bugfixResult.ok, true);\n  });\n});\n\ntest('releaseLock should remove lock file', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const { lockPath } = await manager.acquireLock('feature');\n    await manager.releaseLock('feature');\n\n    assert.ok(!fs.existsSync(lockPath));\n  });\n});\n\ntest('releaseLock should be idempotent', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    await manager.acquireLock('feature');\n    await manager.releaseLock('feature');\n    // Should not throw\n    await manager.releaseLock('feature');\n  });\n});\n\n// T-019: Tests for isLocked/validateLock\ntest('isLocked should return true when lock exists', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    assert.equal(await manager.isLocked('feature'), false);\n\n    await manager.acquireLock('feature');\n    assert.equal(await manager.isLocked('feature'), true);\n  });\n});\n\ntest('validateLock should return false when lock file missing', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const result = await manager.validateLock('feature');\n    assert.equal(result.valid, false);\n  });\n});\n\ntest('validateLock should return false when PID is dead', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    // Acquire with a fake PID that definitely doesn't exist\n    await manager.acquireLock('feature', 99999999);\n\n    const result = await manager.validateLock('feature');\n    assert.equal(result.valid, false);\n    assert.equal(result.stale, true);\n  });\n});\n\ntest('validateLock should return true when PID is alive', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    await manager.acquireLock('feature', process.pid);\n\n    const result = await manager.validateLock('feature');\n    assert.equal(result.valid, true);\n  });\n});\n\n// T-020: Tests for forceUnlock/getLockInfo\ntest('forceUnlock should remove lock and return previous holder info', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    await manager.acquireLock('feature');\n    const result = await manager.forceUnlock('feature');\n\n    assert.equal(result.ok, true);\n    assert.ok(result.previousPid);\n    assert.equal(await manager.isLocked('feature'), false);\n  });\n});\n\ntest('forceUnlock should work even when no lock exists', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const result = await manager.forceUnlock('feature');\n\n    assert.equal(result.ok, true);\n    assert.equal(result.previousPid, undefined);\n  });\n});\n\ntest('getLockInfo should return lock metadata', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    await manager.acquireLock('feature', 12345);\n    const info = await manager.getLockInfo('feature');\n\n    assert.equal(info.pid, 12345);\n    assert.ok(info.acquiredAt);\n    assert.equal(info.type, 'feature');\n  });\n});\n\ntest('getLockInfo should return null when no lock', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const info = await manager.getLockInfo('feature');\n    assert.equal(info, null);\n  });\n});\n\n// T-017: Stale lock cleanup\ntest('acquireLock should auto-cleanup stale locks', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    // Create lock with dead PID\n    await manager.acquireLock('feature', 99999999);\n\n    // Should successfully acquire because stale lock is cleaned up\n    const result = await manager.acquireLock('feature', process.pid);\n    assert.equal(result.ok, true);\n  });\n});\n\ntest('acquireLock should respect lock held by live process', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    // Create lock with current process PID (live)\n    await manager.acquireLock('feature', process.pid);\n\n    // Should fail because process is alive\n    const result = await manager.acquireLock('feature', 12345);\n    assert.equal(result.ok, false);\n    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n  });\n});\n\n// Edge cases\ntest('acquireLock should handle bugfix type', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const result = await manager.acquireLock('bugfix');\n    assert.equal(result.ok, true);\n\n    const info = await manager.getLockInfo('bugfix');\n    assert.equal(info.type, 'bugfix');\n  });\n});\n\ntest('lock files should be JSON serializable', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createLockManager({ config });\n\n    const { lockPath } = await manager.acquireLock('feature');\n    const content = await fs.promises.readFile(lockPath, 'utf8');\n\n    // Should be valid JSON\n    const lockData = JSON.parse(content);\n    assert.ok(lockData.pid);\n    assert.ok(lockData.acquiredAt);\n    assert.ok(lockData.type);\n  });\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/pipeline-infra/lock-manager.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":44601,"output_tokens":1994,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:44:47.340Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
