{"type":"user","uuid":"2945dd92-0cf5-48f2-ac82-ef37dde035cc","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_6fee290ff6b441c09bcfd819","content":[{"type":"text","text":"   1→import test from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import fs from 'node:fs';\n   4→import path from 'node:path';\n   5→import os from 'node:os';\n   6→\n   7→import { createPipelineController } from '../../src/services/pipeline-controller.js';\n   8→import { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n   9→import { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  10→import { loadPipelineInfraConfig } from '../../src/pipeline-infra/config-loader.js';\n  11→\n  12→async function withTempDir(fn) {\n  13→  const tempDir = await fs.promises.mkdtemp(path.join(os.tmpdir(), 'f004-integration-test-'));\n  14→  try {\n  15→    await fn(tempDir);\n  16→  } finally {\n  17→    await fs.promises.rm(tempDir, { recursive: true, force: true });\n  18→  }\n  19→}\n  20→\n  21→function createTestConfig(tempDir) {\n  22→  return {\n  23→    stateDir: path.join(tempDir, 'state'),\n  24→    bugfixStateDir: path.join(tempDir, 'bugfix-state'),\n  25→    pipelineDir: path.join(tempDir, 'dev-pipeline'),\n  26→    projectRoot: tempDir\n  27→  };\n  28→}\n  29→\n  30→async function setupStateFiles(tempDir, type = 'feature') {\n  31→  const stateDir = type === 'feature'\n  32→    ? path.join(tempDir, 'state')\n  33→    : path.join(tempDir, 'bugfix-state');\n  34→\n  35→  await fs.promises.mkdir(stateDir, { recursive: true });\n  36→\n  37→  // Create minimal daemon log\n  38→  await fs.promises.writeFile(\n  39→    path.join(stateDir, 'pipeline-daemon.log'),\n  40→    'Integration test log line 1\\nIntegration test log line 2\\n'\n  41→  );\n  42→\n  43→  return stateDir;\n  44→}\n  45→\n  46→// US-1: Unified Pipeline Start\n  47→test('US-1: Full lifecycle startPipeline with daemon mode', async () => {\n  48→  await withTempDir(async (tempDir) => {\n  49→    const config = createTestConfig(tempDir);\n  50→    await setupStateFiles(tempDir, 'feature');\n  51→\n  52→    const lockManager = createLockManager({ config });\n  53→    const stateManager = createStateManager({ config });\n  54→\n  55→    // Mock script runner for daemon start\n  56→    let runnerCalled = false;\n  57→    const mockRunner = async (req) => {\n  58→      runnerCalled = true;\n  59→      return { ok: true, exitCode: 0, stdout: 'Daemon started', stderr: '' };\n  60→    };\n  61→\n  62→    const controller = createPipelineController({\n  63→      lockManager,\n  64→      stateManager,\n  65→      scriptRunner: mockRunner,\n  66→      config\n  67→    });\n  68→\n  69→    const result = await controller.startPipeline({ type: 'feature', daemon: true });\n  70→\n  71→    assert.equal(result.ok, true);\n  72→    assert.ok(result.runId);\n  73→    assert.equal(runnerCalled, true);\n  74→  });\n  75→});\n  76→\n  77→test('US-1: startPipeline with foreground mode', async () => {\n  78→  await withTempDir(async (tempDir) => {\n  79→    const config = createTestConfig(tempDir);\n  80→\n  81→    const lockManager = createLockManager({ config });\n  82→    const stateManager = createStateManager({ config });\n  83→\n  84→    const mockRunner = async (req) => ({\n  85→      ok: true,\n  86→      exitCode: 0,\n  87→      stdout: 'Foreground run completed',\n  88→      stderr: ''\n  89→    });\n  90→\n  91→    const controller = createPipelineController({\n  92→      lockManager,\n  93→      stateManager,\n  94→      scriptRunner: mockRunner,\n  95→      config\n  96→    });\n  97→\n  98→    const result = await controller.startPipeline({ type: 'feature', daemon: false });\n  99→\n 100→    assert.equal(result.ok, true);\n 101→  });\n 102→});\n 103→\n 104→// US-2: Pipeline Stop\n 105→test('US-2: stopPipeline should stop running daemon', async () => {\n 106→  await withTempDir(async (tempDir) => {\n 107→    const config = createTestConfig(tempDir);\n 108→    await setupStateFiles(tempDir, 'feature');\n 109→\n 110→    const lockManager = createLockManager({ config });\n 111→    const stateManager = createStateManager({ config });\n 112→\n 113→    // Simulate running daemon\n 114→    await stateManager.writeDaemonMeta('feature', {\n 115→      pid: process.pid,\n 116→      started_at: new Date().toISOString()\n 117→    });\n 118→\n 119→    const mockRunner = async (req) => ({\n 120→      ok: true,\n 121→      exitCode: 0,\n 122→      stdout: 'Daemon stopped',\n 123→      stderr: ''\n 124→    });\n 125→\n 126→    const controller = createPipelineController({\n 127→      lockManager,\n 128→      stateManager,\n 129→      scriptRunner: mockRunner,\n 130→      config\n 131→    });\n 132→\n 133→    const result = await controller.stopPipeline({ type: 'feature' });\n 134→\n 135→    assert.equal(result.ok, true);\n 136→  });\n 137→});\n 138→\n 139→test('US-2: stopPipeline should return ALREADY_STOPPED when not running', async () => {\n 140→  await withTempDir(async (tempDir) => {\n 141→    const config = createTestConfig(tempDir);\n 142→\n 143→    const lockManager = createLockManager({ config });\n 144→    const stateManager = createStateManager({ config });\n 145→\n 146→    const controller = createPipelineController({\n 147→      lockManager,\n 148→      stateManager,\n 149→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 150→      config\n 151→    });\n 152→\n 153→    const result = await controller.stopPipeline({ type: 'feature' });\n 154→\n 155→    assert.equal(result.ok, true);\n 156→    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 157→  });\n 158→});\n 159→\n 160→// US-3: Target Retry\n 161→test('US-3: retryTarget should retry a failed target', async () => {\n 162→  await withTempDir(async (tempDir) => {\n 163→    const config = createTestConfig(tempDir);\n 164→\n 165→    const lockManager = createLockManager({ config });\n 166→    const stateManager = createStateManager({ config });\n 167→\n 168→    const mockRunner = async (req) => ({\n 169→      ok: true,\n 170→      exitCode: 0,\n 171→      stdout: 'Retry successful',\n 172→      stderr: ''\n 173→    });\n 174→\n 175→    const controller = createPipelineController({\n 176→      lockManager,\n 177→      stateManager,\n 178→      scriptRunner: mockRunner,\n 179→      config\n 180→    });\n 181→\n 182→    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n 183→\n 184→    assert.equal(result.ok, true);\n 185→    assert.equal(result.targetId, 'F-001');\n 186→  });\n 187→});\n 188→\n 189→// US-4: Run Single Feature\n 190→test('US-4: runSingle should execute single target without lock', async () => {\n 191→  await withTempDir(async (tempDir) => {\n 192→    const config = createTestConfig(tempDir);\n 193→\n 194→    const lockManager = createLockManager({ config });\n 195→    const stateManager = createStateManager({ config });\n 196→\n 197→    const mockRunner = async (req) => ({\n 198→      ok: true,\n 199→      exitCode: 0,\n 200→      stdout: 'Single run completed',\n 201→      stderr: ''\n 202→    });\n 203→\n 204→    const controller = createPipelineController({\n 205→      lockManager,\n 206→      stateManager,\n 207→      scriptRunner: mockRunner,\n 208→      config\n 209→    });\n 210→\n 211→    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 212→\n 213→    assert.equal(result.ok, true);\n 214→    assert.equal(result.targetId, 'F-001');\n 215→    assert.equal(result.stdout, 'Single run completed');\n 216→\n 217→    // Verify lock was not acquired\n 218→    assert.equal(await lockManager.isLocked('feature'), false);\n 219→  });\n 220→});\n 221→\n 222→// US-5: Status Query\n 223→test('US-5: getStatus should return complete status', async () => {\n 224→  await withTempDir(async (tempDir) => {\n 225→    const config = createTestConfig(tempDir);\n 226→    await setupStateFiles(tempDir, 'feature');\n 227→\n 228→    const lockManager = createLockManager({ config });\n 229→    const stateManager = createStateManager({ config });\n 230→\n 231→    // Write some state\n 232→    await stateManager.writeDaemonMeta('feature', {\n 233→      pid: process.pid,\n 234→      started_at: new Date().toISOString()\n 235→    });\n 236→\n 237→    await stateManager.writeLastResult('feature', {\n 238→      runId: 'run-001',\n 239→      completedAt: new Date().toISOString(),\n 240→      status: 'success',\n 241→      featuresTotal: 5,\n 242→      featuresCompleted: 5\n 243→    });\n 244→\n 245→    const controller = createPipelineController({\n 246→      lockManager,\n 247→      stateManager,\n 248→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 249→      config\n 250→    });\n 251→\n 252→    const result = await controller.getStatus({ type: 'feature' });\n 253→\n 254→    assert.equal(result.ok, true);\n 255→    assert.equal(result.isRunning, true);\n 256→    assert.ok(result.pid);\n 257→  });\n 258→});\n 259→\n 260→// US-6: Logs Query\n 261→test('US-6: getLogs should return daemon logs', async () => {\n 262→  await withTempDir(async (tempDir) => {\n 263→    const config = createTestConfig(tempDir);\n 264→    await setupStateFiles(tempDir, 'feature');\n 265→\n 266→    const lockManager = createLockManager({ config });\n 267→    const stateManager = createStateManager({ config });\n 268→\n 269→    const controller = createPipelineController({\n 270→      lockManager,\n 271→      stateManager,\n 272→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 273→      config\n 274→    });\n 275→\n 276→    const result = await controller.getLogs({ type: 'feature' });\n 277→\n 278→    assert.equal(result.ok, true);\n 279→    assert.ok(result.logs.includes('Integration test log'));\n 280→    assert.ok(result.logPath);\n 281→  });\n 282→});\n 283→\n 284→// US-7: Concurrency Protection\n 285→test('US-7: Concurrent start attempts should fail second attempt', async () => {\n 286→  await withTempDir(async (tempDir) => {\n 287→    const config = createTestConfig(tempDir);\n 288→\n 289→    const lockManager = createLockManager({ config });\n 290→    const stateManager = createStateManager({ config });\n 291→\n 292→    const mockRunner = async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' });\n 293→\n 294→    const controller = createPipelineController({\n 295→      lockManager,\n 296→      stateManager,\n 297→      scriptRunner: mockRunner,\n 298→      config\n 299→    });\n 300→\n 301→    // First start should succeed\n 302→    const result1 = await controller.startPipeline({ type: 'feature', daemon: true });\n 303→    assert.equal(result1.ok, true);\n 304→\n 305→    // Second start should fail due to lock\n 306→    const result2 = await controller.startPipeline({ type: 'feature', daemon: true });\n 307→    assert.equal(result2.ok, false);\n 308→    assert.equal(result2.errorCode, 'LOCK_ACQUISITION_FAILED');\n 309→  });\n 310→});\n 311→\n 312→test('US-7: forceUnlock should release stuck lock', async () => {\n 313→  await withTempDir(async (tempDir) => {\n 314→    const config = createTestConfig(tempDir);\n 315→\n 316→    const lockManager = createLockManager({ config });\n 317→    const stateManager = createStateManager({ config });\n 318→\n 319→    const mockRunner = async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' });\n 320→\n 321→    const controller = createPipelineController({\n 322→      lockManager,\n 323→      stateManager,\n 324→      scriptRunner: mockRunner,\n 325→      config\n 326→    });\n 327→\n 328→    // Start pipeline\n 329→    await controller.startPipeline({ type: 'feature', daemon: true });\n 330→    assert.equal(await lockManager.isLocked('feature'), true);\n 331→\n 332→    // Force unlock\n 333→    const result = await controller.forceUnlock({ type: 'feature' });\n 334→    assert.equal(result.ok, true);\n 335→    assert.equal(await lockManager.isLocked('feature'), false);\n 336→  });\n 337→});\n 338→\n 339→// US-8: Error Mapping\n 340→test('US-8: All errors should have structured error codes', async () => {\n 341→  await withTempDir(async (tempDir) => {\n 342→    const config = createTestConfig(tempDir);\n 343→\n 344→    const lockManager = createLockManager({ config });\n 345→    const stateManager = createStateManager({ config });\n 346→\n 347→    const controller = createPipelineController({\n 348→      lockManager,\n 349→      stateManager,\n 350→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 351→      config\n 352→    });\n 353→\n 354→    // Test error without targetId\n 355→    const result = await controller.retryTarget({ type: 'feature' });\n 356→\n 357→    assert.equal(result.ok, false);\n 358→    assert.ok(result.errorCode);\n 359→    assert.ok(result.message);\n 360→\n 361→    // Error should be JSON serializable\n 362→    const serialized = JSON.stringify(result);\n 363→    assert.ok(serialized);\n 364→  });\n 365→});\n 366→\n 367→// US-9: Telegram Handler Integration\n 368→test('US-9: All results should be JSON serializable for Telegram', async () => {\n 369→  await withTempDir(async (tempDir) => {\n 370→    const config = createTestConfig(tempDir);\n 371→    await setupStateFiles(tempDir, 'feature');\n 372→    await setupStateFiles(tempDir, 'bugfix');\n 373→\n 374→    const lockManager = createLockManager({ config });\n 375→    const stateManager = createStateManager({ config });\n 376→\n 377→    const mockRunner = async () => ({\n 378→      ok: true,\n 379→      exitCode: 0,\n 380→      stdout: 'Test output',\n 381→      stderr: ''\n 382→    });\n 383→\n 384→    const controller = createPipelineController({\n 385→      lockManager,\n 386→      stateManager,\n 387→      scriptRunner: mockRunner,\n 388→      config\n 389→    });\n 390→\n 391→    const results = {\n 392→      start: await controller.startPipeline({ type: 'feature' }),\n 393→      stop: await controller.stopPipeline({ type: 'feature' }),\n 394→      retry: await controller.retryTarget({ type: 'feature', targetId: 'F-001' }),\n 395→      single: await controller.runSingle({ type: 'feature', targetId: 'F-001' }),\n 396→      status: await controller.getStatus({ type: 'feature' }),\n 397→      logs: await controller.getLogs({ type: 'feature' }),\n 398→      unlock: await controller.forceUnlock({ type: 'feature' })\n 399→    };\n 400→\n 401→    for (const [key, result] of Object.entries(results)) {\n 402→      const serialized = JSON.stringify(result);\n 403→      assert.ok(serialized, `${key} result should be JSON serializable`);\n 404→\n 405→      const parsed = JSON.parse(serialized);\n 406→      assert.ok(parsed.ok !== undefined, `${key} result should have ok field`);\n 407→      assert.ok(parsed.message !== undefined, `${key} result should have message field`);\n 408→    }\n 409→  });\n 410→});\n 411→\n 412→// Full lifecycle test\n 413→test('Full lifecycle: start -> status -> stop', async () => {\n 414→  await withTempDir(async (tempDir) => {\n 415→    const config = createTestConfig(tempDir);\n 416→    await setupStateFiles(tempDir, 'feature');\n 417→\n 418→    const lockManager = createLockManager({ config });\n 419→    const stateManager = createStateManager({ config });\n 420→\n 421→    const mockRunner = async (req) => ({\n 422→      ok: true,\n 423→      exitCode: 0,\n 424→      stdout: `${req.action} completed`,\n 425→      stderr: ''\n 426→    });\n 427→\n 428→    const controller = createPipelineController({\n 429→      lockManager,\n 430→      stateManager,\n 431→      scriptRunner: mockRunner,\n 432→      config\n 433→    });\n 434→\n 435→    // Start\n 436→    const startResult = await controller.startPipeline({ type: 'feature', daemon: true });\n 437→    assert.equal(startResult.ok, true);\n 438→\n 439→    // Status (should be running)\n 440→    const statusResult = await controller.getStatus({ type: 'feature' });\n 441→    assert.equal(statusResult.ok, true);\n 442→\n 443→    // Stop\n 444→    const stopResult = await controller.stopPipeline({ type: 'feature' });\n 445→    assert.equal(stopResult.ok, true);\n 446→\n 447→    // Status (should not be running)\n 448→    const finalStatus = await controller.getStatus({ type: 'feature' });\n 449→    assert.equal(finalStatus.ok, true);\n 450→    assert.equal(finalStatus.isRunning, false);\n 451→  });\n 452→});\n 453→\n 454→// H-2: Integration test for forceUnlock (US-7)\n 455→test('H-2: forceUnlock should work even when lock is stale', async () => {\n 456→  await withTempDir(async (tempDir) => {\n 457→    const config = createTestConfig(tempDir);\n 458→\n 459→    const lockManager = createLockManager({ config });\n 460→    const stateManager = createStateManager({ config });\n 461→\n 462→    // Create a stale lock with a dead PID\n 463→    await lockManager.acquireLock('feature', 99999999);\n 464→\n 465→    const controller = createPipelineController({\n 466→      lockManager,\n 467→      stateManager,\n 468→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 469→      config\n 470→    });\n 471→\n 472→    // Force unlock should work\n 473→    const result = await controller.forceUnlock({ type: 'feature' });\n 474→    assert.equal(result.ok, true);\n 475→\n 476→    // Should now be able to start\n 477→    const startResult = await controller.startPipeline({ type: 'feature' });\n 478→    assert.equal(startResult.ok, true);\n 479→  });\n 480→});\n 481→\n 482→// H-5: Error code verification across operations\n 483→test('H-5: Error codes should be consistent across all operations', async () => {\n 484→  await withTempDir(async (tempDir) => {\n 485→    const config = createTestConfig(tempDir);\n 486→\n 487→    const lockManager = createLockManager({ config });\n 488→    const stateManager = createStateManager({ config });\n 489→\n 490→    const controller = createPipelineController({\n 491→      lockManager,\n 492→      stateManager,\n 493→      scriptRunner: async () => ({ ok: true, exitCode: 0, stdout: '', stderr: '' }),\n 494→      config\n 495→    });\n 496→\n 497→    // Test INVALID_TARGET for missing targetId\n 498→    const retryResult = await controller.retryTarget({ type: 'feature' });\n 499→    assert.equal(retryResult.errorCode, 'INVALID_TARGET');\n 500→\n 501→    const singleResult = await controller.runSingle({ type: 'feature' });\n 502→    assert.equal(singleResult.errorCode, 'INVALID_TARGET');\n 503→\n 504→    // Test LOCK_ACQUISITION_FAILED\n 505→    await controller.startPipeline({ type: 'feature' });\n 506→    const secondStart = await controller.startPipeline({ type: 'feature' });\n 507→    assert.equal(secondStart.errorCode, 'LOCK_ACQUISITION_FAILED');\n 508→\n 509→    // Verify all error codes are in the known set\n 510→    const knownCodes = [\n 511→      'LOCK_ACQUISITION_FAILED',\n 512→      'ALREADY_STOPPED',\n 513→      'PIPELINE_NOT_RUNNING',\n 514→      'INVALID_TARGET',\n 515→      'TARGET_NOT_RETRYABLE',\n 516→      'DAEMON_START_FAILED'\n 517→    ];\n 518→\n 519→    for (const code of knownCodes) {\n 520→      assert.ok(typeof code === 'string', `Error code ${code} should be a string`);\n 521→    }\n 522→  });\n 523→});\n 524→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_8e7f968efcfb4733ba37e0dc","__timestamp":"2026-03-11T19:57:58.545Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
