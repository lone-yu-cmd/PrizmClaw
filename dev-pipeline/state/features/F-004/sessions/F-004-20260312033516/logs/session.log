{"type":"assistant","uuid":"20260312034534c2c49f67af754da5","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"id":"20260312034534c2c49f67af754da5","content":[{"type":"tool_use","id":"call_f167625f176c4ea0ad3cd7a3","name":"Write","input":{"content":"import test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nimport { createPipelineController } from '../../src/services/pipeline-controller.js';\n\nasync function withTempDir(fn) {\n  const tempDir = await fs.promises.mkdtemp(path.join(os.tmpdir(), 'pipeline-controller-test-'));\n  try {\n    await fn(tempDir);\n  } finally {\n    await fs.promises.rm(tempDir, { recursive: true, force: true });\n  }\n}\n\nfunction createMockConfig(tempDir) {\n  return {\n    stateDir: path.join(tempDir, 'state'),\n    bugfixStateDir: path.join(tempDir, 'bugfix-state'),\n    pipelineDir: path.join(tempDir, 'dev-pipeline'),\n    projectRoot: tempDir\n  };\n}\n\nfunction createMockLockManager() {\n  const locks = new Map();\n\n  return {\n    async acquireLock(type, pid = process.pid) {\n      if (locks.has(type)) {\n        return {\n          ok: false,\n          errorCode: 'LOCK_ACQUISITION_FAILED',\n          currentHolder: locks.get(type)\n        };\n      }\n      const lockInfo = { pid, acquiredAt: new Date().toISOString(), type };\n      locks.set(type, lockInfo);\n      return { ok: true, lockPath: `/tmp/${type}.lock` };\n    },\n    async releaseLock(type) {\n      locks.delete(type);\n    },\n    async isLocked(type) {\n      return locks.has(type);\n    },\n    async validateLock(type) {\n      const lock = locks.get(type);\n      if (!lock) return { valid: false };\n      // Simulate PID check - assume our process is alive\n      const isAlive = lock.pid === process.pid;\n      return { valid: isAlive, stale: !isAlive };\n    },\n    async forceUnlock(type) {\n      const prev = locks.get(type);\n      locks.delete(type);\n      return { ok: true, previousPid: prev?.pid };\n    },\n    async getLockInfo(type) {\n      return locks.get(type) || null;\n    }\n  };\n}\n\nfunction createMockStateManager(tempDir) {\n  const stateDir = path.join(tempDir, 'state');\n  let daemonMeta = null;\n  let lastResult = null;\n\n  return {\n    async readDaemonMeta(type) {\n      return daemonMeta;\n    },\n    async readPipelineState(type) {\n      const stateFile = path.join(stateDir, 'pipeline.json');\n      if (!fs.existsSync(stateFile)) return null;\n      const content = await fs.promises.readFile(stateFile, 'utf8');\n      return JSON.parse(content);\n    },\n    async readCurrentSession(type) {\n      return null;\n    },\n    async getLastResult(type) {\n      return lastResult;\n    },\n    async writeDaemonMeta(type, meta) {\n      daemonMeta = meta;\n    },\n    async writeLastResult(type, result) {\n      lastResult = result;\n    },\n    async isDaemonRunning(type) {\n      return daemonMeta !== null && daemonMeta.pid === process.pid;\n    },\n    async getDaemonPid(type) {\n      return daemonMeta?.pid || null;\n    }\n  };\n}\n\nfunction createMockScriptRunner() {\n  return async function mockRunner(req) {\n    return {\n      ok: true,\n      exitCode: 0,\n      stdout: 'Pipeline started',\n      stderr: '',\n      normalizedStatus: 'success'\n    };\n  };\n}\n\ntest('createPipelineController should return controller interface', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager: createMockLockManager(),\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    assert.equal(typeof controller.startPipeline, 'function');\n    assert.equal(typeof controller.stopPipeline, 'function');\n    assert.equal(typeof controller.retryTarget, 'function');\n    assert.equal(typeof controller.runSingle, 'function');\n    assert.equal(typeof controller.getStatus, 'function');\n    assert.equal(typeof controller.getLogs, 'function');\n    assert.equal(typeof controller.forceUnlock, 'function');\n  });\n});\n\n// T-057: Tests for factory and helpers\ntest('createPipelineController should support dependency injection', async () => {\n  await withTempDir(async (tempDir) => {\n    let runnerCalled = false;\n    const customRunner = async () => {\n      runnerCalled = true;\n      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n    };\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager: createMockLockManager(),\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: customRunner,\n      config\n    });\n\n    await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n    assert.equal(runnerCalled, true);\n  });\n});\n\ntest('createPipelineController should use defaults when not provided', async () => {\n  const controller = createPipelineController();\n  assert.ok(controller);\n  assert.equal(typeof controller.startPipeline, 'function');\n});\n\n// T-107: Tests for startPipeline daemon mode\ntest('startPipeline should acquire lock before starting', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.startPipeline({ type: 'feature', daemon: true });\n\n    assert.equal(result.ok, true);\n    assert.equal(await lockManager.isLocked('feature'), true);\n  });\n});\n\ntest('startPipeline should fail when lock acquisition fails', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    // Pre-acquire lock\n    await lockManager.acquireLock('feature', 12345);\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.startPipeline({ type: 'feature' });\n\n    assert.equal(result.ok, false);\n    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n    assert.ok(result.message);\n  });\n});\n\ntest('startPipeline should return runId and pid for daemon mode', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const stateManager = createMockStateManager(tempDir);\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager,\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.startPipeline({ type: 'feature', daemon: true });\n\n    assert.equal(result.ok, true);\n    assert.ok(result.runId);\n  });\n});\n\n// T-108: Tests for startPipeline foreground mode\ntest('startPipeline foreground should not use daemon mode', async () => {\n  await withTempDir(async (tempDir) => {\n    let capturedReq = null;\n    const customRunner = async (req) => {\n      capturedReq = req;\n      return { ok: true, exitCode: 0, stdout: 'done', stderr: '' };\n    };\n\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: customRunner,\n      config\n    });\n\n    const result = await controller.startPipeline({ type: 'feature', daemon: false });\n\n    assert.equal(result.ok, true);\n    assert.equal(capturedReq.action, 'run');\n  });\n});\n\ntest('startPipeline should support targetId parameter', async () => {\n  await withTempDir(async (tempDir) => {\n    let capturedReq = null;\n    const customRunner = async (req) => {\n      capturedReq = req;\n      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n    };\n\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: customRunner,\n      config\n    });\n\n    await controller.startPipeline({ type: 'feature', targetId: 'F-003' });\n\n    assert.equal(capturedReq.targetId, 'F-003');\n  });\n});\n\n// T-125: Tests for stopPipeline\ntest('stopPipeline should release lock after stopping', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const stateManager = createMockStateManager(tempDir);\n    await stateManager.writeDaemonMeta('feature', { pid: process.pid, started_at: new Date().toISOString() });\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager,\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    await controller.startPipeline({ type: 'feature', daemon: true });\n    await controller.stopPipeline({ type: 'feature' });\n\n    assert.equal(await lockManager.isLocked('feature'), false);\n  });\n});\n\ntest('stopPipeline should return ALREADY_STOPPED when not running', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.stopPipeline({ type: 'feature' });\n\n    assert.equal(result.ok, true);\n    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n  });\n});\n\n// T-134: Tests for retryTarget\ntest('retryTarget should validate target exists', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    // Should work with valid targetId\n    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n    assert.equal(result.ok, true);\n  });\n});\n\ntest('retryTarget should require targetId', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.retryTarget({ type: 'feature' });\n\n    assert.equal(result.ok, false);\n    assert.equal(result.errorCode, 'INVALID_TARGET');\n  });\n});\n\n// T-144: Tests for runSingle\ntest('runSingle should not acquire lock', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n\n    // runSingle should not hold lock\n    assert.equal(await lockManager.isLocked('feature'), false);\n  });\n});\n\ntest('runSingle should return full execution details', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n\n    assert.equal(result.ok, true);\n    assert.equal(result.targetId, 'F-001');\n    assert.ok(result.stdout !== undefined);\n    assert.ok(result.stderr !== undefined);\n  });\n});\n\ntest('runSingle should support timeout', async () => {\n  await withTempDir(async (tempDir) => {\n    let capturedReq = null;\n    const customRunner = async (req) => {\n      capturedReq = req;\n      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n    };\n\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: customRunner,\n      config\n    });\n\n    await controller.runSingle({ type: 'feature', targetId: 'F-001', timeoutMs: 5000 });\n\n    assert.equal(capturedReq.timeoutMs, 5000);\n  });\n});\n\n// T-155: Tests for getStatus\ntest('getStatus should return isRunning false when no daemon', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.getStatus({ type: 'feature' });\n\n    assert.equal(result.ok, true);\n    assert.equal(result.isRunning, false);\n    assert.ok(result.message);\n  });\n});\n\ntest('getStatus should return isRunning true when daemon running', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const stateManager = createMockStateManager(tempDir);\n    await stateManager.writeDaemonMeta('feature', { pid: process.pid, started_at: new Date().toISOString() });\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager,\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.getStatus({ type: 'feature' });\n\n    assert.equal(result.ok, true);\n    assert.equal(result.isRunning, true);\n  });\n});\n\ntest('getStatus should include lastResult when not running', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const stateManager = createMockStateManager(tempDir);\n    await stateManager.writeLastResult('feature', {\n      runId: 'run-001',\n      completedAt: new Date().toISOString(),\n      status: 'success',\n      featuresTotal: 5,\n      featuresCompleted: 5\n    });\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager,\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.getStatus({ type: 'feature' });\n\n    assert.ok(result.lastResult);\n    assert.equal(result.lastResult.runId, 'run-001');\n  });\n});\n\n// T-164: Tests for getLogs\ntest('getLogs should return log content', async () => {\n  await withTempDir(async (tempDir) => {\n    const stateDir = path.join(tempDir, 'state');\n    await fs.promises.mkdir(stateDir, { recursive: true });\n    await fs.promises.writeFile(\n      path.join(stateDir, 'pipeline-daemon.log'),\n      'Line 1\\nLine 2\\nLine 3\\n'\n    );\n\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.getLogs({ type: 'feature' });\n\n    assert.equal(result.ok, true);\n    assert.ok(result.logs);\n    assert.ok(result.logPath);\n  });\n});\n\ntest('getLogs should return empty string when log missing', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.getLogs({ type: 'feature' });\n\n    assert.equal(result.ok, true);\n    assert.equal(result.logs, '');\n    assert.ok(result.logPath);\n  });\n});\n\ntest('getLogs should respect lines parameter', async () => {\n  await withTempDir(async (tempDir) => {\n    const stateDir = path.join(tempDir, 'state');\n    await fs.promises.mkdir(stateDir, { recursive: true });\n    await fs.promises.writeFile(\n      path.join(stateDir, 'pipeline-daemon.log'),\n      'Line 1\\nLine 2\\nLine 3\\nLine 4\\nLine 5\\n'\n    );\n\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.getLogs({ type: 'feature', lines: 2 });\n\n    assert.equal(result.ok, true);\n    assert.equal(result.lines, 2);\n  });\n});\n\n// T-173: Tests for forceUnlock\ntest('forceUnlock should release lock forcibly', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    await lockManager.acquireLock('feature', 12345);\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.forceUnlock({ type: 'feature' });\n\n    assert.equal(result.ok, true);\n    assert.equal(await lockManager.isLocked('feature'), false);\n  });\n});\n\ntest('forceUnlock should return previousPid', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    await lockManager.acquireLock('feature', 12345);\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.forceUnlock({ type: 'feature' });\n\n    assert.equal(result.previousPid, 12345);\n  });\n});\n\n// T-183: Tests for error mapping\ntest('all methods should use buildError helper for errors', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    await lockManager.acquireLock('feature', 12345); // Pre-lock\n\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const result = await controller.startPipeline({ type: 'feature' });\n\n    assert.equal(result.ok, false);\n    assert.ok(result.errorCode);\n    assert.ok(result.message);\n    assert.ok(typeof result.hint === 'string' || result.hint === undefined);\n  });\n});\n\ntest('error results should include hint field', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    // Missing targetId should produce INVALID_TARGET error\n    const result = await controller.retryTarget({ type: 'feature' });\n\n    assert.equal(result.ok, false);\n    assert.ok(result.message);\n    assert.ok(result.hint || result.context);\n  });\n});\n\n// T-190: JSON serialization tests\ntest('all results should be JSON serializable', async () => {\n  await withTempDir(async (tempDir) => {\n    const lockManager = createMockLockManager();\n    const config = createMockConfig(tempDir);\n    const controller = createPipelineController({\n      lockManager,\n      stateManager: createMockStateManager(tempDir),\n      scriptRunner: createMockScriptRunner(),\n      config\n    });\n\n    const results = await Promise.all([\n      controller.startPipeline({ type: 'feature' }),\n      controller.stopPipeline({ type: 'feature' }),\n      controller.retryTarget({ type: 'feature', targetId: 'F-001' }),\n      controller.runSingle({ type: 'feature', targetId: 'F-001' }),\n      controller.getStatus({ type: 'feature' }),\n      controller.getLogs({ type: 'feature' }),\n      controller.forceUnlock({ type: 'feature' })\n    ]);\n\n    for (const result of results) {\n      assert.doesNotThrow(() => JSON.stringify(result), `Result ${JSON.stringify(result)} should be serializable`);\n    }\n  });\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/pipeline-controller.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":49434,"output_tokens":4662,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:46:51.396Z","_requestId":"deb8a7f51c654133868