ineCommand(\n  40→    { pipelineType: 'bugfix', action: 'retry', targetId: 'B-001', listPath: '/repo/bug-fix-list.json' },\n  41→    baseConfig\n  42→  );\n  43→  assert.equal(retryCmd.command, '/repo/dev-pipeline/retry-bug.sh');\n  44→  assert.deepEqual(retryCmd.args, ['B-001', '/repo/bug-fix-list.json']);\n  45→\n  46→  const resetCmd = buildPipelineCommand(\n  47→    { pipelineType: 'bugfix', action: 'reset', targetId: 'B-001', listPath: '/repo/bug-fix-list.json' },\n  48→    baseConfig\n  49→  );\n  50→  assert.equal(resetCmd.command, '/repo/dev-pipeline/scripts/update-bug-status.py');\n  51→  assert.deepEqual(resetCmd.args, [\n  52→    '--bug-list',\n  53→    '/repo/bug-fix-list.json',\n  54→    '--state-dir',\n  55→    '/repo/dev-pipeline/bugfix-state',\n  56→    '--bug-id',\n  57→    'B-001',\n  58→    '--project-root',\n  59→    '/repo',\n  60→    '--action',\n  61→    'clean'\n  62→  ]);\n  63→});\n  64→\n  65→test('normalizePipelineResult should map exit outcomes to normalized status and error', () => {\n  66→  assert.deepEqual(\n  67→    normalizePipelineResult({ exitCode: 0, signal: null, stdout: 'ok', stderr: '' }),\n  68→    {\n  69→      ok: true,\n  70→      exitCode: 0,\n  71→      signal: undefined,\n  72→      stdout: 'ok',\n  73→      stderr: '',\n  74→      normalizedStatus: 'success',\n  75→      errorCode: undefined\n  76→    }\n  77→  );\n  78→\n  79→  assert.equal(\n  80→    normalizePipelineResult({ exitCode: 124, signal: null, stdout: '', stderr: '' }).normalizedStatus,\n  81→    'timed_out'\n  82→  );\n  83→\n  84→  const crashed = normalizePipelineResult({ exitCode: 143, signal: 'SIGTERM', stdout: '', stderr: '' });\n  85→  assert.equal(crashed.normalizedStatus, 'crashed');\n  86→  assert.equal(crashed.errorCode, 'EXEC_FAILED');\n  87→\n  88→  const failed = normalizePipelineResult({ exitCode: 1, signal: null, stdout: '', stderr: 'err' });\n  89→  assert.equal(failed.normalizedStatus, 'failed');\n  90→  assert.equal(failed.errorCode, 'EXEC_FAILED');\n  91→});\n  92→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:43:04.961Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
