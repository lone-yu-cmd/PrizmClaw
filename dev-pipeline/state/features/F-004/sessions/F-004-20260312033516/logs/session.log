{"type":"user","uuid":"3c77f3cf-36ab-41d5-a28d-443c6c0912c5","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_5250ae4b8e024c0f9ed512d3","content":[{"type":"text","text":"   1→export const INFRA_ERROR_CODES = Object.freeze({\n   2→  CONFIG_MISSING: 'CONFIG_MISSING',\n   3→  CONFIG_INVALID: 'CONFIG_INVALID',\n   4→  PATH_INVALID: 'PATH_INVALID',\n   5→  SCRIPT_NOT_FOUND: 'SCRIPT_NOT_FOUND',\n   6→  EXEC_TIMEOUT: 'EXEC_TIMEOUT',\n   7→  EXEC_FAILED: 'EXEC_FAILED'\n   8→});\n   9→\n  10→const ERROR_CODE_SET = new Set(Object.values(INFRA_ERROR_CODES));\n  11→\n  12→export function isInfraErrorCode(code) {\n  13→  return ERROR_CODE_SET.has(code);\n  14→}\n  15→\n  16→export function createInfraError(code, message, options = {}) {\n  17→  if (!isInfraErrorCode(code)) {\n  18→    throw new Error(`Unknown infra error code: ${code}`);\n  19→  }\n  20→\n  21→  return {\n  22→    code,\n  23→    message: String(message ?? ''),\n  24→    ...(options.hint ? { hint: String(options.hint) } : {}),\n  25→    ...(options.context ? { context: options.context } : {})\n  26→  };\n  27→}\n  28→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:42:59.979Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
{"type":"user","uuid":"40b5d1bb-9754-4fa8-b5c4-335ff2078123","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_a445bcfd6c3e467fab09a699","content":[{"type":"text","text":"   1→import path from 'node:path';\n   2→\n   3→const SAFE_SEGMENT_PATTERN = /^[A-Za-z0-9._-]+$/;\n   4→\n   5→function assertSafeSegment(value, label) {\n   6→  const normalized = String(value ?? '').trim();\n   7→  if (!normalized || !SAFE_SEGMENT_PATTERN.test(normalized) || normalized.includes('..')) {\n   8→    throw new Error(`Invalid path segment for ${label}: ${value}`);\n   9→  }\n  10→\n  11→  return normalized;\n  12→}\n  13→\n  14→export function computeFeatureSlug(featureId, title) {\n  15→  const normalizedFeatureId = assertSafeSegment(featureId, 'featureId');\n  16→  const numeric = normalizedFeatureId.replace(/^F-/i, '').replace(/^0+/, '').padStart(3, '0');\n  17→\n  18→  const rawTitle = String(title ?? '').toLowerCase();\n  19→  const cleanedTitle = rawTitle\n  20→    .replace(/[^a-z0-9\\s-]/g, '')\n  21→    .trim()\n  22→    .replace(/[\\s]+/g, '-')\n  23→    .replace(/-+/g, '-');\n  24→\n  25→  const safeTitle = cleanedTitle || 'feature';\n  26→  return `${numeric}-${safeTitle}`;\n  27→}\n  28→\n  29→export function resolveFeaturePaths(input) {\n  30→  const projectRoot = path.resolve(String(input?.projectRoot ?? ''));\n  31→  const featureId = assertSafeSegment(input?.featureId, 'featureId');\n  32→  const sessionId = assertSafeSegment(input?.sessionId, 'sessionId');\n  33→  const featureSlug = computeFeatureSlug(featureId, input?.title ?? '');\n  34→\n  35→  const specsDir = path.join(projectRoot, '.prizmkit/specs', featureSlug);\n  36→  const sessionDir = path.join(projectRoot, 'dev-pipeline/state/features', featureId, 'sessions', sessionId);\n  37→\n  38→  return {\n  39→    featureSlug,\n  40→    specsDir,\n  41→    sessionDir,\n  42→    sessionLog: path.join(sessionDir, 'logs/session.log'),\n  43→    sessionStatus: path.join(sessionDir, 'session-status.json')\n  44→  };\n  45→}\n  46→\n  47→export function resolveBugPaths(input) {\n  48→  const projectRoot = path.resolve(String(input?.projectRoot ?? ''));\n  49→  const bugId = assertSafeSegment(input?.bugId, 'bugId');\n  50→  const sessionId = assertSafeSegment(input?.sessionId, 'sessionId');\n  51→\n  52→  const bugDir = path.join(projectRoot, 'dev-pipeline/bugfix-state/bugs', bugId);\n  53→  const sessionDir = path.join(bugDir, 'sessions', sessionId);\n  54→\n  55→  return {\n  56→    bugDir,\n  57→    sessionDir,\n  58→    sessionLog: path.join(sessionDir, 'logs/session.log'),\n  59→    sessionStatus: path.join(sessionDir, 'session-status.json')\n  60→  };\n  61→}\n  62→\n  63→export function resolveDaemonLogPaths(projectRoot) {\n  64→  const resolvedRoot = path.resolve(String(projectRoot ?? ''));\n  65→\n  66→  return {\n  67→    featureDaemonLog: path.join(resolvedRoot, 'dev-pipeline/state/pipeline-daemon.log'),\n  68→    bugfixDaemonLog: path.join(resolvedRoot, 'dev-pipeline/bugfix-state/pipeline-daemon.log')\n  69→  };\n  70→}\n  71→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:42:59.979Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
{"type":"user","uuid":"26f03550-2347-4736-811f-eb28a918134c","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_37a2834412cd46c3b6deebdf","content":[{"type":"text","text":"   1→import { spawn } from 'node:child_process';\n   2→import fs from 'node:fs';\n   3→import path from 'node:path';\n   4→\n   5→import { INFRA_ERROR_CODES } from './error-codes.js';\n   6→import { loadPipelineInfraConfig } from './config-loader.js';\n   7→\n   8→const PIPELINE_TYPES = new Set(['feature', 'bugfix']);\n   9→const PIPELINE_ACTIONS = new Set(['run', 'status', 'stop', 'logs', 'retry', 'reset']);\n  10→\n  11→function ensureValidRequest(req) {\n  12→  if (!PIPELINE_TYPES.has(req?.pipelineType)) {\n  13→    throw new Error(`Invalid pipelineType: ${req?.pipelineType}`);\n  14→  }\n  15→  if (!PIPELINE_ACTIONS.has(req?.action)) {\n  16→    throw new Error(`Invalid action: ${req?.action}`);\n  17→  }\n  18→}\n  19→\n  20→function ensureTargetId(targetId, action) {\n  21→  const normalized = String(targetId ?? '').trim();\n  22→  if (!normalized) {\n  23→    throw new Error(`targetId is required for action '${action}'`);\n  24→  }\n  25→  return normalized;\n  26→}\n  27→\n  28→function withOptionalList(args, listPath) {\n  29→  if (listPath) {\n  30→    args.push(listPath);\n  31→  }\n  32→  return args;\n  33→}\n  34→\n  35→export function buildPipelineCommand(req, config) {\n  36→  ensureValidRequest(req);\n  37→\n  38→  const pipelineDir = config.pipelineDir;\n  39→  const featureListPath = req.listPath || config.featureListPath;\n  40→  const bugFixListPath = req.listPath || config.bugFixListPath;\n  41→\n  42→  if (req.pipelineType === 'feature') {\n  43→    switch (req.action) {\n  44→      case 'run': {\n  45→        const args = ['run'];\n  46→        if (req.targetId) {\n  47→          args.push(req.targetId);\n  48→        }\n  49→        return { command: path.join(pipelineDir, 'run.sh'), args: withOptionalList(args, featureListPath) };\n  50→      }\n  51→      case 'status':\n  52→        return {\n  53→          command: path.join(pipelineDir, 'run.sh'),\n  54→          args: withOptionalList(['status'], featureListPath)\n  55→        };\n  56→      case 'stop':\n  57→        return { command: path.join(pipelineDir, 'launch-daemon.sh'), args: ['stop'] };\n  58→      case 'logs':\n  59→        return { command: path.join(pipelineDir, 'launch-daemon.sh'), args: ['logs'] };\n  60→      case 'retry': {\n  61→        const targetId = ensureTargetId(req.targetId, req.action);\n  62→        return {\n  63→          command: path.join(pipelineDir, 'retry-feature.sh'),\n  64→          args: withOptionalList([targetId], featureListPath)\n  65→        };\n  66→      }\n  67→      case 'reset': {\n  68→        if (req.targetId) {\n  69→          const targetId = ensureTargetId(req.targetId, req.action);\n  70→          return {\n  71→            command: path.join(pipelineDir, 'reset-feature.sh'),\n  72→            args: withOptionalList([targetId, '--clean'], featureListPath)\n  73→          };\n  74→        }\n  75→\n  76→        return { command: path.join(pipelineDir, 'run.sh'), args: ['reset'] };\n  77→      }\n  78→      default:\n  79→        throw new Error(`Unsupported feature action: ${req.action}`);\n  80→    }\n  81→  }\n  82→\n  83→  switch (req.action) {\n  84→    case 'run': {\n  85→      const args = ['run'];\n  86→      if (req.targetId) {\n  87→        args.push(req.targetId);\n  88→      }\n  89→      return { command: path.join(pipelineDir, 'run-bugfix.sh'), args: withOptionalList(args, bugFixListPath) };\n  90→    }\n  91→    case 'status':\n  92→      return {\n  93→        command: path.join(pipelineDir, 'run-bugfix.sh'),\n  94→        args: withOptionalList(['status'], bugFixListPath)\n  95→      };\n  96→    case 'stop':\n  97→      return { command: path.join(pipelineDir, 'launch-bugfix-daemon.sh'), args: ['stop'] };\n  98→    case 'logs':\n  99→      return { command: path.join(pipelineDir, 'launch-bugfix-daemon.sh'), args: ['logs'] };\n 100→    case 'retry': {\n 101→      const targetId = ensureTargetId(req.targetId, req.action);\n 102→      return {\n 103→        command: path.join(pipelineDir, 'retry-bug.sh'),\n 104→        args: withOptionalList([targetId], bugFixListPath)\n 105→      };\n 106→    }\n 107→    case 'reset': {\n 108→      if (req.targetId) {\n 109→        const targetId = ensureTargetId(req.targetId, req.action);\n 110→        const listPath = req.listPath || config.bugFixListPath;\n 111→        return {\n 112→          command: path.join(pipelineDir, 'scripts/update-bug-status.py'),\n 113→          args: [\n 114→            '--bug-list',\n 115→            listPath,\n 116→            '--state-dir',\n 117→            path.join(pipelineDir, 'bugfix-state'),\n 118→            '--bug-id',\n 119→            targetId,\n 120→            '--project-root',\n 121→            config.projectRoot,\n 122→            '--action',\n 123→            'clean'\n 124→          ]\n 125→        };\n 126→      }\n 127→\n 128→      return { command: path.join(pipelineDir, 'run-bugfix.sh'), args: ['reset'] };\n 129→    }\n 130→    default:\n 131→      throw new Error(`Unsupported bugfix action: ${req.action}`);\n 132→  }\n 133→}\n 134→\n 135→export function normalizePipelineResult({ exitCode, signal, stdout, stderr, timedOut = false }) {\n 136→  let normalizedStatus = 'failed';\n 137→  let errorCode;\n 138→\n 139→  if (timedOut || exitCode === 124) {\n 140→    normalizedStatus = 'timed_out';\n 141→    errorCode = INFRA_ERROR_CODES.EXEC_TIMEOUT;\n 142→  } else if (signal) {\n 143→    normalizedStatus = 'crashed';\n 144→    errorCode = INFRA_ERROR_CODES.EXEC_FAILED;\n 145→  } else if (exitCode === 0) {\n 146→    normalizedStatus = 'success';\n 147→  } else {\n 148→    normalizedStatus = 'failed';\n 149→    errorCode = INFRA_ERROR_CODES.EXEC_FAILED;\n 150→  }\n 151→\n 152→  return {\n 153→    ok: normalizedStatus === 'success',\n 154→    exitCode: Number.isInteger(exitCode) ? exitCode : 1,\n 155→    signal: signal || undefined,\n 156→    stdout: stdout ?? '',\n 157→    stderr: stderr ?? '',\n 158→    normalizedStatus,\n 159→    errorCode\n 160→  };\n 161→}\n 162→\n 163→function runCommand({ command, args, env, timeoutMs }) {\n 164→  return new Promise((resolve, reject) => {\n 165→    let stdout = '';\n 166→    let stderr = '';\n 167→    let timedOut = false;\n 168→\n 169→    const child = spawn(command, args, {\n 170→      env,\n 171→      stdio: ['ignore', 'pipe', 'pipe']\n 172→    });\n 173→\n 174→    const timer = timeoutMs && timeoutMs > 0\n 175→      ? setTimeout(() => {\n 176→          timedOut = true;\n 177→          child.kill('SIGTERM');\n 178→        }, timeoutMs)\n 179→      : null;\n 180→\n 181→    child.stdout.on('data', (chunk) => {\n 182→      stdout += chunk.toString();\n 183→    });\n 184→\n 185→    child.stderr.on('data', (chunk) => {\n 186→      stderr += chunk.toString();\n 187→    });\n 188→\n 189→    child.on('error', (error) => {\n 190→      if (timer) {\n 191→        clearTimeout(timer);\n 192→      }\n 193→      reject(error);\n 194→    });\n 195→\n 196→    child.on('close', (exitCode, signal) => {\n 197→      if (timer) {\n 198→        clearTimeout(timer);\n 199→      }\n 200→      resolve({ exitCode: exitCode ?? (timedOut ? 124 : 1), signal, stdout, stderr, timedOut });\n 201→    });\n 202→  });\n 203→}\n 204→\n 205→function scriptExists(commandPath) {\n 206→  if (commandPath === 'python3' || commandPath === 'node') {\n 207→    return true;\n 208→  }\n 209→  return fs.existsSync(commandPath);\n 210→}\n 211→\n 212→export async function executePipelineCommand(req) {\n 213→  const config = loadPipelineInfraConfig();\n 214→  const commandRequest = {\n 215→    ...req,\n 216→    listPath:\n 217→      req.listPath || (req.pipelineType === 'feature' ? config.featureListPath : config.bugFixListPath)\n 218→  };\n 219→\n 220→  let command;\n 221→  let args;\n 222→\n 223→  try {\n 224→    ({ command, args } = buildPipelineCommand(commandRequest, config));\n 225→  } catch (error) {\n 226→    return {\n 227→      ok: false,\n 228→      exitCode: 1,\n 229→      stdout: '',\n 230→      stderr: error instanceof Error ? error.message : String(error),\n 231→      normalizedStatus: 'failed',\n 232→      errorCode: INFRA_ERROR_CODES.EXEC_FAILED\n 233→    };\n 234→  }\n 235→\n 236→  if (!scriptExists(command)) {\n 237→    return {\n 238→      ok: false,\n 239→      exitCode: 127,\n 240→      stdout: '',\n 241→      stderr: `Command not found: ${command}`,\n 242→      normalizedStatus: 'failed',\n 243→      errorCode: INFRA_ERROR_CODES.SCRIPT_NOT_FOUND\n 244→    };\n 245→  }\n 246→\n 247→  try {\n 248→    const raw = await runCommand({\n 249→      command,\n 250→      args,\n 251→      timeoutMs: req.timeoutMs,\n 252→      env: {\n 253→        ...process.env,\n 254→        ...(req.envOverrides ?? {})\n 255→      }\n 256→    });\n 257→\n 258→    return normalizePipelineResult(raw);\n 259→  } catch (error) {\n 260→    const message = error instanceof Error ? error.message : String(error);\n 261→\n 262→    if (error && error.code === 'ENOENT') {\n 263→      return {\n 264→        ok: false,\n 265→        exitCode: 127,\n 266→        stdout: '',\n 267→        stderr: message,\n 268→        normalizedStatus: 'failed',\n 269→        errorCode: INFRA_ERROR_CODES.SCRIPT_NOT_FOUND\n 270→      };\n 271→    }\n 272→\n 273→    return {\n 274→      ok: false,\n 275→      exitCode: 1,\n 276→      stdout: '',\n 277→      stderr: message,\n 278→      normalizedStatus: 'failed',\n 279→      errorCode: INFRA_ERROR_CODES.EXEC_FAILED\n 280→    };\n 281→  }\n 282→}\n 283→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:42:59.980Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
