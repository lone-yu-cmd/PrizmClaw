{"type":"assistant","uuid":"20260312034447199db3f47fa24e82","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"id":"20260312034447199db3f47fa24e82","content":[{"type":"tool_use","id":"call_1815a9e8426e46478b967528","name":"Write","input":{"content":"import test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nimport { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n\nasync function withTempDir(fn) {\n  const tempDir = await fs.promises.mkdtemp(path.join(os.tmpdir(), 'state-manager-test-'));\n  try {\n    await fn(tempDir);\n  } finally {\n    await fs.promises.rm(tempDir, { recursive: true, force: true });\n  }\n}\n\nfunction createMockConfig(tempDir) {\n  return {\n    stateDir: path.join(tempDir, 'state'),\n    bugfixStateDir: path.join(tempDir, 'bugfix-state')\n  };\n}\n\nasync function createMockStateFiles(tempDir, type = 'feature') {\n  const stateDir = type === 'feature'\n    ? path.join(tempDir, 'state')\n    : path.join(tempDir, 'bugfix-state');\n\n  await fs.promises.mkdir(stateDir, { recursive: true });\n\n  // Create mock daemon meta\n  const daemonMeta = {\n    pid: 12345,\n    started_at: new Date().toISOString(),\n    feature_list: '/path/to/feature-list.json',\n    env_overrides: '',\n    log_file: path.join(stateDir, 'pipeline-daemon.log')\n  };\n  await fs.promises.writeFile(\n    path.join(stateDir, '.pipeline-meta.json'),\n    JSON.stringify(daemonMeta)\n  );\n\n  // Create mock pipeline state\n  const pipelineState = {\n    run_id: 'run-20260312-103000',\n    status: 'running',\n    feature_list_path: '/path/to/feature-list.json',\n    created_at: new Date().toISOString(),\n    total_features: 5,\n    completed_features: 2\n  };\n  await fs.promises.writeFile(\n    path.join(stateDir, 'pipeline.json'),\n    JSON.stringify(pipelineState)\n  );\n\n  // Create mock current session\n  const currentSession = {\n    feature_id: 'F-003',\n    session_id: 'session-001',\n    started_at: new Date().toISOString(),\n    status: 'in_progress'\n  };\n  await fs.promises.writeFile(\n    path.join(stateDir, 'current-session.json'),\n    JSON.stringify(currentSession)\n  );\n\n  // Create mock daemon log\n  await fs.promises.writeFile(\n    path.join(stateDir, 'pipeline-daemon.log'),\n    'Line 1\\nLine 2\\nLine 3\\n'\n  );\n\n  return { daemonMeta, pipelineState, currentSession };\n}\n\ntest('createStateManager should return state manager interface', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    assert.equal(typeof manager.readDaemonMeta, 'function');\n    assert.equal(typeof manager.readPipelineState, 'function');\n    assert.equal(typeof manager.readCurrentSession, 'function');\n    assert.equal(typeof manager.getLastResult, 'function');\n    assert.equal(typeof manager.writeDaemonMeta, 'function');\n    assert.equal(typeof manager.writeLastResult, 'function');\n    assert.equal(typeof manager.isDaemonRunning, 'function');\n    assert.equal(typeof manager.getDaemonPid, 'function');\n  });\n});\n\n// T-039: Tests for read operations\ntest('readDaemonMeta should return daemon metadata', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const { daemonMeta } = await createMockStateFiles(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.readDaemonMeta('feature');\n\n    assert.deepEqual(result, daemonMeta);\n  });\n});\n\ntest('readDaemonMeta should return null when file missing', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.readDaemonMeta('feature');\n    assert.equal(result, null);\n  });\n});\n\ntest('readPipelineState should return pipeline state', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const { pipelineState } = await createMockStateFiles(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.readPipelineState('feature');\n\n    assert.deepEqual(result, pipelineState);\n  });\n});\n\ntest('readPipelineState should return null when file missing', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.readPipelineState('feature');\n    assert.equal(result, null);\n  });\n});\n\ntest('readCurrentSession should return current session', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const { currentSession } = await createMockStateFiles(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.readCurrentSession('feature');\n\n    assert.deepEqual(result, currentSession);\n  });\n});\n\ntest('readCurrentSession should return null when file missing', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.readCurrentSession('feature');\n    assert.equal(result, null);\n  });\n});\n\ntest('getLastResult should return last result', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    await createMockStateFiles(tempDir);\n\n    // Write last result\n    const lastResult = {\n      runId: 'run-20260312-103000',\n      completedAt: new Date().toISOString(),\n      status: 'success',\n      featuresTotal: 5,\n      featuresCompleted: 5\n    };\n    const stateDir = path.join(tempDir, 'state');\n    await fs.promises.writeFile(\n      path.join(stateDir, '.last-result.json'),\n      JSON.stringify(lastResult)\n    );\n\n    const manager = createStateManager({ config });\n    const result = await manager.getLastResult('feature');\n\n    assert.deepEqual(result, lastResult);\n  });\n});\n\ntest('getLastResult should return null when file missing', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.getLastResult('feature');\n    assert.equal(result, null);\n  });\n});\n\n// T-040: Tests for write operations\ntest('writeDaemonMeta should write daemon metadata', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const meta = {\n      pid: 54321,\n      started_at: new Date().toISOString(),\n      feature_list: '/new/path.json',\n      env_overrides: 'FOO=bar',\n      log_file: '/path/to/log'\n    };\n\n    await manager.writeDaemonMeta('feature', meta);\n    const result = await manager.readDaemonMeta('feature');\n\n    assert.deepEqual(result, meta);\n  });\n});\n\ntest('writeLastResult should write last result', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const lastResult = {\n      runId: 'run-20260312-103000',\n      completedAt: new Date().toISOString(),\n      status: 'success',\n      featuresTotal: 5,\n      featuresCompleted: 5\n    };\n\n    await manager.writeLastResult('feature', lastResult);\n    const result = await manager.getLastResult('feature');\n\n    assert.deepEqual(result, lastResult);\n  });\n});\n\n// T-041: Tests for isDaemonRunning/getDaemonPid\ntest('isDaemonRunning should return false when no daemon meta', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.isDaemonRunning('feature');\n    assert.equal(result, false);\n  });\n});\n\ntest('isDaemonRunning should return false when PID is dead', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    await createMockStateFiles(tempDir);\n\n    // Override daemon meta with dead PID\n    const stateDir = path.join(tempDir, 'state');\n    const deadMeta = {\n      pid: 99999999, // Dead PID\n      started_at: new Date().toISOString()\n    };\n    await fs.promises.writeFile(\n      path.join(stateDir, '.pipeline-meta.json'),\n      JSON.stringify(deadMeta)\n    );\n\n    const manager = createStateManager({ config });\n    const result = await manager.isDaemonRunning('feature');\n\n    assert.equal(result, false);\n  });\n});\n\ntest('isDaemonRunning should return true when PID is alive', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n\n    // Create state dir and meta with current process PID\n    const stateDir = path.join(tempDir, 'state');\n    await fs.promises.mkdir(stateDir, { recursive: true });\n\n    const liveMeta = {\n      pid: process.pid,\n      started_at: new Date().toISOString()\n    };\n    await fs.promises.writeFile(\n      path.join(stateDir, '.pipeline-meta.json'),\n      JSON.stringify(liveMeta)\n    );\n\n    const manager = createStateManager({ config });\n    const result = await manager.isDaemonRunning('feature');\n\n    assert.equal(result, true);\n  });\n});\n\ntest('getDaemonPid should return PID when daemon running', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    await createMockStateFiles(tempDir);\n\n    const manager = createStateManager({ config });\n    const result = await manager.getDaemonPid('feature');\n\n    assert.equal(result, 12345);\n  });\n});\n\ntest('getDaemonPid should return null when no daemon', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const manager = createStateManager({ config });\n\n    const result = await manager.getDaemonPid('feature');\n    assert.equal(result, null);\n  });\n});\n\n// Bugfix type tests\ntest('readDaemonMeta should handle bugfix type', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    await createMockStateFiles(tempDir, 'bugfix');\n    const manager = createStateManager({ config });\n\n    const result = await manager.readDaemonMeta('bugfix');\n\n    assert.ok(result);\n    assert.ok(result.pid);\n  });\n});\n\ntest('readPipelineState should handle bugfix type', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    await createMockStateFiles(tempDir, 'bugfix');\n    const manager = createStateManager({ config });\n\n    const result = await manager.readPipelineState('bugfix');\n\n    assert.ok(result);\n    assert.ok(result.run_id);\n  });\n});\n\n// Corrupted file handling (T-906)\ntest('readDaemonMeta should return null for corrupted JSON', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const stateDir = path.join(tempDir, 'state');\n    await fs.promises.mkdir(stateDir, { recursive: true });\n\n    // Write invalid JSON\n    await fs.promises.writeFile(\n      path.join(stateDir, '.pipeline-meta.json'),\n      'not valid json {{{'\n    );\n\n    const manager = createStateManager({ config });\n    const result = await manager.readDaemonMeta('feature');\n\n    assert.equal(result, null);\n  });\n});\n\ntest('readPipelineState should return null for corrupted JSON', async () => {\n  await withTempDir(async (tempDir) => {\n    const config = createMockConfig(tempDir);\n    const stateDir = path.join(tempDir, 'state');\n    await fs.promises.mkdir(stateDir, { recursive: true });\n\n    // Write invalid JSON\n    await fs.promises.writeFile(\n      path.join(stateDir, 'pipeline.json'),\n      'not valid json {{{'\n    );\n\n    const manager = createStateManager({ config });\n    const result = await manager.readPipelineState('feature');\n\n    assert.equal(result, null);\n  });\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/pipeline-infra/state-manager.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":46654,"output_tokens":2729,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:45:34.293Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
{"type":"user","uuid":"37e815b6-d947-4de5-af34-9ec6c9c40066","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_1815a9e8426e46478b967528","content":[{"type":"text","text":"Successfully created and wrote to new file: /Users/loneyu/SelfProjects/PrizmClaw/tests/pipeline-infra/state-manager.test.js"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:45:34.312Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
