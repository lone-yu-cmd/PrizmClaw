{"type":"user","uuid":"1a34eff5-b7a7-4134-93ac-040f5c2c40d8","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"content":[{"type":"tool_result","tool_use_id":"call_82df09fcb9334bba9745b8af","content":[{"type":"text","text":"   1→/**\n   2→ * Lock Manager Unit Tests\n   3→ * Tests for src/pipeline-infra/lock-manager.js\n   4→ *\n   5→ * F-004: Pipeline Process Controller - US-7 Concurrency Protection\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n  15→\n  16→/**\n  17→ * Helper to create temp directory for test state\n  18→ */\n  19→function createTempStateDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'lock-manager-test-'));\n  21→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  22→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  23→  fs.mkdirSync(stateDir, { recursive: true });\n  24→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  25→  return {\n  26→    tempDir,\n  27→    stateDir,\n  28→    bugfixStateDir,\n  29→    cleanup: () => {\n  30→      fs.rmSync(tempDir, { recursive: true, force: true });\n  31→    }\n  32→  };\n  33→}\n  34→\n  35→/**\n  36→ * Helper to create a mock config\n  37→ */\n  38→function createMockConfig(stateDir, bugfixStateDir) {\n  39→  const projectRoot = path.dirname(path.dirname(stateDir));\n  40→  return {\n  41→    projectRoot,\n  42→    stateDir,\n  43→    bugfixStateDir\n  44→  };\n  45→}\n  46→\n  47→test('createLockManager should be a factory function', () => {\n  48→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  49→  try {\n  50→    const config = createMockConfig(stateDir, bugfixStateDir);\n  51→    const manager = createLockManager({ config });\n  52→    assert.equal(typeof manager.acquireLock, 'function');\n  53→    assert.equal(typeof manager.releaseLock, 'function');\n  54→    assert.equal(typeof manager.isLocked, 'function');\n  55→    assert.equal(typeof manager.validateLock, 'function');\n  56→    assert.equal(typeof manager.forceUnlock, 'function');\n  57→    assert.equal(typeof manager.getLockInfo, 'function');\n  58→  } finally {\n  59→    cleanup();\n  60→  }\n  61→});\n  62→\n  63→test('acquireLock should create lock file with PID and timestamp', async () => {\n  64→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  65→  try {\n  66→    const config = createMockConfig(stateDir, bugfixStateDir);\n  67→    const manager = createLockManager({ config });\n  68→\n  69→    const result = await manager.acquireLock('feature', 12345);\n  70→\n  71→    assert.equal(result.ok, true);\n  72→    assert.ok(result.lockPath.endsWith('.pipeline.lock'));\n  73→\n  74→    // Verify lock file contents\n  75→    const lockContent = JSON.parse(fs.readFileSync(result.lockPath, 'utf8'));\n  76→    assert.equal(lockContent.pid, 12345);\n  77→    assert.ok(lockContent.acquiredAt);\n  78→    assert.equal(lockContent.type, 'feature');\n  79→    assert.ok(lockContent.hostname);\n  80→  } finally {\n  81→    cleanup();\n  82→  }\n  83→});\n  84→\n  85→test('acquireLock should fail if lock already held by live process', async () => {\n  86→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  87→  try {\n  88→    const config = createMockConfig(stateDir, bugfixStateDir);\n  89→    const manager = createLockManager({ config });\n  90→\n  91→    // First acquire with current process PID (guaranteed alive)\n  92→    const result1 = await manager.acquireLock('feature', process.pid);\n  93→    assert.equal(result1.ok, true);\n  94→\n  95→    // Try to acquire again with different PID\n  96→    const result2 = await manager.acquireLock('feature', 99999);\n  97→    assert.equal(result2.ok, false);\n  98→    assert.equal(result2.errorCode, 'LOCK_ACQUISITION_FAILED');\n  99→    assert.ok(result2.currentHolder);\n 100→    assert.equal(result2.currentHolder.pid, process.pid);\n 101→  } finally {\n 102→    cleanup();\n 103→  }\n 104→});\n 105→\n 106→test('acquireLock should succeed if lock held by dead process (stale lock)', async () => {\n 107→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 108→  try {\n 109→    const config = createMockConfig(stateDir, bugfixStateDir);\n 110→    const manager = createLockManager({ config });\n 111→\n 112→    // Create a stale lock with a non-existent PID\n 113→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 114→    const staleLock = {\n 115→      pid: 99999999, // Very unlikely to exist\n 116→      acquiredAt: new Date().toISOString(),\n 117→      type: 'feature',\n 118→      hostname: 'test'\n 119→    };\n 120→    fs.writeFileSync(lockPath, JSON.stringify(staleLock));\n 121→\n 122→    // Should succeed because stale lock\n 123→    const result = await manager.acquireLock('feature', process.pid);\n 124→    assert.equal(result.ok, true);\n 125→  } finally {\n 126→    cleanup();\n 127→  }\n 128→});\n 129→\n 130→test('releaseLock should remove lock file', async () => {\n 131→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 132→  try {\n 133→    const config = createMockConfig(stateDir, bugfixStateDir);\n 134→    const manager = createLockManager({ config });\n 135→\n 136→    // Acquire lock\n 137→    await manager.acquireLock('feature', process.pid);\n 138→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 139→    assert.ok(fs.existsSync(lockPath));\n 140→\n 141→    // Release lock\n 142→    await manager.releaseLock('feature', process.pid);\n 143→    assert.ok(!fs.existsSync(lockPath));\n 144→  } finally {\n 145→    cleanup();\n 146→  }\n 147→});\n 148→\n 149→test('releaseLock should only release lock owned by current PID', async () => {\n 150→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 151→  try {\n 152→    const config = createMockConfig(stateDir, bugfixStateDir);\n 153→    const manager = createLockManager({ config });\n 154→\n 155→    // Acquire lock with specific PID\n 156→    await manager.acquireLock('feature', process.pid);\n 157→\n 158→    // Try to release with different PID\n 159→    await manager.releaseLock('feature', 99999);\n 160→\n 161→    // Lock should still exist\n 162→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 163→    assert.ok(fs.existsSync(lockPath));\n 164→  } finally {\n 165→    cleanup();\n 166→  }\n 167→});\n 168→\n 169→test('isLocked should return true when lock exists and holder is alive', async () => {\n 170→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 171→  try {\n 172→    const config = createMockConfig(stateDir, bugfixStateDir);\n 173→    const manager = createLockManager({ config });\n 174→\n 175→    await manager.acquireLock('feature', process.pid);\n 176→    const locked = await manager.isLocked('feature');\n 177→    assert.equal(locked, true);\n 178→  } finally {\n 179→    cleanup();\n 180→  }\n 181→});\n 182→\n 183→test('isLocked should return false when no lock exists', async () => {\n 184→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 185→  try {\n 186→    const config = createMockConfig(stateDir, bugfixStateDir);\n 187→    const manager = createLockManager({ config });\n 188→\n 189→    const locked = await manager.isLocked('feature');\n 190→    assert.equal(locked, false);\n 191→  } finally {\n 192→    cleanup();\n 193→  }\n 194→});\n 195→\n 196→test('isLocked should return false when lock held by dead process', async () => {\n 197→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 198→  try {\n 199→    const config = createMockConfig(stateDir, bugfixStateDir);\n 200→    const manager = createLockManager({ config });\n 201→\n 202→    // Create a stale lock\n 203→    const lockPath = path.join(stateDir, '.pipeline.lock');\n 204→    const staleLock = {\n 205→      pid: 99999999,\n 206→      acquiredAt: new Date().toISOString(),\n 207→      type: 'feature',\n 208→      hostname: 'test'\n 209→    };\n 210→    fs.writeFileSync(lockPath, JSON.stringify(staleLock));\n 211→\n 212→    const locked = await manager.isLocked('feature');\n 213→    assert.equal(locked, false);\n 214→  } finally {\n 215→    cleanup();\n 216→  }\n 217→});\n 218→\n 219→test('validateLock should return lock info if valid', async () => {\n 220→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 221→  try {\n 222→    const config = createMockConfig(stateDir, bugfixStateDir);\n 223→    const manager = createLockManager({ config });\n 224→\n 225→    await manager.acquireLock('feature', process.pid);\n 226→    const lockInfo = await manager.validateLock('feature');\n 227→\n 228→    assert.ok(lockInfo);\n 229→    assert.equal(lockInfo.pid, process.pid);\n 230→    assert.ok(lockInfo.acquiredAt);\n 231→    assert.equal(lockInfo.type, 'feature');\n 232→  } finally {\n 233→    cleanup();\n 234→  }\n 235→});\n 236→\n 237→test('validateLock should return null if lock invalid or missing', async () => {\n 238→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 239→  try {\n 240→    const config = createMockConfig(stateDir, bugfixStateDir);\n 241→    const manager = createLockManager({ config });\n 242→\n 243→    const lockInfo = await manager.validateLock('feature');\n 244→    assert.equal(lockInfo, null);\n 245→  } finally {\n 246→    cleanup();\n 247→  }\n 248→});\n 249→\n 250→test('forceUnlock should remove lock regardless of owner', async () => {\n 251→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 252→  try {\n 253→    const config = createMockConfig(stateDir, bugfixStateDir);\n 254→    const manager = createLockManager({ config });\n 255→\n 256→    // Create a lock with a different PID\n 257→    const lockPath = path.join(