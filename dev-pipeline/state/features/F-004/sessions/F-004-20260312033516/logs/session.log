{"type":"assistant","uuid":"202603120348487cb5cdb714654e28","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"id":"202603120348487cb5cdb714654e28","content":[{"type":"tool_use","id":"call_0ddad55363f842d2a992e4e2","name":"Write","input":{"content":"import fs from 'node:fs';\nimport path from 'node:path';\n\nimport { loadPipelineInfraConfig } from './config-loader.js';\n\n/**\n * @typedef {Object} DaemonMeta\n * @property {number} pid - Daemon process ID\n * @property {string} started_at - ISO timestamp when daemon started\n * @property {string} [feature_list] - Path to feature list\n * @property {string} [env_overrides] - Environment overrides\n * @property {string} [log_file] - Path to log file\n */\n\n/**\n * @typedef {Object} PipelineState\n * @property {string} run_id - Unique run identifier\n * @property {string} status - Pipeline status ('running', 'paused', 'completed', 'failed')\n * @property {string} feature_list_path - Path to feature list\n * @property {string} created_at - ISO timestamp when pipeline started\n * @property {number} total_features - Total number of features\n * @property {number} completed_features - Number of completed features\n * @property {string} [paused_at] - ISO timestamp when paused\n */\n\n/**\n * @typedef {Object} CurrentSession\n * @property {string} feature_id - Current feature ID\n * @property {string} session_id - Current session ID\n * @property {string} started_at - ISO timestamp when session started\n * @property {string} status - Session status\n */\n\n/**\n * @typedef {Object} LastResult\n * @property {string} runId - Run identifier\n * @property {string} completedAt - ISO timestamp when completed\n * @property {string} status - Result status ('success', 'failed', 'partial')\n * @property {number} featuresTotal - Total features\n * @property {number} featuresCompleted - Completed features\n * @property {number} [exitCode] - Exit code\n * @property {string} [message] - Result message\n */\n\n/**\n * Check if a process is alive.\n * @param {number} pid - Process ID to check\n * @returns {boolean} True if process is alive\n */\nfunction isProcessAlive(pid) {\n  try {\n    process.kill(pid, 0);\n    return true;\n  } catch {\n    return false;\n  }\n}\n\n/**\n * Get the state directory for a pipeline type.\n * @param {string} type - Pipeline type ('feature' or 'bugfix')\n * @param {Object} config - Pipeline config\n * @returns {string} State directory path\n */\nfunction getStateDir(type, config) {\n  return type === 'feature' ? config.stateDir : config.bugfixStateDir;\n}\n\n/**\n * Safely read a JSON file.\n * @param {string} filePath - Path to JSON file\n * @returns {Object|null} Parsed JSON or null if not exists/invalid\n */\nfunction readJsonFile(filePath) {\n  try {\n    const content = fs.readFileSync(filePath, 'utf8');\n    return JSON.parse(content);\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Safely write a JSON file atomically.\n * @param {string} filePath - Path to JSON file\n * @param {Object} data - Data to write\n */\nfunction writeJsonFile(filePath, data) {\n  const dir = path.dirname(filePath);\n\n  // Ensure directory exists\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n\n  // Write to temp file first\n  const tempPath = `${filePath}.${Date.now()}.tmp`;\n  fs.writeFileSync(tempPath, JSON.stringify(data, null, 2));\n\n  // Atomic rename\n  fs.renameSync(tempPath, filePath);\n}\n\n/**\n * Create a state manager instance.\n * @param {Object} options - Options\n * @param {Object} [options.config] - Pipeline config (will load if not provided)\n * @returns {Object} State manager interface\n */\nexport function createStateManager(options = {}) {\n  const { config = loadPipelineInfraConfig() } = options;\n\n  return {\n    /**\n     * Read daemon metadata for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<DaemonMeta|null>} Daemon metadata or null\n     */\n    async readDaemonMeta(type) {\n      const stateDir = getStateDir(type, config);\n      const metaPath = path.join(stateDir, '.pipeline-meta.json');\n      return readJsonFile(metaPath);\n    },\n\n    /**\n     * Read pipeline state for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<PipelineState|null>} Pipeline state or null\n     */\n    async readPipelineState(type) {\n      const stateDir = getStateDir(type, config);\n      const statePath = path.join(stateDir, 'pipeline.json');\n      return readJsonFile(statePath);\n    },\n\n    /**\n     * Read current session for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<CurrentSession|null>} Current session or null\n     */\n    async readCurrentSession(type) {\n      const stateDir = getStateDir(type, config);\n      const sessionPath = path.join(stateDir, 'current-session.json');\n      return readJsonFile(sessionPath);\n    },\n\n    /**\n     * Get the last result for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<LastResult|null>} Last result or null\n     */\n    async getLastResult(type) {\n      const stateDir = getStateDir(type, config);\n      const resultPath = path.join(stateDir, '.last-result.json');\n      return readJsonFile(resultPath);\n    },\n\n    /**\n     * Write daemon metadata for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @param {DaemonMeta} meta - Daemon metadata\n     * @returns {Promise<void>}\n     */\n    async writeDaemonMeta(type, meta) {\n      const stateDir = getStateDir(type, config);\n      const metaPath = path.join(stateDir, '.pipeline-meta.json');\n      writeJsonFile(metaPath, meta);\n    },\n\n    /**\n     * Write the last result for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @param {LastResult} result - Last result\n     * @returns {Promise<void>}\n     */\n    async writeLastResult(type, result) {\n      const stateDir = getStateDir(type, config);\n      const resultPath = path.join(stateDir, '.last-result.json');\n      writeJsonFile(resultPath, result);\n    },\n\n    /**\n     * Check if the daemon is running for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<boolean>} True if daemon is running\n     */\n    async isDaemonRunning(type) {\n      const meta = await this.readDaemonMeta(type);\n      if (!meta || !meta.pid) {\n        return false;\n      }\n      return isProcessAlive(meta.pid);\n    },\n\n    /**\n     * Get the daemon PID for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<number|null>} Daemon PID or null\n     */\n    async getDaemonPid(type) {\n      const meta = await this.readDaemonMeta(type);\n      return meta?.pid || null;\n    }\n  };\n}\n\n// Default instance for convenience\nlet defaultManager = null;\n\n/**\n * Get the default state manager instance.\n * @returns {Object} State manager instance\n */\nexport function getDefaultStateManager() {\n  if (!defaultManager) {\n    defaultManager = createStateManager();\n  }\n  return defaultManager;\n}\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/pipeline-infra/state-manager.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":62852,"output_tokens":1693,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:49:19.010Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
