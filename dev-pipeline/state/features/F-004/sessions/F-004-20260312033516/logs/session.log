error.includes('not found') || error.includes('没有') || error.includes('no pipeline')) {\n        await reply('⚠️ 没有找到运行中的管道。');\n      } else {\n        await reply(`❌ 停止失败: ${error || '未知错误'}`);\n      }\n    }\n  } catch (error) {\n    await reply(`❌ 停止失败: ${error.message}`);\n  }\n}"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":94691,"output_tokens":566,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:55:37.750Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
