{"type":"assistant","uuid":"202603120348096fc4af1ae1d74cc0","session_id":"bb910a42-1a56-4ede-aaca-e9123e8e7d31","message":{"id":"202603120348096fc4af1ae1d74cc0","content":[{"type":"tool_use","id":"call_ac2b0f08cf9948afa6a327fd","name":"Write","input":{"content":"import fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nimport { loadPipelineInfraConfig } from './config-loader.js';\n\n/**\n * @typedef {Object} LockInfo\n * @property {number} pid - Process ID holding the lock\n * @property {string} acquiredAt - ISO timestamp when lock was acquired\n * @property {string} type - Pipeline type ('feature' or 'bugfix')\n * @property {string} [hostname] - Hostname of the machine holding the lock\n */\n\n/**\n * @typedef {Object} LockResult\n * @property {boolean} ok - Whether the lock was acquired\n * @property {string} [lockPath] - Path to the lock file\n * @property {string} [errorCode] - Error code if failed\n * @property {LockInfo} [currentHolder] - Current lock holder if failed\n */\n\n/**\n * Check if a process is alive.\n * @param {number} pid - Process ID to check\n * @returns {boolean} True if process is alive\n */\nfunction isProcessAlive(pid) {\n  try {\n    // Sending signal 0 doesn't kill the process, just checks if it exists\n    process.kill(pid, 0);\n    return true;\n  } catch {\n    return false;\n  }\n}\n\n/**\n * Get the lock file path for a pipeline type.\n * @param {string} type - Pipeline type ('feature' or 'bugfix')\n * @param {Object} config - Pipeline config\n * @returns {string} Lock file path\n */\nfunction getLockFilePath(type, config) {\n  const stateDir = type === 'feature' ? config.stateDir : config.bugfixStateDir;\n  return path.join(stateDir, '.pipeline.lock');\n}\n\n/**\n * Read lock file contents.\n * @param {string} lockPath - Path to lock file\n * @returns {LockInfo|null} Lock info or null if not exists\n */\nfunction readLockFile(lockPath) {\n  try {\n    const content = fs.readFileSync(lockPath, 'utf8');\n    return JSON.parse(content);\n  } catch {\n    return null;\n  }\n}\n\n/**\n * Write lock file atomically using temp file + rename.\n * @param {string} lockPath - Path to lock file\n * @param {LockInfo} lockInfo - Lock info to write\n */\nfunction writeLockFile(lockPath, lockInfo) {\n  const dir = path.dirname(lockPath);\n\n  // Ensure directory exists\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n\n  // Write to temp file first\n  const tempPath = `${lockPath}.${Date.now()}.tmp`;\n  fs.writeFileSync(tempPath, JSON.stringify(lockInfo, null, 2));\n\n  // Atomic rename\n  fs.renameSync(tempPath, lockPath);\n}\n\n/**\n * Delete lock file.\n * @param {string} lockPath - Path to lock file\n */\nfunction deleteLockFile(lockPath) {\n  try {\n    fs.unlinkSync(lockPath);\n  } catch {\n    // Ignore if file doesn't exist\n  }\n}\n\n/**\n * Create a lock manager instance.\n * @param {Object} options - Options\n * @param {Object} [options.config] - Pipeline config (will load if not provided)\n * @returns {Object} Lock manager interface\n */\nexport function createLockManager(options = {}) {\n  const { config = loadPipelineInfraConfig() } = options;\n\n  return {\n    /**\n     * Acquire a lock for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @param {number} [pid=process.pid] - PID to use for lock\n     * @returns {Promise<LockResult>} Lock result\n     */\n    async acquireLock(type, pid = process.pid) {\n      const lockPath = getLockFilePath(type, config);\n\n      // Check if lock exists\n      const existingLock = readLockFile(lockPath);\n\n      if (existingLock) {\n        // Check if the process holding the lock is still alive\n        if (isProcessAlive(existingLock.pid)) {\n          return {\n            ok: false,\n            errorCode: 'LOCK_ACQUISITION_FAILED',\n            currentHolder: existingLock\n          };\n        }\n        // Stale lock - clean it up\n        deleteLockFile(lockPath);\n      }\n\n      // Acquire the lock\n      const lockInfo = {\n        pid,\n        acquiredAt: new Date().toISOString(),\n        type,\n        hostname: os.hostname()\n      };\n\n      try {\n        writeLockFile(lockPath, lockInfo);\n        return {\n          ok: true,\n          lockPath\n        };\n      } catch (error) {\n        return {\n          ok: false,\n          errorCode: 'LOCK_ACQUISITION_FAILED',\n          currentHolder: null\n        };\n      }\n    },\n\n    /**\n     * Release a lock for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @param {number} [pid=process.pid] - PID that holds the lock\n     * @returns {Promise<void>}\n     */\n    async releaseLock(type, pid = process.pid) {\n      const lockPath = getLockFilePath(type, config);\n      const existingLock = readLockFile(lockPath);\n\n      // Only release if we hold the lock (or if no lock exists)\n      if (existingLock && existingLock.pid !== pid) {\n        // Someone else holds the lock, don't release it\n        return;\n      }\n\n      deleteLockFile(lockPath);\n    },\n\n    /**\n     * Check if a lock exists for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<boolean>} True if locked\n     */\n    async isLocked(type) {\n      const lockPath = getLockFilePath(type, config);\n      const existingLock = readLockFile(lockPath);\n\n      if (!existingLock) {\n        return false;\n      }\n\n      // Check if the process holding the lock is still alive\n      return isProcessAlive(existingLock.pid);\n    },\n\n    /**\n     * Validate a lock for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<{valid: boolean, stale?: boolean, lockInfo?: LockInfo}>}\n     */\n    async validateLock(type) {\n      const lockPath = getLockFilePath(type, config);\n      const existingLock = readLockFile(lockPath);\n\n      if (!existingLock) {\n        return { valid: false };\n      }\n\n      const isAlive = isProcessAlive(existingLock.pid);\n      return {\n        valid: isAlive,\n        stale: !isAlive,\n        lockInfo: existingLock\n      };\n    },\n\n    /**\n     * Force unlock a pipeline type (admin operation).\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<{ok: boolean, previousPid?: number}>}\n     */\n    async forceUnlock(type) {\n      const lockPath = getLockFilePath(type, config);\n      const existingLock = readLockFile(lockPath);\n\n      deleteLockFile(lockPath);\n\n      return {\n        ok: true,\n        previousPid: existingLock?.pid\n      };\n    },\n\n    /**\n     * Get lock info for a pipeline type.\n     * @param {string} type - Pipeline type ('feature' or 'bugfix')\n     * @returns {Promise<LockInfo|null>} Lock info or null\n     */\n    async getLockInfo(type) {\n      const lockPath = getLockFilePath(type, config);\n      return readLockFile(lockPath);\n    }\n  };\n}\n\n// Default instance for convenience\nlet defaultManager = null;\n\n/**\n * Get the default lock manager instance.\n * @returns {Object} Lock manager instance\n */\nexport function getDefaultLockManager() {\n  if (!defaultManager) {\n    defaultManager = createLockManager();\n  }\n  return defaultManager;\n}\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/pipeline-infra/lock-manager.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":60750,"output_tokens":1747,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_26b1495f4b02474583c54277","__timestamp":"2026-03-11T19:48:38.850Z","_requestId":"deb8a7f51c6541338686a9cbc6281864"}
