{"type":"user","uuid":"966371c0-92f7-4117-a671-833448846304","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde9165a8419b49340249d5a17331","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Tests for F-005: Pipeline Status Aggregation and Log Streaming\n   3→ *\n   4→ * Tests for US-1 through US-6:\n   5→ * - US-1: Aggregated Status Query\n   6→ * - US-2: Paginated Logs Query\n   7→ * - US-3: Message Length Compliance\n   8→ * - US-4: Heartbeat Progress Push\n   9→ * - US-5: Error Summary Push\n  10→ * - US-6: Diagnostic Error Messages\n  11→ */\n  12→\n  13→import test from 'node:test';\n  14→import assert from 'node:assert/strict';\n  15→import fs from 'node:fs';\n  16→import path from 'node:path';\n  17→import os from 'node:os';\n  18→\n  19→import { createStatusAggregator } from '../../src/services/status-aggregator.js';\n  20→import { createLogPager } from '../../src/services/log-pager.js';\n  21→import { createTelegramPusher } from '../../src/services/telegram-pusher.js';\n  22→\n  23→// ============================================================\n  24→// Test Helpers\n  25→// ============================================================\n  26→\n  27→function createTempStateDir() {\n  28→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f005-integration-test-'));\n  29→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  30→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  31→  fs.mkdirSync(stateDir, { recursive: true });\n  32→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  33→  return {\n  34→    tempDir,\n  35→    stateDir,\n  36→    bugfixStateDir,\n  37→    cleanup: () => {\n  38→      fs.rmSync(tempDir, { recursive: true, force: true });\n  39→    }\n  40→  };\n  41→}\n  42→\n  43→function createMockConfig(stateDir, bugfixStateDir) {\n  44→  const projectRoot = path.dirname(path.dirname(stateDir));\n  45→  return {\n  46→    projectRoot,\n  47→    stateDir,\n  48→    bugfixStateDir\n  49→  };\n  50→}\n  51→\n  52→function createMockBot() {\n  53→  const sentMessages = [];\n  54→  const sentFiles = [];\n  55→\n  56→  return {\n  57→    telegram: {\n  58→      sendMessage: async (chatId, text, options = {}) => {\n  59→        sentMessages.push({ chatId, text, options });\n  60→        return { message_id: Date.now() };\n  61→      },\n  62→      sendDocument: async (chatId, document, options = {}) => {\n  63→        sentFiles.push({ chatId, document, options });\n  64→        return { message_id: Date.now() };\n  65→      }\n  66→    },\n  67→    _sentMessages: sentMessages,\n  68→    _sentFiles: sentFiles\n  69→  };\n  70→}\n  71→\n  72→// ============================================================\n  73→// US-1: Aggregated Status Query Integration Tests (T-104)\n  74→// ============================================================\n  75→\n  76→test('[US-1] Full status flow should aggregate running state correctly', async () => {\n  77→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  78→  try {\n  79→    const config = createMockConfig(stateDir, bugfixStateDir);\n  80→\n  81→    // Write state files\n  82→    fs.writeFileSync(\n  83→      path.join(stateDir, '.pipeline-meta.json'),\n  84→      JSON.stringify({\n  85→        pid: process.pid,\n  86→        started_at: new Date(Date.now() - 3600000).toISOString(),\n  87→        feature_list: '/path/to/feature-list.json'\n  88→      })\n  89→    );\n  90→\n  91→    fs.writeFileSync(\n  92→      path.join(stateDir, 'pipeline.json'),\n  93→      JSON.stringify({\n  94→        run_id: 'run-001',\n  95→        status: 'running',\n  96→        total_features: 10,\n  97→        completed_features: 4,\n  98→        failed_features: 1,\n  99→        in_progress_features: 1\n 100→      })\n 101→    );\n 102→\n 103→    fs.writeFileSync(\n 104→      path.join(stateDir, 'current-session.json'),\n 105→      JSON.stringify({\n 106→        feature_id: 'F-005',\n 107→        started_at: new Date().toISOString()\n 108→      })\n 109→    );\n 110→\n 111→    const aggregator = createStatusAggregator({ config });\n 112→    const status = await aggregator.aggregateStatus('feature');\n 113→\n 114→    assert.equal(status.stage, 'running');\n 115→    assert.equal(status.type, 'feature');\n 116→    assert.ok(status.current);\n 117→    assert.equal(status.current.featureId, 'F-005');\n 118→    assert.ok(status.progress);\n 119→    assert.equal(status.progress.total, 10);\n 120→    assert.equal(status.progress.completed, 4);\n 121→\n 122→    // Test formatting\n 123→    const formatted = aggregator.formatStatusForTelegram(status);\n 124→    assert.ok(formatted.includes('运行中') || formatted.includes('running'));\n 125→    assert.ok(formatted.includes('F-005'));\n 126→  } finally {\n 127→    cleanup();\n 128→  }\n 129→});\n 130→\n 131→test('[US-1] Status should handle idle state with last result', async () => {\n 132→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 133→  try {\n 134→    const config = createMockConfig(stateDir, bugfixStateDir);\n 135→\n 136→    fs.writeFileSync(\n 137→      path.join(stateDir, '.last-result.json'),\n 138→      JSON.stringify({\n 139→        runId: 'run-previous',\n 140→        completedAt: new Date().toISOString(),\n 141→        status: 'success',\n 142→        featuresTotal: 5,\n 143→        featuresCompleted: 5\n 144→      })\n 145→    );\n 146→\n 147→    const aggregator = createStatusAggregator({ config });\n 148→    const status = await aggregator.aggregateStatus('feature');\n 149→\n 150→    assert.equal(status.stage, 'idle');\n 151→    assert.ok(status.lastResult);\n 152→    assert.equal(status.lastResult.status, 'success');\n 153→  } finally {\n 154→    cleanup();\n 155→  }\n 156→});\n 157→\n 158→// ============================================================\n 159→// US-2: Paginated Logs Query Integration Tests (T-115)\n 160→// ============================================================\n 161→\n 162→test('[US-2] Logs should paginate correctly', async () => {\n 163→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 164→  try {\n 165→    const config = createMockConfig(stateDir, bugfixStateDir);\n 166→\n 167→    // Generate log file\n 168→    const lines = [];\n 169→    for (let i = 1; i <= 100; i++) {\n 170→      lines.push(`[${new Date().toISOString()}] [INFO] Log line ${i}`);\n 171→    }\n 172→    fs.writeFileSync(\n 173→      path.join(stateDir, 'pipeline-daemon.log'),\n 174→      lines.join('\\n')\n 175→    );\n 176→\n 177→    const pager = createLogPager({ config });\n 178→\n 179→    // Test first page\n 180→    const page1 = await pager.readLogPage('feature', { lines: 20, offset: 0 });\n 181→    assert.ok(page1.ok);\n 182→    assert.ok(page1.logs);\n 183→    assert.equal(page1.metadata.requestedLines, 20);\n 184→\n 185→    // Test second page\n 186→    const page2 = await pager.readLogPage('feature', { lines: 20, offset: 20 });\n 187→    assert.ok(page2.ok);\n 188→  } finally {\n 189→    cleanup();\n 190→  }\n 191→});\n 192→\n 193→test('[US-2] Logs should return friendly message when missing', async () => {\n 194→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 195→  try {\n 196→    const config = createMockConfig(stateDir, bugfixStateDir);\n 197→    const pager = createLogPager({ config });\n 198→\n 199→    const result = await pager.readLogPage('feature', { lines: 50 });\n 200→\n 201→    assert.ok(result.ok);\n 202→    assert.ok(result.message || result.logs === '');\n 203→  } finally {\n 204→    cleanup();\n 205→  }\n 206→});\n 207→\n 208→// ============================================================\n 209→// US-3: Message Length Compliance Integration Tests (T-124)\n 210→// ============================================================\n 211→\n 212→test('[US-3] Long messages should be chunked with segment numbering', async () => {\n 213→  const bot = createMockBot();\n 214→  const pusher = createTelegramPusher({\n 215→    bot,\n 216→    targetChatId: 123456,\n 217→    segmentInterval: 10 // Fast for testing\n 218→  });\n 219→\n 220→  // Create a message longer than 4000 chars\n 221→  const longMessage = 'x'.repeat(10000);\n 222→  await pusher.sendMessageChunked(123456, longMessage);\n 223→\n 224→  // Should have sent multiple messages\n 225→  assert.ok(bot._sentMessages.length >= 2);\n 226→\n 227→  // Check segment numbering\n 228→  const hasSegmentNumber = bot._sentMessages.some(m =>\n 229→    m.text.includes('[1/') || m.text.includes('[2/')\n 230→  );\n 231→  assert.ok(hasSegmentNumber);\n 232→});\n 233→\n 234→test('[US-3] Should send as file when threshold exceeded', async () => {\n 235→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 236→  try {\n 237→    const config = createMockConfig(stateDir, bugfixStateDir);\n 238→    const pager = createLogPager({ config });\n 239→\n 240→    // Create large log content\n 241→    const largeLog = 'x'.repeat(5000);\n 242→    const shouldSendAsFile = pager.shouldSendAsFile(largeLog);\n 243→\n 244→    assert.equal(shouldSendAsFile, true);\n 245→  } finally {\n 246→    cleanup();\n 247→  }\n 248→});\n 249→\n 250→// ============================================================\n 251→// US-4: Heartbeat Progress Push Integration Tests (T-136)\n 252→// ============================================================\n 253→\n 254→test('[US-4] Heartbeat should push with throttle', async () => {\n 255→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 256→  try {\n 257→    const config = createMockConfig(stateDir, bugfixStateDir);\n 258→\n 259→    fs.writeFileSync(\n 260→      path.join(stateDir, '.pipeline-meta.json'),\n 261→      JSON.stringify({\n 262→        pid: process.pid,\n 263→        started_at: new Date().toISOString()\n 264→      })\n 265→    );\n 266→\n 267→    const bot = createMockBot();\n 268→    const aggregator = createStatusAggregator({ config });\n 269→    const pusher = createTelegramPusher({\n 270→      bot,\n 271→      targetChatId: 123456,\n 272→      heartbeatInterval: 50, // Fast for testing\n 273→      throttleInterval: 10\n 274→    });\n 275→\n 276→    pusher.startHeartbeat('feature', aggregator);\n 277→\n 278→    // Wait for heartbeat\n 279→    await new Promise(resolve => setTimeout(resolve, 100));\n 280→\n 281→    pusher.stopHeartbeat('feature');\n 282→\n 283→    // Should have sent at least one message\n 284→    assert.ok(bot._sentMessages.length >= 1);\n 285→  } finally {\n 286→    cleanup();\n 287→  }\n 288→});\n 289→\n 290→// ============================================================\n 291→// US-5: Error Summary Push Integration Tests (T-144)\n 292→// ============================================================\n 293→\n 294→test('[US-5] Error summary should include all required info', async () => {\n 295→  const bot = createMockBot();\n 296→  const pusher = createTelegramPusher({\n 297→    bot,\n 298→    targetChatId: 123456,\n 299→    errorLinesCount: 5\n 300→  });\n 301→\n 302→  const error = {\n 303→    type: 'execution_error',\n 304→    message: 'Script execution failed',\n 305→    duration: 180,\n 306→    logLines: ['Error 1', 'Error 2', 'Error 3', 'Error 4', 'Error 5']\n 307→  };\n 308→\n 309→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 310→\n 311→  assert.equal(bot._sentMessages.length, 1);\n 312→  const text = bot._sentMessages[0].text;\n 313→\n 314→  // Should include feature ID\n 315→  assert.ok(text.includes('F-005'));\n 316→\n 317→  // Should include error type\n 318→  assert.ok(text.includes('execution_error') || text.includes('类型'));\n 319→\n 320→  // Should include duration\n 321→  assert.ok(text.includes('180') || text.includes('3m') || text.includes('执行时间'));\n 322→\n 323→  // Should include log lines\n 324→  assert.ok(text.includes('Error'));\n 325→});\n 326→\n 327→// ============================================================\n 328→// US-6: Diagnostic Error Messages Integration Tests (T-155)\n 329→// ============================================================\n 330→\n 331→test('[US-6] Should provide diagnostic for missing state files', async () => {\n 332→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 333→  try {\n 334→    const config = createMockConfig(stateDir, bugfixStateDir);\n 335→    const aggregator = createStatusAggregator({ config });\n 336→\n 337→    const status = await aggregator.aggregateStatus('feature');\n 338→\n 339→    // Should return idle state, not throw\n 340→    assert.equal(status.stage, 'idle');\n 341→  } finally {\n 342→    cleanup();\n 343→  }\n 344→});\n 345→\n 346→test('[US-6] Should handle corrupted JSON gracefully', async () => {\n 347→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 348→  try {\n 349→    const config = createMockConfig(stateDir, bugfixStateDir);\n 350→\n 351→    // Write corrupted JSON\n 352→    fs.writeFileSync(\n 353→      path.join(stateDir, '.pipeline-meta.json'),\n 354→      'not valid json {{{'\n 355→    );\n 356→\n 357→    const aggregator = createStatusAggregator({ config });\n 358→    const status = await aggregator.aggregateStatus('feature');\n 359→\n 360→    // Should not throw, return idle\n 361→    assert.equal(status.stage, 'idle');\n 362→  } finally {\n 363→    cleanup();\n 364→  }\n 365→});\n 366→\n 367→test('[US-6] Should provide diagnostic for missing log files', async () => {\n 368→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 369→  try {\n 370→    const config = createMockConfig(stateDir, bugfixStateDir);\n 371→    const pager = createLogPager({ config });\n 372→\n 373→    const result = await pager.readLogPage('feature', { lines: 50 });\n 374→\n 375→    assert.ok(result.ok);\n 376→    assert.ok(result.message || result.logs === '');\n 377→    assert.ok(result.metadata.logPath);\n 378→  } finally {\n 379→    cleanup();\n 380→  }\n 381→});\n 382→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:23:17.334Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
