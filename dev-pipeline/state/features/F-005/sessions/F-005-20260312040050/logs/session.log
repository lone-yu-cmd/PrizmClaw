{"type":"user","uuid":"2321ce9b-8ef0-4b12-89df-468d5170aef6","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90838c17d255e755446529bc33","content":[{"type":"text","text":"   1→DOC_LEVEL: L2\n   2→MODULE: runtime/services\n   3→PATH: src/services/**\n   4→DESCRIPTION: runtime service layer for chat/session/system actions plus pipeline control facade\n   5→\n   6→KEY_FILES:\n   7→- src/services/chat-service.js\n   8→- src/services/chat-queue.js\n   9→- src/services/session-store.js\n  10→- src/services/realtime-hub.js\n  11→- src/services/system-exec-service.js\n  12→- src/services/pipeline-control-service.js\n  13→- src/services/pipeline-controller.js\n  14→- src/services/plan-ingestion-service.js\n  15→- src/services/status-aggregator.js\n  16→- src/services/log-pager.js\n  17→- src/services/telegram-pusher.js\n  18→\n  19→PUBLIC_APIS:\n  20→- chatWithSession({ channel, sessionId, message, realtimeHooks })\n  21→- resetSession({ channel, sessionId })\n  22→- pipeline control: startPipeline/getPipelineStatus/stopPipeline/retryTarget/getPipelineLogs/resetTarget\n  23→- pipeline controller (F-004): createPipelineController -> startPipeline/stopPipeline/retryTarget/runSingle/getStatus/getLogs/forceUnlock\n  24→- plan ingestion: validate/save/listVersions/getVersion/setCurrent/getCurrent/rollback/getActivePath\n  25→- status aggregator (F-005): createStatusAggregator -> aggregateStatus/formatStatusForTelegram/calculateProgress/getErrorSummary\n  26→- log pager (F-005): createLogPager -> readLogPage/extractErrorLines/shouldSendAsFile/formatLogsForTelegram\n  27→- telegram pusher (F-005): createTelegramPusher -> startHeartbeat/stopHeartbeat/pushErrorSummary/sendMessageChunked/sendFile\n  28→\n  29→TRAPS:\n  30→- chat operations are serialized by session key; keep async queue semantics unchanged\n  31→- pipeline-control-service must delegate to script-runner instead of shell string concatenation\n  32→- pipeline-controller must use lock-manager for concurrency protection (F-004)\n  33→- runSingle must NOT acquire lock (independent execution, D5)\n  34→\n  35→DECISIONS:\n  36→- 2026-03-10 | f001-pipeline-service | expose logs/reset methods in pipeline-control-service to satisfy US3 reusable control surface\n  37→- 2026-03-12 | f003-plan-ingestion | add plan-ingestion-service for schema validation, version management, and plan registry\n  38→- 2026-03-12 | f004-pipeline-controller | new module for unified pipeline control with lock management (D4)\n  39→- 2026-03-13 | f005-status-logs | add status-aggregator, log-pager, telegram-pusher for pipeline status aggregation and log streaming\n  40→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:21.224Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
{"type":"user","uuid":"c29a1141-12fb-428d-94bc-a9287891fe93","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde9085716afd55029fd7a09d3eb8","content":[{"type":"text","text":"   1→/**\n   2→ * Status Aggregator Unit Tests\n   3→ * Tests for src/services/status-aggregator.js\n   4→ *\n   5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-1: Aggregated Status Query\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createStatusAggregator } from '../../src/services/status-aggregator.js';\n  15→\n  16→/**\n  17→ * Helper to create temp directory for test state\n  18→ */\n  19→function createTempStateDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'status-aggregator-test-'));\n  21→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  22→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  23→  fs.mkdirSync(stateDir, { recursive: true });\n  24→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  25→  return {\n  26→    tempDir,\n  27→    stateDir,\n  28→    bugfixStateDir,\n  29→    cleanup: () => {\n  30→      fs.rmSync(tempDir, { recursive: true, force: true });\n  31→    }\n  32→  };\n  33→}\n  34→\n  35→/**\n  36→ * Helper to create a mock config\n  37→ */\n  38→function createMockConfig(stateDir, bugfixStateDir) {\n  39→  const projectRoot = path.dirname(path.dirname(stateDir));\n  40→  return {\n  41→    projectRoot,\n  42→    stateDir,\n  43→    bugfixStateDir\n  44→  };\n  45→}\n  46→\n  47→/**\n  48→ * Helper to create sample daemon meta\n  49→ */\n  50→function createSampleDaemonMeta() {\n  51→  return {\n  52→    pid: process.pid, // Use current process for alive check\n  53→    started_at: new Date(Date.now() - 3600000).toISOString(), // 1 hour ago\n  54→    feature_list: '/path/to/feature-list.json',\n  55→    env_overrides: '',\n  56→    log_file: '/path/to/pipeline-daemon.log'\n  57→  };\n  58→}\n  59→\n  60→/**\n  61→ * Helper to create sample pipeline state\n  62→ */\n  63→function createSamplePipelineState() {\n  64→  return {\n  65→    run_id: 'run-20260313-103000',\n  66→    status: 'running',\n  67→    feature_list_path: '/path/to/feature-list.json',\n  68→    created_at: new Date(Date.now() - 1800000).toISOString(), // 30 min ago\n  69→    total_features: 10,\n  70→    completed_features: 4,\n  71→    failed_features: 1,\n  72→    in_progress_features: 1\n  73→  };\n  74→}\n  75→\n  76→/**\n  77→ * Helper to create sample current session\n  78→ */\n  79→function createSampleCurrentSession() {\n  80→  return {\n  81→    feature_id: 'F-005',\n  82→    started_at: new Date(Date.now() - 600000).toISOString() // 10 min ago\n  83→  };\n  84→}\n  85→\n  86→/**\n  87→ * Helper to create sample last result\n  88→ */\n  89→function createSampleLastResult() {\n  90→  return {\n  91→    runId: 'run-20260312-103000',\n  92→    completedAt: new Date(Date.now() - 86400000).toISOString(), // 1 day ago\n  93→    status: 'success',\n  94→    featuresTotal: 8,\n  95→    featuresCompleted: 8,\n  96→    featuresFailed: 0,\n  97→    duration: 7200 // 2 hours in seconds\n  98→  };\n  99→}\n 100→\n 101→// ============================================================\n 102→// Factory Tests (T-015)\n 103→// ============================================================\n 104→\n 105→test('createStatusAggregator should be a factory function', () => {\n 106→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 107→  try {\n 108→    const config = createMockConfig(stateDir, bugfixStateDir);\n 109→    const aggregator = createStatusAggregator({ config });\n 110→\n 111→    assert.equal(typeof aggregator.aggregateStatus, 'function');\n 112→    assert.equal(typeof aggregator.formatStatusForTelegram, 'function');\n 113→    assert.equal(typeof aggregator.calculateProgress, 'function');\n 114→    assert.equal(typeof aggregator.getErrorSummary, 'function');\n 115→    assert.equal(typeof aggregator.determinePipelineStage, 'function');\n 116→  } finally {\n 117→    cleanup();\n 118→  }\n 119→});\n 120→\n 121→// ============================================================\n 122→// aggregateStatus Tests (T-010, T-015)\n 123→// ============================================================\n 124→\n 125→test('aggregateStatus should return idle state when no pipeline is running', async () => {\n 126→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 127→  try {\n 128→    const config = createMockConfig(stateDir, bugfixStateDir);\n 129→    const aggregator = createStatusAggregator({ config });\n 130→\n 131→    const result = await aggregator.aggregateStatus('feature');\n 132→\n 133→    assert.equal(result.stage, 'idle');\n 134→    assert.equal(result.type, 'feature');\n 135→    assert.ok(result.timestamp);\n 136→  } finally {\n 137→    cleanup();\n 138→  }\n 139→});\n 140→\n 141→test('aggregateStatus should return running state when pipeline is active', async () => {\n 142→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 143→  try {\n 144→    const config = createMockConfig(stateDir, bugfixStateDir);\n 145→\n 146→    // Write daemon meta with alive PID\n 147→    fs.writeFileSync(\n 148→      path.join(stateDir, '.pipeline-meta.json'),\n 149→      JSON.stringify(createSampleDaemonMeta())\n 150→    );\n 151→\n 152→    // Write pipeline state\n 153→    fs.writeFileSync(\n 154→      path.join(stateDir, 'pipeline.json'),\n 155→      JSON.stringify(createSamplePipelineState())\n 156→    );\n 157→\n 158→    // Write current session\n 159→    fs.writeFileSync(\n 160→      path.join(stateDir, 'current-session.json'),\n 161→      JSON.stringify(createSampleCurrentSession())\n 162→    );\n 163→\n 164→    const aggregator = createStatusAggregator({ config });\n 165→    const result = await aggregator.aggregateStatus('feature');\n 166→\n 167→    assert.equal(result.stage, 'running');\n 168→    assert.equal(result.type, 'feature');\n 169→    assert.ok(result.current);\n 170→    assert.equal(result.current.featureId, 'F-005');\n 171→    assert.ok(result.current.duration > 0);\n 172→  } finally {\n 173→    cleanup();\n 174→  }\n 175→});\n 176→\n 177→test('aggregateStatus should include last result when not running', async () => {\n 178→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 179→  try {\n 180→    const config = createMockConfig(stateDir, bugfixStateDir);\n 181→\n 182→    // Write last result\n 183→    fs.writeFileSync(\n 184→      path.join(stateDir, '.last-result.json'),\n 185→      JSON.stringify(createSampleLastResult())\n 186→    );\n 187→\n 188→    const aggregator = createStatusAggregator({ config });\n 189→    const result = await aggregator.aggregateStatus('feature');\n 190→\n 191→    assert.equal(result.stage, 'idle');\n 192→    assert.ok(result.lastResult);\n 193→    assert.equal(result.lastResult.runId, 'run-20260312-103000');\n 194→    assert.equal(result.lastResult.status, 'success');\n 195→  } finally {\n 196→    cleanup();\n 197→  }\n 198→});\n 199→\n 200→test('aggregateStatus should work for bugfix type', async () => {\n 201→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 202→  try {\n 203→    const config = createMockConfig(stateDir, bugfixStateDir);\n 204→\n 205→    // Write daemon meta for bugfix\n 206→    fs.writeFileSync(\n 207→      path.join(bugfixStateDir, '.pipeline-meta.json'),\n 208→      JSON.stringify(createSampleDaemonMeta())\n 209→    );\n 210→\n 211→    const aggregator = createStatusAggregator({ config });\n 212→    const result = await aggregator.aggregateStatus('bugfix');\n 213→\n 214→    assert.equal(result.type, 'bugfix');\n 215→  } finally {\n 216→    cleanup();\n 217→  }\n 218→});\n 219→\n 220→// ============================================================\n 221→// determinePipelineStage Tests (T-011, T-016)\n 222→// ============================================================\n 223→\n 224→test('determinePipelineStage should return running when daemon is alive', async () => {\n 225→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 226→  try {\n 227→    const config = createMockConfig(stateDir, bugfixStateDir);\n 228→\n 229→    fs.writeFileSync(\n 230→      path.join(stateDir, '.pipeline-meta.json'),\n 231→      JSON.stringify(createSampleDaemonMeta())\n 232→    );\n 233→\n 234→    const aggregator = createStatusAggregator({ config });\n 235→    const daemonMeta = await aggregator._readDaemonMeta?.('feature');\n 236→\n 237→    // determinePipelineStage should be callable\n 238→    const stage = await aggregator.determinePipelineStage(null, daemonMeta);\n 239→    assert.equal(stage, 'running');\n 240→  } finally {\n 241→    cleanup();\n 242→  }\n 243→});\n 244→\n 245→test('determinePipelineStage should return idle when no daemon and no state', async () => {\n 246→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 247→  try {\n 248→    const config = createMockConfig(stateDir, bugfixStateDir);\n 249→    const aggregator = createStatusAggregator({ config });\n 250→\n 251→    const stage = await aggregator.determinePipelineStage(null, null);\n 252→    assert.equal(stage, 'idle');\n 253→  } finally {\n 254→    cleanup();\n 255→  }\n 256→});\n 257→\n 258→// ============================================================\n 259→// calculateProgress Tests (T-012, T-016)\n 260→// ============================================================\n 261→\n 262→test('calculateProgress should compute stats from pipeline state', () => {\n 263→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 264→  try {\n 265→    const config = createMockConfig(stateDir, bugfixStateDir);\n 266→    const aggregator = createStatusAggregator({ config });\n 267→\n 268→    const state = createSamplePipelineState();\n 269→    const progress = aggregator.calculateProgress(state);\n 270→\n 271→    assert.equal(progress.total, 10);\n 272→    assert.equal(progress.completed, 4);\n 273→    assert.equal(progress.failed, 1);\n 274→    assert.equal(progress.inProgress, 1);\n 275→    assert.ok(progress.successRate > 0);\n 276→  } finally {\n 277→    cleanup();\n 278→  }\n 279→});\n 280→\n 281→test('calculateProgress should handle missing fields', () => {\n 282→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 283→  try {\n 284→    const config = createMockConfig(stateDir, bugfixStateDir);\n 285→    const aggregator = createStatusAggregator({ config });\n 286→\n 287→    const state = { total_features: 5, completed_features: 2 };\n 288→    const progress = aggregator.calculateProgress(state);\n 289→\n 290→    assert.equal(progress.total, 5);\n 291→    assert.equal(progress.completed, 2);\n 292→    assert.equal(progress.failed, 0);\n 293→    assert.equal(progress.inProgress, 0);\n 294→  } finally {\n 295→    cleanup();\n 296→  }\n 297→});\n 298→\n 299→// ============================================================\n 300→// getErrorSummary Tests (T-013)\n 301→// ============================================================\n 302→\n 303→test('getErrorSummary should extract errors from last result', () => {\n 304→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 305→  try {\n 306→    const config = createMockConfig(stateDir, bugfixStateDir);\n 307→    const aggregator = createStatusAggregator({ config });\n 308→\n 309→    const lastResult = {\n 310→      ...createSampleLastResult(),\n 311→      status: 'failed',\n 312→      errors: [\n 313→        { featureId: 'F-003', errorType: 'execution', message: 'Script failed' }\n 314→      ]\n 315→    };\n 316→\n 317→    const summary = aggregator.getErrorSummary(lastResult);\n 318→    assert.ok(Array.isArray(summary));\n 319→    assert.equal(summary.length, 1);\n 320→    assert.equal(summary[0].featureId, 'F-003');\n 321→  } finally {\n 322→    cleanup();\n 323→  }\n 324→});\n 325→\n 326→test('getErrorSummary should return empty array for success', () => {\n 327→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 328→  try {\n 329→    const config = createMockConfig(stateDir, bugfixStateDir);\n 330→    const aggregator = createStatusAggregator({ config });\n 331→\n 332→    const summary = aggregator.getErrorSummary(createSampleLastResult());\n 333→    assert.deepEqual(summary, []);\n 334→  } finally {\n 335→    cleanup();\n 336→  }\n 337→});\n 338→\n 339→// ============================================================\n 340→// formatStatusForTelegram Tests (T-014)\n 341→// ============================================================\n 342→\n 343→test('formatStatusForTelegram should format running status', () => {\n 344→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 345→  try {\n 346→    const config = createMockConfig(stateDir, bugfixStateDir);\n 347→    const aggregator = createStatusAggregator({ config });\n 348→\n 349→    const status = {\n 350→      stage: 'running',\n 351→      type: 'feature',\n 352→      timestamp: new Date().toISOString(),\n 353→      progress: { total: 10, completed: 4, failed: 1, inProgress: 1, successRate: 80 },\n 354→      current: { featureId: 'F-005', startedAt: new Date().toISOString(), duration: 300 },\n 355→      daemon: { pid: 12345, startedAt: new Date().toISOString(), uptime: 3600 }\n 356→    };\n 357→\n 358→    const formatted = aggregator.formatStatusForTelegram(status);\n 359→\n 360→    assert.ok(formatted.includes('running'));\n 361→    assert.ok(formatted.includes('F-005'));\n 362→    assert.ok(formatted.includes('4/10'));\n 363→  } finally {\n 364→    cleanup();\n 365→  }\n 366→});\n 367→\n 368→test('formatStatusForTelegram should format idle status', () => {\n 369→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 370→  try {\n 371→    const config = createMockConfig(stateDir, bugfixStateDir);\n 372→    const aggregator = createStatusAggregator({ config });\n 373→\n 374→    const status = {\n 375→      stage: 'idle',\n 376→      type: 'feature',\n 377→      timestamp: new Date().toISOString(),\n 378→      progress: { total: 0, completed: 0, failed: 0, inProgress: 0, successRate: 0 }\n 379→    };\n 380→\n 381→    const formatted = aggregator.formatStatusForTelegram(status);\n 382→    assert.ok(formatted.includes('idle') || formatted.includes('未运行') || formatted.includes('空闲'));\n 383→  } finally {\n 384→    cleanup();\n 385→  }\n 386→});\n 387→\n 388→// ============================================================\n 389→// Diagnostic Error Tests (T-151, T-153, T-154) - US-6\n 390→// ============================================================\n 391→\n 392→test('aggregateStatus should handle corrupted JSON with diagnostic message', async () => {\n 393→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 394→  try {\n 395→    const config = createMockConfig(stateDir, bugfixStateDir);\n 396→\n 397→    // Write corrupted JSON\n 398→    fs.writeFileSync(\n 399→      path.join(stateDir, '.pipeline-meta.json'),\n 400→      'not valid json {{{'\n 401→    );\n 402→\n 403→    const aggregator = createStatusAggregator({ config });\n 404→    const result = await aggregator.aggregateStatus('feature');\n 405→\n 406→    // Should still return a result, not throw\n 407→    assert.ok(result);\n 408→    assert.equal(result.stage, 'idle');\n 409→  } finally {\n 410→    cleanup();\n 411→  }\n 412→});\n 413→\n 414→test('aggregateStatus should provide diagnostic for missing state files', async () => {\n 415→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 416→  try {\n 417→    const config = createMockConfig(stateDir, bugfixStateDir);\n 418→    const aggregator = createStatusAggregator({ config });\n 419→\n 420→    const result = await aggregator.aggregateStatus('feature');\n 421→\n 422→    // Should include hint about pipeline not being initialized\n 423→    assert.ok(result);\n 424→    assert.ok(result.diagnostic || result.hint || result.stage === 'idle');\n 425→  } finally {\n 426→    cleanup();\n 427→  }\n 428→});\n 429→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:21.225Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
{"type":"user","uuid":"3e885e2f-1604-439f-abc4-575fff037efa","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90871ecbf256e9b93fe475f8a0","content":[{"type":"text","text":"   1→/**\n   2→ * Log Pager Unit Tests\n   3→ * Tests for src/services/log-pager.js\n   4→ *\n   5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-2: Paginated Logs Query, US-3: Message Length Compliance\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createLogPager } from '../../src/services/log-pager.js';\n  15→\n  16→/**\n  17→ * Helper to create temp directory for test state\n  18→ */\n  19→function createTempStateDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'log-pager-test-'));\n  21→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  22→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  23→  fs.mkdirSync(stateDir, { recursive: true });\n  24→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  25→  return {\n  26→    tempDir,\n  27→    stateDir,\n  28→    bugfixStateDir,\n  29→    cleanup: () => {\n  30→      fs.rmSync(tempDir, { recursive: true, force: true });\n  31→    }\n  32→  };\n  33→}\n  34→\n  35→/**\n  36→ * Helper to create a mock config\n  37→ */\n  38→function createMockConfig(stateDir, bugfixStateDir) {\n  39→  const projectRoot = path.dirname(path.dirname(stateDir));\n  40→  return {\n  41→    projectRoot,\n  42→    stateDir,\n  43→    bugfixStateDir\n  44→  };\n  45→}\n  46→\n  47→/**\n  48→ * Helper to generate sample log content\n  49→ */\n  50→function generateLogLines(count) {\n  51→  const lines = [];\n  52→  for (let i = 1; i <= count; i++) {\n  53→    lines.push(`[${new Date().toISOString()}] [INFO] Log line ${i}: Some log content here`);\n  54→  }\n  55→  return lines.join('\\n');\n  56→}\n  57→\n  58→/**\n  59→ * Helper to generate log with errors\n  60→ */\n  61→function generateLogWithErrors() {\n  62→  return `[\n  63→${new Date().toISOString()}] [INFO] Starting pipeline\n  64→[${new Date().toISOString()}] [INFO] Processing F-001\n  65→[${new Date().toISOString()}] [ERROR] Failed to process F-001: Script failed\n  66→[${new Date().toISOString()}] [INFO] Processing F-002\n  67→[${new Date().toISOString()}] [ERROR] Exception: ENOENT: no such file\n  68→[${new Date().toISOString()}] [ERROR] Stack trace line 1\n  69→[${new Date().toISOString()}] [ERROR] Stack trace line 2\n  70→[${new Date().toISOString()}] [INFO] Completed`;\n  71→}\n  72→\n  73→// ============================================================\n  74→// Factory Tests\n  75→// ============================================================\n  76→\n  77→test('createLogPager should be a factory function', () => {\n  78→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  79→  try {\n  80→    const config = createMockConfig(stateDir, bugfixStateDir);\n  81→    const pager = createLogPager({ config });\n  82→\n  83→    assert.equal(typeof pager.readLogPage, 'function');\n  84→    assert.equal(typeof pager.formatLogsForTelegram, 'function');\n  85→    assert.equal(typeof pager.extractErrorLines, 'function');\n  86→    assert.equal(typeof pager.shouldSendAsFile, 'function');\n  87→    assert.equal(typeof pager.buildLogMetadata, 'function');\n  88→  } finally {\n  89→    cleanup();\n  90→  }\n  91→});\n  92→\n  93→// ============================================================\n  94→// readLogPage Tests (T-020, T-026)\n  95→// ============================================================\n  96→\n  97→test('readLogPage should return last N lines by default', async () => {\n  98→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  99→  try {\n 100→    const config = createMockConfig(stateDir, bugfixStateDir);\n 101→\n 102→    // Write log file with 200 lines\n 103→    fs.writeFileSync(\n 104→      path.join(stateDir, 'pipeline-daemon.log'),\n 105→      generateLogLines(200)\n 106→    );\n 107→\n 108→    const pager = createLogPager({ config });\n 109→    const result = await pager.readLogPage('feature', { lines: 50 });\n 110→\n 111→    assert.equal(result.ok, true);\n 112→    assert.ok(result.logs);\n 113→    assert.ok(result.metadata);\n 114→    assert.equal(result.metadata.requestedLines, 50);\n 115→    assert.ok(result.metadata.actualLines <= 50);\n 116→  } finally {\n 117→    cleanup();\n 118→  }\n 119→});\n 120→\n 121→test('readLogPage should support offset parameter', async () => {\n 122→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 123→  try {\n 124→    const config = createMockConfig(stateDir, bugfixStateDir);\n 125→\n 126→    // Write log file\n 127→    fs.writeFileSync(\n 128→      path.join(stateDir, 'pipeline-daemon.log'),\n 129→      generateLogLines(100)\n 130→    );\n 131→\n 132→    const pager = createLogPager({ config });\n 133→    const result = await pager.readLogPage('feature', { lines: 20, offset: 10 });\n 134→\n 135→    assert.equal(result.ok, true);\n 136→    assert.ok(result.metadata.pageStart > 0);\n 137→  } finally {\n 138→    cleanup();\n 139→  }\n 140→});\n 141→\n 142→test('readLogPage should cap lines at max 500', async () => {\n 143→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 144→  try {\n 145→    const config = createMockConfig(stateDir, bugfixStateDir);\n 146→\n 147→    fs.writeFileSync(\n 148→      path.join(stateDir, 'pipeline-daemon.log'),\n 149→      generateLogLines(1000)\n 150→    );\n 151→\n 152→    const pager = createLogPager({ config });\n 153→    const result = await pager.readLogPage('feature', { lines: 1000 });\n 154→\n 155→    // Should cap at 500\n 156→    assert.ok(result.metadata.actualLines <= 500);\n 157→  } finally {\n 158→    cleanup();\n 159→  }\n 160→});\n 161→\n 162→test('readLogPage should return friendly message for missing log file', async () => {\n 163→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 164→  try {\n 165→    const config = createMockConfig(stateDir, bugfixStateDir);\n 166→    const pager = createLogPager({ config });\n 167→\n 168→    const result = await pager.readLogPage('feature', { lines: 50 });\n 169→\n 170→    assert.equal(result.ok, true);\n 171→    assert.ok(result.logs === '' || result.message);\n 172→    assert.ok(result.metadata);\n 173→  } finally {\n 174→    cleanup();\n 175→  }\n 176→});\n 177→\n 178→test('readLogPage should work for bugfix type', async () => {\n 179→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 180→  try {\n 181→    const config = createMockConfig(stateDir, bugfixStateDir);\n 182→\n 183→    fs.writeFileSync(\n 184→      path.join(bugfixStateDir, 'pipeline-daemon.log'),\n 185→      generateLogLines(50)\n 186→    );\n 187→\n 188→    const pager = createLogPager({ config });\n 189→    const result = await pager.readLogPage('bugfix', { lines: 20 });\n 190→\n 191→    assert.equal(result.ok, true);\n 192→    assert.ok(result.logs);\n 193→  } finally {\n 194→    cleanup();\n 195→  }\n 196→});\n 197→\n 198→// ============================================================\n 199→// extractErrorLines Tests (T-022, T-027)\n 200→// ============================================================\n 201→\n 202→test('extractErrorLines should extract lines containing ERROR', () => {\n 203→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 204→  try {\n 205→    const config = createMockConfig(stateDir, bugfixStateDir);\n 206→    const pager = createLogPager({ config });\n 207→\n 208→    const logs = generateLogWithErrors();\n 209→    const errorLines = pager.extractErrorLines(logs, 10);\n 210→\n 211→    assert.ok(Array.isArray(errorLines));\n 212→    assert.ok(errorLines.length > 0);\n 213→    assert.ok(errorLines.every(line => line.includes('ERROR')));\n 214→  } finally {\n 215→    cleanup();\n 216→  }\n 217→});\n 218→\n 219→test('extractErrorLines should limit to N lines', () => {\n 220→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 221→  try {\n 222→    const config = createMockConfig(stateDir, bugfixStateDir);\n 223→    const pager = createLogPager({ config });\n 224→\n 225→    const logs = generateLogWithErrors();\n 226→    const errorLines = pager.extractErrorLines(logs, 2);\n 227→\n 228→    assert.ok(errorLines.length <= 2);\n 229→  } finally {\n 230→    cleanup();\n 231→  }\n 232→});\n 233→\n 234→test('extractErrorLines should return empty array for no errors', () => {\n 235→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 236→  try {\n 237→    const config = createMockConfig(stateDir, bugfixStateDir);\n 238→    const pager = createLogPager({ config });\n 239→\n 240→    const logs = generateLogLines(50);\n 241→    const errorLines = pager.extractErrorLines(logs, 10);\n 242→\n 243→    assert.deepEqual(errorLines, []);\n 244→  } finally {\n 245→    cleanup();\n 246→  }\n 247→});\n 248→\n 249→// ============================================================\n 250→// shouldSendAsFile Tests (T-023, T-027)\n 251→// ============================================================\n 252→\n 253→test('shouldSendAsFile should return true for large logs', () => {\n 254→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 255→  try {\n 256→    const config = createMockConfig(stateDir, bugfixStateDir);\n 257→    const pager = createLogPager({ config });\n 258→\n 259→    // Create log larger than 4000 chars\n 260→    const largeLog = 'x'.repeat(5000);\n 261→    const result = pager.shouldSendAsFile(largeLog);\n 262→\n 263→    assert.equal(result, true);\n 264→  } finally {\n 265→    cleanup();\n 266→  }\n 267→});\n 268→\n 269→test('shouldSendAsFile should return false for small logs', () => {\n 270→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 271→  try {\n 272→    const config = createMockConfig(stateDir, bugfixStateDir);\n 273→    const pager = createLogPager({ config });\n 274→\n 275→    const smallLog = 'x'.repeat(1000);\n 276→    const result = pager.shouldSendAsFile(smallLog);\n 277→\n 278→    assert.equal(result, false);\n 279→  } finally {\n 280→    cleanup();\n 281→  }\n 282→});\n 283→\n 284→test('shouldSendAsFile should use custom threshold', () => {\n 285→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 286→  try {\n 287→    const config = createMockConfig(stateDir, bugfixStateDir);\n 288→    const pager = createLogPager({ config });\n 289→\n 290→    const log = 'x'.repeat(2000);\n 291→    const result = pager.shouldSendAsFile(log, 1500);\n 292→\n 293→    assert.equal(result, true);\n 294→  } finally {\n 295→    cleanup();\n 296→  }\n 297→});\n 298→\n 299→// ============================================================\n 300→// formatLogsForTelegram Tests (T-024)\n 301→// ============================================================\n 302→\n 303→test('formatLogsForTelegram should add metadata header', () => {\n 304→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 305→  try {\n 306→    const config = createMockConfig(stateDir, bugfixStateDir);\n 307→    const pager = createLogPager({ config });\n 308→\n 309→    const logs = generateLogLines(20);\n 310→    const metadata = {\n 311→      logPath: '/path/to/log',\n 312→      totalLines: 100,\n 313→      pageStart: 80,\n 314→      pageEnd: 100,\n 315→      requestedLines: 20,\n 316→      actualLines: 20\n 317→    };\n 318→\n 319→    const formatted = pager.formatLogsForTelegram(logs, metadata);\n 320→\n 321→    assert.ok(formatted.includes('100')); // total lines\n 322→    assert.ok(formatted.includes('80')); // page start\n 323→    assert.ok(logs.split('\\n')[0]); // log content\n 324→  } finally {\n 325→    cleanup();\n 326→  }\n 327→});\n 328→\n 329→test('formatLogsForTelegram should handle empty logs', () => {\n 330→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 331→  try {\n 332→    const config = createMockConfig(stateDir, bugfixStateDir);\n 333→    const pager = createLogPager({ config });\n 334→\n 335→    const formatted = pager.formatLogsForTelegram('', { totalLines: 0 });\n 336→\n 337→    assert.ok(formatted);\n 338→  } finally {\n 339→    cleanup();\n 340→  }\n 341→});\n 342→\n 343→// ============================================================\n 344→// buildLogMetadata Tests (T-025)\n 345→// ============================================================\n 346→\n 347→test('buildLogMetadata should create metadata object', () => {\n 348→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 349→  try {\n 350→    const config = createMockConfig(stateDir, bugfixStateDir);\n 351→    const pager = createLogPager({ config });\n 352→\n 353→    const metadata = pager.buildLogMetadata('/path/to/log', 100, 80, 100, 20, 20);\n 354→\n 355→    assert.equal(metadata.logPath, '/path/to/log');\n 356→    assert.equal(metadata.totalLines, 100);\n 357→    assert.equal(metadata.pageStart, 80);\n 358→    assert.equal(metadata.pageEnd, 100);\n 359→    assert.equal(metadata.requestedLines, 20);\n 360→    assert.equal(metadata.actualLines, 20);\n 361→  } finally {\n 362→    cleanup();\n 363→  }\n 364→});\n 365→\n 366→// ============================================================\n 367→// Message Segment Numbering Tests (T-121) - US-3\n 368→// ============================================================\n 369→\n 370→test('formatLogsForTelegram should add segment numbering for chunked output', () => {\n 371→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 372→  try {\n 373→    const config = createMockConfig(stateDir, bugfixStateDir);\n 374→    const pager = createLogPager({ config });\n 375→\n 376→    const logs = generateLogLines(100);\n 377→    const metadata = {\n 378→      logPath: '/path/to/log',\n 379→      totalLines: 100,\n 380→      pageStart: 0,\n 381→      pageEnd: 100,\n 382→      requestedLines: 100,\n 383→      actualLines: 100,\n 384→      segmentIndex: 0,\n 385→      totalSegments: 3\n 386→    };\n 387→\n 388→    const formatted = pager.formatLogsForTelegram(logs, metadata);\n 389→\n 390→    // Should include segment numbering like [1/3]\n 391→    assert.ok(formatted.includes('[1/3]') || !metadata.totalSegments);\n 392→  } finally {\n 393→    cleanup();\n 394→  }\n 395→});\n 396→\n 397→// ============================================================\n 398→// Diagnostic Error Tests (T-152) - US-6\n 399→// ============================================================\n 400→\n 401→test('readLogPage should return diagnostic message for missing log file', async () => {\n 402→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 403→  try {\n 404→    const config = createMockConfig(stateDir, bugfixStateDir);\n 405→    const pager = createLogPager({ config });\n 406→\n 407→    const result = await pager.readLogPage('feature', { lines: 50 });\n 408→\n 409→    assert.equal(result.ok, true);\n 410→    // Should have a friendly message\n 411→    assert.ok(result.message || result.logs === '');\n 412→    assert.ok(result.metadata.logPath);\n 413→  } finally {\n 414→    cleanup();\n 415→  }\n 416→});\n 417→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:21.226Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
{"type":"user","uuid":"8d8bf6e5-d8c7-445d-92e6-f0c124ccb77c","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde9088cc0fee7665b8afa6c9680c","content":[{"type":"text","text":"   1→/**\n   2→ * Telegram Pusher Unit Tests\n   3→ * Tests for src/services/telegram-pusher.js\n   4→ *\n   5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-4: Heartbeat Progress Push, US-5: Error Summary Push\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→\n  11→import { createTelegramPusher } from '../../src/services/telegram-pusher.js';\n  12→\n  13→/**\n  14→ * Helper to create a mock bot\n  15→ */\n  16→function createMockBot() {\n  17→  const sentMessages = [];\n  18→  const sentFiles = [];\n  19→\n  20→  return {\n  21→    telegram: {\n  22→      sendMessage: async (chatId, text, options = {}) => {\n  23→        sentMessages.push({ chatId, text, options });\n  24→        return { message_id: Date.now() };\n  25→      },\n  26→      sendDocument: async (chatId, document, options = {}) => {\n  27→        sentFiles.push({ chatId, document, options });\n  28→        return { message_id: Date.now() };\n  29→      }\n  30→    },\n  31→    _sentMessages: sentMessages,\n  32→    _sentFiles: sentFiles\n  33→  };\n  34→}\n  35→\n  36→/**\n  37→ * Helper to create a mock status aggregator\n  38→ */\n  39→function createMockAggregator() {\n  40→  return {\n  41→    aggregateStatus: async () => ({\n  42→      stage: 'running',\n  43→      type: 'feature',\n  44→      timestamp: new Date().toISOString(),\n  45→      progress: { total: 10, completed: 4, failed: 1, inProgress: 1, successRate: 80 },\n  46→      current: { featureId: 'F-005', startedAt: new Date().toISOString(), duration: 300 }\n  47→    }),\n  48→    formatStatusForTelegram: (status) => JSON.stringify(status, null, 2)\n  49→  };\n  50→}\n  51→\n  52→// ============================================================\n  53→// Factory Tests (T-030)\n  54→// ============================================================\n  55→\n  56→test('createTelegramPusher should be a factory function', () => {\n  57→  const bot = createMockBot();\n  58→  const pusher = createTelegramPusher({\n  59→    bot,\n  60→    targetChatId: 123456\n  61→  });\n  62→\n  63→  assert.equal(typeof pusher.startHeartbeat, 'function');\n  64→  assert.equal(typeof pusher.stopHeartbeat, 'function');\n  65→  assert.equal(typeof pusher.pushErrorSummary, 'function');\n  66→  assert.equal(typeof pusher.sendMessageChunked, 'function');\n  67→  assert.equal(typeof pusher.sendFile, 'function');\n  68→  assert.equal(typeof pusher.throttle, 'function');\n  69→});\n  70→\n  71→test('createTelegramPusher should accept config options', () => {\n  72→  const bot = createMockBot();\n  73→  const pusher = createTelegramPusher({\n  74→    bot,\n  75→    targetChatId: 123456,\n  76→    heartbeatInterval: 60000,\n  77→    errorLinesCount: 20,\n  78→    throttleInterval: 60000\n  79→  });\n  80→\n  81→  assert.ok(pusher);\n  82→});\n  83→\n  84→// ============================================================\n  85→// sendMessageChunked Tests (T-031, T-037)\n  86→// ============================================================\n  87→\n  88→test('sendMessageChunked should send single message for short text', async () => {\n  89→  const bot = createMockBot();\n  90→  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n  91→\n  92→  const text = 'Short message';\n  93→  await pusher.sendMessageChunked(123456, text);\n  94→\n  95→  assert.equal(bot._sentMessages.length, 1);\n  96→});\n  97→\n  98→test('sendMessageChunked should split long messages at 4000 chars', async () => {\n  99→  const bot = createMockBot();\n 100→  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n 101→\n 102→  // Create message longer than 4000 chars\n 103→  const text = 'x'.repeat(5000);\n 104→  await pusher.sendMessageChunked(123456, text);\n 105→\n 106→  // Should send multiple messages\n 107→  assert.ok(bot._sentMessages.length >= 2);\n 108→});\n 109→\n 110→test('sendMessageChunked should add segment numbering [N/M]', async () => {\n 111→  const bot = createMockBot();\n 112→  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n 113→\n 114→  const text = 'x'.repeat(5000);\n 115→  await pusher.sendMessageChunked(123456, text);\n 116→\n 117→  // Check that messages have segment numbering\n 118→  const hasSegmentNumber = bot._sentMessages.some(m =>\n 119→    m.text.includes('[1/') || m.text.includes('[2/')\n 120→  );\n 121→  assert.ok(hasSegmentNumber);\n 122→});\n 123→\n 124→test('sendMessageChunked should respect segment interval delay', async () => {\n 125→  const bot = createMockBot();\n 126→  const pusher = createTelegramPusher({\n 127→    bot,\n 128→    targetChatId: 123456,\n 129→    segmentInterval: 10 // Fast for testing\n 130→  });\n 131→\n 132→  const text = 'x'.repeat(10000);\n 133→  const start = Date.now();\n 134→  await pusher.sendMessageChunked(123456, text);\n 135→  const elapsed = Date.now() - start;\n 136→\n 137→  // Should have some delay between segments (at least 10ms per segment)\n 138→  assert.ok(bot._sentMessages.length >= 2);\n 139→});\n 140→\n 141→// ============================================================\n 142→// throttle Tests (T-032, T-037)\n 143→// ============================================================\n 144→\n 145→test('throttle should prevent rapid successive calls', async () => {\n 146→  const bot = createMockBot();\n 147→  const pusher = createTelegramPusher({\n 148→    bot,\n 149→    targetChatId: 123456,\n 150→    throttleInterval: 100\n 151→  });\n 152→\n 153→  let callCount = 0;\n 154→  const fn = async () => { callCount++; };\n 155→\n 156→  // First call should execute immediately\n 157→  await pusher.throttle('test-key', fn);\n 158→  assert.equal(callCount, 1);\n 159→\n 160→  // Second call immediately should be throttled\n 161→  await pusher.throttle('test-key', fn);\n 162→  assert.equal(callCount, 1);\n 163→\n 164→  // After interval, should allow again\n 165→  await new Promise(resolve => setTimeout(resolve, 150));\n 166→  await pusher.throttle('test-key', fn);\n 167→  assert.equal(callCount, 2);\n 168→});\n 169→\n 170→test('throttle should track separate keys independently', async () => {\n 171→  const bot = createMockBot();\n 172→  const pusher = createTelegramPusher({\n 173→    bot,\n 174→    targetChatId: 123456,\n 175→    throttleInterval: 100\n 176→  });\n 177→\n 178→  let callCount = 0;\n 179→  const fn = async () => { callCount++; };\n 180→\n 181→  await pusher.throttle('key-a', fn);\n 182→  await pusher.throttle('key-b', fn);\n 183→\n 184→  // Both should execute since different keys\n 185→  assert.equal(callCount, 2);\n 186→});\n 187→\n 188→// ============================================================\n 189→// startHeartbeat/stopHeartbeat Tests (T-033, T-034, T-038)\n 190→// ============================================================\n 191→\n 192→test('startHeartbeat should begin periodic updates', async () => {\n 193→  const bot = createMockBot();\n 194→  const pusher = createTelegramPusher({\n 195→    bot,\n 196→    targetChatId: 123456,\n 197→    heartbeatInterval: 50 // Fast for testing\n 198→  });\n 199→\n 200→  const aggregator = createMockAggregator();\n 201→\n 202→  pusher.startHeartbeat('feature', aggregator);\n 203→\n 204→  // Wait for at least one heartbeat\n 205→  await new Promise(resolve => setTimeout(resolve, 100));\n 206→\n 207→  pusher.stopHeartbeat('feature');\n 208→\n 209→  // Should have sent at least one message\n 210→  assert.ok(bot._sentMessages.length >= 1);\n 211→});\n 212→\n 213→test('stopHeartbeat should stop periodic updates', async () => {\n 214→  const bot = createMockBot();\n 215→  const pusher = createTelegramPusher({\n 216→    bot,\n 217→    targetChatId: 123456,\n 218→    heartbeatInterval: 50\n 219→  });\n 220→\n 221→  const aggregator = createMockAggregator();\n 222→\n 223→  pusher.startHeartbeat('feature', aggregator);\n 224→  await new Promise(resolve => setTimeout(resolve, 80));\n 225→  pusher.stopHeartbeat('feature');\n 226→\n 227→  const countAfterStop = bot._sentMessages.length;\n 228→\n 229→  // Wait more - should not send more\n 230→  await new Promise(resolve => setTimeout(resolve, 100));\n 231→\n 232→  assert.equal(bot._sentMessages.length, countAfterStop);\n 233→});\n 234→\n 235→test('startHeartbeat should not start duplicate timers', async () => {\n 236→  const bot = createMockBot();\n 237→  const pusher = createTelegramPusher({\n 238→    bot,\n 239→    targetChatId: 123456,\n 240→    heartbeatInterval: 50\n 241→  });\n 242→\n 243→  const aggregator = createMockAggregator();\n 244→\n 245→  // Start twice\n 246→  pusher.startHeartbeat('feature', aggregator);\n 247→  pusher.startHeartbeat('feature', aggregator);\n 248→\n 249→  await new Promise(resolve => setTimeout(resolve, 100));\n 250→  pusher.stopHeartbeat('feature');\n 251→\n 252→  // Should only have one timer's worth of messages\n 253→  assert.ok(bot._sentMessages.length < 5);\n 254→});\n 255→\n 256→// ============================================================\n 257→// pushErrorSummary Tests (T-035)\n 258→// ============================================================\n 259→\n 260→test('pushErrorSummary should send error notification', async () => {\n 261→  const bot = createMockBot();\n 262→  const pusher = createTelegramPusher({\n 263→    bot,\n 264→    targetChatId: 123456,\n 265→    errorLinesCount: 10\n 266→  });\n 267→\n 268→  const error = {\n 269→    type: 'execution_error',\n 270→    message: 'Script failed',\n 271→    logLines: ['Error line 1', 'Error line 2']\n 272→  };\n 273→\n 274→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 275→\n 276→  assert.equal(bot._sentMessages.length, 1);\n 277→  assert.ok(bot._sentMessages[0].text.includes('F-005'));\n 278→});\n 279→\n 280→test('pushErrorSummary should include execution time', async () => {\n 281→  const bot = createMockBot();\n 282→  const pusher = createTelegramPusher({\n 283→    bot,\n 284→    targetChatId: 123456\n 285→  });\n 286→\n 287→  const error = {\n 288→    type: 'execution_error',\n 289→    message: 'Script failed',\n 290→    duration: 120 // seconds\n 291→  };\n 292→\n 293→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 294→\n 295→  const sentText = bot._sentMessages[0].text;\n 296→  assert.ok(sentText.includes('120') || sentText.includes('2m') || sentText.includes('duration'));\n 297→});\n 298→\n 299→test('pushErrorSummary should include last N error log lines', async () => {\n 300→  const bot = createMockBot();\n 301→  const pusher = createTelegramPusher({\n 302→    bot,\n 303→    targetChatId: 123456,\n 304→    errorLinesCount: 5\n 305→  });\n 306→\n 307→  const error = {\n 308→    type: 'execution_error',\n 309→    message: 'Script failed',\n 310→    logLines: ['Err1', 'Err2', 'Err3', 'Err4', 'Err5', 'Err6', 'Err7']\n 311→  };\n 312→\n 313→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 314→\n 315→  const sentText = bot._sentMessages[0].text;\n 316→  // Should include up to 5 error lines\n 317→  assert.ok(sentText.includes('Err'));\n 318→});\n 319→\n 320→// ============================================================\n 321→// sendFile Tests (T-036)\n 322→// ============================================================\n 323→\n 324→test('sendFile should send document to chat', async () => {\n 325→  const bot = createMockBot();\n 326→  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n 327→\n 328→  const content = 'Log content here';\n 329→  await pusher.sendFile(123456, content, 'test-log.txt');\n 330→\n 331→  assert.equal(bot._sentFiles.length, 1);\n 332→});\n 333→\n 334→// ============================================================\n 335→// Heartbeat Config Tests (T-131, T-134) - US-4\n 336→// ============================================================\n 337→\n 338→test('createTelegramPusher should read heartbeat config from options', () => {\n 339→  const bot = createMockBot();\n 340→  const pusher = createTelegramPusher({\n 341→    bot,\n 342→    targetChatId: 123456,\n 343→    heartbeatConfig: {\n 344→      enabled: true,\n 345→      intervalMs: 60000,\n 346→      chatId: 789012,\n 347→      silentMode: false,\n 348→      errorLinesCount: 15\n 349→    }\n 350→  });\n 351→\n 352→  assert.ok(pusher);\n 353→});\n 354→\n 355→test('heartbeat should respect enabled config', async () => {\n 356→  const bot = createMockBot();\n 357→  const pusher = createTelegramPusher({\n 358→    bot,\n 359→    targetChatId: 123456,\n 360→    heartbeatConfig: {\n 361→      enabled: false\n 362→    }\n 363→  });\n 364→\n 365→  const aggregator = createMockAggregator();\n 366→  pusher.startHeartbeat('feature', aggregator);\n 367→\n 368→  await new Promise(resolve => setTimeout(resolve, 100));\n 369→\n 370→  pusher.stopHeartbeat('feature');\n 371→\n 372→  // Should not send any messages when disabled\n 373→  assert.equal(bot._sentMessages.length, 0);\n 374→});\n 375→\n 376→// ============================================================\n 377→// Startup Notification Tests (T-132) - US-4 AC-4.1\n 378→// ============================================================\n 379→\n 380→test('pushStartupNotification should include runId and target list', async () => {\n 381→  const bot = createMockBot();\n 382→  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n 383→\n 384→  const runInfo = {\n 385→    runId: 'run-20260313-103000',\n 386→    targets: ['F-001', 'F-002', 'F-003', 'F-004', 'F-005'],\n 387→    startedAt: new Date().toISOString()\n 388→  };\n 389→\n 390→  await pusher.pushStartupNotification?.('feature', runInfo);\n 391→\n 392→  // Check that the message includes runId and targets\n 393→  if (bot._sentMessages.length > 0) {\n 394→    const text = bot._sentMessages[0].text;\n 395→    assert.ok(text.includes('run-20260313-103000') || text.includes('runId'));\n 396→    assert.ok(text.includes('F-001') || text.includes('target'));\n 397→  }\n 398→});\n 399→\n 400→// ============================================================\n 401→// Silent Mode Tests (T-143) - US-5 AC-5.4\n 402→// ============================================================\n 403→\n 404→test('pushErrorSummary should respect silent mode', async () => {\n 405→  const bot = createMockBot();\n 406→  const pusher = createTelegramPusher({\n 407→    bot,\n 408→    targetChatId: 123456,\n 409→    heartbeatConfig: {\n 410→      silentMode: true\n 411→    }\n 412→  });\n 413→\n 414→  // In silent mode, only critical errors should be sent\n 415→  const error = {\n 416→    type: 'expected_error',\n 417→    message: 'Expected failure',\n 418→    isExpected: true\n 419→  };\n 420→\n 421→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 422→\n 423→  // Should skip expected errors in silent mode\n 424→  // Implementation dependent - may send or not\n 425→  assert.ok(bot._sentMessages.length <= 1);\n 426→});\n 427→\n 428→// ============================================================\n 429→// Error Summary Format Tests (T-141) - US-5 AC-5.3\n 430→// ============================================================\n 431→\n 432→test('pushErrorSummary message format should include execution time/duration', async () => {\n 433→  const bot = createMockBot();\n 434→  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n 435→\n 436→  const error = {\n 437→    type: 'execution_error',\n 438→    message: 'Script execution failed',\n 439→    duration: 180, // 3 minutes\n 440→    featureId: 'F-005'\n 441→  };\n 442→\n 443→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 444→\n 445→  const sentText = bot._sentMessages[0].text;\n 446→\n 447→  // Should include duration/execution time\n 448→  assert.ok(\n 449→    sentText.includes('180') ||\n 450→    sentText.includes('3m') ||\n 451→    sentText.includes('duration') ||\n 452→    sentText.includes('耗时') ||\n 453→    sentText.includes('执行时间')\n 454→  );\n 455→});\n 456→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:21.227Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
{"type":"user","uuid":"046e4afa-8cff-4ff1-a89c-97d47535b346","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde908aa12930a2193beda88e0ae6","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Tests for F-005: Pipeline Status Aggregation and Log Streaming\n   3→ *\n   4→ * Tests for US-1 through US-6:\n   5→ * - US-1: Aggregated Status Query\n   6→ * - US-2: Paginated Logs Query\n   7→ * - US-3: Message Length Compliance\n   8→ * - US-4: Heartbeat Progress Push\n   9→ * - US-5: Error Summary Push\n  10→ * - US-6: Diagnostic Error Messages\n  11→ */\n  12→\n  13→import test from 'node:test';\n  14→import assert from 'node:assert/strict';\n  15→import fs from 'node:fs';\n  16→import path from 'node:path';\n  17→import os from 'node:os';\n  18→\n  19→import { createStatusAggregator } from '../../src/services/status-aggregator.js';\n  20→import { createLogPager } from '../../src/services/log-pager.js';\n  21→import { createTelegramPusher } from '../../src/services/telegram-pusher.js';\n  22→\n  23→// ============================================================\n  24→// Test Helpers\n  25→// ============================================================\n  26→\n  27→function createTempStateDir() {\n  28→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f005-integration-test-'));\n  29→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  30→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  31→  fs.mkdirSync(stateDir, { recursive: true });\n  32→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  33→  return {\n  34→    tempDir,\n  35→    stateDir,\n  36→    bugfixStateDir,\n  37→    cleanup: () => {\n  38→      fs.rmSync(tempDir, { recursive: true, force: true });\n  39→    }\n  40→  };\n  41→}\n  42→\n  43→function createMockConfig(stateDir, bugfixStateDir) {\n  44→  const projectRoot = path.dirname(path.dirname(stateDir));\n  45→  return {\n  46→    projectRoot,\n  47→    stateDir,\n  48→    bugfixStateDir\n  49→  };\n  50→}\n  51→\n  52→function createMockBot() {\n  53→  const sentMessages = [];\n  54→  const sentFiles = [];\n  55→\n  56→  return {\n  57→    telegram: {\n  58→      sendMessage: async (chatId, text, options = {}) => {\n  59→        sentMessages.push({ chatId, text, options });\n  60→        return { message_id: Date.now() };\n  61→      },\n  62→      sendDocument: async (chatId, document, options = {}) => {\n  63→        sentFiles.push({ chatId, document, options });\n  64→        return { message_id: Date.now() };\n  65→      }\n  66→    },\n  67→    _sentMessages: sentMessages,\n  68→    _sentFiles: sentFiles\n  69→  };\n  70→}\n  71→\n  72→// ============================================================\n  73→// US-1: Aggregated Status Query Integration Tests (T-104)\n  74→// ============================================================\n  75→\n  76→test('[US-1] Full status flow should aggregate running state correctly', async () => {\n  77→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  78→  try {\n  79→    const config = createMockConfig(stateDir, bugfixStateDir);\n  80→\n  81→    // Write state files\n  82→    fs.writeFileSync(\n  83→      path.join(stateDir, '.pipeline-meta.json'),\n  84→      JSON.stringify({\n  85→        pid: process.pid,\n  86→        started_at: new Date(Date.now() - 3600000).toISOString(),\n  87→        feature_list: '/path/to/feature-list.json'\n  88→      })\n  89→    );\n  90→\n  91→    fs.writeFileSync(\n  92→      path.join(stateDir, 'pipeline.json'),\n  93→      JSON.stringify({\n  94→        run_id: 'run-001',\n  95→        status: 'running',\n  96→        total_features: 10,\n  97→        completed_features: 4,\n  98→        failed_features: 1,\n  99→        in_progress_features: 1\n 100→      })\n 101→    );\n 102→\n 103→    fs.writeFileSync(\n 104→      path.join(stateDir, 'current-session.json'),\n 105→      JSON.stringify({\n 106→        feature_id: 'F-005',\n 107→        started_at: new Date().toISOString()\n 108→      })\n 109→    );\n 110→\n 111→    const aggregator = createStatusAggregator({ config });\n 112→    const status = await aggregator.aggregateStatus('feature');\n 113→\n 114→    assert.equal(status.stage, 'running');\n 115→    assert.equal(status.type, 'feature');\n 116→    assert.ok(status.current);\n 117→    assert.equal(status.current.featureId, 'F-005');\n 118→    assert.ok(status.progress);\n 119→    assert.equal(status.progress.total, 10);\n 120→    assert.equal(status.progress.completed, 4);\n 121→\n 122→    // Test formatting\n 123→    const formatted = aggregator.formatStatusForTelegram(status);\n 124→    assert.ok(formatted.includes('运行中') || formatted.includes('running'));\n 125→    assert.ok(formatted.includes('F-005'));\n 126→  } finally {\n 127→    cleanup();\n 128→  }\n 129→});\n 130→\n 131→test('[US-1] Status should handle idle state with last result', async () => {\n 132→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 133→  try {\n 134→    const config = createMockConfig(stateDir, bugfixStateDir);\n 135→\n 136→    fs.writeFileSync(\n 137→      path.join(stateDir, '.last-result.json'),\n 138→      JSON.stringify({\n 139→        runId: 'run-previous',\n 140→        completedAt: new Date().toISOString(),\n 141→        status: 'success',\n 142→        featuresTotal: 5,\n 143→        featuresCompleted: 5\n 144→      })\n 145→    );\n 146→\n 147→    const aggregator = createStatusAggregator({ config });\n 148→    const status = await aggregator.aggregateStatus('feature');\n 149→\n 150→    assert.equal(status.stage, 'idle');\n 151→    assert.ok(status.lastResult);\n 152→    assert.equal(status.lastResult.status, 'success');\n 153→  } finally {\n 154→    cleanup();\n 155→  }\n 156→});\n 157→\n 158→// ============================================================\n 159→// US-2: Paginated Logs Query Integration Tests (T-115)\n 160→// ============================================================\n 161→\n 162→test('[US-2] Logs should paginate correctly', async () => {\n 163→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 164→  try {\n 165→    const config = createMockConfig(stateDir, bugfixStateDir);\n 166→\n 167→    // Generate log file\n 168→    const lines = [];\n 169→    for (let i = 1; i <= 100; i++) {\n 170→      lines.push(`[${new Date().toISOString()}] [INFO] Log line ${i}`);\n 171→    }\n 172→    fs.writeFileSync(\n 173→      path.join(stateDir, 'pipeline-daemon.log'),\n 174→      lines.join('\\n')\n 175→    );\n 176→\n 177→    const pager = createLogPager({ config });\n 178→\n 179→    // Test first page\n 180→    const page1 = await pager.readLogPage('feature', { lines: 20, offset: 0 });\n 181→    assert.ok(page1.ok);\n 182→    assert.ok(page1.logs);\n 183→    assert.equal(page1.metadata.requestedLines, 20);\n 184→\n 185→    // Test second page\n 186→    const page2 = await pager.readLogPage('feature', { lines: 20, offset: 20 });\n 187→    assert.ok(page2.ok);\n 188→  } finally {\n 189→    cleanup();\n 190→  }\n 191→});\n 192→\n 193→test('[US-2] Logs should return friendly message when missing', async () => {\n 194→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 195→  try {\n 196→    const config = createMockConfig(stateDir, bugfixStateDir);\n 197→    const pager = createLogPager({ config });\n 198→\n 199→    const result = await pager.readLogPage('feature', { lines: 50 });\n 200→\n 201→    assert.ok(result.ok);\n 202→    assert.ok(result.message || result.logs === '');\n 203→  } finally {\n 204→    cleanup();\n 205→  }\n 206→});\n 207→\n 208→// ============================================================\n 209→// US-3: Message Length Compliance Integration Tests (T-124)\n 210→// ============================================================\n 211→\n 212→test('[US-3] Long messages should be chunked with segment numbering', async () => {\n 213→  const bot = createMockBot();\n 214→  const pusher = createTelegramPusher({\n 215→    bot,\n 216→    targetChatId: 123456,\n 217→    segmentInterval: 10 // Fast for testing\n 218→  });\n 219→\n 220→  // Create a message longer than 4000 chars\n 221→  const longMessage = 'x'.repeat(10000);\n 222→  await pusher.sendMessageChunked(123456, longMessage);\n 223→\n 224→  // Should have sent multiple messages\n 225→  assert.ok(bot._sentMessages.length >= 2);\n 226→\n 227→  // Check segment numbering\n 228→  const hasSegmentNumber = bot._sentMessages.some(m =>\n 229→    m.text.includes('[1/') || m.text.includes('[2/')\n 230→  );\n 231→  assert.ok(hasSegmentNumber);\n 232→});\n 233→\n 234→test('[US-3] Should send as file when threshold exceeded', async () => {\n 235→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 236→  try {\n 237→    const config = createMockConfig(stateDir, bugfixStateDir);\n 238→    const pager = createLogPager({ config });\n 239→\n 240→    // Create large log content\n 241→    const largeLog = 'x'.repeat(5000);\n 242→    const shouldSendAsFile = pager.shouldSendAsFile(largeLog);\n 243→\n 244→    assert.equal(shouldSendAsFile, true);\n 245→  } finally {\n 246→    cleanup();\n 247→  }\n 248→});\n 249→\n 250→// ============================================================\n 251→// US-4: Heartbeat Progress Push Integration Tests (T-136)\n 252→// ============================================================\n 253→\n 254→test('[US-4] Heartbeat should push with throttle', async () => {\n 255→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 256→  try {\n 257→    const config = createMockConfig(stateDir, bugfixStateDir);\n 258→\n 259→    fs.writeFileSync(\n 260→      path.join(stateDir, '.pipeline-meta.json'),\n 261→      JSON.stringify({\n 262→        pid: process.pid,\n 263→        started_at: new Date().toISOString()\n 264→      })\n 265→    );\n 266→\n 267→    const bot = createMockBot();\n 268→    const aggregator = createStatusAggregator({ config });\n 269→    const pusher = createTelegramPusher({\n 270→      bot,\n 271→      targetChatId: 123456,\n 272→      heartbeatInterval: 50, // Fast for testing\n 273→      throttleInterval: 10\n 274→    });\n 275→\n 276→    pusher.startHeartbeat('feature', aggregator);\n 277→\n 278→    // Wait for heartbeat\n 279→    await new Promise(resolve => setTimeout(resolve, 100));\n 280→\n 281→    pusher.stopHeartbeat('feature');\n 282→\n 283→    // Should have sent at least one message\n 284→    assert.ok(bot._sentMessages.length >= 1);\n 285→  } finally {\n 286→    cleanup();\n 287→  }\n 288→});\n 289→\n 290→// ============================================================\n 291→// US-5: Error Summary Push Integration Tests (T-144)\n 292→// ============================================================\n 293→\n 294→test('[US-5] Error summary should include all required info', async () => {\n 295→  const bot = createMockBot();\n 296→  const pusher = createTelegramPusher({\n 297→    bot,\n 298→    targetChatId: 123456,\n 299→    errorLinesCount: 5\n 300→  });\n 301→\n 302→  const error = {\n 303→    type: 'execution_error',\n 304→    message: 'Script execution failed',\n 305→    duration: 180,\n 306→    logLines: ['Error 1', 'Error 2', 'Error 3', 'Error 4', 'Error 5']\n 307→  };\n 308→\n 309→  await pusher.pushErrorSummary('feature', 'F-005', error);\n 310→\n 311→  assert.equal(bot._sentMessages.length, 1);\n 312→  const text = bot._sentMessages[0].text;\n 313→\n 314→  // Should include feature ID\n 315→  assert.ok(text.includes('F-005'));\n 316→\n 317→  // Should include error type\n 318→  assert.ok(text.includes('execution_error') || text.includes('类型'));\n 319→\n 320→  // Should include duration\n 321→  assert.ok(text.includes('180') || text.includes('3m') || text.includes('执行时间'));\n 322→\n 323→  // Should include log lines\n 324→  assert.ok(text.includes('Error'));\n 325→});\n 326→\n 327→// ============================================================\n 328→// US-6: Diagnostic Error Messages Integration Tests (T-155)\n 329→// ============================================================\n 330→\n 331→test('[US-6] Should provide diagnostic for missing state files', async () => {\n 332→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 333→  try {\n 334→    const config = createMockConfig(stateDir, bugfixStateDir);\n 335→    const aggregator = createStatusAggregator({ config });\n 336→\n 337→    const status = await aggregator.aggregateStatus('feature');\n 338→\n 339→    // Should return idle state, not throw\n 340→    assert.equal(status.stage, 'idle');\n 341→  } finally {\n 342→    cleanup();\n 343→  }\n 344→});\n 345→\n 346→test('[US-6] Should handle corrupted JSON gracefully', async () => {\n 347→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 348→  try {\n 349→    const config = createMockConfig(stateDir, bugfixStateDir);\n 350→\n 351→    // Write corrupted JSON\n 352→    fs.writeFileSync(\n 353→      path.join(stateDir, '.pipeline-meta.json'),\n 354→      'not valid json {{{'\n 355→    );\n 356→\n 357→    const aggregator = createStatusAggregator({ config });\n 358→    const status = await aggregator.aggregateStatus('feature');\n 359→\n 360→    // Should not throw, return idle\n 361→    assert.equal(status.stage, 'idle');\n 362→  } finally {\n 363→    cleanup();\n 364→  }\n 365→});\n 366→\n 367→test('[US-6] Should provide diagnostic for missing log files', async () => {\n 368→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 369→  try {\n 370→    const config = createMockConfig(stateDir, bugfixStateDir);\n 371→    const pager = createLogPager({ config });\n 372→\n 373→    const result = await pager.readLogPage('feature', { lines: 50 });\n 374→\n 375→    assert.ok(result.ok);\n 376→    assert.ok(result.message || result.logs === '');\n 377→    assert.ok(result.metadata.logPath);\n 378→  } finally {\n 379→    cleanup();\n 380→  }\n 381→});\n 382→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:21.227Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
