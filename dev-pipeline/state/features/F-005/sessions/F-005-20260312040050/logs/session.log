{"type":"user","uuid":"b23993b6-890b-4efa-870f-7bbb411f8e55","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde910c734a8fcfd2797c1a57236c","content":[{"type":"text","text":"   1→import fs from 'node:fs';\n   2→import path from 'node:path';\n   3→\n   4→import { createInfraError, INFRA_ERROR_CODES } from './error-codes.js';\n   5→\n   6→function toArgMap(argv = []) {\n   7→  const args = Array.isArray(argv) ? argv : [];\n   8→  const map = new Map();\n   9→\n  10→  for (let i = 0; i < args.length; i += 1) {\n  11→    const token = String(args[i] ?? '');\n  12→    if (!token.startsWith('--')) {\n  13→      continue;\n  14→    }\n  15→\n  16→    const normalized = token.slice(2);\n  17→    if (!normalized) {\n  18→      continue;\n  19→    }\n  20→\n  21→    if (normalized.includes('=')) {\n  22→      const [key, ...rest] = normalized.split('=');\n  23→      map.set(key, rest.join('='));\n  24→      continue;\n  25→    }\n  26→\n  27→    const next = args[i + 1];\n  28→    if (typeof next === 'string' && !next.startsWith('--')) {\n  29→      map.set(normalized, next);\n  30→      i += 1;\n  31→    } else {\n  32→      map.set(normalized, 'true');\n  33→    }\n  34→  }\n  35→\n  36→  return map;\n  37→}\n  38→\n  39→function toAbsolutePath(raw, projectRoot) {\n  40→  const value = String(raw ?? '').trim();\n  41→  if (!value) {\n  42→    return '';\n  43→  }\n  44→\n  45→  if (path.isAbsolute(value)) {\n  46→    return path.normalize(value);\n  47→  }\n  48→\n  49→  return path.resolve(projectRoot, value);\n  50→}\n  51→\n  52→function parseInteger({ raw, field, min, code = INFRA_ERROR_CODES.CONFIG_INVALID, hint }) {\n  53→  const parsed = Number.parseInt(String(raw ?? ''), 10);\n  54→  if (!Number.isInteger(parsed) || parsed < min) {\n  55→    throwInfraError({\n  56→      code,\n  57→      field,\n  58→      message: `${field} must be an integer >= ${min}`,\n  59→      hint\n  60→    });\n  61→  }\n  62→\n  63→  return parsed;\n  64→}\n  65→\n  66→function throwInfraError({ code, field, message, hint, context = undefined }) {\n  67→  const infraError = createInfraError(code, message, {\n  68→    hint,\n  69→    context: {\n  70→      ...(context ?? {}),\n  71→      field\n  72→    }\n  73→  });\n  74→\n  75→  const err = new Error(`${infraError.message} (field: ${field}, hint: ${hint ?? 'n/a'})`);\n  76→  const mutableError = /** @type {any} */ (err);\n  77→  mutableError.code = infraError.code;\n  78→  mutableError.hint = infraError.hint;\n  79→  mutableError.context = infraError.context;\n  80→  mutableError.infraError = infraError;\n  81→  throw mutableError;\n  82→}\n  83→\n  84→function ensureDirectoryExists(dirPath, field) {\n  85→  if (!fs.existsSync(dirPath)) {\n  86→    throwInfraError({\n  87→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n  88→      field,\n  89→      message: `${field} does not exist: ${dirPath}`,\n  90→      hint: 'Ensure project root points to a repository containing dev-pipeline/'\n  91→    });\n  92→  }\n  93→}\n  94→\n  95→export function loadPipelineInfraConfig(input = {}) {\n  96→  const env = input.env ?? process.env;\n  97→  const argv = input.argv ?? [];\n  98→  const cwd = input.cwd ?? process.cwd();\n  99→  const argMap = toArgMap(argv);\n 100→\n 101→  const projectRootRaw = argMap.get('project-root') ?? env.PIPELINE_PROJECT_ROOT ?? cwd;\n 102→  const projectRoot = toAbsolutePath(projectRootRaw, cwd);\n 103→\n 104→  if (!projectRoot) {\n 105→    throwInfraError({\n 106→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 107→      field: 'projectRoot',\n 108→      message: 'projectRoot is required',\n 109→      hint: 'Set --project-root or PIPELINE_PROJECT_ROOT, or provide cwd input'\n 110→    });\n 111→  }\n 112→\n 113→  const pipelineDir = toAbsolutePath(\n 114→    argMap.get('pipeline-dir') ?? env.PIPELINE_DIR ?? path.join(projectRoot, 'dev-pipeline'),\n 115→    projectRoot\n 116→  );\n 117→\n 118→  ensureDirectoryExists(pipelineDir, 'pipelineDir');\n 119→\n 120→  const featureListPath = toAbsolutePath(\n 121→    argMap.get('feature-list') ?? env.FEATURE_LIST_PATH ?? path.join(projectRoot, 'feature-list.json'),\n 122→    projectRoot\n 123→  );\n 124→\n 125→  const bugFixListPath = toAbsolutePath(\n 126→    argMap.get('bug-fix-list') ?? env.BUG_FIX_LIST_PATH ?? path.join(projectRoot, 'bug-fix-list.json'),\n 127→    projectRoot\n 128→  );\n 129→\n 130→  // T-003: plansDir for versioned plan files\n 131→  const plansDir = toAbsolutePath(\n 132→    argMap.get('plans-dir') ?? env.PLANS_DIR ?? path.join(projectRoot, 'plans'),\n 133→    projectRoot\n 134→  );\n 135→\n 136→  const maxRetries = parseInteger({\n 137→    raw: argMap.get('max-retries') ?? env.MAX_RETRIES ?? 3,\n 138→    field: 'MAX_RETRIES',\n 139→    min: 1,\n 140→    hint: 'Set MAX_RETRIES to a positive integer'\n 141→  });\n 142→\n 143→  const sessionTimeoutSec = parseInteger({\n 144→    raw: argMap.get('session-timeout') ?? env.SESSION_TIMEOUT ?? 0,\n 145→    field: 'SESSION_TIMEOUT',\n 146→    min: 0,\n 147→    hint: 'Set SESSION_TIMEOUT to 0 or a positive integer (seconds)'\n 148→  });\n 149→\n 150→  const heartbeatIntervalSec = parseInteger({\n 151→    raw: argMap.get('heartbeat-interval') ?? env.HEARTBEAT_INTERVAL ?? 30,\n 152→    field: 'HEARTBEAT_INTERVAL',\n 153→    min: 1,\n 154→    hint: 'Set HEARTBEAT_INTERVAL to a positive integer (seconds)'\n 155→  });\n 156→\n 157→  // F-005: Heartbeat config options (AC-4.5)\n 158→  const heartbeatEnabled = String(argMap.get('heartbeat-enabled') ?? env.HEARTBEAT_ENABLED ?? 'true').trim().toLowerCase() === 'true';\n 159→\n 160→  const heartbeatChatIdRaw = argMap.get('heartbeat-chat-id') ?? env.HEARTBEAT_CHAT_ID;\n 161→  const heartbeatChatId = heartbeatChatIdRaw ? Number.parseInt(String(heartbeatChatIdRaw), 10) : null;\n 162→\n 163→  const heartbeatIntervalMs = parseInteger({\n 164→    raw: argMap.get('heartbeat-interval-ms') ?? env.HEARTBEAT_INTERVAL_MS ?? heartbeatIntervalSec * 1000,\n 165→    field: 'HEARTBEAT_INTERVAL_MS',\n 166→    min: 1000,\n 167→    hint: 'Set HEARTBEAT_INTERVAL_MS to at least 1000 (milliseconds)'\n 168→  });\n 169→\n 170→  const silentMode = String(argMap.get('silent-mode') ?? env.SILENT_MODE ?? 'false').trim().toLowerCase() === 'true';\n 171→\n 172→  const errorLinesCount = parseInteger({\n 173→    raw: argMap.get('error-lines-count') ?? env.ERROR_LINES_COUNT ?? 10,\n 174→    field: 'ERROR_LINES_COUNT',\n 175→    min: 0,\n 176→    hint: 'Set ERROR_LINES_COUNT to a non-negative integer'\n 177→  });\n 178→\n 179→  const aiCli = String(argMap.get('ai-cli') ?? env.AI_CLI ?? env.CODEBUDDY_CLI ?? 'cbc').trim();\n 180→  if (!aiCli) {\n 181→    throwInfraError({\n 182→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 183→      field: 'AI_CLI',\n 184→      message: 'AI_CLI is required',\n 185→      hint: 'Set AI_CLI or CODEBUDDY_CLI to a CLI command name'\n 186→    });\n 187→  }\n 188→\n 189→  const platformRaw = String(\n 190→    argMap.get('platform') ?? env.PRIZMKIT_PLATFORM ?? (aiCli.includes('claude') ? 'claude' : 'codebuddy')\n 191→  ).trim();\n 192→\n 193→  if (platformRaw !== 'codebuddy' && platformRaw !== 'claude') {\n 194→    throwInfraError({\n 195→      code: INFRA_ERROR_CODES.CONFIG_INVALID,\n 196→      field: 'PRIZMKIT_PLATFORM',\n 197→      message: `Unsupported platform: ${platformRaw}`,\n 198→      hint: \"Use 'codebuddy' or 'claude'\"\n 199→    });\n 200→  }\n 201→\n 202→  return Object.freeze({\n 203→    projectRoot,\n 204→    pipelineDir,\n 205→    featureListPath,\n 206→    bugFixListPath,\n 207→    plansDir,\n 208→    stateDir: path.join(pipelineDir, 'state'),\n 209→    bugfixStateDir: path.join(pipelineDir, 'bugfix-state'),\n 210→    maxRetries,\n 211→    sessionTimeoutSec,\n 212→    heartbeatIntervalSec,\n 213→    // F-005: Heartbeat config options (AC-4.5)\n 214→    heartbeatEnabled,\n 215→    heartbeatChatId,\n 216→    heartbeatIntervalMs,\n 217→    silentMode,\n 218→    errorLinesCount,\n 219→    aiCli,\n 220→    platform: platformRaw\n 221→  });\n 222→}\n 223→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:54.971Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
