{"type":"user","uuid":"f7a98ee8-a20a-4b6b-a15d-03c06655eb81","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde870e7db7b075237b3a32b4a54a","content":[{"type":"text","text":"   1→export const INFRA_ERROR_CODES = Object.freeze({\n   2→  // Existing codes\n   3→  CONFIG_MISSING: 'CONFIG_MISSING',\n   4→  CONFIG_INVALID: 'CONFIG_INVALID',\n   5→  PATH_INVALID: 'PATH_INVALID',\n   6→  SCRIPT_NOT_FOUND: 'SCRIPT_NOT_FOUND',\n   7→  EXEC_TIMEOUT: 'EXEC_TIMEOUT',\n   8→  EXEC_FAILED: 'EXEC_FAILED',\n   9→\n  10→  // F-004: Pipeline Process Controller\n  11→  LOCK_ACQUISITION_FAILED: 'LOCK_ACQUISITION_FAILED',\n  12→  ALREADY_STOPPED: 'ALREADY_STOPPED',\n  13→  PIPELINE_NOT_RUNNING: 'PIPELINE_NOT_RUNNING',\n  14→  INVALID_TARGET: 'INVALID_TARGET',\n  15→  TARGET_NOT_RETRYABLE: 'TARGET_NOT_RETRYABLE',\n  16→  DAEMON_START_FAILED: 'DAEMON_START_FAILED'\n  17→});\n  18→\n  19→const ERROR_CODE_SET = new Set(Object.values(INFRA_ERROR_CODES));\n  20→\n  21→export function isInfraErrorCode(code) {\n  22→  return ERROR_CODE_SET.has(code);\n  23→}\n  24→\n  25→export function createInfraError(code, message, options = {}) {\n  26→  if (!isInfraErrorCode(code)) {\n  27→    throw new Error(`Unknown infra error code: ${code}`);\n  28→  }\n  29→\n  30→  return {\n  31→    code,\n  32→    message: String(message ?? ''),\n  33→    ...(options.hint ? { hint: String(options.hint) } : {}),\n  34→    ...(options.context ? { context: options.context } : {})\n  35→  };\n  36→}\n  37→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde86ad9a0ae1a9c5cf86c76a0ac0","__timestamp":"2026-03-11T20:12:00.217Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
{"type":"user","uuid":"6527cf8c-c334-4d56-bbf6-06b6d32e24e6","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde8710311774262675efc5ebeaab","content":[{"type":"text","text":"   1→/**\n   2→ * State Manager\n   3→ *\n   4→ * F-004: Pipeline Process Controller - US-5 Status Query, US-6 Logs Query\n   5→ *\n   6→ * Manages reading and writing pipeline state files including:\n   7→ * - Daemon meta (.pipeline-meta.json)\n   8→ * - Pipeline state (pipeline.json)\n   9→ * - Current session (current-session.json)\n  10→ * - Last result (.last-result.json)\n  11→ *\n  12→ * Design Decisions:\n  13→ * - D3: Reuse existing state files (backward compatible)\n  14→ * - D6: Last result stored in separate file\n  15→ */\n  16→\n  17→import fs from 'node:fs';\n  18→import path from 'node:path';\n  19→\n  20→import { loadPipelineInfraConfig } from './config-loader.js';\n  21→import { getStatePaths } from './path-policy.js';\n  22→\n  23→/**\n  24→ * @typedef {'feature' | 'bugfix'} PipelineType\n  25→ */\n  26→\n  27→/**\n  28→ * @typedef {Object} DaemonMeta\n  29→ * @property {number} pid - Daemon process ID\n  30→ * @property {string} started_at - ISO timestamp when daemon started\n  31→ * @property {string} feature_list - Path to feature list\n  32→ * @property {string} env_overrides - Environment overrides string\n  33→ * @property {string} log_file - Path to log file\n  34→ */\n  35→\n  36→/**\n  37→ * @typedef {Object} PipelineState\n  38→ * @property {string} run_id - Unique run identifier\n  39→ * @property {string} status - Pipeline status (running/paused/completed/failed)\n  40→ * @property {string} feature_list_path - Path to feature list\n  41→ * @property {string} created_at - ISO timestamp when created\n  42→ * @property {number} total_features - Total features to process\n  43→ * @property {number} completed_features - Number of completed features\n  44→ * @property {string} [paused_at] - ISO timestamp when paused\n  45→ */\n  46→\n  47→/**\n  48→ * @typedef {Object} LastResult\n  49→ * @property {string} runId - Run identifier\n  50→ * @property {string} completedAt - ISO timestamp when completed\n  51→ * @property {'success' | 'failed' | 'partial'} status - Completion status\n  52→ * @property {number} featuresTotal - Total features\n  53→ * @property {number} featuresCompleted - Completed features count\n  54→ * @property {number} [exitCode] - Exit code\n  55→ * @property {string} [message] - Result message\n  56→ */\n  57→\n  58→/**\n  59→ * Safely read and parse a JSON file.\n  60→ * @param {string} filePath - File path\n  61→ * @returns {Object | null} Parsed JSON or null if file doesn't exist\n  62→ */\n  63→function readJsonFile(filePath) {\n  64→  try {\n  65→    const content = fs.readFileSync(filePath, 'utf8');\n  66→    return JSON.parse(content);\n  67→  } catch {\n  68→    return null;\n  69→  }\n  70→}\n  71→\n  72→/**\n  73→ * Write JSON to file atomically.\n  74→ * @param {string} filePath - File path\n  75→ * @param {Object} data - Data to write\n  76→ */\n  77→function writeJsonFile(filePath, data) {\n  78→  const dir = path.dirname(filePath);\n  79→  if (!fs.existsSync(dir)) {\n  80→    fs.mkdirSync(dir, { recursive: true });\n  81→  }\n  82→\n  83→  const tempPath = `${filePath}.${Date.now()}.tmp`;\n  84→  fs.writeFileSync(tempPath, JSON.stringify(data, null, 2));\n  85→  fs.renameSync(tempPath, filePath);\n  86→}\n  87→\n  88→/**\n  89→ * Check if a process is alive.\n  90→ * @param {number} pid - Process ID to check\n  91→ * @returns {boolean} True if process is alive\n  92→ */\n  93→function isProcessAlive(pid) {\n  94→  try {\n  95→    process.kill(pid, 0);\n  96→    return true;\n  97→  } catch (error) {\n  98→    return error.code !== 'ESRCH';\n  99→  }\n 100→}\n 101→\n 102→/**\n 103→ * Create a state manager instance.\n 104→ * @param {Object} [options] - Options\n 105→ * @param {Object} [options.config] - Pipeline config (will load if not provided)\n 106→ * @returns {Object} State manager instance\n 107→ */\n 108→export function createStateManager(options = {}) {\n 109→  const config = options.config ?? loadPipelineInfraConfig();\n 110→\n 111→  /**\n 112→   * Get state paths for pipeline type.\n 113→   * @param {PipelineType} type - Pipeline type\n 114→   * @returns {Object} State paths\n 115→   */\n 116→  function getPaths(type) {\n 117→    return getStatePaths(config.projectRoot, type);\n 118→  }\n 119→\n 120→  /**\n 121→   * Read daemon meta file.\n 122→   * @param {PipelineType} type - Pipeline type\n 123→   * @returns {Promise<DaemonMeta | null>} Daemon meta or null\n 124→   */\n 125→  async function readDaemonMeta(type) {\n 126→    const paths = getPaths(type);\n 127→    return readJsonFile(paths.daemonMetaFile);\n 128→  }\n 129→\n 130→  /**\n 131→   * Read pipeline state file.\n 132→   * @param {PipelineType} type - Pipeline type\n 133→   * @returns {Promise<PipelineState | null>} Pipeline state or null\n 134→   */\n 135→  async function readPipelineState(type) {\n 136→    const paths = getPaths(type);\n 137→    return readJsonFile(paths.pipelineStateFile);\n 138→  }\n 139→\n 140→  /**\n 141→   * Read current session file.\n 142→   * @param {PipelineType} type - Pipeline type\n 143→   * @returns {Promise<Object | null>} Current session or null\n 144→   */\n 145→  async function readCurrentSession(type) {\n 146→    const paths = getPaths(type);\n 147→    return readJsonFile(paths.currentSessionFile);\n 148→  }\n 149→\n 150→  /**\n 151→   * Get last result.\n 152→   * @param {PipelineType} type - Pipeline type\n 153→   * @returns {Promise<LastResult | null>} Last result or null\n 154→   */\n 155→  async function getLastResult(type) {\n 156→    const paths = getPaths(type);\n 157→    return readJsonFile(paths.lastResultFile);\n 158→  }\n 159→\n 160→  /**\n 161→   * Write daemon meta file.\n 162→   * @param {PipelineType} type - Pipeline type\n 163→   * @param {DaemonMeta} meta - Daemon meta to write\n 164→   * @returns {Promise<void>}\n 165→   */\n 166→  async function writeDaemonMeta(type, meta) {\n 167→    const paths = getPaths(type);\n 168→    writeJsonFile(paths.daemonMetaFile, meta);\n 169→  }\n 170→\n 171→  /**\n 172→   * Write last result file.\n 173→   * @param {PipelineType} type - Pipeline type\n 174→   * @param {LastResult} result - Last result to write\n 175→   * @returns {Promise<void>}\n 176→   */\n 177→  async function writeLastResult(type, result) {\n 178→    const paths = getPaths(type);\n 179→    writeJsonFile(paths.lastResultFile, result);\n 180→  }\n 181→\n 182→  /**\n 183→   * Check if daemon is running.\n 184→   * @param {PipelineType} type - Pipeline type\n 185→   * @returns {Promise<boolean>} True if daemon is running\n 186→   */\n 187→  async function isDaemonRunning(type) {\n 188→    const meta = await readDaemonMeta(type);\n 189→    if (!meta || !meta.pid) {\n 190→      return false;\n 191→    }\n 192→    return isProcessAlive(meta.pid);\n 193→  }\n 194→\n 195→  /**\n 196→   * Get daemon PID.\n 197→   * @param {PipelineType} type - Pipeline type\n 198→   * @returns {Promise<number | null>} Daemon PID or null\n 199→   */\n 200→  async function getDaemonPid(type) {\n 201→    const meta = await readDaemonMeta(type);\n 202→    return meta?.pid ?? null;\n 203→  }\n 204→\n 205→  /**\n 206→   * Read log file with line limit.\n 207→   * @param {PipelineType} type - Pipeline type\n 208→   * @param {number} [lines] - Number of lines (default: 100)\n 209→   * @returns {Promise<{logs: string, logPath: string, lines: number}>}\n 210→   */\n 211→  async function readLogs(type, lines = 100) {\n 212→    const paths = getPaths(type);\n 213→    const logPath = paths.daemonLogFile;\n 214→\n 215→    if (!fs.existsSync(logPath)) {\n 216→      return { logs: '', logPath, lines: 0 };\n 217→    }\n 218→\n 219→    try {\n 220→      const content = fs.readFileSync(logPath, 'utf8');\n 221→      const allLines = content.split('\\n');\n 222→      const selectedLines = allLines.slice(-lines);\n 223→      return {\n 224→        logs: selectedLines.join('\\n'),\n 225→        logPath,\n 226→        lines: selectedLines.filter(l => l.trim()).length\n 227→      };\n 228→    } catch {\n 229→      return { logs: '', logPath, lines: 0 };\n 230→    }\n 231→  }\n 232→\n 233→  return {\n 234→    readDaemonMeta,\n 235→    readPipelineState,\n 236→    readCurrentSession,\n 237→    getLastResult,\n 238→    writeDaemonMeta,\n 239→    writeLastResult,\n 240→    isDaemonRunning,\n 241→    getDaemonPid,\n 242→    readLogs\n 243→  };\n 244→}\n 245→\n 246→// Default instance\n 247→let defaultManager = null;\n 248→\n 249→/**\n 250→ * Get default state manager instance.\n 251→ * @returns {Object} Default state manager\n 252→ */\n 253→export function getDefaultStateManager() {\n 254→  if (!defaultManager) {\n 255→    defaultManager = createStateManager();\n 256→  }\n 257→  return defaultManager;\n 258→}\n 259→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde86ad9a0ae1a9c5cf86c76a0ac0","__timestamp":"2026-03-11T20:12:00.217Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
