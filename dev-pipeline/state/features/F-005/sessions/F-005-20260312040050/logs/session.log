{"type":"user","uuid":"1599cdcb-3ed7-4e1f-8752-afd6cb85ac91","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde8c5ed913e16212aace25ddd65a","content":[{"type":"text","text":"   1→/**\n   2→ * Log Pager Service\n   3→ *\n   4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-2: Paginated Logs Query, US-3: Message Length Compliance\n   5→ *\n   6→ * Handles paginated log reading with offset and line limits.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D3: CLI argument pagination, no complex protocol\n  10→ * - D5: Real-time error extraction, no additional storage\n  11→ */\n  12→\n  13→import fs from 'node:fs';\n  14→import readline from 'node:readline';\n  15→import { once } from 'node:events';\n  16→\n  17→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  18→import { getStatePaths } from '../pipeline-infra/path-policy.js';\n  19→\n  20→const MAX_LINES = 500;\n  21→const DEFAULT_LINES = 50;\n  22→const FILE_THRESHOLD_BYTES = 4000;\n  23→const LARGE_FILE_THRESHOLD = 1024 * 1024; // 1MB - use streaming for larger files\n  24→\n  25→/**\n  26→ * Create a log pager instance.\n  27→ * @param {Object} options - Options\n  28→ * @param {Object} [options.stateManager] - State manager instance\n  29→ * @param {Object} [options.config] - Pipeline config\n  30→ * @returns {Object} Log pager interface\n  31→ */\n  32→export function createLogPager(options = {}) {\n  33→  const config = options.config || loadPipelineInfraConfig();\n  34→\n  35→  /**\n  36→   * Get log file path for pipeline type.\n  37→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  38→   * @returns {string} Log file path\n  39→   */\n  40→  function getLogPath(type) {\n  41→    const paths = getStatePaths(config.projectRoot, type);\n  42→    return paths.daemonLogFile;\n  43→  }\n  44→\n  45→  /**\n  46→   * Count total lines in a file.\n  47→   * @param {string} filePath - File path\n  48→   * @returns {Promise<number>} Total line count\n  49→   */\n  50→  async function countLines(filePath) {\n  51→    try {\n  52→      const content = fs.readFileSync(filePath, 'utf8');\n  53→      return content.split('\\n').filter(l => l.trim()).length;\n  54→    } catch {\n  55→      return 0;\n  56→    }\n  57→  }\n  58→\n  59→  /**\n  60→   * Stream-read last N lines from a large file efficiently.\n  61→   * @param {string} filePath - File path\n  62→   * @param {number} lineCount - Number of lines to read\n  63→   * @param {number} offset - Lines to skip from end\n  64→   * @returns {Promise<{lines: string[], totalLines: number}>}\n  65→   */\n  66→  async function streamReadLastLines(filePath, lineCount, offset = 0) {\n  67→    return new Promise((resolve, reject) => {\n  68→      const lines = [];\n  69→      let totalLines = 0;\n  70→\n  71→      const stream = fs.createReadStream(filePath, { encoding: 'utf8' });\n  72→      const rl = readline.createInterface({\n  73→        input: stream,\n  74→        crlfDelay: Infinity\n  75→      });\n  76→\n  77→      rl.on('line', (line) => {\n  78→        totalLines++;\n  79→        // We'll collect all lines then slice at the end\n  80→      });\n  81→\n  82→      rl.on('close', () => {\n  83→        // Re-open to get specific lines\n  84→        const startIdx = Math.max(0, totalLines - offset - lineCount);\n  85→        const endIdx = totalLines - offset;\n  86→\n  87→        let currentLine = 0;\n  88→        const selectedLines = [];\n  89→\n  90→        const stream2 = fs.createReadStream(filePath, { encoding: 'utf8' });\n  91→        const rl2 = readline.createInterface({\n  92→          input: stream2,\n  93→          crlfDelay: Infinity\n  94→        });\n  95→\n  96→        rl2.on('line', (line) => {\n  97→          currentLine++;\n  98→          if (currentLine > startIdx && currentLine <= endIdx) {\n  99→            if (line.trim()) {\n 100→              selectedLines.push(line);\n 101→            }\n 102→          }\n 103→        });\n 104→\n 105→        rl2.on('close', () => {\n 106→          resolve({ lines: selectedLines, totalLines });\n 107→        });\n 108→\n 109→        rl2.on('error', (err) => {\n 110→          reject(err);\n 111→        });\n 112→      });\n 113→\n 114→      rl.on('error', (err) => {\n 115→        reject(err);\n 116→      });\n 117→    });\n 118→  }\n 119→\n 120→  /**\n 121→   * Read log page with pagination.\n 122→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 123→   * @param {Object} pageOptions - Pagination options\n 124→   * @param {number} [pageOptions.lines=50] - Number of lines to read\n 125→   * @param {number} [pageOptions.offset=0] - Number of lines to skip\n 126→   * @param {boolean} [pageOptions.reverse=true] - Read from end (newest first)\n 127→   * @returns {Promise<Object>} Log page result\n 128→   */\n 129→  async function readLogPage(type, pageOptions = {}) {\n 130→    const requestedLines = Math.min(pageOptions.lines || DEFAULT_LINES, MAX_LINES);\n 131→    const offset = pageOptions.offset || 0;\n 132→    const reverse = pageOptions.reverse !== false; // Default true\n 133→\n 134→    const logPath = getLogPath(type);\n 135→\n 136→    // Check if file exists\n 137→    if (!fs.existsSync(logPath)) {\n 138→      return {\n 139→        ok: true,\n 140→        logs: '',\n 141→        metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 142→        message: '📭 暂无日志。Pipeline 尚未运行或日志文件不存在。'\n 143→      };\n 144→    }\n 145→\n 146→    try {\n 147→      const content = fs.readFileSync(logPath, 'utf8');\n 148→      const allLines = content.split('\\n').filter(l => l.trim());\n 149→      const totalLines = allLines.length;\n 150→\n 151→      if (totalLines === 0) {\n 152→        return {\n 153→          ok: true,\n 154→          logs: '',\n 155→          metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 156→          message: '📭 日志文件为空。'\n 157→        };\n 158→      }\n 159→\n 160→      // Apply pagination\n 161→      let selectedLines;\n 162→      let pageStart;\n 163→      let pageEnd;\n 164→\n 165→      if (reverse) {\n 166→        // Read from end (newest first)\n 167→        const startIdx = Math.max(0, totalLines - offset - requestedLines);\n 168→        const endIdx = totalLines - offset;\n 169→        selectedLines = allLines.slice(startIdx, endIdx).reverse();\n 170→        pageStart = startIdx + 1;\n 171→        pageEnd = endIdx;\n 172→      } else {\n 173→        // Read from beginning\n 174→        selectedLines = allLines.slice(offset, offset + requestedLines);\n 175→        pageStart = offset + 1;\n 176→        pageEnd = Math.min(offset + requestedLines, totalLines);\n 177→      }\n 178→\n 179→      const logs = selectedLines.join('\\n');\n 180→      const actualLines = selectedLines.length;\n 181→\n 182→      return {\n 183→        ok: true,\n 184→        logs,\n 185→        metadata: buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines)\n 186→      };\n 187→    } catch (error) {\n 188→      return {\n 189→        ok: true,\n 190→        logs: '',\n 191→        metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 192→        message: `⚠️ 读取日志失败: ${error.message}`\n 193→      };\n 194→    }\n 195→  }\n 196→\n 197→  /**\n 198→   * Extract error lines from log content.\n 199→   * @param {string} logs - Log content\n 200→   * @param {number} lineCount - Maximum lines to extract\n 201→   * @returns {Array<string>} Array of error lines\n 202→   */\n 203→  function extractErrorLines(logs, lineCount = 10) {\n 204→    if (!logs) return [];\n 205→\n 206→    const lines = logs.split('\\n');\n 207→    const errorLines = lines.filter(line =>\n 208→      line.includes('ERROR') ||\n 209→      line.includes('Error:') ||\n 210→      line.includes('Exception') ||\n 211→      line.includes('FAIL')\n 212→    );\n 213→\n 214→    // Return last N error lines\n 215→    return errorLines.slice(-lineCount);\n 216→  }\n 217→\n 218→  /**\n 219→   * Check if logs should be sent as file.\n 220→   * @param {string} logs - Log content\n 221→   * @param {number} [threshold] - Byte threshold (default 4000)\n 222→   * @returns {boolean} True if should send as file\n 223→   */\n 224→  function shouldSendAsFile(logs, threshold = FILE_THRESHOLD_BYTES) {\n 225→    if (!logs) return false;\n 226→    return Buffer.byteLength(logs, 'utf8') >= threshold;\n 227→  }\n 228→\n 229→  /**\n 230→   * Build log metadata object.\n 231→   * @param {string} logPath - Log file path\n 232→   * @param {number} totalLines - Total lines in file\n 233→   * @param {number} pageStart - Start line of page\n 234→   * @param {number} pageEnd - End line of page\n 235→   * @param {number} requestedLines - Requested lines\n 236→   * @param {number} actualLines - Actual lines returned\n 237→   * @returns {Object} Metadata object\n 238→   */\n 239→  function buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines) {\n 240→    return {\n 241→      logPath,\n 242→      totalLines,\n 243→      pageStart,\n 244→      pageEnd,\n 245→      requestedLines,\n 246→      actualLines\n 247→    };\n 248→  }\n 249→\n 250→  /**\n 251→   * Format logs for Telegram display.\n 252→   * @param {string} logs - Log content\n 253→   * @param {Object} metadata - Log metadata\n 254→   * @returns {string} Formatted message\n 255→   */\n 256→  function formatLogsForTelegram(logs, metadata = {}) {\n 257→    if (!logs || logs.trim() === '') {\n 258→      return '📭 暂无日志内容。';\n 259→    }\n 260→\n 261→    const lines = [];\n 262→\n 263→    // Add header with metadata\n 264→    lines.push('📋 **Pipeline 日志**');\n 265→    if (metadata.totalLines !== undefined) {\n 266→      lines.push(`总计: ${metadata.totalLines} 行`);\n 267→      if (metadata.pageStart && metadata.pageEnd) {\n 268→        lines.push(`显示: 第 ${metadata.pageStart}-${metadata.pageEnd} 行`);\n 269→      }\n 270→    }\n 271→    lines.push('');\n 272→\n 273→    // Add segment numbering if provided\n 274→    if (metadata.totalSegments && metadata.segmentIndex !== undefined) {\n 275→      lines[0] = `📋 **Pipeline 日志** [${metadata.segmentIndex + 1}/${metadata.totalSegments}]`;\n 276→    }\n 277→\n 278→    // Add log content\n 279→    lines.push('```');\n 280→    lines.push(logs);\n 281→    lines.push('```');\n 282→\n 283→    return lines.join('\\n');\n 284→  }\n 285→\n 286→  return {\n 287→    readLogPage,\n 288→    formatLogsForTelegram,\n 289→    extractErrorLines,\n 290→    shouldSendAsFile,\n 291→    buildLogMetadata\n 292→  };\n 293→}\n 294→\n 295→export default createLogPager;\n 296→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde86ad9a0ae1a9c5cf86c76a0ac0","__timestamp":"2026-03-11T20:17:47.718Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
