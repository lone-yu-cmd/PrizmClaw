{"type":"user","uuid":"a235b841-d452-4c01-894d-c3eca33f4aa5","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde911a853351fdd9a228799173f8","content":[{"type":"text","text":"   1→import fs from 'node:fs';\n   2→import { EventEmitter } from 'node:events';\n   3→import { createLockManager, getDefaultLockManager } from '../pipeline-infra/lock-manager.js';\n   4→import { createStateManager, getDefaultStateManager } from '../pipeline-infra/state-manager.js';\n   5→import { executePipelineCommand, buildPipelineCommand } from '../pipeline-infra/script-runner.js';\n   6→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   7→import { resolveDaemonLogPaths } from '../pipeline-infra/path-policy.js';\n   8→import { INFRA_ERROR_CODES } from '../pipeline-infra/error-codes.js';\n   9→\n  10→const DEFAULT_LOG_LINES = 100;\n  11→const DEFAULT_STOP_TIMEOUT_MS = 10000;\n  12→\n  13→/**\n  14→ * Build an error result object.\n  15→ * @param {string} errorCode - Error code\n  16→ * @param {string} message - Error message\n  17→ * @param {Object} [options] - Additional options\n  18→ * @param {string} [options.hint] - Hint for resolving the error\n  19→ * @param {Object} [options.context] - Additional context\n  20→ * @returns {Object} Error result\n  21→ */\n  22→function buildError(errorCode, message, options = {}) {\n  23→  return {\n  24→    ok: false,\n  25→    errorCode,\n  26→    message,\n  27→    ...(options.hint ? { hint: options.hint } : {}),\n  28→    ...(options.context ? { context: options.context } : {})\n  29→  };\n  30→}\n  31→\n  32→/**\n  33→ * Build a success result object.\n  34→ * @param {string} message - Success message\n  35→ * @param {Object} [extra] - Additional fields\n  36→ * @returns {Object} Success result\n  37→ */\n  38→function buildResult(message, extra = {}) {\n  39→  return {\n  40→    ok: true,\n  41→    message,\n  42→    ...extra\n  43→  };\n  44→}\n  45→\n  46→/**\n  47→ * Generate a unique run ID.\n  48→ * @returns {string} Run ID\n  49→ */\n  50→function generateRunId() {\n  51→  const now = new Date();\n  52→  const timestamp = now.toISOString().replace(/[-:T]/g, '').slice(0, 15);\n  53→  return `run-${timestamp}`;\n  54→}\n  55→\n  56→/**\n  57→ * Read last N lines from a file.\n  58→ * @param {string} filePath - Path to file\n  59→ * @param {number} lines - Number of lines to read\n  60→ * @returns {string} File content\n  61→ */\n  62→function readLastLines(filePath, lines) {\n  63→  try {\n  64→    const content = fs.readFileSync(filePath, 'utf8');\n  65→    const allLines = content.split('\\n');\n  66→    const selectedLines = allLines.slice(-lines);\n  67→    return selectedLines.join('\\n');\n  68→  } catch {\n  69→    return '';\n  70→  }\n  71→}\n  72→\n  73→/**\n  74→ * Create a pipeline controller instance.\n  75→ * @param {Object} options - Options\n  76→ * @param {Object} [options.lockManager] - Lock manager instance\n  77→ * @param {Object} [options.stateManager] - State manager instance\n  78→ * @param {Function} [options.scriptRunner] - Script runner function\n  79→ * @param {Object} [options.config] - Pipeline config\n  80→ * @returns {Object} Pipeline controller interface\n  81→ */\n  82→export function createPipelineController(options = {}) {\n  83→  const lockManager = options.lockManager || getDefaultLockManager();\n  84→  const stateManager = options.stateManager || getDefaultStateManager();\n  85→  const scriptRunner = options.scriptRunner || executePipelineCommand;\n  86→  const config = options.config || loadPipelineInfraConfig();\n  87→\n  88→  // F-005: Lifecycle event emitter for heartbeat and notifications\n  89→  const eventEmitter = new EventEmitter();\n  90→\n  91→  /**\n  92→   * Internal: Acquire lock and return result.\n  93→   * @param {string} type - Pipeline type\n  94→   * @returns {Promise<Object|null>} Lock result or null on success\n  95→   */\n  96→  async function _acquireLock(type) {\n  97→    const lockResult = await lockManager.acquireLock(type);\n  98→    if (!lockResult.ok) {\n  99→      return buildError(\n 100→        INFRA_ERROR_CODES.LOCK_ACQUISITION_FAILED,\n 101→        `Pipeline ${type} is already running`,\n 102→        {\n 103→          hint: 'Stop the current pipeline first or use forceUnlock',\n 104→          context: { currentHolder: lockResult.currentHolder }\n 105→        }\n 106→      );\n 107→    }\n 108→    return null;\n 109→  }\n 110→\n 111→  /**\n 112→   * Internal: Release lock.\n 113→   * @param {string} type - Pipeline type\n 114→   */\n 115→  async function _releaseLock(type) {\n 116→    await lockManager.releaseLock(type);\n 117→  }\n 118→\n 119→  return {\n 120→    // Internal methods (exposed for testing)\n 121→    _acquireLock,\n 122→    _releaseLock,\n 123→\n 124→    // F-005: Lifecycle event emitter\n 125→    eventEmitter,\n 126→\n 127→    // Event names\n 128→    events: {\n 129→      PIPELINE_START: 'pipeline:start',\n 130→      PIPELINE_STOP: 'pipeline:stop',\n 131→      FEATURE_COMPLETE: 'feature:complete',\n 132→      FEATURE_ERROR: 'feature:error'\n 133→    },\n 134→\n 135→    /**\n 136→     * Register a lifecycle hook.\n 137→     * @param {string} event - Event name\n 138→     * @param {Function} callback - Callback function\n 139→     */\n 140→    on(event, callback) {\n 141→      eventEmitter.on(event, callback);\n 142→    },\n 143→\n 144→    /**\n 145→     * Remove a lifecycle hook.\n 146→     * @param {string} event - Event name\n 147→     * @param {Function} callback - Callback function\n 148→     */\n 149→    off(event, callback) {\n 150→      eventEmitter.off(event, callback);\n 151→    },\n 152→\n 153→    /**\n 154→     * Start a pipeline.\n 155→     * @param {Object} params - Parameters\n 156→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 157→     * @param {string} [params.targetId] - Optional target ID to start with\n 158→     * @param {string} [params.listPath] - Optional list path\n 159→     * @param {boolean} [params.daemon=true] - Run in daemon mode\n 160→     * @param {Object} [params.envOverrides] - Environment overrides\n 161→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 162→     * @returns {Promise<Object>} Start result\n 163→     */\n 164→    async startPipeline(params) {\n 165→      const { type = 'feature', targetId, listPath, daemon = true, envOverrides, timeoutMs } = params;\n 166→\n 167→      // Acquire lock\n 168→      const lockError = await _acquireLock(type);\n 169→      if (lockError) {\n 170→        return lockError;\n 171→      }\n 172→\n 173→      // Build and execute command\n 174→      const runId = generateRunId();\n 175→\n 176→      try {\n 177→        const result = await scriptRunner({\n 178→          pipelineType: type,\n 179→          action: 'run',\n 180→          targetId,\n 181→          listPath,\n 182→          envOverrides,\n 183→          timeoutMs\n 184→        });\n 185→\n 186→        if (!result.ok) {\n 187→          // Release lock on failure\n 188→          await _releaseLock(type);\n 189→          return buildError(\n 190→            result.errorCode || INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 191→            result.stderr || 'Failed to start pipeline',\n 192→            { context: { exitCode: result.exitCode } }\n 193→          );\n 194→        }\n 195→\n 196→        // F-005: Emit pipeline:start event for heartbeat pusher\n 197→        eventEmitter.emit('pipeline:start', {\n 198→          type,\n 199→          runId,\n 200→          startedAt: new Date().toISOString(),\n 201→          targetId,\n 202→          listPath\n 203→        });\n 204→\n 205→        return buildResult(`Pipeline ${type} started successfully`, {\n 206→          runId,\n 207→          pid: daemon ? process.pid : undefined,\n 208→          stdout: result.stdout\n 209→        });\n 210→      } catch (error) {\n 211→        await _releaseLock(type);\n 212→        return buildError(\n 213→          INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 214→          error.message,\n 215→          { hint: 'Check pipeline scripts and configuration' }\n 216→        );\n 217→      }\n 218→    },\n 219→\n 220→    /**\n 221→     * Stop a pipeline.\n 222→     * @param {Object} params - Parameters\n 223→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 224→     * @param {number} [params.timeoutMs=10000] - Timeout in milliseconds\n 225→     * @returns {Promise<Object>} Stop result\n 226→     */\n 227→    async stopPipeline(params) {\n 228→      const { type = 'feature', timeoutMs = DEFAULT_STOP_TIMEOUT_MS } = params;\n 229→\n 230→      // Check if daemon is running\n 231→      const isRunning = await stateManager.isDaemonRunning(type);\n 232→      const previousPid = await stateManager.getDaemonPid(type);\n 233→\n 234→      if (!isRunning) {\n 235→        // Already stopped\n 236→        return buildResult(`Pipeline ${type} is not running`, {\n 237→          errorCode: INFRA_ERROR_CODES.ALREADY_STOPPED,\n 238→          previousPid\n 239→        });\n 240→      }\n 241→\n 242→      try {\n 243→        // Execute stop command\n 244→        const result = await scriptRunner({\n 245→          pipelineType: type,\n 246→          action: 'stop',\n 247→          timeoutMs\n 248→        });\n 249→\n 250→        // Release lock\n 251→        await _releaseLock(type);\n 252→\n 253→        if (!result.ok) {\n 254→          return buildError(\n 255→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 256→            result.stderr || 'Failed to stop pipeline',\n 257→            { context: { previousPid } }\n 258→          );\n 259→        }\n 260→\n 261→        // F-005: Emit pipeline:stop event for heartbeat pusher\n 262→        eventEmitter.emit('pipeline:stop', {\n 263→          type,\n 264→          stoppedAt: new Date().toISOString(),\n 265→          previousPid\n 266→        });\n 267→\n 268→        return buildResult(`Pipeline ${type} stopped successfully`, {\n 269→          previousPid\n 270→        });\n 271→      } catch (error) {\n 272→        // Still release lock on error\n 273→        await _releaseLock(type);\n 274→        return buildError(\n 275→          INFRA_ERROR_CODES.EXEC_FAILED,\n 276→          error.message,\n 277→          { context: { previousPid } }\n 278→        );\n 279→      }\n 280→    },\n 281→\n 282→    /**\n 283→     * Retry a target.\n 284→     * @param {Object} params - Parameters\n 285→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 286→     * @param {string} params.targetId - Target ID to retry\n 287→     * @param {string} [params.listPath] - Optional list path\n 288→     * @param {boolean} [params.daemon=false] - Run in daemon mode\n 289→     * @param {Object} [params.envOverrides] - Environment overrides\n 290→     * @returns {Promise<Object>} Retry result\n 291→     */\n 292→    async retryTarget(params) {\n 293→      const { type = 'feature', targetId, listPath, daemon = false, envOverrides } = params;\n 294→\n 295→      // Validate targetId\n 296→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 297→        return buildError(\n 298→          INFRA_ERROR_CODES.INVALID_TARGET,\n 299→          'targetId is required for retry',\n 300→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 301→        );\n 302→      }\n 303→\n 304→      // For daemon mode, acquire lock\n 305→      if (daemon) {\n 306→        const lockError = await _acquireLock(type);\n 307→        if (lockError) {\n 308→          return lockError;\n 309→        }\n 310→      }\n 311→\n 312→      try {\n 313→        const result = await scriptRunner({\n 314→          pipelineType: type,\n 315→          action: 'retry',\n 316→          targetId: targetId.trim(),\n 317→          listPath,\n 318→          envOverrides\n 319→        });\n 320→\n 321→        if (daemon) {\n 322→          await _releaseLock(type);\n 323→        }\n 324→\n 325→        if (!result.ok) {\n 326→          return buildError(\n 327→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 328→            result.stderr || `Failed to retry target ${targetId}`,\n 329→            { context: { targetId } }\n 330→          );\n 331→        }\n 332→\n 333→        return buildResult(`Target ${targetId} retry completed`, {\n 334→          targetId,\n 335→          stdout: result.stdout\n 336→        });\n 337→      } catch (error) {\n 338→        if (daemon) {\n 339→          await _releaseLock(type);\n 340→        }\n 341→        return buildError(\n 342→          INFRA_ERROR_CODES.EXEC_FAILED,\n 343→          error.message,\n 344→          { context: { targetId } }\n 345→        );\n 346→      }\n 347→    },\n 348→\n 349→    /**\n 350→     * Run a single target without affecting pipeline state.\n 351→     * @param {Object} params - Parameters\n 352→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 353→     * @param {string} params.targetId - Target ID to run\n 354→     * @param {string} [params.listPath] - Optional list path\n 355→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 356→     * @param {Object} [params.envOverrides] - Environment overrides\n 357→     * @returns {Promise<Object>} Run result\n 358→     */\n 359→    async runSingle(params) {\n 360→      const { type = 'feature', targetId, listPath, timeoutMs, envOverrides } = params;\n 361→\n 362→      // Validate targetId\n 363→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 364→        return buildError(\n 365→          INFRA_ERROR_CODES.INVALID_TARGET,\n 366→          'targetId is required for runSingle',\n 367→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 368→        );\n 369→      }\n 370→\n 371→      // Note: runSingle does NOT acquire lock (independent execution per D5)\n 372→\n 373→      try {\n 374→        const result = await scriptRunner({\n 375→          pipelineType: type,\n 376→          action: 'run',\n 377→          targetId: targetId.trim(),\n 378→          listPath,\n 379→          timeoutMs,\n 380→          envOverrides\n 381→        });\n 382→\n 383→        return {\n 384→          ok: result.ok,\n 385→          targetId,\n 386→          message: result.ok\n 387→            ? `Target ${targetId} completed successfully`\n 388→            : `Target ${targetId} failed`,\n 389→          stdout: result.stdout,\n 390→          stderr: result.stderr,\n 391→          exitCode: result.exitCode,\n 392→          errorCode: result.errorCode\n 393→        };\n 394→      } catch (error) {\n 395→        return buildError(\n 396→          INFRA_ERROR_CODES.EXEC_FAILED,\n 397→          error.message,\n 398→          { context: { targetId } }\n 399→        );\n 400→      }\n 401→    },\n 402→\n 403→    /**\n 404→     * Get pipeline status.\n 405→     * @param {Object} params - Parameters\n 406→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 407→     * @returns {Promise<Object>} Status result\n 408→     */\n 409→    async getStatus(params) {\n 410→      const { type = 'feature' } = params;\n 411→\n 412→      const isRunning = await stateManager.isDaemonRunning(type);\n 413→      const pid = await stateManager.getDaemonPid(type);\n 414→      const pipelineState = await stateManager.readPipelineState(type);\n 415→      const currentSession = await stateManager.readCurrentSession(type);\n 416→      const lastResult = await stateManager.getLastResult(type);\n 417→      const lockInfo = await lockManager.getLockInfo(type);\n 418→\n 419→      const result = {\n 420→        ok: true,\n 421→        isRunning,\n 422→        pid: isRunning ? pid : undefined,\n 423→        message: isRunning\n 424→          ? `Pipeline ${type} is running`\n 425→          : `Pipeline ${type} is not running`\n 426→      };\n 427→\n 428→      // Add current feature info if running\n 429→      if (isRunning && currentSession) {\n 430→        result.currentFeature = currentSession.feature_id;\n 431→        result.startedAt = currentSession.started_at;\n 432→      }\n 433→\n 434→      // Add last result if not running\n 435→      if (!isRunning && lastResult) {\n 436→        result.lastResult = lastResult;\n 437→      }\n 438→\n 439→      // Add lock info\n 440→      if (lockInfo) {\n 441→        result.lockInfo = lockInfo;\n 442→      }\n 443→\n 444→      return result;\n 445→    },\n 446→\n 447→    /**\n 448→     * Get pipeline logs.\n 449→     * @param {Object} params - Parameters\n 450→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 451→     * @param {number} [params.lines=100] - Number of lines to read\n 452→     * @returns {Promise<Object>} Logs result\n 453→     */\n 454→    async getLogs(params) {\n 455→      const { type = 'feature', lines = DEFAULT_LOG_LINES } = params;\n 456→\n 457→      const logPaths = resolveDaemonLogPaths(config.projectRoot);\n 458→      const logPath = type === 'feature'\n 459→        ? logPaths.featureDaemonLog\n 460→        : logPaths.bugfixDaemonLog;\n 461→\n 462→      const logs = readLastLines(logPath, lines);\n 463→\n 464→      return buildResult(`Retrieved ${lines} lines from ${type} log`, {\n 465→        logs,\n 466→        logPath,\n 467→        lines\n 468→      });\n 469→    },\n 470→\n 471→    /**\n 472→     * Force unlock a pipeline (admin operation).\n 473→     * @param {Object} params - Parameters\n 474→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 475→     * @returns {Promise<Object>} Unlock result\n 476→     */\n 477→    async forceUnlock(params) {\n 478→      const { type = 'feature' } = params;\n 479→\n 480→      const result = await lockManager.forceUnlock(type);\n 481→\n 482→      return buildResult(`Lock released for ${type} pipeline`, {\n 483→        previousPid: result.previousPid\n 484→      });\n 485→    }\n 486→  };\n 487→}\n 488→\n 489→// Default instance\n 490→let defaultController = null;\n 491→\n 492→/**\n 493→ * Get the default pipeline controller instance.\n 494→ * @returns {Object} Pipeline controller instance\n 495→ */\n 496→export function getDefaultPipelineController() {\n 497→  if (!defaultController) {\n 498→    defaultController = createPipelineController();\n 499→  }\n 500→  return defaultController;\n 501→}\n 502→\n 503→// Export convenience methods that use default controller\n 504→export async function startPipeline(params) {\n 505→  return getDefaultPipelineController().startPipeline(params);\n 506→}\n 507→\n 508→export async function stopPipeline(params) {\n 509→  return getDefaultPipelineController().stopPipeline(params);\n 510→}\n 511→\n 512→export async function retryTarget(params) {\n 513→  return getDefaultPipelineController().retryTarget(params);\n 514→}\n 515→\n 516→export async function runSingle(params) {\n 517→  return getDefaultPipelineController().runSingle(params);\n 518→}\n 519→\n 520→export async function getStatus(params) {\n 521→  return getDefaultPipelineController().getStatus(params);\n 522→}\n 523→\n 524→export async function getLogs(params) {\n 525→  return getDefaultPipelineController().getLogs(params);\n 526→}\n 527→\n 528→export async function forceUnlock(params) {\n 529→  return getDefaultPipelineController().forceUnlock(params);\n 530→}\n 531→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde903ecc52ba80adf183cd8d5a9f","__timestamp":"2026-03-11T20:22:57.863Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
