her.throttle('test', fn);\n  assert.equal(callCount, 1); // Still 1, throttled\n  \n  console.log('✅ Test passed: throttle');\n});\n\ntest('pushErrorSummary sends notification', async () => {\n  const bot = createMockBot();\n  const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n  await pusher.pushErrorSummary('feature', 'F-005', { type: 'test', message: 'Error', duration: 60 });\n  assert.equal(bot._sentMessages.length, 1);\n  console.log('✅ Test passed: pushErrorSummary');\n});\n\" 2>&1 | grep -E \"(✅|passed|failed|Error)\" | head -20\nStdout: ✅ Test passed: createTelegramPusher factory\n✅ Test passed: throttle\n✅ Test passed: pushErrorSummary\ntest:start\"\u0004datao\"\u0007nestingI\u0000\"\u0004name\"#pushErrorSummary sends notification\"\u0004lineIn\"\u0006columnI\u0002\"\u0004file\",/Users/loneyu/SelfProjects/PrizmClaw/[eval1]{\u0005{\u0002�\u000f\u0000\u0000\u0000��\u000fo\"\u0004type\"\ttest:pass\"\u0004datao\"\u0004name\"#pushErrorSummary sends notification\"\u0007nestingI\u0000\"\n\nStderr: (empty)\nExit Code: 0\nSignal: (none)"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde86ad9a0ae1a9c5cf86c76a0ac0","__timestamp":"2026-03-11T20:16:46.416Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
