{"type":"user","uuid":"9d7ef0fa-a3bb-42b7-bef0-4f4b7461b59e","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde8c03e08925e2544923ef44003e","content":[{"type":"text","text":"   1→/**\n   2→ * Log Pager Service\n   3→ *\n   4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-2: Paginated Logs Query, US-3: Message Length Compliance\n   5→ *\n   6→ * Handles paginated log reading with offset and line limits.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D3: CLI argument pagination, no complex protocol\n  10→ * - D5: Real-time error extraction, no additional storage\n  11→ */\n  12→\n  13→import fs from 'node:fs';\n  14→import readline from 'node:readline';\n  15→import { once } from 'node:events';\n  16→\n  17→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  18→import { getStatePaths } from '../pipeline-infra/path-policy.js';\n  19→\n  20→const MAX_LINES = 500;\n  21→const DEFAULT_LINES = 50;\n  22→const FILE_THRESHOLD_BYTES = 4000;\n  23→\n  24→/**\n  25→ * Create a log pager instance.\n  26→ * @param {Object} options - Options\n  27→ * @param {Object} [options.stateManager] - State manager instance\n  28→ * @param {Object} [options.config] - Pipeline config\n  29→ * @returns {Object} Log pager interface\n  30→ */\n  31→export function createLogPager(options = {}) {\n  32→  const config = options.config || loadPipelineInfraConfig();\n  33→\n  34→  /**\n  35→   * Get log file path for pipeline type.\n  36→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  37→   * @returns {string} Log file path\n  38→   */\n  39→  function getLogPath(type) {\n  40→    const paths = getStatePaths(config.projectRoot, type);\n  41→    return paths.daemonLogFile;\n  42→  }\n  43→\n  44→  /**\n  45→   * Count total lines in a file.\n  46→   * @param {string} filePath - File path\n  47→   * @returns {Promise<number>} Total line count\n  48→   */\n  49→  async function countLines(filePath) {\n  50→    try {\n  51→      const content = fs.readFileSync(filePath, 'utf8');\n  52→      return content.split('\\n').filter(l => l.trim()).length;\n  53→    } catch {\n  54→      return 0;\n  55→    }\n  56→  }\n  57→\n  58→  /**\n  59→   * Read log page with pagination.\n  60→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  61→   * @param {Object} pageOptions - Pagination options\n  62→   * @param {number} [pageOptions.lines=50] - Number of lines to read\n  63→   * @param {number} [pageOptions.offset=0] - Number of lines to skip\n  64→   * @param {boolean} [pageOptions.reverse=true] - Read from end (newest first)\n  65→   * @returns {Promise<Object>} Log page result\n  66→   */\n  67→  async function readLogPage(type, pageOptions = {}) {\n  68→    const requestedLines = Math.min(pageOptions.lines || DEFAULT_LINES, MAX_LINES);\n  69→    const offset = pageOptions.offset || 0;\n  70→    const reverse = pageOptions.reverse !== false; // Default true\n  71→\n  72→    const logPath = getLogPath(type);\n  73→\n  74→    // Check if file exists\n  75→    if (!fs.existsSync(logPath)) {\n  76→      return {\n  77→        ok: true,\n  78→        logs: '',\n  79→        metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n  80→        message: '📭 暂无日志。Pipeline 尚未运行或日志文件不存在。'\n  81→      };\n  82→    }\n  83→\n  84→    try {\n  85→      const content = fs.readFileSync(logPath, 'utf8');\n  86→      const allLines = content.split('\\n').filter(l => l.trim());\n  87→      const totalLines = allLines.length;\n  88→\n  89→      if (totalLines === 0) {\n  90→        return {\n  91→          ok: true,\n  92→          logs: '',\n  93→          metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n  94→          message: '📭 日志文件为空。'\n  95→        };\n  96→      }\n  97→\n  98→      // Apply pagination\n  99→      let selectedLines;\n 100→      let pageStart;\n 101→      let pageEnd;\n 102→\n 103→      if (reverse) {\n 104→        // Read from end (newest first)\n 105→        const startIdx = Math.max(0, totalLines - offset - requestedLines);\n 106→        const endIdx = totalLines - offset;\n 107→        selectedLines = allLines.slice(startIdx, endIdx).reverse();\n 108→        pageStart = startIdx + 1;\n 109→        pageEnd = endIdx;\n 110→      } else {\n 111→        // Read from beginning\n 112→        selectedLines = allLines.slice(offset, offset + requestedLines);\n 113→        pageStart = offset + 1;\n 114→        pageEnd = Math.min(offset + requestedLines, totalLines);\n 115→      }\n 116→\n 117→      const logs = selectedLines.join('\\n');\n 118→      const actualLines = selectedLines.length;\n 119→\n 120→      return {\n 121→        ok: true,\n 122→        logs,\n 123→        metadata: buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines)\n 124→      };\n 125→    } catch (error) {\n 126→      return {\n 127→        ok: true,\n 128→        logs: '',\n 129→        metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 130→        message: `⚠️ 读取日志失败: ${error.message}`\n 131→      };\n 132→    }\n 133→  }\n 134→\n 135→  /**\n 136→   * Extract error lines from log content.\n 137→   * @param {string} logs - Log content\n 138→   * @param {number} lineCount - Maximum lines to extract\n 139→   * @returns {Array<string>} Array of error lines\n 140→   */\n 141→  function extractErrorLines(logs, lineCount = 10) {\n 142→    if (!logs) return [];\n 143→\n 144→    const lines = logs.split('\\n');\n 145→    const errorLines = lines.filter(line =>\n 146→      line.includes('ERROR') ||\n 147→      line.includes('Error:') ||\n 148→      line.includes('Exception') ||\n 149→      line.includes('FAIL')\n 150→    );\n 151→\n 152→    // Return last N error lines\n 153→    return errorLines.slice(-lineCount);\n 154→  }\n 155→\n 156→  /**\n 157→   * Check if logs should be sent as file.\n 158→   * @param {string} logs - Log content\n 159→   * @param {number} [threshold] - Byte threshold (default 4000)\n 160→   * @returns {boolean} True if should send as file\n 161→   */\n 162→  function shouldSendAsFile(logs, threshold = FILE_THRESHOLD_BYTES) {\n 163→    if (!logs) return false;\n 164→    return Buffer.byteLength(logs, 'utf8') >= threshold;\n 165→  }\n 166→\n 167→  /**\n 168→   * Build log metadata object.\n 169→   * @param {string} logPath - Log file path\n 170→   * @param {number} totalLines - Total lines in file\n 171→   * @param {number} pageStart - Start line of page\n 172→   * @param {number} pageEnd - End line of page\n 173→   * @param {number} requestedLines - Requested lines\n 174→   * @param {number} actualLines - Actual lines returned\n 175→   * @returns {Object} Metadata object\n 176→   */\n 177→  function buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines) {\n 178→    return {\n 179→      logPath,\n 180→      totalLines,\n 181→      pageStart,\n 182→      pageEnd,\n 183→      requestedLines,\n 184→      actualLines\n 185→    };\n 186→  }\n 187→\n 188→  /**\n 189→   * Format logs for Telegram display.\n 190→   * @param {string} logs - Log content\n 191→   * @param {Object} metadata - Log metadata\n 192→   * @returns {string} Formatted message\n 193→   */\n 194→  function formatLogsForTelegram(logs, metadata = {}) {\n 195→    if (!logs || logs.trim() === '') {\n 196→      return '📭 暂无日志内容。';\n 197→    }\n 198→\n 199→    const lines = [];\n 200→\n 201→    // Add header with metadata\n 202→    lines.push('📋 **Pipeline 日志**');\n 203→    if (metadata.totalLines !== undefined) {\n 204→      lines.push(`总计: ${metadata.totalLines} 行`);\n 205→      if (metadata.pageStart && metadata.pageEnd) {\n 206→        lines.push(`显示: 第 ${metadata.pageStart}-${metadata.pageEnd} 行`);\n 207→      }\n 208→    }\n 209→    lines.push('');\n 210→\n 211→    // Add segment numbering if provided\n 212→    if (metadata.totalSegments && metadata.segmentIndex !== undefined) {\n 213→      lines[0] = `📋 **Pipeline 日志** [${metadata.segmentIndex + 1}/${metadata.totalSegments}]`;\n 214→    }\n 215→\n 216→    // Add log content\n 217→    lines.push('```');\n 218→    lines.push(logs);\n 219→    lines.push('```');\n 220→\n 221→    return lines.join('\\n');\n 222→  }\n 223→\n 224→  return {\n 225→    readLogPage,\n 226→    formatLogsForTelegram,\n 227→    extractErrorLines,\n 228→    shouldSendAsFile,\n 229→    buildLogMetadata\n 230→  };\n 231→}\n 232→\n 233→export default createLogPager;\n 234→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde86ad9a0ae1a9c5cf86c76a0ac0","__timestamp":"2026-03-11T20:17:24.410Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
