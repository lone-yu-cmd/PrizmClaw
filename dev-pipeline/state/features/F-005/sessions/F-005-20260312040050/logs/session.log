{"type":"user","uuid":"c912f269-cd45-42ef-a29f-be0ad83f162b","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde872e2d5581435b955f2874b48d","content":[{"type":"text","text":"   1→import fs from 'node:fs';\n   2→import path from 'node:path';\n   3→\n   4→import { createInfraError, INFRA_ERROR_CODES } from './error-codes.js';\n   5→\n   6→function toArgMap(argv = []) {\n   7→  const args = Array.isArray(argv) ? argv : [];\n   8→  const map = new Map();\n   9→\n  10→  for (let i = 0; i < args.length; i += 1) {\n  11→    const token = String(args[i] ?? '');\n  12→    if (!token.startsWith('--')) {\n  13→      continue;\n  14→    }\n  15→\n  16→    const normalized = token.slice(2);\n  17→    if (!normalized) {\n  18→      continue;\n  19→    }\n  20→\n  21→    if (normalized.includes('=')) {\n  22→      const [key, ...rest] = normalized.split('=');\n  23→      map.set(key, rest.join('='));\n  24→      continue;\n  25→    }\n  26→\n  27→    const next = args[i + 1];\n  28→    if (typeof next === 'string' && !next.startsWith('--')) {\n  29→      map.set(normalized, next);\n  30→      i += 1;\n  31→    } else {\n  32→      map.set(normalized, 'true');\n  33→    }\n  34→  }\n  35→\n  36→  return map;\n  37→}\n  38→\n  39→function toAbsolutePath(raw, projectRoot) {\n  40→  const value = String(raw ?? '').trim();\n  41→  if (!value) {\n  42→    return '';\n  43→  }\n  44→\n  45→  if (path.isAbsolute(value)) {\n  46→    return path.normalize(value);\n  47→  }\n  48→\n  49→  return path.resolve(projectRoot, value);\n  50→}\n  51→\n  52→function parseInteger({ raw, field, min, code = INFRA_ERROR_CODES.CONFIG_INVALID, hint }) {\n  53→  const parsed = Number.parseInt(String(raw ?? ''), 10);\n  54→  if (!Number.isInteger(parsed) || parsed < min) {\n  55→    throwInfraError({\n  56→      code,\n  57→      field,\n  58→      message: `${field} must be an integer >= ${min}`,\n  59→      hint\n  60→    });\n  61→  }\n  62→\n  63→  return parsed;\n  64→}\n  65→\n  66→function throwInfraError({ code, field, message, hint, context = undefined }) {\n  67→  const infraError = createInfraError(code, message, {\n  68→    hint,\n  69→    context: {\n  70→      ...(context ?? {}),\n  71→      field\n  72→    }\n  73→  });\n  74→\n  75→  const err = new Error(`${infraError.message} (field: ${field}, hint: ${hint ?? 'n/a'})`);\n  76→  const mutableError = /** @type {any} */ (err);\n  77→  mutableError.code = infraError.code;\n  78→  mutableError.hint = infraError.hint;\n  79→  mutableError.context = infraError.context;\n  80→  mutableError.infraError = infraError;\n  81→  throw mutableError;\n  82→}\n  83→\n  84→function ensureDirectoryExists(dirPath, field) {\n  85→  if (!fs.existsSync(dirPath)) {\n  86→    throwInfraError({\n  87→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n  88→      field,\n  89→      message: `${field} does not exist: ${dirPath}`,\n  90→      hint: 'Ensure project root points to a repository containing dev-pipeline/'\n  91→    });\n  92→  }\n  93→}\n  94→\n  95→export function loadPipelineInfraConfig(input = {}) {\n  96→  const env = input.env ?? process.env;\n  97→  const argv = input.argv ?? [];\n  98→  const cwd = input.cwd ?? process.cwd();\n  99→  const argMap = toArgMap(argv);\n 100→\n 101→  const projectRootRaw = argMap.get('project-root') ?? env.PIPELINE_PROJECT_ROOT ?? cwd;\n 102→  const projectRoot = toAbsolutePath(projectRootRaw, cwd);\n 103→\n 104→  if (!projectRoot) {\n 105→    throwInfraError({\n 106→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 107→      field: 'projectRoot',\n 108→      message: 'projectRoot is required',\n 109→      hint: 'Set --project-root or PIPELINE_PROJECT_ROOT, or provide cwd input'\n 110→    });\n 111→  }\n 112→\n 113→  const pipelineDir = toAbsolutePath(\n 114→    argMap.get('pipeline-dir') ?? env.PIPELINE_DIR ?? path.join(projectRoot, 'dev-pipeline'),\n 115→    projectRoot\n 116→  );\n 117→\n 118→  ensureDirectoryExists(pipelineDir, 'pipelineDir');\n 119→\n 120→  const featureListPath = toAbsolutePath(\n 121→    argMap.get('feature-list') ?? env.FEATURE_LIST_PATH ?? path.join(projectRoot, 'feature-list.json'),\n 122→    projectRoot\n 123→  );\n 124→\n 125→  const bugFixListPath = toAbsolutePath(\n 126→    argMap.get('bug-fix-list') ?? env.BUG_FIX_LIST_PATH ?? path.join(projectRoot, 'bug-fix-list.json'),\n 127→    projectRoot\n 128→  );\n 129→\n 130→  // T-003: plansDir for versioned plan files\n 131→  const plansDir = toAbsolutePath(\n 132→    argMap.get('plans-dir') ?? env.PLANS_DIR ?? path.join(projectRoot, 'plans'),\n 133→    projectRoot\n 134→  );\n 135→\n 136→  const maxRetries = parseInteger({\n 137→    raw: argMap.get('max-retries') ?? env.MAX_RETRIES ?? 3,\n 138→    field: 'MAX_RETRIES',\n 139→    min: 1,\n 140→    hint: 'Set MAX_RETRIES to a positive integer'\n 141→  });\n 142→\n 143→  const sessionTimeoutSec = parseInteger({\n 144→    raw: argMap.get('session-timeout') ?? env.SESSION_TIMEOUT ?? 0,\n 145→    field: 'SESSION_TIMEOUT',\n 146→    min: 0,\n 147→    hint: 'Set SESSION_TIMEOUT to 0 or a positive integer (seconds)'\n 148→  });\n 149→\n 150→  const heartbeatIntervalSec = parseInteger({\n 151→    raw: argMap.get('heartbeat-interval') ?? env.HEARTBEAT_INTERVAL ?? 30,\n 152→    field: 'HEARTBEAT_INTERVAL',\n 153→    min: 1,\n 154→    hint: 'Set HEARTBEAT_INTERVAL to a positive integer (seconds)'\n 155→  });\n 156→\n 157→  const aiCli = String(argMap.get('ai-cli') ?? env.AI_CLI ?? env.CODEBUDDY_CLI ?? 'cbc').trim();\n 158→  if (!aiCli) {\n 159→    throwInfraError({\n 160→      code: INFRA_ERROR_CODES.CONFIG_MISSING,\n 161→      field: 'AI_CLI',\n 162→      message: 'AI_CLI is required',\n 163→      hint: 'Set AI_CLI or CODEBUDDY_CLI to a CLI command name'\n 164→    });\n 165→  }\n 166→\n 167→  const platformRaw = String(\n 168→    argMap.get('platform') ?? env.PRIZMKIT_PLATFORM ?? (aiCli.includes('claude') ? 'claude' : 'codebuddy')\n 169→  ).trim();\n 170→\n 171→  if (platformRaw !== 'codebuddy' && platformRaw !== 'claude') {\n 172→    throwInfraError({\n 173→      code: INFRA_ERROR_CODES.CONFIG_INVALID,\n 174→      field: 'PRIZMKIT_PLATFORM',\n 175→      message: `Unsupported platform: ${platformRaw}`,\n 176→      hint: \"Use 'codebuddy' or 'claude'\"\n 177→    });\n 178→  }\n 179→\n 180→  return Object.freeze({\n 181→    projectRoot,\n 182→    pipelineDir,\n 183→    featureListPath,\n 184→    bugFixListPath,\n 185→    plansDir,\n 186→    stateDir: path.join(pipelineDir, 'state'),\n 187→    bugfixStateDir: path.join(pipelineDir, 'bugfix-state'),\n 188→    maxRetries,\n 189→    sessionTimeoutSec,\n 190→    heartbeatIntervalSec,\n 191→    aiCli,\n 192→    platform: platformRaw\n 193→  });\n 194→}\n 195→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde86ad9a0ae1a9c5cf86c76a0ac0","__timestamp":"2026-03-11T20:12:08.111Z","_requestId":"8c83b89fde8941858aa97e5b6b7114a4"}
{"type":"user","uuid":"b94423d3-245d-4df5-8506-ffda3e88f4c2","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde87302bee18917a83c3c4871d20","content":[{"type":"text","text":"   1→import path from 'node:path';\n   2→\n   3→const SAFE_SEGMENT_PATTERN = /^[A-Za-z0-9._-]+$/;\n   4→\n   5→function assertSafeSegment(value, label) {\n   6→  const normalized = String(value ?? '').trim();\n   7→  if (!normalized || !SAFE_SEGMENT_PATTERN.test(normalized) || normalized.includes('..')) {\n   8→    throw new Error(`Invalid path segment for ${label}: ${value}`);\n   9→  }\n  10→\n  11→  return normalized;\n  12→}\n  13→\n  14→export function computeFeatureSlug(featureId, title) {\n  15→  const normalizedFeatureId = assertSafeSegment(featureId, 'featureId');\n  16→  const numeric = normalizedFeatureId.replace(/^F-/i, '').replace(/^0+/, '').padStart(3, '0');\n  17→\n  18→  const rawTitle = String(title ?? '').toLowerCase();\n  19→  const cleanedTitle = rawTitle\n  20→    .replace(/[^a-z0-9\\s-]/g, '')\n  21→    .trim()\n  22→    .replace(/[\\s]+/g, '-')\n  23→    .replace(/-+/g, '-');\n  24→\n  25→  const safeTitle = cleanedTitle || 'feature';\n  26→  return `${numeric}-${safeTitle}`;\n  27→}\n  28→\n  29→export function resolveFeaturePaths(input) {\n  30→  const projectRoot = path.resolve(String(input?.projectRoot ?? ''));\n  31→  const featureId = assertSafeSegment(input?.featureId, 'featureId');\n  32→  const sessionId = assertSafeSegment(input?.sessionId, 'sessionId');\n  33→  const featureSlug = computeFeatureSlug(featureId, input?.title ?? '');\n  34→\n  35→  const specsDir = path.join(projectRoot, '.prizmkit/specs', featureSlug);\n  36→  const sessionDir = path.join(projectRoot, 'dev-pipeline/state/features', featureId, 'sessions', sessionId);\n  37→\n  38→  return {\n  39→    featureSlug,\n  40→    specsDir,\n  41→    sessionDir,\n  42→    sessionLog: path.join(sessionDir, 'logs/session.log'),\n  43→    sessi