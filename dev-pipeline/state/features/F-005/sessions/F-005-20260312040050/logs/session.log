{"type":"user","uuid":"19ebfe66-a182-4a20-bede-76943482501f","session_id":"5a4189c6-c669-4ea4-8c81-fee95bc26849","message":{"content":[{"type":"tool_result","tool_use_id":"019cde8d352f2503255625e904130876","content":[{"type":"text","text":"   1→import fs from 'node:fs';\n   2→import { EventEmitter } from 'node:events';\n   3→import { createLockManager, getDefaultLockManager } from '../pipeline-infra/lock-manager.js';\n   4→import { createStateManager, getDefaultStateManager } from '../pipeline-infra/state-manager.js';\n   5→import { executePipelineCommand, buildPipelineCommand } from '../pipeline-infra/script-runner.js';\n   6→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   7→import { resolveDaemonLogPaths } from '../pipeline-infra/path-policy.js';\n   8→import { INFRA_ERROR_CODES } from '../pipeline-infra/error-codes.js';\n   9→\n  10→const DEFAULT_LOG_LINES = 100;\n  11→const DEFAULT_STOP_TIMEOUT_MS = 10000;\n  12→\n  13→/**\n  14→ * Build an error result object.\n  15→ * @param {string} errorCode - Error code\n  16→ * @param {string} message - Error message\n  17→ * @param {Object} [options] - Additional options\n  18→ * @param {string} [options.hint] - Hint for resolving the error\n  19→ * @param {Object} [options.context] - Additional context\n  20→ * @returns {Object} Error result\n  21→ */\n  22→function buildError(errorCode, message, options = {}) {\n  23→  return {\n  24→    ok: false,\n  25→    errorCode,\n  26→    message,\n  27→    ...(options.hint ? { hint: options.hint } : {}),\n  28→    ...(options.context ? { context: options.context } : {})\n  29→  };\n  30→}\n  31→\n  32→/**\n  33→ * Build a success result object.\n  34→ * @param {string} message - Success message\n  35→ * @param {Object} [extra] - Additional fields\n  36→ * @returns {Object} Success result\n  37→ */\n  38→function buildResult(message, extra = {}) {\n  39→  return {\n  40→    ok: true,\n  41→    message,\n  42→    ...extra\n  43→  };\n  44→}\n  45→\n  46→/**\n  47→ * Generate a unique run ID.\n  48→ * @returns {string} Run ID\n  49→ */\n  50→function generateRunId() {\n  51→  const now = new Date();\n  52→  const timestamp = now.toISOString().replace(/[-:T]/g, '').slice(0, 15);\n  53→  return `run-${timestamp}`;\n  54→}\n  55→\n  56→/**\n  57→ * Read last N lines from a file.\n  58→ * @param {string} filePath - Path to file\n  59→ * @param {number} lines - Number of lines to read\n  60→ * @returns {string} File content\n  61→ */\n  62→function readLastLines(filePath, lines) {\n  63→  try {\n  64→    const content = fs.readFileSync(filePath, 'utf8');\n  65→    const allLines = content.split('\\n');\n  66→    const selectedLines = allLines.slice(-lines);\n  67→    return selectedLines.join('\\n');\n  68→  } catch {\n  69→    return '';\n  70→  }\n  71→}\n  72→\n  73→/**\n  74→ * Create a pipeline controller instance.\n  75→ * @param {Object} options - Options\n  76→ * @param {Object} [options.lockManager] - Lock manager instance\n  77→ * @param {Object} [options.stateManager] - State manager instance\n  78→ * @param {Function} [options.scriptRunner] - Script runner function\n  79→ * @param {Object} [options.config] - Pipeline config\n  80→ * @returns {Object} Pipeline controller interface\n  81→ */\n  82→export function createPipelineController(options = {}) {\n  83→  const lockManager = options.lockManager || getDefaultLockManager();\n  84→  const stateManager = options.stateManager || getDefaultStateManager();\n  85→  const scriptRunner = options.scriptRunner || executePipelineCommand;\n  86→  const config = options.config || loadPipelineInfraConfig();\n  87→\n  88→  // F-005: Lifecycle event emitter for heartbeat and notifications\n  89→  const eventEmitter = new EventEmitter();\n  90→\n  91→  /**\n  92→   * Internal: Acquire lock and return result.\n  93→   * @param {string} type - Pipeline type\n  94→   * @returns {Promise<Object|null>} Lock result or null on success\n  95→   */\n  96→  async function _acquireLock(type) {\n  97→    const lockResult = await lockManager.acquireLock(type);\n  98→    if (!lockResult.ok) {\n  99→      return buildError(\n 100→        INFRA_ERROR_CODES.LOCK_ACQUISITION_FAILED,\n 101→        `Pipeline ${type} is already running`,\n 102→        {\n 103→          hint: 'Stop the current pipeline first or use forceUnlock',\n 104→          context: { currentHolder: lockResult.currentHolder }\n 105→        }\n 106→      );\n 107→    }\n 108→    return null;\n 109→  }\n 110→\n 111→  /**\n 112→   * Internal: Release lock.\n 113→   * @param {string} type - Pipeline type\n 114→   */\n 115→  async function _releaseLock(type) {\n 116→    await lockManager.releaseLock(type);\n 117→  }\n 118→\n 119→  return {\n 120→    // Internal methods (exposed for testing)\n 121→    _acquireLock,\n 122→    _releaseLock,\n 123→\n 124→    /**\n 125→     * Start a pipeline.\n 126→     * @param {Object} params - Parameters\n 127→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 128→     * @param {string} [params.targetId] - Optional target ID to start with\n 129→     * @param {string} [params.listPath] - Optional list path\n 130→     * @param {boolean} [params.daemon=true] - Run in daemon mode\n 131→     * @param {Object} [params.envOverrides] - Environment overrides\n 132→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 133→     * @returns {Promise<Object>} Start result\n 134→     */\n 135→    async startPipeline(params) {\n 136→      const { type = 'feature', targetId, listPath, daemon = true, envOverrides, timeoutMs } = params;\n 137→\n 138→      // Acquire lock\n 139→      const lockError = await _acquireLock(type);\n 140→      if (lockError) {\n 141→        return lockError;\n 142→      }\n 143→\n 144→      // Build and execute command\n 145→      const runId = generateRunId();\n 146→\n 147→      try {\n 148→        const result = await scriptRunner({\n 149→          pipelineType: type,\n 150→          action: 'run',\n 151→          targetId,\n 152→          listPath,\n 153→          envOverrides,\n 154→          timeoutMs\n 155→        });\n 156→\n 157→        if (!result.ok) {\n 158→          // Release lock on failure\n 159→          await _releaseLock(type);\n 160→          return buildError(\n 161→            result.errorCode || INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 162→            result.stderr || 'Failed to start pipeline',\n 163→            { context: { exitCode: result.exitCode } }\n 164→          );\n 165→        }\n 166→\n 167→        return buildResult(`Pipeline ${type} started successfully`, {\n 168→          runId,\n 169→          pid: daemon ? process.pid : undefined,\n 170→          stdout: result.stdout\n 171→        });\n 172→      } catch (error) {\n 173→        await _releaseLock(type);\n 174→        return buildError(\n 175→          INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 176→          error.message,\n 177→          { hint: 'Check pipeline scripts and configuration' }\n 178→        );\n 179→      }\n 180→    },\n 181→\n 182→    /**\n 183→     * Stop a pipeline.\n 184→     * @param {Object} params - Parameters\n 185→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 186→     * @param {number} [params.timeoutMs=10000] - Timeout in milliseconds\n 187→     * @returns {Promise<Object>} Stop result\n 188→     */\n 189→    async stopPipeline(params) {\n 190→      const { type = 'feature', timeoutMs = DEFAULT_STOP_TIMEOUT_MS } = params;\n 191→\n 192→      // Check if daemon is running\n 193→      const isRunning = await stateManager.isDaemonRunning(type);\n 194→      const previousPid = await stateManager.getDaemonPid(type);\n 195→\n 196→      if (!isRunning) {\n 197→        // Already stopped\n 198→        return buildResult(`Pipeline ${type} is not running`, {\n 199→          errorCode: INFRA_ERROR_CODES.ALREADY_STOPPED,\n 200→          previousPid\n 201→        });\n 202→      }\n 203→\n 204→      try {\n 205→        // Execute stop command\n 206→        const result = await scriptRunner({\n 207→          pipelineType: type,\n 208→          action: 'stop',\n 209→          timeoutMs\n 210→        });\n 211→\n 212→        // Release lock\n 213→        await _releaseLock(type);\n 214→\n 215→        if (!result.ok) {\n 216→          return buildError(\n 217→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 218→            result.stderr || 'Failed to stop pipeline',\n 219→            { context: { previousPid } }\n 220→          );\n 221→        }\n 222→\n 223→        return buildResult(`Pipeline ${type} stopped successfully`, {\n 224→          previousPid\n 225→        });\n 226→      } catch (error) {\n 227→        // Still release lock on error\n 228→        await _releaseLock(type);\n 229→        return buildError(\n 230→          INFRA_ERROR_CODES.EXEC_FAILED,\n 231→          error.message,\n 232→          { context: { previousPid } }\n 233→        );\n 234→      }\n 235→    },\n 236→\n 237→    /**\n 238→     * Retry a target.\n 239→     * @param {Object} params - Parameters\n 240→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 241→     * @param {string} params.targetId - Target ID to retry\n 242→     * @param {string} [params.listPath] - Optional list path\n 243→     * @param {boolean} [params.daemon=false] - Run in daemon mode\n 244→     * @param {Object} [params.envOverrides] - Environment overrides\n 245→     * @returns {Promise<Object>} Retry result\n 246→     */\n 247→    async retryTarget(params) {\n 248→      const { type = 'feature', targetId, listPath, daemon = false, envOverrides } = params;\n 249→\n 250→      // Validate targetId\n 251→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 252→        return buildError(\n 253→          INFRA_ERROR_CODES.INVALID_TARGET,\n 254→          'targetId is required for retry',\n 255→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 256→        );\n 257→      }\n 258→\n 259→      // For daemon mode, acquire lock\n 260→      if (daemon) {\n 261→        const lockError = await _acquireLock(type);\n 262→        if (lockError) {\n 263→          return lockError;\n 264→        }\n 265→      }\n 266→\n 267→      try {\n 268→        const result = await scriptRunner({\n 269→          pipelineType: type,\n 270→          action: 'retry',\n 271→          targetId: targetId.trim(),\n 272→          listPath,\n 273→          envOverrides\n 274→        });\n 275→\n 276→        if (daemon) {\n 277→          await _releaseLock(type);\n 278→        }\n 279→\n 280→        if (!result.ok) {\n 281→          return buildError(\n 282→            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 283→            result.stderr || `Failed to retry target ${targetId}`,\n 284→            { context: { targetId } }\n 285→          );\n 286→        }\n 287→\n 288→        return buildResult(`Target ${targetId} retry completed`, {\n 289→          targetId,\n 290→          stdout: result.stdout\n 291→        });\n 292→      } catch (error) {\n 293→        if (daemon) {\n 294→          await _releaseLock(type);\n 295→        }\n 296→        return buildError(\n 297→          INFRA_ERROR_CODES.EXEC_FAILED,\n 298→          error.message,\n 299→          { context: { targetId } }\n 300→        );\n 301→      }\n 302→    },\n 303→\n 304→    /**\n 305→     * Run a single target without affecting pipeline state.\n 306→     * @param {Object} params - Parameters\n 307→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 308→     * @param {string} params.targetId - Target ID to run\n 309→     * @param {string} [params.listPath] - Optional list path\n 310→     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 311→     * @param {Object} [params.envOverrides] - Environment overrides\n 312→     * @returns {Promise<Object>} Run result\n 313→     */\n 314→    async runSingle(params) {\n 315→      const { type = 'feature', targetId, listPath, timeoutMs, envOverrides } = params;\n 316→\n 317→      // Validate targetId\n 318→      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 319→        return buildError(\n 320→          INFRA_ERROR_CODES.INVALID_TARGET,\n 321→          'targetId is required for runSingle',\n 322→          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 323→        );\n 324→      }\n 325→\n 326→      // Note: runSingle does NOT acquire lock (independent execution per D5)\n 327→\n 328→      try {\n 329→        const result = await scriptRunner({\n 330→          pipelineType: type,\n 331→          action: 'run',\n 332→          targetId: targetId.trim(),\n 333→          listPath,\n 334→          timeoutMs,\n 335→          envOverrides\n 336→        });\n 337→\n 338→        return {\n 339→          ok: result.ok,\n 340→          targetId,\n 341→          message: result.ok\n 342→            ? `Target ${targetId} completed successfully`\n 343→            : `Target ${targetId} failed`,\n 344→          stdout: result.stdout,\n 345→          stderr: result.stderr,\n 346→          exitCode: result.exitCode,\n 347→          errorCode: result.errorCode\n 348→        };\n 349→      } catch (error) {\n 350→        return buildError(\n 351→          INFRA_ERROR_CODES.EXEC_FAILED,\n 352→          error.message,\n 353→          { context: { targetId } }\n 354→        );\n 355→      }\n 356→    },\n 357→\n 358→    /**\n 359→     * Get pipeline status.\n 360→     * @param {Object} params - Parameters\n 361→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 362→     * @returns {Promise<Object>} Status result\n 363→     */\n 364→    async getStatus(params) {\n 365→      const { type = 'feature' } = params;\n 366→\n 367→      const isRunning = await stateManager.isDaemonRunning(type);\n 368→      const pid = await stateManager.getDaemonPid(type);\n 369→      const pipelineState = await stateManager.readPipelineState(type);\n 370→      const currentSession = await stateManager.readCurrentSession(type);\n 371→      const lastResult = await stateManager.getLastResult(type);\n 372→      const lockInfo = await lockManager.getLockInfo(type);\n 373→\n 374→      const result = {\n 375→        ok: true,\n 376→        isRunning,\n 377→        pid: isRunning ? pid : undefined,\n 378→        message: isRunning\n 379→          ? `Pipeline ${type} is running`\n 380→          : `Pipeline ${type} is not running`\n 381→      };\n 382→\n 383→      // Add current feature info if running\n 384→      if (isRunning && currentSession) {\n 385→        result.currentFeature = currentSession.feature_id;\n 386→        result.startedAt = currentSession.started_at;\n 387→      }\n 388→\n 389→      // Add last result if not running\n 390→      if (!isRunning && lastResult) {\n 391→        result.lastResult = lastResult;\n 392→      }\n 393→\n 394→      // Add lock info\n 395→      if (lockInfo) {\n 396→        result.lockInfo = lockInfo;\n 397→      }\n 398→\n 399→      return result;\n 400→    },\n 401→\n 402→    /**\n 403→     * Get pipeline logs.\n 404→     * @param {Object} params - Parameters\n 405→     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 406→     * @param {number} [params.lines=100] - Number of lines to read\n 407→     * @returns {Promise<Object>} Logs result\n 408→     */\n 409→    async getLogs(params) {\n 410→      const { type = 'feature', lines = DEFAULT_LOG_LINES } = params;\n 411→\n 412→      const logPaths = resolveDaemonLogPaths(config.projectRoot);\n 413→      const logPath = type === 'feature'\n 414→        ? logPaths.featureDaemonLog\n 415→        : logPaths.bugfixDaemonLog;\n 416→\n 417→      const logs = readLastLines(logPath, lines);\n 418→\n 419→      return buildResult(`Retrieved ${lines} lines from ${type} log`, {\n 420→        logs,\n 421→        logPath,\n 422→        lines\n 423→      });\n 424→    },\n 425→\n 426→    /**\n 427→     * Force 