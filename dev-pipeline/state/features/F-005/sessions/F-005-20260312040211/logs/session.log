{"type":"assistant","uuid":"20260312041300fcef4ab502474700","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"id":"20260312041300fcef4ab502474700","content":[{"type":"tool_use","id":"019cde8808be61f56d7d0f0a9c577035","name":"Write","input":{"content":"/**\n * F-005: Pipeline Status Aggregation and Log Streaming Integration Tests\n *\n * Tests for US-1 through US-6 user stories.\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nimport { createStatusAggregator } from '../../src/services/status-aggregator.js';\nimport { createLogPager } from '../../src/services/log-pager.js';\nimport { createTelegramPusher } from '../../src/services/telegram-pusher.js';\n\n/**\n * Helper to create temp directory for test state\n */\nfunction createTempStateDir() {\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f005-integration-test-'));\n  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  fs.mkdirSync(stateDir, { recursive: true });\n  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  return {\n    tempDir,\n    stateDir,\n    bugfixStateDir,\n    cleanup: () => {\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    }\n  };\n}\n\n/**\n * Helper to create a mock config\n */\nfunction createMockConfig(stateDir, bugfixStateDir) {\n  const projectRoot = path.dirname(path.dirname(stateDir));\n  return {\n    projectRoot,\n    stateDir,\n    bugfixStateDir\n  };\n}\n\n/**\n * Helper to create a mock bot\n */\nfunction createMockBot() {\n  const sentMessages = [];\n  const sentFiles = [];\n\n  return {\n    telegram: {\n      sendMessage: async (chatId, text, options = {}) => {\n        sentMessages.push({ chatId, text, options });\n        return { message_id: Date.now() };\n      },\n      sendDocument: async (chatId, document, options = {}) => {\n        sentFiles.push({ chatId, document, options });\n        return { message_id: Date.now() };\n      }\n    },\n    _sentMessages: sentMessages,\n    _sentFiles: sentFiles\n  };\n}\n\n// ============================================================\n// US-1: Aggregated Status Query Integration Tests (T-104)\n// ============================================================\n\ntest('US-1: Full status flow - running pipeline', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    // Write running state\n    fs.writeFileSync(\n      path.join(stateDir, '.pipeline-meta.json'),\n      JSON.stringify({\n        pid: process.pid,\n        started_at: new Date(Date.now() - 3600000).toISOString(),\n        feature_list: '/path/to/feature-list.json'\n      })\n    );\n\n    fs.writeFileSync(\n      path.join(stateDir, 'pipeline.json'),\n      JSON.stringify({\n        run_id: 'run-test',\n        status: 'running',\n        total_features: 10,\n        completed_features: 4,\n        failed_features: 1\n      })\n    );\n\n    fs.writeFileSync(\n      path.join(stateDir, 'current-session.json'),\n      JSON.stringify({\n        feature_id: 'F-005',\n        started_at: new Date().toISOString()\n      })\n    );\n\n    const aggregator = createStatusAggregator({ config });\n    const status = await aggregator.aggregateStatus('feature');\n    const formatted = aggregator.formatStatusForTelegram(status);\n\n    assert.equal(status.stage, 'running');\n    assert.ok(status.current);\n    assert.equal(status.current.featureId, 'F-005');\n    assert.ok(formatted.includes('F-005'));\n    assert.ok(formatted.includes('running') || formatted.includes('运行中'));\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-1: Full status flow - idle pipeline with last result', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    // Write last result only\n    fs.writeFileSync(\n      path.join(stateDir, '.last-result.json'),\n      JSON.stringify({\n        runId: 'run-previous',\n        completedAt: new Date().toISOString(),\n        status: 'success',\n        featuresTotal: 5,\n        featuresCompleted: 5,\n        duration: 1800\n      })\n    );\n\n    const aggregator = createStatusAggregator({ config });\n    const status = await aggregator.aggregateStatus('feature');\n    const formatted = aggregator.formatStatusForTelegram(status);\n\n    assert.equal(status.stage, 'idle');\n    assert.ok(status.lastResult);\n    assert.equal(status.lastResult.status, 'success');\n    assert.ok(formatted.includes('success') || formatted.includes('成功'));\n  } finally {\n    cleanup();\n  }\n});\n\n// ============================================================\n// US-2: Paginated Logs Query Integration Tests (T-115)\n// ============================================================\n\ntest('US-2: Log pagination with offset and lines', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    // Write log file with many lines\n    const lines = [];\n    for (let i = 1; i <= 200; i++) {\n      lines.push(`[${new Date().toISOString()}] [INFO] Log line ${i}`);\n    }\n    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), lines.join('\\n'));\n\n    const pager = createLogPager({ config });\n\n    // First page\n    const page1 = await pager.readLogPage('feature', { lines: 50, offset: 0 });\n    assert.equal(page1.ok, true);\n\n    // Second page\n    const page2 = await pager.readLogPage('feature', { lines: 50, offset: 50 });\n    assert.equal(page2.ok, true);\n\n    // Metadata should show different pages\n    assert.notEqual(page1.metadata.pageStart, page2.metadata.pageStart);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-2: Missing log file returns friendly message', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n    const pager = createLogPager({ config });\n\n    const result = await pager.readLogPage('feature', { lines: 50 });\n\n    assert.equal(result.ok, true);\n    assert.ok(result.message || result.logs === '');\n  } finally {\n    cleanup();\n  }\n});\n\n// ============================================================\n// US-3: Message Length Compliance Integration Tests (T-124)\n// ============================================================\n\ntest('US-3: Message chunking for long logs', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n    const bot = createMockBot();\n    const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n\n    // Create long message\n    const longText = 'x'.repeat(10000);\n    await pusher.sendMessageChunked(123456, longText);\n\n    // Should have split into multiple messages\n    assert.ok(bot._sentMessages.length >= 2);\n\n    // Check segment numbering\n    const hasSegmentNumber = bot._sentMessages.some(m =>\n      m.text.includes('[1/') || m.text.includes('[2/')\n    );\n    assert.ok(hasSegmentNumber);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-3: File option for large logs', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    // Write large log file\n    const largeContent = 'x'.repeat(10000);\n    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), largeContent);\n\n    const pager = createLogPager({ config });\n    const result = await pager.readLogPage('feature', { lines: 500 });\n\n    assert.ok(pager.shouldSendAsFile(result.logs));\n  } finally {\n    cleanup();\n  }\n});\n\n// ============================================================\n// US-4: Heartbeat Progress Push Integration Tests (T-135)\n// ============================================================\n\ntest('US-4: Heartbeat pushes status updates', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    // Write running state\n    fs.writeFileSync(\n      path.join(stateDir, '.pipeline-meta.json'),\n      JSON.stringify({\n        pid: process.pid,\n        started_at: new Date().toISOString()\n      })\n    );\n\n    const bot = createMockBot();\n    const pusher = createTelegramPusher({\n      bot,\n      targetChatId: 123456,\n      heartbeatInterval: 50\n    });\n\n    const aggregator = createStatusAggregator({ config });\n    pusher.startHeartbeat('feature', aggregator);\n\n    // Wait for heartbeat\n    await new Promise(resolve => setTimeout(resolve, 150));\n\n    pusher.stopHeartbeat('feature');\n\n    // Should have sent at least one heartbeat\n    assert.ok(bot._sentMessages.length >= 1);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-4: Heartbeat respects throttle interval', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    const bot = createMockBot();\n    const pusher = createTelegramPusher({\n      bot,\n      targetChatId: 123456,\n      heartbeatInterval: 200,\n      throttleInterval: 100\n    });\n\n    const aggregator = createStatusAggregator({ config });\n    pusher.startHeartbeat('feature', aggregator);\n\n    await new Promise(resolve => setTimeout(resolve, 500));\n\n    pusher.stopHeartbeat('feature');\n\n    // Should have limited messages due to throttle\n    assert.ok(bot._sentMessages.length < 10);\n  } finally {\n    cleanup();\n  }\n});\n\n// ============================================================\n// US-5: Error Summary Push Integration Tests (T-144)\n// ============================================================\n\ntest('US-5: Error summary includes execution time', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n    const bot = createMockBot();\n    const pusher = createTelegramPusher({ bot, targetChatId: 123456 });\n\n    await pusher.pushErrorSummary('feature', 'F-005', {\n      type: 'execution_error',\n      message: 'Script failed',\n      duration: 120,\n      logLines: ['Error line 1', 'Error line 2']\n    });\n\n    assert.equal(bot._sentMessages.length, 1);\n\n    const text = bot._sentMessages[0].text;\n    assert.ok(text.includes('F-005'));\n    assert.ok(text.includes('120') || text.includes('2分') || text.includes('执行时间'));\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-5: Silent mode filters expected errors', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n    const bot = createMockBot();\n    const pusher = createTelegramPusher({\n      bot,\n      targetChatId: 123456,\n      heartbeatConfig: { silentMode: true }\n    });\n\n    // Expected error should be filtered\n    const result = await pusher.pushErrorSummary('feature', 'F-005', {\n      type: 'expected_error',\n      message: 'Expected failure',\n      isExpected: true\n    });\n\n    assert.ok(result.skipped || bot._sentMessages.length === 0);\n  } finally {\n    cleanup();\n  }\n});\n\n// ============================================================\n// US-6: Diagnostic Error Messages Integration Tests (T-155)\n// ============================================================\n\ntest('US-6: Diagnostic for missing state files', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n    const aggregator = createStatusAggregator({ config });\n\n    const status = await aggregator.aggregateStatus('feature');\n\n    assert.equal(status.stage, 'idle');\n    assert.ok(status.diagnostic);\n    assert.ok(status.diagnostic.includes('初始化') || status.diagnostic.includes('启动'));\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-6: Diagnostic for corrupted JSON', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n\n    // Write corrupted JSON\n    fs.writeFileSync(\n      path.join(stateDir, '.pipeline-meta.json'),\n      'not valid json {{{'\n    );\n\n    const aggregator = createStatusAggregator({ config });\n    const status = await aggregator.aggregateStatus('feature');\n\n    // Should still return valid status, not throw\n    assert.ok(status);\n    assert.ok(status.diagnostic || status.stage === 'idle');\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-6: Diagnostic for missing log file', async () => {\n  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  try {\n    const config = createMockConfig(stateDir, bugfixStateDir);\n    const pager = createLogPager({ config });\n\n    const result = await pager.readLogPage('feature', { lines: 50 });\n\n    assert.equal(result.ok, true);\n    assert.ok(result.message || result.logs === '');\n    assert.ok(result.metadata.logPath);\n  } finally {\n    cleanup();\n  }\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f005-status-and-logs.integration.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_8d8fb4ee010f4820805a4013","__timestamp":"2026-03-11T20:13:48.826Z","_requestId":"2a50dd3