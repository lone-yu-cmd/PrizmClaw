{"type":"assistant","uuid":"202603120422279db1a8481fca4902","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"id":"202603120422279db1a8481fca4902","content":[{"type":"tool_use","id":"019cde90b0e2db93f8283bd8a104ce40","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/status.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.257Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
{"type":"assistant","uuid":"202603120422279db1a8481fca4902","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"id":"202603120422279db1a8481fca4902","content":[{"type":"tool_use","id":"019cde90b27c51a8835aabaaa8a6ed72","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/logs.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":27158,"output_tokens":186,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.257Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
{"type":"user","uuid":"b7ce7c7f-7385-43d1-91b7-8f39583c24fa","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90ac9730a9f4e2023ef146322b","content":[{"type":"text","text":"   1→/**\n   2→ * Status Aggregator Service\n   3→ *\n   4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-1: Aggregated Status Query\n   5→ *\n   6→ * Aggregates multiple state sources to generate structured status reports.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D1: Independent service, not extending pipeline-controller (single responsibility)\n  10→ * - D5: Real-time error extraction from logs, no additional storage\n  11→ */\n  12→\n  13→import fs from 'node:fs';\n  14→import path from 'node:path';\n  15→\n  16→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  17→import { getStatePaths } from '../pipeline-infra/path-policy.js';\n  18→import { getDefaultStateManager } from '../pipeline-infra/state-manager.js';\n  19→\n  20→/**\n  21→ * Check if a process is alive.\n  22→ * @param {number} pid - Process ID to check\n  23→ * @returns {boolean} True if process is alive\n  24→ */\n  25→function isProcessAlive(pid) {\n  26→  try {\n  27→    process.kill(pid, 0);\n  28→    return true;\n  29→  } catch (error) {\n  30→    return error.code !== 'ESRCH';\n  31→  }\n  32→}\n  33→\n  34→/**\n  35→ * Safely read and parse a JSON file with error handling.\n  36→ * @param {string} filePath - File path\n  37→ * @returns {Object | null} Parsed JSON or null if file doesn't exist or is corrupted\n  38→ */\n  39→function readJsonFileSafe(filePath) {\n  40→  try {\n  41→    const content = fs.readFileSync(filePath, 'utf8');\n  42→    return JSON.parse(content);\n  43→  } catch {\n  44→    return null;\n  45→  }\n  46→}\n  47→\n  48→/**\n  49→ * Create a status aggregator instance.\n  50→ * @param {Object} options - Options\n  51→ * @param {Object} [options.stateManager] - State manager instance\n  52→ * @param {Object} [options.pipelineController] - Pipeline controller instance\n  53→ * @param {Object} [options.config] - Pipeline config\n  54→ * @returns {Object} Status aggregator interface\n  55→ */\n  56→export function createStatusAggregator(options = {}) {\n  57→  const config = options.config || loadPipelineInfraConfig();\n  58→  const stateManager = options.stateManager || getDefaultStateManager();\n  59→\n  60→  /**\n  61→   * Read daemon meta for a pipeline type.\n  62→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  63→   * @returns {Promise<Object | null>} Daemon meta or null\n  64→   */\n  65→  async function _readDaemonMeta(type) {\n  66→    const paths = getStatePaths(config.projectRoot, type);\n  67→    return readJsonFileSafe(paths.daemonMetaFile);\n  68→  }\n  69→\n  70→  /**\n  71→   * Read pipeline state for a pipeline type.\n  72→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  73→   * @returns {Promise<Object | null>} Pipeline state or null\n  74→   */\n  75→  async function _readPipelineState(type) {\n  76→    const paths = getStatePaths(config.projectRoot, type);\n  77→    return readJsonFileSafe(paths.pipelineStateFile);\n  78→  }\n  79→\n  80→  /**\n  81→   * Read current session for a pipeline type.\n  82→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  83→   * @returns {Promise<Object | null>} Current session or null\n  84→   */\n  85→  async function _readCurrentSession(type) {\n  86→    const paths = getStatePaths(config.projectRoot, type);\n  87→    return readJsonFileSafe(paths.currentSessionFile);\n  88→  }\n  89→\n  90→  /**\n  91→   * Read last result for a pipeline type.\n  92→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  93→   * @returns {Promise<Object | null>} Last result or null\n  94→   */\n  95→  async function _readLastResult(type) {\n  96→    const paths = getStatePaths(config.projectRoot, type);\n  97→    return readJsonFileSafe(paths.lastResultFile);\n  98→  }\n  99→\n 100→  /**\n 101→   * Determine pipeline stage based on state and daemon meta.\n 102→   * @param {Object | null} pipelineState - Pipeline state\n 103→   * @param {Object | null} daemonMeta - Daemon meta\n 104→   * @returns {Promise<'running' | 'paused' | 'completed' | 'failed' | 'idle'>}\n 105→   */\n 106→  async function determinePipelineStage(pipelineState, daemonMeta) {\n 107→    // Check if daemon is alive\n 108→    if (daemonMeta && daemonMeta.pid && isProcessAlive(daemonMeta.pid)) {\n 109→      return 'running';\n 110→    }\n 111→\n 112→    // Check pipeline state for paused/completed/failed\n 113→    if (pipelineState) {\n 114→      if (pipelineState.status === 'paused') {\n 115→        return 'paused';\n 116→      }\n 117→      if (pipelineState.status === 'completed') {\n 118→        return 'completed';\n 119→      }\n 120→      if (pipelineState.status === 'failed') {\n 121→        return 'failed';\n 122→      }\n 123→    }\n 124→\n 125→    return 'idle';\n 126→  }\n 127→\n 128→  /**\n 129→   * Calculate progress from pipeline state.\n 130→   * @param {Object | null} state - Pipeline state\n 131→   * @returns {Object} Progress object\n 132→   */\n 133→  function calculateProgress(state) {\n 134→    if (!state) {\n 135→      return {\n 136→        total: 0,\n 137→        completed: 0,\n 138→        failed: 0,\n 139→        inProgress: 0,\n 140→        successRate: 0\n 141→      };\n 142→    }\n 143→\n 144→    const total = state.total_features || 0;\n 145→    const completed = state.completed_features || 0;\n 146→    const failed = state.failed_features || 0;\n 147→    const inProgress = state.in_progress_features || 0;\n 148→\n 149→    // Calculate success rate (completed / total attempts, excluding in-progress)\n 150→    const attempts = completed + failed;\n 151→    const successRate = attempts > 0 ? Math.round((completed / attempts) * 100) : 0;\n 152→\n 153→    return {\n 154→      total,\n 155→      completed,\n 156→      failed,\n 157→      inProgress,\n 158→      successRate\n 159→    };\n 160→  }\n 161→\n 162→  /**\n 163→   * Get error summary from last result.\n 164→   * @param {Object | null} lastResult - Last result\n 165→   * @returns {Array} Array of error objects\n 166→   */\n 167→  function getErrorSummary(lastResult) {\n 168→    if (!lastResult || lastResult.status === 'success') {\n 169→      return [];\n 170→    }\n 171→\n 172→    // Extract errors from last result if available\n 173→    if (lastResult.errors && Array.isArray(lastResult.errors)) {\n 174→      return lastResult.errors.map(err => ({\n 175→        featureId: err.featureId || 'unknown',\n 176→        errorType: err.errorType || 'unknown',\n 177→        message: err.message || 'No message'\n 178→      }));\n 179→    }\n 180→\n 181→    return [];\n 182→  }\n 183→\n 184→  /**\n 185→   * Aggregate status from all state sources.\n 186→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 187→   * @returns {Promise<Object>} Aggregated status\n 188→   */\n 189→  async function aggregateStatus(type) {\n 190→    const timestamp = new Date().toISOString();\n 191→\n 192→    // Read all state sources\n 193→    const daemonMeta = await _readDaemonMeta(type);\n 194→    const pipelineState = await _readPipelineState(type);\n 195→    const currentSession = await _readCurrentSession(type);\n 196→    const lastResult = await _readLastResult(type);\n 197→\n 198→    // Determine stage\n 199→    const stage = await determinePipelineStage(pipelineState, daemonMeta);\n 200→\n 201→    // Build status object\n 202→    const status = {\n 203→      stage,\n 204→      type,\n 205→      timestamp,\n 206→      progress: calculateProgress(pipelineState)\n 207→    };\n 208→\n 209→    // Add current execution info if running\n 210→    if (stage === 'running' && currentSession) {\n 211→      const startedAt = new Date(currentSession.started_at);\n 212→      status.current = {\n 213→        featureId: currentSession.feature_id,\n 214→        startedAt: currentSession.started_at,\n 215→        duration: Math.floor((Date.now() - startedAt.getTime()) / 1000)\n 216→      };\n 217→    }\n 218→\n 219→    // Add daemon info if running\n 220→    if (stage === 'running' && daemonMeta) {\n 221→      const daemonStartedAt = new Date(daemonMeta.started_at);\n 222→      status.daemon = {\n 223→        pid: daemonMeta.pid,\n 224→        startedAt: daemonMeta.started_at,\n 225→        uptime: Math.floor((Date.now() - daemonStartedAt.getTime()) / 1000)\n 226→      };\n 227→    }\n 228→\n 229→    // Add last result if not running\n 230→    if (stage === 'idle' && lastResult) {\n 231→      status.lastResult = {\n 232→        runId: lastResult.runId,\n 233→        completedAt: lastResult.completedAt,\n 234→        status: lastResult.status,\n 235→        summary: lastResult.message || `Completed ${lastResult.featuresCompleted}/${lastResult.featuresTotal}`\n 236→      };\n 237→    }\n 238→\n 239→    // Add errors if failed\n 240→    if (stage === 'failed' || (lastResult && lastResult.status === 'failed')) {\n 241→      status.errors = getErrorSummary(lastResult);\n 242→    }\n 243→\n 244→    return status;\n 245→  }\n 246→\n 247→  /**\n 248→   * Format status for Telegram display.\n 249→   * @param {Object} status - Aggregated status\n 250→   * @returns {string} Formatted message\n 251→   */\n 252→  function formatStatusForTelegram(status) {\n 253→    const lines = [];\n 254→    const stageEmojis = {\n 255→      running: '🔄',\n 256→      paused: '⏸️',\n 257→      completed: '✅',\n 258→      failed: '❌',\n 259→      idle: '💤'\n 260→    };\n 261→\n 262→    const emoji = stageEmojis[status.stage] || '📦';\n 263→    const stageText = {\n 264→      running: '运行中',\n 265→      paused: '已暂停',\n 266→      completed: '已完成',\n 267→      failed: '失败',\n 268→      idle: '空闲'\n 269→    };\n 270→\n 271→    lines.push(`${emoji} **Pipeline 状态** (${status.type})`);\n 272→    lines.push(`阶段: ${stageText[status.stage] || status.stage}`);\n 273→    lines.push('');\n 274→\n 275→    // Progress info\n 276→    const p = status.progress;\n 277→    if (p.total > 0) {\n 278→      lines.push(`📊 进度: ${p.completed}/${p.total} (${p.successRate}% 成功率)`);\n 279→      if (p.failed > 0) {\n 280→        lines.push(`   ❌ 失败: ${p.failed}`);\n 281→      }\n 282→      if (p.inProgress > 0) {\n 283→        lines.push(`   🔄 进行中: ${p.inProgress}`);\n 284→      }\n 285→    }\n 286→\n 287→    // Current execution\n 288→    if (status.current) {\n 289→      lines.push('');\n 290→      lines.push(`🎯 当前目标: ${status.current.featureId}`);\n 291→      lines.push(`   开始时间: ${status.current.startedAt}`);\n 292→      lines.push(`   执行时长: ${formatDuration(status.current.duration)}`);\n 293→    }\n 294→\n 295→    // Daemon info\n 296→    if (status.daemon) {\n 297→      lines.push('');\n 298→      lines.push(`🤖 Daemon PID: ${status.daemon.pid}`);\n 299→      lines.push(`   运行时长: ${formatDuration(status.daemon.uptime)}`);\n 300→    }\n 301→\n 302→    // Last result\n 303→    if (status.lastResult && status.stage === 'idle') {\n 304→      lines.push('');\n 305→      lines.push(`📋 最后运行: ${status.lastResult.runId}`);\n 306→      lines.push(`   状态: ${status.lastResult.status}`);\n 307→      lines.push(`   完成时间: ${status.lastResult.completedAt}`);\n 308→    }\n 309→\n 310→    // Errors\n 311→    if (status.errors && status.errors.length > 0) {\n 312→      lines.push('');\n 313→      lines.push(`⚠️ 错误摘要:`);\n 314→      for (const err of status.errors.slice(0, 3)) {\n 315→        lines.push(`   • ${err.featureId}: ${err.message}`);\n 316→      }\n 317→    }\n 318→\n 319→    return lines.join('\\n');\n 320→  }\n 321→\n 322→  /**\n 323→   * Format duration in human-readable form.\n 324→   * @param {number} seconds - Duration in seconds\n 325→   * @returns {string} Formatted duration\n 326→   */\n 327→  function formatDuration(seconds) {\n 328→    if (seconds < 60) {\n 329→      return `${seconds}s`;\n 330→    }\n 331→    const minutes = Math.floor(seconds / 60);\n 332→    const secs = seconds % 60;\n 333→    if (minutes < 60) {\n 334→      return secs > 0 ? `${minutes}m ${secs}s` : `${minutes}m`;\n 335→    }\n 336→    const hours = Math.floor(minutes / 60);\n 337→    const mins = minutes % 60;\n 338→    return mins > 0 ? `${hours}h ${mins}m` : `${hours}h`;\n 339→  }\n 340→\n 341→  return {\n 342→    aggregateStatus,\n 343→    formatStatusForTelegram,\n 344→    calculateProgress,\n 345→    getErrorSummary,\n 346→    determinePipelineStage,\n 347→    _readDaemonMeta\n 348→  };\n 349→}\n 350→\n 351→export default createStatusAggregator;\n 352→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.258Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
{"type":"user","uuid":"2015f03a-a82f-41b3-bb08-e3a06ce88312","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90adfd2657343e9e08be27d502","content":[{"type":"text","text":"   1→/**\n   2→ * Log Pager Service\n   3→ *\n   4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-2: Paginated Logs Query, US-3: Message Length Compliance\n   5→ *\n   6→ * Handles paginated log reading with offset and line limits.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D3: CLI argument pagination, no complex protocol\n  10→ * - D5: Real-time error extraction, no additional storage\n  11→ */\n  12→\n  13→import fs from 'node:fs';\n  14→import readline from 'node:readline';\n  15→import { once } from 'node:events';\n  16→\n  17→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  18→import { getStatePaths } from '../pipeline-infra/path-policy.js';\n  19→\n  20→const MAX_LINES = 500;\n  21→const DEFAULT_LINES = 50;\n  22→const FILE_THRESHOLD_BYTES = 4000;\n  23→const LARGE_FILE_THRESHOLD = 1024 * 1024; // 1MB - use streaming for larger files\n  24→\n  25→/**\n  26→ * Create a log pager instance.\n  27→ * @param {Object} options - Options\n  28→ * @param {Object} [options.stateManager] - State manager instance\n  29→ * @param {Object} [options.config] - Pipeline config\n  30→ * @returns {Object} Log pager interface\n  31→ */\n  32→export function createLogPager(options = {}) {\n  33→  const config = options.config || loadPipelineInfraConfig();\n  34→\n  35→  /**\n  36→   * Get log file path for pipeline type.\n  37→   * @param {'feature' | 'bugfix'} type - Pipeline type\n  38→   * @returns {string} Log file path\n  39→   */\n  40→  function getLogPath(type) {\n  41→    const paths = getStatePaths(config.projectRoot, type);\n  42→    return paths.daemonLogFile;\n  43→  }\n  44→\n  45→  /**\n  46→   * Count total lines in a file.\n  47→   * @param {string} filePath - File path\n  48→   * @returns {Promise<number>} Total line count\n  49→   */\n  50→  async function countLines(filePath) {\n  51→    try {\n  52→      const content = fs.readFileSync(filePath, 'utf8');\n  53→      return content.split('\\n').filter(l => l.trim()).length;\n  54→    } catch {\n  55→      return 0;\n  56→    }\n  57→  }\n  58→\n  59→  /**\n  60→   * Stream-read last N lines from a large file efficiently.\n  61→   * @param {string} filePath - File path\n  62→   * @param {number} lineCount - Number of lines to read\n  63→   * @param {number} offset - Lines to skip from end\n  64→   * @returns {Promise<{lines: string[], totalLines: number}>}\n  65→   */\n  66→  async function streamReadLastLines(filePath, lineCount, offset = 0) {\n  67→    return new Promise((resolve, reject) => {\n  68→      const lines = [];\n  69→      let totalLines = 0;\n  70→\n  71→      const stream = fs.createReadStream(filePath, { encoding: 'utf8' });\n  72→      const rl = readline.createInterface({\n  73→        input: stream,\n  74→        crlfDelay: Infinity\n  75→      });\n  76→\n  77→      rl.on('line', (line) => {\n  78→        totalLines++;\n  79→        // We'll collect all lines then slice at the end\n  80→      });\n  81→\n  82→      rl.on('close', () => {\n  83→        // Re-open to get specific lines\n  84→        const startIdx = Math.max(0, totalLines - offset - lineCount);\n  85→        const endIdx = totalLines - offset;\n  86→\n  87→        let currentLine = 0;\n  88→        const selectedLines = [];\n  89→\n  90→        const stream2 = fs.createReadStream(filePath, { encoding: 'utf8' });\n  91→        const rl2 = readline.createInterface({\n  92→          input: stream2,\n  93→          crlfDelay: Infinity\n  94→        });\n  95→\n  96→        rl2.on('line', (line) => {\n  97→          currentLine++;\n  98→          if (currentLine > startIdx && currentLine <= endIdx) {\n  99→            if (line.trim()) {\n 100→              selectedLines.push(line);\n 101→            }\n 102→          }\n 103→        });\n 104→\n 105→        rl2.on('close', () => {\n 106→          resolve({ lines: selectedLines, totalLines });\n 107→        });\n 108→\n 109→        rl2.on('error', (err) => {\n 110→          reject(err);\n 111→        });\n 112→      });\n 113→\n 114→      rl.on('error', (err) => {\n 115→        reject(err);\n 116→      });\n 117→    });\n 118→  }\n 119→\n 120→  /**\n 121→   * Read log page with pagination.\n 122→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 123→   * @param {Object} pageOptions - Pagination options\n 124→   * @param {number} [pageOptions.lines=50] - Number of lines to read\n 125→   * @param {number} [pageOptions.offset=0] - Number of lines to skip\n 126→   * @param {boolean} [pageOptions.reverse=true] - Read from end (newest first)\n 127→   * @returns {Promise<Object>} Log page result\n 128→   */\n 129→  async function readLogPage(type, pageOptions = {}) {\n 130→    const requestedLines = Math.min(pageOptions.lines || DEFAULT_LINES, MAX_LINES);\n 131→    const offset = pageOptions.offset || 0;\n 132→    const reverse = pageOptions.reverse !== false; // Default true\n 133→\n 134→    const logPath = getLogPath(type);\n 135→\n 136→    // Check if file exists\n 137→    if (!fs.existsSync(logPath)) {\n 138→      return {\n 139→        ok: true,\n 140→        logs: '',\n 141→        metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 142→        message: '📭 暂无日志。Pipeline 尚未运行或日志文件不存在。'\n 143→      };\n 144→    }\n 145→\n 146→    try {\n 147→      // Check file size for streaming optimization\n 148→      const stats = fs.statSync(logPath);\n 149→      const useStreaming = stats.size > LARGE_FILE_THRESHOLD;\n 150→\n 151→      if (useStreaming) {\n 152→        // Use stream-based reading for large files (T-021)\n 153→        const result = await streamReadLastLines(logPath, requestedLines, offset);\n 154→        const { lines: selectedLines, totalLines } = result;\n 155→\n 156→        const pageStart = Math.max(1, totalLines - offset - requestedLines + 1);\n 157→        const pageEnd = totalLines - offset;\n 158→        const logs = reverse ? selectedLines.reverse().join('\\n') : selectedLines.join('\\n');\n 159→        const actualLines = selectedLines.length;\n 160→\n 161→        return {\n 162→          ok: true,\n 163→          logs,\n 164→          metadata: buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines)\n 165→        };\n 166→      }\n 167→\n 168→      // Standard reading for smaller files\n 169→      const content = fs.readFileSync(logPath, 'utf8');\n 170→      const allLines = content.split('\\n').filter(l => l.trim());\n 171→      const totalLines = allLines.length;\n 172→\n 173→      if (totalLines === 0) {\n 174→        return {\n 175→          ok: true,\n 176→          logs: '',\n 177→          metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 178→          message: '📭 日志文件为空。'\n 179→        };\n 180→      }\n 181→\n 182→      // Apply pagination\n 183→      let selectedLines;\n 184→      let pageStart;\n 185→      let pageEnd;\n 186→\n 187→      if (reverse) {\n 188→        // Read from end (newest first)\n 189→        const startIdx = Math.max(0, totalLines - offset - requestedLines);\n 190→        const endIdx = totalLines - offset;\n 191→        selectedLines = allLines.slice(startIdx, endIdx).reverse();\n 192→        pageStart = startIdx + 1;\n 193→        pageEnd = endIdx;\n 194→      } else {\n 195→        // Read from beginning\n 196→        selectedLines = allLines.slice(offset, offset + requestedLines);\n 197→        pageStart = offset + 1;\n 198→        pageEnd = Math.min(offset + requestedLines, totalLines);\n 199→      }\n 200→\n 201→      const logs = selectedLines.join('\\n');\n 202→      const actualLines = selectedLines.length;\n 203→\n 204→      return {\n 205→        ok: true,\n 206→        logs,\n 207→        metadata: buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines)\n 208→      };\n 209→    } catch (error) {\n 210→      return {\n 211→        ok: true,\n 212→        logs: '',\n 213→        metadata: buildLogMetadata(logPath, 0, 0, 0, requestedLines, 0),\n 214→        message: `⚠️ 读取日志失败: ${error.message}`\n 215→      };\n 216→    }\n 217→  }\n 218→\n 219→  /**\n 220→   * Extract error lines from log content.\n 221→   * @param {string} logs - Log content\n 222→   * @param {number} lineCount - Maximum lines to extract\n 223→   * @returns {Array<string>} Array of error lines\n 224→   */\n 225→  function extractErrorLines(logs, lineCount = 10) {\n 226→    if (!logs) return [];\n 227→\n 228→    const lines = logs.split('\\n');\n 229→    const errorLines = lines.filter(line =>\n 230→      line.includes('ERROR') ||\n 231→      line.includes('Error:') ||\n 232→      line.includes('Exception') ||\n 233→      line.includes('FAIL')\n 234→    );\n 235→\n 236→    // Return last N error lines\n 237→    return errorLines.slice(-lineCount);\n 238→  }\n 239→\n 240→  /**\n 241→   * Check if logs should be sent as file.\n 242→   * @param {string} logs - Log content\n 243→   * @param {number} [threshold] - Byte threshold (default 4000)\n 244→   * @returns {boolean} True if should send as file\n 245→   */\n 246→  function shouldSendAsFile(logs, threshold = FILE_THRESHOLD_BYTES) {\n 247→    if (!logs) return false;\n 248→    return Buffer.byteLength(logs, 'utf8') >= threshold;\n 249→  }\n 250→\n 251→  /**\n 252→   * Build log metadata object.\n 253→   * @param {string} logPath - Log file path\n 254→   * @param {number} totalLines - Total lines in file\n 255→   * @param {number} pageStart - Start line of page\n 256→   * @param {number} pageEnd - End line of page\n 257→   * @param {number} requestedLines - Requested lines\n 258→   * @param {number} actualLines - Actual lines returned\n 259→   * @returns {Object} Metadata object\n 260→   */\n 261→  function buildLogMetadata(logPath, totalLines, pageStart, pageEnd, requestedLines, actualLines) {\n 262→    return {\n 263→      logPath,\n 264→      totalLines,\n 265→      pageStart,\n 266→      pageEnd,\n 267→      requestedLines,\n 268→      actualLines\n 269→    };\n 270→  }\n 271→\n 272→  /**\n 273→   * Format logs for Telegram display.\n 274→   * @param {string} logs - Log content\n 275→   * @param {Object} metadata - Log metadata\n 276→   * @returns {string} Formatted message\n 277→   */\n 278→  function formatLogsForTelegram(logs, metadata = {}) {\n 279→    if (!logs || logs.trim() === '') {\n 280→      return '📭 暂无日志内容。';\n 281→    }\n 282→\n 283→    const lines = [];\n 284→\n 285→    // Add header with metadata\n 286→    lines.push('📋 **Pipeline 日志**');\n 287→    if (metadata.totalLines !== undefined) {\n 288→      lines.push(`总计: ${metadata.totalLines} 行`);\n 289→      if (metadata.pageStart && metadata.pageEnd) {\n 290→        lines.push(`显示: 第 ${metadata.pageStart}-${metadata.pageEnd} 行`);\n 291→      }\n 292→    }\n 293→    lines.push('');\n 294→\n 295→    // Add segment numbering if provided\n 296→    if (metadata.totalSegments && metadata.segmentIndex !== undefined) {\n 297→      lines[0] = `📋 **Pipeline 日志** [${metadata.segmentIndex + 1}/${metadata.totalSegments}]`;\n 298→    }\n 299→\n 300→    // Add log content\n 301→    lines.push('```');\n 302→    lines.push(logs);\n 303→    lines.push('```');\n 304→\n 305→    return lines.join('\\n');\n 306→  }\n 307→\n 308→  return {\n 309→    readLogPage,\n 310→    formatLogsForTelegram,\n 311→    extractErrorLines,\n 312→    shouldSendAsFile,\n 313→    buildLogMetadata\n 314→  };\n 315→}\n 316→\n 317→export default createLogPager;\n 318→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.258Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
{"type":"user","uuid":"2b59859b-0f1e-47e2-a4ec-577d94f550ae","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90af6338604fc8439136fbc560","content":[{"type":"text","text":"   1→/**\n   2→ * Telegram Pusher Service\n   3→ *\n   4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-4: Heartbeat Progress Push, US-5: Error Summary Push\n   5→ *\n   6→ * Manages Telegram message pushing with throttling, chunking, and heartbeat.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D2: In-memory queue with retry, non-blocking\n  10→ * - D4: Event-driven heartbeat with time throttle\n  11→ * - D7: Retry strategy: max 3, exponential backoff (1s → 2s → 4s)\n  12→ */\n  13→\n  14→import { randomUUID } from 'node:crypto';\n  15→\n  16→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  17→\n  18→const DEFAULT_THROTTLE_INTERVAL = 30 * 1000; // 30 seconds\n  19→const DEFAULT_SEGMENT_INTERVAL = 500; // 500ms between segments\n  20→const DEFAULT_ERROR_LINES_COUNT = 10;\n  21→const MAX_MESSAGE_LENGTH = 4000;\n  22→const MAX_RETRIES = 3;\n  23→\n  24→/**\n  25→ * Create a Telegram pusher instance.\n  26→ * @param {Object} options - Options\n  27→ * @param {Object} options.bot - Telegraf bot instance\n  28→ * @param {number} options.targetChatId - Target chat ID\n  29→ * @param {number} [options.heartbeatInterval] - Heartbeat interval in ms\n  30→ * @param {number} [options.heartbeatFeatureCount] - Features completed before push check\n  31→ * @param {number} [options.errorLinesCount] - Error lines to include\n  32→ * @param {number} [options.throttleInterval] - Throttle interval in ms\n  33→ * @param {number} [options.segmentInterval] - Segment delay in ms\n  34→ * @param {number} [options.maxRetries] - Max retry attempts\n  35→ * @param {Object} [options.heartbeatConfig] - Heartbeat configuration\n  36→ * @returns {Object} Telegram pusher interface\n  37→ */\n  38→export function createTelegramPusher(options = {}) {\n  39→  const bot = options.bot;\n  40→  const targetChatId = options.targetChatId;\n  41→  const heartbeatInterval = options.heartbeatInterval || options.heartbeatConfig?.intervalMs || 30000;\n  42→  const heartbeatFeatureCount = options.heartbeatFeatureCount || 1;\n  43→  const errorLinesCount = options.errorLinesCount || options.heartbeatConfig?.errorLinesCount || DEFAULT_ERROR_LINES_COUNT;\n  44→  const throttleInterval = options.throttleInterval || DEFAULT_THROTTLE_INTERVAL;\n  45→  const segmentInterval = options.segmentInterval || DEFAULT_SEGMENT_INTERVAL;\n  46→  const maxRetries = options.maxRetries || MAX_RETRIES;\n  47→  const heartbeatConfig = options.heartbeatConfig || {};\n  48→\n  49→  // Internal state\n  50→  const heartbeatTimers = new Map(); // type -> timer\n  51→  const throttleTimestamps = new Map(); // key -> lastExecutionTime\n  52→  const messageQueue = [];\n  53→  let queueProcessing = false;\n  54→\n  55→  /**\n  56→   * Throttle a function call.\n  57→   * @param {string} key - Throttle key\n  58→   * @param {Function} fn - Async function to throttle\n  59→   * @returns {Promise<void>}\n  60→   */\n  61→  async function throttle(key, fn) {\n  62→    const now = Date.now();\n  63→    const lastExecution = throttleTimestamps.get(key) || 0;\n  64→\n  65→    if (now - lastExecution < throttleInterval) {\n  66→      // Throttled, skip execution\n  67→      return;\n  68→    }\n  69→\n  70→    throttleTimestamps.set(key, now);\n  71→    await fn();\n  72→  }\n  73→\n  74→  /**\n  75→   * Split message into chunks respecting Telegram limits.\n  76→   * @param {string} text - Text to split\n  77→   * @returns {Array<string>} Array of chunks\n  78→   */\n  79→  function splitMessage(text) {\n  80→    if (text.length <= MAX_MESSAGE_LENGTH) {\n  81→      return [text];\n  82→    }\n  83→\n  84→    const chunks = [];\n  85→    let remaining = text;\n  86→\n  87→    while (remaining.length > 0) {\n  88→      // Find a good break point\n  89→      let breakPoint = MAX_MESSAGE_LENGTH;\n  90→      if (remaining.length > MAX_MESSAGE_LENGTH) {\n  91→        // Try to break at newline\n  92→        const newlineSearch = remaining.lastIndexOf('\\n', MAX_MESSAGE_LENGTH);\n  93→        if (newlineSearch > MAX_MESSAGE_LENGTH / 2) {\n  94→          breakPoint = newlineSearch + 1;\n  95→        }\n  96→      }\n  97→\n  98→      chunks.push(remaining.slice(0, breakPoint));\n  99→      remaining = remaining.slice(breakPoint);\n 100→    }\n 101→\n 102→    return chunks;\n 103→  }\n 104→\n 105→  /**\n 106→   * Send a message chunked to respect Telegram limits.\n 107→   * @param {number} chatId - Target chat ID\n 108→   * @param {string} text - Message text\n 109→   * @returns {Promise<Array>} Array of message results\n 110→   */\n 111→  async function sendMessageChunked(chatId, text) {\n 112→    const chunks = splitMessage(text);\n 113→    const results = [];\n 114→    const total = chunks.length;\n 115→\n 116→    for (let i = 0; i < chunks.length; i++) {\n 117→      // Add segment numbering for multiple chunks\n 118→      let chunk = chunks[i];\n 119→      if (total > 1) {\n 120→        chunk = `[${i + 1}/${total}] ${chunk}`;\n 121→      }\n 122→\n 123→      try {\n 124→        const result = await bot.telegram.sendMessage(chatId, chunk, {\n 125→          parse_mode: 'Markdown'\n 126→        });\n 127→        results.push(result);\n 128→\n 129→        // Delay between segments\n 130→        if (i < chunks.length - 1 && segmentInterval > 0) {\n 131→          await new Promise(resolve => setTimeout(resolve, segmentInterval));\n 132→        }\n 133→      } catch (error) {\n 134→        // Queue for retry\n 135→        enqueueMessage({\n 136→          id: randomUUID(),\n 137→          chatId,\n 138→          text: chunk,\n 139→          type: 'notification',\n 140→          priority: 10,\n 141→          retryCount: 0\n 142→        });\n 143→        results.push({ error: error.message });\n 144→      }\n 145→    }\n 146→\n 147→    return results;\n 148→  }\n 149→\n 150→  /**\n 151→   * Send a file to chat.\n 152→   * @param {number} chatId - Target chat ID\n 153→   * @param {string} content - File content\n 154→   * @param {string} filename - Filename\n 155→   * @returns {Promise<Object>} Send result\n 156→   */\n 157→  async function sendFile(chatId, content, filename) {\n 158→    try {\n 159→      const { Input } = await import('telegraf');\n 160→      const buffer = Buffer.from(content, 'utf-8');\n 161→      const document = new Input(buffer, filename);\n 162→\n 163→      return await bot.telegram.sendDocument(chatId, document, {\n 164→        filename\n 165→      });\n 166→    } catch (error) {\n 167→      // Fallback to chunked message if file send fails\n 168→      return sendMessageChunked(chatId, content);\n 169→    }\n 170→  }\n 171→\n 172→  /**\n 173→   * Enqueue a message for async processing.\n 174→   * @param {Object} message - Message object\n 175→   */\n 176→  function enqueueMessage(message) {\n 177→    messageQueue.push(message);\n 178→    processQueue();\n 179→  }\n 180→\n 181→  /**\n 182→   * Process message queue with retry logic.\n 183→   */\n 184→  async function processQueue() {\n 185→    if (queueProcessing) return;\n 186→    queueProcessing = true;\n 187→\n 188→    while (messageQueue.length > 0) {\n 189→      const message = messageQueue.shift();\n 190→\n 191→      try {\n 192→        await bot.telegram.sendMessage(message.chatId, message.text, {\n 193→          parse_mode: 'Markdown'\n 194→        });\n 195→      } catch (error) {\n 196→        // Retry with exponential backoff\n 197→        if (message.retryCount < maxRetries) {\n 198→          message.retryCount++;\n 199→          const delay = Math.pow(2, message.retryCount - 1) * 1000; // 1s, 2s, 4s\n 200→\n 201→          await new Promise(resolve => setTimeout(resolve, delay));\n 202→          messageQueue.unshift(message); // Re-queue at front\n 203→        }\n 204→        // If max retries exceeded, discard message (non-blocking)\n 205→      }\n 206→    }\n 207→\n 208→    queueProcessing = false;\n 209→  }\n 210→\n 211→  /**\n 212→   * Start heartbeat for a pipeline type.\n 213→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 214→   * @param {Object} aggregator - Status aggregator\n 215→   */\n 216→  function startHeartbeat(type, aggregator) {\n 217→    // Check if heartbeat is enabled\n 218→    if (heartbeatConfig.enabled === false) {\n 219→      return;\n 220→    }\n 221→\n 222→    // Don't start duplicate timers\n 223→    if (heartbeatTimers.has(type)) {\n 224→      return;\n 225→    }\n 226→\n 227→    const timer = setInterval(async () => {\n 228→      await throttle(`heartbeat-${type}`, async () => {\n 229→        try {\n 230→          const status = await aggregator.aggregateStatus(type);\n 231→          const formatted = aggregator.formatStatusForTelegram(status);\n 232→          await sendMessageChunked(targetChatId, formatted);\n 233→        } catch (error) {\n 234→          // Log error but don't block\n 235→          console.error(`Heartbeat error for ${type}:`, error.message);\n 236→        }\n 237→      });\n 238→    }, heartbeatInterval);\n 239→\n 240→    heartbeatTimers.set(type, timer);\n 241→  }\n 242→\n 243→  /**\n 244→   * Stop heartbeat for a pipeline type.\n 245→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 246→   */\n 247→  function stopHeartbeat(type) {\n 248→    const timer = heartbeatTimers.get(type);\n 249→    if (timer) {\n 250→      clearInterval(timer);\n 251→      heartbeatTimers.delete(type);\n 252→    }\n 253→\n 254→    // Process remaining queue\n 255→    processQueue();\n 256→  }\n 257→\n 258→  /**\n 259→   * Handle feature completed event.\n 260→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 261→   * @param {string} featureId - Feature ID\n 262→   * @param {Object} aggregator - Status aggregator\n 263→   */\n 264→  async function onFeatureCompleted(type, featureId, aggregator) {\n 265→    await throttle(`feature-complete-${type}`, async () => {\n 266→      try {\n 267→        const status = await aggregator.aggregateStatus(type);\n 268→        const message = `✅ Feature 完成: ${featureId}\\n\\n` +\n 269→          `📊 进度: ${status.progress.completed}/${status.progress.total} (${status.progress.successRate}%)`;\n 270→        await sendMessageChunked(targetChatId, message);\n 271→      } catch (error) {\n 272→        console.error(`Feature completed notification error:`, error.message);\n 273→      }\n 274→    });\n 275→  }\n 276→\n 277→  /**\n 278→   * Push error summary notification.\n 279→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 280→   * @param {string} featureId - Feature ID\n 281→   * @param {Object} error - Error object\n 282→   * @returns {Promise<Object>} Push result\n 283→   */\n 284→  async function pushErrorSummary(type, featureId, error) {\n 285→    // Check silent mode\n 286→    if (heartbeatConfig.silentMode && error.isExpected) {\n 287→      return { ok: true, skipped: true };\n 288→    }\n 289→\n 290→    const lines = [];\n 291→    lines.push(`❌ **执行失败: ${featureId}**`);\n 292→    lines.push(`类型: ${error.type || 'unknown'}`);\n 293→    lines.push('');\n 294→\n 295→    if (error.message) {\n 296→      lines.push(`**错误信息:**`);\n 297→      lines.push(error.message);\n 298→      lines.push('');\n 299→    }\n 300→\n 301→    // Include execution time/duration\n 302→    if (error.duration) {\n 303→      const mins = Math.floor(error.duration / 60);\n 304→      const secs = error.duration % 60;\n 305→      lines.push(`⏱️ 执行时间: ${mins}m ${secs}s`);\n 306→      lines.push('');\n 307→    }\n 308→\n 309→    // Include error log lines\n 310→    if (error.logLines && error.logLines.length > 0) {\n 311→      lines.push(`**日志片段:** (最后 ${Math.min(errorLinesCount, error.logLines.length)} 行)`);\n 312→      const errorLines = error.logLines.slice(-errorLinesCount);\n 313→      lines.push('```');\n 314→      lines.push(errorLines.join('\\n'));\n 315→      lines.push('```');\n 316→    }\n 317→\n 318→    const message = lines.join('\\n');\n 319→\n 320→    try {\n 321→      const result = await sendMessageChunked(targetChatId, message);\n 322→      return {\n 323→        ok: true,\n 324→        messageId: result[0]?.message_id\n 325→      };\n 326→    } catch (err) {\n 327→      return {\n 328→        ok: false,\n 329→        errorCode: 'SEND_FAILED',\n 330→        message: err.message\n 331→      };\n 332→    }\n 333→  }\n 334→\n 335→  /**\n 336→   * Push startup notification.\n 337→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 338→   * @param {Object} runInfo - Run info object\n 339→   * @returns {Promise<Object>} Push result\n 340→   */\n 341→  async function pushStartupNotification(type, runInfo) {\n 342→    const lines = [];\n 343→    lines.push(`🚀 **Pipeline 启动** (${type})`);\n 344→    lines.push(`Run ID: ${runInfo.runId}`);\n 345→    lines.push(`开始时间: ${runInfo.startedAt}`);\n 346→    lines.push('');\n 347→\n 348→    if (runInfo.targets && runInfo.targets.length > 0) {\n 349→      lines.push(`**目标列表:** (${runInfo.targets.length} 个)`);\n 350→      const displayTargets = runInfo.targets.slice(0, 10);\n 351→      for (const target of displayTargets) {\n 352→        lines.push(`  • ${target}`);\n 353→      }\n 354→      if (runInfo.targets.length > 10) {\n 355→        lines.push(`  ... 及其他 ${runInfo.targets.length - 10} 个`);\n 356→      }\n 357→    }\n 358→\n 359→    const message = lines.join('\\n');\n 360→\n 361→    try {\n 362→      const result = await sendMessageChunked(targetChatId, message);\n 363→      return {\n 364→        ok: true,\n 365→        messageId: result[0]?.message_id\n 366→      };\n 367→    } catch (err) {\n 368→      return {\n 369→        ok: false,\n 370→        errorCode: 'SEND_FAILED',\n 371→        message: err.message\n 372→      };\n 373→    }\n 374→  }\n 375→\n 376→  return {\n 377→    throttle,\n 378→    sendMessageChunked,\n 379→    sendFile,\n 380→    enqueueMessage,\n 381→    processQueue,\n 382→    startHeartbeat,\n 383→    stopHeartbeat,\n 384→    onFeatureCompleted,\n 385→    pushErrorSummary,\n 386→    pushStartupNotification\n 387→  };\n 388→}\n 389→\n 390→export default createTelegramPusher;\n 391→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.259Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
{"type":"user","uuid":"d3269fc3-1e1b-470f-a54e-bb81b4195d40","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90b0e2db93f8283bd8a104ce40","content":[{"type":"text","text":"   1→/**\n   2→ * Status Command Handler\n   3→ * Handles /status command to show aggregated pipeline status.\n   4→ *\n   5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-1: Aggregated Status Query\n   6→ */\n   7→\n   8→import { createStatusAggregator } from '../../../services/status-aggregator.js';\n   9→\n  10→/**\n  11→ * Status command metadata.\n  12→ */\n  13→export const statusMeta = {\n  14→  name: 'status',\n  15→  aliases: ['s'],\n  16→  description: '查看管道状态',\n  17→  usage: '/status [--type=feature|bugfix]',\n  18→  examples: ['/status', '/status --type=bugfix', '/status -t feature'],\n  19→  params: [\n  20→    {\n  21→      name: 'type',\n  22→      type: 'string',\n  23→      required: false,\n  24→      description: 'Pipeline 类型 (feature 或 bugfix)',\n  25→      default: 'feature',\n  26→      aliases: ['t']\n  27→    }\n  28→  ],\n  29→  requiresAuth: true,\n  30→  helpText: '/status [--type=feature|bugfix] - 查看管道状态'\n  31→};\n  32→\n  33→/**\n  34→ * Handle status command.\n  35→ * @param {Object} handlerCtx - Handler context\n  36→ */\n  37→export async function handleStatus(handlerCtx) {\n  38→  const { reply, params } = handlerCtx;\n  39→  const pipelineType = params.type || params.t || 'feature';\n  40→\n  41→  // Validate pipeline type\n  42→  if (pipelineType !== 'feature' && pipelineType !== 'bugfix') {\n  43→    await reply(`❌ 无效的 pipeline 类型: ${pipelineType}。请使用 'feature' 或 'bugfix'。`);\n  44→    return;\n  45→  }\n  46→\n  47→  try {\n  48→    const aggregator = createStatusAggregator();\n  49→    const status = await aggregator.aggregateStatus(pipelineType);\n  50→    const formatted = aggregator.formatStatusForTelegram(status);\n  51→\n  52→    await reply(formatted);\n  53→  } catch (error) {\n  54→    await reply(`❌ 查询失败: ${error.message}`);\n  55→  }\n  56→}\n  57→\n  58→export default handleStatus;\n  59→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.259Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
{"type":"user","uuid":"1dd10ec4-fd56-4499-87a2-658e9e2433f7","session_id":"da6f98d4-7e33-4c58-9c42-a371874e10ea","message":{"content":[{"type":"tool_result","tool_use_id":"019cde90b27c51a8835aabaaa8a6ed72","content":[{"type":"text","text":"   1→/**\n   2→ * Logs Command Handler\n   3→ * Handles /logs command to retrieve pipeline logs with pagination support.\n   4→ *\n   5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-2: Paginated Logs Query, US-3: Message Length Compliance\n   6→ */\n   7→\n   8→import { createLogPager } from '../../../services/log-pager.js';\n   9→\n  10→/**\n  11→ * Logs command metadata.\n  12→ */\n  13→export const logsMeta = {\n  14→  name: 'logs',\n  15→  aliases: ['l'],\n  16→  description: '查看管道日志',\n  17→  usage: '/logs [--lines=N] [--offset=N] [--type=feature|bugfix] [--file]',\n  18→  examples: [\n  19→    '/logs',\n  20→    '/logs --lines=100',\n  21→    '/logs --lines=50 --offset=50',\n  22→    '/logs --type=bugfix',\n  23→    '/logs --file'\n  24→  ],\n  25→  params: [\n  26→    {\n  27→      name: 'lines',\n  28→      type: 'number',\n  29→      required: false,\n  30→      description: '显示行数 (最大 500)',\n  31→      default: 50,\n  32→      aliases: ['n']\n  33→    },\n  34→    {\n  35→      name: 'offset',\n  36→      type: 'number',\n  37→      required: false,\n  38→      description: '跳过前 N 行',\n  39→      default: 0,\n  40→      aliases: ['o']\n  41→    },\n  42→    {\n  43→      name: 'type',\n  44→      type: 'string',\n  45→      required: false,\n  46→      description: 'Pipeline 类型 (feature 或 bugfix)',\n  47→      default: 'feature',\n  48→      aliases: ['t']\n  49→    },\n  50→    {\n  51→      name: 'file',\n  52→      type: 'boolean',\n  53→      required: false,\n  54→      description: '发送为文件',\n  55→      default: false,\n  56→      aliases: ['f']\n  57→    }\n  58→  ],\n  59→  requiresAuth: true,\n  60→  helpText: '/logs [--lines=N] [--offset=N] [--type=feature|bugfix] [--file] - 查看管道日志'\n  61→};\n  62→\n  63→/**\n  64→ * Handle logs command.\n  65→ * @param {Object} handlerCtx - Handler context\n  66→ */\n  67→export async function handleLogs(handlerCtx) {\n  68→  const { params, reply, replyFile } = handlerCtx;\n  69→\n  70→  // Parse parameters\n  71→  const lines = Math.min(parseInt(params.lines || params.n, 10) || 50, 500);\n  72→  const offset = parseInt(params.offset || params.o, 10) || 0;\n  73→  const pipelineType = params.type || params.t || 'feature';\n  74→  const sendAsFile = params.file || params.f || false;\n  75→\n  76→  // Validate pipeline type\n  77→  if (pipelineType !== 'feature' && pipelineType !== 'bugfix') {\n  78→    await reply(`❌ 无效的 pipeline 类型: ${pipelineType}。请使用 'feature' 或 'bugfix'。`);\n  79→    return;\n  80→  }\n  81→\n  82→  try {\n  83→    const pager = createLogPager();\n  84→    const result = await pager.readLogPage(pipelineType, { lines, offset });\n  85→\n  86→    if (!result.ok) {\n  87→      await reply(`❌ 获取日志失败: ${result.message || '未知错误'}`);\n  88→      return;\n  89→    }\n  90→\n  91→    const logs = result.logs || '';\n  92→\n  93→    // Check for empty logs\n  94→    if (!logs.trim()) {\n  95→      await reply(`📭 ${result.message || '暂无日志。'}`);\n  96→      return;\n  97→    }\n  98→\n  99→    // Send as file if requested or if too long\n 100→    if (sendAsFile || pager.shouldSendAsFile(logs)) {\n 101→      const filename = `pipeline-${pipelineType}-logs-${Date.now()}.txt`;\n 102→      await replyFile(logs, filename);\n 103→      await reply(`📄 日志已发送为文件 (${logs.length} 字符, ${result.metadata.actualLines} 行)`);\n 104→      return;\n 105→    }\n 106→\n 107→    // Send formatted logs\n 108→    const formatted = pager.formatLogsForTelegram(logs, result.metadata);\n 109→    await reply(formatted);\n 110→  } catch (error) {\n 111→    await reply(`❌ 获取日志失败: ${error.message}`);\n 112→  }\n 113→}\n 114→\n 115→export default handleLogs;\n 116→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_475ad05a155d4431bd73ba2b","__timestamp":"2026-03-11T20:22:31.259Z","_requestId":"2a50dd388a364b15840cdcad9dcd8a24"}
