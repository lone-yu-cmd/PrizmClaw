atted);\n  54→  } catch (error) {\n  55→    await reply(`❌ 查询失败: ${error.message}`);\n  56→  }\n  57→}\n  58→\n  59→export default handleStatus;\n  60→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_6ed227e88daa4bc7bcc1af8c","__timestamp":"2026-03-11T20:43:07.331Z","_requestId":"1836a01aa07b4323b33253678e844458"}
