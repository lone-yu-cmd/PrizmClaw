R: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5)\n  32→});\n  33→\n  34→const parsed = schema.parse(process.env);\n  35→\n  36→function parseAllowedUserIds(input) {\n  37→  return new Set(\n  38→    input\n  39→      .split(',')\n  40→      .map((id) => id.trim())\n  41→      .filter(Boolean)\n  42→  );\n  43→}\n  44→\n  45→function parseCsvList(input) {\n  46→  return input\n  47→    .split(',')\n  48→    .map((item) => item.trim())\n  49→    .filter(Boolean);\n  50→}\n  51→\n  52→function parseBoolean(input) {\n  53→  const normalized = (input ?? '').trim().toLowerCase();\n  54→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  55→}\n  56→\n  57→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n  58→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n  59→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n  60→}\n  61→\n  62→const pipelineInfra = loadPipelineInfraConfig({\n  63→  env: process.env,\n  64→  argv: process.argv.slice(2),\n  65→  cwd: process.cwd()\n  66→});\n  67→\n  68→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n  69→\n  70→export const config = Object.freeze({\n  71→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n  72→  enableTelegram,\n  73→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n  74→  codebuddyBin: parsed.CODEBUDDY_BIN,\n  75→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n  76→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n  77→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n  78→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n  79→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n  80→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n  81→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n  82→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n  83→  webHost: parsed.WEB_HOST,\n  84→  webPort: parsed.WEB_PORT,\n  85→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n  86→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n  87→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n  88→  logLevel: parsed.LOG_LEVEL,\n  89→  pipelineInfra: Object.freeze({\n  90→    ...pipelineInfra,\n  91→    daemonLogPaths\n  92→  })\n  93→});\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:32:54.319Z","_requestId":"1836a01aa07b4323b33253678e844458"}
