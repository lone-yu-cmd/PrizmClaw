{"type":"user","uuid":"b40bcc89-d44a-4764-b470-ac2f1782fd86","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"019cde9960c20218a255e82c96e406e1","content":[{"type":"text","text":"[\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/bugfix.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/planner.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/plan.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/pipeline.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/stop.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/status.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/logs.js\"]"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:32:00.869Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"9914c9ab-5f60-4bf1-80f3-732b75c2583d","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"019cde9961bd1d1c37a5c79aef6a09ad","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} helpText - Help text for the command\n  34→ */\n  35→\n  36→/**\n  37→ * @typedef {Object} CommandEntry\n  38→ * @property {CommandMeta} meta - Command metadata\n  39→ * @property {Function} handler - Command handler function\n  40→ */\n  41→\n  42→/**\n  43→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  44→ */\n  45→\n  46→// Internal registry storage\n  47→const commands = new Map();\n  48→const aliasToCommand = new Map();\n  49→\n  50→/**\n  51→ * Register a command with its metadata and handler.\n  52→ * @param {CommandMeta} meta - Command metadata\n  53→ * @param {Function} handler - Command handler function\n  54→ * @throws {Error} If command already registered\n  55→ */\n  56→export function registerCommand(meta, handler) {\n  57→  if (!meta || !meta.name) {\n  58→    throw new Error('Command meta must have a name');\n  59→  }\n  60→\n  61→  // Normalize meta with lowercase name\n  62→  const normalizedMeta = {\n  63→    ...meta,\n  64→    name: meta.name.toLowerCase()\n  65→  };\n  66→  const name = normalizedMeta.name;\n  67→\n  68→  if (commands.has(name)) {\n  69→    throw new Error(`Command \"${name}\" is already registered`);\n  70→  }\n  71→\n  72→  // Register command\n  73→  commands.set(name, { meta: normalizedMeta, handler });\n  74→\n  75→  // Register aliases\n  76→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  77→    for (const alias of meta.aliases) {\n  78→      const aliasLower = alias.toLowerCase();\n  79→      if (aliasToCommand.has(aliasLower)) {\n  80→        throw new Error(`Alias \"${alias}\" is already registered`);\n  81→      }\n  82→      aliasToCommand.set(aliasLower, name);\n  83→    }\n  84→  }\n  85→}\n  86→\n  87→/**\n  88→ * Get a command entry by name or alias.\n  89→ * @param {string} name - Command name or alias\n  90→ * @returns {CommandEntry | null} Command entry or null\n  91→ */\n  92→export function getCommand(name) {\n  93→  if (!name || typeof name !== 'string') {\n  94→    return null;\n  95→  }\n  96→\n  97→  const nameLower = name.toLowerCase();\n  98→\n  99→  // Try direct lookup\n 100→  if (commands.has(nameLower)) {\n 101→    return commands.get(nameLower);\n 102→  }\n 103→\n 104→  // Try alias lookup\n 105→  const resolvedName = aliasToCommand.get(nameLower);\n 106→  if (resolvedName && commands.has(resolvedName)) {\n 107→    return commands.get(resolvedName);\n 108→  }\n 109→\n 110→  return null;\n 111→}\n 112→\n 113→/**\n 114→ * Check if a name is a registered alias.\n 115→ * @param {string} name - Name to check\n 116→ * @returns {boolean} True if name is an alias\n 117→ */\n 118→export function isAlias(name) {\n 119→  if (!name || typeof name !== 'string') {\n 120→    return false;\n 121→  }\n 122→  return aliasToCommand.has(name.toLowerCase());\n 123→}\n 124→\n 125→/**\n 126→ * Get all registered commands.\n 127→ * @returns {CommandEntry[]} All command entries\n 128→ */\n 129→export function getAllCommands() {\n 130→  return Array.from(commands.values());\n 131→}\n 132→\n 133→/**\n 134→ * Generate help text for a specific command or all commands.\n 135→ * @param {string} [commandName] - Optional command name for specific help\n 136→ * @returns {string} Help text\n 137→ */\n 138→export function getHelpText(commandName) {\n 139→  if (commandName) {\n 140→    const entry = getCommand(commandName);\n 141→    if (!entry) {\n 142→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 143→    }\n 144→    return formatCommandHelp(entry.meta);\n 145→  }\n 146→\n 147→  // Generate general help\n 148→  const commandList = getAllCommands()\n 149→    .map((entry) => {\n 150→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 151→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 152→    })\n 153→    .sort();\n 154→\n 155→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 156→}\n 157→\n 158→/**\n 159→ * Format detailed help for a single command.\n 160→ * @param {CommandMeta} meta - Command metadata\n 161→ * @returns {string} Formatted help text\n 162→ */\n 163→function formatCommandHelp(meta) {\n 164→  const lines = [`/${meta.name} - ${meta.description}`];\n 165→\n 166→  if (meta.aliases?.length) {\n 167→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 168→  }\n 169→\n 170→  if (meta.usage) {\n 171→    lines.push(`用法: ${meta.usage}`);\n 172→  }\n 173→\n 174→  if (meta.subcommands?.length) {\n 175→    lines.push('\\n子命令:');\n 176→    for (const sub of meta.subcommands) {\n 177→      lines.push(`  ${sub.name} - ${sub.description}`);\n 178→    }\n 179→  }\n 180→\n 181→  if (meta.params?.length) {\n 182→    lines.push('\\n参数:');\n 183→    for (const param of meta.params) {\n 184→      const required = param.required ? '(必填)' : '(可选)';\n 185→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 186→    }\n 187→  }\n 188→\n 189→  if (meta.examples?.length) {\n 190→    lines.push('\\n示例:');\n 191→    for (const example of meta.examples) {\n 192→      lines.push(`  ${example}`);\n 193→    }\n 194→  }\n 195→\n 196→  return lines.join('\\n');\n 197→}\n 198→\n 199→/**\n 200→ * Clear the registry (for testing).\n 201→ */\n 202→export function clearRegistry() {\n 203→  commands.clear();\n 204→  aliasToCommand.clear();\n 205→}\n 206→\n 207→/**\n 208→ * Get the alias map for parser usage.\n 209→ * @returns {Record<string, string>} Alias to command name mapping\n 210→ */\n 211→export function getAliasMap() {\n 212→  const map = {};\n 213→  for (const [alias, command] of aliasToCommand) {\n 214→    map[alias] = command;\n 215→  }\n 216→  return map;\n 217→}\n 218→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:32:00.874Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"38781411-6392-4d98-9070-da7be218aea2","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"019cde9963715a9f196439139cffca38","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { captureScreenshot } from '../services/screenshot-service.js';\n  11→import { executeSystemCommand } from '../services/system-exec-service.js';\n  12→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  13→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  14→import { registerCommand } from './commands/index.js';\n  15→import { routeCommand } from './commands/index.js';\n  16→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  17→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  18→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  19→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  20→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  21→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  22→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  23→import { generateHelp } from './commands/help.js';\n  24→\n  25→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  26→const STREAM_MIN_CHARS = 220;\n  27→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  28→const TYPING_INTERVAL_MS = 3500;\n  29→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  30→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  31→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  32→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  33→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  34→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  35→const TMP_DIR = path.resolve(os.tmpdir());\n  36→const HOME_DIR = path.resolve(os.homedir());\n  37→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  38→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  39→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  40→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  41→\n  42→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  43→  const normalized = configuredDirs\n  44→    .map((dir) => String(dir ?? '').trim())\n  45→    .filter(Boolean)\n  46→    .map((dir) => path.resolve(dir));\n  47→\n  48→  if (normalized.length > 0) {\n  49→    return [...new Set(normalized)];\n  50→  }\n  51→\n  52→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  53→}\n  54→\n  55→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  56→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  57→\n  58→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  59→  const chunks = [];\n  60→  for (let i = 0; i < text.length; i += chunkSize) {\n  61→    chunks.push(text.slice(i, i + chunkSize));\n  62→  }\n  63→  return chunks;\n  64→}\n  65→\n  66→function sanitizeMarkerPath(raw) {\n  67→  return String(raw ?? '')\n  68→    .trim()\n  69→    .replace(/^['\"`]+/, '')\n  70→    .replace(/['\"`]+$/, '');\n  71→}\n  72→\n  73→function extractFileMarkers(text = '') {\n  74→  const fileRefs = [];\n  75→\n  76→  const withSendFileRemoved = text.replace(\n  77→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  78→    (_full, rawRef) => {\n  79→      const ref = sanitizeMarkerPath(rawRef);\n  80→      if (ref) {\n  81→        fileRefs.push(ref);\n  82→      }\n  83→      return '\\n';\n  84→    }\n  85→  );\n  86→\n  87→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  88→    const ref = sanitizeMarkerPath(rawRef);\n  89→    if (ref) {\n  90→      fileRefs.push(ref);\n  91→    }\n  92→    return '';\n  93→  });\n  94→\n  95→  const withBacktickPathRemoved = withImageRemoved.replace(\n  96→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n  97→    (_full, rawRef) => {\n  98→      const ref = sanitizeMarkerPath(rawRef);\n  99→      if (ref) {\n 100→        fileRefs.push(ref);\n 101→      }\n 102→      return '';\n 103→    }\n 104→  );\n 105→\n 106→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 107→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 108→    (_full, rawRef) => {\n 109→      const ref = sanitizeMarkerPath(rawRef);\n 110→      if (ref) {\n 111→        fileRefs.push(ref);\n 112→      }\n 113→      return '';\n 114→    }\n 115→  );\n 116→\n 117→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 118→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 119→    (_full, rawRef) => {\n 120→      const ref = sanitizeMarkerPath(rawRef);\n 121→      if (ref) {\n 122→        fileRefs.push(ref);\n 123→      }\n 124→      return '\\n';\n 125→    }\n 126→  );\n 127→\n 128→  return {\n 129→    fileRefs: [...new Set(fileRefs)],\n 130→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 131→  };\n 132→}\n 133→\n 134→function isPathWithinRoot(targetPath, rootPath) {\n 135→  const relative = path.relative(rootPath, targetPath);\n 136→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 137→}\n 138→\n 139→function isAllowedFilePath(filePath) {\n 140→  const resolved = path.resolve(filePath);\n 141→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 142→}\n 143→\n 144→function buildFileCandidates(normalizedPath) {\n 145→  if (path.isAbsolute(normalizedPath)) {\n 146→    return [normalizedPath];\n 147→  }\n 148→\n 149→  const baseName = path.basename(normalizedPath);\n 150→  const candidates = [\n 151→    path.resolve(process.cwd(), normalizedPath),\n 152→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 153→  ];\n 154→\n 155→  return [...new Set(candidates)];\n 156→}\n 157→\n 158→async function resolveLocalFilePath(fileRef) {\n 159→  const normalized = sanitizeMarkerPath(fileRef);\n 160→  if (!normalized) {\n 161→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 162→  }\n 163→\n 164→  if (!path.isAbsolute(normalized)) {\n 165→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 166→  }\n 167→\n 168→  const candidates = buildFileCandidates(normalized);\n 169→\n 170→  for (const candidate of candidates) {\n 171→    try {\n 172→      await access(candidate);\n 173→      return { filePath: candidate, triedPaths: candidates };\n 174→    } catch {\n 175→      // ignore\n 176→    }\n 177→  }\n 178→\n 179→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 180→}\n 181→\n 182→async function validateFileForTelegram(filePath) {\n 183→  const resolvedPath = path.resolve(filePath);\n 184→  if (!isAllowedFilePath(resolvedPath)) {\n 185→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 186→  }\n 187→\n 188→  const ext = path.extname(resolvedPath).toLowerCase();\n 189→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 190→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 191→  }\n 192→\n 193→  const fileStat = await stat(resolvedPath);\n 194→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 195→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 196→\n 197→  if (fileStat.size > maxSize) {\n 198→    return {\n 199→      ok: false,\n 200→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 201→    };\n 202→  }\n 203→\n 204→  return { ok: true, isPhoto, resolvedPath };\n 205→}\n 206→\n 207→function isTimeoutLikeError(message = '') {\n 208→  const normalized = String(message).toLowerCase();\n 209→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 210→}\n 211→\n 212→function sleep(ms) {\n 213→  return new Promise((resolve) => setTimeout(resolve, ms));\n 214→}\n 215→\n 216→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 217→  if (isPhoto) {\n 218→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 219→    return;\n 220→  }\n 221→\n 222→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 223→}\n 224→\n 225→async function replyFiles(ctx, fileRefs = []) {\n 226→  const results = [];\n 227→\n 228→  for (const fileRef of fileRefs) {\n 229→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 230→    if (!filePath) {\n 231→      const reason = rejectReason || 'not_found';\n 232→      results.push({ fileRef, sent: false, reason, triedPaths });\n 233→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 234→      continue;\n 235→    }\n 236→\n 237→    try {\n 238→      const validation = await validateFileForTelegram(filePath);\n 239→      if (!validation.ok) {\n 240→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 241→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 242→        continue;\n 243→      }\n 244→\n 245→      const actualPath = validation.resolvedPath;\n 246→      let sent = false;\n 247→      let lastReason = '';\n 248→\n 249→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 250→        try {\n 251→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 252→          sent = true;\n 253→          logger.info(\n 254→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 255→            'Telegram file sent'\n 256→          );\n 257→          break;\n 258→        } catch (error) {\n 259→          lastReason = error instanceof Error ? error.message : String(error);\n 260→          logger.warn(\n 261→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 262→            'Telegram file send attempt failed'\n 263→          );\n 264→\n 265→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 266→            await sleep(600);\n 267→            continue;\n 268→          }\n 269→\n 270→          break;\n 271→        }\n 272→      }\n 273→\n 274→      if (!sent) {\n 275→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 276→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 277→        continue;\n 278→      }\n 279→\n 280→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 281→    } catch (error) {\n 282→      const reason = error instanceof Error ? error.message : String(error);\n 283→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 284→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 285→    }\n 286→  }\n 287→\n 288→  return results;\n 289→}\n 290→\n 291→async function safeReply(ctx, text) {\n 292→  try {\n 293→    await ctx.reply(text);\n 294→    return true;\n 295→  } catch (error) {\n 296→    const reason = error instanceof Error ? error.message : String(error);\n 297→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 298→    return false;\n 299→  }\n 300→}\n 301→\n 302→async function replyLargeText(ctx, text) {\n 303→  const chunks = splitMessage(text);\n 304→  for (const chunk of chunks) {\n 305→    const ok = await safeReply(ctx, chunk);\n 306→    if (!ok) {\n 307→      break;\n 308→    }\n 309→  }\n 310→}\n 311→\n 312→async function safeEditMessageText(ctx, messageId, text) {\n 313→  const nextText = text && text.trim() ? text : ' ';\n 314→\n 315→  try {\n 316→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 317→  } catch (error) {\n 318→    const message = error instanceof Error ? error.message : String(error);\n 319→    if (message.includes('message is not modified')) {\n 320→      return;\n 321→    }\n 322→    throw error;\n 323→  }\n 324→}\n 325→\n 326→function createEditableStreamPublisher(ctx) {\n 327→  let fullText = '';\n 328→  let renderedText = '';\n 329→  let pendingChars = 0;\n 330→  let lastFlushAt = 0;\n 331→  let flushChain = Promise.resolve();\n 332→  let activeMessage = null;\n 333→  let activeSegmentIndex = 0;\n 334→  let publishedMessageCount = 0;\n 335→\n 336→  async function ensureActiveMessage() {\n 337→    if (activeMessage) {\n 338→      return;\n 339→    }\n 340→    activeMessage = await ctx.reply('处理中...');\n 341→    activeSegmentIndex = 0;\n 342→    publishedMessageCount += 1;\n 343→  }\n 344→\n 345→  async function render(force = false) {\n 346→    const now = Date.now();\n 347→\n 348→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 349→      return;\n 350→    }\n 351→\n 352→    if (fullText === renderedText) {\n 353→      pendingChars = 0;\n 354→      return;\n 355→    }\n 356→\n 357→    await ensureActiveMessage();\n 358→\n 359→    const segments = splitMessage(fullText);\n 360→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 361→\n 362→    while (activeSegmentIndex < targetLastIndex) {\n 363→      const text = segments[activeSegmentIndex] ?? ' ';\n 364→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 365→\n 366→      activeMessage = await ctx.reply('继续输出中...');\n 367→      activeSegmentIndex += 1;\n 368→      publishedMessageCount += 1;\n 369→    }\n 370→\n 371→    const activeText = segments[targetLastIndex] ?? ' ';\n 372→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 373→\n 374→    renderedText = fullText;\n 375→    pendingChars = 0;\n 376→    lastFlushAt = now;\n 377→  }\n 378→\n 379→  function enqueueRender(force = false) {\n 380→    flushChain = flushChain.then(() => render(force));\n 381→  }\n 382→\n 383→  return {\n 384→    push(text) {\n 385→      const appendText = text ?? '';\n 386→      if (!appendText) {\n 387→        return;\n 388→      }\n 389→      fullText += appendText;\n 390→      pendingChars += appendText.length;\n 391→      enqueueRender(false);\n 392→    },\n 393→    setFinalText(text) {\n 394→      fullText = text ?? '';\n 395→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 396→      enqueueRender(true);\n 397→    },\n 398→    async finish() {\n 399→      enqueueRender(true);\n 400→      await flushChain;\n 401→      return {\n 402→        outputLength: renderedText.length,\n 403→        messageCount: publishedMessageCount\n 404→      };\n 405→    }\n 406→  };\n 407→}\n 408→\n 409→function buildSessionId(ctx) {\n 410→  return String(ctx.chat.id);\n 411→}\n 412→\n 413→function ensureAllowed(ctx) {\n 414→  const userId = ctx.from?.id;\n 415→  if (!isAllowedUser(userId)) {\n 416→    throw new Error('当前账号未被授权使用该机器人。');\n 417→  }\n 418→}\n 419→\n 420→/**\n 421→ * Register all pipeline-related commands.\n 422→ */\n 423→function registerPipelineCommands() {\n 424→  registerCommand(pipelineMeta, handlePipeline);\n 425→  registerCommand(bugfixMeta, handleBugfix);\n 426→  registerCommand(plannerMeta, handlePlanner);\n 427→  registerCommand(statusMeta, handleStatus);\n 428→  registerCommand(logsMeta, handleLogs);\n 429→  registerCommand(stopMeta, handleStop);\n 430→  registerCommand(planMeta, handlePlan);\n 431→}\n 432→\n 433→export function createTelegramBot() {\n 434→  const bot = new Telegraf(config.telegramBotToken, {\n 435→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 436→  });\n 437→\n 438→  // Register pipeline commands\n 439→  registerPipelineCommands();\n 440→\n 441→  bot.catch((error, ctx) => {\n 442→    const message = error instanceof Error ? error.message : String(error);\n 443→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 444→  });\n 445→\n 446→  bot.start(async (ctx) => {\n 447→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 448→  });\n 449→\n 450→  bot.help(async (ctx) => {\n 451→    const helpText = generateHelp();\n 452→    await ctx.reply(helpText);\n 453→  });\n 454→\n 455→  bot.command('reset', async (ctx) => {\n 456→    try {\n 457→      ensureAllowed(ctx);\n 458→      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 459→      await ctx.reply('已清空当前会话上下文。');\n 460→    } catch (error) {\n 461→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 462→    }\n 463→  });\n 464→\n 465→  bot.command('screenshot', async (ctx) => {\n 466→    try {\n 467→      ensureAllowed(ctx);\n 468→      await ctx.reply('正在获取截图。');\n 469→      const { buffer } = await captureScreenshot();\n 470→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 471→    } catch (error) {\n 472→      const message = error instanceof Error ? error.message : String(error);\n 473→      logger.error({ err: message }, 'Failed to