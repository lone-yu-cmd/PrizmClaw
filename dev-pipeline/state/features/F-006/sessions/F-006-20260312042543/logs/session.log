{"type":"user","uuid":"01dae4ce-209b-4137-9794-60102ab85a88","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"call_c5b9cd78e1084559bf9e69c6","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for permission-guard.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import {\n   9→  getUserRole,\n  10→  checkCommandPermission,\n  11→  isAdmin,\n  12→  ROLE_HIERARCHY,\n  13→  setConfigForTesting,\n  14→  resetConfig\n  15→} from '../../src/security/permission-guard.js';\n  16→\n  17→// Helper to create test config\n  18→function createTestConfig(overrides = {}) {\n  19→  return {\n  20→    userPermissions: new Map(),\n  21→    allowAdminSkipConfirm: true,\n  22→    enableSystemExec: false,\n  23→    allowedUserIds: new Set(),\n  24→    ...overrides\n  25→  };\n  26→}\n  27→\n  28→test.beforeEach(() => {\n  29→  resetConfig();\n  30→});\n  31→\n  32→test.afterEach(() => {\n  33→  resetConfig();\n  34→});\n  35→\n  36→// ROLE_HIERARCHY tests\n  37→test('ROLE_HIERARCHY defines correct hierarchy levels', () => {\n  38→  assert.equal(ROLE_HIERARCHY.viewer, 0);\n  39→  assert.equal(ROLE_HIERARCHY.operator, 1);\n  40→  assert.equal(ROLE_HIERARCHY.admin, 2);\n  41→});\n  42→\n  43→// getUserRole tests\n  44→test('getUserRole returns admin for configured admin user', () => {\n  45→  const config = createTestConfig();\n  46→  config.userPermissions.set('123456789', 'admin');\n  47→  setConfigForTesting(config);\n  48→\n  49→  assert.equal(getUserRole('123456789'), 'admin');\n  50→});\n  51→\n  52→test('getUserRole returns operator for configured operator user', () => {\n  53→  const config = createTestConfig();\n  54→  config.userPermissions.set('987654321', 'operator');\n  55→  setConfigForTesting(config);\n  56→\n  57→  assert.equal(getUserRole('987654321'), 'operator');\n  58→});\n  59→\n  60→test('getUserRole returns viewer for configured viewer user', () => {\n  61→  const config = createTestConfig();\n  62→  config.userPermissions.set('111222333', 'viewer');\n  63→  setConfigForTesting(config);\n  64→\n  65→  assert.equal(getUserRole('111222333'), 'viewer');\n  66→});\n  67→\n  68→test('getUserRole returns operator as default for unknown users (AC-1.3)', () => {\n  69→  setConfigForTesting(createTestConfig());\n  70→  assert.equal(getUserRole('unknown-user'), 'operator');\n  71→});\n  72→\n  73→test('getUserRole handles numeric userId', () => {\n  74→  const config = createTestConfig();\n  75→  config.userPermissions.set('123456789', 'admin');\n  76→  setConfigForTesting(config);\n  77→\n  78→  assert.equal(getUserRole(123456789), 'admin');\n  79→});\n  80→\n  81→// isAdmin tests\n  82→test('isAdmin returns true for admin user', () => {\n  83→  const config = createTestConfig();\n  84→  config.userPermissions.set('123456789', 'admin');\n  85→  setConfigForTesting(config);\n  86→\n  87→  assert.equal(isAdmin('123456789'), true);\n  88→});\n  89→\n  90→test('isAdmin returns false for operator user', () => {\n  91→  const config = createTestConfig();\n  92→  config.userPermissions.set('987654321', 'operator');\n  93→  setConfigForTesting(config);\n  94→\n  95→  assert.equal(isAdmin('987654321'), false);\n  96→});\n  97→\n  98→test('isAdmin returns false for viewer user', () => {\n  99→  const config = createTestConfig();\n 100→  config.userPermissions.set('111222333', 'viewer');\n 101→  setConfigForTesting(config);\n 102→\n 103→  assert.equal(isAdmin('111222333'), false);\n 104→});\n 105→\n 106→test('isAdmin returns false for unknown user (default is operator)', () => {\n 107→  setConfigForTesting(createTestConfig());\n 108→  assert.equal(isAdmin('unknown-user'), false);\n 109→});\n 110→\n 111→// checkCommandPermission - status command (viewer)\n 112→test('checkCommandPermission allows viewer to execute status', () => {\n 113→  const config = createTestConfig();\n 114→  config.userPermissions.set('viewer-user', 'viewer');\n 115→  setConfigForTesting(config);\n 116→\n 117→  const result = checkCommandPermission('viewer-user', 'status');\n 118→  assert.equal(result.allowed, true);\n 119→  assert.equal(result.requiresConfirmation, false);\n 120→});\n 121→\n 122→// checkCommandPermission - logs command (viewer)\n 123→test('checkCommandPermission allows viewer to execute logs', () => {\n 124→  const config = createTestConfig();\n 125→  config.userPermissions.set('viewer-user', 'viewer');\n 126→  setConfigForTesting(config);\n 127→\n 128→  const result = checkCommandPermission('viewer-user', 'logs');\n 129→  assert.equal(result.allowed, true);\n 130→  assert.equal(result.requiresConfirmation, false);\n 131→});\n 132→\n 133→// checkCommandPermission - pipeline command (operator)\n 134→test('checkCommandPermission allows operator to execute pipeline', () => {\n 135→  const config = createTestConfig();\n 136→  config.userPermissions.set('op-user', 'operator');\n 137→  setConfigForTesting(config);\n 138→\n 139→  const result = checkCommandPermission('op-user', 'pipeline');\n 140→  assert.equal(result.allowed, true);\n 141→});\n 142→\n 143→test('checkCommandPermission denies viewer for pipeline', () => {\n 144→  const config = createTestConfig();\n 145→  config.userPermissions.set('viewer-user', 'viewer');\n 146→  setConfigForTesting(config);\n 147→\n 148→  const result = checkCommandPermission('viewer-user', 'pipeline');\n 149→  assert.equal(result.allowed, false);\n 150→  assert.ok(result.reason.includes('权限不足'));\n 151→});\n 152→\n 153→// checkCommandPermission - retry command (operator) - AC-2.3\n 154→test('checkCommandPermission allows operator for retry without confirmation', () => {\n 155→  const config = createTestConfig();\n 156→  config.userPermissions.set('op-user', 'operator');\n 157→  setConfigForTesting(config);\n 158→\n 159→  const result = checkCommandPermission('op-user', 'retry');\n 160→  assert.equal(result.allowed, true);\n 161→  assert.equal(result.requiresConfirmation, false);\n 162→});\n 163→\n 164→test('checkCommandPermission denies viewer for retry', () => {\n 165→  const config = createTestConfig();\n 166→  config.userPermissions.set('viewer-user', 'viewer');\n 167→  setConfigForTesting(config);\n 168→\n 169→  const result = checkCommandPermission('viewer-user', 'retry');\n 170→  assert.equal(result.allowed, false);\n 171→});\n 172→\n 173→// checkCommandPermission - stop command (admin) - AC-2.2\n 174→test('checkCommandPermission allows admin for stop with confirmation', () => {\n 175→  const config = createTestConfig();\n 176→  config.userPermissions.set('admin-user', 'admin');\n 177→  setConfigForTesting(config);\n 178→\n 179→  const result = checkCommandPermission('admin-user', 'stop');\n 180→  assert.equal(result.allowed, true);\n 181→  assert.equal(result.requiresConfirmation, true);\n 182→});\n 183→\n 184→test('checkCommandPermission denies operator for stop', () => {\n 185→  const config = createTestConfig();\n 186→  config.userPermissions.set('op-user', 'operator');\n 187→  setConfigForTesting(config);\n 188→\n 189→  const result = checkCommandPermission('op-user', 'stop');\n 190→  assert.equal(result.allowed, false);\n 191→  assert.ok(result.reason.includes('权限不足'));\n 192→});\n 193→\n 194→test('checkCommandPermission denies viewer for stop', () => {\n 195→  const config = createTestConfig();\n 196→  config.userPermissions.set('viewer-user', 'viewer');\n 197→  setConfigForTesting(config);\n 198→\n 199→  const result = checkCommandPermission('viewer-user', 'stop');\n 200→  assert.equal(result.allowed, false);\n 201→});\n 202→\n 203→// checkCommandPermission - reset command (admin) - AC-2.2\n 204→test('checkCommandPermission allows admin for reset with confirmation', () => {\n 205→  const config = createTestConfig();\n 206→  config.userPermissions.set('admin-user', 'admin');\n 207→  setConfigForTesting(config);\n 208→\n 209→  const result = checkCommandPermission('admin-user', 'reset');\n 210→  assert.equal(result.allowed, true);\n 211→  assert.equal(result.requiresConfirmation, true);\n 212→});\n 213→\n 214→test('checkCommandPermission denies operator for reset', () => {\n 215→  const config = createTestConfig();\n 216→  config.userPermissions.set('op-user', 'operator');\n 217→  setConfigForTesting(config);\n 218→\n 219→  const result = checkCommandPermission('op-user', 'reset');\n 220→  assert.equal(result.allowed, false);\n 221→});\n 222→\n 223→// checkCommandPermission - force-unlock command (admin) - F-001\n 224→test('checkCommandPermission requires admin for force-unlock', () => {\n 225→  const config = createTestConfig();\n 226→  config.userPermissions.set('admin-user', 'admin');\n 227→  setConfigForTesting(config);\n 228→\n 229→  const result = checkCommandPermission('admin-user', 'force-unlock');\n 230→  assert.equal(result.allowed, true);\n 231→  assert.equal(result.requiresConfirmation, true);\n 232→});\n 233→\n 234→test('checkCommandPermission denies operator for force-unlock', () => {\n 235→  const config = createTestConfig();\n 236→  config.userPermissions.set('op-user', 'operator');\n 237→  setConfigForTesting(config);\n 238→\n 239→  const result = checkCommandPermission('op-user', 'force-unlock');\n 240→  assert.equal(result.allowed, false);\n 241→  assert.ok(result.reason.includes('权限不足'));\n 242→});\n 243→\n 244→// checkCommandPermission - exec command (admin + ENABLE_SYSTEM_EXEC) - AC-2.4, F-002\n 245→test('checkCommandPermission denies exec when ENABLE_SYSTEM_EXEC is false', () => {\n 246→  const config = createTestConfig({ enableSystemExec: false });\n 247→  config.userPermissions.set('admin-user', 'admin');\n 248→  setConfigForTesting(config);\n 249→\n 250→  const result = checkCommandPermission('admin-user', 'exec');\n 251→  assert.equal(result.allowed, false);\n 252→  assert.ok(result.reason.includes('系统命令执行未启用'));\n 253→});\n 254→\n 255→test('checkCommandPermission allows admin for exec when ENABLE_SYSTEM_EXEC is true', () => {\n 256→  const config = createTestConfig({ enableSystemExec: true });\n 257→  config.userPermissions.set('admin-user', 'admin');\n 258→  setConfigForTesting(config);\n 259→\n 260→  const result = checkCommandPermission('admin-user', 'exec');\n 261→  assert.equal(result.allowed, true);\n 262→  assert.equal(result.requiresConfirmation, false);\n 263→});\n 264→\n 265→test('checkCommandPermission denies operator for exec even when ENABLE_SYSTEM_EXEC is true', () => {\n 266→  const config = createTestConfig({ enableSystemExec: true });\n 267→  config.userPermissions.set('op-user', 'operator');\n 268→  setConfigForTesting(config);\n 269→\n 270→  const result = checkCommandPermission('op-user', 'exec');\n 271→  assert.equal(result.allowed, false);\n 272→});\n 273→\n 274→// checkCommandPermission - unknown command\n 275→test('checkCommandPermission allows unknown command by default (defensive but permissive)', () => {\n 276→  const config = createTestConfig();\n 277→  config.userPermissions.set('op-user', 'operator');\n 278→  setConfigForTesting(config);\n 279→\n 280→  const result = checkCommandPermission('op-user', 'unknown-command');\n 281→  assert.equal(result.allowed, true);\n 282→  assert.equal(result.requiresConfirmation, false);\n 283→});\n 284→\n 285→// error message security - AC-2.5\n 286→test('checkCommandPermission does not expose internal paths in error messages', () => {\n 287→  const config = createTestConfig();\n 288→  config.userPermissions.set('viewer-user', 'viewer');\n 289→  setConfigForTesting(config);\n 290→\n 291→  const result = checkCommandPermission('viewer-user', 'stop');\n 292→  assert.ok(!result.reason.includes('/var/'));\n 293→  assert.ok(!result.reason.includes('/home/'));\n 294→  assert.ok(!result.reason.includes('config'));\n 295→});\n 296→\n 297→test('checkCommandPermission provides unified denial message', () => {\n 298→  const config = createTestConfig();\n 299→  config.userPermissions.set('viewer-user', 'viewer');\n 300→  setConfigForTesting(config);\n 301→\n 302→  const result = checkCommandPermission('viewer-user', 'stop');\n 303→  assert.ok(result.reason.match(/权限不足|未授权/));\n 304→});\n 305→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0d027c03943d4ecf95a6fbf8","__timestamp":"2026-03-11T20:49:37.783Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"514eddeb-100c-4369-97f9-afcdaa465276","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"call_9afb0766ac1641c48e8a5ece","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for param-sanitizer.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n   9→\n  10→// detectDangerousPatterns tests\n  11→test('detectDangerousPatterns detects path traversal (..)', () => {\n  12→  const result = detectDangerousPatterns('../../../etc/passwd');\n  13→  assert.equal(result.safe, false);\n  14→  assert.ok(result.patterns.some((p) => p.includes('path traversal')));\n  15→});\n  16→\n  17→test('detectDangerousPatterns detects shell injection ($)', () => {\n  18→  const result = detectDangerousPatterns('$(whoami)');\n  19→  assert.equal(result.safe, false);\n  20→  assert.ok(result.patterns.length > 0);\n  21→});\n  22→\n  23→test('detectDangerousPatterns detects backticks', () => {\n  24→  const result = detectDangerousPatterns('`id`');\n  25→  assert.equal(result.safe, false);\n  26→});\n  27→\n  28→test('detectDangerousPatterns detects command separator (;)', () => {\n  29→  const result = detectDangerousPatterns('ls; rm -rf /');\n  30→  assert.equal(result.safe, false);\n  31→});\n  32→\n  33→test('detectDangerousPatterns detects command chain (||)', () => {\n  34→  const result = detectDangerousPatterns('test || cat /etc/passwd');\n  35→  assert.equal(result.safe, false);\n  36→});\n  37→\n  38→test('detectDangerousPatterns detects command chain (&&)', () => {\n  39→  const result = detectDangerousPatterns('test && cat /etc/passwd');\n  40→  assert.equal(result.safe, false);\n  41→});\n  42→\n  43→test('detectDangerousPatterns detects home directory (~)', () => {\n  44→  const result = detectDangerousPatterns('~/secret.txt');\n  45→  assert.equal(result.safe, false);\n  46→});\n  47→\n  48→test('detectDangerousPatterns detects --exec flag', () => {\n  49→  const result = detectDangerousPatterns('test --exec');\n  50→  assert.equal(result.safe, false);\n  51→});\n  52→\n  53→test('detectDangerousPatterns detects --eval flag', () => {\n  54→  const result = detectDangerousPatterns('test --eval');\n  55→  assert.equal(result.safe, false);\n  56→});\n  57→\n  58→test('detectDangerousPatterns returns safe for clean input', () => {\n  59→  const result = detectDangerousPatterns('my-feature-branch');\n  60→  assert.equal(result.safe, true);\n  61→  assert.deepEqual(result.patterns, []);\n  62→});\n  63→\n  64→// sanitizeParam tests\n  65→test('sanitizeParam accepts valid string', () => {\n  66→  const result = sanitizeParam('valid-input', { maxLength: 200 });\n  67→  assert.equal(result.ok, true);\n  68→  assert.equal(result.value, 'valid-input');\n  69→});\n  70→\n  71→test('sanitizeParam trims whitespace', () => {\n  72→  const result = sanitizeParam('  trimmed  ', { maxLength: 200 });\n  73→  assert.equal(result.ok, true);\n  74→  assert.equal(result.value, 'trimmed');\n  75→});\n  76→\n  77→test('sanitizeParam rejects empty input', () => {\n  78→  const result = sanitizeParam('', { maxLength: 200 });\n  79→  assert.equal(result.ok, false);\n  80→  assert.ok(result.error);\n  81→});\n  82→\n  83→test('sanitizeParam rejects whitespace-only input', () => {\n  84→  const result = sanitizeParam('   ', { maxLength: 200 });\n  85→  assert.equal(result.ok, false);\n  86→});\n  87→\n  88→test('sanitizeParam enforces max length', () => {\n  89→  const longInput = 'a'.repeat(300);\n  90→  const result = sanitizeParam(longInput, { maxLength: 200 });\n  91→  assert.equal(result.ok, false);\n  92→  assert.ok(result.error.includes('过长'));\n  93→});\n  94→\n  95→test('sanitizeParam uses default max length of 200', () => {\n  96→  const longInput = 'a'.repeat(250);\n  97→  const result = sanitizeParam(longInput);\n  98→  assert.equal(result.ok, false);\n  99→});\n 100→\n 101→test('sanitizeParam rejects dangerous patterns', () => {\n 102→  const result = sanitizeParam('../../../etc/passwd');\n 103→  assert.equal(result.ok, false);\n 104→  assert.ok(result.error);\n 105→});\n 106→\n 107→test('sanitizeParam handles null input', () => {\n 108→  const result = sanitizeParam(null);\n 109→  assert.equal(result.ok, false);\n 110→});\n 111→\n 112→test('sanitizeParam handles undefined input', () => {\n 113→  const result = sanitizeParam(undefined);\n 114→  assert.equal(result.ok, false);\n 115→});\n 116→\n 117→test('sanitizeParam accepts targetId format [A-Za-z0-9_-]+', () => {\n 118→  const result = sanitizeParam('my-feature_123', { maxLength: 100 });\n 119→  assert.equal(result.ok, true);\n 120→  assert.equal(result.value, 'my-feature_123');\n 121→});\n 122→\n 123→// validatePath tests\n 124→test('validatePath accepts path within allowed roots', () => {\n 125→  const result = validatePath('/project/src/file.js', ['/project', '/home']);\n 126→  assert.equal(result.ok, true);\n 127→  assert.ok(result.resolved);\n 128→});\n 129→\n 130→test('validatePath rejects path outside allowed roots', () => {\n 131→  const result = validatePath('/etc/passwd', ['/project', '/home']);\n 132→  assert.equal(result.ok, false);\n 133→  assert.ok(result.error);\n 134→});\n 135→\n 136→test('validatePath rejects path traversal', () => {\n 137→  const result = validatePath('/project/../../../etc/passwd', ['/project']);\n 138→  assert.equal(result.ok, false);\n 139→});\n 140→\n 141→test('validatePath rejects relative path', () => {\n 142→  const result = validatePath('relative/path', ['/project']);\n 143→  assert.equal(result.ok, false);\n 144→});\n 145→\n 146→test('validatePath handles empty path', () => {\n 147→  const result = validatePath('', ['/project']);\n 148→  assert.equal(result.ok, false);\n 149→});\n 150→\n 151→test('validatePath handles null path', () => {\n 152→  const result = validatePath(null, ['/project']);\n 153→  assert.equal(result.ok, false);\n 154→});\n 155→\n 156→// AC-3.1: Path traversal should be rejected\n 157→test('validatePath rejects path traversal with ..', () => {\n 158→  const result = validatePath('/project/./src/../test.js', ['/project']);\n 159→  // Should reject paths containing .. per AC-3.1\n 160→  assert.equal(result.ok, false);\n 161→  assert.ok(result.error.includes('..'));\n 162→});\n 163→\n 164→test('validatePath accepts valid path within root', () => {\n 165→  const result = validatePath('/project/src/test.js', ['/project']);\n 166→  assert.equal(result.ok, true);\n 167→  assert.equal(result.resolved, '/project/src/test.js');\n 168→});\n 169→\n 170→// AC-3.2: targetId parameter only allows [A-Za-z0-9_-]+ format\n 171→test('sanitizeParam with isTargetId rejects invalid characters', () => {\n 172→  const result = sanitizeParam('feature/branch', { isTargetId: true });\n 173→  assert.equal(result.ok, false);\n 174→  assert.ok(result.error.includes('格式无效'));\n 175→});\n 176→\n 177→test('sanitizeParam with isTargetId accepts valid targetId', () => {\n 178→  const result = sanitizeParam('feature-branch_123', { isTargetId: true });\n 179→  assert.equal(result.ok, true);\n 180→  assert.equal(result.value, 'feature-branch_123');\n 181→});\n 182→\n 183→// AC-3.3: reject dangerous characters\n 184→test('sanitizeParam rejects semicolon', () => {\n 185→  const result = sanitizeParam('test;rm -rf');\n 186→  assert.equal(result.ok, false);\n 187→});\n 188→\n 189→test('sanitizeParam rejects pipe', () => {\n 190→  const result = sanitizeParam('test|cat');\n 191→  assert.equal(result.ok, false);\n 192→});\n 193→\n 194→test('sanitizeParam rejects ampersand', () => {\n 195→  const result = sanitizeParam('test&&ls');\n 196→  assert.equal(result.ok, false);\n 197→});\n 198→\n 199→test('sanitizeParam rejects dollar sign', () => {\n 200→  const result = sanitizeParam('$HOME');\n 201→  assert.equal(result.ok, false);\n 202→});\n 203→\n 204→test('sanitizeParam rejects backtick', () => {\n 205→  const result = sanitizeParam('`id`');\n 206→  assert.equal(result.ok, false);\n 207→});\n 208→\n 209→test('sanitizeParam rejects single quote', () => {\n 210→  const result = sanitizeParam(\"test' or '1'='1\");\n 211→  assert.equal(result.ok, false);\n 212→});\n 213→\n 214→test('sanitizeParam rejects double quote', () => {\n 215→  const result = sanitizeParam('test\" or \"1\"=\"1');\n 216→  assert.equal(result.ok, false);\n 217→});\n 218→\n 219→test('sanitizeParam rejects parentheses', () => {\n 220→  const result = sanitizeParam('$(whoami)');\n 221→  assert.equal(result.ok, false);\n 222→});\n 223→\n 224→test('sanitizeParam rejects angle brackets', () => {\n 225→  const result = sanitizeParam('<script>');\n 226→  assert.equal(result.ok, false);\n 227→});\n 228→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0d027c03943d4ecf95a6fbf8","__timestamp":"2026-03-11T20:49:37.784Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"429b2cb8-16d5-4749-8146-c59dfb719954","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"call_09ced61b5f4844b98d4c597c","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for confirmation-manager.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import {\n   9→  createConfirmation,\n  10→  checkConfirmation,\n  11→  confirmAction,\n  12→  cancelConfirmation,\n  13→  clearExpiredConfirmations\n  14→} from '../../src/security/confirmation-manager.js';\n  15→\n  16→// Helper to wait\n  17→const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n  18→\n  19→test.beforeEach(() => {\n  20→  // Clear any existing confirmations\n  21→  clearExpiredConfirmations();\n  22→});\n  23→\n  24→test.afterEach(() => {\n  25→  clearExpiredConfirmations();\n  26→});\n  27→\n  28→// createConfirmation tests\n  29→test('createConfirmation creates a pending confirmation', () => {\n  30→  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  31→\n  32→  assert.ok(result.confirmId);\n  33→  assert.ok(result.message);\n  34→  assert.ok(result.message.includes('stop'));\n  35→});\n  36→\n  37→test('createConfirmation generates unique confirmId', () => {\n  38→  const result1 = createConfirmation('user123', 'stop', { type: 'feature' });\n  39→  const result2 = createConfirmation('user123', 'reset', {});\n  40→\n  41→  assert.notEqual(result1.confirmId, result2.confirmId);\n  42→});\n  43→\n  44→test('createConfirmation uses custom timeout', () => {\n  45→  const result = createConfirmation('user123', 'stop', {}, 5000);\n  46→\n  47→  assert.ok(result.confirmId);\n  48→  // Verify by checking it expires after timeout\n  49→});\n  50→\n  51→test('createConfirmation stores userId correctly', () => {\n  52→  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  53→\n  54→  const check = checkConfirmation(result.confirmId, 'user123');\n  55→  assert.equal(check.status, 'pending');\n  56→});\n  57→\n  58→// checkConfirmation tests\n  59→test('checkConfirmation returns pending for active confirmation', () => {\n  60→  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  61→\n  62→  const result = checkConfirmation(confirmId, 'user123');\n  63→\n  64→  assert.equal(result.status, 'pending');\n  65→  assert.equal(result.action, 'stop');\n  66→  assert.deepEqual(result.params, { type: 'feature' });\n  67→});\n  68→\n  69→test('checkConfirmation returns not_found for unknown confirmId', () => {\n  70→  const result = checkConfirmation('nonexistent-id', 'user123');\n  71→\n  72→  assert.equal(result.status, 'not_found');\n  73→});\n  74→\n  75→test('checkConfirmation returns not_found for wrong userId', () => {\n  76→  const { confirmId } = createConfirmation('user123', 'stop', {});\n  77→\n  78→  const result = checkConfirmation(confirmId, 'different-user');\n  79→\n  80→  assert.equal(result.status, 'not_found');\n  81→});\n  82→\n  83→test('checkConfirmation returns expired after timeout', async () => {\n  84→  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n  85→\n  86→  await wait(150);\n  87→\n  88→  const result = checkConfirmation(confirmId, 'user123');\n  89→\n  90→  assert.equal(result.status, 'expired');\n  91→});\n  92→\n  93→// confirmAction tests\n  94→test('confirmAction confirms pending action', () => {\n  95→  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  96→\n  97→  const result = confirmAction(confirmId, 'user123');\n  98→\n  99→  assert.equal(result.ok, true);\n 100→  assert.equal(result.action, 'stop');\n 101→  assert.deepEqual(result.params, { type: 'feature' });\n 102→});\n 103→\n 104→test('confirmAction fails for wrong userId', () => {\n 105→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 106→\n 107→  const result = confirmAction(confirmId, 'different-user');\n 108→\n 109→  assert.equal(result.ok, false);\n 110→  assert.ok(result.error);\n 111→});\n 112→\n 113→test('confirmAction fails for unknown confirmId', () => {\n 114→  const result = confirmAction('nonexistent-id', 'user123');\n 115→\n 116→  assert.equal(result.ok, false);\n 117→  assert.ok(result.error);\n 118→});\n 119→\n 120→test('confirmAction fails for already confirmed action', () => {\n 121→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 122→\n 123→  confirmAction(confirmId, 'user123');\n 124→  const result = confirmAction(confirmId, 'user123');\n 125→\n 126→  assert.equal(result.ok, false);\n 127→  assert.ok(result.error.includes('已确认') || result.error.includes('not_found'));\n 128→});\n 129→\n 130→test('confirmAction fails for expired action', async () => {\n 131→  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n 132→\n 133→  await wait(150);\n 134→\n 135→  const result = confirmAction(confirmId, 'user123');\n 136→\n 137→  assert.equal(result.ok, false);\n 138→});\n 139→\n 140→// cancelConfirmation tests\n 141→test('cancelConfirmation cancels pending action', () => {\n 142→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 143→\n 144→  cancelConfirmation(confirmId, 'user123');\n 145→\n 146→  const result = checkConfirmation(confirmId, 'user123');\n 147→  assert.equal(result.status, 'not_found');\n 148→});\n 149→\n 150→test('cancelConfirmation does nothing for unknown confirmId', () => {\n 151→  // Should not throw\n 152→  cancelConfirmation('nonexistent-id', 'user123');\n 153→});\n 154→\n 155→test('cancelConfirmation does nothing for wrong userId', () => {\n 156→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 157→\n 158→  cancelConfirmation(confirmId, 'different-user');\n 159→\n 160→  const result = checkConfirmation(confirmId, 'user123');\n 161→  assert.equal(result.status, 'pending');\n 162→});\n 163→\n 164→// clearExpiredConfirmations tests\n 165→test('clearExpiredConfirmations removes expired confirmations', async () => {\n 166→  createConfirmation('user123', 'stop', {}, 100);\n 167→  createConfirmation('user456', 'reset', {}, 10000);\n 168→\n 169→  await wait(150);\n 170→\n 171→  clearExpiredConfirmations();\n 172→\n 173→  // The expired one should be gone, the active one should remain\n 174→  const check1 = checkConfirmation(\n 175→    // We can't check the specific one, but clearExpiredConfirmations should clean up\n 176→    'any-id',\n 177→    'user123'\n 178→  );\n 179→  assert.equal(check1.status, 'not_found');\n 180→});\n 181→\n 182→// Integration test: full confirmation flow\n 183→test('full confirmation flow: create, check, confirm', () => {\n 184→  // Create\n 185→  const { confirmId, message } = createConfirmation('user123', 'stop', { type: 'feature' });\n 186→\n 187→  assert.ok(confirmId);\n 188→  assert.ok(message);\n 189→\n 190→  // Check\n 191→  const check1 = checkConfirmation(confirmId, 'user123');\n 192→  assert.equal(check1.status, 'pending');\n 193→\n 194→  // Confirm\n 195→  const confirm = confirmAction(confirmId, 'user123');\n 196→  assert.equal(confirm.ok, true);\n 197→\n 198→  // Verify confirmed\n 199→  const check2 = checkConfirmation(confirmId, 'user123');\n 200→  assert.equal(check2.status, 'not_found'); // Consumed\n 201→});\n 202→\n 203→test('full confirmation flow: create, check, cancel', () => {\n 204→  // Create\n 205→  const { confirmId } = createConfirmation('user123', 'reset', {});\n 206→\n 207→  // Check\n 208→  const check1 = checkConfirmation(confirmId, 'user123');\n 209→  assert.equal(check1.status, 'pending');\n 210→\n 211→  // Cancel\n 212→  cancelConfirmation(confirmId, 'user123');\n 213→\n 214→  // Verify cancelled\n 215→  const check2 = checkConfirmation(confirmId, 'user123');\n 216→  assert.equal(check2.status, 'not_found');\n 217→});\n 218→\n 219→// AC-4.3: 60 second timeout default\n 220→test('default timeout is 60 seconds', () => {\n 221→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 222→\n 223→  const check = checkConfirmation(confirmId, 'user123');\n 224→  assert.equal(check.status, 'pending');\n 225→\n 226→  // We can't wait 60s in test, but we can verify it exists initially\n 227→});\n 228→\n 229→// AC-4.4: --force flag handling (in handler, not here)\n 230→// This is tested at the integration level\n 231→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0d027c03943d4ecf95a6fbf8","__timestamp":"2026-03-11T20:49:37.785Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"e8b59f03-eca9-4296-979d-4c2a09d3f921","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"call_eacaf463f1c046be9b1c4e6d","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Test for F-006: Safety and Permission Guard\n   3→ * Tests the full security flow end-to-end.\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdtemp, rm, readFile } from 'node:fs/promises';\n   9→import { join } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→import {\n  12→  checkCommandPermission,\n  13→  getUserRole,\n  14→  isAdmin,\n  15→  setConfigForTesting,\n  16→  resetConfig as resetPermConfig\n  17→} from '../../src/security/permission-guard.js';\n  18→import {\n  19→  createConfirmation,\n  20→  checkConfirmation,\n  21→  confirmAction,\n  22→  cancelConfirmation,\n  23→  clearExpiredConfirmations\n  24→} from '../../src/security/confirmation-manager.js';\n  25→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n  26→import {\n  27→  initAuditLogService,\n  28→  logAuditEntry,\n  29→  queryAuditLogs,\n  30→  resetAuditLogService\n  31→} from '../../src/services/audit-log-service.js';\n  32→\n  33→let tempDir;\n  34→\n  35→// Helper to create test config\n  36→function createTestConfig(overrides = {}) {\n  37→  return {\n  38→    userPermissions: new Map(),\n  39→    allowAdminSkipConfirm: true,\n  40→    enableSystemExec: false,\n  41→    allowedUserIds: new Set(),\n  42→    ...overrides\n  43→  };\n  44→}\n  45→\n  46→test.before(async () => {\n  47→  tempDir = await mkdtemp(join(tmpdir(), 'security-integration-'));\n  48→});\n  49→\n  50→test.after(async () => {\n  51→  if (tempDir) {\n  52→    await rm(tempDir, { recursive: true, force: true });\n  53→  }\n  54→});\n  55→\n  56→test.beforeEach(() => {\n  57→  resetPermConfig();\n  58→  resetAuditLogService();\n  59→  clearExpiredConfirmations();\n  60→});\n  61→\n  62→test.afterEach(() => {\n  63→  resetPermConfig();\n  64→  resetAuditLogService();\n  65→  clearExpiredConfirmations();\n  66→});\n  67→\n  68→// US-1: User Permission Levels\n  69→test('US-1: User permission levels work correctly', async () => {\n  70→  const config = createTestConfig();\n  71→  config.userPermissions.set('admin-user', 'admin');\n  72→  config.userPermissions.set('op-user', 'operator');\n  73→  config.userPermissions.set('viewer-user', 'viewer');\n  74→  setConfigForTesting(config);\n  75→\n  76→  // Test role retrieval\n  77→  assert.equal(getUserRole('admin-user'), 'admin');\n  78→  assert.equal(getUserRole('op-user'), 'operator');\n  79→  assert.equal(getUserRole('viewer-user'), 'viewer');\n  80→  assert.equal(getUserRole('unknown-user'), 'operator'); // Default\n  81→\n  82→  // Test isAdmin\n  83→  assert.equal(isAdmin('admin-user'), true);\n  84→  assert.equal(isAdmin('op-user'), false);\n  85→  assert.equal(isAdmin('viewer-user'), false);\n  86→});\n  87→\n  88→// US-2: High-Risk Command Authorization\n  89→test('US-2: High-risk command authorization works correctly', async () => {\n  90→  const config = createTestConfig();\n  91→  config.userPermissions.set('admin-user', 'admin');\n  92→  config.userPermissions.set('op-user', 'operator');\n  93→  config.userPermissions.set('viewer-user', 'viewer');\n  94→  setConfigForTesting(config);\n  95→\n  96→  // stop command - admin only\n  97→  const adminStopResult = checkCommandPermission('admin-user', 'stop');\n  98→  assert.equal(adminStopResult.allowed, true);\n  99→  assert.equal(adminStopResult.requiresConfirmation, true);\n 100→\n 101→  const opStopResult = checkCommandPermission('op-user', 'stop');\n 102→  assert.equal(opStopResult.allowed, false);\n 103→\n 104→  // retry command - operator level\n 105→  const opRetryResult = checkCommandPermission('op-user', 'retry');\n 106→  assert.equal(opRetryResult.allowed, true);\n 107→  assert.equal(opRetryResult.requiresConfirmation, false);\n 108→\n 109→  const viewerRetryResult = checkCommandPermission('viewer-user', 'retry');\n 110→  assert.equal(viewerRetryResult.allowed, false);\n 111→});\n 112→\n 113→// US-3: Parameter Sanitization\n 114→test('US-3: Parameter sanitization works correctly', async () => {\n 115→  // Valid input passes\n 116→  const validResult = sanitizeParam('my-feature-123', { maxLength: 100 });\n 117→  assert.equal(validResult.ok, true);\n 118→\n 119→  // Dangerous patterns are blocked\n 120→  const traversalResult = sanitizeParam('../../../etc/passwd');\n 121→  assert.equal(traversalResult.ok, false);\n 122→\n 123→  const shellInjectionResult = sanitizeParam('$(whoami)');\n 124→  assert.equal(shellInjectionResult.ok, false);\n 125→\n 126→  // TargetId format validation\n 127→  const validTargetId = sanitizeParam('feature-branch_123', { isTargetId: true });\n 128→  assert.equal(validTargetId.ok, true);\n 129→\n 130→  const invalidTargetId = sanitizeParam('feature/branch', { isTargetId: true });\n 131→  assert.equal(invalidTargetId.ok, false);\n 132→\n 133→  // Path validation\n 134→  const validPath = validatePath('/project/src/file.js', ['/project']);\n 135→  assert.equal(validPath.ok, true);\n 136→\n 137→  const invalidPath = validatePath('/etc/passwd', ['/project']);\n 138→  assert.equal(invalidPath.ok, false);\n 139→});\n 140→\n 141→// US-4: Confirmation Flow\n 142→test('US-4: Confirmation flow works correctly', async () => {\n 143→  // Create confirmation\n 144→  const { confirmId, message } = createConfirmation('test-user', 'stop', { type: 'feature' });\n 145→  assert.ok(confirmId);\n 146→  assert.ok(message);\n 147→\n 148→  // Check pending status\n 149→  const pendingResult = checkConfirmation(confirmId, 'test-user');\n 150→  assert.equal(pendingResult.status, 'pending');\n 151→  assert.equal(pendingResult.action, 'stop');\n 152→\n 153→  // Confirm action\n 154→  const confirmResult = confirmAction(confirmId, 'test-user');\n 155→  assert.equal(confirmResult.ok, true);\n 156→  assert.equal(confirmResult.action, 'stop');\n 157→\n 158→  // Verify consumed\n 159→  const consumedResult = checkConfirmation(confirmId, 'test-user');\n 160→  assert.equal(consumedResult.status, 'not_found');\n 161→});\n 162→\n 163→test('US-4: Confirmation cancel works correctly', () => {\n 164→  const { confirmId } = createConfirmation('test-user', 'reset', {});\n 165→\n 166→  cancelConfirmation(confirmId, 'test-user');\n 167→\n 168→  const result = checkConfirmation(confirmId, 'test-user');\n 169→  assert.equal(result.status, 'not_found');\n 170→});\n 171→\n 172→test('US-4: Wrong user cannot confirm', () => {\n 173→  const { confirmId } = createConfirmation('user-1', 'stop', {});\n 174→\n 175→  const result = confirmAction(confirmId, 'user-2');\n 176→  assert.equal(result.ok, false);\n 177→});\n 178→\n 179→// US-5: Audit Logging\n 180→test('US-5: Audit logging works correctly', async () => {\n 181→  await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 182→\n 183→  // Log entry\n 184→  await logAuditEntry({\n 185→    userId: '123456789',\n 186→    action: 'stop',\n 187→    params: { type: 'feature' },\n 188→    result: 'success'\n 189→  });\n 190→\n 191→  // Query logs\n 192→  const entries = await queryAuditLogs({ userId: '123456789' });\n 193→  assert.ok(entries.length >= 1);\n 194→\n 195→  const entry = entries.find((e) => e.action === 'stop');\n 196→  assert.ok(entry);\n 197→  assert.equal(entry.userId, '123456789');\n 198→  assert.equal(entry.result, 'success');\n 199→});\n 200→\n 201→test('US-5: Audit log query filters work', async () => {\n 202→  await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 203→\n 204→  await logAuditEntry({ userId: 'user-1', action: 'stop', params: {}, result: 'success' });\n 205→  await logAuditEntry({ userId: 'user-1', action: 'reset', params: {}, result: 'success' });\n 206→  await logAuditEntry({ userId: 'user-2', action: 'stop', params: {}, result: 'denied' });\n 207→\n 208→  const user1Entries = await queryAuditLogs({ userId: 'user-1' });\n 209→  assert.ok(user1Entries.every((e) => e.userId === 'user-1'));\n 210→\n 211→  const stopEntries = await queryAuditLogs({ action: 'stop' });\n 212→  assert.ok(stopEntries.every((e) => e.action === 'stop'));\n 213→});\n 214→\n 215→// F-001: force-unlock command\n 216→test('F-001: force-unlock command requires admin and confirmation', async () => {\n 217→  const config = createTestConfig();\n 218→  config.userPermissions.set('admin-user', 'admin');\n 219→  config.userPermissions.set('op-user', 'operator');\n 220→  setConfigForTesting(config);\n 221→\n 222→  const adminResult = checkCommandPermission('admin-user', 'force-unlock');\n 223→  assert.equal(adminResult.allowed, true);\n 224→  assert.equal(adminResult.requiresConfirmation, true);\n 225→\n 226→  const opResult = checkCommandPermission('op-user', 'force-unlock');\n 227→  assert.equal(opResult.allowed, false);\n 228→});\n 229→\n 230→// F-002: exec command with ENABLE_SYSTEM_EXEC\n 231→test('F-002: exec command requires ENABLE_SYSTEM_EXEC', async () => {\n 232→  const config = createTestConfig({ enableSystemExec: false });\n 233→  config.userPermissions.set('admin-user', 'admin');\n 234→  setConfigForTesting(config);\n 235→\n 236→  const disabledResult = checkCommandPermission('admin-user', 'exec');\n 237→  assert.equal(disabledResult.allowed, false);\n 238→  assert.ok(disabledResult.reason.includes('系统命令执行未启用'));\n 239→\n 240→  // Enable system exec\n 241→  config.enableSystemExec = true;\n 242→  setConfigForTesting(config);\n 243→\n 244→  const enabledResult = checkCommandPermission('admin-user', 'exec');\n 245→  assert.equal(enabledResult.allowed, true);\n 246→});\n 247→\n 248→// Full flow test: Operator stop flow (should be denied)\n 249→test('Integration: Operator cannot execute stop command', async () => {\n 250→  const config = createTestConfig();\n 251→  config.userPermissions.set('op-user', 'operator');\n 252→  setConfigForTesting(config);\n 253→\n 254→  const result = checkCommandPermission('op-user', 'stop');\n 255→  assert.equal(result.allowed, false);\n 256→\n 257→  // Log denial\n 258→  await initAuditLogService({ logDir: tempDir });\n 259→  await logAuditEntry({\n 260→    userId: 'op-user',\n 261→    action: 'stop',\n 262→    params: {},\n 263→    result: 'denied',\n 264→    reason: result.reason\n 265→  });\n 266→\n 267→  const entries = await queryAuditLogs({ action: 'stop', userId: 'op-user' });\n 268→  assert.ok(entries.some((e) => e.result === 'denied'));\n 269→});\n 270→\n 271→// Full flow test: Admin stop with confirmation\n 272→test('Integration: Admin stop with confirmation flow', async () => {\n 273→  const config = createTestConfig();\n 274→  config.userPermissions.set('admin-user', 'admin');\n 275→  setConfigForTesting(config);\n 276→\n 277→  // 1. Check permission\n 278→  const permResult = checkCommandPermission('admin-user', 'stop');\n 279→  assert.equal(permResult.allowed, true);\n 280→  assert.equal(permResult.requiresConfirmation, true);\n 281→\n 282→  // 2. Create confirmation\n 283→  const { confirmId } = createConfirmation('admin-user', 'stop', { type: 'feature' });\n 284→\n 285→  // 3. Confirm\n 286→  const confirmResult = confirmAction(confirmId, 'admin-user');\n 287→  assert.equal(confirmResult.ok, true);\n 288→\n 289→  // 4. Log success\n 290→  await initAuditLogService({ logDir: tempDir });\n 291→  await logAuditEntry({\n 292→    userId: 'admin-user',\n 293→    action: 'stop',\n 294→    params: { type: 'feature' },\n 295→    result: 'success'\n 296→  });\n 297→\n 298→  const entries = await queryAuditLogs({ userId: 'admin-user', action: 'stop' });\n 299→  assert.ok(entries.some((e) => e.result === 'success'));\n 300→});\n 301→\n 302→// AC-2.5: Error message security\n 303→test('AC-2.5: Error messages do not expose sensitive info', async () => {\n 304→  const config = createTestConfig();\n 305→  config.userPermissions.set('viewer-user', 'viewer');\n 306→  setConfigForTesting(config);\n 307→\n 308→  const result = checkCommandPermission('viewer-user', 'stop');\n 309→  assert.equal(result.allowed, false);\n 310→  assert.ok(!result.reason.includes('/'));\n 311→  assert.ok(!result.reason.includes('config'));\n 312→  assert.ok(!result.reason.includes('password'));\n 313→});\n 314→\n 315→// NFR-1: Performance\n 316→test('NFR-1: Permission check is fast', () => {\n 317→  const config = createTestConfig();\n 318→  config.userPermissions.set('test-user', 'admin');\n 319→  setConfigForTesting(config);\n 320→\n 321→  const start = Date.now();\n 322→  for (let i = 0; i < 1000; i++) {\n 323→    checkCommandPermission('test-user', 'stop');\n 324→  }\n 325→  const duration = Date.now() - start;\n 326→\n 327→  // 1000 checks should take < 50ms total (< 0.05ms per check, well under 5ms requirement)\n 328→  assert.ok(duration < 50, `Permission check too slow: ${duration}ms for 1000 checks`);\n 329→});\n 330→\n 331→test('NFR-1: Param sanitization is fast', () => {\n 332→  const start = Date.now();\n 333→  for (let i = 0; i < 1000; i++) {\n 334→    sanitizeParam('test-input-with-moderate-length', { maxLength: 100 });\n 335→  }\n 336→  const duration = Date.now() - start;\n 337→\n 338→  // 1000 sanitizations should take < 20ms total (< 0.02ms per check, well under 2ms requirement)\n 339→  assert.ok(duration < 20, `Sanitization too slow: ${duration}ms for 1000 checks`);\n 340→});\n 341→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0d027c03943d4ecf95a6fbf8","__timestamp":"2026-03-11T20:49:37.790Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"b4d12f9d-2922-4015-bd12-113d5638e326","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"call_50e405098e074c1c82b55daf","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  const map = {};\n 215→  for (const [alias, command] of aliasToCommand) {\n 216→    map[alias] = command;\n 217→  }\n 218→  return map;\n 219→}\n 220→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0d027c03943d4ecf95a6fbf8","__timestamp":"2026-03-11T20:49:37.791Z","_requestId":"1836a01aa07b4323b33253678e844458"}
