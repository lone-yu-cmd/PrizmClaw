{"type":"assistant","uuid":"2026031204333887f1f8c7a6a5492e","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"id":"2026031204333887f1f8c7a6a5492e","content":[{"type":"tool_use","id":"019cde9af319c9ecf60618526570ce34","name":"Write","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/security/permission-guard.test.js","content":"/**\n * Tests for permission-guard.js\n * F-006: Safety and Permission Guard\n */\n\nimport { describe, it, expect, beforeEach, vi, afterEach } from 'vitest';\n\n// Mock config before importing permission-guard\nconst mockConfig = {\n  userPermissions: new Map(),\n  allowAdminSkipConfirm: true,\n  enableSystemExec: false,\n  allowedUserIds: new Set()\n};\n\nvi.mock('../../src/config.js', () => ({\n  config: mockConfig\n}));\n\n// Import after mocking\nconst { getUserRole, checkCommandPermission, isAdmin, ROLE_HIERARCHY } = await import(\n  '../../src/security/permission-guard.js'\n);\n\ndescribe('permission-guard', () => {\n  beforeEach(() => {\n    // Reset mock config\n    mockConfig.userPermissions = new Map();\n    mockConfig.allowAdminSkipConfirm = true;\n    mockConfig.enableSystemExec = false;\n    mockConfig.allowedUserIds = new Set();\n  });\n\n  afterEach(() => {\n    vi.clearAllMocks();\n  });\n\n  describe('ROLE_HIERARCHY', () => {\n    it('should define correct hierarchy levels', () => {\n      expect(ROLE_HIERARCHY.viewer).toBe(0);\n      expect(ROLE_HIERARCHY.operator).toBe(1);\n      expect(ROLE_HIERARCHY.admin).toBe(2);\n    });\n  });\n\n  describe('getUserRole', () => {\n    it('should return admin for configured admin user', () => {\n      mockConfig.userPermissions.set('123456789', 'admin');\n      expect(getUserRole('123456789')).toBe('admin');\n    });\n\n    it('should return operator for configured operator user', () => {\n      mockConfig.userPermissions.set('987654321', 'operator');\n      expect(getUserRole('987654321')).toBe('operator');\n    });\n\n    it('should return viewer for configured viewer user', () => {\n      mockConfig.userPermissions.set('111222333', 'viewer');\n      expect(getUserRole('111222333')).toBe('viewer');\n    });\n\n    it('should return operator as default for unknown users (AC-1.3)', () => {\n      expect(getUserRole('unknown-user')).toBe('operator');\n    });\n\n    it('should handle numeric userId', () => {\n      mockConfig.userPermissions.set('123456789', 'admin');\n      expect(getUserRole(123456789)).toBe('admin');\n    });\n  });\n\n  describe('isAdmin', () => {\n    it('should return true for admin user', () => {\n      mockConfig.userPermissions.set('123456789', 'admin');\n      expect(isAdmin('123456789')).toBe(true);\n    });\n\n    it('should return false for operator user', () => {\n      mockConfig.userPermissions.set('987654321', 'operator');\n      expect(isAdmin('987654321')).toBe(false);\n    });\n\n    it('should return false for viewer user', () => {\n      mockConfig.userPermissions.set('111222333', 'viewer');\n      expect(isAdmin('111222333')).toBe(false);\n    });\n\n    it('should return false for unknown user (default is operator)', () => {\n      expect(isAdmin('unknown-user')).toBe(false);\n    });\n  });\n\n  describe('checkCommandPermission', () => {\n    describe('status command (viewer)', () => {\n      it('should allow viewer to execute', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'status');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(false);\n      });\n    });\n\n    describe('logs command (viewer)', () => {\n      it('should allow viewer to execute', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'logs');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(false);\n      });\n    });\n\n    describe('pipeline command (operator)', () => {\n      it('should allow operator to execute', () => {\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'pipeline');\n        expect(result.allowed).toBe(true);\n      });\n\n      it('should deny viewer', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'pipeline');\n        expect(result.allowed).toBe(false);\n        expect(result.reason).toContain('权限不足');\n      });\n    });\n\n    describe('retry command (operator) - AC-2.3', () => {\n      it('should allow operator without confirmation', () => {\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'retry');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(false);\n      });\n\n      it('should deny viewer', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'retry');\n        expect(result.allowed).toBe(false);\n      });\n    });\n\n    describe('stop command (admin) - AC-2.2', () => {\n      it('should allow admin with confirmation', () => {\n        mockConfig.userPermissions.set('admin-user', 'admin');\n        const result = checkCommandPermission('admin-user', 'stop');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(true);\n      });\n\n      it('should allow admin to skip confirmation when configured', () => {\n        mockConfig.userPermissions.set('admin-user', 'admin');\n        mockConfig.allowAdminSkipConfirm = true;\n        // Note: force flag handling is in the handler, not here\n        const result = checkCommandPermission('admin-user', 'stop');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(true);\n      });\n\n      it('should deny operator', () => {\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'stop');\n        expect(result.allowed).toBe(false);\n        expect(result.reason).toContain('权限不足');\n      });\n\n      it('should deny viewer', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'stop');\n        expect(result.allowed).toBe(false);\n      });\n    });\n\n    describe('reset command (admin) - AC-2.2', () => {\n      it('should allow admin with confirmation', () => {\n        mockConfig.userPermissions.set('admin-user', 'admin');\n        const result = checkCommandPermission('admin-user', 'reset');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(true);\n      });\n\n      it('should deny operator', () => {\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'reset');\n        expect(result.allowed).toBe(false);\n      });\n    });\n\n    describe('force-unlock command (admin) - F-001', () => {\n      it('should require admin role', () => {\n        mockConfig.userPermissions.set('admin-user', 'admin');\n        const result = checkCommandPermission('admin-user', 'force-unlock');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(true);\n      });\n\n      it('should deny operator', () => {\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'force-unlock');\n        expect(result.allowed).toBe(false);\n        expect(result.reason).toContain('权限不足');\n      });\n    });\n\n    describe('exec command (admin + ENABLE_SYSTEM_EXEC) - AC-2.4, F-002', () => {\n      it('should deny when ENABLE_SYSTEM_EXEC is false', () => {\n        mockConfig.enableSystemExec = false;\n        mockConfig.userPermissions.set('admin-user', 'admin');\n        const result = checkCommandPermission('admin-user', 'exec');\n        expect(result.allowed).toBe(false);\n        expect(result.reason).toContain('系统命令执行未启用');\n      });\n\n      it('should allow admin when ENABLE_SYSTEM_EXEC is true', () => {\n        mockConfig.enableSystemExec = true;\n        mockConfig.userPermissions.set('admin-user', 'admin');\n        const result = checkCommandPermission('admin-user', 'exec');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(false);\n      });\n\n      it('should deny operator even when ENABLE_SYSTEM_EXEC is true', () => {\n        mockConfig.enableSystemExec = true;\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'exec');\n        expect(result.allowed).toBe(false);\n      });\n    });\n\n    describe('unknown command', () => {\n      it('should allow by default (defensive but permissive)', () => {\n        mockConfig.userPermissions.set('op-user', 'operator');\n        const result = checkCommandPermission('op-user', 'unknown-command');\n        expect(result.allowed).toBe(true);\n        expect(result.requiresConfirmation).toBe(false);\n      });\n    });\n\n    describe('error message security - AC-2.5', () => {\n      it('should not expose internal paths in error messages', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'stop');\n        expect(result.reason).not.toContain('/var/');\n        expect(result.reason).not.toContain('/home/');\n        expect(result.reason).not.toContain('config');\n      });\n\n      it('should provide unified denial message', () => {\n        mockConfig.userPermissions.set('viewer-user', 'viewer');\n        const result = checkCommandPermission('viewer-user', 'stop');\n        expect(result.reason).toMatch(/权限不足|未授权/);\n      });\n    });\n  });\n});\n"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":50853,"output_tokens":2262,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:34:12.477Z","_requestId":"1836a01aa07b4323b33253678e844458"}
