{"type":"user","uuid":"f90e06ef-e92a-46af-85ce-e305eda54dff","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"019cde996de2b002a010fddff4d2814d","content":[{"type":"text","text":"   1→/**\n   2→ * Stop Command Handler\n   3→ * Handles /stop command to stop running pipelines.\n   4→ */\n   5→\n   6→import { stopPipeline } from '../../../services/pipeline-controller.js';\n   7→\n   8→/**\n   9→ * Stop command metadata.\n  10→ */\n  11→export const stopMeta = {\n  12→  name: 'stop',\n  13→  aliases: [],\n  14→  description: '停止运行中的管道',\n  15→  usage: '/stop [target]',\n  16→  examples: ['/stop', '/stop my-feature'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: false,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/stop [target] - 停止运行中的管道'\n  27→};\n  28→\n  29→/**\n  30→ * Handle stop command.\n  31→ * @param {Object} handlerCtx - Handler context\n  32→ */\n  33→export async function handleStop(handlerCtx) {\n  34→  const { params, reply, parsed } = handlerCtx;\n  35→\n  36→  // Get target from positional args or params\n  37→  const target = params._args?.[0] || params.target;\n  38→  const pipelineType = params.type || 'feature';\n  39→\n  40→  try {\n  41→    const result = await stopPipeline({ type: pipelineType });\n  42→\n  43→    if (result.ok) {\n  44→      if (result.errorCode === 'ALREADY_STOPPED') {\n  45→        await reply('⚠️ 没有运行中的管道。');\n  46→      } else {\n  47→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n  48→        await reply(`✅ 已停止管道${pidInfo}。`);\n  49→      }\n  50→    } else {\n  51→      await reply(`❌ 停止失败: ${result.message || '未知错误'}`);\n  52→    }\n  53→  } catch (error) {\n  54→    await reply(`❌ 停止失败: ${error.message}`);\n  55→  }\n  56→}\n  57→\n  58→export default handleStop;\n  59→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:32:04.134Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"user","uuid":"4e422fa2-7f71-4a4e-a5d1-9a355a9c0b84","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"content":[{"type":"tool_result","tool_use_id":"019cde996f78172fecc3c7886c0837fe","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ */\n   5→\n   6→import {\n   7→  startPipeline,\n   8→  stopPipeline,\n   9→  getStatus,\n  10→  getLogs\n  11→} from '../../../services/pipeline-controller.js';\n  12→import { formatValidationErrors, formatError, ErrorCodes } from '../formatter.js';\n  13→\n  14→/**\n  15→ * Pipeline command metadata.\n  16→ */\n  17→export const pipelineMeta = {\n  18→  name: 'pipeline',\n  19→  aliases: ['p'],\n  20→  description: '管理管道任务',\n  21→  usage: '/pipeline <action> [target] [--type=<type>]',\n  22→  examples: [\n  23→    '/pipeline run my-feature',\n  24→    '/pipeline run my-feature --type=bugfix',\n  25→    '/pipeline status',\n  26→    '/pipeline logs my-feature',\n  27→    '/pipeline stop my-feature'\n  28→  ],\n  29→  subcommands: [\n  30→    { name: 'run', description: '启动管道' },\n  31→    { name: 'status', description: '查询状态' },\n  32→    { name: 'logs', description: '查看日志' },\n  33→    { name: 'stop', description: '停止管道' }\n  34→  ],\n  35→  params: [\n  36→    {\n  37→      name: 'target',\n  38→      type: 'string',\n  39→      required: false,\n  40→      description: '目标标识符'\n  41→    },\n  42→    {\n  43→      name: 'type',\n  44→      type: 'enum',\n  45→      enum: ['feature', 'bugfix', 'planner'],\n  46→      required: false,\n  47→      default: 'feature',\n  48→      description: '管道类型'\n  49→    }\n  50→  ],\n  51→  requiresAuth: true,\n  52→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  53→};\n  54→\n  55→/**\n  56→ * Handle pipeline command.\n  57→ * @param {Object} handlerCtx - Handler context\n  58→ * @param {Object} handlerCtx.ctx - Telegraf context\n  59→ * @param {Object} handlerCtx.parsed - Parsed command\n  60→ * @param {Object} handlerCtx.params - Normalized parameters\n  61→ * @param {Function} handlerCtx.reply - Reply function\n  62→ */\n  63→export async function handlePipeline(handlerCtx) {\n  64→  const { ctx, parsed, params, reply } = handlerCtx;\n  65→\n  66→  // Determine action from subcommand or default to status\n  67→  const action = parsed.subcommand || 'status';\n  68→\n  69→  switch (action) {\n  70→    case 'run':\n  71→      return handleRun(handlerCtx);\n  72→    case 'status':\n  73→      return handleStatus(handlerCtx);\n  74→    case 'logs':\n  75→      return handleLogs(handlerCtx);\n  76→    case 'stop':\n  77→      return handleStop(handlerCtx);\n  78→    default:\n  79→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop`);\n  80→  }\n  81→}\n  82→\n  83→/**\n  84→ * Handle run subcommand.\n  85→ */\n  86→async function handleRun({ params, reply, parsed }) {\n  87→  const target = params._args?.[0] || params.target;\n  88→  const pipelineType = params.type || 'feature';\n  89→\n  90→  try {\n  91→    const result = await startPipeline({\n  92→      type: pipelineType,\n  93→      targetId: target,\n  94→      daemon: true\n  95→    });\n  96→\n  97→    if (result.ok) {\n  98→      const pidInfo = result.pid ? ` (PID: ${result.pid})` : '';\n  99→      await reply(`✅ 已启动 ${pipelineType} 管道${target ? `: ${target}` : ''}${pidInfo}`);\n 100→    } else {\n 101→      const errorMsg = result.message || result.stderr || '未知错误';\n 102→      const hint = result.hint ? `\\n💡 提示: ${result.hint}` : '';\n 103→      await reply(`❌ 启动失败: ${errorMsg}${hint}`);\n 104→    }\n 105→  } catch (error) {\n 106→    await reply(`❌ 启动失败: ${error.message}`);\n 107→  }\n 108→}\n 109→\n 110→/**\n 111→ * Handle status subcommand.\n 112→ */\n 113→async function handleStatus({ params, reply }) {\n 114→  const pipelineType = params.type || 'feature';\n 115→\n 116→  try {\n 117→    const result = await getStatus({ type: pipelineType });\n 118→\n 119→    if (result.ok) {\n 120→      const status = formatStatusOutput(result);\n 121→      await reply(status);\n 122→    } else {\n 123→      const errorMsg = result.message || result.stderr || '未知错误';\n 124→      await reply(`❌ 查询失败: ${errorMsg}`);\n 125→    }\n 126→  } catch (error) {\n 127→    await reply(`❌ 查询失败: ${error.message}`);\n 128→  }\n 129→}\n 130→\n 131→/**\n 132→ * Handle logs subcommand.\n 133→ */\n 134→async function handleLogs({ params, reply, replyFile, parsed }) {\n 135→  const target = params._args?.[0] || params.target;\n 136→  const pipelineType = params.type || 'feature';\n 137→\n 138→  try {\n 139→    const result = await getLogs({ type: pipelineType, lines: 100 });\n 140→\n 141→    if (result.ok) {\n 142→      const logs = result.logs || '';\n 143→\n 144→      if (logs.length >= 4000) {\n 145→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n 146→      } else {\n 147→        await reply(logs || '暂无日志');\n 148→      }\n 149→    } else {\n 150→      const errorMsg = result.message || '未知错误';\n 151→      await reply(`❌ 获取日志失败: ${errorMsg}`);\n 152→    }\n 153→  } catch (error) {\n 154→    await reply(`❌ 获取日志失败: ${error.message}`);\n 155→  }\n 156→}\n 157→\n 158→/**\n 159→ * Handle stop subcommand.\n 160→ */\n 161→async function handleStop({ params, reply, parsed }) {\n 162→  const target = params._args?.[0] || params.target;\n 163→  const pipelineType = params.type || 'feature';\n 164→\n 165→  try {\n 166→    const result = await stopPipeline({ type: pipelineType });\n 167→\n 168→    if (result.ok) {\n 169→      if (result.errorCode === 'ALREADY_STOPPED') {\n 170→        await reply(`⚠️ ${pipelineType} 管道未在运行。`);\n 171→      } else {\n 172→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n 173→        await reply(`✅ 已停止 ${pipelineType} 管道${pidInfo}`);\n 174→      }\n 175→    } else {\n 176→      const errorMsg = result.message || '未知错误';\n 177→      await reply(`❌ 停止失败: ${errorMsg}`);\n 178→    }\n 179→  } catch (error) {\n 180→    await reply(`❌ 停止失败: ${error.message}`);\n 181→  }\n 182→}\n 183→\n 184→/**\n 185→ * Format status output.\n 186→ * @param {Object} result - Status result\n 187→ * @returns {string} Formatted status\n 188→ */\n 189→function formatStatusOutput(result) {\n 190→  if (!result.isRunning) {\n 191→    const lastResultInfo = result.lastResult\n 192→      ? `\\n最后一次运行: ${result.lastResult.status} (${result.lastResult.featuresCompleted}/${result.lastResult.featuresTotal})`\n 193→      : '';\n 194→    return `✅ ${result.message}${lastResultInfo}`;\n 195→  }\n 196→\n 197→  const lines = [`🔄 ${result.message}`, ''];\n 198→\n 199→  if (result.pid) {\n 200→    lines.push(`• PID: ${result.pid}`);\n 201→  }\n 202→\n 203→  if (result.currentFeature) {\n 204→    lines.push(`• 当前目标: ${result.currentFeature}`);\n 205→  }\n 206→\n 207→  if (result.startedAt) {\n 208→    lines.push(`• 开始时间: ${result.startedAt}`);\n 209→  }\n 210→\n 211→  if (result.lockInfo) {\n 212→    lines.push(`• 锁持有者 PID: ${result.lockInfo.pid}`);\n 213→  }\n 214→\n 215→  return lines.join('\\n');\n 216→}\n 217→\n 218→export default handlePipeline;\n 219→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:32:04.141Z","_requestId":"1836a01aa07b4323b33253678e844458"}
