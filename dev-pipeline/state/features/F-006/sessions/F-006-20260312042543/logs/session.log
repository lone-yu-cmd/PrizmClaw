enderer":{"type":"todo"}}}],"role":"user"},"parent_tool_use_id":"call_6ed227e88daa4bc7bcc1af8c","__timestamp":"2026-03-11T20:44:39.223Z","_requestId":"1836a01aa07b4323b33253678e844458"}
{"type":"assistant","uuid":"202603120444398e4ede99d593472a","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"id":"202603120444398e4ede99d593472a","content":[{"type":"tool_use","id":"019cdea5002d66d92d64be4e8bb12da3","name":"Write","input":{"content":"/**\n * Audit Command Handler\n * Handles /audit command to query audit logs.\n *\n * F-006: Safety and Permission Guard - US-5: Audit Logging\n * T-108: /audit command for log query\n */\n\nimport { queryAuditLogs, getAuditLogStats } from '../../../services/audit-log-service.js';\nimport { sanitizeParam } from '../../../security/param-sanitizer.js';\n\n/**\n * Audit command metadata.\n * T-102: minRole added (admin only for security)\n */\nexport const auditMeta = {\n  name: 'audit',\n  aliases: [],\n  description: '查询审计日志 (管理员)',\n  usage: '/audit [options]',\n  examples: [\n    '/audit',\n    '/audit --user=123456789',\n    '/audit --action=stop',\n    '/audit --limit=50',\n    '/audit --stats'\n  ],\n  params: [\n    {\n      name: 'user',\n      type: 'string',\n      required: false,\n      description: '按用户 ID 筛选',\n      aliases: ['u']\n    },\n    {\n      name: 'action',\n      type: 'string',\n      required: false,\n      description: '按操作类型筛选',\n      aliases: ['a']\n    },\n    {\n      name: 'limit',\n      type: 'number',\n      required: false,\n      description: '返回条数限制 (最大 100)',\n      default: 20,\n      aliases: ['l']\n    },\n    {\n      name: 'stats',\n      type: 'boolean',\n      required: false,\n      description: '显示审计日志统计',\n      default: false,\n      aliases: ['s']\n    }\n  ],\n  requiresAuth: true,\n  minRole: 'admin',\n  helpText: '/audit [options] - 查询审计日志 (管理员)'\n};\n\n/**\n * Handle audit command.\n * T-108: Admin-only audit log query\n * @param {Object} handlerCtx - Handler context\n */\nexport async function handleAudit(handlerCtx) {\n  const { params, reply, userId, userRole } = handlerCtx;\n\n  // Check if stats mode\n  const showStats = params.stats || params.s || false;\n\n  if (showStats) {\n    return handleStats(handlerCtx);\n  }\n\n  // Parse and sanitize parameters\n  const limit = Math.min(parseInt(params.limit || params.l, 10) || 20, 100);\n  const userFilter = params.user || params.u || null;\n  const actionFilter = params.action || params.a || null;\n\n  // Sanitize filter values\n  if (userFilter) {\n    const userResult = sanitizeParam(userFilter, { maxLength: 50 });\n    if (!userResult.ok) {\n      await reply(`❌ 用户 ID 参数无效: ${userResult.error}`);\n      return;\n    }\n  }\n\n  if (actionFilter) {\n    const actionResult = sanitizeParam(actionFilter, { maxLength: 50 });\n    if (!actionResult.ok) {\n      await reply(`❌ 操作类型参数无效: ${actionResult.error}`);\n      return;\n    }\n  }\n\n  try {\n    // Build query filters\n    const filters = { limit };\n    if (userFilter) filters.userId = userFilter;\n    if (actionFilter) filters.action = actionFilter;\n\n    // Query audit logs\n    const entries = await queryAuditLogs(filters);\n\n    if (entries.length === 0) {\n      await reply('📭 没有找到匹配的审计日志。');\n      return;\n    }\n\n    // Format results\n    const formatted = formatAuditEntries(entries);\n    await reply(formatted);\n\n    // Log this query\n    await logAuditEntry({\n      userId,\n      role: userRole,\n      action: 'audit_query',\n      params: filters,\n      result: 'success'\n    });\n  } catch (error) {\n    await reply(`❌ 查询审计日志失败: ${error.message}`);\n  }\n}\n\n/**\n * Handle stats subcommand.\n */\nasync function handleStats({ reply, userId, userRole }) {\n  try {\n    const stats = await getAuditLogStats();\n\n    const lines = [\n      '📊 审计日志统计',\n      '',\n      `• 总条目数: ${stats.totalEntries}`,\n      `• 文件大小: ${formatBytes(stats.fileSize)}`,\n      `• 最早记录: ${stats.oldestEntry ? formatTimestamp(stats.oldestEntry) : '无'}`\n    ];\n\n    await reply(lines.join('\\n'));\n\n    // Log this query\n    await logAuditEntry({\n      userId,\n      role: userRole,\n      action: 'audit_stats',\n      params: {},\n      result: 'success'\n    });\n  } catch (error) {\n    await reply(`❌ 获取审计日志统计失败: ${error.message}`);\n  }\n}\n\n/**\n * Format audit entries for display.\n * @param {Object[]} entries - Audit log entries\n * @returns {string} Formatted string\n */\nfunction formatAuditEntries(entries) {\n  const lines = [`📋 审计日志 (共 ${entries.length} 条)`, ''];\n\n  for (const entry of entries) {\n    const timestamp = formatTimestamp(new Date(entry.timestamp));\n    const resultIcon = entry.result === 'success' ? '✅' :\n                       entry.result === 'denied' ? '⛔' : '❌';\n\n    lines.push(`${resultIcon} [${timestamp}] ${entry.action}`);\n    lines.push(`   用户: ${entry.userId} (${entry.role || '未知'})`);\n\n    if (entry.params && Object.keys(entry.params).length > 0) {\n      const paramsStr = Object.entries(entry.params)\n        .map(([k, v]) => `${k}=${v}`)\n        .join(', ');\n      lines.push(`   参数: ${paramsStr}`);\n    }\n\n    if (entry.reason) {\n      lines.push(`   原因: ${entry.reason}`);\n    }\n\n    lines.push('');\n  }\n\n  return lines.join('\\n');\n}\n\n/**\n * Format timestamp for display.\n * @param {Date} date - Date object\n * @returns {string} Formatted string\n */\nfunction formatTimestamp(date) {\n  if (!(date instanceof Date)) {\n    date = new Date(date);\n  }\n  return date.toLocaleString('zh-CN', {\n    month: '2-digit',\n    day: '2-digit',\n    hour: '2-digit',\n    minute: '2-digit',\n    second: '2-digit'\n  });\n}\n\n/**\n * Format bytes for display.\n * @param {number} bytes - Bytes\n * @returns {string} Formatted string\n */\nfunction formatBytes(bytes) {\n  if (bytes === 0) return '0 B';\n  const k = 1024;\n  const sizes = ['B', 'KB', 'MB', 'GB'];\n  const i = Math.floor(Math.log(bytes) / Math.log(k));\n  return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];\n}\n\n// Import for audit logging within this module\nimport { logAuditEntry } from '../../../services/audit-log-service.js';\n\nexport default handleAudit;\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/audit.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":80218,"output_tokens":1529,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_6ed227e88daa4bc7bcc1af8c","__timestamp":"2026-03-11T20:45:03.482Z","_requestId":"1836a01aa07b4323b33253678e844458"}
