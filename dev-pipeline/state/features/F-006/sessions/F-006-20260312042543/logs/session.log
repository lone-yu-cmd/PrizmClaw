{"type":"assistant","uuid":"20260312044605ec1d6272c43646e5","session_id":"531490f3-af15-4b63-b1c5-2c677e54409f","message":{"id":"20260312044605ec1d6272c43646e5","content":[{"type":"tool_use","id":"019cdea657a8ba261060369eaf669b61","name":"Write","input":{"content":"/**\n * Security Flow Integration Tests\n * Tests for F-006: Safety and Permission Guard\n *\n * Validates end-to-end security flow including:\n * - Permission tiers (US-1)\n * - High-risk command authorization (US-2)\n * - Parameter sanitization (US-3)\n * - Confirmation flow (US-4)\n * - Audit logging (US-5)\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\n// Import security modules\nimport {\n  getUserRole,\n  checkCommandPermission,\n  isAdmin,\n  setConfigForTesting,\n  resetConfig\n} from '../../src/security/permission-guard.js';\nimport {\n  sanitizeParam,\n  validatePath,\n  detectDangerousPatterns\n} from '../../src/security/param-sanitizer.js';\nimport {\n  createConfirmation,\n  checkConfirmation,\n  confirmAction,\n  cancelConfirmation,\n  clearExpiredConfirmations\n} from '../../src/security/confirmation-manager.js';\nimport {\n  initAuditLogService,\n  logAuditEntry,\n  queryAuditLogs,\n  resetAuditLogService\n} from '../../src/services/audit-log-service.js';\n\n/**\n * Helper to create temp directory for test logs\n */\nfunction createTempLogDir() {\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'security-flow-test-'));\n  return {\n    tempDir,\n    cleanup: () => {\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    }\n  };\n}\n\n/**\n * Helper to create mock config\n */\nfunction createMockConfig(userPermissions = new Map()) {\n  return {\n    userPermissions,\n    allowAdminSkipConfirm: true,\n    enableSystemExec: false,\n    auditLogDir: 'logs',\n    auditLogMaxSizeMb: 10,\n    auditLogMaxFiles: 5\n  };\n}\n\n// ============================================================\n// US-1: User Permission Levels Tests\n// ============================================================\n\ntest('US-1.1: Should support three permission levels', () => {\n  const roles = ['admin', 'operator', 'viewer'];\n  const userPermissions = new Map([\n    ['111', 'admin'],\n    ['222', 'operator'],\n    ['333', 'viewer']\n  ]);\n\n  setConfigForTesting(createMockConfig(userPermissions));\n\n  assert.equal(getUserRole('111'), 'admin');\n  assert.equal(getUserRole('222'), 'operator');\n  assert.equal(getUserRole('333'), 'viewer');\n\n  resetConfig();\n});\n\ntest('US-1.2: Should default to operator for unknown users', () => {\n  setConfigForTesting(createMockConfig(new Map()));\n\n  const role = getUserRole('unknown-user-999');\n  assert.equal(role, 'operator');\n\n  resetConfig();\n});\n\ntest('US-1.3: Should identify admin users correctly', () => {\n  const userPermissions = new Map([['123', 'admin']]);\n  setConfigForTesting(createMockConfig(userPermissions));\n\n  assert.equal(isAdmin('123'), true);\n  assert.equal(isAdmin('456'), false);\n\n  resetConfig();\n});\n\n// ============================================================\n// US-2: High-Risk Command Authorization Tests\n// ============================================================\n\ntest('US-2.1: Should deny high-risk commands for insufficient permissions', () => {\n  const userPermissions = new Map([['222', 'operator']]);\n  setConfigForTesting(createMockConfig(userPermissions));\n\n  // stop requires admin\n  const result = checkCommandPermission('222', 'stop');\n  assert.equal(result.allowed, false);\n  assert.ok(result.reason);\n\n  resetConfig();\n});\n\ntest('US-2.2: Should allow high-risk commands for sufficient permissions', () => {\n  const userPermissions = new Map([['111', 'admin']]);\n  setConfigForTesting(createMockConfig(userPermissions));\n\n  const result = checkCommandPermission('111', 'stop');\n  assert.equal(result.allowed, true);\n  assert.equal(result.requiresConfirmation, true);\n\n  resetConfig();\n});\n\ntest('US-2.3: Should require confirmation for high-risk commands', () => {\n  const userPermissions = new Map([['111', 'admin']]);\n  setConfigForTesting(createMockConfig(userPermissions));\n\n  const highRiskCommands = ['stop', 'reset', 'force-unlock'];\n\n  for (const cmd of highRiskCommands) {\n    const result = checkCommandPermission('111', cmd);\n    assert.equal(result.allowed, true);\n    assert.equal(result.requiresConfirmation, true, `${cmd} should require confirmation`);\n  }\n\n  resetConfig();\n});\n\ntest('US-2.4: Should deny exec when system exec disabled', () => {\n  const userPermissions = new Map([['111', 'admin']]);\n  setConfigForTesting(createMockConfig(userPermissions));\n\n  const result = checkCommandPermission('111', 'exec');\n  assert.equal(result.allowed, false);\n  assert.ok(result.reason.includes('未启用'));\n\n  resetConfig();\n});\n\n// ============================================================\n// US-3: Parameter Sanitization Tests\n// ============================================================\n\ntest('US-3.1: Should block path traversal attempts', () => {\n  const dangerousPaths = [\n    '../../../etc/passwd',\n    '..\\\\..\\\\windows\\\\system32',\n    '/etc/passwd',\n    '~/secret'\n  ];\n\n  for (const input of dangerousPaths) {\n    const result = detectDangerousPatterns(input);\n    assert.equal(result.safe, false, `Should detect danger in: ${input}`);\n  }\n});\n\ntest('US-3.2: Should block shell injection attempts', () => {\n  const dangerousInputs = [\n    'test; rm -rf /',\n    'test && cat /etc/passwd',\n    'test || echo hacked',\n    'test $(whoami)',\n    'test `whoami`'\n  ];\n\n  for (const input of dangerousInputs) {\n    const result = detectDangerousPatterns(input);\n    assert.equal(result.safe, false, `Should detect danger in: ${input}`);\n  }\n});\n\ntest('US-3.3: Should allow safe parameters', () => {\n  const safeInputs = [\n    'my-feature-branch',\n    'F-001',\n    'bugfix-123',\n    'feature_name'\n  ];\n\n  for (const input of safeInputs) {\n    const result = sanitizeParam(input);\n    assert.equal(result.ok, true, `Should allow: ${input}`);\n  }\n});\n\ntest('US-3.4: Should enforce length limits', () => {\n  const longInput = 'a'.repeat(500);\n  const result = sanitizeParam(longInput, { maxLength: 200 });\n\n  assert.equal(result.ok, false);\n  assert.ok(result.error.includes('长度'));\n});\n\n// ============================================================\n// US-4: Confirmation Flow Tests\n// ============================================================\n\ntest('US-4.1: Should create confirmation for high-risk actions', () => {\n  const { confirmId, message } = createConfirmation('123', 'stop', { type: 'feature' });\n\n  assert.ok(confirmId);\n  assert.ok(message);\n\n  const status = checkConfirmation(confirmId, '123');\n  assert.equal(status.status, 'pending');\n});\n\ntest('US-4.2: Should confirm pending action', () => {\n  const { confirmId } = createConfirmation('123', 'stop', { type: 'feature' });\n\n  const result = confirmAction(confirmId, '123');\n\n  assert.equal(result.ok, true);\n  assert.equal(result.action, 'stop');\n  assert.deepEqual(result.params, { type: 'feature' });\n});\n\ntest('US-4.3: Should cancel pending confirmation', () => {\n  const { confirmId } = createConfirmation('123', 'stop', { type: 'feature' });\n\n  cancelConfirmation(confirmId, '123');\n\n  const status = checkConfirmation(confirmId, '123');\n  assert.equal(status.status, 'not_found');\n});\n\ntest('US-4.4: Should reject wrong user confirmation', () => {\n  const { confirmId } = createConfirmation('123', 'stop', { type: 'feature' });\n\n  const result = confirmAction(confirmId, '456');\n\n  assert.equal(result.ok, false);\n  assert.ok(result.error);\n});\n\n// ============================================================\n// US-5: Audit Logging Tests\n// ============================================================\n\ntest('US-5.1: Should log sensitive actions', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    initAuditLogService({ logPath: tempDir });\n\n    await logAuditEntry({\n      userId: '123',\n      role: 'admin',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'success'\n    });\n\n    const entries = await queryAuditLogs({ userId: '123' });\n\n    assert.equal(entries.length, 1);\n    assert.equal(entries[0].action, 'stop');\n    assert.equal(entries[0].result, 'success');\n\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-5.2: Should log denied actions with reason', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    initAuditLogService({ logPath: tempDir });\n\n    await logAuditEntry({\n      userId: '222',\n      role: 'operator',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'denied',\n      reason: '权限不足'\n    });\n\n    const entries = await queryAuditLogs({ action: 'stop' });\n\n    assert.equal(entries.length, 1);\n    assert.equal(entries[0].result, 'denied');\n    assert.equal(entries[0].reason, '权限不足');\n\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-5.3: Should query audit logs by user', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    initAuditLogService({ logPath: tempDir });\n\n    await logAuditEntry({ userId: '111', action: 'stop', result: 'success' });\n    await logAuditEntry({ userId: '222', action: 'stop', result: 'success' });\n    await logAuditEntry({ userId: '111', action: 'reset', result: 'success' });\n\n    const entries = await queryAuditLogs({ userId: '111' });\n\n    assert.equal(entries.length, 2);\n    assert.ok(entries.every(e => e.userId === '111'));\n\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\ntest('US-5.4: Should query audit logs by action', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    initAuditLogService({ logPath: tempDir });\n\n    await logAuditEntry({ userId: '111', action: 'stop', result: 'success' });\n    await logAuditEntry({ userId: '111', action: 'reset', result: 'success' });\n    await logAuditEntry({ userId: '111', action: 'stop', result: 'failed' });\n\n    const entries = await queryAuditLogs({ action: 'stop' });\n\n    assert.equal(entries.length, 2);\n    assert.ok(entries.every(e => e.action === 'stop'));\n\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\n// ============================================================\n// End-to-End Security Flow Tests\n// ============================================================\n\ntest('E2E-1: Complete permission check + audit flow', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    const userPermissions = new Map([['111', 'admin']]);\n    setConfigForTesting(createMockConfig(userPermissions));\n    initAuditLogService({ logPath: tempDir });\n\n    // 1. Check permission\n    const perm = checkCommandPermission('111', 'stop');\n    assert.equal(perm.allowed, true);\n\n    // 2. Log the access attempt\n    await logAuditEntry({\n      userId: '111',\n      role: 'admin',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'success'\n    });\n\n    // 3. Verify audit log\n    const logs = await queryAuditLogs({ userId: '111' });\n    assert.equal(logs.length, 1);\n\n    resetConfig();\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\ntest('E2E-2: Denied permission + audit flow', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    const userPermissions = new Map([['222', 'operator']]);\n    setConfigForTesting(createMockConfig(userPermissions));\n    initAuditLogService({ logPath: tempDir });\n\n    // 1. Check permission - should be denied\n    const perm = checkCommandPermission('222', 'stop');\n    assert.equal(perm.allowed, false);\n\n    // 2. Log the denial\n    await logAuditEntry({\n      userId: '222',\n      role: 'operator',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'denied',\n      reason: perm.reason\n    });\n\n    // 3. Verify audit log shows denial\n    const logs = await queryAuditLogs({ action: 'stop' });\n    assert.equal(logs.length, 1);\n    assert.equal(logs[0].result, 'denied');\n\n    resetConfig();\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\ntest('E2E-3: Confirmation flow with audit', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    initAuditLogService({ logPath: tempDir });\n\n    // 1. Create confirmation\n    const { confirmId } = createConfirmation('111', 'stop', { type: 'feature' });\n\n    // 2. Log pending state\n    await logAuditEntry({\n      userId: '111',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'pending',\n      reason: 'Waiting for confirmation'\n    });\n\n    // 3. Confirm action\n    const result = confirmAction(confirmId, '111');\n    assert.equal(result.ok, true);\n\n    // 4. Log success\n    await logAuditEntry({\n      userId: '111',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'success'\n    });\n\n    // 5. Verify audit trail\n    const logs = await queryAuditLogs({ userId: '111' });\n    assert.equal(logs.length, 2);\n\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n\ntest('E2E-4: Parameter sanitization blocks injection', async () => {\n  const { tempDir, cleanup } = createTempLogDir();\n  try {\n    initAuditLogService({ logPath: tempDir });\n\n    // Simulate malicious input\n    const maliciousTarget = '../../../etc/passwd';\n\n    // 1. Sanitize should fail\n    const result = sanitizeParam(maliciousTarget);\n    assert.equal(result.ok, false);\n\n    // 2. Log the rejection\n    await logAuditEntry({\n      userId: '111',\n      action: 'pipeline_run',\n      params: { target: '[BLOCKED]' },\n      result: 'denied',\n      reason: 'Dangerous pattern detected'\n    });\n\n    // 3. Verify audit log\n    const logs = await queryAuditLogs({ action: 'pipeline_run' });\n    assert.equal(logs.length, 1);\n    assert.equal(logs[0].result, 'denied');\n\n    resetAuditLogService();\n  } finally {\n    cleanup();\n  }\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/security-flow.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":90483,"output_tokens":3339,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_6ed227e88daa4bc7bcc1af8c","__timestamp":"2026-03-11T20:46:55.307Z","_requestId":"1836a01aa07b4323b33253678e844458"}
