 Download file content\n 532→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 533→      const fileUrl = fileLink.href || fileLink.toString();\n 534→\n 535→      const response = await fetch(fileUrl);\n 536→      if (!response.ok) {\n 537→        throw new Error(`下载文件失败: ${response.status}`);\n 538→      }\n 539→\n 540→      const content = await response.text();\n 541→\n 542→      // Validate and save using plan-ingestion-service\n 543→      const infraConfig = loadPipelineInfraConfig();\n 544→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 545→\n 546→      const validationResult = planService.validate(content);\n 547→\n 548→      if (!validationResult.valid) {\n 549→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 550→        await ctx.reply(errorMsg);\n 551→        return;\n 552→      }\n 553→\n 554→      // Save the plan\n 555→      const saveResult = await planService.save(\n 556→        validationResult.type,\n 557→        content,\n 558→        { uploadedBy: ctx.from?.id }\n 559→      );\n 560→\n 561→      if (!saveResult.success) {\n 562→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 563→        return;\n 564→      }\n 565→\n 566→      // Set as current version\n 567→      await planService.setCurrent(validationResult.type, saveResult.version);\n 568→\n 569→      // Format success message\n 570→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 571→      const summary = validationResult.summary;\n 572→\n 573→      await ctx.reply([\n 574→        `✅ ${typeDisplay}已保存并激活`,\n 575→        `版本: ${saveResult.version}`,\n 576→        `名称: ${summary?.name || '未知'}`,\n 577→        `项目数: ${summary?.itemCount || 0}`,\n 578→        '',\n 579→        summary?.statusBreakdown ? '状态分布:' : '',\n 580→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 581→      ].filter(Boolean).join('\\n'));\n 582→\n 583→    } catch (error) {\n 584→      const message = error instanceof Error ? error.message : String(error);\n 585→      logger.error({ err: message }, 'Failed to process document upload');\n 586→      await ctx.reply(`❌ 处理失败：${message}`);\n 587→    }\n 588→  });\n 589→\n 590→  bot.on('text', async (ctx) => {\n 591→    // Check for pipeline commands first\n 592→    const handled = await routeCommand(ctx);\n 593→    if (handled) {\n 594→      return;\n 595→    }\n 596→\n 597→    const sessionId = buildSessionId(ctx);\n 598→\n 599→    let typingTimer = null;\n 600→\n 601→    try {\n 602→      ensureAllowed(ctx);\n 603→      await ctx.sendChatAction('typing');\n 604→\n 605→      const streamPublisher = createEditableStreamPublisher(ctx);\n 606→      typingTimer = setInterval(() => {\n 607→        ctx.sendChatAction('typing').catch(() => undefined);\n 608→      }, TYPING_INTERVAL_MS);\n 609→\n 610→      const reply = await chatWithSession({\n 611→        channel: 'telegram',\n 612→        sessionId,\n 613→        message: ctx.message.text,\n 614→        realtimeHooks: {\n 615→          onStatus: ({ stage }) => {\n 616→            if (stage === 'running') {\n 617→              ctx.sendChatAction('typing').catch(() => undefined);\n 618→            }\n 619→          },\n 620→          onAssistantChunk: ({ text }) => {\n 621→            streamPublisher.push(text);\n 622→          }\n 623→        }\n 624→      });\n 625→\n 626→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 627→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 628→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 629→\n 630→      streamPublisher.setFinalText(finalText);\n 631→      const streamed = await streamPublisher.finish();\n 632→      if (streamed.outputLength === 0) {\n 633→        await replyLargeText(ctx, finalText);\n 634→      }\n 635→\n 636→      if (fileRefs.length > 0) {\n 637→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 638→        const failed = fileSendResults.filter((item) => !item.sent);\n 639→\n 640→        if (failed.length === 0) {\n 641→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 642→        } else {\n 643→          const failedList = failed\n 644→            .map((item) => {\n 645→              const reason =\n 646→                item.reason === 'relative_path_not_allowed'\n 647→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 648→                  : item.reason === 'not_found'\n 649→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 650→                    : item.reason;\n 651→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 652→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 653→            })\n 654→            .join('\\n');\n 655→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 656→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 657→        }\n 658→      }\n 659→    } catch (error) {\n 660→      const message = error instanceof Error ? error.message : String(error);\n 661→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 662→      await safeReply(ctx, `处理失败：${message}`);\n 663→    } finally {\n 664→      if (typingTimer) {\n 665→        clearInterval(typingTimer);\n 666→      }\n 667→    }\n 668→  });\n 669→\n 670→  return bot;\n 671→}\n 672→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ccbecff65fa64c6b898f8181","__timestamp":"2026-03-11T20:32:00.882Z","_requestId":"1836a01aa07b4323b33253678e844458"}
