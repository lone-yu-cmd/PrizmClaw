{"type":"assistant","uuid":"20260312044100d7006de5a21849ac","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"id":"20260312044100d7006de5a21849ac","content":[{"type":"tool_use","id":"call_f23b194667114ac9abe2db80","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/audit-log-service.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":47902,"output_tokens":49,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:41:02.307Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"d8952efb-a44f-472d-880c-34c36ebe63be","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_f23b194667114ac9abe2db80","content":[{"type":"text","text":"   1→/**\n   2→ * Audit Log Service\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides audit logging for sensitive operations.\n   6→ * AC-5: Audit Logging\n   7→ */\n   8→\n   9→import { appendFile, mkdir, readdir, stat, rename, unlink } from 'node:fs/promises';\n  10→import { join } from 'node:path';\n  11→import { createReadStream } from 'node:fs';\n  12→import { createInterface } from 'node:readline';\n  13→import { config } from '../config.js';\n  14→\n  15→/**\n  16→ * Service state\n  17→ */\n  18→let serviceConfig = null;\n  19→let logFilePath = null;\n  20→let writeQueue = Promise.resolve();\n  21→\n  22→/**\n  23→ * Default log file name\n  24→ */\n  25→const LOG_FILE_NAME = 'audit.log';\n  26→\n  27→/**\n  28→ * Initialize audit log service\n  29→ * @param {Object} cfg\n  30→ * @param {string} [cfg.logDir] - Log directory path (defaults to config.auditLogDir)\n  31→ * @param {number} [cfg.maxFileSizeMb] - Max file size in MB (defaults to config.auditLogMaxSizeMb)\n  32→ * @param {number} [cfg.maxFiles] - Max files to keep (defaults to config.auditLogMaxFiles)\n  33→ */\n  34→export async function initAuditLogService(cfg = {}) {\n  35→  serviceConfig = {\n  36→    logDir: cfg.logDir || config.auditLogDir || 'logs',\n  37→    maxFileSizeMb: cfg.maxFileSizeMb || config.auditLogMaxSizeMb || 10,\n  38→    maxFiles: cfg.maxFiles || config.auditLogMaxFiles || 5\n  39→  };\n  40→\n  41→  // Ensure directory exists\n  42→  await mkdir(serviceConfig.logDir, { recursive: true });\n  43→\n  44→  // Set log file path\n  45→  logFilePath = join(serviceConfig.logDir, LOG_FILE_NAME);\n  46→}\n  47→\n  48→/**\n  49→ * Reset service state (for testing)\n  50→ */\n  51→export function resetService() {\n  52→  serviceConfig = null;\n  53→  logFilePath = null;\n  54→  writeQueue = Promise.resolve();\n  55→}\n  56→\n  57→/**\n  58→ * Log sensitive action\n  59→ * @param {Object} entry\n  60→ * @param {string|number} entry.userId\n  61→ * @param {string} [entry.username]\n  62→ * @param {string} entry.action\n  63→ * @param {Object} entry.params\n  64→ * @param {string} entry.result - 'success'|'denied'|'failed'\n  65→ * @param {string} [entry.reason]\n  66→ * @param {string} [entry.sessionId]\n  67→ * @returns {Promise<void>}\n  68→ */\n  69→export async function logAuditEntry(entry) {\n  70→  // Ensure initialized\n  71→  if (!serviceConfig || !logFilePath) {\n  72→    // Try to initialize with defaults\n  73→    try {\n  74→      await initAuditLogService();\n  75→    } catch {\n  76→      // NFR-2: Fail silently - don't affect command execution\n  77→      return;\n  78→    }\n  79→  }\n  80→\n  81→  const logEntry = {\n  82→    timestamp: new Date().toISOString(),\n  83→    userId: String(entry.userId),\n  84→    username: entry.username || null,\n  85→    action: entry.action,\n  86→    params: entry.params || {},\n  87→    result: entry.result,\n  88→    reason: entry.reason || null,\n  89→    sessionId: entry.sessionId || null\n  90→  };\n  91→\n  92→  // Serialize to JSON Lines format\n  93→  const line = JSON.stringify(logEntry) + '\\n';\n  94→\n  95→  // Queue write to ensure ordering (NFR-2: async write)\n  96→  writeQueue = writeQueue.then(async () => {\n  97→    try {\n  98→      await appendFile(logFilePath, line, 'utf-8');\n  99→\n 100→      // Check for rotation\n 101→      await rotateLogIfNeeded();\n 102→    } catch {\n 103→      // NFR-2: Fail silently - don't affect command execution\n 104→    }\n 105→  });\n 106→\n 107→  await writeQueue;\n 108→}\n 109→\n 110→/**\n 111→ * Check and rotate log if needed\n 112→ * AC-5.4: Single file max 10MB, keep last 5 files\n 113→ */\n 114→export async function rotateLogIfNeeded() {\n 115→  if (!serviceConfig || !logFilePath) return;\n 116→\n 117→  try {\n 118→    const fileStat = await stat(logFilePath);\n 119→    const sizeMb = fileStat.size / (1024 * 1024);\n 120→\n 121→    if (sizeMb >= serviceConfig.maxFileSizeMb) {\n 122→      await rotateLog();\n 123→    }\n 124→  } catch {\n 125→    // File doesn't exist yet, no rotation needed\n 126→  }\n 127→}\n 128→\n 129→/**\n 130→ * Perform log rotation\n 131→ */\n 132→async function rotateLog() {\n 133→  const timestamp = new Date().toISOString().replace(/[:.]/g, '-');\n 134→  const rotatedName = `audit-${timestamp}.log`;\n 135→  const rotatedPath = join(serviceConfig.logDir, rotatedName);\n 136→\n 137→  try {\n 138→    // Rename current log\n 139→    await rename(logFilePath, rotatedPath);\n 140→\n 141→    // Clean up old files\n 142→    await cleanupOldLogs();\n 143→  } catch {\n 144→    // Ignore rotation errors\n 145→  }\n 146→}\n 147→\n 148→/**\n 149→ * Clean up old log files beyond maxFiles limit\n 150→ */\n 151→async function cleanupOldLogs() {\n 152→  const files = await readdir(serviceConfig.logDir);\n 153→\n 154→  // Filter to audit log files, sorted by modification time (oldest first)\n 155→  const auditFiles = files.filter((f) => f.startsWith('audit-') && f.endsWith('.log'));\n 156→\n 157→  // Add current log file to the count\n 158→  const totalFiles = auditFiles.length + 1; // +1 for current audit.log\n 159→\n 160→  if (totalFiles > serviceConfig.maxFiles) {\n 161→    // Delete oldest files\n 162→    const toDelete = totalFiles - serviceConfig.maxFiles;\n 163→\n 164→    // Sort by name (which includes timestamp)\n 165→    auditFiles.sort();\n 166→\n 167→    for (let i = 0; i < toDelete && i < auditFiles.length; i++) {\n 168→      const filePath = join(serviceConfig.logDir, auditFiles[i]);\n 169→      try {\n 170→        await unlink(filePath);\n 171→      } catch {\n 172→        // Ignore deletion errors\n 173→      }\n 174→    }\n 175→  }\n 176→}\n 177→\n 178→/**\n 179→ * Query audit logs\n 180→ * @param {Object} filters\n 181→ * @param {string|number} [filters.userId]\n 182→ * @param {string} [filters.action]\n 183→ * @param {string} [filters.sessionId]\n 184→ * @param {Date} [filters.startDate]\n 185→ * @param {Date} [filters.endDate]\n 186→ * @param {number} [filters.limit=100]\n 187→ * @returns {Promise<Object[]>}\n 188→ */\n 189→export async function queryAuditLogs(filters = {}) {\n 190→  if (!serviceConfig || !logFilePath) {\n 191→    await initAuditLogService();\n 192→  }\n 193→\n 194→  const { userId, action, sessionId, startDate, endDate, limit = 100 } = filters;\n 195→\n 196→  const entries = [];\n 197→\n 198→  try {\n 199→    const fileStream = createReadStream(logFilePath, { encoding: 'utf-8' });\n 200→    const rl = createInterface({\n 201→      input: fileStream,\n 202→      crlfDelay: Infinity\n 203→    });\n 204→\n 205→    for await (const line of rl) {\n 206→      if (!line.trim()) continue;\n 207→\n 208→      try {\n 209→        const entry = JSON.parse(line);\n 210→\n 211→        // Apply filters\n 212→        if (userId && entry.userId !== String(userId)) continue;\n 213→        if (action && entry.action !== action) continue;\n 214→        if (sessionId && entry.sessionId !== sessionId) continue;\n 215→        if (startDate && new Date(entry.timestamp) < startDate) continue;\n 216→        if (endDate && new Date(entry.timestamp) > endDate) continue;\n 217→\n 218→        entries.push(entry);\n 219→\n 220→        if (entries.length >= limit) break;\n 221→      } catch {\n 222→        // Skip malformed lines\n 223→      }\n 224→    }\n 225→\n 226→    rl.close();\n 227→    fileStream.destroy();\n 228→  } catch {\n 229→    // File doesn't exist or can't be read\n 230→    return [];\n 231→  }\n 232→\n 233→  // Return in reverse chronological order\n 234→  return entries.reverse().slice(0, limit);\n 235→}\n 236→\n 237→export default {\n 238→  initAuditLogService,\n 239→  logAuditEntry,\n 240→  queryAuditLogs,\n 241→  rotateLogIfNeeded,\n 242→  resetService\n 243→};\n 244→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:41:02.312Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
