{"type":"user","uuid":"da51e529-c32d-455f-ad02-2092848a39c6","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_ddb4f6f980074932aaa242b8","content":[{"type":"text","text":"   1→/**\n   2→ * Audit Command Handler\n   3→ * Handles /audit command to query audit logs.\n   4→ * F-006: Safety and Permission Guard - US-5: Audit Logging\n   5→ */\n   6→\n   7→import { queryAuditLogs, initAuditLogService } from '../../../services/audit-log-service.js';\n   8→import { isAdmin } from '../../../security/permission-guard.js';\n   9→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n  10→\n  11→/**\n  12→ * Audit command metadata.\n  13→ * T-108: Admin-only audit log query\n  14→ */\n  15→export const auditMeta = {\n  16→  name: 'audit',\n  17→  aliases: [],\n  18→  description: '查询审计日志 (仅限管理员)',\n  19→  usage: '/audit [--user=<userId>] [--action=<action>] [--limit=<N>]',\n  20→  examples: [\n  21→    '/audit',\n  22→    '/audit --user=123456789',\n  23→    '/audit --action=stop',\n  24→    '/audit --limit=20'\n  25→  ],\n  26→  params: [\n  27→    {\n  28→      name: 'user',\n  29→      type: 'string',\n  30→      required: false,\n  31→      description: '按用户 ID 过滤'\n  32→    },\n  33→    {\n  34→      name: 'action',\n  35→      type: 'string',\n  36→      required: false,\n  37→      description: '按操作类型过滤'\n  38→    },\n  39→    {\n  40→      name: 'limit',\n  41→      type: 'number',\n  42→      required: false,\n  43→      description: '返回条数限制 (最大 100)',\n  44→      default: 20\n  45→    }\n  46→  ],\n  47→  requiresAuth: true,\n  48→  minRole: 'admin',\n  49→  helpText: '/audit [--user=<userId>] [--action=<action>] [--limit=<N>] - 查询审计日志'\n  50→};\n  51→\n  52→/**\n  53→ * Handle audit command.\n  54→ * @param {Object} handlerCtx - Handler context\n  55→ */\n  56→export async function handleAudit(handlerCtx) {\n  57→  const { reply, params, userId, requiresConfirmation } = handlerCtx;\n  58→\n  59→  // Double-check admin permission (defense in depth)\n  60→  if (!isAdmin(userId)) {\n  61→    await reply('⛔ 此命令仅限管理员使用。');\n  62→    return;\n  63→  }\n  64→\n  65→  // Parse and sanitize parameters\n  66→  const limit = Math.min(parseInt(params.limit, 10) || 20, 100);\n  67→\n  68→  let userFilter = null;\n  69→  if (params.user) {\n  70→    const userResult = sanitizeParam(params.user, { maxLength: 50 });\n  71→    if (!userResult.ok) {\n  72→      await reply(`❌ 用户参数无效: ${userResult.error}`);\n  73→      return;\n  74→    }\n  75→    userFilter = userResult.value;\n  76→  }\n  77→\n  78→  let actionFilter = null;\n  79→  if (params.action) {\n  80→    const actionResult = sanitizeParam(params.action, { maxLength: 50 });\n  81→    if (!actionResult.ok) {\n  82→      await reply(`❌ 操作参数无效: ${actionResult.error}`);\n  83→      return;\n  84→    }\n  85→    actionFilter = actionResult.value;\n  86→  }\n  87→\n  88→  try {\n  89→    // Initialize service if needed\n  90→    await initAuditLogService();\n  91→\n  92→    // Query logs\n  93→    const entries = await queryAuditLogs({\n  94→      userId: userFilter,\n  95→      action: actionFilter,\n  96→      limit\n  97→    });\n  98→\n  99→    if (entries.length === 0) {\n 100→      await reply('📭 没有找到匹配的审计日志。');\n 101→      return;\n 102→    }\n 103→\n 104→    // Format entries for display\n 105→    const formatted = formatAuditEntries(entries);\n 106→    await reply(formatted);\n 107→  } catch (error) {\n 108→    await reply(`❌ 查询失败: ${error.message}`);\n 109→  }\n 110→}\n 111→\n 112→/**\n 113→ * Format audit entries for Telegram display.\n 114→ * @param {Object[]} entries\n 115→ * @returns {string}\n 116→ */\n 117→function formatAuditEntries(entries) {\n 118→  const lines = [`📋 审计日志 (${entries.length} 条)\\n`];\n 119→\n 120→  for (const entry of entries) {\n 121→    const time = new Date(entry.timestamp).toLocaleString('zh-CN', {\n 122→      timeZone: 'Asia/Shanghai'\n 123→    });\n 124→    const resultEmoji = entry.result === 'success' ? '✅' : entry.result === 'denied' ? '⛔' : '❌';\n 125→\n 126→    lines.push(`${resultEmoji} ${time}`);\n 127→    lines.push(`   用户: ${entry.userId}`);\n 128→    lines.push(`   操作: ${entry.action}`);\n 129→    if (entry.params && Object.keys(entry.params).length > 0) {\n 130→      lines.push(`   参数: ${JSON.stringify(entry.params)}`);\n 131→    }\n 132→    lines.push(`   结果: ${entry.result}`);\n 133→    if (entry.reason) {\n 134→      lines.push(`   原因: ${entry.reason}`);\n 135→    }\n 136→    lines.push('');\n 137→  }\n 138→\n 139→  return lines.join('\\n').trim();\n 140→}\n 141→\n 142→export default handleAudit;\n 143→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb0eca880b82916352a46acc4a0","__timestamp":"2026-03-11T20:59:08.897Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"bfde1046-825e-483a-b542-f5b7235290db","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_1ef79110bc84463594f78457","content":[{"type":"text","text":"   1→DOC_LEVEL: L2\n   2→MODULE: security\n   3→PATH: src/security/**\n   4→DESCRIPTION: Security guard layer for permission tiers, param sanitization, and confirmation flow\n   5→\n   6→KEY_FILES:\n   7→- src/security/index.js -> module exports\n   8→- src/security/permission-guard.js -> role hierarchy and command authorization\n   9→- src/security/param-sanitizer.js -> parameter sanitization and dangerous pattern detection\n  10→- src/security/confirmation-manager.js -> confirmation flow for high-risk actions\n  11→- src/security/guard.js -> existing user authorization\n  12→- src/security/system-guard.js -> system exec authorization\n  13→\n  14→INTERFACES:\n  15→- getUserRole(userId) -> 'admin' | 'operator' | 'viewer'\n  16→- checkCommandPermission(userId, command) -> { allowed, requiresConfirmation, reason }\n  17→- isAdmin(userId) -> boolean\n  18→- sanitizeParam(input, options) -> { ok, value?, error? }\n  19→- validatePath(path, allowedRoots) -> { ok, resolved?, error? }\n  20→- detectDangerousPatterns(input) -> { safe, patterns }\n  21→- createConfirmation(userId, action, params, timeoutMs) -> { confirmId, message }\n  22→- checkConfirmation(confirmId, userId) -> { status, action?, params? }\n  23→- confirmAction(confirmId, userId) -> { ok, action?, params?, error? }\n  24→- cancelConfirmation(confirmId, userId) -> void\n  25→- logAuditEntry(entry) -> Promise<void>\n  26→- queryAuditLogs(filters) -> Promise<Object[]>\n  27→\n  28→ROLE_HIERARCHY:\n  29→- viewer: 0 -> can view status and logs\n  30→- operator: 1 -> can run pipelines and retry\n  31→- admin: 2 -> can stop, reset, force-unlock, exec\n  32→\n  33→COMMAND_PERMISSIONS:\n  34→- status, logs: viewer\n  35→- pipeline, bugfix, planner, retry: operator\n  36→- stop, reset, force-unlock, exec: admin\n  37→\n  38→HIGH_RISK_COMMANDS:\n  39→- stop, reset, force-unlock -> require confirmation (CONFIRM text)\n  40→- admin can skip confirmation with --force flag\n  41→\n  42→DANGEROUS_PATTERNS:\n  43→- path traversal (..)\n  44→- shell injection (backticks, $(), ${})\n  45→- command chains (||, &&, ;)\n  46→- home directory expansion (~)\n  47→- exec/eval flags\n  48→\n  49→AUDIT_LOG:\n  50→- format: JSON Lines (.jsonl)\n  51→- fields: timestamp, userId, role, action, params, result, reason, sessionId\n  52→- rotation: max 10MB per file, max 5 files\n  53→\n  54→TRAPS:\n  55→- unknown users default to 'operator' role\n  56→- permission denied is logged before returning error\n  57→- confirmation expires after 60 seconds\n  58→- audit log write failures are silent (non-blocking)\n  59→- param sanitizer rejects all dangerous patterns regardless of context\n  60→\n  61→DEPENDS_ON:\n  62→- src/config.js -> USER_PERMISSIONS, ALLOW_ADMIN_SKIP_CONFIRM, AUDIT_LOG_*\n  63→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb0eca880b82916352a46acc4a0","__timestamp":"2026-03-11T20:59:08.929Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
