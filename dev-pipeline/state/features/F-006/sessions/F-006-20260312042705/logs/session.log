on: '强制释放锁' }\n  51→  ],\n  52→  params: [\n  53→    {\n  54→      name: 'target',\n  55→      type: 'string',\n  56→      required: false,\n  57→      description: '目标标识符'\n  58→    },\n  59→    {\n  60→      name: 'type',\n  61→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:42:48.429Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
