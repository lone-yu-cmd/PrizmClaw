{"type":"user","uuid":"6b3b049c-8252-410e-9a3e-fea0bc71fbe5","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_5ae911737bbb425e9c61e903","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for audit-log-service.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdtemp, rm, readFile, stat } from 'node:fs/promises';\n   9→import { join } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→import {\n  12→  initAuditLogService,\n  13→  logAuditEntry,\n  14→  queryAuditLogs,\n  15→  rotateLogIfNeeded,\n  16→  resetService\n  17→} from '../../src/services/audit-log-service.js';\n  18→\n  19→let tempDir;\n  20→\n  21→test.before(async () => {\n  22→  tempDir = await mkdtemp(join(tmpdir(), 'audit-test-'));\n  23→});\n  24→\n  25→test.after(async () => {\n  26→  if (tempDir) {\n  27→    await rm(tempDir, { recursive: true, force: true });\n  28→  }\n  29→});\n  30→\n  31→test.beforeEach(() => {\n  32→  resetService();\n  33→});\n  34→\n  35→// initAuditLogService tests\n  36→test('initAuditLogService initializes with config', async () => {\n  37→  await initAuditLogService({\n  38→    logDir: tempDir,\n  39→    maxFileSizeMb: 10,\n  40→    maxFiles: 5\n  41→  });\n  42→\n  43→  // Should not throw\n  44→});\n  45→\n  46→test('initAuditLogService creates log directory if needed', async () => {\n  47→  const newDir = join(tempDir, 'new-logs');\n  48→\n  49→  await initAuditLogService({\n  50→    logDir: newDir,\n  51→    maxFileSizeMb: 10,\n  52→    maxFiles: 5\n  53→  });\n  54→\n  55→  // Directory should exist\n  56→  const dirStat = await stat(newDir);\n  57→  assert.ok(dirStat.isDirectory());\n  58→});\n  59→\n  60→// logAuditEntry tests\n  61→test('logAuditEntry writes entry to log file', async () => {\n  62→  await initAuditLogService({\n  63→    logDir: tempDir,\n  64→    maxFileSizeMb: 10,\n  65→    maxFiles: 5\n  66→  });\n  67→\n  68→  await logAuditEntry({\n  69→    userId: '123456789',\n  70→    action: 'stop',\n  71→    params: { type: 'feature' },\n  72→    result: 'success'\n  73→  });\n  74→\n  75→  // Read and verify\n  76→  const content = await readFile(join(tempDir, 'audit.log'), 'utf-8');\n  77→  const lines = content.trim().split('\\n');\n  78→  assert.ok(lines.length >= 1);\n  79→\n  80→  const entry = JSON.parse(lines[lines.length - 1]);\n  81→  assert.equal(entry.userId, '123456789');\n  82→  assert.equal(entry.action, 'stop');\n  83→  assert.equal(entry.result, 'success');\n  84→});\n  85→\n  86→test('logAuditEntry includes timestamp', async () => {\n  87→  await initAuditLogService({\n  88→    logDir: tempDir,\n  89→    maxFileSizeMb: 10,\n  90→    maxFiles: 5\n  91→  });\n  92→\n  93→  const before = new Date().toISOString();\n  94→\n  95→  await logAuditEntry({\n  96→    userId: '123456789',\n  97→    action: 'stop',\n  98→    params: {},\n  99→    result: 'success'\n 100→  });\n 101→\n 102→  const after = new Date().toISOString();\n 103→\n 104→  const content = await readFile(join(tempDir, 'audit.log'), 'utf-8');\n 105→  const lines = content.trim().split('\\n');\n 106→  const entry = JSON.parse(lines[lines.length - 1]);\n 107→\n 108→  assert.ok(entry.timestamp >= before);\n 109→  assert.ok(entry.timestamp <= after);\n 110→});\n 111→\n 112→test('logAuditEntry handles denied result', async () => {\n 113→  await initAuditLogService({\n 114→    logDir: tempDir,\n 115→    maxFileSizeMb: 10,\n 116→    maxFiles: 5\n 117→  });\n 118→\n 119→  await logAuditEntry({\n 120→    userId: '987654321',\n 121→    action: 'stop',\n 122→    params: { type: 'feature' },\n 123→    result: 'denied',\n 124→    reason: '权限不足'\n 125→  });\n 126→\n 127→  const content = await readFile(join(tempDir, 'audit.log'), 'utf-8');\n 128→  const lines = content.trim().split('\\n');\n 129→  const entry = JSON.parse(lines[lines.length - 1]);\n 130→\n 131→  assert.equal(entry.result, 'denied');\n 132→  assert.equal(entry.reason, '权限不足');\n 133→});\n 134→\n 135→test('logAuditEntry handles failed result', async () => {\n 136→  await initAuditLogService({\n 137→    logDir: tempDir,\n 138→    maxFileSizeMb: 10,\n 139→    maxFiles: 5\n 140→  });\n 141→\n 142→  await logAuditEntry({\n 143→    userId: '123456789',\n 144→    action: 'reset',\n 145→    params: {},\n 146→    result: 'failed',\n 147→    reason: 'Pipeline not found'\n 148→  });\n 149→\n 150→  const content = await readFile(join(tempDir, 'audit.log'), 'utf-8');\n 151→  const lines = content.trim().split('\\n');\n 152→  const entry = JSON.parse(lines[lines.length - 1]);\n 153→\n 154→  assert.equal(entry.result, 'failed');\n 155→});\n 156→\n 157→// queryAuditLogs tests\n 158→test('queryAuditLogs returns all entries', async () => {\n 159→  await initAuditLogService({\n 160→    logDir: tempDir,\n 161→    maxFileSizeMb: 10,\n 162→    maxFiles: 5\n 163→  });\n 164→\n 165→  // Write multiple entries\n 166→  await logAuditEntry({ userId: '111', action: 'stop', params: {}, result: 'success' });\n 167→  await logAuditEntry({ userId: '222', action: 'reset', params: {}, result: 'success' });\n 168→  await logAuditEntry({ userId: '333', action: 'stop', params: {}, result: 'denied' });\n 169→\n 170→  const entries = await queryAuditLogs({});\n 171→\n 172→  assert.ok(entries.length >= 3);\n 173→});\n 174→\n 175→test('queryAuditLogs filters by userId', async () => {\n 176→  await initAuditLogService({\n 177→    logDir: tempDir,\n 178→    maxFileSizeMb: 10,\n 179→    maxFiles: 5\n 180→  });\n 181→\n 182→  await logAuditEntry({ userId: '111', action: 'stop', params: {}, result: 'success' });\n 183→  await logAuditEntry({ userId: '222', action: 'reset', params: {}, result: 'success' });\n 184→  await logAuditEntry({ userId: '111', action: 'stop', params: {}, result: 'denied' });\n 185→\n 186→  const entries = await queryAuditLogs({ userId: '111' });\n 187→\n 188→  assert.ok(entries.every((e) => e.userId === '111'));\n 189→});\n 190→\n 191→test('queryAuditLogs filters by action', async () => {\n 192→  await initAuditLogService({\n 193→    logDir: tempDir,\n 194→    maxFileSizeMb: 10,\n 195→    maxFiles: 5\n 196→  });\n 197→\n 198→  await logAuditEntry({ userId: '111', action: 'stop', params: {}, result: 'success' });\n 199→  await logAuditEntry({ userId: '222', action: 'reset', params: {}, result: 'success' });\n 200→  await logAuditEntry({ userId: '333', action: 'stop', params: {}, result: 'denied' });\n 201→\n 202→  const entries = await queryAuditLogs({ action: 'stop' });\n 203→\n 204→  assert.ok(entries.every((e) => e.action === 'stop'));\n 205→});\n 206→\n 207→test('queryAuditLogs respects limit', async () => {\n 208→  await initAuditLogService({\n 209→    logDir: tempDir,\n 210→    maxFileSizeMb: 10,\n 211→    maxFiles: 5\n 212→  });\n 213→\n 214→  for (let i = 0; i < 20; i++) {\n 215→    await logAuditEntry({ userId: `${i}`, action: 'test', params: {}, result: 'success' });\n 216→  }\n 217→\n 218→  const entries = await queryAuditLogs({ limit: 5 });\n 219→\n 220→  assert.ok(entries.length <= 5);\n 221→});\n 222→\n 223→// AC-5.1: Log entry structure\n 224→test('logAuditEntry includes required fields per AC-5.1', async () => {\n 225→  await initAuditLogService({\n 226→    logDir: tempDir,\n 227→    maxFileSizeMb: 10,\n 228→    maxFiles: 5\n 229→  });\n 230→\n 231→  await logAuditEntry({\n 232→    userId: '123456789',\n 233→    username: 'testuser',\n 234→    action: 'stop',\n 235→    params: { type: 'feature' },\n 236→    result: 'success',\n 237→    sessionId: 'telegram-123456789'\n 238→  });\n 239→\n 240→  const content = await readFile(join(tempDir, 'audit.log'), 'utf-8');\n 241→  const lines = content.trim().split('\\n');\n 242→  const entry = JSON.parse(lines[lines.length - 1]);\n 243→\n 244→  assert.ok(entry.timestamp);\n 245→  assert.equal(entry.userId, '123456789');\n 246→  assert.equal(entry.username, 'testuser');\n 247→  assert.equal(entry.action, 'stop');\n 248→  assert.deepEqual(entry.params, { type: 'feature' });\n 249→  assert.equal(entry.result, 'success');\n 250→  assert.equal(entry.sessionId, 'telegram-123456789');\n 251→});\n 252→\n 253→// AC-5.2: JSON Lines format\n 254→test('audit log uses JSON Lines format per AC-5.2', async () => {\n 255→  await initAuditLogService({\n 256→    logDir: tempDir,\n 257→    maxFileSizeMb: 10,\n 258→    maxFiles: 5\n 259→  });\n 260→\n 261→  await logAuditEntry({ userId: '111', action: 'test', params: {}, result: 'success' });\n 262→  await logAuditEntry({ userId: '222', action: 'test', params: {}, result: 'success' });\n 263→\n 264→  const content = await readFile(join(tempDir, 'audit.log'), 'utf-8');\n 265→  const lines = content.trim().split('\\n');\n 266→\n 267→  // Each line should be valid JSON\n 268→  for (const line of lines) {\n 269→    if (line.trim()) {\n 270→      const entry = JSON.parse(line);\n 271→      assert.ok(entry.timestamp);\n 272→    }\n 273→  }\n 274→});\n 275→\n 276→// AC-5.3: Query by sessionId or userId\n 277→test('queryAuditLogs filters by sessionId', async () => {\n 278→  await initAuditLogService({\n 279→    logDir: tempDir,\n 280→    maxFileSizeMb: 10,\n 281→    maxFiles: 5\n 282→  });\n 283→\n 284→  await logAuditEntry({\n 285→    userId: '111',\n 286→    action: 'stop',\n 287→    params: {},\n 288→    result: 'success',\n 289→    sessionId: 'session-aaa'\n 290→  });\n 291→  await logAuditEntry({\n 292→    userId: '111',\n 293→    action: 'reset',\n 294→    params: {},\n 295→    result: 'success',\n 296→    sessionId: 'session-bbb'\n 297→  });\n 298→\n 299→  const entries = await queryAuditLogs({ sessionId: 'session-aaa' });\n 300→\n 301→  assert.ok(entries.every((e) => e.sessionId === 'session-aaa'));\n 302→});\n 303→\n 304→// Log rotation tests (AC-5.4)\n 305→test('rotateLogIfNeeded creates new file when size exceeded', async () => {\n 306→  const smallTempDir = await mkdtemp(join(tmpdir(), 'audit-rotate-'));\n 307→\n 308→  try {\n 309→    await initAuditLogService({\n 310→      logDir: smallTempDir,\n 311→      maxFileSizeMb: 0.001, // 1KB for testing\n 312→      maxFiles: 3\n 313→    });\n 314→\n 315→    // Write enough entries to trigger rotation\n 316→    for (let i = 0; i < 50; i++) {\n 317→      await logAuditEntry({\n 318→        userId: `${i}`,\n 319→        action: 'test-action-with-long-name',\n 320→        params: { data: 'x'.repeat(100) },\n 321→        result: 'success'\n 322→      });\n 323→    }\n 324→\n 325→    await rotateLogIfNeeded();\n 326→\n 327→    // Check if rotation happened (at least one backup file)\n 328→    const files = await import('node:fs/promises').then((fs) => fs.readdir(smallTempDir));\n 329→    assert.ok(files.length >= 1);\n 330→  } finally {\n 331→    await rm(smallTempDir, { recursive: true, force: true });\n 332→  }\n 333→});\n 334→\n 335→// NFR-2: Audit log write failure should not affect command execution\n 336→test('logAuditEntry handles write errors gracefully', async () => {\n 337→  // Initialize with valid dir first\n 338→  await initAuditLogService({\n 339→    logDir: tempDir,\n 340→    maxFileSizeMb: 10,\n 341→    maxFiles: 5\n 342→  });\n 343→\n 344→  // Reset and don't initialize (simulates not initialized)\n 345→  resetService();\n 346→\n 347→  // Should not throw even when not initialized\n 348→  await logAuditEntry({\n 349→    userId: '123',\n 350→    action: 'test',\n 351→    params: {},\n 352→    result: 'success'\n 353→  });\n 354→});\n 355→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:57.134Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"b748196f-dbd1-4dab-94ee-a59128b8900b","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_d0d59bf8f6384f5aa8c9a25f","content":[{"type":"text","text":"   1→/**\n   2→ * Log Pager Unit Tests\n   3→ * Tests for src/services/log-pager.js\n   4→ *\n   5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-2: Paginated Logs Query, US-3: Message Length Compliance\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import { createLogPager } from '../../src/services/log-pager.js';\n  15→\n  16→/**\n  17→ * Helper to create temp directory for test state\n  18→ */\n  19→function createTempStateDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'log-pager-test-'));\n  21→  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  22→  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  23→  fs.mkdirSync(stateDir, { recursive: true });\n  24→  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  25→  return {\n  26→    tempDir,\n  27→    stateDir,\n  28→    bugfixStateDir,\n  29→    cleanup: () => {\n  30→      fs.rmSync(tempDir, { recursive: true, force: true });\n  31→    }\n  32→  };\n  33→}\n  34→\n  35→/**\n  36→ * Helper to create a mock config\n  37→ */\n  38→function createMockConfig(stateDir, bugfixStateDir) {\n  39→  const projectRoot = path.dirname(path.dirname(stateDir));\n  40→  return {\n  41→    projectRoot,\n  42→    stateDir,\n  43→    bugfixStateDir\n  44→  };\n  45→}\n  46→\n  47→/**\n  48→ * Helper to generate sample log content\n  49→ */\n  50→function generateLogLines(count) {\n  51→  const lines = [];\n  52→  for (let i = 1; i <= count; i++) {\n  53→    lines.push(`[${new Date().toISOString()}] [INFO] Log line ${i}: Some log content here`);\n  54→  }\n  55→  return lines.join('\\n');\n  56→}\n  57→\n  58→/**\n  59→ * Helper to generate log with errors\n  60→ */\n  61→function generateLogWithErrors() {\n  62→  return `[\n  63→${new Date().toISOString()}] [INFO] Starting pipeline\n  64→[${new Date().toISOString()}] [INFO] Processing F-001\n  65→[${new Date().toISOString()}] [ERROR] Failed to process F-001: Script failed\n  66→[${new Date().toISOString()}] [INFO] Processing F-002\n  67→[${new Date().toISOString()}] [ERROR] Exception: ENOENT: no such file\n  68→[${new Date().toISOString()}] [ERROR] Stack trace line 1\n  69→[${new Date().toISOString()}] [ERROR] Stack trace line 2\n  70→[${new Date().toISOString()}] [INFO] Completed`;\n  71→}\n  72→\n  73→// ============================================================\n  74→// Factory Tests\n  75→// ============================================================\n  76→\n  77→test('createLogPager should be a factory function', () => {\n  78→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  79→  try {\n  80→    const config = createMockConfig(stateDir, bugfixStateDir);\n  81→    const pager = createLogPager({ config });\n  82→\n  83→    assert.equal(typeof pager.readLogPage, 'function');\n  84→    assert.equal(typeof pager.formatLogsForTelegram, 'function');\n  85→    assert.equal(typeof pager.extractErrorLines, 'function');\n  86→    assert.equal(typeof pager.shouldSendAsFile, 'function');\n  87→    assert.equal(typeof pager.buildLogMetadata, 'function');\n  88→  } finally {\n  89→    cleanup();\n  90→  }\n  91→});\n  92→\n  93→// ============================================================\n  94→// readLogPage Tests (T-020, T-026)\n  95→// ============================================================\n  96→\n  97→test('readLogPage should return last N lines by default', async () => {\n  98→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  99→  try {\n 100→    const config = createMockConfig(stateDir, bugfixStateDir);\n 101→\n 102→    // Write log file with 200 lines\n 103→    fs.writeFileSync(\n 104→      path.join(stateDir, 'pipeline-daemon.log'),\n 105→      generateLogLines(200)\n 106→    );\n 107→\n 108→    const pager = createLogPager({ config });\n 109→    const result = await pager.readLogPage('feature', { lines: 50 });\n 110→\n 111→    assert.equal(result.ok, true);\n 112→    assert.ok(result.logs);\n 113→    assert.ok(result.metadata);\n 114→    assert.equal(result.metadata.requestedLines, 50);\n 115→    assert.ok(result.metadata.actualLines <= 50);\n 116→  } finally {\n 117→    cleanup();\n 118→  }\n 119→});\n 120→\n 121→test('readLogPage should support offset parameter', async () => {\n 122→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 123→  try {\n 124→    const config = createMockConfig(stateDir, bugfixStateDir);\n 125→\n 126→    // Write log file\n 127→    fs.writeFileSync(\n 128→      path.join(stateDir, 'pipeline-daemon.log'),\n 129→      generateLogLines(100)\n 130→    );\n 131→\n 132→    const pager = createLogPager({ config });\n 133→    const result = await pager.readLogPage('feature', { lines: 20, offset: 10 });\n 134→\n 135→    assert.equal(result.ok, true);\n 136→    assert.ok(result.metadata.pageStart > 0);\n 137→  } finally {\n 138→    cleanup();\n 139→  }\n 140→});\n 141→\n 142→test('readLogPage should cap lines at max 500', async () => {\n 143→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 144→  try {\n 145→    const config = createMockConfig(stateDir, bugfixStateDir);\n 146→\n 147→    fs.writeFileSync(\n 148→      path.join(stateDir, 'pipeline-daemon.log'),\n 149→      generateLogLines(1000)\n 150→    );\n 151→\n 152→    const pager = createLogPager({ config });\n 153→    const result = await pager.readLogPage('feature', { lines: 1000 });\n 154→\n 155→    // Should cap at 500\n 156→    assert.ok(result.metadata.actualLines <= 500);\n 157→  } finally {\n 158→    cleanup();\n 159→  }\n 160→});\n 161→\n 162→test('readLogPage should return friendly message for missing log file', async () => {\n 163→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 164→  try {\n 165→    const config = createMockConfig(stateDir, bugfixStateDir);\n 166→    const pager = createLogPager({ config });\n 167→\n 168→    const result = await pager.readLogPage('feature', { lines: 50 });\n 169→\n 170→    assert.equal(result.ok, true);\n 171→    assert.ok(result.logs === '' || result.message);\n 172→    assert.ok(result.metadata);\n 173→  } finally {\n 174→    cleanup();\n 175→  }\n 176→});\n 177→\n 178→test('readLogPage should work for bugfix type', async () => {\n 179→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 180→  try {\n 181→    const config = createMockConfig(stateDir, bugfixStateDir);\n 182→\n 183→    fs.writeFileSync(\n 184→      path.join(bugfixStateDir, 'pipeline-daemon.log'),\n 185→      generateLogLines(50)\n 186→    );\n 187→\n 188→    const pager = createLogPager({ config });\n 189→    const result = await pager.readLogPage('bugfix', { lines: 20 });\n 190→\n 191→    assert.equal(result.ok, true);\n 192→    assert.ok(result.logs);\n 193→  } finally {\n 194→    cleanup();\n 195→  }\n 196→});\n 197→\n 198→// ============================================================\n 199→// extractErrorLines Tests (T-022, T-027)\n 200→// ============================================================\n 201→\n 202→test('extractErrorLines should extract lines containing ERROR', () => {\n 203→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 204→  try {\n 205→    const config = createMockConfig(stateDir, bugfixStateDir);\n 206→    const pager = createLogPager({ config });\n 207→\n 208→    const logs = generateLogWithErrors();\n 209→    const errorLines = pager.extractErrorLines(logs, 10);\n 210→\n 211→    assert.ok(Array.isArray(errorLines));\n 212→    assert.ok(errorLines.length > 0);\n 213→    assert.ok(errorLines.every(line => line.includes('ERROR')));\n 214→  } finally {\n 215→    cleanup();\n 216→  }\n 217→});\n 218→\n 219→test('extractErrorLines should limit to N lines', () => {\n 220→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 221→  try {\n 222→    const config = createMockConfig(stateDir, bugfixStateDir);\n 223→    const pager = createLogPager({ config });\n 224→\n 225→    const logs = generateLogWithErrors();\n 226→    const errorLines = pager.extractErrorLines(logs, 2);\n 227→\n 228→    assert.ok(errorLines.length <= 2);\n 229→  } finally {\n 230→    cleanup();\n 231→  }\n 232→});\n 233→\n 234→test('extractErrorLines should return empty array for no errors', () => {\n 235→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 236→  try {\n 237→    const config = createMockConfig(stateDir, bugfixStateDir);\n 238→    const pager = createLogPager({ config });\n 239→\n 240→    const logs = generateLogLines(50);\n 241→    const errorLines = pager.extractErrorLines(logs, 10);\n 242→\n 243→    assert.deepEqual(errorLines, []);\n 244→  } finally {\n 245→    cleanup();\n 246→  }\n 247→});\n 248→\n 249→// ============================================================\n 250→// shouldSendAsFile Tests (T-023, T-027)\n 251→// ============================================================\n 252→\n 253→test('shouldSendAsFile should return true for large logs', () => {\n 254→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 255→  try {\n 256→    const config = createMockConfig(stateDir, bugfixStateDir);\n 257→    const pager = createLogPager({ config });\n 258→\n 259→    // Create log larger than 4000 chars\n 260→    const largeLog = 'x'.repeat(5000);\n 261→    const result = pager.shouldSendAsFile(largeLog);\n 262→\n 263→    assert.equal(result, true);\n 264→  } finally {\n 265→    cleanup();\n 266→  }\n 267→});\n 268→\n 269→test('shouldSendAsFile should return false for small logs', () => {\n 270→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 271→  try {\n 272→    const config = createMockConfig(stateDir, bugfixStateDir);\n 273→    const pager = createLogPager({ config });\n 274→\n 275→    const smallLog = 'x'.repeat(1000);\n 276→    const result = pager.shouldSendAsFile(smallLog);\n 277→\n 278→    assert.equal(result, false);\n 279→  } finally {\n 280→    cleanup();\n 281→  }\n 282→});\n 283→\n 284→test('shouldSendAsFile should use custom threshold', () => {\n 285→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 286→  try {\n 287→    const config = createMockConfig(stateDir, bugfixStateDir);\n 288→    const pager = createLogPager({ config });\n 289→\n 290→    const log = 'x'.repeat(2000);\n 291→    const result = pager.shouldSendAsFile(log, 1500);\n 292→\n 293→    assert.equal(result, true);\n 294→  } finally {\n 295→    cleanup();\n 296→  }\n 297→});\n 298→\n 299→// ============================================================\n 300→// formatLogsForTelegram Tests (T-024)\n 301→// ============================================================\n 302→\n 303→test('formatLogsForTelegram should add metadata header', () => {\n 304→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 305→  try {\n 306→    const config = createMockConfig(stateDir, bugfixStateDir);\n 307→    const pager = createLogPager({ config });\n 308→\n 309→    const logs = generateLogLines(20);\n 310→    const metadata = {\n 311→      logPath: '/path/to/log',\n 312→      totalLines: 100,\n 313→      pageStart: 80,\n 314→      pageEnd: 100,\n 315→      requestedLines: 20,\n 316→      actualLines: 20\n 317→    };\n 318→\n 319→    const formatted = pager.formatLogsForTelegram(logs, metadata);\n 320→\n 321→    assert.ok(formatted.includes('100')); // total lines\n 322→    assert.ok(formatted.includes('80')); // page start\n 323→    assert.ok(logs.split('\\n')[0]); // log content\n 324→  } finally {\n 325→    cleanup();\n 326→  }\n 327→});\n 328→\n 329→test('formatLogsForTelegram should handle empty logs', () => {\n 330→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 331→  try {\n 332→    const config = createMockConfig(stateDir, bugfixStateDir);\n 333→    const pager = createLogPager({ config });\n 334→\n 335→    const formatted = pager.formatLogsForTelegram('', { totalLines: 0 });\n 336→\n 337→    assert.ok(formatted);\n 338→  } finally {\n 339→    cleanup();\n 340→  }\n 341→});\n 342→\n 343→// ============================================================\n 344→// buildLogMetadata Tests (T-025)\n 345→// ============================================================\n 346→\n 347→test('buildLogMetadata should create metadata object', () => {\n 348→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 349→  try {\n 350→    const config = createMockConfig(stateDir, bugfixStateDir);\n 351→    const pager = createLogPager({ config });\n 352→\n 353→    const metadata = pager.buildLogMetadata('/path/to/log', 100, 80, 100, 20, 20);\n 354→\n 355→    assert.equal(metadata.logPath, '/path/to/log');\n 356→    assert.equal(metadata.totalLines, 100);\n 357→    assert.equal(metadata.pageStart, 80);\n 358→    assert.equal(metadata.pageEnd, 100);\n 359→    assert.equal(metadata.requestedLines, 20);\n 360→    assert.equal(metadata.actualLines, 20);\n 361→  } finally {\n 362→    cleanup();\n 363→  }\n 364→});\n 365→\n 366→// ============================================================\n 367→// Message Segment Numbering Tests (T-121) - US-3\n 368→// ============================================================\n 369→\n 370→test('formatLogsForTelegram should add segment numbering for chunked output', () => {\n 371→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 372→  try {\n 373→    const config = createMockConfig(stateDir, bugfixStateDir);\n 374→    const pager = createLogPager({ config });\n 375→\n 376→    const logs = generateLogLines(100);\n 377→    const metadata = {\n 378→      logPath: '/path/to/log',\n 379→      totalLines: 100,\n 380→      pageStart: 0,\n 381→      pageEnd: 100,\n 382→      requestedLines: 100,\n 383→      actualLines: 100,\n 384→      segmentIndex: 0,\n 385→      totalSegments: 3\n 386→    };\n 387→\n 388→    const formatted = pager.formatLogsForTelegram(logs, metadata);\n 389→\n 390→    // Should include segment numbering like [1/3]\n 391→    assert.ok(formatted.includes('[1/3]') || !metadata.totalSegments);\n 392→  } finally {\n 393→    cleanup();\n 394→  }\n 395→});\n 396→\n 397→// ============================================================\n 398→// Diagnostic Error Tests (T-152) - US-6\n 399→// ============================================================\n 400→\n 401→test('readLogPage should return diagnostic message for missing log file', async () => {\n 402→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 403→  try {\n 404→    const config = createMockConfig(stateDir, bugfixStateDir);\n 405→    const pager = createLogPager({ config });\n 406→\n 407→    const result = await pager.readLogPage('feature', { lines: 50 });\n 408→\n 409→    assert.equal(result.ok, true);\n 410→    // Should have a friendly message\n 411→    assert.ok(result.message || result.logs === '');\n 412→    assert.ok(result.metadata.logPath);\n 413→  } finally {\n 414→    cleanup();\n 415→  }\n 416→});\n 417→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:57.147Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
