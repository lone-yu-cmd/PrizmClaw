{"type":"assistant","uuid":"20260312044008d96c65e6d5994c98","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"id":"20260312044008d96c65e6d5994c98","content":[{"type":"tool_use","id":"call_725f031e9b5e48e0a0b9a21b","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/config.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":23389,"output_tokens":412,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.280Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"978facbe-c693-41f9-9af2-bcf778dea34a","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_96dd76dc55304396b81339c5","content":[{"type":"text","text":"   1→/**\n   2→ * Permission Guard Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides user permission tiers and command authorization checking.\n   6→ */\n   7→\n   8→import { config } from '../config.js';\n   9→\n  10→/**\n  11→ * Role hierarchy levels (higher = more permissions)\n  12→ */\n  13→export const ROLE_HIERARCHY = {\n  14→  viewer: 0,\n  15→  operator: 1,\n  16→  admin: 2\n  17→};\n  18→\n  19→/**\n  20→ * Minimum required role for each command\n  21→ */\n  22→const COMMAND_MIN_ROLE = {\n  23→  status: 'viewer',\n  24→  logs: 'viewer',\n  25→  pipeline: 'operator',\n  26→  bugfix: 'operator',\n  27→  planner: 'operator',\n  28→  retry: 'operator',\n  29→  stop: 'admin',\n  30→  reset: 'admin',\n  31→  'force-unlock': 'admin',\n  32→  exec: 'admin'\n  33→};\n  34→\n  35→/**\n  36→ * High-risk commands that require confirmation\n  37→ */\n  38→const HIGH_RISK_COMMANDS = new Set(['stop', 'reset', 'force-unlock']);\n  39→\n  40→/**\n  41→ * Internal config reference - can be overridden for testing\n  42→ * @type {Object}\n  43→ */\n  44→let _config = config;\n  45→\n  46→/**\n  47→ * Set config for testing purposes\n  48→ * @param {Object} testConfig\n  49→ */\n  50→export function setConfigForTesting(testConfig) {\n  51→  _config = testConfig;\n  52→}\n  53→\n  54→/**\n  55→ * Reset config to original (for testing cleanup)\n  56→ */\n  57→export function resetConfig() {\n  58→  _config = config;\n  59→}\n  60→\n  61→/**\n  62→ * Get user permission level\n  63→ * @param {string|number} userId - Telegram user ID\n  64→ * @returns {'admin'|'operator'|'viewer'}\n  65→ */\n  66→export function getUserRole(userId) {\n  67→  const userIdStr = String(userId);\n  68→  const configuredRole = _config.userPermissions.get(userIdStr);\n  69→\n  70→  if (configuredRole) {\n  71→    return configuredRole;\n  72→  }\n  73→\n  74→  // Default to operator for unknown users (AC-1.3)\n  75→  return 'operator';\n  76→}\n  77→\n  78→/**\n  79→ * Check if user is admin\n  80→ * @param {string|number} userId\n  81→ * @returns {boolean}\n  82→ */\n  83→export function isAdmin(userId) {\n  84→  return getUserRole(userId) === 'admin';\n  85→}\n  86→\n  87→/**\n  88→ * Check if user can execute command\n  89→ * @param {string|number} userId\n  90→ * @param {string} command - Command name\n  91→ * @returns {{ allowed: boolean, requiresConfirmation: boolean, reason?: string }}\n  92→ */\n  93→export function checkCommandPermission(userId, command) {\n  94→  const userRole = getUserRole(userId);\n  95→  const minRole = COMMAND_MIN_ROLE[command] || 'viewer';\n  96→\n  97→  // Special handling for exec command (AC-2.4, F-002)\n  98→  if (command === 'exec' && !_config.enableSystemExec) {\n  99→    return {\n 100→      allowed: false,\n 101→      requiresConfirmation: false,\n 102→      reason: '系统命令执行未启用。请在 .env 中设置 ENABLE_SYSTEM_EXEC=true。'\n 103→    };\n 104→  }\n 105→\n 106→  // Check role hierarchy\n 107→  const userLevel = ROLE_HIERARCHY[userRole];\n 108→  const requiredLevel = ROLE_HIERARCHY[minRole];\n 109→\n 110→  if (userLevel < requiredLevel) {\n 111→    return {\n 112→      allowed: false,\n 113→      requiresConfirmation: false,\n 114→      reason: `权限不足。此命令需要 ${minRole} 权限，当前权限: ${userRole}。`\n 115→    };\n 116→  }\n 117→\n 118→  // Check if this is a high-risk command requiring confirmation\n 119→  const requiresConfirmation = HIGH_RISK_COMMANDS.has(command);\n 120→\n 121→  return {\n 122→    allowed: true,\n 123→    requiresConfirmation\n 124→  };\n 125→}\n 126→\n 127→export default {\n 128→  getUserRole,\n 129→  checkCommandPermission,\n 130→  isAdmin,\n 131→  ROLE_HIERARCHY,\n 132→  setConfigForTesting,\n 133→  resetConfig\n 134→};\n 135→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.294Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"de59a525-989a-4abc-aa03-aae1f35dfbd5","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_19d6820bee554c45b5c30d46","content":[{"type":"text","text":"   1→/**\n   2→ * Param Sanitizer Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides parameter sanitization and dangerous pattern detection.\n   6→ */\n   7→\n   8→import path from 'node:path';\n   9→\n  10→/**\n  11→ * Dangerous patterns to detect\n  12→ * AC-3.1: Path traversal, absolute path escape, shell metacharacters\n  13→ * AC-3.3: Dangerous characters: ; | & $ ` ' \" ( ) < >\n  14→ */\n  15→const DANGEROUS_PATTERNS = [\n  16→  { pattern: /\\.\\./, name: 'path traversal (..)' },\n  17→  { pattern: /[`$]/, name: 'shell injection ($ or `)' },\n  18→  { pattern: /~/, name: 'home directory (~)' },\n  19→  { pattern: /\\$\\(/, name: 'command substitution ($())' },\n  20→  { pattern: /\\|\\|/, name: 'command chain (||)' },\n  21→  { pattern: /&&/, name: 'command chain (&&)' },\n  22→  { pattern: /;/, name: 'command separator (;)' },\n  23→  { pattern: /\\|/, name: 'pipe (|)' },\n  24→  { pattern: /&/, name: 'ampersand (&)' },\n  25→  { pattern: /--exec\\b/, name: 'exec flag (--exec)' },\n  26→  { pattern: /--eval\\b/, name: 'eval flag (--eval)' },\n  27→  { pattern: /'/, name: 'single quote (\\')' },\n  28→  { pattern: /\"/, name: 'double quote (\")' },\n  29→  { pattern: /\\(/, name: 'left parenthesis ((' },\n  30→  { pattern: /\\)/, name: 'right parenthesis ())' },\n  31→  { pattern: /</, name: 'left angle bracket (<)' },\n  32→  { pattern: />/, name: 'right angle bracket (>)' }\n  33→];\n  34→\n  35→/**\n  36→ * TargetId valid format: [A-Za-z0-9_-]+\n  37→ */\n  38→const TARGET_ID_PATTERN = /^[A-Za-z0-9_-]+$/;\n  39→\n  40→/**\n  41→ * Check for dangerous patterns in input\n  42→ * @param {string} input\n  43→ * @returns {{ safe: boolean, patterns: string[] }}\n  44→ */\n  45→export function detectDangerousPatterns(input) {\n  46→  const detectedPatterns = [];\n  47→\n  48→  for (const { pattern, name } of DANGEROUS_PATTERNS) {\n  49→    if (pattern.test(input)) {\n  50→      detectedPatterns.push(name);\n  51→    }\n  52→  }\n  53→\n  54→  return {\n  55→    safe: detectedPatterns.length === 0,\n  56→    patterns: detectedPatterns\n  57→  };\n  58→}\n  59→\n  60→/**\n  61→ * Sanitize string parameter\n  62→ * @param {string} input - Raw input\n  63→ * @param {Object} options\n  64→ * @param {number} [options.maxLength=200]\n  65→ * @param {boolean} [options.isTargetId=false]\n  66→ * @param {boolean} [options.isPath=false]\n  67→ * @returns {{ ok: boolean, value?: string, error?: string }}\n  68→ */\n  69→export function sanitizeParam(input, options = {}) {\n  70→  const { maxLength = 200, isTargetId = false, isPath = false } = options;\n  71→\n  72→  // Handle null/undefined\n  73→  if (input === null || input === undefined) {\n  74→    return { ok: false, error: '参数不能为空' };\n  75→  }\n  76→\n  77→  // Convert to string and trim\n  78→  const text = String(input).trim();\n  79→\n  80→  // Check for empty input\n  81→  if (!text) {\n  82→    return { ok: false, error: '参数不能为空' };\n  83→  }\n  84→\n  85→  // Check max length\n  86→  if (text.length > maxLength) {\n  87→    return { ok: false, error: `参数过长，最大 ${maxLength} 个字符` };\n  88→  }\n  89→\n  90→  // For targetId, check specific format (AC-3.2)\n  91→  if (isTargetId) {\n  92→    if (!TARGET_ID_PATTERN.test(text)) {\n  93→      return { ok: false, error: '目标 ID 格式无效，仅允许字母、数字、下划线和连字符' };\n  94→    }\n  95→    return { ok: true, value: text };\n  96→  }\n  97→\n  98→  // Check for dangerous patterns (AC-3.1, AC-3.3)\n  99→  const { safe, patterns } = detectDangerousPatterns(text);\n 100→  if (!safe) {\n 101→    // For isPath, allow certain patterns that are valid in paths\n 102→    if (isPath) {\n 103→      // Paths can have / and . but not .. or other dangerous patterns\n 104→      const pathSpecificPatterns = patterns.filter(\n 105→        (p) =>\n 106→          !p.includes('path traversal') ||\n 107→          // Only filter path traversal if it's actually .. (handled separately)\n 108→          false\n 109→      );\n 110→      if (pathSpecificPatterns.length > 0) {\n 111→        return { ok: false, error: `参数包含危险字符: ${pathSpecificPatterns.join(', ')}` };\n 112→      }\n 113→    } else {\n 114→      return { ok: false, error: `参数包含危险字符: ${patterns.join(', ')}` };\n 115→    }\n 116→  }\n 117→\n 118→  return { ok: true, value: text };\n 119→}\n 120→\n 121→/**\n 122→ * Validate path parameter\n 123→ * @param {string} inputPath - Path to validate\n 124→ * @param {string[]} allowedRoots - Allowed root directories\n 125→ * @returns {{ ok: boolean, resolved?: string, error?: string }}\n 126→ */\n 127→export function validatePath(inputPath, allowedRoots) {\n 128→  // Handle null/undefined\n 129→  if (!inputPath) {\n 130→    return { ok: false, error: '路径不能为空' };\n 131→  }\n 132→\n 133→  const text = String(inputPath).trim();\n 134→  if (!text) {\n 135→    return { ok: false, error: '路径不能为空' };\n 136→  }\n 137→\n 138→  // Must be absolute path\n 139→  if (!path.isAbsolute(text)) {\n 140→    return { ok: false, error: '仅允许绝对路径' };\n 141→  }\n 142→\n 143→  // Check for path traversal\n 144→  if (text.includes('..')) {\n 145→    return { ok: false, error: '路径不允许包含 ..' };\n 146→  }\n 147→\n 148→  // Resolve to canonical path\n 149→  const resolved = path.resolve(text);\n 150→\n 151→  // Check against allowed roots\n 152→  if (allowedRoots && allowedRoots.length > 0) {\n 153→    const isWithinRoot = allowedRoots.some((root) => {\n 154→      const resolvedRoot = path.resolve(root);\n 155→      const relative = path.relative(resolvedRoot, resolved);\n 156→      return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 157→    });\n 158→\n 159→    if (!isWithinRoot) {\n 160→      return { ok: false, error: '路径不在允许的根目录范围内' };\n 161→    }\n 162→  }\n 163→\n 164→  return { ok: true, resolved };\n 165→}\n 166→\n 167→export default {\n 168→  sanitizeParam,\n 169→  validatePath,\n 170→  detectDangerousPatterns\n 171→};\n 172→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.298Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"6b916be8-0741-46e3-99ae-83a1cb83cd10","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_24b73487ba5047d8bc0fa517","content":[{"type":"text","text":"   1→/**\n   2→ * Confirmation Manager Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Manages confirmation flow for high-risk actions.\n   6→ * AC-4: Confirmation for Sensitive Actions\n   7→ */\n   8→\n   9→import { randomUUID } from 'node:crypto';\n  10→\n  11→/**\n  12→ * Default confirmation timeout (60 seconds per AC-4.3)\n  13→ */\n  14→const DEFAULT_TIMEOUT_MS = 60000;\n  15→\n  16→/**\n  17→ * Pending confirmations storage\n  18→ * Map<confirmId, ConfirmationEntry>\n  19→ */\n  20→const pendingConfirmations = new Map();\n  21→\n  22→/**\n  23→ * @typedef {Object} ConfirmationEntry\n  24→ * @property {string} confirmId\n  25→ * @property {string|number} userId\n  26→ * @property {string} action\n  27→ * @property {Object} params\n  28→ * @property {number} createdAt\n  29→ * @property {number} expiresAt\n  30→ */\n  31→\n  32→/**\n  33→ * Create pending confirmation\n  34→ * @param {string|number} userId\n  35→ * @param {string} action - Action name\n  36→ * @param {Object} params - Action parameters\n  37→ * @param {number} [timeoutMs=60000]\n  38→ * @returns {{ confirmId: string, message: string }}\n  39→ */\n  40→export function createConfirmation(userId, action, params, timeoutMs = DEFAULT_TIMEOUT_MS) {\n  41→  const confirmId = randomUUID();\n  42→  const now = Date.now();\n  43→\n  44→  const entry = {\n  45→    confirmId,\n  46→    userId: String(userId),\n  47→    action,\n  48→    params,\n  49→    createdAt: now,\n  50→    expiresAt: now + timeoutMs\n  51→  };\n  52→\n  53→  pendingConfirmations.set(confirmId, entry);\n  54→\n  55→  const message = `⚠️ 确认执行操作: ${action}\\n参数: ${JSON.stringify(params)}\\n请在 60 秒内回复 CONFIRM 确认，或回复 CANCEL 取消。`;\n  56→\n  57→  return { confirmId, message };\n  58→}\n  59→\n  60→/**\n  61→ * Check confirmation status\n  62→ * @param {string} confirmId\n  63→ * @param {string|number} userId\n  64→ * @returns {{ status: 'pending'|'confirmed'|'expired'|'not_found', action?: string, params?: Object }}\n  65→ */\n  66→export function checkConfirmation(confirmId, userId) {\n  67→  const entry = pendingConfirmations.get(confirmId);\n  68→\n  69→  if (!entry) {\n  70→    return { status: 'not_found' };\n  71→  }\n  72→\n  73→  // Verify userId matches\n  74→  if (entry.userId !== String(userId)) {\n  75→    return { status: 'not_found' };\n  76→  }\n  77→\n  78→  // Check if expired\n  79→  if (Date.now() > entry.expiresAt) {\n  80→    return { status: 'expired', action: entry.action, params: entry.params };\n  81→  }\n  82→\n  83→  return {\n  84→    status: 'pending',\n  85→    action: entry.action,\n  86→    params: entry.params\n  87→  };\n  88→}\n  89→\n  90→/**\n  91→ * Confirm pending action\n  92→ * @param {string} confirmId\n  93→ * @param {string|number} userId\n  94→ * @returns {{ ok: boolean, action?: string, params?: Object, error?: string }}\n  95→ */\n  96→export function confirmAction(confirmId, userId) {\n  97→  const entry = pendingConfirmations.get(confirmId);\n  98→\n  99→  if (!entry) {\n 100→    return { ok: false, error: '确认请求不存在或已过期' };\n 101→  }\n 102→\n 103→  // Verify userId matches\n 104→  if (entry.userId !== String(userId)) {\n 105→    return { ok: false, error: '无权确认此操作' };\n 106→  }\n 107→\n 108→  // Check if expired\n 109→  if (Date.now() > entry.expiresAt) {\n 110→    return { ok: false, error: '确认请求已过期' };\n 111→  }\n 112→\n 113→  // Remove from pending (consumed)\n 114→  pendingConfirmations.delete(confirmId);\n 115→\n 116→  return {\n 117→    ok: true,\n 118→    action: entry.action,\n 119→    params: entry.params\n 120→  };\n 121→}\n 122→\n 123→/**\n 124→ * Cancel pending confirmation\n 125→ * @param {string} confirmId\n 126→ * @param {string|number} userId\n 127→ */\n 128→export function cancelConfirmation(confirmId, userId) {\n 129→  const entry = pendingConfirmations.get(confirmId);\n 130→\n 131→  if (!entry) {\n 132→    return;\n 133→  }\n 134→\n 135→  // Only allow creator to cancel\n 136→  if (entry.userId === String(userId)) {\n 137→    pendingConfirmations.delete(confirmId);\n 138→  }\n 139→}\n 140→\n 141→/**\n 142→ * Clear all expired confirmations\n 143→ * Should be called periodically\n 144→ */\n 145→export function clearExpiredConfirmations() {\n 146→  const now = Date.now();\n 147→\n 148→  for (const [confirmId, entry] of pendingConfirmations) {\n 149→    if (entry.expiresAt <= now) {\n 150→      pendingConfirmations.delete(confirmId);\n 151→    }\n 152→  }\n 153→}\n 154→\n 155→export default {\n 156→  createConfirmation,\n 157→  checkConfirmation,\n 158→  confirmAction,\n 159→  cancelConfirmation,\n 160→  clearExpiredConfirmations\n 161→};\n 162→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.309Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"b9d392d3-5053-4a57-b6c3-3e54b5191c18","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_60226cf5bfa74436a67cdfd9","content":[{"type":"text","text":"   1→/**\n   2→ * Security Module Exports\n   3→ * Central exports for all security-related utilities.\n   4→ */\n   5→\n   6→// Existing guards\n   7→export { isAllowedUser, sanitizeInput } from './guard.js';\n   8→export { assertSystemExecEnabled, assertAllowedCommand } from './system-guard.js';\n   9→\n  10→// Permission Guard (F-006)\n  11→export { getUserRole, checkCommandPermission, isAdmin, ROLE_HIERARCHY } from './permission-guard.js';\n  12→\n  13→// Param Sanitizer (F-006)\n  14→export { sanitizeParam, validatePath, detectDangerousPatterns } from './param-sanitizer.js';\n  15→\n  16→// Confirmation Manager (F-006)\n  17→export {\n  18→  createConfirmation,\n  19→  checkConfirmation,\n  20→  confirmAction,\n  21→  cancelConfirmation,\n  22→  clearExpiredConfirmations\n  23→} from './confirmation-manager.js';\n  24→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.310Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"7111d138-1743-471d-99ae-e8bbe2f73afc","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_1d3c85bf99a04c0c9ab5ae7f","content":[{"type":"text","text":"[\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/chat-queue.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/system-exec-service.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/screenshot-service.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/chat-service.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/realtime-hub.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/session-store.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/pipeline-control-service.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/plan-ingestion-service.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/status-aggregator.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/telegram-pusher.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/index.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/log-pager.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/pipeline-controller.js\"]"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.310Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"2e777c6b-4811-4bc3-a6da-2e625fe8f415","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_725f031e9b5e48e0a0b9a21b","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5)\n  32→});\n  33→\n  34→const parsed = schema.parse(process.env);\n  35→\n  36→function parseAllowedUserIds(input) {\n  37→  return new Set(\n  38→    input\n  39→      .split(',')\n  40→      .map((id) => id.trim())\n  41→      .filter(Boolean)\n  42→  );\n  43→}\n  44→\n  45→function parseCsvList(input) {\n  46→  return input\n  47→    .split(',')\n  48→    .map((item) => item.trim())\n  49→    .filter(Boolean);\n  50→}\n  51→\n  52→function parseBoolean(input) {\n  53→  const normalized = (input ?? '').trim().toLowerCase();\n  54→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  55→}\n  56→\n  57→/**\n  58→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  59→ * Format: \"123456789:admin,987654321:operator\"\n  60→ * @param {string} input\n  61→ * @returns {Map<string, string>}\n  62→ */\n  63→function parseUserPermissions(input) {\n  64→  const permissions = new Map();\n  65→  if (!input || !input.trim()) {\n  66→    return permissions;\n  67→  }\n  68→\n  69→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  70→  for (const entry of entries) {\n  71→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  72→    if (userId && role) {\n  73→      const normalizedRole = role.toLowerCase();\n  74→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  75→        permissions.set(userId, normalizedRole);\n  76→      }\n  77→    }\n  78→  }\n  79→  return permissions;\n  80→}\n  81→\n  82→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n  83→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n  84→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n  85→}\n  86→\n  87→const pipelineInfra = loadPipelineInfraConfig({\n  88→  env: process.env,\n  89→  argv: process.argv.slice(2),\n  90→  cwd: process.cwd()\n  91→});\n  92→\n  93→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n  94→\n  95→export const config = Object.freeze({\n  96→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n  97→  enableTelegram,\n  98→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n  99→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 100→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 101→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 102→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 103→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 104→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 105→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 106→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 107→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 108→  webHost: parsed.WEB_HOST,\n 109→  webPort: parsed.WEB_PORT,\n 110→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 111→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 112→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 113→  logLevel: parsed.LOG_LEVEL,\n 114→  // F-006: Safety and Permission Guard\n 115→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 116→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 117→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 118→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 119→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 120→  pipelineInfra: Object.freeze({\n 121→    ...pipelineInfra,\n 122→    daemonLogPaths\n 123→  })\n 124→});\n 125→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:40:20.310Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
