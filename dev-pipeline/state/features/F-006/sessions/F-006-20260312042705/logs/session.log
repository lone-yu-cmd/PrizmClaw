{"type":"user","uuid":"04e73f66-0b8d-4039-bd75-fa9a4b711b65","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_f494ecb9d68a42a4bb280d5e","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Test for F-006: Safety and Permission Guard\n   3→ * Tests the full security flow end-to-end.\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdtemp, rm, readFile } from 'node:fs/promises';\n   9→import { join } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→import {\n  12→  checkCommandPermission,\n  13→  getUserRole,\n  14→  isAdmin,\n  15→  setConfigForTesting,\n  16→  resetConfig as resetPermConfig\n  17→} from '../../src/security/permission-guard.js';\n  18→import {\n  19→  createConfirmation,\n  20→  checkConfirmation,\n  21→  confirmAction,\n  22→  cancelConfirmation,\n  23→  clearExpiredConfirmations\n  24→} from '../../src/security/confirmation-manager.js';\n  25→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n  26→import {\n  27→  initAuditLogService,\n  28→  logAuditEntry,\n  29→  queryAuditLogs,\n  30→  resetAuditLogService\n  31→} from '../../src/services/audit-log-service.js';\n  32→\n  33→let tempDir;\n  34→\n  35→// Helper to create test config\n  36→function createTestConfig(overrides = {}) {\n  37→  return {\n  38→    userPermissions: new Map(),\n  39→    allowAdminSkipConfirm: true,\n  40→    enableSystemExec: false,\n  41→    allowedUserIds: new Set(),\n  42→    ...overrides\n  43→  };\n  44→}\n  45→\n  46→test.before(async () => {\n  47→  tempDir = await mkdtemp(join(tmpdir(), 'security-integration-'));\n  48→});\n  49→\n  50→test.after(async () => {\n  51→  if (tempDir) {\n  52→    await rm(tempDir, { recursive: true, force: true });\n  53→  }\n  54→});\n  55→\n  56→test.beforeEach(() => {\n  57→  resetPermConfig();\n  58→  resetAuditLogService();\n  59→  clearExpiredConfirmations();\n  60→});\n  61→\n  62→test.afterEach(() => {\n  63→  resetPermConfig();\n  64→  resetAuditLogService();\n  65→  clearExpiredConfirmations();\n  66→});\n  67→\n  68→// US-1: User Permission Levels\n  69→test('US-1: User permission levels work correctly', async () => {\n  70→  const config = createTestConfig();\n  71→  config.userPermissions.set('admin-user', 'admin');\n  72→  config.userPermissions.set('op-user', 'operator');\n  73→  config.userPermissions.set('viewer-user', 'viewer');\n  74→  setConfigForTesting(config);\n  75→\n  76→  // Test role retrieval\n  77→  assert.equal(getUserRole('admin-user'), 'admin');\n  78→  assert.equal(getUserRole('op-user'), 'operator');\n  79→  assert.equal(getUserRole('viewer-user'), 'viewer');\n  80→  assert.equal(getUserRole('unknown-user'), 'operator'); // Default\n  81→\n  82→  // Test isAdmin\n  83→  assert.equal(isAdmin('admin-user'), true);\n  84→  assert.equal(isAdmin('op-user'), false);\n  85→  assert.equal(isAdmin('viewer-user'), false);\n  86→});\n  87→\n  88→// US-2: High-Risk Command Authorization\n  89→test('US-2: High-risk command authorization works correctly', async () => {\n  90→  const config = createTestConfig();\n  91→  config.userPermissions.set('admin-user', 'admin');\n  92→  config.userPermissions.set('op-user', 'operator');\n  93→  config.userPermissions.set('viewer-user', 'viewer');\n  94→  setConfigForTesting(config);\n  95→\n  96→  // stop command - admin only\n  97→  const adminStopResult = checkCommandPermission('admin-user', 'stop');\n  98→  assert.equal(adminStopResult.allowed, true);\n  99→  assert.equal(adminStopResult.requiresConfirmation, true);\n 100→\n 101→  const opStopResult = checkCommandPermission('op-user', 'stop');\n 102→  assert.equal(opStopResult.allowed, false);\n 103→\n 104→  // retry command - operator level\n 105→  const opRetryResult = checkCommandPermission('op-user', 'retry');\n 106→  assert.equal(opRetryResult.allowed, true);\n 107→  assert.equal(opRetryResult.requiresConfirmation, false);\n 108→\n 109→  const viewerRetryResult = checkCommandPermission('viewer-user', 'retry');\n 110→  assert.equal(viewerRetryResult.allowed, false);\n 111→});\n 112→\n 113→// US-3: Parameter Sanitization\n 114→test('US-3: Parameter sanitization works correctly', async () => {\n 115→  // Valid input passes\n 116→  const validResult = sanitizeParam('my-feature-123', { maxLength: 100 });\n 117→  assert.equal(validResult.ok, true);\n 118→\n 119→  // Dangerous patterns are blocked\n 120→  const traversalResult = sanitizeParam('../../../etc/passwd');\n 121→  assert.equal(traversalResult.ok, false);\n 122→\n 123→  const shellInjectionResult = sanitizeParam('$(whoami)');\n 124→  assert.equal(shellInjectionResult.ok, false);\n 125→\n 126→  // TargetId format validation\n 127→  const validTargetId = sanitizeParam('feature-branch_123', { isTargetId: true });\n 128→  assert.equal(validTargetId.ok, true);\n 129→\n 130→  const invalidTargetId = sanitizeParam('feature/branch', { isTargetId: true });\n 131→  assert.equal(invalidTargetId.ok, false);\n 132→\n 133→  // Path validation\n 134→  const validPath = validatePath('/project/src/file.js', ['/project']);\n 135→  assert.equal(validPath.ok, true);\n 136→\n 137→  const invalidPath = validatePath('/etc/passwd', ['/project']);\n 138→  assert.equal(invalidPath.ok, false);\n 139→});\n 140→\n 141→// US-4: Confirmation Flow\n 142→test('US-4: Confirmation flow works correctly', async () => {\n 143→  // Create confirmation\n 144→  const { confirmId, message } = createConfirmation('test-user', 'stop', { type: 'feature' });\n 145→  assert.ok(confirmId);\n 146→  assert.ok(message);\n 147→\n 148→  // Check pending status\n 149→  const pendingResult = checkConfirmation(confirmId, 'test-user');\n 150→  assert.equal(pendingResult.status, 'pending');\n 151→  assert.equal(pendingResult.action, 'stop');\n 152→\n 153→  // Confirm action\n 154→  const confirmResult = confirmAction(confirmId, 'test-user');\n 155→  assert.equal(confirmResult.ok, true);\n 156→  assert.equal(confirmResult.action, 'stop');\n 157→\n 158→  // Verify consumed\n 159→  const consumedResult = checkConfirmation(confirmId, 'test-user');\n 160→  assert.equal(consumedResult.status, 'not_found');\n 161→});\n 162→\n 163→test('US-4: Confirmation cancel works correctly', () => {\n 164→  const { confirmId } = createConfirmation('test-user', 'reset', {});\n 165→\n 166→  cancelConfirmation(confirmId, 'test-user');\n 167→\n 168→  const result = checkConfirmation(confirmId, 'test-user');\n 169→  assert.equal(result.status, 'not_found');\n 170→});\n 171→\n 172→test('US-4: Wrong user cannot confirm', () => {\n 173→  const { confirmId } = createConfirmation('user-1', 'stop', {});\n 174→\n 175→  const result = confirmAction(confirmId, 'user-2');\n 176→  assert.equal(result.ok, false);\n 177→});\n 178→\n 179→// US-5: Audit Logging\n 180→test('US-5: Audit logging works correctly', async () => {\n 181→  await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 182→\n 183→  // Log entry\n 184→  await logAuditEntry({\n 185→    userId: '123456789',\n 186→    action: 'stop',\n 187→    params: { type: 'feature' },\n 188→    result: 'success'\n 189→  });\n 190→\n 191→  // Query logs\n 192→  const entries = await queryAuditLogs({ userId: '123456789' });\n 193→  assert.ok(entries.length >= 1);\n 194→\n 195→  const entry = entries.find((e) => e.action === 'stop');\n 196→  assert.ok(entry);\n 197→  assert.equal(entry.userId, '123456789');\n 198→  assert.equal(entry.result, 'success');\n 199→});\n 200→\n 201→test('US-5: Audit log query filters work', async () => {\n 202→  await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 203→\n 204→  await logAuditEntry({ userId: 'user-1', action: 'stop', params: {}, result: 'success' });\n 205→  await logAuditEntry({ userId: 'user-1', action: 'reset', params: {}, result: 'success' });\n 206→  await logAuditEntry({ userId: 'user-2', action: 'stop', params: {}, result: 'denied' });\n 207→\n 208→  const user1Entries = await queryAuditLogs({ userId: 'user-1' });\n 209→  assert.ok(user1Entries.every((e) => e.userId === 'user-1'));\n 210→\n 211→  const stopEntries = await queryAuditLogs({ action: 'stop' });\n 212→  assert.ok(stopEntries.every((e) => e.action === 'stop'));\n 213→});\n 214→\n 215→// F-001: force-unlock command\n 216→test('F-001: force-unlock command requires admin and confirmation', async () => {\n 217→  const config = createTestConfig();\n 218→  config.userPermissions.set('admin-user', 'admin');\n 219→  config.userPermissions.set('op-user', 'operator');\n 220→  setConfigForTesting(config);\n 221→\n 222→  const adminResult = checkCommandPermission('admin-user', 'force-unlock');\n 223→  assert.equal(adminResult.allowed, true);\n 224→  assert.equal(adminResult.requiresConfirmation, true);\n 225→\n 226→  const opResult = checkCommandPermission('op-user', 'force-unlock');\n 227→  assert.equal(opResult.allowed, false);\n 228→});\n 229→\n 230→// F-002: exec command with ENABLE_SYSTEM_EXEC\n 231→test('F-002: exec command requires ENABLE_SYSTEM_EXEC', async () => {\n 232→  const config = createTestConfig({ enableSystemExec: false });\n 233→  config.userPermissions.set('admin-user', 'admin');\n 234→  setConfigForTesting(config);\n 235→\n 236→  const disabledResult = checkCommandPermission('admin-user', 'exec');\n 237→  assert.equal(disabledResult.allowed, false);\n 238→  assert.ok(disabledResult.reason.includes('系统命令执行未启用'));\n 239→\n 240→  // Enable system exec\n 241→  config.enableSystemExec = true;\n 242→  setConfigForTesting(config);\n 243→\n 244→  const enabledResult = checkCommandPermission('admin-user', 'exec');\n 245→  assert.equal(enabledResult.allowed, true);\n 246→});\n 247→\n 248→// Full flow test: Operator stop flow (should be denied)\n 249→test('Integration: Operator cannot execute stop command', async () => {\n 250→  const config = createTestConfig();\n 251→  config.userPermissions.set('op-user', 'operator');\n 252→  setConfigForTesting(config);\n 253→\n 254→  const result = checkCommandPermission('op-user', 'stop');\n 255→  assert.equal(result.allowed, false);\n 256→\n 257→  // Log denial\n 258→  await initAuditLogService({ logDir: tempDir });\n 259→  await logAuditEntry({\n 260→    userId: 'op-user',\n 261→    action: 'stop',\n 262→    params: {},\n 263→    result: 'denied',\n 264→    reason: result.reason\n 265→  });\n 266→\n 267→  const entries = await queryAuditLogs({ action: 'stop', userId: 'op-user' });\n 268→  assert.ok(entries.some((e) => e.result === 'denied'));\n 269→});\n 270→\n 271→// Full flow test: Admin stop with confirmation\n 272→test('Integration: Admin stop with confirmation flow', async () => {\n 273→  const config = createTestConfig();\n 274→  config.userPermissions.set('admin-user', 'admin');\n 275→  setConfigForTesting(config);\n 276→\n 277→  // 1. Check permission\n 278→  const permResult = checkCommandPermission('admin-user', 'stop');\n 279→  assert.equal(permResult.allowed, true);\n 280→  assert.equal(permResult.requiresConfirmation, true);\n 281→\n 282→  // 2. Create confirmation\n 283→  const { confirmId } = createConfirmation('admin-user', 'stop', { type: 'feature' });\n 284→\n 285→  // 3. Confirm\n 286→  const confirmResult = confirmAction(confirmId, 'admin-user');\n 287→  assert.equal(confirmResult.ok, true);\n 288→\n 289→  // 4. Log success\n 290→  await initAuditLogService({ logDir: tempDir });\n 291→  await logAuditEntry({\n 292→    userId: 'admin-user',\n 293→    action: 'stop',\n 294→    params: { type: 'feature' },\n 295→    result: 'success'\n 296→  });\n 297→\n 298→  const entries = await queryAuditLogs({ userId: 'admin-user', action: 'stop' });\n 299→  assert.ok(entries.some((e) => e.result === 'success'));\n 300→});\n 301→\n 302→// AC-2.5: Error message security\n 303→test('AC-2.5: Error messages do not expose sensitive info', async () => {\n 304→  const config = createTestConfig();\n 305→  config.userPermissions.set('viewer-user', 'viewer');\n 306→  setConfigForTesting(config);\n 307→\n 308→  const result = checkCommandPermission('viewer-user', 'stop');\n 309→  assert.equal(result.allowed, false);\n 310→  assert.ok(!result.reason.includes('/'));\n 311→  assert.ok(!result.reason.includes('config'));\n 312→  assert.ok(!result.reason.includes('password'));\n 313→});\n 314→\n 315→// NFR-1: Performance\n 316→test('NFR-1: Permission check is fast', () => {\n 317→  const config = createTestConfig();\n 318→  config.userPermissions.set('test-user', 'admin');\n 319→  setConfigForTesting(config);\n 320→\n 321→  const start = Date.now();\n 322→  for (let i = 0; i < 1000; i++) {\n 323→    checkCommandPermission('test-user', 'stop');\n 324→  }\n 325→  const duration = Date.now() - start;\n 326→\n 327→  // 1000 checks should take < 50ms total (< 0.05ms per check, well under 5ms requirement)\n 328→  assert.ok(duration < 50, `Permission check too slow: ${duration}ms for 1000 checks`);\n 329→});\n 330→\n 331→test('NFR-1: Param sanitization is fast', () => {\n 332→  const start = Date.now();\n 333→  for (let i = 0; i < 1000; i++) {\n 334→    sanitizeParam('test-input-with-moderate-length', { maxLength: 100 });\n 335→  }\n 336→  const duration = Date.now() - start;\n 337→\n 338→  // 1000 sanitizations should take < 20ms total (< 0.02ms per check, well under 2ms requirement)\n 339→  assert.ok(duration < 20, `Sanitization too slow: ${duration}ms for 1000 checks`);\n 340→});\n 341→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeaa8531c8dfab16958d2e20c699","__timestamp":"2026-03-11T20:53:35.268Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"assistant","uuid":"20260312045335af62389f26134c73","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"id":"20260312045335af62389f26134c73","content":[{"type":"tool_use","id":"call_1d1e3f4ae70049d68e110755","name":"Write","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/security-flow.test.js","content":"/**\n * Integration Test for F-006: Safety and Permission Guard\n * Tests the full security flow end-to-end.\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport { mkdtemp, rm } from 'node:fs/promises';\nimport { join } from 'node:path';\nimport { tmpdir } from 'node:os';\nimport {\n  checkCommandPermission,\n  getUserRole,\n  isAdmin,\n  setConfigForTesting,\n  resetConfig as resetPermConfig\n} from '../../src/security/permission-guard.js';\nimport {\n  createConfirmation,\n  checkConfirmation,\n  confirmAction,\n  cancelConfirmation,\n  clearExpiredConfirmations\n} from '../../src/security/confirmation-manager.js';\nimport { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\nimport {\n  initAuditLogService,\n  logAuditEntry,\n  queryAuditLogs,\n  resetAuditLogService\n} from '../../src/services/audit-log-service.js';\n\n// Helper to create test config\nfunction createTestConfig(overrides = {}) {\n  return {\n    userPermissions: new Map(),\n    allowAdminSkipConfirm: true,\n    enableSystemExec: false,\n    allowedUserIds: new Set(),\n    ...overrides\n  };\n}\n\n// Helper to create temp directory for audit log tests\nasync function withTempDir(fn) {\n  const tempDir = await mkdtemp(join(tmpdir(), 'security-integration-'));\n  try {\n    return await fn(tempDir);\n  } finally {\n    await rm(tempDir, { recursive: true, force: true });\n  }\n}\n\n// US-1: User Permission Levels\ntest('US-1: User permission levels work correctly', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const config = createTestConfig();\n  config.userPermissions.set('admin-user', 'admin');\n  config.userPermissions.set('op-user', 'operator');\n  config.userPermissions.set('viewer-user', 'viewer');\n  setConfigForTesting(config);\n\n  // Test role retrieval\n  assert.equal(getUserRole('admin-user'), 'admin');\n  assert.equal(getUserRole('op-user'), 'operator');\n  assert.equal(getUserRole('viewer-user'), 'viewer');\n  assert.equal(getUserRole('unknown-user'), 'operator'); // Default\n\n  // Test isAdmin\n  assert.equal(isAdmin('admin-user'), true);\n  assert.equal(isAdmin('op-user'), false);\n  assert.equal(isAdmin('viewer-user'), false);\n});\n\n// US-2: High-Risk Command Authorization\ntest('US-2: High-risk command authorization works correctly', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const config = createTestConfig();\n  config.userPermissions.set('admin-user', 'admin');\n  config.userPermissions.set('op-user', 'operator');\n  config.userPermissions.set('viewer-user', 'viewer');\n  setConfigForTesting(config);\n\n  // stop command - admin only\n  const adminStopResult = checkCommandPermission('admin-user', 'stop');\n  assert.equal(adminStopResult.allowed, true);\n  assert.equal(adminStopResult.requiresConfirmation, true);\n\n  const opStopResult = checkCommandPermission('op-user', 'stop');\n  assert.equal(opStopResult.allowed, false);\n\n  // retry command - operator level\n  const opRetryResult = checkCommandPermission('op-user', 'retry');\n  assert.equal(opRetryResult.allowed, true);\n  assert.equal(opRetryResult.requiresConfirmation, false);\n\n  const viewerRetryResult = checkCommandPermission('viewer-user', 'retry');\n  assert.equal(viewerRetryResult.allowed, false);\n});\n\n// US-3: Parameter Sanitization\ntest('US-3: Parameter sanitization works correctly', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  // Valid input passes\n  const validResult = sanitizeParam('my-feature-123', { maxLength: 100 });\n  assert.equal(validResult.ok, true);\n\n  // Dangerous patterns are blocked\n  const traversalResult = sanitizeParam('../../../etc/passwd');\n  assert.equal(traversalResult.ok, false);\n\n  const shellInjectionResult = sanitizeParam('$(whoami)');\n  assert.equal(shellInjectionResult.ok, false);\n\n  // TargetId format validation\n  const validTargetId = sanitizeParam('feature-branch_123', { isTargetId: true });\n  assert.equal(validTargetId.ok, true);\n\n  const invalidTargetId = sanitizeParam('feature/branch', { isTargetId: true });\n  assert.equal(invalidTargetId.ok, false);\n\n  // Path validation\n  const validPath = validatePath('/project/src/file.js', ['/project']);\n  assert.equal(validPath.ok, true);\n\n  const invalidPath = validatePath('/etc/passwd', ['/project']);\n  assert.equal(invalidPath.ok, false);\n});\n\n// US-4: Confirmation Flow\ntest('US-4: Confirmation flow works correctly', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  // Create confirmation\n  const { confirmId, message } = createConfirmation('test-user', 'stop', { type: 'feature' });\n  assert.ok(confirmId);\n  assert.ok(message);\n\n  // Check pending status\n  const pendingResult = checkConfirmation(confirmId, 'test-user');\n  assert.equal(pendingResult.status, 'pending');\n  assert.equal(pendingResult.action, 'stop');\n\n  // Confirm action\n  const confirmResult = confirmAction(confirmId, 'test-user');\n  assert.equal(confirmResult.ok, true);\n  assert.equal(confirmResult.action, 'stop');\n\n  // Verify consumed\n  const consumedResult = checkConfirmation(confirmId, 'test-user');\n  assert.equal(consumedResult.status, 'not_found');\n});\n\ntest('US-4: Confirmation cancel works correctly', () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const { confirmId } = createConfirmation('test-user', 'reset', {});\n\n  cancelConfirmation(confirmId, 'test-user');\n\n  const result = checkConfirmation(confirmId, 'test-user');\n  assert.equal(result.status, 'not_found');\n});\n\ntest('US-4: Wrong user cannot confirm', () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const { confirmId } = createConfirmation('user-1', 'stop', {});\n\n  const result = confirmAction(confirmId, 'user-2');\n  assert.equal(result.ok, false);\n});\n\n// US-5: Audit Logging\ntest('US-5: Audit logging works correctly', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  await withTempDir(async (tempDir) => {\n    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n\n    // Log entry\n    await logAuditEntry({\n      userId: '123456789',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'success'\n    });\n\n    // Query logs\n    const entries = await queryAuditLogs({ userId: '123456789' });\n    assert.ok(entries.length >= 1);\n\n    const entry = entries.find((e) => e.action === 'stop');\n    assert.ok(entry);\n    assert.equal(entry.userId, '123456789');\n    assert.equal(entry.result, 'success');\n  });\n});\n\ntest('US-5: Audit log query filters work', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  await withTempDir(async (tempDir) => {\n    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n\n    await logAuditEntry({ userId: 'user-1', action: 'stop', params: {}, result: 'success' });\n    await logAuditEntry({ userId: 'user-1', action: 'reset', params: {}, result: 'success' });\n    await logAuditEntry({ userId: 'user-2', action: 'stop', params: {}, result: 'denied' });\n\n    const user1Entries = await queryAuditLogs({ userId: 'user-1' });\n    assert.ok(user1Entries.every((e) => e.userId === 'user-1'));\n\n    const stopEntries = await queryAuditLogs({ action: 'stop' });\n    assert.ok(stopEntries.every((e) => e.action === 'stop'));\n  });\n});\n\n// F-001: force-unlock command\ntest('F-001: force-unlock command requires admin and confirmation', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const config = createTestConfig();\n  config.userPermissions.set('admin-user', 'admin');\n  config.userPermissions.set('op-user', 'operator');\n  setConfigForTesting(config);\n\n  const adminResult = checkCommandPermission('admin-user', 'force-unlock');\n  assert.equal(adminResult.allowed, true);\n  assert.equal(adminResult.requiresConfirmation, true);\n\n  const opResult = checkCommandPermission('op-user', 'force-unlock');\n  assert.equal(opResult.allowed, false);\n});\n\n// F-002: exec command with ENABLE_SYSTEM_EXEC\ntest('F-002: exec command requires ENABLE_SYSTEM_EXEC', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const config = createTestConfig({ enableSystemExec: false });\n  config.userPermissions.set('admin-user', 'admin');\n  setConfigForTesting(config);\n\n  const disabledResult = checkCommandPermission('admin-user', 'exec');\n  assert.equal(disabledResult.allowed, false);\n  assert.ok(disabledResult.reason.includes('系统命令执行未启用'));\n\n  // Enable system exec\n  config.enableSystemExec = true;\n  setConfigForTesting(config);\n\n  const enabledResult = checkCommandPermission('admin-user', 'exec');\n  assert.equal(enabledResult.allowed, true);\n});\n\n// Full flow test: Operator stop flow (should be denied)\ntest('Integration: Operator cannot execute stop command', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  await withTempDir(async (tempDir) => {\n    const config = createTestConfig();\n    config.userPermissions.set('op-user', 'operator');\n    setConfigForTesting(config);\n\n    const result = checkCommandPermission('op-user', 'stop');\n    assert.equal(result.allowed, false);\n\n    // Log denial\n    await initAuditLogService({ logDir: tempDir });\n    await logAuditEntry({\n      userId: 'op-user',\n      action: 'stop',\n      params: {},\n      result: 'denied',\n      reason: result.reason\n    });\n\n    const entries = await queryAuditLogs({ action: 'stop', userId: 'op-user' });\n    assert.ok(entries.some((e) => e.result === 'denied'));\n  });\n});\n\n// Full flow test: Admin stop with confirmation\ntest('Integration: Admin stop with confirmation flow', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  await withTempDir(async (tempDir) => {\n    const config = createTestConfig();\n    config.userPermissions.set('admin-user', 'admin');\n    setConfigForTesting(config);\n\n    // 1. Check permission\n    const permResult = checkCommandPermission('admin-user', 'stop');\n    assert.equal(permResult.allowed, true);\n    assert.equal(permResult.requiresConfirmation, true);\n\n    // 2. Create confirmation\n    const { confirmId } = createConfirmation('admin-user', 'stop', { type: 'feature' });\n\n    // 3. Confirm\n    const confirmResult = confirmAction(confirmId, 'admin-user');\n    assert.equal(confirmResult.ok, true);\n\n    // 4. Log success\n    await initAuditLogService({ logDir: tempDir });\n    await logAuditEntry({\n      userId: 'admin-user',\n      action: 'stop',\n      params: { type: 'feature' },\n      result: 'success'\n    });\n\n    const entries = await queryAuditLogs({ userId: 'admin-user', action: 'stop' });\n    assert.ok(entries.some((e) => e.result === 'success'));\n  });\n});\n\n// AC-2.5: Error message security\ntest('AC-2.5: Error messages do not expose sensitive info', async () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const config = createTestConfig();\n  config.userPermissions.set('viewer-user', 'viewer');\n  setConfigForTesting(config);\n\n  const result = checkCommandPermission('viewer-user', 'stop');\n  assert.equal(result.allowed, false);\n  assert.ok(!result.reason.includes('/'));\n  assert.ok(!result.reason.includes('config'));\n  assert.ok(!result.reason.includes('password'));\n});\n\n// NFR-1: Performance\ntest('NFR-1: Permission check is fast', () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const config = createTestConfig();\n  config.userPermissions.set('test-user', 'admin');\n  setConfigForTesting(config);\n\n  const start = Date.now();\n  for (let i = 0; i < 1000; i++) {\n    checkCommandPermission('test-user', 'stop');\n  }\n  const duration = Date.now() - start;\n\n  // 1000 checks should take < 50ms total (< 0.05ms per check, well under 5ms requirement)\n  assert.ok(duration < 50, `Permission check too slow: ${duration}ms for 1000 checks`);\n});\n\ntest('NFR-1: Param sanitization is fast', () => {\n  resetPermConfig();\n  resetAuditLogService();\n  clearExpiredConfirmations();\n\n  const start = Date.now();\n  for (let i = 0; i < 1000; i++) {\n    sanitizeParam('test-input-with-moderate-length', { maxLength: 100 });\n  }\n  const duration = Date.now() - start;\n\n  // 1000 sanitizations should take < 20ms total (< 0.02ms per check, well under 2ms requirement)\n  assert.ok(duration < 20, `Sanitization too slow: ${duration}ms for 1000 checks`);\n});\n"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":46691,"output_tokens":3147,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdeaa8531c8dfab16958d2e20c699","__timestamp":"2026-03-11T20:54:27.217Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
