{"type":"user","uuid":"040792ba-bf9c-428b-a035-89cd72d1b07b","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_d38e39d1427b4d3da1cb2d43","content":[{"type":"text","text":"   1→/**\n   2→ * Stop Command Handler\n   3→ * Handles /stop command to stop running pipelines.\n   4→ * F-006: Integrated with security guard\n   5→ */\n   6→\n   7→import { stopPipeline } from '../../../services/pipeline-controller.js';\n   8→import { logAuditEntry } from '../../../services/audit-log-service.js';\n   9→import {\n  10→  createConfirmation,\n  11→  checkConfirmation,\n  12→  confirmAction,\n  13→  cancelConfirmation\n  14→} from '../../../security/confirmation-manager.js';\n  15→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n  16→import { isAdmin } from '../../../security/permission-guard.js';\n  17→\n  18→// Store pending confirmations for text-based flow\n  19→const pendingConfirmations = new Map();\n  20→\n  21→/**\n  22→ * Stop command metadata.\n  23→ * T-102: minRole added\n  24→ */\n  25→export const stopMeta = {\n  26→  name: 'stop',\n  27→  aliases: [],\n  28→  description: '停止运行中的管道',\n  29→  usage: '/stop [target]',\n  30→  examples: ['/stop', '/stop my-feature'],\n  31→  params: [\n  32→    {\n  33→      name: 'target',\n  34→      type: 'string',\n  35→      required: false,\n  36→      description: '目标标识符'\n  37→    }\n  38→  ],\n  39→  requiresAuth: true,\n  40→  minRole: 'admin',\n  41→  helpText: '/stop [target] - 停止运行中的管道'\n  42→};\n  43→\n  44→/**\n  45→ * Handle stop command.\n  46→ * T-104, T-106: Added confirmation flow\n  47→ * @param {Object} handlerCtx - Handler context\n  48→ */\n  49→export async function handleStop(handlerCtx) {\n  50→  const { params, reply, userId, userRole, requiresConfirmation, parsed } = handlerCtx;\n  51→\n  52→  // Sanitize target parameter\n  53→  const rawTarget = params._args?.[0] || params.target;\n  54→  const typeResult = sanitizeParam(params.type || 'feature', { maxLength: 50, isTargetId: false });\n  55→  if (!typeResult.ok) {\n  56→    await reply(`❌ 参数无效: ${typeResult.error}`);\n  57→    return;\n  58→  }\n  59→  const pipelineType = typeResult.value;\n  60→\n  61→  // Check if force flag is set (AC-4.4: --force skips confirmation for admin)\n  62→  const forceFlag = params.force === true || parsed?.flags?.force === true;\n  63→  const canSkipConfirmation = isAdmin(userId) && forceFlag;\n  64→\n  65→  // Handle confirmation flow (AC-4.1)\n  66→  if (requiresConfirmation && !canSkipConfirmation) {\n  67→    // Check if this is a CONFIRM response\n  68→    if (rawTarget === 'CONFIRM') {\n  69→      const pendingKey = `stop:${userId}`;\n  70→      const confirmId = pendingConfirmations.get(pendingKey);\n  71→\n  72→      if (confirmId) {\n  73→        const result = confirmAction(confirmId, userId);\n  74→        if (result.ok) {\n  75→          pendingConfirmations.delete(pendingKey);\n  76→          await executeStop(handlerCtx, result.params.type, userId, reply);\n  77→        } else {\n  78→          await reply(`❌ 确认失败: ${result.error}`);\n  79→        }\n  80→        return;\n  81→      } else {\n  82→        await reply('❌ 没有待确认的 stop 操作，或操作已过期。');\n  83→        return;\n  84→      }\n  85→    }\n  86→\n  87→    // Check if this is a CANCEL response\n  88→    if (rawTarget === 'CANCEL') {\n  89→      const pendingKey = `stop:${userId}`;\n  90→      const confirmId = pendingConfirmations.get(pendingKey);\n  91→      if (confirmId) {\n  92→        cancelConfirmation(confirmId, userId);\n  93→        pendingConfirmations.delete(pendingKey);\n  94→        await reply('✅ 已取消 stop 操作。');\n  95→      } else {\n  96→        await reply('没有待确认的 stop 操作。');\n  97→      }\n  98→      return;\n  99→    }\n 100→\n 101→    // Create new confirmation\n 102→    const { confirmId, message } = createConfirmation(userId, 'stop', { type: pipelineType });\n 103→    pendingConfirmations.set(`stop:${userId}`, confirmId);\n 104→\n 105→    await reply(`⚠️ 高风险操作确认\\n\\n${message}\\n\\n请回复 /stop CONFIRM 确认，或 /stop CANCEL 取消。`);\n 106→    return;\n 107→  }\n 108→\n 109→  // Execute directly (admin with --force or no confirmation required)\n 110→  await executeStop(handlerCtx, pipelineType, userId, reply);\n 111→}\n 112→\n 113→/**\n 114→ * Execute stop operation\n 115→ */\n 116→async function executeStop(handlerCtx, pipelineType, userId, reply) {\n 117→  try {\n 118→    const result = await stopPipeline({ type: pipelineType });\n 119→\n 120→    if (result.ok) {\n 121→      await logAuditEntry({\n 122→        userId,\n 123→        action: 'stop',\n 124→        params: { type: pipelineType },\n 125→        result: 'success'\n 126→      });\n 127→\n 128→      if (result.errorCode === 'ALREADY_STOPPED') {\n 129→        await reply('⚠️ 没有运行中的管道。');\n 130→      } else {\n 131→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n 132→        await reply(`✅ 已停止管道${pidInfo}。`);\n 133→      }\n 134→    } else {\n 135→      await logAuditEntry({\n 136→        userId,\n 137→        action: 'stop',\n 138→        params: { type: pipelineType },\n 139→        result: 'failed',\n 140→        reason: result.message\n 141→      });\n 142→      await reply(`❌ 停止失败: ${result.message || '未知错误'}`);\n 143→    }\n 144→  } catch (error) {\n 145→    await logAuditEntry({\n 146→      userId,\n 147→      action: 'stop',\n 148→      params: { type: pipelineType },\n 149→      result: 'failed',\n 150→      reason: error.message\n 151→    });\n 152→    await reply(`❌ 停止失败: ${error.message}`);\n 153→  }\n 154→}\n 155→\n 156→export default handleStop;\n 157→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdea0a0f2071162982668050dfc81","__timestamp":"2026-03-11T20:42:48.406Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
