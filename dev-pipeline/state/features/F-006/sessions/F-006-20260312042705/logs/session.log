{"type":"user","uuid":"4f6b1a38-83b9-4e7b-a873-37b761881a42","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_ffa2f84530824710bfd4ab27","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for permission-guard.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import {\n   9→  getUserRole,\n  10→  checkCommandPermission,\n  11→  isAdmin,\n  12→  ROLE_HIERARCHY,\n  13→  setConfigForTesting,\n  14→  resetConfig\n  15→} from '../../src/security/permission-guard.js';\n  16→\n  17→// Helper to create test config\n  18→function createTestConfig(overrides = {}) {\n  19→  return {\n  20→    userPermissions: new Map(),\n  21→    allowAdminSkipConfirm: true,\n  22→    enableSystemExec: false,\n  23→    allowedUserIds: new Set(),\n  24→    ...overrides\n  25→  };\n  26→}\n  27→\n  28→// ROLE_HIERARCHY tests\n  29→test('ROLE_HIERARCHY defines correct hierarchy levels', () => {\n  30→  resetConfig();\n  31→  assert.equal(ROLE_HIERARCHY.viewer, 0);\n  32→  assert.equal(ROLE_HIERARCHY.operator, 1);\n  33→  assert.equal(ROLE_HIERARCHY.admin, 2);\n  34→});\n  35→\n  36→// getUserRole tests\n  37→test('getUserRole returns admin for configured admin user', () => {\n  38→  resetConfig();\n  39→  const config = createTestConfig();\n  40→  config.userPermissions.set('123456789', 'admin');\n  41→  setConfigForTesting(config);\n  42→\n  43→  assert.equal(getUserRole('123456789'), 'admin');\n  44→});\n  45→\n  46→test('getUserRole returns operator for configured operator user', () => {\n  47→  resetConfig();\n  48→  const config = createTestConfig();\n  49→  config.userPermissions.set('987654321', 'operator');\n  50→  setConfigForTesting(config);\n  51→\n  52→  assert.equal(getUserRole('987654321'), 'operator');\n  53→});\n  54→\n  55→test('getUserRole returns viewer for configured viewer user', () => {\n  56→  resetConfig();\n  57→  const config = createTestConfig();\n  58→  config.userPermissions.set('111222333', 'viewer');\n  59→  setConfigForTesting(config);\n  60→\n  61→  assert.equal(getUserRole('111222333'), 'viewer');\n  62→});\n  63→\n  64→test('getUserRole returns operator as default for unknown users (AC-1.3)', () => {\n  65→  resetConfig();\n  66→  setConfigForTesting(createTestConfig());\n  67→  assert.equal(getUserRole('unknown-user'), 'operator');\n  68→});\n  69→\n  70→test('getUserRole handles numeric userId', () => {\n  71→  resetConfig();\n  72→  const config = createTestConfig();\n  73→  config.userPermissions.set('123456789', 'admin');\n  74→  setConfigForTesting(config);\n  75→\n  76→  assert.equal(getUserRole(123456789), 'admin');\n  77→});\n  78→\n  79→// isAdmin tests\n  80→test('isAdmin returns true for admin user', () => {\n  81→  resetConfig();\n  82→  const config = createTestConfig();\n  83→  config.userPermissions.set('123456789', 'admin');\n  84→  setConfigForTesting(config);\n  85→\n  86→  assert.equal(isAdmin('123456789'), true);\n  87→});\n  88→\n  89→test('isAdmin returns false for operator user', () => {\n  90→  resetConfig();\n  91→  const config = createTestConfig();\n  92→  config.userPermissions.set('987654321', 'operator');\n  93→  setConfigForTesting(config);\n  94→\n  95→  assert.equal(isAdmin('987654321'), false);\n  96→});\n  97→\n  98→test('isAdmin returns false for viewer user', () => {\n  99→  resetConfig();\n 100→  const config = createTestConfig();\n 101→  config.userPermissions.set('111222333', 'viewer');\n 102→  setConfigForTesting(config);\n 103→\n 104→  assert.equal(isAdmin('111222333'), false);\n 105→});\n 106→\n 107→test('isAdmin returns false for unknown user (default is operator)', () => {\n 108→  resetConfig();\n 109→  setConfigForTesting(createTestConfig());\n 110→  assert.equal(isAdmin('unknown-user'), false);\n 111→});\n 112→\n 113→// checkCommandPermission - status command (viewer)\n 114→test('checkCommandPermission allows viewer to execute status', () => {\n 115→  resetConfig();\n 116→  const config = createTestConfig();\n 117→  config.userPermissions.set('viewer-user', 'viewer');\n 118→  setConfigForTesting(config);\n 119→\n 120→  const result = checkCommandPermission('viewer-user', 'status');\n 121→  assert.equal(result.allowed, true);\n 122→  assert.equal(result.requiresConfirmation, false);\n 123→});\n 124→\n 125→// checkCommandPermission - logs command (viewer)\n 126→test('checkCommandPermission allows viewer to execute logs', () => {\n 127→  resetConfig();\n 128→  const config = createTestConfig();\n 129→  config.userPermissions.set('viewer-user', 'viewer');\n 130→  setConfigForTesting(config);\n 131→\n 132→  const result = checkCommandPermission('viewer-user', 'logs');\n 133→  assert.equal(result.allowed, true);\n 134→  assert.equal(result.requiresConfirmation, false);\n 135→});\n 136→\n 137→// checkCommandPermission - pipeline command (operator)\n 138→test('checkCommandPermission allows operator to execute pipeline', () => {\n 139→  resetConfig();\n 140→  const config = createTestConfig();\n 141→  config.userPermissions.set('op-user', 'operator');\n 142→  setConfigForTesting(config);\n 143→\n 144→  const result = checkCommandPermission('op-user', 'pipeline');\n 145→  assert.equal(result.allowed, true);\n 146→});\n 147→\n 148→test('checkCommandPermission denies viewer for pipeline', () => {\n 149→  resetConfig();\n 150→  const config = createTestConfig();\n 151→  config.userPermissions.set('viewer-user', 'viewer');\n 152→  setConfigForTesting(config);\n 153→\n 154→  const result = checkCommandPermission('viewer-user', 'pipeline');\n 155→  assert.equal(result.allowed, false);\n 156→  assert.ok(result.reason.includes('权限不足'));\n 157→});\n 158→\n 159→// checkCommandPermission - retry command (operator) - AC-2.3\n 160→test('checkCommandPermission allows operator for retry without confirmation', () => {\n 161→  resetConfig();\n 162→  const config = createTestConfig();\n 163→  config.userPermissions.set('op-user', 'operator');\n 164→  setConfigForTesting(config);\n 165→\n 166→  const result = checkCommandPermission('op-user', 'retry');\n 167→  assert.equal(result.allowed, true);\n 168→  assert.equal(result.requiresConfirmation, false);\n 169→});\n 170→\n 171→test('checkCommandPermission denies viewer for retry', () => {\n 172→  resetConfig();\n 173→  const config = createTestConfig();\n 174→  config.userPermissions.set('viewer-user', 'viewer');\n 175→  setConfigForTesting(config);\n 176→\n 177→  const result = checkCommandPermission('viewer-user', 'retry');\n 178→  assert.equal(result.allowed, false);\n 179→});\n 180→\n 181→// checkCommandPermission - stop command (admin) - AC-2.2\n 182→test('checkCommandPermission allows admin for stop with confirmation', () => {\n 183→  resetConfig();\n 184→  const config = createTestConfig();\n 185→  config.userPermissions.set('admin-user', 'admin');\n 186→  setConfigForTesting(config);\n 187→\n 188→  const result = checkCommandPermission('admin-user', 'stop');\n 189→  assert.equal(result.allowed, true);\n 190→  assert.equal(result.requiresConfirmation, true);\n 191→});\n 192→\n 193→test('checkCommandPermission denies operator for stop', () => {\n 194→  resetConfig();\n 195→  const config = createTestConfig();\n 196→  config.userPermissions.set('op-user', 'operator');\n 197→  setConfigForTesting(config);\n 198→\n 199→  const result = checkCommandPermission('op-user', 'stop');\n 200→  assert.equal(result.allowed, false);\n 201→  assert.ok(result.reason.includes('权限不足'));\n 202→});\n 203→\n 204→test('checkCommandPermission denies viewer for stop', () => {\n 205→  resetConfig();\n 206→  const config = createTestConfig();\n 207→  config.userPermissions.set('viewer-user', 'viewer');\n 208→  setConfigForTesting(config);\n 209→\n 210→  const result = checkCommandPermission('viewer-user', 'stop');\n 211→  assert.equal(result.allowed, false);\n 212→});\n 213→\n 214→// checkCommandPermission - reset command (admin) - AC-2.2\n 215→test('checkCommandPermission allows admin for reset with confirmation', () => {\n 216→  resetConfig();\n 217→  const config = createTestConfig();\n 218→  config.userPermissions.set('admin-user', 'admin');\n 219→  setConfigForTesting(config);\n 220→\n 221→  const result = checkCommandPermission('admin-user', 'reset');\n 222→  assert.equal(result.allowed, true);\n 223→  assert.equal(result.requiresConfirmation, true);\n 224→});\n 225→\n 226→test('checkCommandPermission denies operator for reset', () => {\n 227→  resetConfig();\n 228→  const config = createTestConfig();\n 229→  config.userPermissions.set('op-user', 'operator');\n 230→  setConfigForTesting(config);\n 231→\n 232→  const result = checkCommandPermission('op-user', 'reset');\n 233→  assert.equal(result.allowed, false);\n 234→});\n 235→\n 236→// checkCommandPermission - force-unlock command (admin) - F-001\n 237→test('checkCommandPermission requires admin for force-unlock', () => {\n 238→  resetConfig();\n 239→  const config = createTestConfig();\n 240→  config.userPermissions.set('admin-user', 'admin');\n 241→  setConfigForTesting(config);\n 242→\n 243→  const result = checkCommandPermission('admin-user', 'force-unlock');\n 244→  assert.equal(result.allowed, true);\n 245→  assert.equal(result.requiresConfirmation, true);\n 246→});\n 247→\n 248→test('checkCommandPermission denies operator for force-unlock', () => {\n 249→  resetConfig();\n 250→  const config = createTestConfig();\n 251→  config.userPermissions.set('op-user', 'operator');\n 252→  setConfigForTesting(config);\n 253→\n 254→  const result = checkCommandPermission('op-user', 'force-unlock');\n 255→  assert.equal(result.allowed, false);\n 256→  assert.ok(result.reason.includes('权限不足'));\n 257→});\n 258→\n 259→// checkCommandPermission - exec command (admin + ENABLE_SYSTEM_EXEC) - AC-2.4, F-002\n 260→test('checkCommandPermission denies exec when ENABLE_SYSTEM_EXEC is false', () => {\n 261→  resetConfig();\n 262→  const config = createTestConfig({ enableSystemExec: false });\n 263→  config.userPermissions.set('admin-user', 'admin');\n 264→  setConfigForTesting(config);\n 265→\n 266→  const result = checkCommandPermission('admin-user', 'exec');\n 267→  assert.equal(result.allowed, false);\n 268→  assert.ok(result.reason.includes('系统命令执行未启用'));\n 269→});\n 270→\n 271→test('checkCommandPermission allows admin for exec when ENABLE_SYSTEM_EXEC is true', () => {\n 272→  resetConfig();\n 273→  const config = createTestConfig({ enableSystemExec: true });\n 274→  config.userPermissions.set('admin-user', 'admin');\n 275→  setConfigForTesting(config);\n 276→\n 277→  const result = checkCommandPermission('admin-user', 'exec');\n 278→  assert.equal(result.allowed, true);\n 279→  assert.equal(result.requiresConfirmation, false);\n 280→});\n 281→\n 282→test('checkCommandPermission denies operator for exec even when ENABLE_SYSTEM_EXEC is true', () => {\n 283→  resetConfig();\n 284→  const config = createTestConfig({ enableSystemExec: true });\n 285→  config.userPermissions.set('op-user', 'operator');\n 286→  setConfigForTesting(config);\n 287→\n 288→  const result = checkCommandPermission('op-user', 'exec');\n 289→  assert.equal(result.allowed, false);\n 290→});\n 291→\n 292→// checkCommandPermission - unknown command\n 293→test('checkCommandPermission allows unknown command by default (defensive but permissive)', () => {\n 294→  resetConfig();\n 295→  const config = createTestConfig();\n 296→  config.userPermissions.set('op-user', 'operator');\n 297→  setConfigForTesting(config);\n 298→\n 299→  const result = checkCommandPermission('op-user', 'unknown-command');\n 300→  assert.equal(result.allowed, true);\n 301→  assert.equal(result.requiresConfirmation, false);\n 302→});\n 303→\n 304→// error message security - AC-2.5\n 305→test('checkCommandPermission does not expose internal paths in error messages', () => {\n 306→  resetConfig();\n 307→  const config = createTestConfig();\n 308→  config.userPermissions.set('viewer-user', 'viewer');\n 309→  setConfigForTesting(config);\n 310→\n 311→  const result = checkCommandPermission('viewer-user', 'stop');\n 312→  assert.ok(!result.reason.includes('/var/'));\n 313→  assert.ok(!result.reason.includes('/home/'));\n 314→  assert.ok(!result.reason.includes('config'));\n 315→});\n 316→\n 317→test('checkCommandPermission provides unified denial message', () => {\n 318→  resetConfig();\n 319→  const config = createTestConfig();\n 320→  config.userPermissions.set('viewer-user', 'viewer');\n 321→  setConfigForTesting(config);\n 322→\n 323→  const result = checkCommandPermission('viewer-user', 'stop');\n 324→  assert.ok(result.reason.match(/权限不足|未授权/));\n 325→});\n 326→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb0eca880b82916352a46acc4a0","__timestamp":"2026-03-11T20:58:18.228Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"4d9152c0-01af-41ab-bb20-6ce46fa4f7e5","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_e515238d20904d48bbdfdf68","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for param-sanitizer.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n   9→\n  10→// detectDangerousPatterns tests\n  11→test('detectDangerousPatterns detects path traversal (..)', () => {\n  12→  const result = detectDangerousPatterns('../../../etc/passwd');\n  13→  assert.equal(result.safe, false);\n  14→  assert.ok(result.patterns.some((p) => p.includes('path traversal')));\n  15→});\n  16→\n  17→test('detectDangerousPatterns detects shell injection ($)', () => {\n  18→  const result = detectDangerousPatterns('$(whoami)');\n  19→  assert.equal(result.safe, false);\n  20→  assert.ok(result.patterns.length > 0);\n  21→});\n  22→\n  23→test('detectDangerousPatterns detects backticks', () => {\n  24→  const result = detectDangerousPatterns('`id`');\n  25→  assert.equal(result.safe, false);\n  26→});\n  27→\n  28→test('detectDangerousPatterns detects command separator (;)', () => {\n  29→  const result = detectDangerousPatterns('ls; rm -rf /');\n  30→  assert.equal(result.safe, false);\n  31→});\n  32→\n  33→test('detectDangerousPatterns detects command chain (||)', () => {\n  34→  const result = detectDangerousPatterns('test || cat /etc/passwd');\n  35→  assert.equal(result.safe, false);\n  36→});\n  37→\n  38→test('detectDangerousPatterns detects command chain (&&)', () => {\n  39→  const result = detectDangerousPatterns('test && cat /etc/passwd');\n  40→  assert.equal(result.safe, false);\n  41→});\n  42→\n  43→test('detectDangerousPatterns detects home directory (~)', () => {\n  44→  const result = detectDangerousPatterns('~/secret.txt');\n  45→  assert.equal(result.safe, false);\n  46→});\n  47→\n  48→test('detectDangerousPatterns detects --exec flag', () => {\n  49→  const result = detectDangerousPatterns('test --exec');\n  50→  assert.equal(result.safe, false);\n  51→});\n  52→\n  53→test('detectDangerousPatterns detects --eval flag', () => {\n  54→  const result = detectDangerousPatterns('test --eval');\n  55→  assert.equal(result.safe, false);\n  56→});\n  57→\n  58→test('detectDangerousPatterns returns safe for clean input', () => {\n  59→  const result = detectDangerousPatterns('my-feature-branch');\n  60→  assert.equal(result.safe, true);\n  61→  assert.deepEqual(result.patterns, []);\n  62→});\n  63→\n  64→// sanitizeParam tests\n  65→test('sanitizeParam accepts valid string', () => {\n  66→  const result = sanitizeParam('valid-input', { maxLength: 200 });\n  67→  assert.equal(result.ok, true);\n  68→  assert.equal(result.value, 'valid-input');\n  69→});\n  70→\n  71→test('sanitizeParam trims whitespace', () => {\n  72→  const result = sanitizeParam('  trimmed  ', { maxLength: 200 });\n  73→  assert.equal(result.ok, true);\n  74→  assert.equal(result.value, 'trimmed');\n  75→});\n  76→\n  77→test('sanitizeParam rejects empty input', () => {\n  78→  const result = sanitizeParam('', { maxLength: 200 });\n  79→  assert.equal(result.ok, false);\n  80→  assert.ok(result.error);\n  81→});\n  82→\n  83→test('sanitizeParam rejects whitespace-only input', () => {\n  84→  const result = sanitizeParam('   ', { maxLength: 200 });\n  85→  assert.equal(result.ok, false);\n  86→});\n  87→\n  88→test('sanitizeParam enforces max length', () => {\n  89→  const longInput = 'a'.repeat(300);\n  90→  const result = sanitizeParam(longInput, { maxLength: 200 });\n  91→  assert.equal(result.ok, false);\n  92→  assert.ok(result.error.includes('过长'));\n  93→});\n  94→\n  95→test('sanitizeParam uses default max length of 200', () => {\n  96→  const longInput = 'a'.repeat(250);\n  97→  const result = sanitizeParam(longInput);\n  98→  assert.equal(result.ok, false);\n  99→});\n 100→\n 101→test('sanitizeParam rejects dangerous patterns', () => {\n 102→  const result = sanitizeParam('../../../etc/passwd');\n 103→  assert.equal(result.ok, false);\n 104→  assert.ok(result.error);\n 105→});\n 106→\n 107→test('sanitizeParam handles null input', () => {\n 108→  const result = sanitizeParam(null);\n 109→  assert.equal(result.ok, false);\n 110→});\n 111→\n 112→test('sanitizeParam handles undefined input', () => {\n 113→  const result = sanitizeParam(undefined);\n 114→  assert.equal(result.ok, false);\n 115→});\n 116→\n 117→test('sanitizeParam accepts targetId format [A-Za-z0-9_-]+', () => {\n 118→  const result = sanitizeParam('my-feature_123', { maxLength: 100 });\n 119→  assert.equal(result.ok, true);\n 120→  assert.equal(result.value, 'my-feature_123');\n 121→});\n 122→\n 123→// validatePath tests\n 124→test('validatePath accepts path within allowed roots', () => {\n 125→  const result = validatePath('/project/src/file.js', ['/project', '/home']);\n 126→  assert.equal(result.ok, true);\n 127→  assert.ok(result.resolved);\n 128→});\n 129→\n 130→test('validatePath rejects path outside allowed roots', () => {\n 131→  const result = validatePath('/etc/passwd', ['/project', '/home']);\n 132→  assert.equal(result.ok, false);\n 133→  assert.ok(result.error);\n 134→});\n 135→\n 136→test('validatePath rejects path traversal', () => {\n 137→  const result = validatePath('/project/../../../etc/passwd', ['/project']);\n 138→  assert.equal(result.ok, false);\n 139→});\n 140→\n 141→test('validatePath rejects relative path', () => {\n 142→  const result = validatePath('relative/path', ['/project']);\n 143→  assert.equal(result.ok, false);\n 144→});\n 145→\n 146→test('validatePath handles empty path', () => {\n 147→  const result = validatePath('', ['/project']);\n 148→  assert.equal(result.ok, false);\n 149→});\n 150→\n 151→test('validatePath handles null path', () => {\n 152→  const result = validatePath(null, ['/project']);\n 153→  assert.equal(result.ok, false);\n 154→});\n 155→\n 156→// AC-3.1: Path traversal should be rejected\n 157→test('validatePath rejects path traversal with ..', () => {\n 158→  const result = validatePath('/project/./src/../test.js', ['/project']);\n 159→  // Should reject paths containing .. per AC-3.1\n 160→  assert.equal(result.ok, false);\n 161→  assert.ok(result.error.includes('..'));\n 162→});\n 163→\n 164→test('validatePath accepts valid path within root', () => {\n 165→  const result = validatePath('/project/src/test.js', ['/project']);\n 166→  assert.equal(result.ok, true);\n 167→  assert.equal(result.resolved, '/project/src/test.js');\n 168→});\n 169→\n 170→// AC-3.2: targetId parameter only allows [A-Za-z0-9_-]+ format\n 171→test('sanitizeParam with isTargetId rejects invalid characters', () => {\n 172→  const result = sanitizeParam('feature/branch', { isTargetId: true });\n 173→  assert.equal(result.ok, false);\n 174→  assert.ok(result.error.includes('格式无效'));\n 175→});\n 176→\n 177→test('sanitizeParam with isTargetId accepts valid targetId', () => {\n 178→  const result = sanitizeParam('feature-branch_123', { isTargetId: true });\n 179→  assert.equal(result.ok, true);\n 180→  assert.equal(result.value, 'feature-branch_123');\n 181→});\n 182→\n 183→// AC-3.3: reject dangerous characters\n 184→test('sanitizeParam rejects semicolon', () => {\n 185→  const result = sanitizeParam('test;rm -rf');\n 186→  assert.equal(result.ok, false);\n 187→});\n 188→\n 189→test('sanitizeParam rejects pipe', () => {\n 190→  const result = sanitizeParam('test|cat');\n 191→  assert.equal(result.ok, false);\n 192→});\n 193→\n 194→test('sanitizeParam rejects ampersand', () => {\n 195→  const result = sanitizeParam('test&&ls');\n 196→  assert.equal(result.ok, false);\n 197→});\n 198→\n 199→test('sanitizeParam rejects dollar sign', () => {\n 200→  const result = sanitizeParam('$HOME');\n 201→  assert.equal(result.ok, false);\n 202→});\n 203→\n 204→test('sanitizeParam rejects backtick', () => {\n 205→  const result = sanitizeParam('`id`');\n 206→  assert.equal(result.ok, false);\n 207→});\n 208→\n 209→test('sanitizeParam rejects single quote', () => {\n 210→  const result = sanitizeParam(\"test' or '1'='1\");\n 211→  assert.equal(result.ok, false);\n 212→});\n 213→\n 214→test('sanitizeParam rejects double quote', () => {\n 215→  const result = sanitizeParam('test\" or \"1\"=\"1');\n 216→  assert.equal(result.ok, false);\n 217→});\n 218→\n 219→test('sanitizeParam rejects parentheses', () => {\n 220→  const result = sanitizeParam('$(whoami)');\n 221→  assert.equal(result.ok, false);\n 222→});\n 223→\n 224→test('sanitizeParam rejects angle brackets', () => {\n 225→  const result = sanitizeParam('<script>');\n 226→  assert.equal(result.ok, false);\n 227→});\n 228→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb0eca880b82916352a46acc4a0","__timestamp":"2026-03-11T20:58:18.229Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"35997f89-f013-4a19-8280-bbacaa487657","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_35b9d92a61634386ac657478","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for confirmation-manager.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import {\n   9→  createConfirmation,\n  10→  checkConfirmation,\n  11→  confirmAction,\n  12→  cancelConfirmation,\n  13→  clearExpiredConfirmations\n  14→} from '../../src/security/confirmation-manager.js';\n  15→\n  16→// Helper to wait\n  17→const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n  18→\n  19→// createConfirmation tests\n  20→test('createConfirmation creates a pending confirmation', () => {\n  21→  clearExpiredConfirmations();\n  22→  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  23→\n  24→  assert.ok(result.confirmId);\n  25→  assert.ok(result.message);\n  26→  assert.ok(result.message.includes('stop'));\n  27→});\n  28→\n  29→test('createConfirmation generates unique confirmId', () => {\n  30→  clearExpiredConfirmations();\n  31→  const result1 = createConfirmation('user123', 'stop', { type: 'feature' });\n  32→  const result2 = createConfirmation('user123', 'reset', {});\n  33→\n  34→  assert.notEqual(result1.confirmId, result2.confirmId);\n  35→});\n  36→\n  37→test('createConfirmation uses custom timeout', () => {\n  38→  clearExpiredConfirmations();\n  39→  const result = createConfirmation('user123', 'stop', {}, 5000);\n  40→\n  41→  assert.ok(result.confirmId);\n  42→  // Verify by checking it expires after timeout\n  43→});\n  44→\n  45→test('createConfirmation stores userId correctly', () => {\n  46→  clearExpiredConfirmations();\n  47→  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  48→\n  49→  const check = checkConfirmation(result.confirmId, 'user123');\n  50→  assert.equal(check.status, 'pending');\n  51→});\n  52→\n  53→// checkConfirmation tests\n  54→test('checkConfirmation returns pending for active confirmation', () => {\n  55→  clearExpiredConfirmations();\n  56→  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  57→\n  58→  const result = checkConfirmation(confirmId, 'user123');\n  59→\n  60→  assert.equal(result.status, 'pending');\n  61→  assert.equal(result.action, 'stop');\n  62→  assert.deepEqual(result.params, { type: 'feature' });\n  63→});\n  64→\n  65→test('checkConfirmation returns not_found for unknown confirmId', () => {\n  66→  clearExpiredConfirmations();\n  67→  const result = checkConfirmation('nonexistent-id', 'user123');\n  68→\n  69→  assert.equal(result.status, 'not_found');\n  70→});\n  71→\n  72→test('checkConfirmation returns not_found for wrong userId', () => {\n  73→  clearExpiredConfirmations();\n  74→  const { confirmId } = createConfirmation('user123', 'stop', {});\n  75→\n  76→  const result = checkConfirmation(confirmId, 'different-user');\n  77→\n  78→  assert.equal(result.status, 'not_found');\n  79→});\n  80→\n  81→test('checkConfirmation returns expired after timeout', async () => {\n  82→  clearExpiredConfirmations();\n  83→  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n  84→\n  85→  await wait(150);\n  86→\n  87→  const result = checkConfirmation(confirmId, 'user123');\n  88→\n  89→  assert.equal(result.status, 'expired');\n  90→});\n  91→\n  92→// confirmAction tests\n  93→test('confirmAction confirms pending action', () => {\n  94→  clearExpiredConfirmations();\n  95→  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  96→\n  97→  const result = confirmAction(confirmId, 'user123');\n  98→\n  99→  assert.equal(result.ok, true);\n 100→  assert.equal(result.action, 'stop');\n 101→  assert.deepEqual(result.params, { type: 'feature' });\n 102→});\n 103→\n 104→test('confirmAction fails for wrong userId', () => {\n 105→  clearExpiredConfirmations();\n 106→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 107→\n 108→  const result = confirmAction(confirmId, 'different-user');\n 109→\n 110→  assert.equal(result.ok, false);\n 111→  assert.ok(result.error);\n 112→});\n 113→\n 114→test('confirmAction fails for unknown confirmId', () => {\n 115→  clearExpiredConfirmations();\n 116→  const result = confirmAction('nonexistent-id', 'user123');\n 117→\n 118→  assert.equal(result.ok, false);\n 119→  assert.ok(result.error);\n 120→});\n 121→\n 122→test('confirmAction fails for already confirmed action', () => {\n 123→  clearExpiredConfirmations();\n 124→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 125→\n 126→  confirmAction(confirmId, 'user123');\n 127→  const result = confirmAction(confirmId, 'user123');\n 128→\n 129→  assert.equal(result.ok, false);\n 130→  assert.ok(result.error.includes('不存在') || result.error.includes('过期'));\n 131→});\n 132→\n 133→test('confirmAction fails for expired action', async () => {\n 134→  clearExpiredConfirmations();\n 135→  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n 136→\n 137→  await wait(150);\n 138→\n 139→  const result = confirmAction(confirmId, 'user123');\n 140→\n 141→  assert.equal(result.ok, false);\n 142→});\n 143→\n 144→// cancelConfirmation tests\n 145→test('cancelConfirmation cancels pending action', () => {\n 146→  clearExpiredConfirmations();\n 147→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 148→\n 149→  cancelConfirmation(confirmId, 'user123');\n 150→\n 151→  const result = checkConfirmation(confirmId, 'user123');\n 152→  assert.equal(result.status, 'not_found');\n 153→});\n 154→\n 155→test('cancelConfirmation does nothing for unknown confirmId', () => {\n 156→  clearExpiredConfirmations();\n 157→  // Should not throw\n 158→  cancelConfirmation('nonexistent-id', 'user123');\n 159→});\n 160→\n 161→test('cancelConfirmation does nothing for wrong userId', () => {\n 162→  clearExpiredConfirmations();\n 163→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 164→\n 165→  cancelConfirmation(confirmId, 'different-user');\n 166→\n 167→  const result = checkConfirmation(confirmId, 'user123');\n 168→  assert.equal(result.status, 'pending');\n 169→});\n 170→\n 171→// clearExpiredConfirmations tests\n 172→test('clearExpiredConfirmations removes expired confirmations', async () => {\n 173→  clearExpiredConfirmations();\n 174→  createConfirmation('user123', 'stop', {}, 100);\n 175→  createConfirmation('user456', 'reset', {}, 10000);\n 176→\n 177→  await wait(150);\n 178→\n 179→  clearExpiredConfirmations();\n 180→\n 181→  // The expired one should be gone, the active one should remain\n 182→  const check1 = checkConfirmation(\n 183→    // We can't check the specific one, but clearExpiredConfirmations should clean up\n 184→    'any-id',\n 185→    'user123'\n 186→  );\n 187→  assert.equal(check1.status, 'not_found');\n 188→});\n 189→\n 190→// Integration test: full confirmation flow\n 191→test('full confirmation flow: create, check, confirm', () => {\n 192→  clearExpiredConfirmations();\n 193→  // Create\n 194→  const { confirmId, message } = createConfirmation('user123', 'stop', { type: 'feature' });\n 195→\n 196→  assert.ok(confirmId);\n 197→  assert.ok(message);\n 198→\n 199→  // Check\n 200→  const check1 = checkConfirmation(confirmId, 'user123');\n 201→  assert.equal(check1.status, 'pending');\n 202→\n 203→  // Confirm\n 204→  const confirm = confirmAction(confirmId, 'user123');\n 205→  assert.equal(confirm.ok, true);\n 206→\n 207→  // Verify confirmed\n 208→  const check2 = checkConfirmation(confirmId, 'user123');\n 209→  assert.equal(check2.status, 'not_found'); // Consumed\n 210→});\n 211→\n 212→test('full confirmation flow: create, check, cancel', () => {\n 213→  clearExpiredConfirmations();\n 214→  // Create\n 215→  const { confirmId } = createConfirmation('user123', 'reset', {});\n 216→\n 217→  // Check\n 218→  const check1 = checkConfirmation(confirmId, 'user123');\n 219→  assert.equal(check1.status, 'pending');\n 220→\n 221→  // Cancel\n 222→  cancelConfirmation(confirmId, 'user123');\n 223→\n 224→  // Verify cancelled\n 225→  const check2 = checkConfirmation(confirmId, 'user123');\n 226→  assert.equal(check2.status, 'not_found');\n 227→});\n 228→\n 229→// AC-4.3: 60 second timeout default\n 230→test('default timeout is 60 seconds', () => {\n 231→  clearExpiredConfirmations();\n 232→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 233→\n 234→  const check = checkConfirmation(confirmId, 'user123');\n 235→  assert.equal(check.status, 'pending');\n 236→\n 237→  // We can't wait 60s in test, but we can verify it exists initially\n 238→});\n 239→\n 240→// AC-4.4: --force flag handling (in handler, not here)\n 241→// This is tested at the integration level\n 242→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb0eca880b82916352a46acc4a0","__timestamp":"2026-03-11T20:58:18.230Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"ea33d176-1663-4906-9377-8c72c234833e","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_f4b90508e7804847adae6da0","content":[{"type":"text","text":"   1→/**\n   2→ * Audit Log Service Unit Tests\n   3→ * Tests for src/services/audit-log-service.js\n   4→ *\n   5→ * F-006: Safety and Permission Guard - US-5: Audit Logging\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import fs from 'node:fs';\n  11→import path from 'node:path';\n  12→import os from 'node:os';\n  13→\n  14→import {\n  15→  initAuditLogService,\n  16→  logAuditEntry,\n  17→  queryAuditLogs,\n  18→  resetAuditLogService\n  19→} from '../../src/services/audit-log-service.js';\n  20→\n  21→/**\n  22→ * Helper to create temp directory for test logs\n  23→ */\n  24→function createTempLogDir() {\n  25→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'audit-log-test-'));\n  26→  return {\n  27→    tempDir,\n  28→    cleanup: () => {\n  29→      fs.rmSync(tempDir, { recursive: true, force: true });\n  30→    }\n  31→  };\n  32→}\n  33→\n  34→/**\n  35→ * Helper to create a mock config\n  36→ */\n  37→function createMockConfig(logDir, options = {}) {\n  38→  return {\n  39→    logPath: logDir,\n  40→    maxSizeMb: options.maxSizeMb || 10,\n  41→    maxFiles: options.maxFiles || 5\n  42→  };\n  43→}\n  44→\n  45→/**\n  46→ * Helper to create sample audit entry\n  47→ */\n  48→function createSampleEntry(overrides = {}) {\n  49→  return {\n  50→    userId: '123456789',\n  51→    role: 'operator',\n  52→    action: 'stop',\n  53→    params: { type: 'feature' },\n  54→    result: 'success',\n  55→    reason: null,\n  56→    sessionId: 'telegram-123456789',\n  57→    ...overrides\n  58→  };\n  59→}\n  60→\n  61→// ============================================================\n  62→// Service Initialization Tests (T-016)\n  63→// ============================================================\n  64→\n  65→test('initAuditLogService should initialize with config', () => {\n  66→  const { tempDir, cleanup } = createTempLogDir();\n  67→  try {\n  68→    const config = createMockConfig(tempDir);\n  69→    \n  70→    // Should not throw\n  71→    initAuditLogService(config);\n  72→    \n  73→    // Reset for next test\n  74→    resetAuditLogService();\n  75→  } finally {\n  76→    cleanup();\n  77→  }\n  78→});\n  79→\n  80→test('initAuditLogService should create log directory if not exists', () => {\n  81→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'audit-log-test-parent-'));\n  82→  const logDir = path.join(tempDir, 'logs');\n  83→  \n  84→  try {\n  85→    // Directory should not exist yet\n  86→    assert.ok(!fs.existsSync(logDir));\n  87→    \n  88→    const config = createMockConfig(logDir);\n  89→    initAuditLogService(config);\n  90→    \n  91→    // Directory should be created\n  92→    assert.ok(fs.existsSync(logDir));\n  93→    \n  94→    resetAuditLogService();\n  95→  } finally {\n  96→    fs.rmSync(tempDir, { recursive: true, force: true });\n  97→  }\n  98→});\n  99→\n 100→// ============================================================\n 101→// logAuditEntry Tests (T-016)\n 102→// ============================================================\n 103→\n 104→test('logAuditEntry should write entry to audit log', async () => {\n 105→  const { tempDir, cleanup } = createTempLogDir();\n 106→  try {\n 107→    const config = createMockConfig(tempDir);\n 108→    initAuditLogService(config);\n 109→    \n 110→    const entry = createSampleEntry();\n 111→    await logAuditEntry(entry);\n 112→    \n 113→    // Check file was created\n 114→    const logFile = path.join(tempDir, 'audit.log');\n 115→    assert.ok(fs.existsSync(logFile));\n 116→    \n 117→    // Check content\n 118→    const content = fs.readFileSync(logFile, 'utf8');\n 119→    const lines = content.trim().split('\\n');\n 120→    assert.equal(lines.length, 1);\n 121→    \n 122→    const logged = JSON.parse(lines[0]);\n 123→    assert.equal(logged.userId, entry.userId);\n 124→    assert.equal(logged.action, entry.action);\n 125→    assert.equal(logged.result, entry.result);\n 126→    assert.ok(logged.timestamp);\n 127→    \n 128→    resetAuditLogService();\n 129→  } finally {\n 130→    cleanup();\n 131→  }\n 132→});\n 133→\n 134→test('logAuditEntry should append entries (JSON Lines format)', async () => {\n 135→  const { tempDir, cleanup } = createTempLogDir();\n 136→  try {\n 137→    const config = createMockConfig(tempDir);\n 138→    initAuditLogService(config);\n 139→    \n 140→    await logAuditEntry(createSampleEntry({ action: 'stop' }));\n 141→    await logAuditEntry(createSampleEntry({ action: 'reset', userId: '987654321' }));\n 142→    \n 143→    const logFile = path.join(tempDir, 'audit.log');\n 144→    const content = fs.readFileSync(logFile, 'utf8');\n 145→    const lines = content.trim().split('\\n');\n 146→    \n 147→    assert.equal(lines.length, 2);\n 148→    \n 149→    const entry1 = JSON.parse(lines[0]);\n 150→    const entry2 = JSON.parse(lines[1]);\n 151→    \n 152→    assert.equal(entry1.action, 'stop');\n 153→    assert.equal(entry2.action, 'reset');\n 154→    \n 155→    resetAuditLogService();\n 156→  } finally {\n 157→    cleanup();\n 158→  }\n 159→});\n 160→\n 161→test('logAuditEntry should include all entry fields', async () => {\n 162→  const { tempDir, cleanup } = createTempLogDir();\n 163→  try {\n 164→    const config = createMockConfig(tempDir);\n 165→    initAuditLogService(config);\n 166→    \n 167→    const entry = createSampleEntry({\n 168→      userId: '111222333',\n 169→      role: 'admin',\n 170→      action: 'force-unlock',\n 171→      params: { target: 'feature-001' },\n 172→      result: 'denied',\n 173→      reason: 'Permission denied for operator',\n 174→      sessionId: 'telegram-111222333'\n 175→    });\n 176→    \n 177→    await logAuditEntry(entry);\n 178→    \n 179→    const logFile = path.join(tempDir, 'audit.log');\n 180→    const content = fs.readFileSync(logFile, 'utf8');\n 181→    const logged = JSON.parse(content.trim());\n 182→    \n 183→    assert.equal(logged.userId, entry.userId);\n 184→    assert.equal(logged.role, entry.role);\n 185→    assert.equal(logged.action, entry.action);\n 186→    assert.deepEqual(logged.params, entry.params);\n 187→    assert.equal(logged.result, entry.result);\n 188→    assert.equal(logged.reason, entry.reason);\n 189→    assert.equal(logged.sessionId, entry.sessionId);\n 190→    assert.ok(logged.timestamp);\n 191→    \n 192→    resetAuditLogService();\n 193→  } finally {\n 194→    cleanup();\n 195→  }\n 196→});\n 197→\n 198→test('logAuditEntry should handle failed result', async () => {\n 199→  const { tempDir, cleanup } = createTempLogDir();\n 200→  try {\n 201→    const config = createMockConfig(tempDir);\n 202→    initAuditLogService(config);\n 203→    \n 204→    const entry = createSampleEntry({\n 205→      result: 'failed',\n 206→      reason: 'Pipeline not running'\n 207→    });\n 208→    \n 209→    await logAuditEntry(entry);\n 210→    \n 211→    const logFile = path.join(tempDir, 'audit.log');\n 212→    const content = fs.readFileSync(logFile, 'utf8');\n 213→    const logged = JSON.parse(content.trim());\n 214→    \n 215→    assert.equal(logged.result, 'failed');\n 216→    assert.equal(logged.reason, 'Pipeline not running');\n 217→    \n 218→    resetAuditLogService();\n 219→  } finally {\n 220→    cleanup();\n 221→  }\n 222→});\n 223→\n 224→// ============================================================\n 225→// queryAuditLogs Tests (T-016)\n 226→// ============================================================\n 227→\n 228→test('queryAuditLogs should return all entries when no filters', async () => {\n 229→  const { tempDir, cleanup } = createTempLogDir();\n 230→  try {\n 231→    const config = createMockConfig(tempDir);\n 232→    initAuditLogService(config);\n 233→    \n 234→    await logAuditEntry(createSampleEntry({ action: 'stop' }));\n 235→    await logAuditEntry(createSampleEntry({ action: 'reset' }));\n 236→    await logAuditEntry(createSampleEntry({ action: 'retry' }));\n 237→    \n 238→    const results = await queryAuditLogs({});\n 239→    \n 240→    assert.equal(results.length, 3);\n 241→    \n 242→    resetAuditLogService();\n 243→  } finally {\n 244→    cleanup();\n 245→  }\n 246→});\n 247→\n 248→test('queryAuditLogs should filter by userId', async () => {\n 249→  const { tempDir, cleanup } = createTempLogDir();\n 250→  try {\n 251→    const config = createMockConfig(tempDir);\n 252→    initAuditLogService(config);\n 253→    \n 254→    await logAuditEntry(createSampleEntry({ userId: '111', action: 'stop' }));\n 255→    await logAuditEntry(createSampleEntry({ userId: '222', action: 'reset' }));\n 256→    await logAuditEntry(createSampleEntry({ userId: '111', action: 'retry' }));\n 257→    \n 258→    const results = await queryAuditLogs({ userId: '111' });\n 259→    \n 260→    assert.equal(results.length, 2);\n 261→    assert.ok(results.every(r => r.userId === '111'));\n 262→    \n 263→    resetAuditLogService();\n 264→  } finally {\n 265→    cleanup();\n 266→  }\n 267→});\n 268→\n 269→test('queryAuditLogs should filter by action', async () => {\n 270→  const { tempDir, cleanup } = createTempLogDir();\n 271→  try {\n 272→    const config = createMockConfig(tempDir);\n 273→    initAuditLogService(config);\n 274→    \n 275→    await logAuditEntry(createSampleEntry({ action: 'stop' }));\n 276→    await logAuditEntry(createSampleEntry({ action: 'reset' }));\n 277→    await logAuditEntry(createSampleEntry({ action: 'stop' }));\n 278→    \n 279→    const results = await queryAuditLogs({ action: 'stop' });\n 280→    \n 281→    assert.equal(results.length, 2);\n 282→    assert.ok(results.every(r => r.action === 'stop'));\n 283→    \n 284→    resetAuditLogService();\n 285→  } finally {\n 286→    cleanup();\n 287→  }\n 288→});\n 289→\n 290→test('queryAuditLogs should filter by date range', async () => {\n 291→  const { tempDir, cleanup } = createTempLogDir();\n 292→  try {\n 293→    const config = createMockConfig(tempDir);\n 294→    initAuditLogService(config);\n 295→    \n 296→    // Write entries with different timestamps\n 297→    const now = Date.now();\n 298→    const oneDayMs = 24 * 60 * 60 * 1000;\n 299→    \n 300→    // We need to manipulate the timestamp, so we'll test with existing entries\n 301→    await logAuditEntry(createSampleEntry({ action: 'stop' }));\n 302→    await logAuditEntry(createSampleEntry({ action: 'reset' }));\n 303→    \n 304→    // Query with date filter (should include recent entries)\n 305→    const startDate = new Date(now - oneDayMs);\n 306→    const endDate = new Date(now + oneDayMs);\n 307→    \n 308→    const results = await queryAuditLogs({ startDate, endDate });\n 309→    \n 310→    assert.ok(results.length >= 2);\n 311→    \n 312→    resetAuditLogService();\n 313→  } finally {\n 314→    cleanup();\n 315→  }\n 316→});\n 317→\n 318→test('queryAuditLogs should respect limit parameter', async () => {\n 319→  const { tempDir, cleanup } = createTempLogDir();\n 320→  try {\n 321→    const config = createMockConfig(tempDir);\n 322→    initAuditLogService(config);\n 323→    \n 324→    // Write 10 entries\n 325→    for (let i = 0; i < 10; i++) {\n 326→      await logAuditEntry(createSampleEntry({ action: `action-${i}` }));\n 327→    }\n 328→    \n 329→    const results = await queryAuditLogs({ limit: 5 });\n 330→    \n 331→    assert.equal(results.length, 5);\n 332→    \n 333→    resetAuditLogService();\n 334→  } finally {\n 335→    cleanup();\n 336→  }\n 337→});\n 338→\n 339→test('queryAuditLogs should return entries in reverse chronological order', async () => {\n 340→  const { tempDir, cleanup } = createTempLogDir();\n 341→  try {\n 342→    const config = createMockConfig(tempDir);\n 343→    initAuditLogService(config);\n 344→    \n 345→    await logAuditEntry(createSampleEntry({ action: 'first' }));\n 346→    // Small delay to ensure different timestamps\n 347→    await new Promise(resolve => setTimeout(resolve, 10));\n 348→    await logAuditEntry(createSampleEntry({ action: 'second' }));\n 349→    await new Promise(resolve => setTimeout(resolve, 10));\n 350→    await logAuditEntry(createSampleEntry({ action: 'third' }));\n 351→    \n 352→    const results = await queryAuditLogs({});\n 353→    \n 354→    // Most recent first\n 355→    assert.equal(results[0].action, 'third');\n 356→    assert.equal(results[1].action, 'second');\n 357→    assert.equal(results[2].action, 'first');\n 358→    \n 359→    resetAuditLogService();\n 360→  } finally {\n 361→    cleanup();\n 362→  }\n 363→});\n 364→\n 365→test('queryAuditLogs should return empty array for no matches', async () => {\n 366→  const { tempDir, cleanup } = createTempLogDir();\n 367→  try {\n 368→    const config = createMockConfig(tempDir);\n 369→    initAuditLogService(config);\n 370→    \n 371→    await logAuditEntry(createSampleEntry({ action: 'stop' }));\n 372→    \n 373→    const results = await queryAuditLogs({ action: 'nonexistent' });\n 374→    \n 375→    assert.deepEqual(results, []);\n 376→    \n 377→    resetAuditLogService();\n 378→  } finally {\n 379→    cleanup();\n 380→  }\n 381→});\n 382→\n 383→test('queryAuditLogs should handle empty log file', async () => {\n 384→  const { tempDir, cleanup } = createTempLogDir();\n 385→  try {\n 386→    const config = createMockConfig(tempDir);\n 387→    initAuditLogService(config);\n 388→    \n 389→    // Don't write anything\n 390→    const results = await queryAuditLogs({});\n 391→    \n 392→    assert.deepEqual(results, []);\n 393→    \n 394→    resetAuditLogService();\n 395→  } finally {\n 396→    cleanup();\n 397→  }\n 398→});\n 399→\n 400→// ============================================================\n 401→// Log Rotation Tests (T-016)\n 402→// ============================================================\n 403→\n 404→test('log rotation should occur when file exceeds maxSizeMb', async () => {\n 405→  const { tempDir, cleanup } = createTempLogDir();\n 406→  try {\n 407→    // Use small max size for testing (1KB)\n 408→    const config = createMockConfig(tempDir, { maxSizeMb: 0.001 });\n 409→    initAuditLogService(config);\n 410→    \n 411→    // Write enough entries to trigger rotation\n 412→    const largeEntry = createSampleEntry({\n 413→      params: { data: 'x'.repeat(500) }\n 414→    });\n 415→    \n 416→    for (let i = 0; i < 10; i++) {\n 417→      await logAuditEntry(largeEntry);\n 418→    }\n 419→    \n 420→    // Check for rotated file\n 421→    const rotatedFile = path.join(tempDir, 'audit.log.1');\n 422→    // Rotation may or may not have occurred depending on exact size\n 423→    // Just verify the main log file exists\n 424→    const logFile = path.join(tempDir, 'audit.log');\n 425→    assert.ok(fs.existsSync(logFile));\n 426→    \n 427→    resetAuditLogService();\n 428→  } finally {\n 429→    cleanup();\n 430→  }\n 431→});\n 432→\n 433→test('log rotation should keep maxFiles rotated files', async () => {\n 434→  const { tempDir, cleanup } = createTempLogDir();\n 435→  try {\n 436→    // Use small max size and max 3 files\n 437→    const config = createMockConfig(tempDir, { maxSizeMb: 0.001, maxFiles: 3 });\n 438→    initAuditLogService(config);\n 439→    \n 440→    // Write many entries to trigger multiple rotations\n 441→    const largeEntry = createSampleEntry({\n 442→      params: { data: 'x'.repeat(500) }\n 443→    });\n 444→    \n 445→    for (let i = 0; i < 30; i++) {\n 446→      await logAuditEntry(largeEntry);\n 447→    }\n 448→    \n 449→    // Check that we don't have more than maxFiles rotated files\n 450→    const files = fs.readdirSync(tempDir);\n 451→    const rotatedFiles = files.filter(f => f.startsWith('audit.log.'));\n 452→    \n 453→    // Should have at most maxFiles rotated files\n 454→    assert.ok(rotatedFiles.length <= 3, `Expected <= 3 rotated files, got ${rotatedFiles.length}`);\n 455→    \n 456→    resetAuditLogService();\n 457→  } finally {\n 458→    cleanup();\n 459→  }\n 460→});\n 461→\n 462→// ============================================================\n 463→// Edge Cases Tests\n 464→// ============================================================\n 465→\n 466→test('logAuditEntry should handle missing optional fields', async () => {\n 467→  const { tempDir, cleanup } = createTempLogDir();\n 468→  try {\n 469→    const config = createMockConfig(tempDir);\n 470→    initAuditLogService(config);\n 471→    \n 472→    const entry = {\n 473→      userId: '123456789',\n 474→      action: 'status',\n 475→      result: 'success'\n 476→    };\n 477→    \n 478→    await logAuditEntry(entry);\n 479→    \n 480→    const logFile = path.join(tempDir, 'audit.log');\n 481→    const content = fs.readFileSync(logFile, 'utf8');\n 482→    const logged = JSON.parse(content.trim());\n 483→    \n 484→    assert.equal(logged.userId, '123456789');\n 485→    assert.equal(logged.action, 'status');\n 486→    assert.equal(logged.result, 'success');\n 487→    \n 488→    resetAuditLogService();\n 489→  } finally {\n 490→    cleanup();\n 491→  }\n 492→});\n 493→\n 494→test('logAuditEntry should handle numeric userId', async () => {\n 495→  const { tempDir, cleanup } = createTempLogDir();\n 496→  try {\n 497→    const config = createMockConfig(tempDir);\n 498→    initAuditLogService(config);\n 499→    \n 500→    const entry = createSampleEntry({ userId: 123456789 });\n 501→    \n 502→    await logAuditEntry(entry);\n 503→    \n 504→    const logFile = path.join(tempDir, 'audit.log');\n 505→    const content = fs.readFileSync(logFile, 'utf8');\n 506→    const logged = JSON.parse(content.trim());\n 507→    \n 508→    // userId should be stringified\n 509→    assert.ok(typeof logged.userId === 'string' || typeof logged.userId === 'number');\n 510→    \n 511→    resetAuditLogService();\n 512→  } finally {\n 513→    cleanup();\n 514→  }\n 515→});\n 516→\n 517→test('queryAuditLogs should handle numeric userId filter', async () => {\n 518→  const { tempDir, cleanup } = createTempLogDir();\n 519→  try {\n 520→    const config = createMockConfig(tempDir);\n 521→    initAuditLogService(config);\n 522→    \n 523→    await logAuditEntry(createSampleEntry({ userId: '123456789' }));\n 524→    \n 525→    // Query with numeric userId\n 526→    const results = await queryAuditLogs({ userId: 123456789 });\n 527→    \n 528→    assert.equal(results.length, 1);\n 529→    \n 530→    resetAuditLogService();\n 531→  } finally {\n 532→    cleanup();\n 533→  }\n 534→});\n 535→\n 536→// ============================================================\n 537→// Error Handling Tests\n 538→// ============================================================\n 539→\n 540→test('logAuditEntry should not throw on write failure', async () => {\n 541→  const { tempDir, cleanup } = createTempLogDir();\n 542→  try {\n 543→    const config = createMockConfig(tempDir);\n 544→    initAuditLogService(config);\n 545→    \n 546→    // Make the log directory read-only to simulate write failure\n 547→    // Note: This test may behave differently on different platforms\n 548→    \n 549→    const entry = createSampleEntry();\n 550→    \n 551→    // Should not throw even if there might be issues\n 552→    await logAuditEntry(entry);\n 553→    \n 554→    resetAuditLogService();\n 555→  } finally {\n 556→    cleanup();\n 557→  }\n 558→});\n 559→\n 560→test('queryAuditLogs should handle corrupted log file gracefully', async () => {\n 561→  const { tempDir, cleanup } = createTempLogDir();\n 562→  try {\n 563→    const config = createMockConfig(tempDir);\n 564→    initAuditLogService(config);\n 565→    \n 566→    // Write a valid entry\n 567→    await logAuditEntry(createSampleEntry());\n 568→    \n 569→    // Append corrupted data\n 570→    const logFile = path.join(tempDir, 'audit.log');\n 571→    fs.appendFileSync(logFile, '\\nnot valid json\\n');\n 572→    \n 573→    // Should still return valid entries and skip corrupted ones\n 574→    const results = await queryAuditLogs({});\n 575→    \n 576→    assert.ok(results.length >= 0);\n 577→    \n 578→    resetAuditLogService();\n 579→  } finally {\n 580→    cleanup();\n 581→  }\n 582→});\n 583→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb0eca880b82916352a46acc4a0","__timestamp":"2026-03-11T20:58:18.230Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
