{"type":"user","uuid":"183b3803-cae5-43ba-affa-f13fa4a3be69","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_b2add47056934811ad059204","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for permission-guard.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mock, fn } from 'node:test';\n   9→\n  10→// We need to mock config before importing permission-guard\n  11→// Create a mock config object\n  12→const mockConfig = {\n  13→  userPermissions: new Map(),\n  14→  allowAdminSkipConfirm: true,\n  15→  enableSystemExec: false,\n  16→  allowedUserIds: new Set()\n  17→};\n  18→\n  19→// Mock the config module\n  20→mock.module('../../src/config.js', {\n  21→  namedExports: {\n  22→    config: mockConfig\n  23→  }\n  24→});\n  25→\n  26→// Import after mocking\n  27→const { getUserRole, checkCommandPermission, isAdmin, ROLE_HIERARCHY } = await import(\n  28→  '../../src/security/permission-guard.js'\n  29→);\n  30→\n  31→test.beforeEach(() => {\n  32→  // Reset mock config\n  33→  mockConfig.userPermissions = new Map();\n  34→  mockConfig.allowAdminSkipConfirm = true;\n  35→  mockConfig.enableSystemExec = false;\n  36→  mockConfig.allowedUserIds = new Set();\n  37→});\n  38→\n  39→// ROLE_HIERARCHY tests\n  40→test('ROLE_HIERARCHY defines correct hierarchy levels', () => {\n  41→  assert.equal(ROLE_HIERARCHY.viewer, 0);\n  42→  assert.equal(ROLE_HIERARCHY.operator, 1);\n  43→  assert.equal(ROLE_HIERARCHY.admin, 2);\n  44→});\n  45→\n  46→// getUserRole tests\n  47→test('getUserRole returns admin for configured admin user', () => {\n  48→  mockConfig.userPermissions.set('123456789', 'admin');\n  49→  assert.equal(getUserRole('123456789'), 'admin');\n  50→});\n  51→\n  52→test('getUserRole returns operator for configured operator user', () => {\n  53→  mockConfig.userPermissions.set('987654321', 'operator');\n  54→  assert.equal(getUserRole('987654321'), 'operator');\n  55→});\n  56→\n  57→test('getUserRole returns viewer for configured viewer user', () => {\n  58→  mockConfig.userPermissions.set('111222333', 'viewer');\n  59→  assert.equal(getUserRole('111222333'), 'viewer');\n  60→});\n  61→\n  62→test('getUserRole returns operator as default for unknown users (AC-1.3)', () => {\n  63→  assert.equal(getUserRole('unknown-user'), 'operator');\n  64→});\n  65→\n  66→test('getUserRole handles numeric userId', () => {\n  67→  mockConfig.userPermissions.set('123456789', 'admin');\n  68→  assert.equal(getUserRole(123456789), 'admin');\n  69→});\n  70→\n  71→// isAdmin tests\n  72→test('isAdmin returns true for admin user', () => {\n  73→  mockConfig.userPermissions.set('123456789', 'admin');\n  74→  assert.equal(isAdmin('123456789'), true);\n  75→});\n  76→\n  77→test('isAdmin returns false for operator user', () => {\n  78→  mockConfig.userPermissions.set('987654321', 'operator');\n  79→  assert.equal(isAdmin('987654321'), false);\n  80→});\n  81→\n  82→test('isAdmin returns false for viewer user', () => {\n  83→  mockConfig.userPermissions.set('111222333', 'viewer');\n  84→  assert.equal(isAdmin('111222333'), false);\n  85→});\n  86→\n  87→test('isAdmin returns false for unknown user (default is operator)', () => {\n  88→  assert.equal(isAdmin('unknown-user'), false);\n  89→});\n  90→\n  91→// checkCommandPermission - status command (viewer)\n  92→test('checkCommandPermission allows viewer to execute status', () => {\n  93→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n  94→  const result = checkCommandPermission('viewer-user', 'status');\n  95→  assert.equal(result.allowed, true);\n  96→  assert.equal(result.requiresConfirmation, false);\n  97→});\n  98→\n  99→// checkCommandPermission - logs command (viewer)\n 100→test('checkCommandPermission allows viewer to execute logs', () => {\n 101→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n 102→  const result = checkCommandPermission('viewer-user', 'logs');\n 103→  assert.equal(result.allowed, true);\n 104→  assert.equal(result.requiresConfirmation, false);\n 105→});\n 106→\n 107→// checkCommandPermission - pipeline command (operator)\n 108→test('checkCommandPermission allows operator to execute pipeline', () => {\n 109→  mockConfig.userPermissions.set('op-user', 'operator');\n 110→  const result = checkCommandPermission('op-user', 'pipeline');\n 111→  assert.equal(result.allowed, true);\n 112→});\n 113→\n 114→test('checkCommandPermission denies viewer for pipeline', () => {\n 115→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n 116→  const result = checkCommandPermission('viewer-user', 'pipeline');\n 117→  assert.equal(result.allowed, false);\n 118→  assert.ok(result.reason.includes('权限不足'));\n 119→});\n 120→\n 121→// checkCommandPermission - retry command (operator) - AC-2.3\n 122→test('checkCommandPermission allows operator for retry without confirmation', () => {\n 123→  mockConfig.userPermissions.set('op-user', 'operator');\n 124→  const result = checkCommandPermission('op-user', 'retry');\n 125→  assert.equal(result.allowed, true);\n 126→  assert.equal(result.requiresConfirmation, false);\n 127→});\n 128→\n 129→test('checkCommandPermission denies viewer for retry', () => {\n 130→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n 131→  const result = checkCommandPermission('viewer-user', 'retry');\n 132→  assert.equal(result.allowed, false);\n 133→});\n 134→\n 135→// checkCommandPermission - stop command (admin) - AC-2.2\n 136→test('checkCommandPermission allows admin for stop with confirmation', () => {\n 137→  mockConfig.userPermissions.set('admin-user', 'admin');\n 138→  const result = checkCommandPermission('admin-user', 'stop');\n 139→  assert.equal(result.allowed, true);\n 140→  assert.equal(result.requiresConfirmation, true);\n 141→});\n 142→\n 143→test('checkCommandPermission denies operator for stop', () => {\n 144→  mockConfig.userPermissions.set('op-user', 'operator');\n 145→  const result = checkCommandPermission('op-user', 'stop');\n 146→  assert.equal(result.allowed, false);\n 147→  assert.ok(result.reason.includes('权限不足'));\n 148→});\n 149→\n 150→test('checkCommandPermission denies viewer for stop', () => {\n 151→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n 152→  const result = checkCommandPermission('viewer-user', 'stop');\n 153→  assert.equal(result.allowed, false);\n 154→});\n 155→\n 156→// checkCommandPermission - reset command (admin) - AC-2.2\n 157→test('checkCommandPermission allows admin for reset with confirmation', () => {\n 158→  mockConfig.userPermissions.set('admin-user', 'admin');\n 159→  const result = checkCommandPermission('admin-user', 'reset');\n 160→  assert.equal(result.allowed, true);\n 161→  assert.equal(result.requiresConfirmation, true);\n 162→});\n 163→\n 164→test('checkCommandPermission denies operator for reset', () => {\n 165→  mockConfig.userPermissions.set('op-user', 'operator');\n 166→  const result = checkCommandPermission('op-user', 'reset');\n 167→  assert.equal(result.allowed, false);\n 168→});\n 169→\n 170→// checkCommandPermission - force-unlock command (admin) - F-001\n 171→test('checkCommandPermission requires admin for force-unlock', () => {\n 172→  mockConfig.userPermissions.set('admin-user', 'admin');\n 173→  const result = checkCommandPermission('admin-user', 'force-unlock');\n 174→  assert.equal(result.allowed, true);\n 175→  assert.equal(result.requiresConfirmation, true);\n 176→});\n 177→\n 178→test('checkCommandPermission denies operator for force-unlock', () => {\n 179→  mockConfig.userPermissions.set('op-user', 'operator');\n 180→  const result = checkCommandPermission('op-user', 'force-unlock');\n 181→  assert.equal(result.allowed, false);\n 182→  assert.ok(result.reason.includes('权限不足'));\n 183→});\n 184→\n 185→// checkCommandPermission - exec command (admin + ENABLE_SYSTEM_EXEC) - AC-2.4, F-002\n 186→test('checkCommandPermission denies exec when ENABLE_SYSTEM_EXEC is false', () => {\n 187→  mockConfig.enableSystemExec = false;\n 188→  mockConfig.userPermissions.set('admin-user', 'admin');\n 189→  const result = checkCommandPermission('admin-user', 'exec');\n 190→  assert.equal(result.allowed, false);\n 191→  assert.ok(result.reason.includes('系统命令执行未启用'));\n 192→});\n 193→\n 194→test('checkCommandPermission allows admin for exec when ENABLE_SYSTEM_EXEC is true', () => {\n 195→  mockConfig.enableSystemExec = true;\n 196→  mockConfig.userPermissions.set('admin-user', 'admin');\n 197→  const result = checkCommandPermission('admin-user', 'exec');\n 198→  assert.equal(result.allowed, true);\n 199→  assert.equal(result.requiresConfirmation, false);\n 200→});\n 201→\n 202→test('checkCommandPermission denies operator for exec even when ENABLE_SYSTEM_EXEC is true', () => {\n 203→  mockConfig.enableSystemExec = true;\n 204→  mockConfig.userPermissions.set('op-user', 'operator');\n 205→  const result = checkCommandPermission('op-user', 'exec');\n 206→  assert.equal(result.allowed, false);\n 207→});\n 208→\n 209→// checkCommandPermission - unknown command\n 210→test('checkCommandPermission allows unknown command by default (defensive but permissive)', () => {\n 211→  mockConfig.userPermissions.set('op-user', 'operator');\n 212→  const result = checkCommandPermission('op-user', 'unknown-command');\n 213→  assert.equal(result.allowed, true);\n 214→  assert.equal(result.requiresConfirmation, false);\n 215→});\n 216→\n 217→// error message security - AC-2.5\n 218→test('checkCommandPermission does not expose internal paths in error messages', () => {\n 219→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n 220→  const result = checkCommandPermission('viewer-user', 'stop');\n 221→  assert.ok(!result.reason.includes('/var/'));\n 222→  assert.ok(!result.reason.includes('/home/'));\n 223→  assert.ok(!result.reason.includes('config'));\n 224→});\n 225→\n 226→test('checkCommandPermission provides unified denial message', () => {\n 227→  mockConfig.userPermissions.set('viewer-user', 'viewer');\n 228→  const result = checkCommandPermission('viewer-user', 'stop');\n 229→  assert.ok(result.reason.match(/权限不足|未授权/));\n 230→});\n 231→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde9b972165b5f35eeda38e0e2170","__timestamp":"2026-03-11T20:35:08.728Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"e4cb587a-7f3e-4685-98f5-dd086302d635","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_7fee7b5c3e304c829c43376c","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} helpText - Help text for the command\n  34→ */\n  35→\n  36→/**\n  37→ * @typedef {Object} CommandEntry\n  38→ * @property {CommandMeta} meta - Command metadata\n  39→ * @property {Function} handler - Command handler function\n  40→ */\n  41→\n  42→/**\n  43→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  44→ */\n  45→\n  46→// Internal registry storage\n  47→const commands = new Map();\n  48→const aliasToCommand = new Map();\n  49→\n  50→/**\n  51→ * Register a command with its metadata and handler.\n  52→ * @param {CommandMeta} meta - Command metadata\n  53→ * @param {Function} handler - Command handler function\n  54→ * @throws {Error} If command already registered\n  55→ */\n  56→export function registerCommand(meta, handler) {\n  57→  if (!meta || !meta.name) {\n  58→    throw new Error('Command meta must have a name');\n  59→  }\n  60→\n  61→  // Normalize meta with lowercase name\n  62→  const normalizedMeta = {\n  63→    ...meta,\n  64→    name: meta.name.toLowerCase()\n  65→  };\n  66→  const name = normalizedMeta.name;\n  67→\n  68→  if (commands.has(name)) {\n  69→    throw new Error(`Command \"${name}\" is already registered`);\n  70→  }\n  71→\n  72→  // Register command\n  73→  commands.set(name, { meta: normalizedMeta, handler });\n  74→\n  75→  // Register aliases\n  76→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  77→    for (const alias of meta.aliases) {\n  78→      const aliasLower = alias.toLowerCase();\n  79→      if (aliasToCommand.has(aliasLower)) {\n  80→        throw new Error(`Alias \"${alias}\" is already registered`);\n  81→      }\n  82→      aliasToCommand.set(aliasLower, name);\n  83→    }\n  84→  }\n  85→}\n  86→\n  87→/**\n  88→ * Get a command entry by name or alias.\n  89→ * @param {string} name - Command name or alias\n  90→ * @returns {CommandEntry | null} Command entry or null\n  91→ */\n  92→export function getCommand(name) {\n  93→  if (!name || typeof name !== 'string') {\n  94→    return null;\n  95→  }\n  96→\n  97→  const nameLower = name.toLowerCase();\n  98→\n  99→  // Try direct lookup\n 100→  if (commands.has(nameLower)) {\n 101→    return commands.get(nameLower);\n 102→  }\n 103→\n 104→  // Try alias lookup\n 105→  const resolvedName = aliasToCommand.get(nameLower);\n 106→  if (resolvedName && commands.has(resolvedName)) {\n 107→    return commands.get(resolvedName);\n 108→  }\n 109→\n 110→  return null;\n 111→}\n 112→\n 113→/**\n 114→ * Check if a name is a registered alias.\n 115→ * @param {string} name - Name to check\n 116→ * @returns {boolean} True if name is an alias\n 117→ */\n 118→export function isAlias(name) {\n 119→  if (!name || typeof name !== 'string') {\n 120→    return false;\n 121→  }\n 122→  return aliasToCommand.has(name.toLowerCase());\n 123→}\n 124→\n 125→/**\n 126→ * Get all registered commands.\n 127→ * @returns {CommandEntry[]} All command entries\n 128→ */\n 129→export function getAllCommands() {\n 130→  return Array.from(commands.values());\n 131→}\n 132→\n 133→/**\n 134→ * Generate help text for a specific command or all commands.\n 135→ * @param {string} [commandName] - Optional command name for specific help\n 136→ * @returns {string} Help text\n 137→ */\n 138→export function getHelpText(commandName) {\n 139→  if (commandName) {\n 140→    const entry = getCommand(commandName);\n 141→    if (!entry) {\n 142→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 143→    }\n 144→    return formatCommandHelp(entry.meta);\n 145→  }\n 146→\n 147→  // Generate general help\n 148→  const commandList = getAllCommands()\n 149→    .map((entry) => {\n 150→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 151→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 152→    })\n 153→    .sort();\n 154→\n 155→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 156→}\n 157→\n 158→/**\n 159→ * Format detailed help for a single command.\n 160→ * @param {CommandMeta} meta - Command metadata\n 161→ * @returns {string} Formatted help text\n 162→ */\n 163→function formatCommandHelp(meta) {\n 164→  const lines = [`/${meta.name} - ${meta.description}`];\n 165→\n 166→  if (meta.aliases?.length) {\n 167→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 168→  }\n 169→\n 170→  if (meta.usage) {\n 171→    lines.push(`用法: ${meta.usage}`);\n 172→  }\n 173→\n 174→  if (meta.subcommands?.length) {\n 175→    lines.push('\\n子命令:');\n 176→    for (const sub of meta.subcommands) {\n 177→      lines.push(`  ${sub.name} - ${sub.description}`);\n 178→    }\n 179→  }\n 180→\n 181→  if (meta.params?.length) {\n 182→    lines.push('\\n参数:');\n 183→    for (const param of meta.params) {\n 184→      const required = param.required ? '(必填)' : '(可选)';\n 185→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 186→    }\n 187→  }\n 188→\n 189→  if (meta.examples?.length) {\n 190→    lines.push('\\n示例:');\n 191→    for (const example of meta.examples) {\n 192→      lines.push(`  ${example}`);\n 193→    }\n 194→  }\n 195→\n 196→  return lines.join('\\n');\n 197→}\n 198→\n 199→/**\n 200→ * Clear the registry (for testing).\n 201→ */\n 202→export function clearRegistry() {\n 203→  commands.clear();\n 204→  aliasToCommand.clear();\n 205→}\n 206→\n 207→/**\n 208→ * Get the alias map for parser usage.\n 209→ * @returns {Record<string, string>} Alias to command name mapping\n 210→ */\n 211→export function getAliasMap() {\n 212→  const map = {};\n 213→  for (const [alias, command] of aliasToCommand) {\n 214→    map[alias] = command;\n 215→  }\n 216→  return map;\n 217→}\n 218→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde9b972165b5f35eeda38e0e2170","__timestamp":"2026-03-11T20:35:08.728Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"fa7fd7bd-a83f-4808-a110-80e22dba0b7b","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_2f24ce5c51104c25a9c55392","content":[{"type":"text","text":"   1→/**\n   2→ * Stop Command Handler\n   3→ * Handles /stop command to stop running pipelines.\n   4→ */\n   5→\n   6→import { stopPipeline } from '../../../services/pipeline-controller.js';\n   7→\n   8→/**\n   9→ * Stop command metadata.\n  10→ */\n  11→export const stopMeta = {\n  12→  name: 'stop',\n  13→  aliases: [],\n  14→  description: '停止运行中的管道',\n  15→  usage: '/stop [target]',\n  16→  examples: ['/stop', '/stop my-feature'],\n  17→  params: [\n  18→    {\n  19→      name: 'target',\n  20→      type: 'string',\n  21→      required: false,\n  22→      description: '目标标识符'\n  23→    }\n  24→  ],\n  25→  requiresAuth: true,\n  26→  helpText: '/stop [target] - 停止运行中的管道'\n  27→};\n  28→\n  29→/**\n  30→ * Handle stop command.\n  31→ * @param {Object} handlerCtx - Handler context\n  32→ */\n  33→export async function handleStop(handlerCtx) {\n  34→  const { params, reply, parsed } = handlerCtx;\n  35→\n  36→  // Get target from positional args or params\n  37→  const target = params._args?.[0] || params.target;\n  38→  const pipelineType = params.type || 'feature';\n  39→\n  40→  try {\n  41→    const result = await stopPipeline({ type: pipelineType });\n  42→\n  43→    if (result.ok) {\n  44→      if (result.errorCode === 'ALREADY_STOPPED') {\n  45→        await reply('⚠️ 没有运行中的管道。');\n  46→      } else {\n  47→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n  48→        await reply(`✅ 已停止管道${pidInfo}。`);\n  49→      }\n  50→    } else {\n  51→      await reply(`❌ 停止失败: ${result.message || '未知错误'}`);\n  52→    }\n  53→  } catch (error) {\n  54→    await reply(`❌ 停止失败: ${error.message}`);\n  55→  }\n  56→}\n  57→\n  58→export default handleStop;\n  59→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde9b972165b5f35eeda38e0e2170","__timestamp":"2026-03-11T20:35:08.729Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"f6121744-8e64-42a3-80f7-6677fb718a3a","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_1bb573638dab4f76a678cf28","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ */\n   5→\n   6→import {\n   7→  startPipeline,\n   8→  stopPipeline,\n   9→  getStatus,\n  10→  getLogs\n  11→} from '../../../services/pipeline-controller.js';\n  12→import { formatValidationErrors, formatError, ErrorCodes } from '../formatter.js';\n  13→\n  14→/**\n  15→ * Pipeline command metadata.\n  16→ */\n  17→export const pipelineMeta = {\n  18→  name: 'pipeline',\n  19→  aliases: ['p'],\n  20→  description: '管理管道任务',\n  21→  usage: '/pipeline <action> [target] [--type=<type>]',\n  22→  examples: [\n  23→    '/pipeline run my-feature',\n  24→    '/pipeline run my-feature --type=bugfix',\n  25→    '/pipeline status',\n  26→    '/pipeline logs my-feature',\n  27→    '/pipeline stop my-feature'\n  28→  ],\n  29→  subcommands: [\n  30→    { name: 'run', description: '启动管道' },\n  31→    { name: 'status', description: '查询状态' },\n  32→    { name: 'logs', description: '查看日志' },\n  33→    { name: 'stop', description: '停止管道' }\n  34→  ],\n  35→  params: [\n  36→    {\n  37→      name: 'target',\n  38→      type: 'string',\n  39→      required: false,\n  40→      description: '目标标识符'\n  41→    },\n  42→    {\n  43→      name: 'type',\n  44→      type: 'enum',\n  45→      enum: ['feature', 'bugfix', 'planner'],\n  46→      required: false,\n  47→      default: 'feature',\n  48→      description: '管道类型'\n  49→    }\n  50→  ],\n  51→  requiresAuth: true,\n  52→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  53→};\n  54→\n  55→/**\n  56→ * Handle pipeline command.\n  57→ * @param {Object} handlerCtx - Handler context\n  58→ * @param {Object} handlerCtx.ctx - Telegraf context\n  59→ * @param {Object} handlerCtx.parsed - Parsed command\n  60→ * @param {Object} handlerCtx.params - Normalized parameters\n  61→ * @param {Function} handlerCtx.reply - Reply function\n  62→ */\n  63→export async function handlePipeline(handlerCtx) {\n  64→  const { ctx, parsed, params, reply } = handlerCtx;\n  65→\n  66→  // Determine action from subcommand or default to status\n  67→  const action = parsed.subcommand || 'status';\n  68→\n  69→  switch (action) {\n  70→    case 'run':\n  71→      return handleRun(handlerCtx);\n  72→    case 'status':\n  73→      return handleStatus(handlerCtx);\n  74→    case 'logs':\n  75→      return handleLogs(handlerCtx);\n  76→    case 'stop':\n  77→      return handleStop(handlerCtx);\n  78→    default:\n  79→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop`);\n  80→  }\n  81→}\n  82→\n  83→/**\n  84→ * Handle run subcommand.\n  85→ */\n  86→async function handleRun({ params, reply, parsed }) {\n  87→  const target = params._args?.[0] || params.target;\n  88→  const pipelineType = params.type || 'feature';\n  89→\n  90→  try {\n  91→    const result = await startPipeline({\n  92→      type: pipelineType,\n  93→      targetId: target,\n  94→      daemon: true\n  95→    });\n  96→\n  97→    if (result.ok) {\n  98→      const pidInfo = result.pid ? ` (PID: ${result.pid})` : '';\n  99→      await reply(`✅ 已启动 ${pipelineType} 管道${target ? `: ${target}` : ''}${pidInfo}`);\n 100→    } else {\n 101→      const errorMsg = result.message || result.stderr || '未知错误';\n 102→      const hint = result.hint ? `\\n💡 提示: ${result.hint}` : '';\n 103→      await reply(`❌ 启动失败: ${errorMsg}${hint}`);\n 104→    }\n 105→  } catch (error) {\n 106→    await reply(`❌ 启动失败: ${error.message}`);\n 107→  }\n 108→}\n 109→\n 110→/**\n 111→ * Handle status subcommand.\n 112→ */\n 113→async function handleStatus({ params, reply }) {\n 114→  const pipelineType = params.type || 'feature';\n 115→\n 116→  try {\n 117→    const result = await getStatus({ type: pipelineType });\n 118→\n 119→    if (result.ok) {\n 120→      const status = formatStatusOutput(result);\n 121→      await reply(status);\n 122→    } else {\n 123→      const errorMsg = result.message || result.stderr || '未知错误';\n 124→      await reply(`❌ 查询失败: ${errorMsg}`);\n 125→    }\n 126→  } catch (error) {\n 127→    await reply(`❌ 查询失败: ${error.message}`);\n 128→  }\n 129→}\n 130→\n 131→/**\n 132→ * Handle logs subcommand.\n 133→ */\n 134→async function handleLogs({ params, reply, replyFile, parsed }) {\n 135→  const target = params._args?.[0] || params.target;\n 136→  const pipelineType = params.type || 'feature';\n 137→\n 138→  try {\n 139→    const result = await getLogs({ type: pipelineType, lines: 100 });\n 140→\n 141→    if (result.ok) {\n 142→      const logs = result.logs || '';\n 143→\n 144→      if (logs.length >= 4000) {\n 145→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n 146→      } else {\n 147→        await reply(logs || '暂无日志');\n 148→      }\n 149→    } else {\n 150→      const errorMsg = result.message || '未知错误';\n 151→      await reply(`❌ 获取日志失败: ${errorMsg}`);\n 152→    }\n 153→  } catch (error) {\n 154→    await reply(`❌ 获取日志失败: ${error.message}`);\n 155→  }\n 156→}\n 157→\n 158→/**\n 159→ * Handle stop subcommand.\n 160→ */\n 161→async function handleStop({ params, reply, parsed }) {\n 162→  const target = params._args?.[0] || params.target;\n 163→  const pipelineType = params.type || 'feature';\n 164→\n 165→  try {\n 166→    const result = await stopPipeline({ type: pipelineType });\n 167→\n 168→    if (result.ok) {\n 169→      if (result.errorCode === 'ALREADY_STOPPED') {\n 170→        await reply(`⚠️ ${pipelineType} 管道未在运行。`);\n 171→      } else {\n 172→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n 173→        await reply(`✅ 已停止 ${pipelineType} 管道${pidInfo}`);\n 174→      }\n 175→    } else {\n 176→      const errorMsg = result.message || '未知错误';\n 177→      await reply(`❌ 停止失败: ${errorMsg}`);\n 178→    }\n 179→  } catch (error) {\n 180→    await reply(`❌ 停止失败: ${error.message}`);\n 181→  }\n 182→}\n 183→\n 184→/**\n 185→ * Format status output.\n 186→ * @param {Object} result - Status result\n 187→ * @returns {string} Formatted status\n 188→ */\n 189→function formatStatusOutput(result) {\n 190→  if (!result.isRunning) {\n 191→    const lastResultInfo = result.lastResult\n 192→      ? `\\n最后一次运行: ${result.lastResult.status} (${result.lastResult.featuresCompleted}/${result.lastResult.featuresTotal})`\n 193→      : '';\n 194→    return `✅ ${result.message}${lastResultInfo}`;\n 195→  }\n 196→\n 197→  const lines = [`🔄 ${result.message}`, ''];\n 198→\n 199→  if (result.pid) {\n 200→    lines.push(`• PID: ${result.pid}`);\n 201→  }\n 202→\n 203→  if (result.currentFeature) {\n 204→    lines.push(`• 当前目标: ${result.currentFeature}`);\n 205→  }\n 206→\n 207→  if (result.startedAt) {\n 208→    lines.push(`• 开始时间: ${result.startedAt}`);\n 209→  }\n 210→\n 211→  if (result.lockInfo) {\n 212→    lines.push(`• 锁持有者 PID: ${result.lockInfo.pid}`);\n 213→  }\n 214→\n 215→  return lines.join('\\n');\n 216→}\n 217→\n 218→export default handlePipeline;\n 219→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde9b972165b5f35eeda38e0e2170","__timestamp":"2026-03-11T20:35:08.730Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
{"type":"user","uuid":"6835d638-6d99-4908-b1b1-f08ad5c0c58e","session_id":"62951781-27f6-43fd-92b7-2a78a8a15ac7","message":{"content":[{"type":"tool_result","tool_use_id":"call_e7efbd5dc01841b3af287fb7","content":[{"type":"text","text":"   1→/**\n   2→ * Command Router\n   3→ * Main entry point for command routing and dispatch.\n   4→ */\n   5→\n   6→import { parseCommand } from './parser.js';\n   7→import { getCommand, getAliasMap, registerCommand } from './registry.js';\n   8→import { validateCommand } from './validator.js';\n   9→import { formatError, formatValidationErrors, ErrorCodes } from './formatter.js';\n  10→import { isAllowedUser } from '../../security/guard.js';\n  11→\n  12→/**\n  13→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  14→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  15→ * @typedef {import('./registry.js').CommandEntry} CommandEntry\n  16→ */\n  17→\n  18→/**\n  19→ * Route and dispatch a command from Telegram context.\n  20→ * @param {Object} ctx - Telegraf context\n  21→ * @returns {Promise<boolean>} True if command was handled\n  22→ */\n  23→export async function routeCommand(ctx) {\n  24→  const text = ctx.message?.text;\n  25→\n  26→  if (!text || !text.startsWith('/')) {\n  27→    return false;\n  28→  }\n  29→\n  30→  // Authorization check\n  31→  const userId = ctx.from?.id;\n  32→  if (!isAuthorized(userId)) {\n  33→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n  34→    return true;\n  35→  }\n  36→\n  37→  // Parse command\n  38→  const aliasMap = getAliasMap();\n  39→  const parsed = parseCommand(text, aliasMap);\n  40→\n  41→  if (!parsed) {\n  42→    await ctx.reply('无法解析命令。');\n  43→    return true;\n  44→  }\n  45→\n  46→  // Lookup command\n  47→  const entry = getCommand(parsed.command);\n  48→\n  49→  if (!entry) {\n  50→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n  51→    return true;\n  52→  }\n  53→\n  54→  const { meta, handler } = entry;\n  55→\n  56→  // Validate command\n  57→  const validation = validateCommand(parsed, meta);\n  58→\n  59→  if (!validation.valid) {\n  60→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n  61→    await ctx.reply(errorMsg);\n  62→    return true;\n  63→  }\n  64→\n  65→  // Create handler context\n  66→  const handlerContext = {\n  67→    ctx,\n  68→    parsed,\n  69→    meta,\n  70→    params: validation.normalized || {},\n  71→    reply: async (text) => ctx.reply(text),\n  72→    replyFile: async (content, filename) => {\n  73→      // Will be implemented with proper file handling\n  74→      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n  75→    }\n  76→  };\n  77→\n  78→  // Dispatch to handler\n  79→  try {\n  80→    await handler(handlerContext);\n  81→  } catch (error) {\n  82→    const message = error instanceof Error ? error.message : String(error);\n  83→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n  84→  }\n  85→\n  86→  return true;\n  87→}\n  88→\n  89→/**\n  90→ * Check if user is authorized.\n  91→ * @param {number|string|undefined} userId - User ID\n  92→ * @returns {boolean} True if authorized\n  93→ */\n  94→function isAuthorized(userId) {\n  95→  return isAllowedUser(userId);\n  96→}\n  97→\n  98→/**\n  99→ * Format error response for display.\n 100→ * @param {Object} error - Error object\n 101→ * @returns {string} Formatted error\n 102→ */\n 103→function formatErrorResponse(error) {\n 104→  const lines = [`❌ ${error.message}`];\n 105→\n 106→  if (error.suggestion) {\n 107→    lines.push(`💡 ${error.suggestion}`);\n 108→  }\n 109→\n 110→  if (error.usage) {\n 111→    lines.push(`用法: ${error.usage}`);\n 112→  }\n 113→\n 114→  return lines.join('\\n');\n 115→}\n 116→\n 117→/**\n 118→ * Register all default commands.\n 119→ */\n 120→export function registerDefaultCommands() {\n 121→  // Commands will be registered by individual handlers\n 122→  // This is called during initialization\n 123→}\n 124→\n 125→/**\n 126→ * Create middleware for command routing.\n 127→ * @returns {Function} Middleware function\n 128→ */\n 129→export function createCommandMiddleware() {\n 130→  return async (ctx, next) => {\n 131→    const handled = await routeCommand(ctx);\n 132→    if (!handled) {\n 133→      return next();\n 134→    }\n 135→  };\n 136→}\n 137→\n 138→// Re-export for convenience\n 139→export { registerCommand, getCommand, getAliasMap };\n 140→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cde9b972165b5f35eeda38e0e2170","__timestamp":"2026-03-11T20:35:08.730Z","_requestId":"9a060372b45d4f5a90dab23b747027c6"}
