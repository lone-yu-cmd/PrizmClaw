{"type":"user","uuid":"d0a4d41b-fcb8-4a65-a2e5-2b7b9f1087a1","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_cdd1b20189b34fc6b2045bb1","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Test for F-006: Safety and Permission Guard\n   3→ * Tests the full security flow end-to-end.\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdtemp, rm } from 'node:fs/promises';\n   9→import { join } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→import {\n  12→  checkCommandPermission,\n  13→  getUserRole,\n  14→  isAdmin,\n  15→  setConfigForTesting,\n  16→  resetConfig as resetPermConfig\n  17→} from '../../src/security/permission-guard.js';\n  18→import {\n  19→  createConfirmation,\n  20→  checkConfirmation,\n  21→  confirmAction,\n  22→  cancelConfirmation,\n  23→  clearExpiredConfirmations\n  24→} from '../../src/security/confirmation-manager.js';\n  25→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n  26→import {\n  27→  initAuditLogService,\n  28→  logAuditEntry,\n  29→  queryAuditLogs,\n  30→  resetAuditLogService\n  31→} from '../../src/services/audit-log-service.js';\n  32→\n  33→// Helper to create test config\n  34→function createTestConfig(overrides = {}) {\n  35→  return {\n  36→    userPermissions: new Map(),\n  37→    allowAdminSkipConfirm: true,\n  38→    enableSystemExec: false,\n  39→    allowedUserIds: new Set(),\n  40→    ...overrides\n  41→  };\n  42→}\n  43→\n  44→// Helper to create temp directory for audit log tests\n  45→async function withTempDir(fn) {\n  46→  const tempDir = await mkdtemp(join(tmpdir(), 'security-integration-'));\n  47→  try {\n  48→    return await fn(tempDir);\n  49→  } finally {\n  50→    await rm(tempDir, { recursive: true, force: true });\n  51→  }\n  52→}\n  53→\n  54→// US-1: User Permission Levels\n  55→test('US-1: User permission levels work correctly', async () => {\n  56→  resetPermConfig();\n  57→  resetAuditLogService();\n  58→  clearExpiredConfirmations();\n  59→\n  60→  const config = createTestConfig();\n  61→  config.userPermissions.set('admin-user', 'admin');\n  62→  config.userPermissions.set('op-user', 'operator');\n  63→  config.userPermissions.set('viewer-user', 'viewer');\n  64→  setConfigForTesting(config);\n  65→\n  66→  // Test role retrieval\n  67→  assert.equal(getUserRole('admin-user'), 'admin');\n  68→  assert.equal(getUserRole('op-user'), 'operator');\n  69→  assert.equal(getUserRole('viewer-user'), 'viewer');\n  70→  assert.equal(getUserRole('unknown-user'), 'operator'); // Default\n  71→\n  72→  // Test isAdmin\n  73→  assert.equal(isAdmin('admin-user'), true);\n  74→  assert.equal(isAdmin('op-user'), false);\n  75→  assert.equal(isAdmin('viewer-user'), false);\n  76→});\n  77→\n  78→// US-2: High-Risk Command Authorization\n  79→test('US-2: High-risk command authorization works correctly', async () => {\n  80→  resetPermConfig();\n  81→  resetAuditLogService();\n  82→  clearExpiredConfirmations();\n  83→\n  84→  const config = createTestConfig();\n  85→  config.userPermissions.set('admin-user', 'admin');\n  86→  config.userPermissions.set('op-user', 'operator');\n  87→  config.userPermissions.set('viewer-user', 'viewer');\n  88→  setConfigForTesting(config);\n  89→\n  90→  // stop command - admin only\n  91→  const adminStopResult = checkCommandPermission('admin-user', 'stop');\n  92→  assert.equal(adminStopResult.allowed, true);\n  93→  assert.equal(adminStopResult.requiresConfirmation, true);\n  94→\n  95→  const opStopResult = checkCommandPermission('op-user', 'stop');\n  96→  assert.equal(opStopResult.allowed, false);\n  97→\n  98→  // retry command - operator level\n  99→  const opRetryResult = checkCommandPermission('op-user', 'retry');\n 100→  assert.equal(opRetryResult.allowed, true);\n 101→  assert.equal(opRetryResult.requiresConfirmation, false);\n 102→\n 103→  const viewerRetryResult = checkCommandPermission('viewer-user', 'retry');\n 104→  assert.equal(viewerRetryResult.allowed, false);\n 105→});\n 106→\n 107→// US-3: Parameter Sanitization\n 108→test('US-3: Parameter sanitization works correctly', async () => {\n 109→  resetPermConfig();\n 110→  resetAuditLogService();\n 111→  clearExpiredConfirmations();\n 112→\n 113→  // Valid input passes\n 114→  const validResult = sanitizeParam('my-feature-123', { maxLength: 100 });\n 115→  assert.equal(validResult.ok, true);\n 116→\n 117→  // Dangerous patterns are blocked\n 118→  const traversalResult = sanitizeParam('../../../etc/passwd');\n 119→  assert.equal(traversalResult.ok, false);\n 120→\n 121→  const shellInjectionResult = sanitizeParam('$(whoami)');\n 122→  assert.equal(shellInjectionResult.ok, false);\n 123→\n 124→  // TargetId format validation\n 125→  const validTargetId = sanitizeParam('feature-branch_123', { isTargetId: true });\n 126→  assert.equal(validTargetId.ok, true);\n 127→\n 128→  const invalidTargetId = sanitizeParam('feature/branch', { isTargetId: true });\n 129→  assert.equal(invalidTargetId.ok, false);\n 130→\n 131→  // Path validation\n 132→  const validPath = validatePath('/project/src/file.js', ['/project']);\n 133→  assert.equal(validPath.ok, true);\n 134→\n 135→  const invalidPath = validatePath('/etc/passwd', ['/project']);\n 136→  assert.equal(invalidPath.ok, false);\n 137→});\n 138→\n 139→// US-4: Confirmation Flow\n 140→test('US-4: Confirmation flow works correctly', async () => {\n 141→  resetPermConfig();\n 142→  resetAuditLogService();\n 143→  clearExpiredConfirmations();\n 144→\n 145→  // Create confirmation\n 146→  const { confirmId, message } = createConfirmation('test-user', 'stop', { type: 'feature' });\n 147→  assert.ok(confirmId);\n 148→  assert.ok(message);\n 149→\n 150→  // Check pending status\n 151→  const pendingResult = checkConfirmation(confirmId, 'test-user');\n 152→  assert.equal(pendingResult.status, 'pending');\n 153→  assert.equal(pendingResult.action, 'stop');\n 154→\n 155→  // Confirm action\n 156→  const confirmResult = confirmAction(confirmId, 'test-user');\n 157→  assert.equal(confirmResult.ok, true);\n 158→  assert.equal(confirmResult.action, 'stop');\n 159→\n 160→  // Verify consumed\n 161→  const consumedResult = checkConfirmation(confirmId, 'test-user');\n 162→  assert.equal(consumedResult.status, 'not_found');\n 163→});\n 164→\n 165→test('US-4: Confirmation cancel works correctly', () => {\n 166→  resetPermConfig();\n 167→  resetAuditLogService();\n 168→  clearExpiredConfirmations();\n 169→\n 170→  const { confirmId } = createConfirmation('test-user', 'reset', {});\n 171→\n 172→  cancelConfirmation(confirmId, 'test-user');\n 173→\n 174→  const result = checkConfirmation(confirmId, 'test-user');\n 175→  assert.equal(result.status, 'not_found');\n 176→});\n 177→\n 178→test('US-4: Wrong user cannot confirm', () => {\n 179→  resetPermConfig();\n 180→  resetAuditLogService();\n 181→  clearExpiredConfirmations();\n 182→\n 183→  const { confirmId } = createConfirmation('user-1', 'stop', {});\n 184→\n 185→  const result = confirmAction(confirmId, 'user-2');\n 186→  assert.equal(result.ok, false);\n 187→});\n 188→\n 189→// US-5: Audit Logging\n 190→test('US-5: Audit logging works correctly', async () => {\n 191→  resetPermConfig();\n 192→  resetAuditLogService();\n 193→  clearExpiredConfirmations();\n 194→\n 195→  await withTempDir(async (tempDir) => {\n 196→    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 197→\n 198→    // Log entry\n 199→    await logAuditEntry({\n 200→      userId: '123456789',\n 201→      action: 'stop',\n 202→      params: { type: 'feature' },\n 203→      result: 'success'\n 204→    });\n 205→\n 206→    // Query logs\n 207→    const entries = await queryAuditLogs({ userId: '123456789' });\n 208→    assert.ok(entries.length >= 1);\n 209→\n 210→    const entry = entries.find((e) => e.action === 'stop');\n 211→    assert.ok(entry);\n 212→    assert.equal(entry.userId, '123456789');\n 213→    assert.equal(entry.result, 'success');\n 214→  });\n 215→});\n 216→\n 217→test('US-5: Audit log query filters work', async () => {\n 218→  resetPermConfig();\n 219→  resetAuditLogService();\n 220→  clearExpiredConfirmations();\n 221→\n 222→  await withTempDir(async (tempDir) => {\n 223→    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 224→\n 225→    await logAuditEntry({ userId: 'user-1', action: 'stop', params: {}, result: 'success' });\n 226→    await logAuditEntry({ userId: 'user-1', action: 'reset', params: {}, result: 'success' });\n 227→    await logAuditEntry({ userId: 'user-2', action: 'stop', params: {}, result: 'denied' });\n 228→\n 229→    const user1Entries = await queryAuditLogs({ userId: 'user-1' });\n 230→    assert.ok(user1Entries.every((e) => e.userId === 'user-1'));\n 231→\n 232→    const stopEntries = await queryAuditLogs({ action: 'stop' });\n 233→    assert.ok(stopEntries.every((e) => e.action === 'stop'));\n 234→  });\n 235→});\n 236→\n 237→// F-001: force-unlock command\n 238→test('F-001: force-unlock command requires admin and confirmation', async () => {\n 239→  resetPermConfig();\n 240→  resetAuditLogService();\n 241→  clearExpiredConfirmations();\n 242→\n 243→  const config = createTestConfig();\n 244→  config.userPermissions.set('admin-user', 'admin');\n 245→  config.userPermissions.set('op-user', 'operator');\n 246→  setConfigForTesting(config);\n 247→\n 248→  const adminResult = checkCommandPermission('admin-user', 'force-unlock');\n 249→  assert.equal(adminResult.allowed, true);\n 250→  assert.equal(adminResult.requiresConfirmation, true);\n 251→\n 252→  const opResult = checkCommandPermission('op-user', 'force-unlock');\n 253→  assert.equal(opResult.allowed, false);\n 254→});\n 255→\n 256→// F-002: exec command with ENABLE_SYSTEM_EXEC\n 257→test('F-002: exec command requires ENABLE_SYSTEM_EXEC', async () => {\n 258→  resetPermConfig();\n 259→  resetAuditLogService();\n 260→  clearExpiredConfirmations();\n 261→\n 262→  const config = createTestConfig({ enableSystemExec: false });\n 263→  config.userPermissions.set('admin-user', 'admin');\n 264→  setConfigForTesting(config);\n 265→\n 266→  const disabledResult = checkCommandPermission('admin-user', 'exec');\n 267→  assert.equal(disabledResult.allowed, false);\n 268→  assert.ok(disabledResult.reason.includes('系统命令执行未启用'));\n 269→\n 270→  // Enable system exec\n 271→  config.enableSystemExec = true;\n 272→  setConfigForTesting(config);\n 273→\n 274→  const enabledResult = checkCommandPermission('admin-user', 'exec');\n 275→  assert.equal(enabledResult.allowed, true);\n 276→});\n 277→\n 278→// Full flow test: Operator stop flow (should be denied)\n 279→test('Integration: Operator cannot execute stop command', async () => {\n 280→  resetPermConfig();\n 281→  resetAuditLogService();\n 282→  clearExpiredConfirmations();\n 283→\n 284→  await withTempDir(async (tempDir) => {\n 285→    const config = createTestConfig();\n 286→    config.userPermissions.set('op-user', 'operator');\n 287→    setConfigForTesting(config);\n 288→\n 289→    const result = checkCommandPermission('op-user', 'stop');\n 290→    assert.equal(result.allowed, false);\n 291→\n 292→    // Log denial\n 293→    await initAuditLogService({ logDir: tempDir });\n 294→    await logAuditEntry({\n 295→      userId: 'op-user',\n 296→      action: 'stop',\n 297→      params: {},\n 298→      result: 'denied',\n 299→      reason: result.reason\n 300→    });\n 301→\n 302→    const entries = await queryAuditLogs({ action: 'stop', userId: 'op-user' });\n 303→    assert.ok(entries.some((e) => e.result === 'denied'));\n 304→  });\n 305→});\n 306→\n 307→// Full flow test: Admin stop with confirmation\n 308→test('Integration: Admin stop with confirmation flow', async () => {\n 309→  resetPermConfig();\n 310→  resetAuditLogService();\n 311→  clearExpiredConfirmations();\n 312→\n 313→  await withTempDir(async (tempDir) => {\n 314→    const config = createTestConfig();\n 315→    config.userPermissions.set('admin-user', 'admin');\n 316→    setConfigForTesting(config);\n 317→\n 318→    // 1. Check permission\n 319→    const permResult = checkCommandPermission('admin-user', 'stop');\n 320→    assert.equal(permResult.allowed, true);\n 321→    assert.equal(permResult.requiresConfirmation, true);\n 322→\n 323→    // 2. Create confirmation\n 324→    const { confirmId } = createConfirmation('admin-user', 'stop', { type: 'feature' });\n 325→\n 326→    // 3. Confirm\n 327→    const confirmResult = confirmAction(confirmId, 'admin-user');\n 328→    assert.equal(confirmResult.ok, true);\n 329→\n 330→    // 4. Log success\n 331→    await initAuditLogService({ logDir: tempDir });\n 332→    await logAuditEntry({\n 333→      userId: 'admin-user',\n 334→      action: 'stop',\n 335→      params: { type: 'feature' },\n 336→      result: 'success'\n 337→    });\n 338→\n 339→    const entries = await queryAuditLogs({ userId: 'admin-user', action: 'stop' });\n 340→    assert.ok(entries.some((e) => e.result === 'success'));\n 341→  });\n 342→});\n 343→\n 344→// AC-2.5: Error message security\n 345→test('AC-2.5: Error messages do not expose sensitive info', async () => {\n 346→  resetPermConfig();\n 347→  resetAuditLogService();\n 348→  clearExpiredConfirmations();\n 349→\n 350→  const config = createTestConfig();\n 351→  config.userPermissions.set('viewer-user', 'viewer');\n 352→  setConfigForTesting(config);\n 353→\n 354→  const result = checkCommandPermission('viewer-user', 'stop');\n 355→  assert.equal(result.allowed, false);\n 356→  assert.ok(!result.reason.includes('/'));\n 357→  assert.ok(!result.reason.includes('config'));\n 358→  assert.ok(!result.reason.includes('password'));\n 359→});\n 360→\n 361→// NFR-1: Performance\n 362→test('NFR-1: Permission check is fast', () => {\n 363→  resetPermConfig();\n 364→  resetAuditLogService();\n 365→  clearExpiredConfirmations();\n 366→\n 367→  const config = createTestConfig();\n 368→  config.userPermissions.set('test-user', 'admin');\n 369→  setConfigForTesting(config);\n 370→\n 371→  const start = Date.now();\n 372→  for (let i = 0; i < 1000; i++) {\n 373→    checkCommandPermission('test-user', 'stop');\n 374→  }\n 375→  const duration = Date.now() - start;\n 376→\n 377→  // 1000 checks should take < 50ms total (< 0.05ms per check, well under 5ms requirement)\n 378→  assert.ok(duration < 50, `Permission check too slow: ${duration}ms for 1000 checks`);\n 379→});\n 380→\n 381→test('NFR-1: Param sanitization is fast', () => {\n 382→  resetPermConfig();\n 383→  resetAuditLogService();\n 384→  clearExpiredConfirmations();\n 385→\n 386→  const start = Date.now();\n 387→  for (let i = 0; i < 1000; i++) {\n 388→    sanitizeParam('test-input-with-moderate-length', { maxLength: 100 });\n 389→  }\n 390→  const duration = Date.now() - start;\n 391→\n 392→  // 1000 sanitizations should take < 20ms total (< 0.02ms per check, well under 2ms requirement)\n 393→  assert.ok(duration < 20, `Sanitization too slow: ${duration}ms for 1000 checks`);\n 394→});\n 395→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:09:35.910Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
