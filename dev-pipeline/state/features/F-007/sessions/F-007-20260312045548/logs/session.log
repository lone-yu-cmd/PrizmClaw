===============================================\n 541→\n 542→test('getLogs should return log content', async () => {\n 543→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 544→  try {\n 545→    const config = createMockConfig(stateDir, bugfixStateDir);\n 546→    const lockManager = createLockManager({ config });\n 547→    const stateManager = createStateManager({ config });\n 548→    const scriptRunner = createMockScriptRunner();\n 549→\n 550→    // Write log file\n 551→    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), 'Line 1\\nLine 2\\nLine 3');\n 552→\n 553→    const controller = createPipelineController({\n 554→      lockManager,\n 555→      stateManager,\n 556→      scriptRunner,\n 557→      config\n 558→    });\n 559→\n 560→    const result = await controller.getLogs({ type: 'feature', lines: 10 });\n 561→    assert.equal(result.ok, true);\n 562→    assert.ok(result.logs);\n 563→    assert.ok(result.logPath);\n 564→    assert.ok(result.lines);\n 565→  } finally {\n 566→    cleanup();\n 567→  }\n 568→});\n 569→\n 570→test('getLogs should handle missing log file gracefully', async () => {\n 571→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 572→  try {\n 573→    const config = createMockConfig(stateDir, bugfixStateDir);\n 574→    const lockManager = createLockManager({ config });\n 575→    const stateManager = createStateManager({ config });\n 576→    const scriptRunner = createMockScriptRunner();\n 577→\n 578→    const controller = createPipelineController({\n 579→      lockManager,\n 580→      stateManager,\n 581→      scriptRunner,\n 582→      config\n 583→    });\n 584→\n 585→    const result = await controller.getLogs({ type: 'feature' });\n 586→    assert.equal(result.ok, true);\n 587→    assert.equal(result.logs, '');\n 588→  } finally {\n 589→    cleanup();\n 590→  }\n 591→});\n 592→\n 593→// ============================================================\n 594→// US-7: forceUnlock Tests\n 595→// ============================================================\n 596→\n 597→test('forceUnlock should remove lock regardless of owner', async () => {\n 598→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 599→  try {\n 600→    const config = createMockConfig(stateDir, bugfixStateDir);\n 601→    const lockManager = createLockManager({ config });\n 602→    const stateManager = createStateManager({ config });\n 603→    const scriptRunner = createMockScriptRunner();\n 604→\n 605→    // Create a lock with a different PID\n 606→    await lockManager.acquireLock('feature', 99999);\n 607→\n 608→    const controller = createPipelineController({\n 609→      lockManager,\n 610→      stateManager,\n 611→      scriptRunner,\n 612→      config\n 613→    });\n 614→\n 615→    const result = await controller.forceUnlock({ type: 'feature' });\n 616→    assert.equal(result.ok, true);\n 617→    assert.equal(result.previousPid, 99999);\n 618→\n 619→    // Lock should be released\n 620→    assert.equal(await lockManager.isLocked('feature'), false);\n 621→  } finally {\n 622→    cleanup();\n 623→  }\n 624→});\n 625→\n 626→// ============================================================\n 627→// US-8: Error Mapping Tests\n 628→// ============================================================\n 629→\n 630→test('all methods should return JSON-serializable results', async () => {\n 631→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 632→  try {\n 633→    const config = createMockConfig(stateDir, bugfixStateDir);\n 634→    const lockManager = createLockManager({ config });\n 635→    const stateManager = createStateManager({ config });\n 636→    const scriptRunner = createMockScriptRunner();\n 637→\n 638→    const controller = createPipelineController({\n 639→      lockManager,\n 640→      stateManager,\n 641→      scriptRunner,\n 642→      config\n 643→    });\n 644→\n 645→    const results = await Promise.all([\n 646→      controller.startPipeline({ type: 'feature' }),\n 647→      controller.getStatus({ type: 'feature' }),\n 648→      controller.getLogs({ type: 'feature' })\n 649→    ]);\n 650→\n 651→    for (const result of results) {\n 652→      assert.doesNotThrow(() => JSON.stringify(result));\n 653→    }\n 654→  } finally {\n 655→    cleanup();\n 656→  }\n 657→});\n 658→\n 659→test('errors should include hint field', async () => {\n 660→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 661→  try {\n 662→    const config = createMockConfig(stateDir, bugfixStateDir);\n 663→    const lockManager = createLockManager({ config });\n 664→    const stateManager = createStateManager({ config });\n 665→    const scriptRunner = createMockScriptRunner();\n 666→\n 667→    // Lock first\n 668→    await lockManager.acquireLock('feature', process.pid);\n 669→\n 670→    const controller = createPipelineController({\n 671→      lockManager,\n 672→      stateManager,\n 673→      scriptRunner,\n 674→      config\n 675→    });\n 676→\n 677→    const result = await controller.startPipeline({ type: 'feature' });\n 678→    assert.equal(result.ok, false);\n 679→    assert.ok(result.hint);\n 680→  } finally {\n 681→    cleanup();\n 682→  }\n 683→});\n 684→\n 685→test('errors should include context field', async () => {\n 686→  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 687→  try {\n 688→    const config = createMockConfig(stateDir, bugfixStateDir);\n 689→    const lockManager = createLockManager({ config });\n 690→    const stateManager = createStateManager({ config });\n 691→    const scriptRunner = createMockScriptRunner();\n 692→\n 693→    // Lock first\n 694→    await lockManager.acquireLock('feature', process.pid);\n 695→\n 696→    const controller = createPipelineController({\n 697→      lockManager,\n 698→      stateManager,\n 699→      scriptRunner,\n 700→      config\n 701→    });\n 702→\n 703→    const result = await controller.startPipeline({ type: 'feature' });\n 704→    