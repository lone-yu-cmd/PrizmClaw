{"type":"assistant","uuid":"20260312051315fd77c199b691496d","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"id":"20260312051315fd77c199b691496d","content":[{"type":"tool_use","id":"019cdebf3943478f723c0e08d0b85b28","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/helpers/test-state.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":44049,"output_tokens":170,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:20.468Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"43782c36-23d3-4159-a2f0-944146b3c3a2","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf3435e77e40cfb0c11d10e1fa","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for test helpers\n   3→ * F-007: Test and Validation Suite\n   4→ *\n   5→ * Verifies that all test helper modules work correctly.\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import { join } from 'node:path';\n  11→\n  12→// Import all helpers at module level\n  13→import {\n  14→  getFixturePath,\n  15→  loadFixture,\n  16→  loadJsonFixture,\n  17→  fixtureExists\n  18→} from './fixture-loader.js';\n  19→\n  20→import {\n  21→  createMockRunner,\n  22→  createStatefulMockRunner\n  23→} from './mock-runner.js';\n  24→\n  25→import {\n  26→  createMockContext,\n  27→  createAdminContext,\n  28→  createOperatorContext,\n  29→  createViewerContext,\n  30→  createDocumentContext,\n  31→  createCommandContext\n  32→} from './mock-telegram.js';\n  33→\n  34→import {\n  35→  createTestStateDir,\n  36→  createTestPipelineDirs,\n  37→  writeTestState,\n  38→  readTestState,\n  39→  createTestPlan\n  40→} from './test-state.js';\n  41→\n  42→// ============================================================\n  43→// Fixture Loader Tests\n  44→// ============================================================\n  45→\n  46→test('fixture-loader: getFixturePath returns correct path', () => {\n  47→  const path = getFixturePath('plans/valid-feature-list.json');\n  48→  assert.ok(path.includes('fixtures'));\n  49→  assert.ok(path.includes('plans'));\n  50→  assert.ok(path.includes('valid-feature-list.json'));\n  51→});\n  52→\n  53→test('fixture-loader: loadFixture loads file content', () => {\n  54→  const content = loadFixture('plans/valid-feature-list.json');\n  55→  assert.ok(content.includes('$schema'));\n  56→  assert.ok(content.includes('TestApp'));\n  57→});\n  58→\n  59→test('fixture-loader: loadFixture throws for non-existent file', () => {\n  60→  assert.throws(\n  61→    () => loadFixture('non-existent-file.json'),\n  62→    /Fixture not found/\n  63→  );\n  64→});\n  65→\n  66→test('fixture-loader: loadJsonFixture parses JSON correctly', () => {\n  67→  const data = loadJsonFixture('plans/valid-feature-list.json');\n  68→  assert.equal(data.$schema, 'dev-pipeline-feature-list-v1');\n  69→  assert.equal(data.app_name, 'TestApp');\n  70→  assert.ok(Array.isArray(data.features));\n  71→});\n  72→\n  73→test('fixture-loader: loadJsonFixture throws for invalid JSON', () => {\n  74→  assert.throws(\n  75→    () => loadJsonFixture('plans/invalid-bad-json.json'),\n  76→    /Invalid JSON/\n  77→  );\n  78→});\n  79→\n  80→test('fixture-loader: fixtureExists returns true for existing fixture', () => {\n  81→  assert.equal(fixtureExists('plans/valid-feature-list.json'), true);\n  82→});\n  83→\n  84→test('fixture-loader: fixtureExists returns false for non-existing fixture', () => {\n  85→  assert.equal(fixtureExists('non-existent.json'), false);\n  86→});\n  87→\n  88→// ============================================================\n  89→// Mock Runner Tests\n  90→// ============================================================\n  91→\n  92→test('mock-runner: createMockRunner returns function', () => {\n  93→  const runner = createMockRunner();\n  94→  assert.equal(typeof runner, 'function');\n  95→});\n  96→\n  97→test('mock-runner: returns default response for unmocked action', async () => {\n  98→  const runner = createMockRunner();\n  99→  const result = await runner({ action: 'unknown' });\n 100→\n 101→  assert.equal(result.ok, true);\n 102→  assert.equal(result.normalizedStatus, 'success');\n 103→});\n 104→\n 105→test('mock-runner: returns configured response', async () => {\n 106→  const runner = createMockRunner({\n 107→    run: { ok: true, pid: 12345, runId: 'run-001' }\n 108→  });\n 109→\n 110→  const result = await runner({ action: 'run' });\n 111→  assert.equal(result.ok, true);\n 112→  assert.equal(result.pid, 12345);\n 113→  assert.equal(result.runId, 'run-001');\n 114→});\n 115→\n 116→test('mock-runner: supports response sequencing', async () => {\n 117→  const runner = createMockRunner({\n 118→    status: [\n 119→      { ok: true, isRunning: true },\n 120→      { ok: true, isRunning: false }\n 121→    ]\n 122→  });\n 123→\n 124→  const result1 = await runner({ action: 'status' });\n 125→  assert.equal(result1.isRunning, true);\n 126→\n 127→  const result2 = await runner({ action: 'status' });\n 128→  assert.equal(result2.isRunning, false);\n 129→});\n 130→\n 131→test('mock-runner: callLog tracks calls', async () => {\n 132→  const runner = createMockRunner();\n 133→  await runner({ action: 'run', targetId: 'F-001' });\n 134→  await runner({ action: 'status' });\n 135→\n 136→  const log = runner.getCallLog();\n 137→  assert.equal(log.length, 2);\n 138→  assert.equal(log[0].action, 'run');\n 139→  assert.equal(log[0].params.targetId, 'F-001');\n 140→});\n 141→\n 142→test('mock-runner: getCalls filters by action', async () => {\n 143→  const runner = createMockRunner();\n 144→  await runner({ action: 'run' });\n 145→  await runner({ action: 'status' });\n 146→  await runner({ action: 'run' });\n 147→\n 148→  const runCalls = runner.getCalls('run');\n 149→  assert.equal(runCalls.length, 2);\n 150→});\n 151→\n 152→test('mock-runner: addResponse adds new response', async () => {\n 153→  const runner = createMockRunner();\n 154→  runner.addResponse('run', { ok: true, pid: 999 });\n 155→\n 156→  const result = await runner({ action: 'run' });\n 157→  assert.equal(result.pid, 999);\n 158→});\n 159→\n 160→test('mock-runner: createStatefulMockRunner tracks state', async () => {\n 161→  const runner = createStatefulMockRunner();\n 162→  let state = runner.getState();\n 163→  assert.equal(state.isRunning, false);\n 164→\n 165→  await runner({ action: 'run' });\n 166→  state = runner.getState();\n 167→  assert.equal(state.isRunning, true);\n 168→\n 169→  await runner({ action: 'stop' });\n 170→  state = runner.getState();\n 171→  assert.equal(state.isRunning, false);\n 172→});\n 173→\n 174→test('mock-runner: createStatefulMockRunner prevents duplicate start', async () => {\n 175→  const runner = createStatefulMockRunner({ startRunning: true });\n 176→  const result = await runner({ action: 'run' });\n 177→\n 178→  assert.equal(result.ok, false);\n 179→  assert.equal(result.errorCode, 'ALREADY_RUNNING');\n 180→});\n 181→\n 182→// ============================================================\n 183→// Mock Telegram Tests\n 184→// ============================================================\n 185→\n 186→test('mock-telegram: createMockContext creates context', () => {\n 187→  const ctx = createMockContext();\n 188→  assert.ok(ctx.message);\n 189→  assert.ok(ctx.chat);\n 190→  assert.ok(ctx.from);\n 191→  assert.equal(typeof ctx.reply, 'function');\n 192→});\n 193→\n 194→test('mock-telegram: createMockContext applies overrides', () => {\n 195→  const ctx = createMockContext({\n 196→    message: { text: '/start' }\n 197→  });\n 198→\n 199→  assert.equal(ctx.message.text, '/start');\n 200→});\n 201→\n 202→test('mock-telegram: reply captures messages', async () => {\n 203→  const ctx = createMockContext();\n 204→  await ctx.reply('Hello');\n 205→  await ctx.reply('World');\n 206→\n 207→  const replies = ctx._getReplies();\n 208→  assert.equal(replies.length, 2);\n 209→  assert.equal(replies[0].text, 'Hello');\n 210→  assert.equal(replies[1].text, 'World');\n 211→});\n 212→\n 213→test('mock-telegram: _getLastReply returns last reply', async () => {\n 214→  const ctx = createMockContext();\n 215→  await ctx.reply('First');\n 216→  await ctx.reply('Last');\n 217→\n 218→  const last = ctx._getLastReply();\n 219→  assert.equal(last.text, 'Last');\n 220→});\n 221→\n 222→test('mock-telegram: createAdminContext sets admin permission', () => {\n 223→  const ctx = createAdminContext();\n 224→  assert.equal(ctx.state.permission, 'admin');\n 225→});\n 226→\n 227→test('mock-telegram: createOperatorContext sets operator permission', () => {\n 228→  const ctx = createOperatorContext();\n 229→  assert.equal(ctx.state.permission, 'operator');\n 230→});\n 231→\n 232→test('mock-telegram: createViewerContext sets viewer permission', () => {\n 233→  const ctx = createViewerContext();\n 234→  assert.equal(ctx.state.permission, 'viewer');\n 235→});\n 236→\n 237→test('mock-telegram: createDocumentContext creates document message', () => {\n 238→  const ctx = createDocumentContext({\n 239→    file_name: 'test-plan.json',\n 240→    file_size: 2048\n 241→  });\n 242→\n 243→  assert.ok(ctx.message.document);\n 244→  assert.equal(ctx.message.document.file_name, 'test-plan.json');\n 245→  assert.equal(ctx.message.document.file_size, 2048);\n 246→});\n 247→\n 248→test('mock-telegram: createCommandContext creates command message', () => {\n 249→  const ctx = createCommandContext('/pipeline run --type=feature');\n 250→  assert.equal(ctx.message.text, '/pipeline run --type=feature');\n 251→});\n 252→\n 253→// ============================================================\n 254→// Test State Tests\n 255→// ============================================================\n 256→\n 257→test('test-state: createTestStateDir creates directory', async () => {\n 258→  const { path, cleanup } = await createTestStateDir();\n 259→  assert.ok(path);\n 260→\n 261→  await cleanup();\n 262→});\n 263→\n 264→test('test-state: createTestPipelineDirs creates full structure', async () => {\n 265→  const { tempDir, stateDir, bugfixStateDir, plansDir, cleanup } = await createTestPipelineDirs();\n 266→\n 267→  assert.ok(tempDir);\n 268→  assert.ok(stateDir);\n 269→  assert.ok(bugfixStateDir);\n 270→  assert.ok(plansDir);\n 271→\n 272→  await cleanup();\n 273→});\n 274→\n 275→test('test-state: writeTestState and readTestState work together', async () => {\n 276→  const { path, cleanup } = await createTestStateDir();\n 277→\n 278→  const testData = { foo: 'bar', nested: { value: 42 } };\n 279→  const filePath = join(path, 'test.json');\n 280→\n 281→  await writeTestState(filePath, testData);\n 282→  const loaded = await readTestState(filePath);\n 283→\n 284→  assert.deepEqual(loaded, testData);\n 285→\n 286→  await cleanup();\n 287→});\n 288→\n 289→test('test-state: readTestState returns null for non-existent file', async () => {\n 290→  const result = await readTestState('/non/existent/path.json');\n 291→  assert.equal(result, null);\n 292→});\n 293→\n 294→test('test-state: createTestPlan creates plan file', async () => {\n 295→  const { plansDir, cleanup } = await createTestPipelineDirs();\n 296→\n 297→  const planContent = {\n 298→    $schema: 'dev-pipeline-feature-list-v1',\n 299→    app_name: 'TestApp',\n 300→    features: []\n 301→  };\n 302→\n 303→  const planPath = await createTestPlan(plansDir, 'feature-list', planContent);\n 304→  const loaded = await readTestState(planPath);\n 305→\n 306→  assert.equal(loaded.app_name, 'TestApp');\n 307→\n 308→  await cleanup();\n 309→});\n 310→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:20.469Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"4d386eed-e3a3-4ed6-9ecd-6a51166d5a39","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf35ba90032619f2b134828444","content":[{"type":"text","text":"   1→/**\n   2→ * Mock Script Runner Helper\n   3→ * F-007: Test and Validation Suite\n   4→ *\n   5→ * Replaces real shell execution with controlled responses.\n   6→ * Supports action routing, response sequencing, and delay simulation.\n   7→ */\n   8→\n   9→/**\n  10→ * @typedef {Object} MockResponse\n  11→ * @property {boolean} ok - Whether the action succeeded\n  12→ * @property {any} [data] - Optional response data\n  13→ * @property {string} [errorCode] - Error code if ok is false\n  14→ * @property {string} [message] - Optional message\n  15→ * @property {number} [delay] - Optional delay in ms to simulate execution time\n  16→ * @property {number} [exitCode] - Exit code (default 0 if ok, 1 if not)\n  17→ * @property {string} [stdout] - Simulated stdout\n  18→ * @property {string} [stderr] - Simulated stderr\n  19→ */\n  20→\n  21→/**\n  22→ * @typedef {Object} MockResponseMap\n  23→ * @property {MockResponse|MockResponse[]} [action] - Response(s) for each action\n  24→ */\n  25→\n  26→/**\n  27→ * Create a mock script runner\n  28→ * @param {MockResponseMap} responses - Map of action -> response(s)\n  29→ * @returns {Function} Mock runner function compatible with pipeline-control-service\n  30→ */\n  31→export function createMockRunner(responses = {}) {\n  32→  const callLog = [];\n  33→  const responseQueue = new Map();\n  34→\n  35→  // Initialize response queues\n  36→  for (const [action, response] of Object.entries(responses)) {\n  37→    if (Array.isArray(response)) {\n  38→      responseQueue.set(action, [...response]);\n  39→    } else {\n  40→      responseQueue.set(action, [response]);\n  41→    }\n  42→  }\n  43→\n  44→  /**\n  45→   * Mock runner function\n  46→   * @param {Object} req - Request object with action and params\n  47→   * @returns {Promise<Object>} Response object\n  48→   */\n  49→  const runner = async (req) => {\n  50→    const { action, ...params } = req;\n  51→    callLog.push({ action, params, timestamp: Date.now() });\n  52→\n  53→    const queue = responseQueue.get(action);\n  54→    let response;\n  55→\n  56→    if (queue && queue.length > 0) {\n  57→      // Get next response from queue (or reuse last one)\n  58→      if (queue.length === 1) {\n  59→        response = queue[0];\n  60→      } else {\n  61→        response = queue.shift();\n  62→      }\n  63→    } else {\n  64→      // Default response for unmocked actions\n  65→      response = {\n  66→        ok: true,\n  67→        message: `Mocked action: ${action}`,\n  68→        exitCode: 0,\n  69→        stdout: '',\n  70→        stderr: ''\n  71→      };\n  72→    }\n  73→\n  74→    // Simulate delay if specified\n  75→    if (response.delay) {\n  76→      await new Promise((resolve) => setTimeout(resolve, response.delay));\n  77→    }\n  78→\n  79→    // Normalize response format\n  80→    return {\n  81→      ok: response.ok ?? true,\n  82→      exitCode: response.exitCode ?? (response.ok !== false ? 0 : 1),\n  83→      stdout: response.stdout ?? '',\n  84→      stderr: response.stderr ?? '',\n  85→      normalizedStatus: response.ok !== false ? 'success' : 'failed',\n  86→      ...response\n  87→    };\n  88→  };\n  89→\n  90→  /**\n  91→   * Get the call log\n  92→   * @returns {Array} List of calls made to the runner\n  93→   */\n  94→  runner.getCallLog = () => [...callLog];\n  95→\n  96→  /**\n  97→   * Get calls for a specific action\n  98→   * @param {string} action - Action to filter by\n  99→   * @returns {Array} List of calls for that action\n 100→   */\n 101→  runner.getCalls = (action) => callLog.filter((c) => c.action === action);\n 102→\n 103→  /**\n 104→   * Clear the call log\n 105→   */\n 106→  runner.clearLog = () => {\n 107→    callLog.length = 0;\n 108→  };\n 109→\n 110→  /**\n 111→   * Add a response for an action\n 112→   * @param {string} action - Action name\n 113→   * @param {MockResponse} response - Response to add\n 114→   */\n 115→  runner.addResponse = (action, response) => {\n 116→    if (!responseQueue.has(action)) {\n 117→      responseQueue.set(action, []);\n 118→    }\n 119→    responseQueue.get(action).push(response);\n 120→  };\n 121→\n 122→  /**\n 123→   * Set responses (replaces existing)\n 124→   * @param {MockResponseMap} newResponses - New response map\n 125→   */\n 126→  runner.setResponses = (newResponses) => {\n 127→    responseQueue.clear();\n 128→    for (const [action, response] of Object.entries(newResponses)) {\n 129→      if (Array.isArray(response)) {\n 130→        responseQueue.set(action, [...response]);\n 131→      } else {\n 132→        responseQueue.set(action, [response]);\n 133→      }\n 134→    }\n 135→  };\n 136→\n 137→  return runner;\n 138→}\n 139→\n 140→/**\n 141→ * Create a mock runner that simulates state transitions\n 142→ * @param {Object} options - Configuration options\n 143→ * @param {boolean} [options.startRunning] - Whether pipeline starts in running state\n 144→ * @returns {Function} Mock runner with state tracking\n 145→ */\n 146→export function createStatefulMockRunner(options = {}) {\n 147→  const state = {\n 148→    isRunning: options.startRunning ?? false,\n 149→    pid: options.startRunning ? 12345 : null,\n 150→    runId: options.startRunning ? 'run-test-001' : null,\n 151→    currentFeature: options.startRunning ? 'F-TEST-001' : null,\n 152→    completed: [],\n 153→    failed: []\n 154→  };\n 155→\n 156→  const responses = {\n 157→    run: () => {\n 158→      if (state.isRunning) {\n 159→        return {\n 160→          ok: false,\n 161→          errorCode: 'ALREADY_RUNNING',\n 162→          message: 'Pipeline is already running'\n 163→        };\n 164→      }\n 165→      state.isRunning = true;\n 166→      state.pid = 12345;\n 167→      state.runId = `run-${Date.now()}`;\n 168→      state.currentFeature = 'F-TEST-001';\n 169→      return {\n 170→        ok: true,\n 171→        pid: state.pid,\n 172→        runId: state.runId,\n 173→        message: 'Pipeline started'\n 174→      };\n 175→    },\n 176→    status: () => ({\n 177→      ok: true,\n 178→      isRunning: state.isRunning,\n 179→      pid: state.pid,\n 180→      runId: state.runId,\n 181→      currentFeature: state.currentFeature,\n 182→      completed: state.completed,\n 183→      failed: state.failed\n 184→    }),\n 185→    stop: () => {\n 186→      if (!state.isRunning) {\n 187→        return {\n 188→          ok: true,\n 189→          errorCode: 'ALREADY_STOPPED',\n 190→          message: 'Pipeline is not running'\n 191→        };\n 192→      }\n 193→      state.isRunning = false;\n 194→      state.completed = ['F-TEST-001', 'F-TEST-002'];\n 195→      state.currentFeature = null;\n 196→      return {\n 197→        ok: true,\n 198→        previousPid: state.pid,\n 199→        message: 'Pipeline stopped'\n 200→      };\n 201→    },\n 202→    retry: ({ targetId }) => ({\n 203→      ok: true,\n 204→      targetId,\n 205→      message: `Retried ${targetId}`\n 206→    }),\n 207→    logs: () => ({\n 208→      ok: true,\n 209→      logs: 'Mock log line 1\\nMock log line 2\\nMock log line 3',\n 210→      lines: 3\n 211→    }),\n 212→    reset: ({ targetId }) => ({\n 213→      ok: true,\n 214→      targetId,\n 215→      message: `Reset ${targetId}`\n 216→    })\n 217→  };\n 218→\n 219→  const runner = async (req) => {\n 220→    const { action, ...params } = req;\n 221→    const handler = responses[action];\n 222→\n 223→    if (handler) {\n 224→      const result = handler(params);\n 225→      return {\n 226→        ...result,\n 227→        exitCode: result.ok !== false ? 0 : 1,\n 228→        stdout: result.message || '',\n 229→        stderr: result.ok === false ? result.message : '',\n 230→        normalizedStatus: result.ok !== false ? 'success' : 'failed'\n 231→      };\n 232→    }\n 233→\n 234→    return {\n 235→      ok: true,\n 236→      message: `Mocked action: ${action}`,\n 237→      exitCode: 0,\n 238→      stdout: '',\n 239→      stderr: '',\n 240→      normalizedStatus: 'success'\n 241→    };\n 242→  };\n 243→\n 244→  runner.getState = () => ({ ...state });\n 245→  runner.setState = (newState) => Object.assign(state, newState);\n 246→\n 247→  return runner;\n 248→}\n 249→\n 250→export default {\n 251→  createMockRunner,\n 252→  createStatefulMockRunner\n 253→};\n 254→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:20.469Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"31991bd7-066c-4b91-bb18-52a5187dc04f","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf3777e6fc79210954adf23853","content":[{"type":"text","text":"   1→/**\n   2→ * Mock Telegram Context Helper\n   3→ * F-007: Test and Validation Suite\n   4→ *\n   5→ * Simulates Telegraf bot context for command handler tests.\n   6→ */\n   7→\n   8→/**\n   9→ * @typedef {Object} MockContext\n  10→ * @property {Object} message - The message object\n  11→ * @property {Object} chat - The chat object\n  12→ * @property {Object} from - The user object\n  13→ * @property {Function} reply - Mock reply function\n  14→ * @property {Function} replyWithDocument - Mock replyWithDocument function\n  15→ * @property {Object} state - State object for middleware data\n  16→ */\n  17→\n  18→/**\n  19→ * Create a mock Telegram context\n  20→ * @param {Object} overrides - Override properties\n  21→ * @returns {MockContext} Mock context object\n  22→ */\n  23→export function createMockContext(overrides = {}) {\n  24→  const replies = [];\n  25→  const documents = [];\n  26→\n  27→  const defaultContext = {\n  28→    message: {\n  29→      text: null,\n  30→      document: null,\n  31→      from: {\n  32→        id: 123456789,\n  33→        is_bot: false,\n  34→        first_name: 'Test',\n  35→        username: 'testuser'\n  36→      },\n  37→      chat: {\n  38→        id: 123456789,\n  39→        type: 'private'\n  40→      },\n  41→      date: Math.floor(Date.now() / 1000),\n  42→      message_id: 1\n  43→    },\n  44→    chat: {\n  45→      id: 123456789,\n  46→      type: 'private'\n  47→    },\n  48→    from: {\n  49→      id: 123456789,\n  50→      is_bot: false,\n  51→      first_name: 'Test',\n  52→      username: 'testuser'\n  53→    },\n  54→    state: {},\n  55→    reply: async (text, options = {}) => {\n  56→      replies.push({ text, options, timestamp: Date.now() });\n  57→      return { message_id: replies.length };\n  58→    },\n  59→    replyWithDocument: async (document, options = {}) => {\n  60→      documents.push({ document, options, timestamp: Date.now() });\n  61→      return { message_id: documents.length };\n  62→    },\n  63→    deleteMessage: async () => true,\n  64→    editMessageText: async (text, options = {}) => {\n  65→      replies.push({ text, options, edited: true, timestamp: Date.now() });\n  66→      return true;\n  67→    }\n  68→  };\n  69→\n  70→  const context = {\n  71→    ...defaultContext,\n  72→    ...overrides,\n  73→    message: {\n  74→      ...defaultContext.message,\n  75→      ...(overrides.message || {}),\n  76→      from: {\n  77→        ...defaultContext.message.from,\n  78→        ...(overrides.message?.from || {})\n  79→      },\n  80→      chat: {\n  81→        ...defaultContext.message.chat,\n  82→        ...(overrides.message?.chat || {})\n  83→      }\n  84→    },\n  85→    chat: {\n  86→      ...defaultContext.chat,\n  87→      ...(overrides.chat || {})\n  88→    },\n  89→    from: {\n  90→      ...defaultContext.from,\n  91→      ...(overrides.from || {})\n  92→    },\n  93→    state: overrides.state || {}\n  94→  };\n  95→\n  96→  // Attach helper methods\n  97→  context._getReplies = () => [...replies];\n  98→  context._getLastReply = () => replies[replies.length - 1] || null;\n  99→  context._getDocuments = () => [...documents];\n 100→  context._getLastDocument = () => documents[documents.length - 1] || null;\n 101→  context._clearReplies = () => {\n 102→    replies.length = 0;\n 103→    documents.length = 0;\n 104→  };\n 105→\n 106→  return context;\n 107→}\n 108→\n 109→/**\n 110→ * Create a mock context with admin user\n 111→ * @param {Object} overrides - Override properties\n 112→ * @returns {MockContext}\n 113→ */\n 114→export function createAdminContext(overrides = {}) {\n 115→  return createMockContext({\n 116→    from: {\n 117→      id: 999999999,\n 118→      username: 'admin_user',\n 119→      first_name: 'Admin'\n 120→    },\n 121→    message: {\n 122→      from: {\n 123→        id: 999999999,\n 124→        username: 'admin_user',\n 125→        first_name: 'Admin'\n 126→      }\n 127→    },\n 128→    state: {\n 129→      permission: 'admin'\n 130→    },\n 131→    ...overrides\n 132→  });\n 133→}\n 134→\n 135→/**\n 136→ * Create a mock context with operator user\n 137→ * @param {Object} overrides - Override properties\n 138→ * @returns {MockContext}\n 139→ */\n 140→export function createOperatorContext(overrides = {}) {\n 141→  return createMockContext({\n 142→    from: {\n 143→      id: 888888888,\n 144→      username: 'operator_user',\n 145→      first_name: 'Operator'\n 146→    },\n 147→    message: {\n 148→      from: {\n 149→        id: 888888888,\n 150→        username: 'operator_user',\n 151→        first_name: 'Operator'\n 152→      }\n 153→    },\n 154→    state: {\n 155→      permission: 'operator'\n 156→    },\n 157→    ...overrides\n 158→  });\n 159→}\n 160→\n 161→/**\n 162→ * Create a mock context with viewer user\n 163→ * @param {Object} overrides - Override properties\n 164→ * @returns {MockContext}\n 165→ */\n 166→export function createViewerContext(overrides = {}) {\n 167→  return createMockContext({\n 168→    from: {\n 169→      id: 777777777,\n 170→      username: 'viewer_user',\n 171→      first_name: 'Viewer'\n 172→    },\n 173→    message: {\n 174→      from: {\n 175→        id: 777777777,\n 176→        username: 'viewer_user',\n 177→        first_name: 'Viewer'\n 178→      }\n 179→    },\n 180→    state: {\n 181→      permission: 'viewer'\n 182→    },\n 183→    ...overrides\n 184→  });\n 185→}\n 186→\n 187→/**\n 188→ * Create a mock context with document upload\n 189→ * @param {Object} documentInfo - Document information\n 190→ * @param {Object} overrides - Override properties\n 191→ * @returns {MockContext}\n 192→ */\n 193→export function createDocumentContext(documentInfo = {}, overrides = {}) {\n 194→  const defaultDocument = {\n 195→    file_id: 'test-file-id-123',\n 196→    file_unique_id: 'test-unique-id-123',\n 197→    file_name: 'test-plan.json',\n 198→    mime_type: 'application/json',\n 199→    file_size: 1024\n 200→  };\n 201→\n 202→  return createMockContext({\n 203→    message: {\n 204→      document: {\n 205→        ...defaultDocument,\n 206→        ...documentInfo\n 207→      },\n 208→      caption: overrides.caption || '',\n 209→      from: overrides.message?.from || {\n 210→        id: 123456789,\n 211→        username: 'testuser',\n 212→        first_name: 'Test'\n 213→      }\n 214→    },\n 215→    ...overrides\n 216→  });\n 217→}\n 218→\n 219→/**\n 220→ * Create a mock context with command text\n 221→ * @param {string} commandText - The command text (e.g., \"/pipeline run --type=feature\")\n 222→ * @param {Object} overrides - Override properties\n 223→ * @returns {MockContext}\n 224→ */\n 225→export function createCommandContext(commandText, overrides = {}) {\n 226→  return createMockContext({\n 227→    message: {\n 228→      text: commandText,\n 229→      ...overrides.message\n 230→    },\n 231→    ...overrides\n 232→  });\n 233→}\n 234→\n 235→export default {\n 236→  createMockContext,\n 237→  createAdminContext,\n 238→  createOperatorContext,\n 239→  createViewerContext,\n 240→  createDocumentContext,\n 241→  createCommandContext\n 242→};\n 243→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:20.470Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"18e741ba-a2b0-46ec-a08d-8da459305598","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf3943478f723c0e08d0b85b28","content":[{"type":"text","text":"   1→/**\n   2→ * Test State Manager Helper\n   3→ * F-007: Test and Validation Suite\n   4→ *\n   5→ * Manages temporary state files for integration tests.\n   6→ */\n   7→\n   8→import { mkdtemp, rm, writeFile, readFile, mkdir } from 'node:fs/promises';\n   9→import { existsSync } from 'node:fs';\n  10→import { join, dirname } from 'node:path';\n  11→import { tmpdir } from 'node:os';\n  12→\n  13→/**\n  14→ * Create a temporary directory for test state\n  15→ * @param {string} [prefix='test-state-'] - Prefix for the temp directory\n  16→ * @returns {Promise<{ path: string, cleanup: Function }>} Temp directory path and cleanup function\n  17→ */\n  18→export async function createTestStateDir(prefix = 'test-state-') {\n  19→  const tempPath = await mkdtemp(join(tmpdir(), prefix));\n  20→\n  21→  return {\n  22→    path: tempPath,\n  23→    cleanup: async () => {\n  24→      await rm(tempPath, { recursive: true, force: true });\n  25→    }\n  26→  };\n  27→}\n  28→\n  29→/**\n  30→ * Create a full test pipeline state directory structure\n  31→ * @param {Object} options - Configuration options\n  32→ * @param {string} [options.prefix='pipeline-test-'] - Prefix for temp directory\n  33→ * @returns {Promise<{ tempDir: string, stateDir: string, bugfixStateDir: string, plansDir: string, cleanup: Function }>}\n  34→ */\n  35→export async function createTestPipelineDirs(options = {}) {\n  36→  const prefix = options.prefix || 'pipeline-test-';\n  37→  const tempDir = await mkdtemp(join(tmpdir(), prefix));\n  38→\n  39→  const stateDir = join(tempDir, 'dev-pipeline', 'state');\n  40→  const bugfixStateDir = join(tempDir, 'dev-pipeline', 'bugfix-state');\n  41→  const plansDir = join(tempDir, 'plans');\n  42→  const featureListDir = join(plansDir, 'feature-list');\n  43→  const bugFixListDir = join(plansDir, 'bug-fix-list');\n  44→\n  45→  await mkdir(stateDir, { recursive: true });\n  46→  await mkdir(bugfixStateDir, { recursive: true });\n  47→  await mkdir(featureListDir, { recursive: true });\n  48→  await mkdir(bugFixListDir, { recursive: true });\n  49→\n  50→  return {\n  51→    tempDir,\n  52→    stateDir,\n  53→    bugfixStateDir,\n  54→    plansDir,\n  55→    featureListDir,\n  56→    bugFixListDir,\n  57→    cleanup: async () => {\n  58→      await rm(tempDir, { recursive: true, force: true });\n  59→    }\n  60→  };\n  61→}\n  62→\n  63→/**\n  64→ * Write test state to a file\n  65→ * @param {string} filePath - Path to write to\n  66→ * @param {Object} data - Data to write\n  67→ * @returns {Promise<void>}\n  68→ */\n  69→export async function writeTestState(filePath, data) {\n  70→  await mkdir(dirname(filePath), { recursive: true });\n  71→  await writeFile(filePath, JSON.stringify(data, null, 2), 'utf-8');\n  72→}\n  73→\n  74→/**\n  75→ * Read test state from a file\n  76→ * @template T\n  77→ * @param {string} filePath - Path to read from\n  78→ * @returns {Promise<T|null>} Parsed JSON or null if file doesn't exist\n  79→ */\n  80→export async function readTestState(filePath) {\n  81→  if (!existsSync(filePath)) {\n  82→    return null;\n  83→  }\n  84→\n  85→  const content = await readFile(filePath, 'utf-8');\n  86→  return JSON.parse(content);\n  87→}\n  88→\n  89→/**\n  90→ * Create a mock state file for pipeline\n  91→ * @param {string} stateDir - State directory path\n  92→ * @param {Object} state - State object\n  93→ * @param {string} [type='feature'] - Pipeline type\n  94→ * @returns {Promise<string>} Path to the state file\n  95→ */\n  96→export async function createPipelineState(stateDir, state, type = 'feature') {\n  97→  const stateFile = join(stateDir, 'pipeline-state.json');\n  98→  await writeTestState(stateFile, state);\n  99→  return stateFile;\n 100→}\n 101→\n 102→/**\n 103→ * Create a mock daemon meta file\n 104→ * @param {string} stateDir - State directory path\n 105→ * @param {Object} meta - Daemon metadata\n 106→ * @param {string} [type='feature'] - Pipeline type\n 107→ * @returns {Promise<string>} Path to the meta file\n 108→ */\n 109→export async function createDaemonMeta(stateDir, meta, type = 'feature') {\n 110→  const metaFile = join(stateDir, 'daemon-meta.json');\n 111→  await writeTestState(metaFile, meta);\n 112→  return metaFile;\n 113→}\n 114→\n 115→/**\n 116→ * Create a mock lock file\n 117→ * @param {string} stateDir - State directory path\n 118→ * @param {number} pid - PID to lock with\n 119→ * @param {string} [type='feature'] - Pipeline type\n 120→ * @returns {Promise<string>} Path to the lock file\n 121→ */\n 122→export async function createLockFile(stateDir, pid, type = 'feature') {\n 123→  const lockFile = join(stateDir, 'pipeline.lock');\n 124→  await writeTestState(lockFile, {\n 125→    pid,\n 126→    createdAt: new Date().toISOString()\n 127→  });\n 128→  return lockFile;\n 129→}\n 130→\n 131→/**\n 132→ * Create a test plan file\n 133→ * @param {string} plansDir - Plans directory\n 134→ * @param {string} type - Plan type ('feature-list' or 'bug-fix-list')\n 135→ * @param {Object} content - Plan content\n 136→ * @param {string} [version='current'] - Version identifier\n 137→ * @returns {Promise<string>} Path to the plan file\n 138→ */\n 139→export async function createTestPlan(plansDir, type, content, version = 'current') {\n 140→  const planDir = join(plansDir, type);\n 141→  await mkdir(planDir, { recursive: true });\n 142→\n 143→  const planFile = join(planDir, `${version}.json`);\n 144→  await writeTestState(planFile, content);\n 145→  return planFile;\n 146→}\n 147→\n 148→/**\n 149→ * Synchronous cleanup helper for afterEach/afterAll hooks\n 150→ * @param {string} path - Path to clean up\n 151→ * @returns {Function} Cleanup function\n 152→ */\n 153→export function cleanupOnExit(path) {\n 154→  return async () => {\n 155→    try {\n 156→      await rm(path, { recursive: true, force: true });\n 157→    } catch {\n 158→      // Ignore cleanup errors\n 159→    }\n 160→  };\n 161→}\n 162→\n 163→export default {\n 164→  createTestStateDir,\n 165→  createTestPipelineDirs,\n 166→  writeTestState,\n 167→  readTestState,\n 168→  createPipelineState,\n 169→  createDaemonMeta,\n 170→  createLockFile,\n 171→  createTestPlan,\n 172→  cleanupOnExit\n 173→};\n 174→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:20.470Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
