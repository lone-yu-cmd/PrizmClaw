rror) {\n  53→    throw new Error(`Invalid JSON in fixture ${relativePath}: ${error.message}`);\n  54→  }\n  55→}\n  56→\n  57→/**\n  58→ * Check if a fixture exists\n  59→ * @param {string} relativePath - Path relative to fixtures/ directory\n  60→ * @returns {boolean}\n  61→ */\n  62→export function fixtureExists(relativePath) {\n  63→  return existsSync(getFixturePath(relativePath));\n  64→}\n  65→\n  66→export default {\n  67→  getFixturePath,\n  68→  loadFixture,\n  69→  loadJsonFixture,\n  70→  fixtureExists\n  71→};\n  72→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:36.000Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
