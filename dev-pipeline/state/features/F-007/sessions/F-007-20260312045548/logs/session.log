Projects/PrizmClaw/tests/pipeline-infra/lock-manager.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/pipeline-infra/state-manager.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/pipeline-controller.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f004-extended.integration.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/telegram-pusher.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/log-pager.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/status-aggregator.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f005-status-and-logs.integration.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f005-extended.integration.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/audit-log-service.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/security/param-sanitizer.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/security/permission-guard.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/security-extended.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/security/confirmation-manager.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/security-flow.test.js\"]"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeaf93760837ebd601924e6d630f","__timestamp":"2026-03-11T20:56:45.843Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"98e6ad6e-fc2e-4e97-acff-e6d378cbaf86","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_acdf0425b81a471d9c1b58a3","content":[{"type":"text","text":"   1→import { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2→import { createPlanIngestionService } from './plan-ingestion-service.js';\n   3→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   4→\n   5→function buildRequest(params = {}, action) {\n   6→  return {\n   7→    pipelineType: params.pipelineType ?? 'feature',\n   8→    action,\n   9→    ...(params.targetId ? { targetId: params.targetId } : {}),\n  10→    ...(params.listPath ? { listPath: params.listPath } : {}),\n  11→    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  12→    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  13→  };\n  14→}\n  15→\n  16→/**\n  17→ * T-015: Resolve list path for plan type and optional version.\n  18→ * @param {Object} options - Options\n  19→ * @param {string} options.planType - 'feature-list' or 'bug-fix-list'\n  20→ * @param {string} [options.version] - Optional version string\n  21→ * @param {Object} [options.config] - Optional config (will load if not provided)\n  22→ * @param {Object} [options.planService] - Optional plan service instance\n  23→ * @returns {Promise<string|null>} Resolved path or null\n  24→ */\n  25→export async function resolvePlanListPath({ planType, version, config, planService }) {\n  26→  const actualConfig = config ?? loadPipelineInfraConfig();\n  27→  const service = planService ?? createPlanIngestionService({ plansDir: actualConfig.plansDir });\n  28→\n  29→  // If version is specified, get that specific version\n  30→  if (version) {\n  31→    return service.getVersion(planType, version).then(content => {\n  32→      if (!content) return null;\n  33→      // Return the path to the version file\n  34→      const plansDir = actualConfig.plansDir;\n  35→      return `${plansDir}/${planType}/v${version.replace(/^v/, '')}.json`;\n  36→    });\n  37→  }\n  38→\n  39→  // Otherwise, use the active path from registry\n  40→  return service.getActivePath(planType);\n  41→}\n  42→\n  43→export function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  44→  return {\n  45→    runner,\n  46→    async startPipeline(params) {\n  47→      return runner(buildRequest(params, 'run'));\n  48→    },\n  49→    async getPipelineStatus(params) {\n  50→      return runner(buildRequest(params, 'status'));\n  51→    },\n  52→    async stopPipeline(params) {\n  53→      return runner(buildRequest(params, 'stop'));\n  54→    },\n  55→    async retryTarget(params) {\n  56→      return runner(buildRequest(params, 'retry'));\n  57→    },\n  58→    async getPipelineLogs(params) {\n  59→      return runner(buildRequest(params, 'logs'));\n  60→    },\n  61→    async resetTarget(params) {\n  62→      return runner(buildRequest(params, 'reset'));\n  63→    }\n  64→  };\n  65→}\n  66→\n  67→const defaultService = createPipelineControlService();\n  68→\n  69→export async function startPipeline(params) {\n  70→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  71→  return service.startPipeline(params);\n  72→}\n  73→\n  74→export async function getPipelineStatus(params) {\n  75→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  76→  return service.getPipelineStatus(params);\n  77→}\n  78→\n  79→export async function stopPipeline(params) {\n  80→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  81→  return service.stopPipeline(params);\n  82→}\n  83→\n  84→export async function retryTarget(params) {\n  85→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  86→  return service.retryTarget(params);\n  87→}\n  88→\n  89→export async function getPipelineLogs(params) {\n  90→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  91→  return service.getPipelineLogs(params);\n  92→}\n  93→\n  94→export async function resetTarget(params) {\n  95→  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  96→  return service.resetTarget(params);\n  97→}\n  98→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeaf93760837ebd601924e6d630f","__timestamp":"2026-03-11T20:56:45.850Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"8f9468dd-a167-41fe-9e16-a50a66eee2b7","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_2d780ca8bdc6420681d15238","content":[{"type":"text","text":"   1→/**\n   2→ * Plan Ingestion Service\n   3→ * Manages plan file validation, versioning, and registry.\n   4→ * Implements T-010 to T-014 for F-003.\n   5→ */\n   6→\n   7→import fs from 'node:fs';\n   8→import path from 'node:path';\n   9→import Ajv from 'ajv';\n  10→\n  11→/**\n  12→ * Schema type identifiers\n  13→ * @typedef {'feature-list' | 'bug-fix-list'} PlanType\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} ValidationResult\n  18→ * @property {boolean} valid - Whether validation passed\n  19→ * @property {PlanType | 'unknown'} type - Detected plan type\n  20→ * @property {ValidationError[]} errors - Validation errors\n  21→ * @property {PlanSummary} [summary] - Content summary if valid\n  22→ */\n  23→\n  24→/**\n  25→ * @typedef {Object} ValidationError\n  26→ * @property {string} path - JSON path to the error\n  27→ * @property {string} message - Human-readable error message\n  28→ * @property {string} [keyword] - JSON Schema keyword\n  29→ */\n  30→\n  31→/**\n  32→ * @typedef {Object} PlanSummary\n  33→ * @property {PlanType} type - Plan type\n  34→ * @property {string} name - App/project name\n  35→ * @property {number} itemCount - Number of features/bugs\n  36→ * @property {Record<string, number>} statusBreakdown - Status counts\n  37→ */\n  38→\n  39→/**\n  40→ * @typedef {Object} VersionInfo\n  41→ * @property {string} version - Version identifier\n  42→ * @property {Date} timestamp - Creation timestamp\n  43→ * @property {number} size - File size in bytes\n  44→ * @property {number} itemCount - Number of items\n  45→ * @property {boolean} isValid - Whether file is valid\n  46→ */\n  47→\n  48→/**\n  49→ * @typedef {Object} SaveResult\n  50→ * @property {boolean} success - Whether save succeeded\n  51→ * @property {string} [version] - Version identifier\n  52→ * @property {string} [error] - Error message\n  53→ */\n  54→\n  55→/**\n  56→ * @typedef {Object} ActiveMeta\n  57→ * @property {string} version - Current version\n  58→ * @property {string} path - Path to current version file\n  59→ * @property {Date} lastModified - Last modification time\n  60→ * @property {number} itemCount - Number of items\n  61→ */\n  62→\n  63→/**\n  64→ * @typedef {Object} RollbackResult\n  65→ * @property {string} previousVersion - Version we rolled back from\n  66→ * @property {string} currentVersion - Version we rolled back to\n  67→ */\n  68→\n  69→/**\n  70→ * Schema mapping from $schema value to type\n  71→ */\n  72→const SCHEMA_TYPE_MAP = {\n  73→  'dev-pipeline-feature-list-v1': 'feature-list',\n  74→  'dev-pipeline-bug-fix-list-v1': 'bug-fix-list'\n  75→};\n  76→\n  77→/**\n  78→ * Schema file paths relative to project root\n  79→ */\n  80→const SCHEMA_PATHS = {\n  81→  'feature-list': 'dev-pipeline/templates/feature-list-schema.json',\n  82→  'bug-fix-list': 'dev-pipeline/templates/bug-fix-list-schema.json'\n  83→};\n  84→\n  85→/**\n  86→ * Create plan ingestion service.\n  87→ * @param {Object} config - Service configuration\n  88→ * @param {string} [config.projectRoot] - Project root directory\n  89→ * @param {string} [config.plansDir] - Plans directory (overrides projectRoot)\n  90→ * @returns {Object} Service instance\n  91→ */\n  92→export function createPlanIngestionService(config = {}) {\n  93→  const projectRoot = config.projectRoot || process.cwd();\n  94→  const plansDir = config.plansDir || path.join(projectRoot, 'plans');\n  95→\n  96→  // Cached Ajv instance and compiled schemas\n  97→  const ajv = new Ajv({ allErrors: true, strict: false });\n  98→  const compiledSchemaCache = new Map();\n  99→\n 100→  /**\n 101→   * Load and compile schema by type.\n 102→   * @param {PlanType} type - Schema type\n 103→   * @returns {Object} Schema object\n 104→   */\n 105→  function loadSchema(type) {\n 106→    // Check if we have a valid schema type first\n 107→    if (!SCHEMA_PATHS[type]) {\n 108→      throw new Error(`Unknown schema type: ${type}`);\n 109→    }\n 110→\n 111→    const schemaPath = path.join(projectRoot, SCHEMA_PATHS[type]);\n 112→    if (!fs.existsSync(schemaPath)) {\n 113→      throw new Error(`Schema file not found for type: ${type}`);\n 114→    }\n 115→\n 116→    const schemaContent = fs.readFileSync(schemaPath, 'utf-8');\n 117→    return JSON.parse(schemaContent);\n 118→  }\n 119→\n 120→  /**\n 121→   * Get compiled validator for schema type (internal).\n 122→   * @param {PlanType} type - Schema type\n 123→   * @returns {Function} Compiled validator function\n 124→   */\n 125→  function getCompiledValidator(type) {\n 126→    if (compiledSchemaCache.has(type)) {\n 127→      return compiledSchemaCache.get(type);\n 128→    }\n 129→\n 130→    const schema = loadSchema(type);\n 131→    const compiled = ajv.compile(schema);\n 132→    compiledSchemaCache.set(type, compiled);\n 133→    return compiled;\n 134→  }\n 135→\n 136→  /**\n 137→   * Detect plan type from $schema field.\n 138→   * @param {Object} parsed - Parsed JSON content\n 139→   * @returns {PlanType | 'unknown'}\n 140→   */\n 141→  function detectType(parsed) {\n 142→    if (!parsed || typeof parsed !== 'object') {\n 143→      return 'unknown';\n 144→    }\n 145→\n 146→    const schemaValue = parsed.$schema;\n 147→    if (typeof schemaValue !== 'string') {\n 148→      return 'unknown';\n 149→    }\n 150→\n 151→    return SCHEMA_TYPE_MAP[schemaValue] || 'unknown';\n 152→  }\n 153→\n 154→  /**\n 155→   * Generate summary from parsed content.\n 156→   * @param {PlanType} type - Plan type\n 157→   * @param {Object} parsed - Parsed content\n 158→   * @returns {PlanSummary}\n 159→   */\n 160→  function generateSummary(type, parsed) {\n 161→    const name = type === 'feature-list' ? parsed.app_name : parsed.project_name;\n 162→    const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 163→    const itemCount = Array.isArray(items) ? items.length : 0;\n 164→\n 165→    const statusBreakdown = {};\n 166→    if (Array.isArray(items)) {\n 167→      for (const item of items) {\n 168→        const status = item.status || 'unknown';\n 169→        statusBreakdown[status] = (statusBreakdown[status] || 0) + 1;\n 170→      }\n 171→    }\n 172→\n 173→    return { type, name: name || 'Unknown', itemCount, statusBreakdown };\n 174→  }\n 175→\n 176→  /**\n 177→   * Convert Ajv errors to ValidationError format.\n 178→   * @param {Array} ajvErrors - Ajv error objects\n 179→   * @returns {ValidationError[]}\n 180→   */\n 181→  function convertAjvErrors(ajvErrors) {\n 182→    if (!Array.isArray(ajvErrors)) {\n 183→      return [];\n 184→    }\n 185→\n 186→    return ajvErrors.map((err) => ({\n 187→      path: err.instancePath || err.schemaPath || '/',\n 188→      message: err.message || 'Validation error',\n 189→      keyword: err.keyword\n 190→    }));\n 191→  }\n 192→\n 193→  /**\n 194→   * Validate plan content.\n 195→   * @param {string} content - JSON string content\n 196→   * @returns {ValidationResult}\n 197→   */\n 198→  function validate(content) {\n 199→    // Try to parse JSON\n 200→    let parsed;\n 201→    try {\n 202→      parsed = JSON.parse(content);\n 203→    } catch (e) {\n 204→      return {\n 205→        valid: false,\n 206→        type: 'unknown',\n 207→        errors: [{ path: '/', message: `Invalid JSON: ${e.message}` }]\n 208→      };\n 209→    }\n 210→\n 211→    // Detect type\n 212→    const type = detectType(parsed);\n 213→    if (type === 'unknown') {\n 214→      return {\n 215→        valid: false,\n 216→        type: 'unknown',\n 217→        errors: [{ path: '/$schema', message: 'Unknown or missing $schema field' }]\n 218→      };\n 219→    }\n 220→\n 221→    // Load and run schema validation\n 222→    const validator = getCompiledValidator(type);\n 223→    const valid = validator(parsed);\n 224→\n 225→    if (!valid) {\n 226→      return {\n 227→        valid: false,\n 228→        type,\n 229→        errors: convertAjvErrors(validator.errors)\n 230→      };\n 231→    }\n 232→\n 233→    // Generate summary\n 234→    const summary = generateSummary(type, parsed);\n 235→\n 236→    return { valid: true, type, errors: [], summary };\n 237→  }\n 238→\n 239→  /**\n 240→   * Format validation errors for display.\n 241→   * @param {ValidationError[]} errors - Validation errors\n 242→   * @returns {string} Formatted error message\n 243→   */\n 244→  function formatValidationErrors(errors) {\n 245→    if (!Array.isArray(errors) || errors.length === 0) {\n 246→      return '';\n 247→    }\n 248→\n 249→    const lines = ['\\u274c \\u6821\\u9a8c\\u5931\\u8d25:'];\n 250→\n 251→    for (const error of errors) {\n 252→      const path = error.path || '/';\n 253→      const message = error.message || 'Unknown error';\n 254→      lines.push(`\\u2022 ${path}: ${message}`);\n 255→    }\n 256→\n 257→    return lines.join('\\n');\n 258→  }\n 259→\n 260→  /**\n 261→   * Get type directory path.\n 262→   * @param {PlanType} type - Plan type\n 263→   * @returns {string}\n 264→   */\n 265→  function getTypeDir(type) {\n 266→    return path.join(plansDir, type);\n 267→  }\n 268→\n 269→  /**\n 270→   * Generate version string from timestamp.\n 271→   * @param {Date} date - Timestamp\n 272→   * @returns {string} Version string like v20260312-143052\n 273→   */\n 274→  function generateVersion(date = new Date()) {\n 275→    const pad = (n) => String(n).padStart(2, '0');\n 276→    const year = date.getFullYear();\n 277→    const month = pad(date.getMonth() + 1);\n 278→    const day = pad(date.getDate());\n 279→    const hour = pad(date.getHours());\n 280→    const minute = pad(date.getMinutes());\n 281→    const second = pad(date.getSeconds());\n 282→    return `v${year}${month}${day}-${hour}${minute}${second}`;\n 283→  }\n 284→\n 285→  /**\n 286→   * Ensure type directory exists.\n 287→   * @param {PlanType} type - Plan type\n 288→   */\n 289→  function ensureTypeDir(type) {\n 290→    const typeDir = getTypeDir(type);\n 291→    fs.mkdirSync(typeDir, { recursive: true });\n 292→  }\n 293→\n 294→  /**\n 295→   * Save plan content as new version.\n 296→   * @param {PlanType} type - Plan type\n 297→   * @param {string} content - JSON content\n 298→   * @param {Object} meta - Upload metadata\n 299→   * @param {number} meta.uploadedBy - User ID who uploaded\n 300→   * @returns {Promise<SaveResult>}\n 301→   */\n 302→  async function save(type, content, meta = {}) {\n 303→    try {\n 304→      ensureTypeDir(type);\n 305→\n 306→      const version = generateVersion();\n 307→      const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 308→\n 309→      // Count items\n 310→      let itemCount = 0;\n 311→      try {\n 312→        const parsed = JSON.parse(content);\n 313→        const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 314→        itemCount = Array.isArray(items) ? items.length : 0;\n 315→      } catch {\n 316→        // Ignore parse errors, already validated\n 317→      }\n 318→\n 319→      // Write file\n 320→      fs.writeFileSync(versionPath, content, 'utf-8');\n 321→\n 322→      return { success: true, version };\n 323→    } catch (e) {\n 324→      return { success: false, error: e.message };\n 325→    }\n 326→  }\n 327→\n 328→  /**\n 329→   * List all versions for a plan type.\n 330→   * @param {PlanType} type - Plan type\n 331→   * @returns {Promise<VersionInfo[]>}\n 332→   */\n 333→  async function listVersions(type) {\n 334→    const typeDir = getTypeDir(type);\n 335→    if (!fs.existsSync(typeDir)) {\n 336→      return [];\n 337→    }\n 338→\n 339→    const files = fs.readdirSync(typeDir);\n 340→    const versions = [];\n 341→\n 342→    for (const file of files) {\n 343→      if (!file.endsWith('.json') || file === '_current.json') {\n 344→        continue;\n 345→      }\n 346→\n 347→      const match = file.match(/^(v\\d{8}-\\d{6})\\.json$/);\n 348→      if (!match) {\n 349→        continue;\n 350→      }\n 351→\n 352→      const version = match[1];\n 353→      const filePath = path.join(typeDir, file);\n 354→      const stat = fs.statSync(filePath);\n 355→\n 356→      // Try to read and count items\n 357→      let itemCount = 0;\n 358→      let isValid = true;\n 359→      try {\n 360→        const content = fs.readFileSync(filePath, 'utf-8');\n 361→        const parsed = JSON.parse(content);\n 362→        const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 363→        itemCount = Array.isArray(items) ? items.length : 0;\n 364→      } catch {\n 365→        isValid = false;\n 366→      }\n 367→\n 368→      versions.push({\n 369→        version,\n 370→        timestamp: stat.mtime,\n 371→        size: stat.size,\n 372→        itemCount,\n 373→        isValid\n 374→      });\n 375→    }\n 376→\n 377→    // Sort by version descending (newest first)\n 378→    versions.sort((a, b) => b.version.localeCompare(a.version));\n 379→\n 380→    return versions;\n 381→  }\n 382→\n 383→  /**\n 384→   * Get content of a specific version.\n 385→   * @param {PlanType} type - Plan type\n 386→   * @param {string} version - Version identifier\n 387→   * @returns {Promise<string | null>}\n 388→   */\n 389→  async function getVersion(type, version) {\n 390→    const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 391→    if (!fs.existsSync(versionPath)) {\n 392→      return null;\n 393→    }\n 394→    return fs.readFileSync(versionPath, 'utf-8');\n 395→  }\n 396→\n 397→  /**\n 398→   * Get path to _current.json file.\n 399→   * @param {PlanType} type - Plan type\n 400→   * @returns {string}\n 401→   */\n 402→  function getCurrentMetaPath(type) {\n 403→    return path.join(getTypeDir(type), '_current.json');\n 404→  }\n 405→\n 406→  /**\n 407→   * Set the current active version.\n 408→   * @param {PlanType} type - Plan type\n 409→   * @param {string} version - Version to activate\n 410→   * @returns {Promise<boolean>}\n 411→   */\n 412→  async function setCurrent(type, version) {\n 413→    // Verify version exists\n 414→    const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 415→    if (!fs.existsSync(versionPath)) {\n 416→      return false;\n 417→    }\n 418→\n 419→    // Read content to get item count\n 420→    let itemCount = 0;\n 421→    try {\n 422→      const content = fs.readFileSync(versionPath, 'utf-8');\n 423→      const parsed = JSON.parse(content);\n 424→      const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 425→      itemCount = Array.isArray(items) ? items.length : 0;\n 426→    } catch {\n 427→      // Ignore\n 428→    }\n 429→\n 430→    // Write _current.json\n 431→    const currentMeta = {\n 432→      version,\n 433→      activatedAt: new Date().toISOString(),\n 434→      path: versionPath,\n 435→      itemCount\n 436→    };\n 437→\n 438→    const currentMetaPath = getCurrentMetaPath(type);\n 439→    fs.writeFileSync(currentMetaPath, JSON.stringify(currentMeta, null, 2), 'utf-8');\n 440→\n 441→    return true;\n 442→  }\n 443→\n 444→  /**\n 445→   * Get current active version metadata.\n 446→   * @param {PlanType} type - Plan type\n 447→   * @returns {Promise<ActiveMeta | null>}\n 448→   */\n 449→  async function getCurrent(type) {\n 450→    const currentMetaPath = getCurrentMetaPath(type);\n 451→    if (!fs.existsSync(currentMetaPath)) {\n 452→      return null;\n 453→    }\n 454→\n 455→    try {\n 456→      const content = fs.readFileSync(currentMetaPath, 'utf-8');\n 457→      const meta = JSON.parse(content);\n 458→\n 459→      return {\n 460→        version: meta.version,\n 461→        path: meta.path,\n 462→        lastModified: new Date(meta.activatedAt),\n 463→        itemCount: meta.itemCount || 0\n 464→      };\n 465→    } catch {\n 466→      return null;\n 467→    }\n 468→  }\n 469→\n 470→  /**\n 471→   * Get path to the current active version file.\n 472→   * @param {PlanType} type - Plan type\n 473→   * @returns {string | null}\n 474→   */\n 475→  function getActivePath(type) {\n 476→    const currentMetaPath = getCurrentMetaPath(type);\n 477→    if (!fs.existsSync(currentMetaPath)) {\n 478→      return null;\n 479→    }\n 480→\n 481→    try {\n 482→      const content = fs.readFileSync(currentMetaPath, 'utf-8');\n 483→      const meta = JSON.parse(content);\n 484→      return meta.path || null;\n 485→    } catch {\n 486→      return null;\n 487→    }\n 488→  }\n 489→\n 490→  /**\n 491→   * Rollback to previous version.\n 492→   * @param {PlanType} type - Plan type\n 493→   * @returns {Promise<RollbackResult | null>}\n 494→   */\n 495→  async function rollback(type) {\n 496→    const versions = await listVersions(type);\n 497→    if (versions.length < 2) {\n 498→      return null;\n 499→    }\n 500→\n 501→    const current = await getCurrent(type);\n 502→    if (!current) {\n 503→      return null;\n 504→    }\n 505→\n 506→    // Find current version index\n 507→    const currentIndex = versions.findIndex((v) => v.version === current.version);\n 508→    if (currentIndex === -1 || currentIndex >= versions.length - 1) {\n 509→      return null;\n 510→    }\n 511→\n 512→    // Get previous version\n 513→    const previousVersion = versions[currentIndex + 1];\n 514→    if (!previousVersion) {\n 515→      return null;\n 516→    }\n 517→\n 518→    // Set previous as current\n 519→    const success = await setCurrent(type, previousVersion.version);\n 520→    if (!success) {\n 521→      return null;\n 522→    }\n 523→\n 524→    return {\n 525→      previousVersion: current.version,\n 526→      currentVersion: previousVersion.version\n 527→    };\n 528→  }\n 529→\n 530→  return {\n 531→    loadSchema,\n 532→    validate,\n 533→    formatValidationErrors,\n 534→    save,\n 535→    listVersions,\n 536→    getVersion,\n 537→    setCurrent,\n 538→    getCurrent,\n 539→    getActivePath,\n 540→    rollback\n 541→  };\n 542→}\n 543→\n 544→export default createPlanIngestionService;\n 545→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeaf93760837ebd601924e6d630f","__timestamp":"2026-03-11T20:56:45.858Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
