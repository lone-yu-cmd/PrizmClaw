{"type":"user","uuid":"4284eccf-a9c7-42b0-8aec-5d8dee4723af","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_56c4d68784eb442e8a178358","content":[{"type":"text","text":"   1→/**\n   2→ * Command Parser\n   3→ * Parses Telegram message text into structured ParsedCommand object.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParsedCommand\n   8→ * @property {string} command - The command name (e.g., \"pipeline\")\n   9→ * @property {string} [subcommand] - Optional subcommand (e.g., \"run\")\n  10→ * @property {string[]} args - Positional arguments\n  11→ * @property {Record<string, string>} options - Key-value options (--key=value)\n  12→ * @property {string} raw - Original message text\n  13→ */\n  14→\n  15→/**\n  16→ * Parse Telegram message text into a structured command object.\n  17→ * @param {string} text - The message text to parse\n  18→ * @param {Object} [aliasMap={}] - Map of aliases to command names\n  19→ * @returns {ParsedCommand | null} Parsed command or null if not a command\n  20→ */\n  21→export function parseCommand(text, aliasMap = {}) {\n  22→  if (!text || typeof text !== 'string') {\n  23→    return null;\n  24→  }\n  25→\n  26→  const trimmed = text.trim();\n  27→\n  28→  // Must start with /\n  29→  if (!trimmed.startsWith('/')) {\n  30→    return null;\n  31→  }\n  32→\n  33→  // Extract command (first token after /)\n  34→  const tokens = trimmed.slice(1).split(/\\s+/);\n  35→  if (tokens.length === 0 || !tokens[0]) {\n  36→    return null;\n  37→  }\n  38→\n  39→  let command = tokens[0].toLowerCase();\n  40→  const rest = tokens.slice(1);\n  41→\n  42→  // Handle @bot suffix (e.g., /command@mybot)\n  43→  const atIndex = command.indexOf('@');\n  44→  if (atIndex !== -1) {\n  45→    command = command.slice(0, atIndex);\n  46→  }\n  47→\n  48→  // Apply alias mapping\n  49→  if (aliasMap[command]) {\n  50→    command = aliasMap[command];\n  51→  }\n  52→\n  53→  const args = [];\n  54→  const options = {};\n  55→  let subcommand = undefined;\n  56→\n  57→  for (const token of rest) {\n  58→    // Parse --key=value options\n  59→    if (token.startsWith('--')) {\n  60→      const optionText = token.slice(2);\n  61→      const eqIndex = optionText.indexOf('=');\n  62→      if (eqIndex !== -1) {\n  63→        const key = optionText.slice(0, eqIndex).toLowerCase();\n  64→        const value = optionText.slice(eqIndex + 1);\n  65→        options[key] = value;\n  66→      } else {\n  67→        // Boolean flag --flag\n  68→        options[optionText.toLowerCase()] = 'true';\n  69→      }\n  70→    } else if (token.includes('=')) {\n  71→      // Parse key=value (without --)\n  72→      const eqIndex = token.indexOf('=');\n  73→      const key = token.slice(0, eqIndex).toLowerCase();\n  74→      const value = token.slice(eqIndex + 1);\n  75→      options[key] = value;\n  76→    } else if (subcommand === undefined && !token.startsWith('-') && args.length === 0) {\n  77→      // First non-option token is subcommand if it looks like one\n  78→      // This will be validated by the registry\n  79→      subcommand = token.toLowerCase();\n  80→    } else {\n  81→      // Positional argument\n  82→      args.push(token);\n  83→    }\n  84→  }\n  85→\n  86→  return {\n  87→    command,\n  88→    subcommand,\n  89→    args,\n  90→    options,\n  91→    raw: text\n  92→  };\n  93→}\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:05:52.000Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"9261d9d2-4b88-4562-8dee-32a1b044f2e5","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_05cd2c4ef7fe47dd81fadbd8","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  const map = {};\n 215→  for (const [alias, command] of aliasToCommand) {\n 216→    map[alias] = command;\n 217→  }\n 218→  return map;\n 219→}\n 220→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:05:52.001Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"6a023197-4cfd-4504-88b9-5c811f00fd45","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_7b5adc627a93468dac99507e","content":[{"type":"text","text":"   1→/**\n   2→ * Command Validator\n   3→ * Validates command parameters and generates error messages.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ValidationError\n   8→ * @property {string} param - Parameter name\n   9→ * @property {string} message - Error message\n  10→ * @property {string} [suggestion] - Correction suggestion\n  11→ */\n  12→\n  13→/**\n  14→ * @typedef {Object} ValidationResult\n  15→ * @property {boolean} valid - Whether validation passed\n  16→ * @property {ValidationError[]} errors - Validation errors\n  17→ * @property {Record<string, *>} [normalized] - Normalized parameters\n  18→ */\n  19→\n  20→/**\n  21→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  22→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  23→ * @typedef {import('./registry.js').ParamMeta} ParamMeta\n  24→ * @typedef {import('./registry.js').SubcommandMeta} SubcommandMeta\n  25→ */\n  26→\n  27→/**\n  28→ * Validate a parsed command against its metadata.\n  29→ * @param {ParsedCommand} parsed - Parsed command\n  30→ * @param {CommandMeta} meta - Command metadata\n  31→ * @returns {ValidationResult} Validation result\n  32→ */\n  33→export function validateCommand(parsed, meta) {\n  34→  const errors = [];\n  35→  const normalized = { ...parsed.options };\n  36→\n  37→  // Validate subcommand if command has subcommands\n  38→  if (meta.subcommands?.length) {\n  39→    const validSubcommands = meta.subcommands.map((s) => s.name);\n  40→    if (parsed.subcommand && !validSubcommands.includes(parsed.subcommand)) {\n  41→      errors.push({\n  42→        param: 'subcommand',\n  43→        message: `未知子命令 '${parsed.subcommand}'`,\n  44→        suggestion: `可用子命令: ${validSubcommands.join(', ')}`\n  45→      });\n  46→    }\n  47→  }\n  48→\n  49→  // Get applicable params\n  50→  const params = getParamsForSubcommand(meta, parsed.subcommand);\n  51→\n  52→  // Validate parameters\n  53→  for (let i = 0; i < params.length; i++) {\n  54→    const param = params[i];\n  55→    const value = getParamValue(parsed, param.name, meta, i);\n  56→    const validationResult = validateParam(param, value);\n  57→\n  58→    if (!validationResult.valid) {\n  59→      errors.push(validationResult.error);\n  60→    } else if (validationResult.value !== undefined) {\n  61→      normalized[param.name] = validationResult.value;\n  62→    }\n  63→  }\n  64→\n  65→  // Add positional args to normalized\n  66→  if (parsed.args.length > 0) {\n  67→    normalized._args = parsed.args;\n  68→  }\n  69→\n  70→  return {\n  71→    valid: errors.length === 0,\n  72→    errors,\n  73→    normalized: errors.length === 0 ? normalized : undefined\n  74→  };\n  75→}\n  76→\n  77→/**\n  78→ * Get parameters applicable to a subcommand.\n  79→ * @param {CommandMeta} meta - Command metadata\n  80→ * @param {string|undefined} subcommand - Subcommand name\n  81→ * @returns {ParamMeta[]} Parameters\n  82→ */\n  83→function getParamsForSubcommand(meta, subcommand) {\n  84→  const params = [...(meta.params || [])];\n  85→\n  86→  // Add subcommand-specific params\n  87→  if (subcommand && meta.subcommands) {\n  88→    const subMeta = meta.subcommands.find((s) => s.name === subcommand);\n  89→    if (subMeta?.params) {\n  90→      params.push(...subMeta.params);\n  91→    }\n  92→  }\n  93→\n  94→  return params;\n  95→}\n  96→\n  97→/**\n  98→ * Get parameter value from parsed command.\n  99→ * @param {ParsedCommand} parsed - Parsed command\n 100→ * @param {string} paramName - Parameter name\n 101→ * @param {CommandMeta} meta - Command metadata\n 102→ * @param {number} paramIndex - Index of parameter in params array\n 103→ * @returns {string|undefined} Parameter value\n 104→ */\n 105→function getParamValue(parsed, paramName, meta, paramIndex) {\n 106→  // Check options first (explicit --key=value takes precedence)\n 107→  if (parsed.options[paramName] !== undefined) {\n 108→    return parsed.options[paramName];\n 109→  }\n 110→\n 111→  // Build positional args list\n 112→  // If command has no subcommands, parsed.subcommand should be treated as first positional arg\n 113→  const hasSubcommands = meta.subcommands && meta.subcommands.length > 0;\n 114→  const positionalArgs = [];\n 115→\n 116→  if (!hasSubcommands && parsed.subcommand !== undefined) {\n 117→    // F002-CRIT-001: Treat subcommand as first positional param when command has no subcommands\n 118→    positionalArgs.push(parsed.subcommand);\n 119→  }\n 120→\n 121→  // Add remaining args\n 122→  positionalArgs.push(...parsed.args);\n 123→\n 124→  // Map positional arg by index\n 125→  if (paramIndex !== undefined && positionalArgs[paramIndex] !== undefined) {\n 126→    return positionalArgs[paramIndex];\n 127→  }\n 128→\n 129→  return undefined;\n 130→}\n 131→\n 132→/**\n 133→ * Validate a single parameter.\n 134→ * @param {ParamMeta} param - Parameter metadata\n 135→ * @param {string|undefined} value - Parameter value\n 136→ * @returns {{valid: boolean, error?: ValidationError, value?: *}}\n 137→ */\n 138→function validateParam(param, value) {\n 139→  // Check required\n 140→  if (param.required && (value === undefined || value === '')) {\n 141→    return {\n 142→      valid: false,\n 143→      error: {\n 144→        param: param.name,\n 145→        message: `缺少参数 '${param.name}'`,\n 146→        suggestion: `请提供 ${param.name} 参数`\n 147→      }\n 148→    };\n 149→  }\n 150→\n 151→  // If not provided and has default, use default\n 152→  if (value === undefined && param.default !== undefined) {\n 153→    return { valid: true, value: param.default };\n 154→  }\n 155→\n 156→  // If not provided and not required, OK\n 157→  if (value === undefined) {\n 158→    return { valid: true };\n 159→  }\n 160→\n 161→  // Type validation\n 162→  if (param.type === 'number') {\n 163→    const num = Number(value);\n 164→    if (Number.isNaN(num)) {\n 165→      return {\n 166→        valid: false,\n 167→        error: {\n 168→          param: param.name,\n 169→          message: `参数 '${param.name}' 必须是数字`,\n 170→          suggestion: `请输入有效的数字`\n 171→        }\n 172→      };\n 173→    }\n 174→    return { valid: true, value: num };\n 175→  }\n 176→\n 177→  // Enum validation\n 178→  if (param.type === 'enum' && param.enum?.length) {\n 179→    if (!param.enum.includes(value)) {\n 180→      return {\n 181→        valid: false,\n 182→        error: {\n 183→          param: param.name,\n 184→          message: `参数 '${param.name}' 值无效: ${value}`,\n 185→          suggestion: `可选值: ${param.enum.join(', ')}`\n 186→        }\n 187→      };\n 188→    }\n 189→  }\n 190→\n 191→  return { valid: true, value };\n 192→}\n 193→\n 194→/**\n 195→ * Validate that a subcommand is valid for a command.\n 196→ * @param {string} subcommand - Subcommand name\n 197→ * @param {SubcommandMeta[]} subcommands - Available subcommands\n 198→ * @returns {{valid: boolean, error?: ValidationError}}\n 199→ */\n 200→export function validateSubcommand(subcommand, subcommands) {\n 201→  if (!subcommand) {\n 202→    return { valid: true };\n 203→  }\n 204→\n 205→  const validNames = (subcommands || []).map((s) => s.name);\n 206→  if (validNames.length === 0) {\n 207→    return { valid: true };\n 208→  }\n 209→\n 210→  if (!validNames.includes(subcommand)) {\n 211→    return {\n 212→      valid: false,\n 213→      error: {\n 214→        param: 'subcommand',\n 215→        message: `未知子命令 '${subcommand}'`,\n 216→        suggestion: `可用子命令: ${validNames.join(', ')}`\n 217→      }\n 218→    };\n 219→  }\n 220→\n 221→  return { valid: true };\n 222→}\n 223→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:05:52.001Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"b45ce05f-3c85-4834-84b5-9180bcd0cae6","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_208cdd1c37f1427f9383eaf2","content":[{"type":"text","text":"   1→/**\n   2→ * Error Formatter\n   3→ * Formats error messages for user-friendly display.\n   4→ */\n   5→\n   6→/**\n   7→ * Error codes for command errors.\n   8→ */\n   9→export const ErrorCodes = {\n  10→  UNKNOWN_COMMAND: 'UNKNOWN_COMMAND',\n  11→  UNKNOWN_SUBCOMMAND: 'UNKNOWN_SUBCOMMAND',\n  12→  MISSING_PARAM: 'MISSING_PARAM',\n  13→  INVALID_PARAM: 'INVALID_PARAM',\n  14→  UNAUTHORIZED: 'UNAUTHORIZED',\n  15→  INTERNAL_ERROR: 'INTERNAL_ERROR'\n  16→};\n  17→\n  18→/**\n  19→ * @typedef {Object} ErrorResponse\n  20→ * @property {string} code - Error code\n  21→ * @property {string} message - User-friendly error message\n  22→ * @property {string} [suggestion] - Correction suggestion\n  23→ * @property {string} [usage] - Correct usage example\n  24→ */\n  25→\n  26→/**\n  27→ * Format an error for display to the user.\n  28→ * @param {string} code - Error code\n  29→ * @param {Object} context - Error context\n  30→ * @param {string} [context.command] - Command name\n  31→ * @param {string} [context.subcommand] - Subcommand name\n  32→ * @param {string} [context.param] - Parameter name\n  33→ * @param {string} [context.value] - Invalid value\n  34→ * @param {string} [context.reason] - Error reason\n  35→ * @param {string} [context.suggestion] - Custom suggestion\n  36→ * @param {string} [context.usage] - Correct usage\n  37→ * @param {string[]} [context.available] - Available options\n  38→ * @returns {ErrorResponse} Formatted error\n  39→ */\n  40→export function formatError(code, context = {}) {\n  41→  switch (code) {\n  42→    case ErrorCodes.UNKNOWN_COMMAND:\n  43→      return {\n  44→        code,\n  45→        message: `未知命令 '${context.command || ''}'。`,\n  46→        suggestion: '输入 /help 查看可用命令。'\n  47→      };\n  48→\n  49→    case ErrorCodes.UNKNOWN_SUBCOMMAND:\n  50→      return {\n  51→        code,\n  52→        message: `未知子命令 '${context.subcommand || ''}'。`,\n  53→        suggestion: context.available ? `可用: ${context.available.join(', ')}` : undefined,\n  54→        usage: context.usage\n  55→      };\n  56→\n  57→    case ErrorCodes.MISSING_PARAM:\n  58→      return {\n  59→        code,\n  60→        message: `缺少参数 '${context.param || ''}'。`,\n  61→        suggestion: context.suggestion || `请提供 ${context.param} 参数`,\n  62→        usage: context.usage\n  63→      };\n  64→\n  65→    case ErrorCodes.INVALID_PARAM:\n  66→      return {\n  67→        code,\n  68→        message: `参数 '${context.param || ''}' 无效: ${context.reason || ''}`,\n  69→        suggestion: context.suggestion,\n  70→        usage: context.usage\n  71→      };\n  72→\n  73→    case ErrorCodes.UNAUTHORIZED:\n  74→      return {\n  75→        code,\n  76→        message: '当前账号未被授权使用该命令。',\n  77→        suggestion: '请联系管理员获取授权。'\n  78→      };\n  79→\n  80→    case ErrorCodes.INTERNAL_ERROR:\n  81→      return {\n  82→        code,\n  83→        message: '内部错误，请稍后重试。',\n  84→        suggestion: context.reason ? `错误: ${context.reason}` : undefined\n  85→      };\n  86→\n  87→    default:\n  88→      return {\n  89→        code: ErrorCodes.INTERNAL_ERROR,\n  90→        message: '未知错误。'\n  91→      };\n  92→  }\n  93→}\n  94→\n  95→/**\n  96→ * Format validation errors into a single message.\n  97→ * @param {import('./validator.js').ValidationError[]} errors - Validation errors\n  98→ * @param {string} [usage] - Usage hint\n  99→ * @returns {string} Formatted error message\n 100→ */\n 101→export function formatValidationErrors(errors, usage) {\n 102→  if (!errors || errors.length === 0) {\n 103→    return '';\n 104→  }\n 105→\n 106→  const lines = [];\n 107→\n 108→  for (const error of errors) {\n 109→    lines.push(`❌ ${error.message}`);\n 110→    if (error.suggestion) {\n 111→      lines.push(`   建议: ${error.suggestion}`);\n 112→    }\n 113→  }\n 114→\n 115→  if (usage) {\n 116→    lines.push(`\\n用法: ${usage}`);\n 117→  }\n 118→\n 119→  return lines.join('\\n');\n 120→}\n 121→\n 122→/**\n 123→ * Format an error response into a display string.\n 124→ * @param {ErrorResponse} error - Error response\n 125→ * @returns {string} Formatted string\n 126→ */\n 127→export function formatErrorResponse(error) {\n 128→  const lines = [`❌ ${error.message}`];\n 129→\n 130→  if (error.suggestion) {\n 131→    lines.push(`💡 ${error.suggestion}`);\n 132→  }\n 133→\n 134→  if (error.usage) {\n 135→    lines.push(`用法: ${error.usage}`);\n 136→  }\n 137→\n 138→  return lines.join('\\n');\n 139→}\n 140→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:05:52.002Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
