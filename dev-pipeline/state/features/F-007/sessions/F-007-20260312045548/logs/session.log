{"type":"user","uuid":"db2ce6e8-3e28-48a6-8c59-6117fec4583f","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf58418eea0db82cf5f9da9da5","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for param-sanitizer.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n   9→\n  10→// detectDangerousPatterns tests\n  11→test('detectDangerousPatterns detects path traversal (..)', () => {\n  12→  const result = detectDangerousPatterns('../../../etc/passwd');\n  13→  assert.equal(result.safe, false);\n  14→  assert.ok(result.patterns.some((p) => p.includes('path traversal')));\n  15→});\n  16→\n  17→test('detectDangerousPatterns detects shell injection ($)', () => {\n  18→  const result = detectDangerousPatterns('$(whoami)');\n  19→  assert.equal(result.safe, false);\n  20→  assert.ok(result.patterns.length > 0);\n  21→});\n  22→\n  23→test('detectDangerousPatterns detects backticks', () => {\n  24→  const result = detectDangerousPatterns('`id`');\n  25→  assert.equal(result.safe, false);\n  26→});\n  27→\n  28→test('detectDangerousPatterns detects command separator (;)', () => {\n  29→  const result = detectDangerousPatterns('ls; rm -rf /');\n  30→  assert.equal(result.safe, false);\n  31→});\n  32→\n  33→test('detectDangerousPatterns detects command chain (||)', () => {\n  34→  const result = detectDangerousPatterns('test || cat /etc/passwd');\n  35→  assert.equal(result.safe, false);\n  36→});\n  37→\n  38→test('detectDangerousPatterns detects command chain (&&)', () => {\n  39→  const result = detectDangerousPatterns('test && cat /etc/passwd');\n  40→  assert.equal(result.safe, false);\n  41→});\n  42→\n  43→test('detectDangerousPatterns detects home directory (~)', () => {\n  44→  const result = detectDangerousPatterns('~/secret.txt');\n  45→  assert.equal(result.safe, false);\n  46→});\n  47→\n  48→test('detectDangerousPatterns detects --exec flag', () => {\n  49→  const result = detectDangerousPatterns('test --exec');\n  50→  assert.equal(result.safe, false);\n  51→});\n  52→\n  53→test('detectDangerousPatterns detects --eval flag', () => {\n  54→  const result = detectDangerousPatterns('test --eval');\n  55→  assert.equal(result.safe, false);\n  56→});\n  57→\n  58→test('detectDangerousPatterns returns safe for clean input', () => {\n  59→  const result = detectDangerousPatterns('my-feature-branch');\n  60→  assert.equal(result.safe, true);\n  61→  assert.deepEqual(result.patterns, []);\n  62→});\n  63→\n  64→// sanitizeParam tests\n  65→test('sanitizeParam accepts valid string', () => {\n  66→  const result = sanitizeParam('valid-input', { maxLength: 200 });\n  67→  assert.equal(result.ok, true);\n  68→  assert.equal(result.value, 'valid-input');\n  69→});\n  70→\n  71→test('sanitizeParam trims whitespace', () => {\n  72→  const result = sanitizeParam('  trimmed  ', { maxLength: 200 });\n  73→  assert.equal(result.ok, true);\n  74→  assert.equal(result.value, 'trimmed');\n  75→});\n  76→\n  77→test('sanitizeParam rejects empty input', () => {\n  78→  const result = sanitizeParam('', { maxLength: 200 });\n  79→  assert.equal(result.ok, false);\n  80→  assert.ok(result.error);\n  81→});\n  82→\n  83→test('sanitizeParam rejects whitespace-only input', () => {\n  84→  const result = sanitizeParam('   ', { maxLength: 200 });\n  85→  assert.equal(result.ok, false);\n  86→});\n  87→\n  88→test('sanitizeParam enforces max length', () => {\n  89→  const longInput = 'a'.repeat(300);\n  90→  const result = sanitizeParam(longInput, { maxLength: 200 });\n  91→  assert.equal(result.ok, false);\n  92→  assert.ok(result.error.includes('过长'));\n  93→});\n  94→\n  95→test('sanitizeParam uses default max length of 200', () => {\n  96→  const longInput = 'a'.repeat(250);\n  97→  const result = sanitizeParam(longInput);\n  98→  assert.equal(result.ok, false);\n  99→});\n 100→\n 101→test('sanitizeParam rejects dangerous patterns', () => {\n 102→  const result = sanitizeParam('../../../etc/passwd');\n 103→  assert.equal(result.ok, false);\n 104→  assert.ok(result.error);\n 105→});\n 106→\n 107→test('sanitizeParam handles null input', () => {\n 108→  const result = sanitizeParam(null);\n 109→  assert.equal(result.ok, false);\n 110→});\n 111→\n 112→test('sanitizeParam handles undefined input', () => {\n 113→  const result = sanitizeParam(undefined);\n 114→  assert.equal(result.ok, false);\n 115→});\n 116→\n 117→test('sanitizeParam accepts targetId format [A-Za-z0-9_-]+', () => {\n 118→  const result = sanitizeParam('my-feature_123', { maxLength: 100 });\n 119→  assert.equal(result.ok, true);\n 120→  assert.equal(result.value, 'my-feature_123');\n 121→});\n 122→\n 123→// validatePath tests\n 124→test('validatePath accepts path within allowed roots', () => {\n 125→  const result = validatePath('/project/src/file.js', ['/project', '/home']);\n 126→  assert.equal(result.ok, true);\n 127→  assert.ok(result.resolved);\n 128→});\n 129→\n 130→test('validatePath rejects path outside allowed roots', () => {\n 131→  const result = validatePath('/etc/passwd', ['/project', '/home']);\n 132→  assert.equal(result.ok, false);\n 133→  assert.ok(result.error);\n 134→});\n 135→\n 136→test('validatePath rejects path traversal', () => {\n 137→  const result = validatePath('/project/../../../etc/passwd', ['/project']);\n 138→  assert.equal(result.ok, false);\n 139→});\n 140→\n 141→test('validatePath rejects relative path', () => {\n 142→  const result = validatePath('relative/path', ['/project']);\n 143→  assert.equal(result.ok, false);\n 144→});\n 145→\n 146→test('validatePath handles empty path', () => {\n 147→  const result = validatePath('', ['/project']);\n 148→  assert.equal(result.ok, false);\n 149→});\n 150→\n 151→test('validatePath handles null path', () => {\n 152→  const result = validatePath(null, ['/project']);\n 153→  assert.equal(result.ok, false);\n 154→});\n 155→\n 156→// AC-3.1: Path traversal should be rejected\n 157→test('validatePath rejects path traversal with ..', () => {\n 158→  const result = validatePath('/project/./src/../test.js', ['/project']);\n 159→  // Should reject paths containing .. per AC-3.1\n 160→  assert.equal(result.ok, false);\n 161→  assert.ok(result.error.includes('..'));\n 162→});\n 163→\n 164→test('validatePath accepts valid path within root', () => {\n 165→  const result = validatePath('/project/src/test.js', ['/project']);\n 166→  assert.equal(result.ok, true);\n 167→  assert.equal(result.resolved, '/project/src/test.js');\n 168→});\n 169→\n 170→// AC-3.2: targetId parameter only allows [A-Za-z0-9_-]+ format\n 171→test('sanitizeParam with isTargetId rejects invalid characters', () => {\n 172→  const result = sanitizeParam('feature/branch', { isTargetId: true });\n 173→  assert.equal(result.ok, false);\n 174→  assert.ok(result.error.includes('格式无效'));\n 175→});\n 176→\n 177→test('sanitizeParam with isTargetId accepts valid targetId', () => {\n 178→  const result = sanitizeParam('feature-branch_123', { isTargetId: true });\n 179→  assert.equal(result.ok, true);\n 180→  assert.equal(result.value, 'feature-branch_123');\n 181→});\n 182→\n 183→// AC-3.3: reject dangerous characters\n 184→test('sanitizeParam rejects semicolon', () => {\n 185→  const result = sanitizeParam('test;rm -rf');\n 186→  assert.equal(result.ok, false);\n 187→});\n 188→\n 189→test('sanitizeParam rejects pipe', () => {\n 190→  const result = sanitizeParam('test|cat');\n 191→  assert.equal(result.ok, false);\n 192→});\n 193→\n 194→test('sanitizeParam rejects ampersand', () => {\n 195→  const result = sanitizeParam('test&&ls');\n 196→  assert.equal(result.ok, false);\n 197→});\n 198→\n 199→test('sanitizeParam rejects dollar sign', () => {\n 200→  const result = sanitizeParam('$HOME');\n 201→  assert.equal(result.ok, false);\n 202→});\n 203→\n 204→test('sanitizeParam rejects backtick', () => {\n 205→  const result = sanitizeParam('`id`');\n 206→  assert.equal(result.ok, false);\n 207→});\n 208→\n 209→test('sanitizeParam rejects single quote', () => {\n 210→  const result = sanitizeParam(\"test' or '1'='1\");\n 211→  assert.equal(result.ok, false);\n 212→});\n 213→\n 214→test('sanitizeParam rejects double quote', () => {\n 215→  const result = sanitizeParam('test\" or \"1\"=\"1');\n 216→  assert.equal(result.ok, false);\n 217→});\n 218→\n 219→test('sanitizeParam rejects parentheses', () => {\n 220→  const result = sanitizeParam('$(whoami)');\n 221→  assert.equal(result.ok, false);\n 222→});\n 223→\n 224→test('sanitizeParam rejects angle brackets', () => {\n 225→  const result = sanitizeParam('<script>');\n 226→  assert.equal(result.ok, false);\n 227→});\n 228→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:29.630Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"13e1668b-bfbf-4d3a-ae26-66643309d967","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf59ca4213d64d8b3ce12cad3b","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for confirmation-manager.js\n   3→ * F-006: Safety and Permission Guard\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import {\n   9→  createConfirmation,\n  10→  checkConfirmation,\n  11→  confirmAction,\n  12→  cancelConfirmation,\n  13→  clearExpiredConfirmations\n  14→} from '../../src/security/confirmation-manager.js';\n  15→\n  16→// Helper to wait\n  17→const wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n  18→\n  19→// createConfirmation tests\n  20→test('createConfirmation creates a pending confirmation', () => {\n  21→  clearExpiredConfirmations();\n  22→  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  23→\n  24→  assert.ok(result.confirmId);\n  25→  assert.ok(result.message);\n  26→  assert.ok(result.message.includes('stop'));\n  27→});\n  28→\n  29→test('createConfirmation generates unique confirmId', () => {\n  30→  clearExpiredConfirmations();\n  31→  const result1 = createConfirmation('user123', 'stop', { type: 'feature' });\n  32→  const result2 = createConfirmation('user123', 'reset', {});\n  33→\n  34→  assert.notEqual(result1.confirmId, result2.confirmId);\n  35→});\n  36→\n  37→test('createConfirmation uses custom timeout', () => {\n  38→  clearExpiredConfirmations();\n  39→  const result = createConfirmation('user123', 'stop', {}, 5000);\n  40→\n  41→  assert.ok(result.confirmId);\n  42→  // Verify by checking it expires after timeout\n  43→});\n  44→\n  45→test('createConfirmation stores userId correctly', () => {\n  46→  clearExpiredConfirmations();\n  47→  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  48→\n  49→  const check = checkConfirmation(result.confirmId, 'user123');\n  50→  assert.equal(check.status, 'pending');\n  51→});\n  52→\n  53→// checkConfirmation tests\n  54→test('checkConfirmation returns pending for active confirmation', () => {\n  55→  clearExpiredConfirmations();\n  56→  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  57→\n  58→  const result = checkConfirmation(confirmId, 'user123');\n  59→\n  60→  assert.equal(result.status, 'pending');\n  61→  assert.equal(result.action, 'stop');\n  62→  assert.deepEqual(result.params, { type: 'feature' });\n  63→});\n  64→\n  65→test('checkConfirmation returns not_found for unknown confirmId', () => {\n  66→  clearExpiredConfirmations();\n  67→  const result = checkConfirmation('nonexistent-id', 'user123');\n  68→\n  69→  assert.equal(result.status, 'not_found');\n  70→});\n  71→\n  72→test('checkConfirmation returns not_found for wrong userId', () => {\n  73→  clearExpiredConfirmations();\n  74→  const { confirmId } = createConfirmation('user123', 'stop', {});\n  75→\n  76→  const result = checkConfirmation(confirmId, 'different-user');\n  77→\n  78→  assert.equal(result.status, 'not_found');\n  79→});\n  80→\n  81→test('checkConfirmation returns expired after timeout', async () => {\n  82→  clearExpiredConfirmations();\n  83→  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n  84→\n  85→  await wait(150);\n  86→\n  87→  const result = checkConfirmation(confirmId, 'user123');\n  88→\n  89→  assert.equal(result.status, 'expired');\n  90→});\n  91→\n  92→// confirmAction tests\n  93→test('confirmAction confirms pending action', () => {\n  94→  clearExpiredConfirmations();\n  95→  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  96→\n  97→  const result = confirmAction(confirmId, 'user123');\n  98→\n  99→  assert.equal(result.ok, true);\n 100→  assert.equal(result.action, 'stop');\n 101→  assert.deepEqual(result.params, { type: 'feature' });\n 102→});\n 103→\n 104→test('confirmAction fails for wrong userId', () => {\n 105→  clearExpiredConfirmations();\n 106→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 107→\n 108→  const result = confirmAction(confirmId, 'different-user');\n 109→\n 110→  assert.equal(result.ok, false);\n 111→  assert.ok(result.error);\n 112→});\n 113→\n 114→test('confirmAction fails for unknown confirmId', () => {\n 115→  clearExpiredConfirmations();\n 116→  const result = confirmAction('nonexistent-id', 'user123');\n 117→\n 118→  assert.equal(result.ok, false);\n 119→  assert.ok(result.error);\n 120→});\n 121→\n 122→test('confirmAction fails for already confirmed action', () => {\n 123→  clearExpiredConfirmations();\n 124→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 125→\n 126→  confirmAction(confirmId, 'user123');\n 127→  const result = confirmAction(confirmId, 'user123');\n 128→\n 129→  assert.equal(result.ok, false);\n 130→  assert.ok(result.error.includes('不存在') || result.error.includes('过期'));\n 131→});\n 132→\n 133→test('confirmAction fails for expired action', async () => {\n 134→  clearExpiredConfirmations();\n 135→  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n 136→\n 137→  await wait(150);\n 138→\n 139→  const result = confirmAction(confirmId, 'user123');\n 140→\n 141→  assert.equal(result.ok, false);\n 142→});\n 143→\n 144→// cancelConfirmation tests\n 145→test('cancelConfirmation cancels pending action', () => {\n 146→  clearExpiredConfirmations();\n 147→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 148→\n 149→  cancelConfirmation(confirmId, 'user123');\n 150→\n 151→  const result = checkConfirmation(confirmId, 'user123');\n 152→  assert.equal(result.status, 'not_found');\n 153→});\n 154→\n 155→test('cancelConfirmation does nothing for unknown confirmId', () => {\n 156→  clearExpiredConfirmations();\n 157→  // Should not throw\n 158→  cancelConfirmation('nonexistent-id', 'user123');\n 159→});\n 160→\n 161→test('cancelConfirmation does nothing for wrong userId', () => {\n 162→  clearExpiredConfirmations();\n 163→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 164→\n 165→  cancelConfirmation(confirmId, 'different-user');\n 166→\n 167→  const result = checkConfirmation(confirmId, 'user123');\n 168→  assert.equal(result.status, 'pending');\n 169→});\n 170→\n 171→// clearExpiredConfirmations tests\n 172→test('clearExpiredConfirmations removes expired confirmations', async () => {\n 173→  clearExpiredConfirmations();\n 174→  createConfirmation('user123', 'stop', {}, 100);\n 175→  createConfirmation('user456', 'reset', {}, 10000);\n 176→\n 177→  await wait(150);\n 178→\n 179→  clearExpiredConfirmations();\n 180→\n 181→  // The expired one should be gone, the active one should remain\n 182→  const check1 = checkConfirmation(\n 183→    // We can't check the specific one, but clearExpiredConfirmations should clean up\n 184→    'any-id',\n 185→    'user123'\n 186→  );\n 187→  assert.equal(check1.status, 'not_found');\n 188→});\n 189→\n 190→// Integration test: full confirmation flow\n 191→test('full confirmation flow: create, check, confirm', () => {\n 192→  clearExpiredConfirmations();\n 193→  // Create\n 194→  const { confirmId, message } = createConfirmation('user123', 'stop', { type: 'feature' });\n 195→\n 196→  assert.ok(confirmId);\n 197→  assert.ok(message);\n 198→\n 199→  // Check\n 200→  const check1 = checkConfirmation(confirmId, 'user123');\n 201→  assert.equal(check1.status, 'pending');\n 202→\n 203→  // Confirm\n 204→  const confirm = confirmAction(confirmId, 'user123');\n 205→  assert.equal(confirm.ok, true);\n 206→\n 207→  // Verify confirmed\n 208→  const check2 = checkConfirmation(confirmId, 'user123');\n 209→  assert.equal(check2.status, 'not_found'); // Consumed\n 210→});\n 211→\n 212→test('full confirmation flow: create, check, cancel', () => {\n 213→  clearExpiredConfirmations();\n 214→  // Create\n 215→  const { confirmId } = createConfirmation('user123', 'reset', {});\n 216→\n 217→  // Check\n 218→  const check1 = checkConfirmation(confirmId, 'user123');\n 219→  assert.equal(check1.status, 'pending');\n 220→\n 221→  // Cancel\n 222→  cancelConfirmation(confirmId, 'user123');\n 223→\n 224→  // Verify cancelled\n 225→  const check2 = checkConfirmation(confirmId, 'user123');\n 226→  assert.equal(check2.status, 'not_found');\n 227→});\n 228→\n 229→// AC-4.3: 60 second timeout default\n 230→test('default timeout is 60 seconds', () => {\n 231→  clearExpiredConfirmations();\n 232→  const { confirmId } = createConfirmation('user123', 'stop', {});\n 233→\n 234→  const check = checkConfirmation(confirmId, 'user123');\n 235→  assert.equal(check.status, 'pending');\n 236→\n 237→  // We can't wait 60s in test, but we can verify it exists initially\n 238→});\n 239→\n 240→// AC-4.4: --force flag handling (in handler, not here)\n 241→// This is tested at the integration level\n 242→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:29.631Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"392e77c0-33d2-45ab-b3b8-0f87b677321f","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf5b6631000905046493e73d9a","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for plan-ingestion-service.js\n   3→ * Covers T-010 (schema loader), T-011 (plan validator), T-012 (version manager),\n   4→ * T-013 (plan registry), T-014 (error formatting)\n   5→ */\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import os from 'node:os';\n   9→import path from 'node:path';\n  10→import fs from 'node:fs';\n  11→import { fileURLToPath } from 'node:url';\n  12→\n  13→const __dirname = path.dirname(fileURLToPath(import.meta.url));\n  14→const PROJECT_ROOT = path.resolve(__dirname, '../..');\n  15→\n  16→// We'll import dynamically after setup\n  17→let createPlanIngestionService;\n  18→\n  19→function createTempPlansDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-plans-'));\n  21→  fs.mkdirSync(path.join(tempDir, 'feature-list'), { recursive: true });\n  22→  fs.mkdirSync(path.join(tempDir, 'bug-fix-list'), { recursive: true });\n  23→  return tempDir;\n  24→}\n  25→\n  26→function createValidFeatureList() {\n  27→  return JSON.stringify({\n  28→    $schema: 'dev-pipeline-feature-list-v1',\n  29→    app_name: 'TestApp',\n  30→    app_description: 'A test application',\n  31→    features: [\n  32→      {\n  33→        id: 'F-001',\n  34→        title: 'Test Feature',\n  35→        description: 'A test feature',\n  36→        priority: 1,\n  37→        dependencies: [],\n  38→        acceptance_criteria: ['AC1: Test passes'],\n  39→        status: 'pending'\n  40→      }\n  41→    ]\n  42→  });\n  43→}\n  44→\n  45→function createValidBugFixList() {\n  46→  return JSON.stringify({\n  47→    $schema: 'dev-pipeline-bug-fix-list-v1',\n  48→    project_name: 'TestProject',\n  49→    bugs: [\n  50→      {\n  51→        id: 'B-001',\n  52→        title: 'Test Bug',\n  53→        description: 'A test bug',\n  54→        severity: 'medium',\n  55→        error_source: { type: 'user_report' },\n  56→        verification_type: 'manual',\n  57→        acceptance_criteria: ['AC1: Bug is fixed'],\n  58→        status: 'pending'\n  59→      }\n  60→    ]\n  61→  });\n  62→}\n  63→\n  64→// ============================================================\n  65→// T-010: Schema Loader Tests\n  66→// ============================================================\n  67→test('T-010: loadSchema should load feature-list schema', async () => {\n  68→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  69→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  70→\n  71→  const schema = service.loadSchema('feature-list');\n  72→  assert.ok(schema);\n  73→  assert.equal(typeof schema, 'object'); // Raw schema object\n  74→});\n  75→\n  76→test('T-010: loadSchema should load bug-fix-list schema', async () => {\n  77→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  78→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  79→\n  80→  const schema = service.loadSchema('bug-fix-list');\n  81→  assert.ok(schema);\n  82→  assert.equal(typeof schema, 'object'); // Raw schema object\n  83→});\n  84→\n  85→test('T-010: loadSchema should throw for unknown schema type', async () => {\n  86→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  87→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  88→\n  89→  assert.throws(\n  90→    () => service.loadSchema('unknown-type'),\n  91→    /unknown.*schema/i\n  92→  );\n  93→});\n  94→\n  95→// ============================================================\n  96→// T-011: Plan Validator Tests\n  97→// ============================================================\n  98→test('T-011: validate should identify feature-list type', async () => {\n  99→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 100→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 101→\n 102→  const result = service.validate(createValidFeatureList());\n 103→\n 104→  assert.equal(result.valid, true);\n 105→  assert.equal(result.type, 'feature-list');\n 106→  assert.ok(result.summary);\n 107→  assert.equal(result.summary.name, 'TestApp');\n 108→  assert.equal(result.summary.itemCount, 1);\n 109→});\n 110→\n 111→test('T-011: validate should identify bug-fix-list type', async () => {\n 112→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 113→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 114→\n 115→  const result = service.validate(createValidBugFixList());\n 116→\n 117→  assert.equal(result.valid, true);\n 118→  assert.equal(result.type, 'bug-fix-list');\n 119→  assert.ok(result.summary);\n 120→  assert.equal(result.summary.name, 'TestProject');\n 121→  assert.equal(result.summary.itemCount, 1);\n 122→});\n 123→\n 124→test('T-011: validate should return unknown type for missing schema', async () => {\n 125→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 126→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 127→\n 128→  const result = service.validate(JSON.stringify({ foo: 'bar' }));\n 129→\n 130→  assert.equal(result.valid, false);\n 131→  assert.equal(result.type, 'unknown');\n 132→});\n 133→\n 134→test('T-011: validate should return field-level errors', async () => {\n 135→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 136→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 137→\n 138→  const invalidContent = JSON.stringify({\n 139→    $schema: 'dev-pipeline-feature-list-v1',\n 140→    app_name: 'TestApp',\n 141→    features: [\n 142→      {\n 143→        id: 'INVALID-ID', // Should match F-\\\\d{3}\n 144→        title: 'Test',\n 145→        description: 'Test',\n 146→        priority: -1, // Should be >= 1\n 147→        dependencies: [],\n 148→        acceptance_criteria: [],\n 149→        status: 'invalid-status'\n 150→      }\n 151→    ]\n 152→  });\n 153→\n 154→  const result = service.validate(invalidContent);\n 155→\n 156→  assert.equal(result.valid, false);\n 157→  assert.ok(result.errors.length > 0);\n 158→  // Check that errors have path and message\n 159→  for (const error of result.errors) {\n 160→    assert.ok(error.path, 'Error should have path');\n 161→    assert.ok(error.message, 'Error should have message');\n 162→  }\n 163→});\n 164→\n 165→test('T-011: validate should return status breakdown in summary', async () => {\n 166→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 167→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 168→\n 169→  const content = JSON.stringify({\n 170→    $schema: 'dev-pipeline-feature-list-v1',\n 171→    app_name: 'TestApp',\n 172→    features: [\n 173→      { id: 'F-001', title: 'A', description: 'A', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' },\n 174→      { id: 'F-002', title: 'B', description: 'B', priority: 2, dependencies: [], acceptance_criteria: ['AC'], status: 'in_progress' },\n 175→      { id: 'F-003', title: 'C', description: 'C', priority: 3, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 176→    ]\n 177→  });\n 178→\n 179→  const result = service.validate(content);\n 180→\n 181→  assert.equal(result.valid, true);\n 182→  assert.deepEqual(result.summary.statusBreakdown, { pending: 2, in_progress: 1 });\n 183→});\n 184→\n 185→test('T-011: validate should handle invalid JSON', async () => {\n 186→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 187→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 188→\n 189→  const result = service.validate('not valid json');\n 190→\n 191→  assert.equal(result.valid, false);\n 192→  assert.equal(result.type, 'unknown');\n 193→  assert.ok(result.errors.length > 0);\n 194→  assert.match(result.errors[0].message, /json/i);\n 195→});\n 196→\n 197→// ============================================================\n 198→// T-014: Error Formatting Tests\n 199→// ============================================================\n 200→test('T-014: formatValidationErrors should format errors with field paths', async () => {\n 201→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 202→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 203→\n 204→  const errors = [\n 205→    { path: 'features[0].id', message: 'Invalid ID format' },\n 206→    { path: 'features[1].priority', message: 'Must be positive' }\n 207→  ];\n 208→\n 209→  const formatted = service.formatValidationErrors(errors);\n 210→\n 211→  assert.match(formatted, /features\\[0\\].id/);\n 212→  assert.match(formatted, /Invalid ID format/);\n 213→  assert.match(formatted, /features\\[1\\].priority/);\n 214→  assert.match(formatted, /Must be positive/);\n 215→});\n 216→\n 217→// ============================================================\n 218→// T-012: Version Manager Tests\n 219→// ============================================================\n 220→test('T-012: save should create versioned file', async () => {\n 221→  const plansDir = createTempPlansDir();\n 222→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 223→  const service = createPlanIngestionService({ plansDir });\n 224→\n 225→  const result = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 226→\n 227→  assert.equal(result.success, true);\n 228→  assert.ok(result.version);\n 229→  assert.match(result.version, /^v\\d{8}-\\d{6}$/);\n 230→\n 231→  // Cleanup\n 232→  fs.rmSync(plansDir, { recursive: true, force: true });\n 233→});\n 234→\n 235→test('T-012: listVersions should return version list', async () => {\n 236→  const plansDir = createTempPlansDir();\n 237→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 238→  const service = createPlanIngestionService({ plansDir });\n 239→\n 240→  // Save two versions\n 241→  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 242→  await new Promise(r => setTimeout(r, 1100)); // Ensure different timestamp\n 243→  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 244→\n 245→  const versions = await service.listVersions('feature-list');\n 246→\n 247→  assert.equal(versions.length, 2);\n 248→  assert.ok(versions[0].version);\n 249→  assert.ok(versions[0].timestamp);\n 250→  assert.ok(versions[0].itemCount);\n 251→\n 252→  // Cleanup\n 253→  fs.rmSync(plansDir, { recursive: true, force: true });\n 254→});\n 255→\n 256→test('T-012: getVersion should return content', async () => {\n 257→  const plansDir = createTempPlansDir();\n 258→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 259→  const service = createPlanIngestionService({ plansDir });\n 260→\n 261→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 262→  const content = await service.getVersion('feature-list', saved.version);\n 263→\n 264→  assert.ok(content);\n 265→  const parsed = JSON.parse(content);\n 266→  assert.equal(parsed.app_name, 'TestApp');\n 267→\n 268→  // Cleanup\n 269→  fs.rmSync(plansDir, { recursive: true, force: true });\n 270→});\n 271→\n 272→test('T-012: getVersion should return null for non-existent version', async () => {\n 273→  const plansDir = createTempPlansDir();\n 274→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 275→  const service = createPlanIngestionService({ plansDir });\n 276→\n 277→  const content = await service.getVersion('feature-list', 'v99999999-999999');\n 278→\n 279→  assert.equal(content, null);\n 280→\n 281→  // Cleanup\n 282→  fs.rmSync(plansDir, { recursive: true, force: true });\n 283→});\n 284→\n 285→// ============================================================\n 286→// T-013: Plan Registry Tests\n 287→// ============================================================\n 288→test('T-013: setCurrent should update _current.json', async () => {\n 289→  const plansDir = createTempPlansDir();\n 290→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 291→  const service = createPlanIngestionService({ plansDir });\n 292→\n 293→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 294→  const success = await service.setCurrent('feature-list', saved.version);\n 295→\n 296→  assert.equal(success, true);\n 297→\n 298→  const current = await service.getCurrent('feature-list');\n 299→  assert.ok(current);\n 300→  assert.equal(current.version, saved.version);\n 301→\n 302→  // Cleanup\n 303→  fs.rmSync(plansDir, { recursive: true, force: true });\n 304→});\n 305→\n 306→test('T-013: getActivePath should return path to current version', async () => {\n 307→  const plansDir = createTempPlansDir();\n 308→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 309→  const service = createPlanIngestionService({ plansDir });\n 310→\n 311→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 312→  await service.setCurrent('feature-list', saved.version);\n 313→\n 314→  const activePath = service.getActivePath('feature-list');\n 315→\n 316→  assert.ok(activePath);\n 317→  assert.match(activePath, /feature-list/);\n 318→  assert.match(activePath, new RegExp(saved.version));\n 319→\n 320→  // Cleanup\n 321→  fs.rmSync(plansDir, { recursive: true, force: true });\n 322→});\n 323→\n 324→test('T-013: rollback should switch to previous version', async () => {\n 325→  const plansDir = createTempPlansDir();\n 326→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 327→  const service = createPlanIngestionService({ plansDir });\n 328→\n 329→  // Save and set first version\n 330→  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 331→  await service.setCurrent('feature-list', v1.version);\n 332→\n 333→  // Save and set second version\n 334→  await new Promise(r => setTimeout(r, 1100));\n 335→  const v2 = await service.save('feature-list', JSON.stringify({\n 336→    $schema: 'dev-pipeline-feature-list-v1',\n 337→    app_name: 'TestApp2',\n 338→    features: [\n 339→      { id: 'F-001', title: 'Test', description: 'Test', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 340→    ]\n 341→  }), { uploadedBy: 12345 });\n 342→  await service.setCurrent('feature-list', v2.version);\n 343→\n 344→  // Rollback\n 345→  const result = await service.rollback('feature-list');\n 346→\n 347→  assert.ok(result);\n 348→  assert.equal(result.previousVersion, v2.version);\n 349→  assert.equal(result.currentVersion, v1.version);\n 350→\n 351→  // Cleanup\n 352→  fs.rmSync(plansDir, { recursive: true, force: true });\n 353→});\n 354→\n 355→test('T-013: rollback should return null when no previous version', async () => {\n 356→  const plansDir = createTempPlansDir();\n 357→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 358→  const service = createPlanIngestionService({ plansDir });\n 359→\n 360→  // Only one version\n 361→  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 362→  await service.setCurrent('feature-list', v1.version);\n 363→\n 364→  const result = await service.rollback('feature-list');\n 365→\n 366→  assert.equal(result, null);\n 367→\n 368→  // Cleanup\n 369→  fs.rmSync(plansDir, { recursive: true, force: true });\n 370→});\n 371→\n 372→test('T-013: getCurrent should return null when no version set', async () => {\n 373→  const plansDir = createTempPlansDir();\n 374→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 375→  const service = createPlanIngestionService({ plansDir });\n 376→\n 377→  const current = await service.getCurrent('feature-list');\n 378→\n 379→  assert.equal(current, null);\n 380→\n 381→  // Cleanup\n 382→  fs.rmSync(plansDir, { recursive: true, force: true });\n 383→});\n 384→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:29.631Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"777b2e98-4bf7-4aee-9ff1-f087e62aa5f1","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebf5d1c286f4d6721c802d325cb","content":[{"type":"text","text":"   1→/**\n   2→ * Error Path Tests for Control Layer\n   3→ * F-007: Test and Validation Suite\n   4→ *\n   5→ * T-114: Tests error handling paths in control layer\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→\n  11→import { createMockRunner } from '../helpers/mock-runner.js';\n  12→import { createTestPipelineDirs } from '../helpers/test-state.js';\n  13→\n  14→// ============================================================\n  15→// Pipeline Control Service Error Paths\n  16→// ============================================================\n  17→\n  18→test('T-114: pipeline-control-service handles runner errors', async () => {\n  19→  const runner = createMockRunner({\n  20→    run: { ok: false, errorCode: 'SCRIPT_ERROR', message: 'Script execution failed' }\n  21→  });\n  22→\n  23→  const result = await runner({ action: 'run' });\n  24→  assert.equal(result.ok, false);\n  25→  assert.equal(result.errorCode, 'SCRIPT_ERROR');\n  26→});\n  27→\n  28→test('T-114: pipeline-control-service handles timeout errors', async () => {\n  29→  const runner = createMockRunner({\n  30→    run: { ok: false, errorCode: 'TIMEOUT', message: 'Operation timed out' }\n  31→  });\n  32→\n  33→  const result = await runner({ action: 'run' });\n  34→  assert.equal(result.ok, false);\n  35→  assert.equal(result.errorCode, 'TIMEOUT');\n  36→});\n  37→\n  38→test('T-114: pipeline-control-service handles invalid input', async () => {\n  39→  const runner = createMockRunner();\n  40→\n  41→  // Test with missing parameters\n  42→  const result = await runner({ action: 'retry' }); // Missing targetId\n  43→  assert.ok(result, 'Should handle gracefully');\n  44→});\n  45→\n  46→// ============================================================\n  47→// Pipeline Controller Error Paths\n  48→// ============================================================\n  49→\n  50→test('T-114: startPipeline handles already running error', async () => {\n  51→  const runner = createMockRunner({\n  52→    run: { ok: false, errorCode: 'ALREADY_RUNNING', message: 'Pipeline is already running' }\n  53→  });\n  54→\n  55→  const result = await runner({ action: 'run' });\n  56→  assert.equal(result.ok, false);\n  57→  assert.equal(result.errorCode, 'ALREADY_RUNNING');\n  58→});\n  59→\n  60→test('T-114: stopPipeline handles not running gracefully', async () => {\n  61→  const runner = createMockRunner({\n  62→    stop: { ok: true, errorCode: 'ALREADY_STOPPED', message: 'Pipeline is not running' }\n  63→  });\n  64→\n  65→  const result = await runner({ action: 'stop' });\n  66→  assert.equal(result.ok, true); // Not an error, just already stopped\n  67→  assert.equal(result.errorCode, 'ALREADY_STOPPED');\n  68→});\n  69→\n  70→test('T-114: retryTarget handles missing target', async () => {\n  71→  const runner = createMockRunner({\n  72→    retry: { ok: false, errorCode: 'INVALID_TARGET', message: 'Target ID required' }\n  73→  });\n  74→\n  75→  const result = await runner({ action: 'retry' });\n  76→  assert.equal(result.ok, false);\n  77→  assert.equal(result.errorCode, 'INVALID_TARGET');\n  78→});\n  79→\n  80→test('T-114: getStatus handles corrupted state', async () => {\n  81→  const runner = createMockRunner({\n  82→    status: { ok: false, errorCode: 'STATE_CORRUPTED', message: 'State file is corrupted' }\n  83→  });\n  84→\n  85→  const result = await runner({ action: 'status' });\n  86→  assert.equal(result.ok, false);\n  87→  assert.equal(result.errorCode, 'STATE_CORRUPTED');\n  88→});\n  89→\n  90→// ============================================================\n  91→// Plan Ingestion Service Error Paths\n  92→// ============================================================\n  93→\n  94→test('T-114: plan validation handles missing schema', async () => {\n  95→  const runner = createMockRunner();\n  96→\n  97→  // Simulate validation error\n  98→  const invalidPlan = JSON.stringify({ app_name: 'Test' }); // Missing $schema\n  99→\n 100→  // This would be validated by plan-ingestion-service\n 101→  // Here we test the error path pattern\n 102→  assert.ok(invalidPlan, 'Invalid plan should be detected');\n 103→});\n 104→\n 105→test('T-114: plan version handles non-existent version', async () => {\n 106→  const runner = createMockRunner({\n 107→    getVersion: { ok: false, errorCode: 'VERSION_NOT_FOUND', message: 'Version does not exist' }\n 108→  });\n 109→\n 110→  const result = await runner({ action: 'getVersion', version: 'v99999999-999999' });\n 111→  assert.equal(result.ok, false);\n 112→  assert.equal(result.errorCode, 'VERSION_NOT_FOUND');\n 113→});\n 114→\n 115→// ============================================================\n 116→// Lock Manager Error Paths\n 117→// ============================================================\n 118→\n 119→test('T-114: lock acquisition handles concurrent access', async () => {\n 120→  const runner = createMockRunner({\n 121→    run: [\n 122→      { ok: true, pid: 12345 },\n 123→      { ok: false, errorCode: 'LOCK_ACQUISITION_FAILED', message: 'Lock is held by another process' }\n 124→    ]\n 125→  });\n 126→\n 127→  const result1 = await runner({ action: 'run' });\n 128→  assert.equal(result1.ok, true);\n 129→\n 130→  const result2 = await runner({ action: 'run' });\n 131→  assert.equal(result2.ok, false);\n 132→  assert.equal(result2.errorCode, 'LOCK_ACQUISITION_FAILED');\n 133→});\n 134→\n 135→test('T-114: force-unlock handles missing lock', async () => {\n 136→  const runner = createMockRunner({\n 137→    forceUnlock: { ok: true, previousPid: null, message: 'No lock to release' }\n 138→  });\n 139→\n 140→  const result = await runner({ action: 'forceUnlock' });\n 141→  assert.equal(result.ok, true);\n 142→  assert.equal(result.previousPid, null);\n 143→});\n 144→\n 145→// ============================================================\n 146→// General Error Response Format Tests\n 147→// ============================================================\n 148→\n 149→test('T-114: error responses include required fields', async () => {\n 150→  const runner = createMockRunner({\n 151→    run: { ok: false, errorCode: 'TEST_ERROR', message: 'Test error', hint: 'Try again' }\n 152→  });\n 153→\n 154→  const result = await runner({ action: 'run' });\n 155→  assert.equal(result.ok, false);\n 156→  assert.ok(result.errorCode, 'Should have errorCode');\n 157→  assert.ok(result.message, 'Should have message');\n 158→});\n 159→\n 160→test('T-114: error responses are JSON serializable', async () => {\n 161→  const runner = createMockRunner({\n 162→    run: { ok: false, errorCode: 'TEST_ERROR', message: 'Test error', context: { foo: 'bar' } }\n 163→  });\n 164→\n 165→  const result = await runner({ action: 'run' });\n 166→  assert.doesNotThrow(() => JSON.stringify(result));\n 167→});\n 168→\n 169→test('T-114: error responses include context for debugging', async () => {\n 170→  const runner = createMockRunner({\n 171→    run: { ok: false, errorCode: 'TEST_ERROR', message: 'Test error', context: { pipelineType: 'feature', targetId: 'F-001' } }\n 172→  });\n 173→\n 174→  const result = await runner({ action: 'run' });\n 175→  assert.ok(result.context);\n 176→  assert.equal(result.context.pipelineType, 'feature');\n 177→  assert.equal(result.context.targetId, 'F-001');\n 178→});\n 179→\n 180→// ============================================================\n 181→// Recovery and Retry Paths\n 182→// ============================================================\n 183→\n 184→test('T-114: retry after failure succeeds', async () => {\n 185→  const runner = createMockRunner({\n 186→    retry: { ok: true, targetId: 'F-001', message: 'Retry successful' }\n 187→  });\n 188→\n 189→  const result = await runner({ action: 'retry', targetId: 'F-001' });\n 190→  assert.equal(result.ok, true);\n 191→  assert.equal(result.targetId, 'F-001');\n 192→});\n 193→\n 194→test('T-114: reset clears error state', async () => {\n 195→  const runner = createMockRunner({\n 196→    reset: { ok: true, targetId: 'F-001', message: 'Reset successful' }\n 197→  });\n 198→\n 199→  const result = await runner({ action: 'reset', targetId: 'F-001' });\n 200→  assert.equal(result.ok, true);\n 201→});\n 202→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebebf5d85e280e638ca4e1c1068","__timestamp":"2026-03-11T21:13:29.632Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
