{"type":"user","uuid":"6e290b88-3bd4-4df8-9d71-f18bade053f3","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_e5d90b803a524dbbaa8870c4","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for plan-ingestion-service.js\n   3→ * Covers T-010 (schema loader), T-011 (plan validator), T-012 (version manager),\n   4→ * T-013 (plan registry), T-014 (error formatting)\n   5→ */\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import os from 'node:os';\n   9→import path from 'node:path';\n  10→import fs from 'node:fs';\n  11→import { fileURLToPath } from 'node:url';\n  12→\n  13→const __dirname = path.dirname(fileURLToPath(import.meta.url));\n  14→const PROJECT_ROOT = path.resolve(__dirname, '../..');\n  15→\n  16→// We'll import dynamically after setup\n  17→let createPlanIngestionService;\n  18→\n  19→function createTempPlansDir() {\n  20→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-plans-'));\n  21→  fs.mkdirSync(path.join(tempDir, 'feature-list'), { recursive: true });\n  22→  fs.mkdirSync(path.join(tempDir, 'bug-fix-list'), { recursive: true });\n  23→  return tempDir;\n  24→}\n  25→\n  26→function createValidFeatureList() {\n  27→  return JSON.stringify({\n  28→    $schema: 'dev-pipeline-feature-list-v1',\n  29→    app_name: 'TestApp',\n  30→    app_description: 'A test application',\n  31→    features: [\n  32→      {\n  33→        id: 'F-001',\n  34→        title: 'Test Feature',\n  35→        description: 'A test feature',\n  36→        priority: 1,\n  37→        dependencies: [],\n  38→        acceptance_criteria: ['AC1: Test passes'],\n  39→        status: 'pending'\n  40→      }\n  41→    ]\n  42→  });\n  43→}\n  44→\n  45→function createValidBugFixList() {\n  46→  return JSON.stringify({\n  47→    $schema: 'dev-pipeline-bug-fix-list-v1',\n  48→    project_name: 'TestProject',\n  49→    bugs: [\n  50→      {\n  51→        id: 'B-001',\n  52→        title: 'Test Bug',\n  53→        description: 'A test bug',\n  54→        severity: 'medium',\n  55→        error_source: { type: 'user_report' },\n  56→        verification_type: 'manual',\n  57→        acceptance_criteria: ['AC1: Bug is fixed'],\n  58→        status: 'pending'\n  59→      }\n  60→    ]\n  61→  });\n  62→}\n  63→\n  64→// ============================================================\n  65→// T-010: Schema Loader Tests\n  66→// ============================================================\n  67→test('T-010: loadSchema should load feature-list schema', async () => {\n  68→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  69→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  70→\n  71→  const schema = service.loadSchema('feature-list');\n  72→  assert.ok(schema);\n  73→  assert.equal(typeof schema, 'object'); // Raw schema object\n  74→});\n  75→\n  76→test('T-010: loadSchema should load bug-fix-list schema', async () => {\n  77→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  78→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  79→\n  80→  const schema = service.loadSchema('bug-fix-list');\n  81→  assert.ok(schema);\n  82→  assert.equal(typeof schema, 'object'); // Raw schema object\n  83→});\n  84→\n  85→test('T-010: loadSchema should throw for unknown schema type', async () => {\n  86→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  87→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  88→\n  89→  assert.throws(\n  90→    () => service.loadSchema('unknown-type'),\n  91→    /unknown.*schema/i\n  92→  );\n  93→});\n  94→\n  95→// ============================================================\n  96→// T-011: Plan Validator Tests\n  97→// ============================================================\n  98→test('T-011: validate should identify feature-list type', async () => {\n  99→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 100→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 101→\n 102→  const result = service.validate(createValidFeatureList());\n 103→\n 104→  assert.equal(result.valid, true);\n 105→  assert.equal(result.type, 'feature-list');\n 106→  assert.ok(result.summary);\n 107→  assert.equal(result.summary.name, 'TestApp');\n 108→  assert.equal(result.summary.itemCount, 1);\n 109→});\n 110→\n 111→test('T-011: validate should identify bug-fix-list type', async () => {\n 112→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 113→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 114→\n 115→  const result = service.validate(createValidBugFixList());\n 116→\n 117→  assert.equal(result.valid, true);\n 118→  assert.equal(result.type, 'bug-fix-list');\n 119→  assert.ok(result.summary);\n 120→  assert.equal(result.summary.name, 'TestProject');\n 121→  assert.equal(result.summary.itemCount, 1);\n 122→});\n 123→\n 124→test('T-011: validate should return unknown type for missing schema', async () => {\n 125→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 126→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 127→\n 128→  const result = service.validate(JSON.stringify({ foo: 'bar' }));\n 129→\n 130→  assert.equal(result.valid, false);\n 131→  assert.equal(result.type, 'unknown');\n 132→});\n 133→\n 134→test('T-011: validate should return field-level errors', async () => {\n 135→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 136→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 137→\n 138→  const invalidContent = JSON.stringify({\n 139→    $schema: 'dev-pipeline-feature-list-v1',\n 140→    app_name: 'TestApp',\n 141→    features: [\n 142→      {\n 143→        id: 'INVALID-ID', // Should match F-\\\\d{3}\n 144→        title: 'Test',\n 145→        description: 'Test',\n 146→        priority: -1, // Should be >= 1\n 147→        dependencies: [],\n 148→        acceptance_criteria: [],\n 149→        status: 'invalid-status'\n 150→      }\n 151→    ]\n 152→  });\n 153→\n 154→  const result = service.validate(invalidContent);\n 155→\n 156→  assert.equal(result.valid, false);\n 157→  assert.ok(result.errors.length > 0);\n 158→  // Check that errors have path and message\n 159→  for (const error of result.errors) {\n 160→    assert.ok(error.path, 'Error should have path');\n 161→    assert.ok(error.message, 'Error should have message');\n 162→  }\n 163→});\n 164→\n 165→test('T-011: validate should return status breakdown in summary', async () => {\n 166→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 167→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 168→\n 169→  const content = JSON.stringify({\n 170→    $schema: 'dev-pipeline-feature-list-v1',\n 171→    app_name: 'TestApp',\n 172→    features: [\n 173→      { id: 'F-001', title: 'A', description: 'A', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' },\n 174→      { id: 'F-002', title: 'B', description: 'B', priority: 2, dependencies: [], acceptance_criteria: ['AC'], status: 'in_progress' },\n 175→      { id: 'F-003', title: 'C', description: 'C', priority: 3, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 176→    ]\n 177→  });\n 178→\n 179→  const result = service.validate(content);\n 180→\n 181→  assert.equal(result.valid, true);\n 182→  assert.deepEqual(result.summary.statusBreakdown, { pending: 2, in_progress: 1 });\n 183→});\n 184→\n 185→test('T-011: validate should handle invalid JSON', async () => {\n 186→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 187→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 188→\n 189→  const result = service.validate('not valid json');\n 190→\n 191→  assert.equal(result.valid, false);\n 192→  assert.equal(result.type, 'unknown');\n 193→  assert.ok(result.errors.length > 0);\n 194→  assert.match(result.errors[0].message, /json/i);\n 195→});\n 196→\n 197→// ============================================================\n 198→// T-014: Error Formatting Tests\n 199→// ============================================================\n 200→test('T-014: formatValidationErrors should format errors with field paths', async () => {\n 201→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 202→  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 203→\n 204→  const errors = [\n 205→    { path: 'features[0].id', message: 'Invalid ID format' },\n 206→    { path: 'features[1].priority', message: 'Must be positive' }\n 207→  ];\n 208→\n 209→  const formatted = service.formatValidationErrors(errors);\n 210→\n 211→  assert.match(formatted, /features\\[0\\].id/);\n 212→  assert.match(formatted, /Invalid ID format/);\n 213→  assert.match(formatted, /features\\[1\\].priority/);\n 214→  assert.match(formatted, /Must be positive/);\n 215→});\n 216→\n 217→// ============================================================\n 218→// T-012: Version Manager Tests\n 219→// ============================================================\n 220→test('T-012: save should create versioned file', async () => {\n 221→  const plansDir = createTempPlansDir();\n 222→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 223→  const service = createPlanIngestionService({ plansDir });\n 224→\n 225→  const result = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 226→\n 227→  assert.equal(result.success, true);\n 228→  assert.ok(result.version);\n 229→  assert.match(result.version, /^v\\d{8}-\\d{6}$/);\n 230→\n 231→  // Cleanup\n 232→  fs.rmSync(plansDir, { recursive: true, force: true });\n 233→});\n 234→\n 235→test('T-012: listVersions should return version list', async () => {\n 236→  const plansDir = createTempPlansDir();\n 237→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 238→  const service = createPlanIngestionService({ plansDir });\n 239→\n 240→  // Save two versions\n 241→  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 242→  await new Promise(r => setTimeout(r, 1100)); // Ensure different timestamp\n 243→  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 244→\n 245→  const versions = await service.listVersions('feature-list');\n 246→\n 247→  assert.equal(versions.length, 2);\n 248→  assert.ok(versions[0].version);\n 249→  assert.ok(versions[0].timestamp);\n 250→  assert.ok(versions[0].itemCount);\n 251→\n 252→  // Cleanup\n 253→  fs.rmSync(plansDir, { recursive: true, force: true });\n 254→});\n 255→\n 256→test('T-012: getVersion should return content', async () => {\n 257→  const plansDir = createTempPlansDir();\n 258→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 259→  const service = createPlanIngestionService({ plansDir });\n 260→\n 261→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 262→  const content = await service.getVersion('feature-list', saved.version);\n 263→\n 264→  assert.ok(content);\n 265→  const parsed = JSON.parse(content);\n 266→  assert.equal(parsed.app_name, 'TestApp');\n 267→\n 268→  // Cleanup\n 269→  fs.rmSync(plansDir, { recursive: true, force: true });\n 270→});\n 271→\n 272→test('T-012: getVersion should return null for non-existent version', async () => {\n 273→  const plansDir = createTempPlansDir();\n 274→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 275→  const service = createPlanIngestionService({ plansDir });\n 276→\n 277→  const content = await service.getVersion('feature-list', 'v99999999-999999');\n 278→\n 279→  assert.equal(content, null);\n 280→\n 281→  // Cleanup\n 282→  fs.rmSync(plansDir, { recursive: true, force: true });\n 283→});\n 284→\n 285→// ============================================================\n 286→// T-013: Plan Registry Tests\n 287→// ============================================================\n 288→test('T-013: setCurrent should update _current.json', async () => {\n 289→  const plansDir = createTempPlansDir();\n 290→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 291→  const service = createPlanIngestionService({ plansDir });\n 292→\n 293→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 294→  const success = await service.setCurrent('feature-list', saved.version);\n 295→\n 296→  assert.equal(success, true);\n 297→\n 298→  const current = await service.getCurrent('feature-list');\n 299→  assert.ok(current);\n 300→  assert.equal(current.version, saved.version);\n 301→\n 302→  // Cleanup\n 303→  fs.rmSync(plansDir, { recursive: true, force: true });\n 304→});\n 305→\n 306→test('T-013: getActivePath should return path to current version', async () => {\n 307→  const plansDir = createTempPlansDir();\n 308→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 309→  const service = createPlanIngestionService({ plansDir });\n 310→\n 311→  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 312→  await service.setCurrent('feature-list', saved.version);\n 313→\n 314→  const activePath = service.getActivePath('feature-list');\n 315→\n 316→  assert.ok(activePath);\n 317→  assert.match(activePath, /feature-list/);\n 318→  assert.match(activePath, new RegExp(saved.version));\n 319→\n 320→  // Cleanup\n 321→  fs.rmSync(plansDir, { recursive: true, force: true });\n 322→});\n 323→\n 324→test('T-013: rollback should switch to previous version', async () => {\n 325→  const plansDir = createTempPlansDir();\n 326→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 327→  const service = createPlanIngestionService({ plansDir });\n 328→\n 329→  // Save and set first version\n 330→  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 331→  await service.setCurrent('feature-list', v1.version);\n 332→\n 333→  // Save and set second version\n 334→  await new Promise(r => setTimeout(r, 1100));\n 335→  const v2 = await service.save('feature-list', JSON.stringify({\n 336→    $schema: 'dev-pipeline-feature-list-v1',\n 337→    app_name: 'TestApp2',\n 338→    features: [\n 339→      { id: 'F-001', title: 'Test', description: 'Test', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 340→    ]\n 341→  }), { uploadedBy: 12345 });\n 342→  await service.setCurrent('feature-list', v2.version);\n 343→\n 344→  // Rollback\n 345→  const result = await service.rollback('feature-list');\n 346→\n 347→  assert.ok(result);\n 348→  assert.equal(result.previousVersion, v2.version);\n 349→  assert.equal(result.currentVersion, v1.version);\n 350→\n 351→  // Cleanup\n 352→  fs.rmSync(plansDir, { recursive: true, force: true });\n 353→});\n 354→\n 355→test('T-013: rollback should return null when no previous version', async () => {\n 356→  const plansDir = createTempPlansDir();\n 357→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 358→  const service = createPlanIngestionService({ plansDir });\n 359→\n 360→  // Only one version\n 361→  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 362→  await service.setCurrent('feature-list', v1.version);\n 363→\n 364→  const result = await service.rollback('feature-list');\n 365→\n 366→  assert.equal(result, null);\n 367→\n 368→  // Cleanup\n 369→  fs.rmSync(plansDir, { recursive: true, force: true });\n 370→});\n 371→\n 372→test('T-013: getCurrent should return null when no version set', async () => {\n 373→  const plansDir = createTempPlansDir();\n 374→  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 375→  const service = createPlanIngestionService({ plansDir });\n 376→\n 377→  const current = await service.getCurrent('feature-list');\n 378→\n 379→  assert.equal(current, null);\n 380→\n 381→  // Cleanup\n 382→  fs.rmSync(plansDir, { recursive: true, force: true });\n 383→});\n 384→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:01:39.083Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"7b8fa57f-4b28-487d-9494-f2f7f770d237","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_c191b802d595471a9bcbe657","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Test for F-006: Safety and Permission Guard\n   3→ * Tests the full security flow end-to-end.\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdtemp, rm } from 'node:fs/promises';\n   9→import { join } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→import {\n  12→  checkCommandPermission,\n  13→  getUserRole,\n  14→  isAdmin,\n  15→  setConfigForTesting,\n  16→  resetConfig as resetPermConfig\n  17→} from '../../src/security/permission-guard.js';\n  18→import {\n  19→  createConfirmation,\n  20→  checkConfirmation,\n  21→  confirmAction,\n  22→  cancelConfirmation,\n  23→  clearExpiredConfirmations\n  24→} from '../../src/security/confirmation-manager.js';\n  25→import { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n  26→import {\n  27→  initAuditLogService,\n  28→  logAuditEntry,\n  29→  queryAuditLogs,\n  30→  resetAuditLogService\n  31→} from '../../src/services/audit-log-service.js';\n  32→\n  33→// Helper to create test config\n  34→function createTestConfig(overrides = {}) {\n  35→  return {\n  36→    userPermissions: new Map(),\n  37→    allowAdminSkipConfirm: true,\n  38→    enableSystemExec: false,\n  39→    allowedUserIds: new Set(),\n  40→    ...overrides\n  41→  };\n  42→}\n  43→\n  44→// Helper to create temp directory for audit log tests\n  45→async function withTempDir(fn) {\n  46→  const tempDir = await mkdtemp(join(tmpdir(), 'security-integration-'));\n  47→  try {\n  48→    return await fn(tempDir);\n  49→  } finally {\n  50→    await rm(tempDir, { recursive: true, force: true });\n  51→  }\n  52→}\n  53→\n  54→// US-1: User Permission Levels\n  55→test('US-1: User permission levels work correctly', async () => {\n  56→  resetPermConfig();\n  57→  resetAuditLogService();\n  58→  clearExpiredConfirmations();\n  59→\n  60→  const config = createTestConfig();\n  61→  config.userPermissions.set('admin-user', 'admin');\n  62→  config.userPermissions.set('op-user', 'operator');\n  63→  config.userPermissions.set('viewer-user', 'viewer');\n  64→  setConfigForTesting(config);\n  65→\n  66→  // Test role retrieval\n  67→  assert.equal(getUserRole('admin-user'), 'admin');\n  68→  assert.equal(getUserRole('op-user'), 'operator');\n  69→  assert.equal(getUserRole('viewer-user'), 'viewer');\n  70→  assert.equal(getUserRole('unknown-user'), 'operator'); // Default\n  71→\n  72→  // Test isAdmin\n  73→  assert.equal(isAdmin('admin-user'), true);\n  74→  assert.equal(isAdmin('op-user'), false);\n  75→  assert.equal(isAdmin('viewer-user'), false);\n  76→});\n  77→\n  78→// US-2: High-Risk Command Authorization\n  79→test('US-2: High-risk command authorization works correctly', async () => {\n  80→  resetPermConfig();\n  81→  resetAuditLogService();\n  82→  clearExpiredConfirmations();\n  83→\n  84→  const config = createTestConfig();\n  85→  config.userPermissions.set('admin-user', 'admin');\n  86→  config.userPermissions.set('op-user', 'operator');\n  87→  config.userPermissions.set('viewer-user', 'viewer');\n  88→  setConfigForTesting(config);\n  89→\n  90→  // stop command - admin only\n  91→  const adminStopResult = checkCommandPermission('admin-user', 'stop');\n  92→  assert.equal(adminStopResult.allowed, true);\n  93→  assert.equal(adminStopResult.requiresConfirmation, true);\n  94→\n  95→  const opStopResult = checkCommandPermission('op-user', 'stop');\n  96→  assert.equal(opStopResult.allowed, false);\n  97→\n  98→  // retry command - operator level\n  99→  const opRetryResult = checkCommandPermission('op-user', 'retry');\n 100→  assert.equal(opRetryResult.allowed, true);\n 101→  assert.equal(opRetryResult.requiresConfirmation, false);\n 102→\n 103→  const viewerRetryResult = checkCommandPermission('viewer-user', 'retry');\n 104→  assert.equal(viewerRetryResult.allowed, false);\n 105→});\n 106→\n 107→// US-3: Parameter Sanitization\n 108→test('US-3: Parameter sanitization works correctly', async () => {\n 109→  resetPermConfig();\n 110→  resetAuditLogService();\n 111→  clearExpiredConfirmations();\n 112→\n 113→  // Valid input passes\n 114→  const validResult = sanitizeParam('my-feature-123', { maxLength: 100 });\n 115→  assert.equal(validResult.ok, true);\n 116→\n 117→  // Dangerous patterns are blocked\n 118→  const traversalResult = sanitizeParam('../../../etc/passwd');\n 119→  assert.equal(traversalResult.ok, false);\n 120→\n 121→  const shellInjectionResult = sanitizeParam('$(whoami)');\n 122→  assert.equal(shellInjectionResult.ok, false);\n 123→\n 124→  // TargetId format validation\n 125→  const validTargetId = sanitizeParam('feature-branch_123', { isTargetId: true });\n 126→  assert.equal(validTargetId.ok, true);\n 127→\n 128→  const invalidTargetId = sanitizeParam('feature/branch', { isTargetId: true });\n 129→  assert.equal(invalidTargetId.ok, false);\n 130→\n 131→  // Path validation\n 132→  const validPath = validatePath('/project/src/file.js', ['/project']);\n 133→  assert.equal(validPath.ok, true);\n 134→\n 135→  const invalidPath = validatePath('/etc/passwd', ['/project']);\n 136→  assert.equal(invalidPath.ok, false);\n 137→});\n 138→\n 139→// US-4: Confirmation Flow\n 140→test('US-4: Confirmation flow works correctly', async () => {\n 141→  resetPermConfig();\n 142→  resetAuditLogService();\n 143→  clearExpiredConfirmations();\n 144→\n 145→  // Create confirmation\n 146→  const { confirmId, message } = createConfirmation('test-user', 'stop', { type: 'feature' });\n 147→  assert.ok(confirmId);\n 148→  assert.ok(message);\n 149→\n 150→  // Check pending status\n 151→  const pendingResult = checkConfirmation(confirmId, 'test-user');\n 152→  assert.equal(pendingResult.status, 'pending');\n 153→  assert.equal(pendingResult.action, 'stop');\n 154→\n 155→  // Confirm action\n 156→  const confirmResult = confirmAction(confirmId, 'test-user');\n 157→  assert.equal(confirmResult.ok, true);\n 158→  assert.equal(confirmResult.action, 'stop');\n 159→\n 160→  // Verify consumed\n 161→  const consumedResult = checkConfirmation(confirmId, 'test-user');\n 162→  assert.equal(consumedResult.status, 'not_found');\n 163→});\n 164→\n 165→test('US-4: Confirmation cancel works correctly', () => {\n 166→  resetPermConfig();\n 167→  resetAuditLogService();\n 168→  clearExpiredConfirmations();\n 169→\n 170→  const { confirmId } = createConfirmation('test-user', 'reset', {});\n 171→\n 172→  cancelConfirmation(confirmId, 'test-user');\n 173→\n 174→  const result = checkConfirmation(confirmId, 'test-user');\n 175→  assert.equal(result.status, 'not_found');\n 176→});\n 177→\n 178→test('US-4: Wrong user cannot confirm', () => {\n 179→  resetPermConfig();\n 180→  resetAuditLogService();\n 181→  clearExpiredConfirmations();\n 182→\n 183→  const { confirmId } = createConfirmation('user-1', 'stop', {});\n 184→\n 185→  const result = confirmAction(confirmId, 'user-2');\n 186→  assert.equal(result.ok, false);\n 187→});\n 188→\n 189→// US-5: Audit Logging\n 190→test('US-5: Audit logging works correctly', async () => {\n 191→  resetPermConfig();\n 192→  resetAuditLogService();\n 193→  clearExpiredConfirmations();\n 194→\n 195→  await withTempDir(async (tempDir) => {\n 196→    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 197→\n 198→    // Log entry\n 199→    await logAuditEntry({\n 200→      userId: '123456789',\n 201→      action: 'stop',\n 202→      params: { type: 'feature' },\n 203→      result: 'success'\n 204→    });\n 205→\n 206→    // Query logs\n 207→    const entries = await queryAuditLogs({ userId: '123456789' });\n 208→    assert.ok(entries.length >= 1);\n 209→\n 210→    const entry = entries.find((e) => e.action === 'stop');\n 211→    assert.ok(entry);\n 212→    assert.equal(entry.userId, '123456789');\n 213→    assert.equal(entry.result, 'success');\n 214→  });\n 215→});\n 216→\n 217→test('US-5: Audit log query filters work', async () => {\n 218→  resetPermConfig();\n 219→  resetAuditLogService();\n 220→  clearExpiredConfirmations();\n 221→\n 222→  await withTempDir(async (tempDir) => {\n 223→    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 224→\n 225→    await logAuditEntry({ userId: 'user-1', action: 'stop', params: {}, result: 'success' });\n 226→    await logAuditEntry({ userId: 'user-1', action: 'reset', params: {}, result: 'success' });\n 227→    await logAuditEntry({ userId: 'user-2', action: 'stop', params: {}, result: 'denied' });\n 228→\n 229→    const user1Entries = await queryAuditLogs({ userId: 'user-1' });\n 230→    assert.ok(user1Entries.every((e) => e.userId === 'user-1'));\n 231→\n 232→    const stopEntries = await queryAuditLogs({ action: 'stop' });\n 233→    assert.ok(stopEntries.every((e) => e.action === 'stop'));\n 234→  });\n 235→});\n 236→\n 237→// F-001: force-unlock command\n 238→test('F-001: force-unlock command requires admin and confirmation', async () => {\n 239→  resetPermConfig();\n 240→  resetAuditLogService();\n 241→  clearExpiredConfirmations();\n 242→\n 243→  const config = createTestConfig();\n 244→  config.userPermissions.set('admin-user', 'admin');\n 245→  config.userPermissions.set('op-user', 'operator');\n 246→  setConfigForTesting(config);\n 247→\n 248→  const adminResult = checkCommandPermission('admin-user', 'force-unlock');\n 249→  assert.equal(adminResult.allowed, true);\n 250→  assert.equal(adminResult.requiresConfirmation, true);\n 251→\n 252→  const opResult = checkCommandPermission('op-user', 'force-unlock');\n 253→  assert.equal(opResult.allowed, false);\n 254→});\n 255→\n 256→// F-002: exec command with ENABLE_SYSTEM_EXEC\n 257→test('F-002: exec command requires ENABLE_SYSTEM_EXEC', async () => {\n 258→  resetPermConfig();\n 259→  resetAuditLogService();\n 260→  clearExpiredConfirmations();\n 261→\n 262→  const config = createTestConfig({ enableSystemExec: false });\n 263→  config.userPermissions.set('admin-user', 'admin');\n 264→  setConfigForTesting(config);\n 265→\n 266→  const disabledResult = checkCommandPermission('admin-user', 'exec');\n 267→  assert.equal(disabledResult.allowed, false);\n 268→  assert.ok(disabledResult.reason.includes('系统命令执行未启用'));\n 269→\n 270→  // Enable system exec\n 271→  config.enableSystemExec = true;\n 272→  setConfigForTesting(config);\n 273→\n 274→  const enabledResult = checkCommandPermission('admin-user', 'exec');\n 275→  assert.equal(enabledResult.allowed, true);\n 276→});\n 277→\n 278→// Full flow test: Operator stop flow (should be denied)\n 279→test('Integration: Operator cannot execute stop command', async () => {\n 280→  resetPermConfig();\n 281→  resetAuditLogService();\n 282→  clearExpiredConfirmations();\n 283→\n 284→  await withTempDir(async (tempDir) => {\n 285→    const config = createTestConfig();\n 286→    config.userPermissions.set('op-user', 'operator');\n 287→    setConfigForTesting(config);\n 288→\n 289→    const result = checkCommandPermission('op-user', 'stop');\n 290→    assert.equal(result.allowed, false);\n 291→\n 292→    // Log denial\n 293→    await initAuditLogService({ logDir: tempDir });\n 294→    await logAuditEntry({\n 295→      userId: 'op-user',\n 296→      action: 'stop',\n 297→      params: {},\n 298→      result: 'denied',\n 299→      reason: result.reason\n 300→    });\n 301→\n 302→    const entries = await queryAuditLogs({ action: 'stop', userId: 'op-user' });\n 303→    assert.ok(entries.some((e) => e.result === 'denied'));\n 304→  });\n 305→});\n 306→\n 307→// Full flow test: Admin stop with confirmation\n 308→test('Integration: Admin stop with confirmation flow', async () => {\n 309→  resetPermConfig();\n 310→  resetAuditLogService();\n 311→  clearExpiredConfirmations();\n 312→\n 313→  await withTempDir(async (tempDir) => {\n 314→    const config = createTestConfig();\n 315→    config.userPermissions.set('admin-user', 'admin');\n 316→    setConfigForTesting(config);\n 317→\n 318→    // 1. Check permission\n 319→    const permResult = checkCommandPermission('admin-user', 'stop');\n 320→    assert.equal(permResult.allowed, true);\n 321→    assert.equal(permResult.requiresConfirmation, true);\n 322→\n 323→    // 2. Create confirmation\n 324→    const { confirmId } = createConfirmation('admin-user', 'stop', { type: 'feature' });\n 325→\n 326→    // 3. Confirm\n 327→    const confirmResult = confirmAction(confirmId, 'admin-user');\n 328→    assert.equal(confirmResult.ok, true);\n 329→\n 330→    // 4. Log success\n 331→    await initAuditLogService({ logDir: tempDir });\n 332→    await logAuditEntry({\n 333→      userId: 'admin-user',\n 334→      action: 'stop',\n 335→      params: { type: 'feature' },\n 336→      result: 'success'\n 337→    });\n 338→\n 339→    const entries = await queryAuditLogs({ userId: 'admin-user', action: 'stop' });\n 340→    assert.ok(entries.some((e) => e.result === 'success'));\n 341→  });\n 342→});\n 343→\n 344→// AC-2.5: Error message security\n 345→test('AC-2.5: Error messages do not expose sensitive info', async () => {\n 346→  resetPermConfig();\n 347→  resetAuditLogService();\n 348→  clearExpiredConfirmations();\n 349→\n 350→  const config = createTestConfig();\n 351→  config.userPermissions.set('viewer-user', 'viewer');\n 352→  setConfigForTesting(config);\n 353→\n 354→  const result = checkCommandPermission('viewer-user', 'stop');\n 355→  assert.equal(result.allowed, false);\n 356→  assert.ok(!result.reason.includes('/'));\n 357→  assert.ok(!result.reason.includes('config'));\n 358→  assert.ok(!result.reason.includes('password'));\n 359→});\n 360→\n 361→// NFR-1: Performance\n 362→test('NFR-1: Permission check is fast', () => {\n 363→  resetPermConfig();\n 364→  resetAuditLogService();\n 365→  clearExpiredConfirmations();\n 366→\n 367→  const config = createTestConfig();\n 368→  config.userPermissions.set('test-user', 'admin');\n 369→  setConfigForTesting(config);\n 370→\n 371→  const start = Date.now();\n 372→  for (let i = 0; i < 1000; i++) {\n 373→    checkCommandPermission('test-user', 'stop');\n 374→  }\n 375→  const duration = Date.now() - start;\n 376→\n 377→  // 1000 checks should take < 50ms total (< 0.05ms per check, well under 5ms requirement)\n 378→  assert.ok(duration < 50, `Permission check too slow: ${duration}ms for 1000 checks`);\n 379→});\n 380→\n 381→test('NFR-1: Param sanitization is fast', () => {\n 382→  resetPermConfig();\n 383→  resetAuditLogService();\n 384→  clearExpiredConfirmations();\n 385→\n 386→  const start = Date.now();\n 387→  for (let i = 0; i < 1000; i++) {\n 388→    sanitizeParam('test-input-with-moderate-length', { maxLength: 100 });\n 389→  }\n 390→  const duration = Date.now() - start;\n 391→\n 392→  // 1000 sanitizations should take < 20ms total (< 0.02ms per check, well under 2ms requirement)\n 393→  assert.ok(duration < 20, `Sanitization too slow: ${duration}ms for 1000 checks`);\n 394→});\n 395→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:01:39.083Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
{"type":"user","uuid":"b5faeedb-5bee-4840-a210-82744ec188eb","session_id":"9310a036-0fcf-4395-9365-74ce968ab0f4","message":{"content":[{"type":"tool_result","tool_use_id":"call_d5b6a3e3d49a4aada2b34270","content":[{"type":"text","text":"   1→/**\n   2→ * Confirmation Manager Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Manages confirmation flow for high-risk actions.\n   6→ * AC-4: Confirmation for Sensitive Actions\n   7→ */\n   8→\n   9→import { randomUUID } from 'node:crypto';\n  10→\n  11→/**\n  12→ * Default confirmation timeout (60 seconds per AC-4.3)\n  13→ */\n  14→const DEFAULT_TIMEOUT_MS = 60000;\n  15→\n  16→/**\n  17→ * Pending confirmations storage\n  18→ * Map<confirmId, ConfirmationEntry>\n  19→ */\n  20→const pendingConfirmations = new Map();\n  21→\n  22→/**\n  23→ * @typedef {Object} ConfirmationEntry\n  24→ * @property {string} confirmId\n  25→ * @property {string|number} userId\n  26→ * @property {string} action\n  27→ * @property {Object} params\n  28→ * @property {number} createdAt\n  29→ * @property {number} expiresAt\n  30→ */\n  31→\n  32→/**\n  33→ * Create pending confirmation\n  34→ * @param {string|number} userId\n  35→ * @param {string} action - Action name\n  36→ * @param {Object} params - Action parameters\n  37→ * @param {number} [timeoutMs=60000]\n  38→ * @returns {{ confirmId: string, message: string }}\n  39→ */\n  40→export function createConfirmation(userId, action, params, timeoutMs = DEFAULT_TIMEOUT_MS) {\n  41→  const confirmId = randomUUID();\n  42→  const now = Date.now();\n  43→\n  44→  const entry = {\n  45→    confirmId,\n  46→    userId: String(userId),\n  47→    action,\n  48→    params,\n  49→    createdAt: now,\n  50→    expiresAt: now + timeoutMs\n  51→  };\n  52→\n  53→  pendingConfirmations.set(confirmId, entry);\n  54→\n  55→  const message = `⚠️ 确认执行操作: ${action}\\n参数: ${JSON.stringify(params)}\\n请在 60 秒内回复 CONFIRM 确认，或回复 CANCEL 取消。`;\n  56→\n  57→  return { confirmId, message };\n  58→}\n  59→\n  60→/**\n  61→ * Check confirmation status\n  62→ * @param {string} confirmId\n  63→ * @param {string|number} userId\n  64→ * @returns {{ status: 'pending'|'confirmed'|'expired'|'not_found', action?: string, params?: Object }}\n  65→ */\n  66→export function checkConfirmation(confirmId, userId) {\n  67→  const entry = pendingConfirmations.get(confirmId);\n  68→\n  69→  if (!entry) {\n  70→    return { status: 'not_found' };\n  71→  }\n  72→\n  73→  // Verify userId matches\n  74→  if (entry.userId !== String(userId)) {\n  75→    return { status: 'not_found' };\n  76→  }\n  77→\n  78→  // Check if expired\n  79→  if (Date.now() > entry.expiresAt) {\n  80→    return { status: 'expired', action: entry.action, params: entry.params };\n  81→  }\n  82→\n  83→  return {\n  84→    status: 'pending',\n  85→    action: entry.action,\n  86→    params: entry.params\n  87→  };\n  88→}\n  89→\n  90→/**\n  91→ * Confirm pending action\n  92→ * @param {string} confirmId\n  93→ * @param {string|number} userId\n  94→ * @returns {{ ok: boolean, action?: string, params?: Object, error?: string }}\n  95→ */\n  96→export function confirmAction(confirmId, userId) {\n  97→  const entry = pendingConfirmations.get(confirmId);\n  98→\n  99→  if (!entry) {\n 100→    return { ok: false, error: '确认请求不存在或已过期' };\n 101→  }\n 102→\n 103→  // Verify userId matches\n 104→  if (entry.userId !== String(userId)) {\n 105→    return { ok: false, error: '无权确认此操作' };\n 106→  }\n 107→\n 108→  // Check if expired\n 109→  if (Date.now() > entry.expiresAt) {\n 110→    return { ok: false, error: '确认请求已过期' };\n 111→  }\n 112→\n 113→  // Remove from pending (consumed)\n 114→  pendingConfirmations.delete(confirmId);\n 115→\n 116→  return {\n 117→    ok: true,\n 118→    action: entry.action,\n 119→    params: entry.params\n 120→  };\n 121→}\n 122→\n 123→/**\n 124→ * Cancel pending confirmation\n 125→ * @param {string} confirmId\n 126→ * @param {string|number} userId\n 127→ */\n 128→export function cancelConfirmation(confirmId, userId) {\n 129→  const entry = pendingConfirmations.get(confirmId);\n 130→\n 131→  if (!entry) {\n 132→    return;\n 133→  }\n 134→\n 135→  // Only allow creator to cancel\n 136→  if (entry.userId === String(userId)) {\n 137→    pendingConfirmations.delete(confirmId);\n 138→  }\n 139→}\n 140→\n 141→/**\n 142→ * Clear all expired confirmations\n 143→ * Should be called periodically\n 144→ */\n 145→export function clearExpiredConfirmations() {\n 146→  const now = Date.now();\n 147→\n 148→  for (const [confirmId, entry] of pendingConfirmations) {\n 149→    if (entry.expiresAt <= now) {\n 150→      pendingConfirmations.delete(confirmId);\n 151→    }\n 152→  }\n 153→}\n 154→\n 155→export default {\n 156→  createConfirmation,\n 157→  checkConfirmation,\n 158→  confirmAction,\n 159→  cancelConfirmation,\n 160→  clearExpiredConfirmations\n 161→};\n 162→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb407ff468dd4921b8d49e24952","__timestamp":"2026-03-11T21:01:39.084Z","_requestId":"f8b0d56a051a42089a34cee3b1b65359"}
