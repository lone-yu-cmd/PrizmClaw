{"type":"user","uuid":"0802ef2a-757d-4b15-a892-8d44e12074eb","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeb5acef626632ce62973e076077","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Tests for confirmation-manager.js\n   3вЖТ * F-006: Safety and Permission Guard\n   4вЖТ */\n   5вЖТ\n   6вЖТimport test from 'node:test';\n   7вЖТimport assert from 'node:assert/strict';\n   8вЖТimport {\n   9вЖТ  createConfirmation,\n  10вЖТ  checkConfirmation,\n  11вЖТ  confirmAction,\n  12вЖТ  cancelConfirmation,\n  13вЖТ  clearExpiredConfirmations\n  14вЖТ} from '../../src/security/confirmation-manager.js';\n  15вЖТ\n  16вЖТ// Helper to wait\n  17вЖТconst wait = (ms) => new Promise((resolve) => setTimeout(resolve, ms));\n  18вЖТ\n  19вЖТ// createConfirmation tests\n  20вЖТtest('createConfirmation creates a pending confirmation', () => {\n  21вЖТ  clearExpiredConfirmations();\n  22вЖТ  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  23вЖТ\n  24вЖТ  assert.ok(result.confirmId);\n  25вЖТ  assert.ok(result.message);\n  26вЖТ  assert.ok(result.message.includes('stop'));\n  27вЖТ});\n  28вЖТ\n  29вЖТtest('createConfirmation generates unique confirmId', () => {\n  30вЖТ  clearExpiredConfirmations();\n  31вЖТ  const result1 = createConfirmation('user123', 'stop', { type: 'feature' });\n  32вЖТ  const result2 = createConfirmation('user123', 'reset', {});\n  33вЖТ\n  34вЖТ  assert.notEqual(result1.confirmId, result2.confirmId);\n  35вЖТ});\n  36вЖТ\n  37вЖТtest('createConfirmation uses custom timeout', () => {\n  38вЖТ  clearExpiredConfirmations();\n  39вЖТ  const result = createConfirmation('user123', 'stop', {}, 5000);\n  40вЖТ\n  41вЖТ  assert.ok(result.confirmId);\n  42вЖТ  // Verify by checking it expires after timeout\n  43вЖТ});\n  44вЖТ\n  45вЖТtest('createConfirmation stores userId correctly', () => {\n  46вЖТ  clearExpiredConfirmations();\n  47вЖТ  const result = createConfirmation('user123', 'stop', { type: 'feature' });\n  48вЖТ\n  49вЖТ  const check = checkConfirmation(result.confirmId, 'user123');\n  50вЖТ  assert.equal(check.status, 'pending');\n  51вЖТ});\n  52вЖТ\n  53вЖТ// checkConfirmation tests\n  54вЖТtest('checkConfirmation returns pending for active confirmation', () => {\n  55вЖТ  clearExpiredConfirmations();\n  56вЖТ  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  57вЖТ\n  58вЖТ  const result = checkConfirmation(confirmId, 'user123');\n  59вЖТ\n  60вЖТ  assert.equal(result.status, 'pending');\n  61вЖТ  assert.equal(result.action, 'stop');\n  62вЖТ  assert.deepEqual(result.params, { type: 'feature' });\n  63вЖТ});\n  64вЖТ\n  65вЖТtest('checkConfirmation returns not_found for unknown confirmId', () => {\n  66вЖТ  clearExpiredConfirmations();\n  67вЖТ  const result = checkConfirmation('nonexistent-id', 'user123');\n  68вЖТ\n  69вЖТ  assert.equal(result.status, 'not_found');\n  70вЖТ});\n  71вЖТ\n  72вЖТtest('checkConfirmation returns not_found for wrong userId', () => {\n  73вЖТ  clearExpiredConfirmations();\n  74вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {});\n  75вЖТ\n  76вЖТ  const result = checkConfirmation(confirmId, 'different-user');\n  77вЖТ\n  78вЖТ  assert.equal(result.status, 'not_found');\n  79вЖТ});\n  80вЖТ\n  81вЖТtest('checkConfirmation returns expired after timeout', async () => {\n  82вЖТ  clearExpiredConfirmations();\n  83вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n  84вЖТ\n  85вЖТ  await wait(150);\n  86вЖТ\n  87вЖТ  const result = checkConfirmation(confirmId, 'user123');\n  88вЖТ\n  89вЖТ  assert.equal(result.status, 'expired');\n  90вЖТ});\n  91вЖТ\n  92вЖТ// confirmAction tests\n  93вЖТtest('confirmAction confirms pending action', () => {\n  94вЖТ  clearExpiredConfirmations();\n  95вЖТ  const { confirmId } = createConfirmation('user123', 'stop', { type: 'feature' });\n  96вЖТ\n  97вЖТ  const result = confirmAction(confirmId, 'user123');\n  98вЖТ\n  99вЖТ  assert.equal(result.ok, true);\n 100вЖТ  assert.equal(result.action, 'stop');\n 101вЖТ  assert.deepEqual(result.params, { type: 'feature' });\n 102вЖТ});\n 103вЖТ\n 104вЖТtest('confirmAction fails for wrong userId', () => {\n 105вЖТ  clearExpiredConfirmations();\n 106вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {});\n 107вЖТ\n 108вЖТ  const result = confirmAction(confirmId, 'different-user');\n 109вЖТ\n 110вЖТ  assert.equal(result.ok, false);\n 111вЖТ  assert.ok(result.error);\n 112вЖТ});\n 113вЖТ\n 114вЖТtest('confirmAction fails for unknown confirmId', () => {\n 115вЖТ  clearExpiredConfirmations();\n 116вЖТ  const result = confirmAction('nonexistent-id', 'user123');\n 117вЖТ\n 118вЖТ  assert.equal(result.ok, false);\n 119вЖТ  assert.ok(result.error);\n 120вЖТ});\n 121вЖТ\n 122вЖТtest('confirmAction fails for already confirmed action', () => {\n 123вЖТ  clearExpiredConfirmations();\n 124вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {});\n 125вЖТ\n 126вЖТ  confirmAction(confirmId, 'user123');\n 127вЖТ  const result = confirmAction(confirmId, 'user123');\n 128вЖТ\n 129вЖТ  assert.equal(result.ok, false);\n 130вЖТ  assert.ok(result.error.includes('дЄНе≠ШеЬ®') || result.error.includes('ињЗжЬЯ'));\n 131вЖТ});\n 132вЖТ\n 133вЖТtest('confirmAction fails for expired action', async () => {\n 134вЖТ  clearExpiredConfirmations();\n 135вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {}, 100);\n 136вЖТ\n 137вЖТ  await wait(150);\n 138вЖТ\n 139вЖТ  const result = confirmAction(confirmId, 'user123');\n 140вЖТ\n 141вЖТ  assert.equal(result.ok, false);\n 142вЖТ});\n 143вЖТ\n 144вЖТ// cancelConfirmation tests\n 145вЖТtest('cancelConfirmation cancels pending action', () => {\n 146вЖТ  clearExpiredConfirmations();\n 147вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {});\n 148вЖТ\n 149вЖТ  cancelConfirmation(confirmId, 'user123');\n 150вЖТ\n 151вЖТ  const result = checkConfirmation(confirmId, 'user123');\n 152вЖТ  assert.equal(result.status, 'not_found');\n 153вЖТ});\n 154вЖТ\n 155вЖТtest('cancelConfirmation does nothing for unknown confirmId', () => {\n 156вЖТ  clearExpiredConfirmations();\n 157вЖТ  // Should not throw\n 158вЖТ  cancelConfirmation('nonexistent-id', 'user123');\n 159вЖТ});\n 160вЖТ\n 161вЖТtest('cancelConfirmation does nothing for wrong userId', () => {\n 162вЖТ  clearExpiredConfirmations();\n 163вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {});\n 164вЖТ\n 165вЖТ  cancelConfirmation(confirmId, 'different-user');\n 166вЖТ\n 167вЖТ  const result = checkConfirmation(confirmId, 'user123');\n 168вЖТ  assert.equal(result.status, 'pending');\n 169вЖТ});\n 170вЖТ\n 171вЖТ// clearExpiredConfirmations tests\n 172вЖТtest('clearExpiredConfirmations removes expired confirmations', async () => {\n 173вЖТ  clearExpiredConfirmations();\n 174вЖТ  createConfirmation('user123', 'stop', {}, 100);\n 175вЖТ  createConfirmation('user456', 'reset', {}, 10000);\n 176вЖТ\n 177вЖТ  await wait(150);\n 178вЖТ\n 179вЖТ  clearExpiredConfirmations();\n 180вЖТ\n 181вЖТ  // The expired one should be gone, the active one should remain\n 182вЖТ  const check1 = checkConfirmation(\n 183вЖТ    // We can't check the specific one, but clearExpiredConfirmations should clean up\n 184вЖТ    'any-id',\n 185вЖТ    'user123'\n 186вЖТ  );\n 187вЖТ  assert.equal(check1.status, 'not_found');\n 188вЖТ});\n 189вЖТ\n 190вЖТ// Integration test: full confirmation flow\n 191вЖТtest('full confirmation flow: create, check, confirm', () => {\n 192вЖТ  clearExpiredConfirmations();\n 193вЖТ  // Create\n 194вЖТ  const { confirmId, message } = createConfirmation('user123', 'stop', { type: 'feature' });\n 195вЖТ\n 196вЖТ  assert.ok(confirmId);\n 197вЖТ  assert.ok(message);\n 198вЖТ\n 199вЖТ  // Check\n 200вЖТ  const check1 = checkConfirmation(confirmId, 'user123');\n 201вЖТ  assert.equal(check1.status, 'pending');\n 202вЖТ\n 203вЖТ  // Confirm\n 204вЖТ  const confirm = confirmAction(confirmId, 'user123');\n 205вЖТ  assert.equal(confirm.ok, true);\n 206вЖТ\n 207вЖТ  // Verify confirmed\n 208вЖТ  const check2 = checkConfirmation(confirmId, 'user123');\n 209вЖТ  assert.equal(check2.status, 'not_found'); // Consumed\n 210вЖТ});\n 211вЖТ\n 212вЖТtest('full confirmation flow: create, check, cancel', () => {\n 213вЖТ  clearExpiredConfirmations();\n 214вЖТ  // Create\n 215вЖТ  const { confirmId } = createConfirmation('user123', 'reset', {});\n 216вЖТ\n 217вЖТ  // Check\n 218вЖТ  const check1 = checkConfirmation(confirmId, 'user123');\n 219вЖТ  assert.equal(check1.status, 'pending');\n 220вЖТ\n 221вЖТ  // Cancel\n 222вЖТ  cancelConfirmation(confirmId, 'user123');\n 223вЖТ\n 224вЖТ  // Verify cancelled\n 225вЖТ  const check2 = checkConfirmation(confirmId, 'user123');\n 226вЖТ  assert.equal(check2.status, 'not_found');\n 227вЖТ});\n 228вЖТ\n 229вЖТ// AC-4.3: 60 second timeout default\n 230вЖТtest('default timeout is 60 seconds', () => {\n 231вЖТ  clearExpiredConfirmations();\n 232вЖТ  const { confirmId } = createConfirmation('user123', 'stop', {});\n 233вЖТ\n 234вЖТ  const check = checkConfirmation(confirmId, 'user123');\n 235вЖТ  assert.equal(check.status, 'pending');\n 236вЖТ\n 237вЖТ  // We can't wait 60s in test, but we can verify it exists initially\n 238вЖТ});\n 239вЖТ\n 240вЖТ// AC-4.4: --force flag handling (in handler, not here)\n 241вЖТ// This is tested at the integration level\n 242вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb501d230bfbd675b221fe70d04","__timestamp":"2026-03-11T21:02:55.500Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
