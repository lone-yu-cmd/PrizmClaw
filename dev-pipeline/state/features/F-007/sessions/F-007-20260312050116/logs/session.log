,\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/status-aggregator.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/telegram-pusher.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/pipeline-infra/config-loader.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/log-pager.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/pipeline-controller.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/security/index.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/config.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/security/permission-guard.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/security/param-sanitizer.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/security/confirmation-manager.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/registry.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/index.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/stop.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/audit-log-service.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/plan.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/status.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/logs.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/bugfix.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/planner.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/services/index.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/pipeline.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/telegram.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/audit.js\"]"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb501d230bfbd675b221fe70d04","__timestamp":"2026-03-11T21:02:47.035Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
