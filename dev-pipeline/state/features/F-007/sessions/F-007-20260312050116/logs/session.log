{"type":"assistant","uuid":"202603120508083cffec788b7c467a","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"id":"202603120508083cffec788b7c467a","content":[{"type":"tool_use","id":"call_3dc8f91edc854b03963ab3b1","name":"Write","input":{"content":"/**\n * E2E: Plan Version Flow Tests\n * F-007: Test and Validation Suite\n *\n * Tests the dynamic plan switch integration with pipeline control.\n * Covers T-137.\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport { join, dirname } from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nimport { createTestPipelineDirs, writeTestState, readTestState, createTestPlan } from '../helpers/test-state.js';\nimport { loadJsonFixture, loadFixture } from '../helpers/fixture-loader.js';\nimport { createPlanIngestionService } from '../../src/services/plan-ingestion-service.js';\nimport { resolvePlanListPath } from '../../src/services/pipeline-control-service.js';\n\n// ============================================================\n// Test Setup Helpers\n// ============================================================\n\nconst __dirname = dirname(fileURLToPath(import.meta.url));\nconst PROJECT_ROOT = join(__dirname, '..', '..');\n\n/**\n * Create a test plan ingestion service with temp directory\n */\nasync function createTestPlanService() {\n  const { tempDir, plansDir, cleanup } = await createTestPipelineDirs();\n\n  const service = createPlanIngestionService({ plansDir });\n\n  return {\n    service,\n    plansDir,\n    tempDir,\n    cleanup\n  };\n}\n\n/**\n * Create a valid feature list plan content\n */\nfunction createFeatureListContent(appName = 'TestApp', features = []) {\n  return JSON.stringify({\n    $schema: 'dev-pipeline-feature-list-v1',\n    app_name: appName,\n    app_description: `Test application for ${appName}`,\n    features: features.length > 0 ? features : [\n      {\n        id: 'F-001',\n        title: 'Test Feature',\n        description: 'A test feature',\n        priority: 1,\n        dependencies: [],\n        acceptance_criteria: ['AC1: Test passes'],\n        status: 'pending'\n      }\n    ]\n  });\n}\n\n/**\n * Create a valid bug-fix list plan content\n */\nfunction createBugFixListContent(projectName = 'TestProject', bugs = []) {\n  return JSON.stringify({\n    $schema: 'dev-pipeline-bug-fix-list-v1',\n    project_name: projectName,\n    bugs: bugs.length > 0 ? bugs : [\n      {\n        id: 'B-001',\n        title: 'Test Bug',\n        description: 'A test bug',\n        severity: 'medium',\n        error_source: { type: 'user_report' },\n        verification_type: 'manual',\n        acceptance_criteria: ['AC1: Bug is fixed'],\n        status: 'pending'\n      }\n    ]\n  });\n}\n\n// ============================================================\n// T-137: Plan Version Flow Tests\n// ============================================================\n\ntest('T-137: Upload plan creates new version', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const content = createFeatureListContent('AppV1');\n\n    // Upload (save) the plan\n    const saveResult = await service.save('feature-list', content, { uploadedBy: 12345 });\n\n    assert.equal(saveResult.success, true, 'Save should succeed');\n    assert.ok(saveResult.version, 'Should have version');\n    assert.match(saveResult.version, /^v\\d{8}-\\d{6}$/, 'Version should match format');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: List versions shows all uploaded plans', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload two versions\n    await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await new Promise(r => setTimeout(r, 1100)); // Ensure different timestamp\n    await service.save('feature-list', createFeatureListContent('AppV2'), { uploadedBy: 12345 });\n\n    const versions = await service.listVersions('feature-list');\n\n    assert.equal(versions.length, 2, 'Should have 2 versions');\n    assert.ok(versions[0].version, 'Each version should have id');\n    assert.ok(versions[0].timestamp, 'Each version should have timestamp');\n    assert.ok(versions[0].isValid, 'Versions should be valid');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Switch active version', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload two versions\n    const v1 = await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await new Promise(r => setTimeout(r, 1100));\n    const v2 = await service.save('feature-list', createFeatureListContent('AppV2'), { uploadedBy: 12345 });\n\n    // Set v1 as active\n    const setV1Result = await service.setCurrent('feature-list', v1.version);\n    assert.equal(setV1Result, true, 'Set v1 should succeed');\n\n    let current = await service.getCurrent('feature-list');\n    assert.equal(current.version, v1.version, 'Current should be v1');\n\n    // Switch to v2\n    const setV2Result = await service.setCurrent('feature-list', v2.version);\n    assert.equal(setV2Result, true, 'Set v2 should succeed');\n\n    current = await service.getCurrent('feature-list');\n    assert.equal(current.version, v2.version, 'Current should be v2');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Rollback to previous version', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload and set three versions\n    const v1 = await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', v1.version);\n\n    await new Promise(r => setTimeout(r, 1100));\n    const v2 = await service.save('feature-list', createFeatureListContent('AppV2'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', v2.version);\n\n    await new Promise(r => setTimeout(r, 1100));\n    const v3 = await service.save('feature-list', createFeatureListContent('AppV3'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', v3.version);\n\n    // Verify current is v3\n    let current = await service.getCurrent('feature-list');\n    assert.equal(current.version, v3.version, 'Current should be v3');\n\n    // Rollback\n    const rollbackResult = await service.rollback('feature-list');\n    assert.ok(rollbackResult, 'Rollback should succeed');\n    assert.equal(rollbackResult.previousVersion, v3.version, 'Should roll back from v3');\n    assert.equal(rollbackResult.currentVersion, v2.version, 'Should roll back to v2');\n\n    current = await service.getCurrent('feature-list');\n    assert.equal(current.version, v2.version, 'Current should now be v2');\n\n    // Rollback again\n    const rollbackResult2 = await service.rollback('feature-list');\n    assert.ok(rollbackResult2, 'Second rollback should succeed');\n    assert.equal(rollbackResult2.currentVersion, v1.version, 'Should roll back to v1');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Get active path returns correct file path', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload and set a version\n    const v1 = await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', v1.version);\n\n    const activePath = service.getActivePath('feature-list');\n\n    assert.ok(activePath, 'Should return active path');\n    assert.ok(activePath.includes('feature-list'), 'Path should include feature-list');\n    assert.ok(activePath.includes(v1.version), 'Path should include version');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Resolve plan list path without version returns active path', async (t) => {\n  const { service, plansDir, tempDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload and set a version\n    const v1 = await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', v1.version);\n\n    // Resolve path\n    const resolvedPath = await resolvePlanListPath({\n      planType: 'feature-list',\n      planService: service\n    });\n\n    assert.ok(resolvedPath, 'Should resolve path');\n    assert.ok(resolvedPath.includes('feature-list'), 'Path should include feature-list');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Resolve plan list path with version returns specific version', async (t) => {\n  const { service, plansDir, tempDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload two versions\n    const v1 = await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await new Promise(r => setTimeout(r, 1100));\n    const v2 = await service.save('feature-list', createFeatureListContent('AppV2'), { uploadedBy: 12345 });\n\n    // Resolve path for specific version\n    const resolvedPath = await resolvePlanListPath({\n      planType: 'feature-list',\n      version: v1.version,\n      planService: service\n    });\n\n    assert.ok(resolvedPath, 'Should resolve path');\n    assert.ok(resolvedPath.includes(v1.version), 'Path should include v1 version');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Validate uploaded plan content', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const content = createFeatureListContent('TestApp', [\n      { id: 'F-001', title: 'Feature 1', description: 'D1', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' },\n      { id: 'F-002', title: 'Feature 2', description: 'D2', priority: 2, dependencies: ['F-001'], acceptance_criteria: ['AC'], status: 'pending' }\n    ]);\n\n    const validation = service.validate(content);\n\n    assert.equal(validation.valid, true, 'Validation should pass');\n    assert.equal(validation.type, 'feature-list', 'Should detect feature-list type');\n    assert.ok(validation.summary, 'Should have summary');\n    assert.equal(validation.summary.itemCount, 2, 'Should count 2 features');\n    assert.deepEqual(validation.summary.statusBreakdown, { pending: 2 }, 'Should have status breakdown');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Invalid plan is rejected', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const invalidContent = JSON.stringify({\n      $schema: 'dev-pipeline-feature-list-v1',\n      app_name: 'TestApp',\n      features: [\n        { id: 'INVALID', title: 'Test' } // Missing required fields, invalid ID format\n      ]\n    });\n\n    const validation = service.validate(invalidContent);\n\n    assert.equal(validation.valid, false, 'Validation should fail');\n    assert.ok(validation.errors.length > 0, 'Should have errors');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Feature-list and bug-fix-list are independent', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload feature-list\n    const featureV1 = await service.save('feature-list', createFeatureListContent('FeatureApp'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', featureV1.version);\n\n    // Upload bug-fix-list\n    const bugfixV1 = await service.save('bug-fix-list', createBugFixListContent('BugProject'), { uploadedBy: 12345 });\n    await service.setCurrent('bug-fix-list', bugfixV1.version);\n\n    // Verify independence\n    const featureCurrent = await service.getCurrent('feature-list');\n    const bugfixCurrent = await service.getCurrent('bug-fix-list');\n\n    assert.equal(featureCurrent.version, featureV1.version, 'Feature-list should have its own current');\n    assert.equal(bugfixCurrent.version, bugfixV1.version, 'Bug-fix-list should have its own current');\n\n    // Rollback feature-list shouldn't affect bug-fix-list\n    const featureV2 = await service.save('feature-list', createFeatureListContent('FeatureAppV2'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', featureV2.version);\n    await service.rollback('feature-list');\n\n    const bugfixAfterFeatureRollback = await service.getCurrent('bug-fix-list');\n    assert.equal(bugfixAfterFeatureRollback.version, bugfixV1.version, 'Bug-fix-list should be unchanged');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Version count matches uploads', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload multiple versions\n    for (let i = 0; i < 5; i++) {\n      await service.save('feature-list', createFeatureListContent(`App${i}`), { uploadedBy: 12345 });\n      await new Promise(r => setTimeout(r, 100)); // Small delay for unique timestamps\n    }\n\n    const versions = await service.listVersions('feature-list');\n\n    assert.equal(versions.length, 5, 'Should have 5 versions');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Get version content returns correct data', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const content = createFeatureListContent('SpecificApp');\n    const saveResult = await service.save('feature-list', content, { uploadedBy: 12345 });\n\n    const retrievedContent = await service.getVersion('feature-list', saveResult.version);\n\n    assert.ok(retrievedContent, 'Should retrieve content');\n    const parsed = JSON.parse(retrievedContent);\n    assert.equal(parsed.app_name, 'SpecificApp', 'Should have correct app name');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Get non-existent version returns null', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const result = await service.getVersion('feature-list', 'v99999999-999999');\n\n    assert.equal(result, null, 'Should return null for non-existent version');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Set non-existent version fails', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const result = await service.setCurrent('feature-list', 'v99999999-999999');\n\n    assert.equal(result, false, 'Should fail for non-existent version');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Current returns null when no version set', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const current = await service.getCurrent('feature-list');\n\n    assert.equal(current, null, 'Should return null when no version set');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Active path returns null when no version set', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const path = service.getActivePath('feature-list');\n\n    assert.equal(path, null, 'Should return null when no version set');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Rollback returns null when only one version', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    const v1 = await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await service.setCurrent('feature-list', v1.version);\n\n    const result = await service.rollback('feature-list');\n\n    assert.equal(result, null, 'Should return null when no previous version');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-137: Rollback returns null when no current version set', async (t) => {\n  const { service, plansDir, cleanup } = await createTestPlanService();\n\n  try {\n    // Upload versions but don't set current\n    await service.save('feature-list', createFeatureListContent('AppV1'), { uploadedBy: 12345 });\n    await new Promise(r => setTimeout(r, 1100));\n    await service.save('feature-list', createFeatureListContent('AppV2'), { uploadedBy: 12345 });\n\n    const result = await service.rollback('feature-list');\n\n    assert.equal(result, null, 'Should return null when no current set');\n  } finally {\n    await cleanup();\n  }\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/plan-version-flow.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":75388,"output_tokens":3801,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:09:04.020Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
