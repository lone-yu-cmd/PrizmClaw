{"type":"assistant","uuid":"202603120505569cf7ee220ec54473","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"id":"202603120505569cf7ee220ec54473","content":[{"type":"tool_use","id":"call_5a92c8214cc7417b870d6ea4","name":"Write","input":{"content":"/**\n * E2E: Main Chain Tests (start вЖТ status вЖТ stop)\n * F-007: Test and Validation Suite\n *\n * Tests the primary user flow for pipeline control.\n * Covers T-121, T-122, T-123, T-124.\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport { join } from 'node:path';\n\nimport { createMockRunner, createStatefulMockRunner } from '../helpers/mock-runner.js';\nimport { createTestPipelineDirs, writeTestState, readTestState } from '../helpers/test-state.js';\nimport { loadJsonFixture } from '../helpers/fixture-loader.js';\nimport { createPipelineController } from '../../src/services/pipeline-controller.js';\nimport { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\nimport { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n\n// ============================================================\n// Test Setup Helpers\n// ============================================================\n\n/**\n * Create a test controller with mock dependencies\n */\nasync function createTestController(options = {}) {\n  const { tempDir, stateDir, bugfixStateDir, plansDir, cleanup } = await createTestPipelineDirs();\n\n  const config = {\n    projectRoot: tempDir,\n    stateDir,\n    bugfixStateDir\n  };\n\n  const lockManager = createLockManager({ config });\n  const stateManager = createStateManager({ config });\n\n  const controller = createPipelineController({\n    lockManager,\n    stateManager,\n    scriptRunner: options.scriptRunner || createMockRunner(),\n    config\n  });\n\n  return {\n    controller,\n    lockManager,\n    stateManager,\n    config,\n    tempDir,\n    stateDir,\n    plansDir,\n    cleanup\n  };\n}\n\n// ============================================================\n// T-121: E2E Main Chain (start вЖТ status вЖТ stop)\n// ============================================================\n\ntest('T-121: E2E main chain - start вЖТ status вЖТ stop', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    // Step 1: Start pipeline\n    const startResult = await controller.startPipeline({ type: 'feature' });\n    assert.equal(startResult.ok, true, 'Start should succeed');\n    assert.ok(startResult.runId, 'Start should return runId');\n    assert.ok(startResult.message, 'Start should return message');\n\n    // Step 2: Check status (should be running)\n    const statusResult = await controller.getStatus({ type: 'feature' });\n    assert.equal(statusResult.ok, true, 'Status check should succeed');\n    assert.equal(statusResult.isRunning, true, 'Pipeline should be running after start');\n\n    // Step 3: Stop pipeline\n    const stopResult = await controller.stopPipeline({ type: 'feature' });\n    assert.equal(stopResult.ok, true, 'Stop should succeed');\n    assert.ok(stopResult.message, 'Stop should return message');\n\n    // Step 4: Check status (should not be running)\n    const finalStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(finalStatus.ok, true, 'Final status check should succeed');\n    assert.equal(finalStatus.isRunning, false, 'Pipeline should not be running after stop');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-121: E2E main chain with stateful mock runner', async (t) => {\n  const statefulRunner = createStatefulMockRunner();\n  const { controller, cleanup } = await createTestController({\n    scriptRunner: statefulRunner\n  });\n\n  try {\n    // Initial state check\n    const initialState = statefulRunner.getState();\n    assert.equal(initialState.isRunning, false, 'Should start in idle state');\n\n    // Start pipeline\n    const startResult = await controller.startPipeline({ type: 'feature' });\n    assert.equal(startResult.ok, true, 'Start should succeed');\n\n    // Check mock runner state changed\n    const runningState = statefulRunner.getState();\n    assert.equal(runningState.isRunning, true, 'Mock runner should track running state');\n\n    // Stop pipeline\n    const stopResult = await controller.stopPipeline({ type: 'feature' });\n    assert.equal(stopResult.ok, true, 'Stop should succeed');\n\n    // Check mock runner state changed back\n    const stoppedState = statefulRunner.getState();\n    assert.equal(stoppedState.isRunning, false, 'Mock runner should track stopped state');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-121: E2E main chain with targetId', async (t) => {\n  let capturedTargetId = null;\n  const trackingRunner = async (req) => {\n    capturedTargetId = req.targetId;\n    return {\n      ok: true,\n      exitCode: 0,\n      stdout: `Running target: ${req.targetId}`,\n      stderr: '',\n      normalizedStatus: 'success'\n    };\n  };\n\n  const { controller, cleanup } = await createTestController({\n    scriptRunner: trackingRunner\n  });\n\n  try {\n    const result = await controller.startPipeline({\n      type: 'feature',\n      targetId: 'F-001'\n    });\n\n    assert.equal(result.ok, true, 'Start with targetId should succeed');\n    assert.equal(capturedTargetId, 'F-001', 'TargetId should be passed to runner');\n  } finally {\n    await cleanup();\n  }\n});\n\n// ============================================================\n// T-122: Duplicate Start Prevention\n// ============================================================\n\ntest('T-122: Duplicate start prevention - second start should fail', async (t) => {\n  const { controller, lockManager, cleanup } = await createTestController();\n\n  try {\n    // First start\n    const firstStart = await controller.startPipeline({ type: 'feature' });\n    assert.equal(firstStart.ok, true, 'First start should succeed');\n\n    // Verify lock is held\n    const isLocked = await lockManager.isLocked('feature');\n    assert.equal(isLocked, true, 'Lock should be held after start');\n\n    // Second start attempt (should fail due to lock)\n    const secondStart = await controller.startPipeline({ type: 'feature' });\n    assert.equal(secondStart.ok, false, 'Second start should fail');\n    assert.equal(secondStart.errorCode, 'LOCK_ACQUISITION_FAILED', 'Should have lock error');\n    assert.ok(secondStart.hint, 'Error should include hint');\n    assert.ok(secondStart.context, 'Error should include context');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-122: Duplicate start prevention with stateful mock', async (t) => {\n  const statefulRunner = createStatefulMockRunner({ startRunning: true });\n  const { controller, cleanup } = await createTestController({\n    scriptRunner: statefulRunner\n  });\n\n  try {\n    // Mock runner already reports running, but we can still try start\n    // The controller should handle the LOCK_ACQUISITION_FAILED first\n    // (lock is checked before script execution)\n\n    // First acquire the lock manually to simulate running\n    await controller._acquireLock('feature');\n\n    // Now try to start\n    const result = await controller.startPipeline({ type: 'feature' });\n    assert.equal(result.ok, false, 'Start should fail when lock is held');\n    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED', 'Should have lock error');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-122: Start after stop should succeed', async (t) => {\n  const statefulRunner = createStatefulMockRunner();\n  const { controller, cleanup } = await createTestController({\n    scriptRunner: statefulRunner\n  });\n\n  try {\n    // First cycle\n    await controller.startPipeline({ type: 'feature' });\n    await controller.stopPipeline({ type: 'feature' });\n\n    // Second start should work\n    const secondStart = await controller.startPipeline({ type: 'feature' });\n    assert.equal(secondStart.ok, true, 'Start after stop should succeed');\n    assert.ok(secondStart.runId, 'Should have new runId');\n  } finally {\n    await cleanup();\n  }\n});\n\n// ============================================================\n// T-123: Stop When Not Running\n// ============================================================\n\ntest('T-123: Stop when not running should return ALREADY_STOPPED', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    // Stop without starting\n    const result = await controller.stopPipeline({ type: 'feature' });\n\n    assert.equal(result.ok, true, 'Stop should return ok:true for idempotency');\n    assert.equal(result.errorCode, 'ALREADY_STOPPED', 'Should indicate already stopped');\n    assert.ok(result.message, 'Should have message');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-123: Stop when not running should not throw', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    // Multiple stops should all be safe\n    const stop1 = await controller.stopPipeline({ type: 'feature' });\n    const stop2 = await controller.stopPipeline({ type: 'feature' });\n    const stop3 = await controller.stopPipeline({ type: 'feature' });\n\n    assert.equal(stop1.ok, true, 'First stop should be ok');\n    assert.equal(stop2.ok, true, 'Second stop should be ok');\n    assert.equal(stop3.ok, true, 'Third stop should be ok');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-123: Stop when not running for bugfix type', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    const result = await controller.stopPipeline({ type: 'bugfix' });\n\n    assert.equal(result.ok, true, 'Stop bugfix when not running should be ok');\n    assert.equal(result.errorCode, 'ALREADY_STOPPED', 'Should indicate already stopped');\n  } finally {\n    await cleanup();\n  }\n});\n\n// ============================================================\n// T-124: State Transitions Verification\n// ============================================================\n\ntest('T-124: State transitions - idle вЖТ running вЖТ stopped вЖТ idle', async (t) => {\n  const statefulRunner = createStatefulMockRunner();\n  const { controller, stateManager, cleanup } = await createTestController({\n    scriptRunner: statefulRunner\n  });\n\n  try {\n    // Initial: idle\n    const initialStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(initialStatus.isRunning, false, 'Should start in idle state');\n\n    // Transition: idle вЖТ running\n    const startResult = await controller.startPipeline({ type: 'feature' });\n    assert.equal(startResult.ok, true, 'Start should succeed');\n\n    const runningStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(runningStatus.isRunning, true, 'Should be running after start');\n\n    // Transition: running вЖТ stopped\n    const stopResult = await controller.stopPipeline({ type: 'feature' });\n    assert.equal(stopResult.ok, true, 'Stop should succeed');\n\n    const stoppedStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(stoppedStatus.isRunning, false, 'Should be stopped after stop');\n\n    // Back to idle (ready for new start)\n    const restartResult = await controller.startPipeline({ type: 'feature' });\n    assert.equal(restartResult.ok, true, 'Restart should succeed after stop');\n\n    const restartedStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(restartedStatus.isRunning, true, 'Should be running after restart');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-124: State transitions with status details', async (t) => {\n  const statefulRunner = createStatefulMockRunner();\n  const { controller, cleanup } = await createTestController({\n    scriptRunner: statefulRunner\n  });\n\n  try {\n    // Start pipeline\n    await controller.startPipeline({ type: 'feature' });\n\n    // Check running status details\n    const runningStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(runningStatus.ok, true, 'Status should be ok');\n    assert.equal(runningStatus.isRunning, true, 'Should be running');\n    assert.ok(runningStatus.message, 'Should have message');\n\n    // Stop pipeline\n    await controller.stopPipeline({ type: 'feature' });\n\n    // Check stopped status details\n    const stoppedStatus = await controller.getStatus({ type: 'feature' });\n    assert.equal(stoppedStatus.ok, true, 'Status should be ok');\n    assert.equal(stoppedStatus.isRunning, false, 'Should not be running');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-124: State transitions with bugfix type', async (t) => {\n  const statefulRunner = createStatefulMockRunner();\n  const { controller, cleanup } = await createTestController({\n    scriptRunner: statefulRunner\n  });\n\n  try {\n    // Bugfix pipeline cycle\n    const startResult = await controller.startPipeline({ type: 'bugfix' });\n    assert.equal(startResult.ok, true, 'Bugfix start should succeed');\n\n    const runningStatus = await controller.getStatus({ type: 'bugfix' });\n    assert.equal(runningStatus.isRunning, true, 'Bugfix should be running');\n\n    const stopResult = await controller.stopPipeline({ type: 'bugfix' });\n    assert.equal(stopResult.ok, true, 'Bugfix stop should succeed');\n\n    const stoppedStatus = await controller.getStatus({ type: 'bugfix' });\n    assert.equal(stoppedStatus.isRunning, false, 'Bugfix should be stopped');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-124: Parallel feature and bugfix pipelines are independent', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    // Start feature pipeline\n    const featureStart = await controller.startPipeline({ type: 'feature' });\n    assert.equal(featureStart.ok, true, 'Feature start should succeed');\n\n    // Start bugfix pipeline (should also succeed, different lock)\n    const bugfixStart = await controller.startPipeline({ type: 'bugfix' });\n    assert.equal(bugfixStart.ok, true, 'Bugfix start should succeed');\n\n    // Both should show as running\n    const featureStatus = await controller.getStatus({ type: 'feature' });\n    const bugfixStatus = await controller.getStatus({ type: 'bugfix' });\n\n    assert.equal(featureStatus.isRunning, true, 'Feature should be running');\n    assert.equal(bugfixStatus.isRunning, true, 'Bugfix should be running');\n\n    // Stop both\n    await controller.stopPipeline({ type: 'feature' });\n    await controller.stopPipeline({ type: 'bugfix' });\n\n    // Both should show as stopped\n    const finalFeatureStatus = await controller.getStatus({ type: 'feature' });\n    const finalBugfixStatus = await controller.getStatus({ type: 'bugfix' });\n\n    assert.equal(finalFeatureStatus.isRunning, false, 'Feature should be stopped');\n    assert.equal(finalBugfixStatus.isRunning, false, 'Bugfix should be stopped');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('T-124: Lock is properly released after stop', async (t) => {\n  const { controller, lockManager, cleanup } = await createTestController();\n\n  try {\n    // Start (acquires lock)\n    await controller.startPipeline({ type: 'feature' });\n    assert.equal(await lockManager.isLocked('feature'), true, 'Lock should be held');\n\n    // Stop (releases lock)\n    await controller.stopPipeline({ type: 'feature' });\n    assert.equal(await lockManager.isLocked('feature'), false, 'Lock should be released');\n\n    // Can start again (acquires lock again)\n    await controller.startPipeline({ type: 'feature' });\n    assert.equal(await lockManager.isLocked('feature'), true, 'Lock should be held again');\n\n    // Cleanup\n    await controller.stopPipeline({ type: 'feature' });\n  } finally {\n    await cleanup();\n  }\n});\n\n// ============================================================\n// Additional E2E Scenarios\n// ============================================================\n\ntest('E2E: Error recovery - force unlock allows restart', async (t) => {\n  const { controller, lockManager, cleanup } = await createTestController();\n\n  try {\n    // Start pipeline\n    await controller.startPipeline({ type: 'feature' });\n\n    // Simulate stale lock (manual force unlock)\n    const unlockResult = await controller.forceUnlock({ type: 'feature' });\n    assert.equal(unlockResult.ok, true, 'Force unlock should succeed');\n\n    // Should be able to start again\n    const restartResult = await controller.startPipeline({ type: 'feature' });\n    assert.equal(restartResult.ok, true, 'Should be able to restart after force unlock');\n\n    // Cleanup\n    await controller.stopPipeline({ type: 'feature' });\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('E2E: getStatus returns consistent structure', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    const status = await controller.getStatus({ type: 'feature' });\n\n    // Verify consistent response structure\n    assert.equal(typeof status.ok, 'boolean', 'Should have ok:boolean');\n    assert.equal(typeof status.isRunning, 'boolean', 'Should have isRunning:boolean');\n    assert.equal(typeof status.message, 'string', 'Should have message:string');\n  } finally {\n    await cleanup();\n  }\n});\n\ntest('E2E: startPipeline returns consistent structure', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    const result = await controller.startPipeline({ type: 'feature' });\n\n    // Verify consistent response structure\n    assert.equal(typeof result.ok, 'boolean', 'Should have ok:boolean');\n    assert.equal(typeof result.message, 'string', 'Should have message:string');\n    assert.ok(result.runId, 'Should have runId');\n  } finally {\n    await controller.stopPipeline({ type: 'feature' });\n    await cleanup();\n  }\n});\n\ntest('E2E: stopPipeline returns consistent structure', async (t) => {\n  const { controller, cleanup } = await createTestController();\n\n  try {\n    await controller.startPipeline({ type: 'feature' });\n    const result = await controller.stopPipeline({ type: 'feature' });\n\n    // Verify consistent response structure\n    assert.equal(typeof result.ok, 'boolean', 'Should have ok:boolean');\n    assert.equal(typeof result.message, 'string', 'Should have message:string');\n  } finally {\n    await cleanup();\n  }\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/e2e-main-chain.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":64828,"output_tokens":4047,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:06:53.734Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
