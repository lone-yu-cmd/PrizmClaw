{"type":"user","uuid":"e79c711f-1fc3-475b-81a9-886fdda33dad","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"019cdebc6d825fea7a987eca13a7525e","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Tests for test helpers\n   3вЖТ * F-007: Test and Validation Suite\n   4вЖТ *\n   5вЖТ * Verifies that all test helper modules work correctly.\n   6вЖТ */\n   7вЖТ\n   8вЖТimport test from 'node:test';\n   9вЖТimport assert from 'node:assert/strict';\n  10вЖТimport { join } from 'node:path';\n  11вЖТ\n  12вЖТ// Import all helpers at module level\n  13вЖТimport {\n  14вЖТ  getFixturePath,\n  15вЖТ  loadFixture,\n  16вЖТ  loadJsonFixture,\n  17вЖТ  fixtureExists\n  18вЖТ} from './fixture-loader.js';\n  19вЖТ\n  20вЖТimport {\n  21вЖТ  createMockRunner,\n  22вЖТ  createStatefulMockRunner\n  23вЖТ} from './mock-runner.js';\n  24вЖТ\n  25вЖТimport {\n  26вЖТ  createMockContext,\n  27вЖТ  createAdminContext,\n  28вЖТ  createOperatorContext,\n  29вЖТ  createViewerContext,\n  30вЖТ  createDocumentContext,\n  31вЖТ  createCommandContext\n  32вЖТ} from './mock-telegram.js';\n  33вЖТ\n  34вЖТimport {\n  35вЖТ  createTestStateDir,\n  36вЖТ  createTestPipelineDirs,\n  37вЖТ  writeTestState,\n  38вЖТ  readTestState,\n  39вЖТ  createTestPlan\n  40вЖТ} from './test-state.js';\n  41вЖТ\n  42вЖТ// ============================================================\n  43вЖТ// Fixture Loader Tests\n  44вЖТ// ============================================================\n  45вЖТ\n  46вЖТtest('fixture-loader: getFixturePath returns correct path', () => {\n  47вЖТ  const path = getFixturePath('plans/valid-feature-list.json');\n  48вЖТ  assert.ok(path.includes('fixtures'));\n  49вЖТ  assert.ok(path.includes('plans'));\n  50вЖТ  assert.ok(path.includes('valid-feature-list.json'));\n  51вЖТ});\n  52вЖТ\n  53вЖТtest('fixture-loader: loadFixture loads file content', () => {\n  54вЖТ  const content = loadFixture('plans/valid-feature-list.json');\n  55вЖТ  assert.ok(content.includes('$schema'));\n  56вЖТ  assert.ok(content.includes('TestApp'));\n  57вЖТ});\n  58вЖТ\n  59вЖТtest('fixture-loader: loadFixture throws for non-existent file', () => {\n  60вЖТ  assert.throws(\n  61вЖТ    () => loadFixture('non-existent-file.json'),\n  62вЖТ    /Fixture not found/\n  63вЖТ  );\n  64вЖТ});\n  65вЖТ\n  66вЖТtest('fixture-loader: loadJsonFixture parses JSON correctly', () => {\n  67вЖТ  const data = loadJsonFixture('plans/valid-feature-list.json');\n  68вЖТ  assert.equal(data.$schema, 'dev-pipeline-feature-list-v1');\n  69вЖТ  assert.equal(data.app_name, 'TestApp');\n  70вЖТ  assert.ok(Array.isArray(data.features));\n  71вЖТ});\n  72вЖТ\n  73вЖТtest('fixture-loader: loadJsonFixture throws for invalid JSON', () => {\n  74вЖТ  assert.throws(\n  75вЖТ    () => loadJsonFixture('plans/invalid-bad-json.json'),\n  76вЖТ    /Invalid JSON/\n  77вЖТ  );\n  78вЖТ});\n  79вЖТ\n  80вЖТtest('fixture-loader: fixtureExists returns true for existing fixture', () => {\n  81вЖТ  assert.equal(fixtureExists('plans/valid-feature-list.json'), true);\n  82вЖТ});\n  83вЖТ\n  84вЖТtest('fixture-loader: fixtureExists returns false for non-existing fixture', () => {\n  85вЖТ  assert.equal(fixtureExists('non-existent.json'), false);\n  86вЖТ});\n  87вЖТ\n  88вЖТ// ============================================================\n  89вЖТ// Mock Runner Tests\n  90вЖТ// ============================================================\n  91вЖТ\n  92вЖТtest('mock-runner: createMockRunner returns function', () => {\n  93вЖТ  const runner = createMockRunner();\n  94вЖТ  assert.equal(typeof runner, 'function');\n  95вЖТ});\n  96вЖТ\n  97вЖТtest('mock-runner: returns default response for unmocked action', async () => {\n  98вЖТ  const runner = createMockRunner();\n  99вЖТ  const result = await runner({ action: 'unknown' });\n 100вЖТ\n 101вЖТ  assert.equal(result.ok, true);\n 102вЖТ  assert.equal(result.normalizedStatus, 'success');\n 103вЖТ});\n 104вЖТ\n 105вЖТtest('mock-runner: returns configured response', async () => {\n 106вЖТ  const runner = createMockRunner({\n 107вЖТ    run: { ok: true, pid: 12345, runId: 'run-001' }\n 108вЖТ  });\n 109вЖТ\n 110вЖТ  const result = await runner({ action: 'run' });\n 111вЖТ  assert.equal(result.ok, true);\n 112вЖТ  assert.equal(result.pid, 12345);\n 113вЖТ  assert.equal(result.runId, 'run-001');\n 114вЖТ});\n 115вЖТ\n 116вЖТtest('mock-runner: supports response sequencing', async () => {\n 117вЖТ  const runner = createMockRunner({\n 118вЖТ    status: [\n 119вЖТ      { ok: true, isRunning: true },\n 120вЖТ      { ok: true, isRunning: false }\n 121вЖТ    ]\n 122вЖТ  });\n 123вЖТ\n 124вЖТ  const result1 = await runner({ action: 'status' });\n 125вЖТ  assert.equal(result1.isRunning, true);\n 126вЖТ\n 127вЖТ  const result2 = await runner({ action: 'status' });\n 128вЖТ  assert.equal(result2.isRunning, false);\n 129вЖТ});\n 130вЖТ\n 131вЖТtest('mock-runner: callLog tracks calls', async () => {\n 132вЖТ  const runner = createMockRunner();\n 133вЖТ  await runner({ action: 'run', targetId: 'F-001' });\n 134вЖТ  await runner({ action: 'status' });\n 135вЖТ\n 136вЖТ  const log = runner.getCallLog();\n 137вЖТ  assert.equal(log.length, 2);\n 138вЖТ  assert.equal(log[0].action, 'run');\n 139вЖТ  assert.equal(log[0].params.targetId, 'F-001');\n 140вЖТ});\n 141вЖТ\n 142вЖТtest('mock-runner: getCalls filters by action', async () => {\n 143вЖТ  const runner = createMockRunner();\n 144вЖТ  await runner({ action: 'run' });\n 145вЖТ  await runner({ action: 'status' });\n 146вЖТ  await runner({ action: 'run' });\n 147вЖТ\n 148вЖТ  const runCalls = runner.getCalls('run');\n 149вЖТ  assert.equal(runCalls.length, 2);\n 150вЖТ});\n 151вЖТ\n 152вЖТtest('mock-runner: addResponse adds new response', async () => {\n 153вЖТ  const runner = createMockRunner();\n 154вЖТ  runner.addResponse('run', { ok: true, pid: 999 });\n 155вЖТ\n 156вЖТ  const result = await runner({ action: 'run' });\n 157вЖТ  assert.equal(result.pid, 999);\n 158вЖТ});\n 159вЖТ\n 160вЖТtest('mock-runner: createStatefulMockRunner tracks state', async () => {\n 161вЖТ  const runner = createStatefulMockRunner();\n 162вЖТ  let state = runner.getState();\n 163вЖТ  assert.equal(state.isRunning, false);\n 164вЖТ\n 165вЖТ  await runner({ action: 'run' });\n 166вЖТ  state = runner.getState();\n 167вЖТ  assert.equal(state.isRunning, true);\n 168вЖТ\n 169вЖТ  await runner({ action: 'stop' });\n 170вЖТ  state = runner.getState();\n 171вЖТ  assert.equal(state.isRunning, false);\n 172вЖТ});\n 173вЖТ\n 174вЖТtest('mock-runner: createStatefulMockRunner prevents duplicate start', async () => {\n 175вЖТ  const runner = createStatefulMockRunner({ startRunning: true });\n 176вЖТ  const result = await runner({ action: 'run' });\n 177вЖТ\n 178вЖТ  assert.equal(result.ok, false);\n 179вЖТ  assert.equal(result.errorCode, 'ALREADY_RUNNING');\n 180вЖТ});\n 181вЖТ\n 182вЖТ// ============================================================\n 183вЖТ// Mock Telegram Tests\n 184вЖТ// ============================================================\n 185вЖТ\n 186вЖТtest('mock-telegram: createMockContext creates context', () => {\n 187вЖТ  const ctx = createMockContext();\n 188вЖТ  assert.ok(ctx.message);\n 189вЖТ  assert.ok(ctx.chat);\n 190вЖТ  assert.ok(ctx.from);\n 191вЖТ  assert.equal(typeof ctx.reply, 'function');\n 192вЖТ});\n 193вЖТ\n 194вЖТtest('mock-telegram: createMockContext applies overrides', () => {\n 195вЖТ  const ctx = createMockContext({\n 196вЖТ    message: { text: '/start' }\n 197вЖТ  });\n 198вЖТ\n 199вЖТ  assert.equal(ctx.message.text, '/start');\n 200вЖТ});\n 201вЖТ\n 202вЖТtest('mock-telegram: reply captures messages', async () => {\n 203вЖТ  const ctx = createMockContext();\n 204вЖТ  await ctx.reply('Hello');\n 205вЖТ  await ctx.reply('World');\n 206вЖТ\n 207вЖТ  const replies = ctx._getReplies();\n 208вЖТ  assert.equal(replies.length, 2);\n 209вЖТ  assert.equal(replies[0].text, 'Hello');\n 210вЖТ  assert.equal(replies[1].text, 'World');\n 211вЖТ});\n 212вЖТ\n 213вЖТtest('mock-telegram: _getLastReply returns last reply', async () => {\n 214вЖТ  const ctx = createMockContext();\n 215вЖТ  await ctx.reply('First');\n 216вЖТ  await ctx.reply('Last');\n 217вЖТ\n 218вЖТ  const last = ctx._getLastReply();\n 219вЖТ  assert.equal(last.text, 'Last');\n 220вЖТ});\n 221вЖТ\n 222вЖТtest('mock-telegram: createAdminContext sets admin permission', () => {\n 223вЖТ  const ctx = createAdminContext();\n 224вЖТ  assert.equal(ctx.state.permission, 'admin');\n 225вЖТ});\n 226вЖТ\n 227вЖТtest('mock-telegram: createOperatorContext sets operator permission', () => {\n 228вЖТ  const ctx = createOperatorContext();\n 229вЖТ  assert.equal(ctx.state.permission, 'operator');\n 230вЖТ});\n 231вЖТ\n 232вЖТtest('mock-telegram: createViewerContext sets viewer permission', () => {\n 233вЖТ  const ctx = createViewerContext();\n 234вЖТ  assert.equal(ctx.state.permission, 'viewer');\n 235вЖТ});\n 236вЖТ\n 237вЖТtest('mock-telegram: createDocumentContext creates document message', () => {\n 238вЖТ  const ctx = createDocumentContext({\n 239вЖТ    file_name: 'test-plan.json',\n 240вЖТ    file_size: 2048\n 241вЖТ  });\n 242вЖТ\n 243вЖТ  assert.ok(ctx.message.document);\n 244вЖТ  assert.equal(ctx.message.document.file_name, 'test-plan.json');\n 245вЖТ  assert.equal(ctx.message.document.file_size, 2048);\n 246вЖТ});\n 247вЖТ\n 248вЖТtest('mock-telegram: createCommandContext creates command message', () => {\n 249вЖТ  const ctx = createCommandContext('/pipeline run --type=feature');\n 250вЖТ  assert.equal(ctx.message.text, '/pipeline run --type=feature');\n 251вЖТ});\n 252вЖТ\n 253вЖТ// ============================================================\n 254вЖТ// Test State Tests\n 255вЖТ// ============================================================\n 256вЖТ\n 257вЖТtest('test-state: createTestStateDir creates directory', async () => {\n 258вЖТ  const { path, cleanup } = await createTestStateDir();\n 259вЖТ  assert.ok(path);\n 260вЖТ\n 261вЖТ  await cleanup();\n 262вЖТ});\n 263вЖТ\n 264вЖТtest('test-state: createTestPipelineDirs creates full structure', async () => {\n 265вЖТ  const { tempDir, stateDir, bugfixStateDir, plansDir, cleanup } = await createTestPipelineDirs();\n 266вЖТ\n 267вЖТ  assert.ok(tempDir);\n 268вЖТ  assert.ok(stateDir);\n 269вЖТ  assert.ok(bugfixStateDir);\n 270вЖТ  assert.ok(plansDir);\n 271вЖТ\n 272вЖТ  await cleanup();\n 273вЖТ});\n 274вЖТ\n 275вЖТtest('test-state: writeTestState and readTestState work together', async () => {\n 276вЖТ  const { path, cleanup } = await createTestStateDir();\n 277вЖТ\n 278вЖТ  const testData = { foo: 'bar', nested: { value: 42 } };\n 279вЖТ  const filePath = join(path, 'test.json');\n 280вЖТ\n 281вЖТ  await writeTestState(filePath, testData);\n 282вЖТ  const loaded = await readTestState(filePath);\n 283вЖТ\n 284вЖТ  assert.deepEqual(loaded, testData);\n 285вЖТ\n 286вЖТ  await cleanup();\n 287вЖТ});\n 288вЖТ\n 289вЖТtest('test-state: readTestState returns null for non-existent file', async () => {\n 290вЖТ  const result = await readTestState('/non/existent/path.json');\n 291вЖТ  assert.equal(result, null);\n 292вЖТ});\n 293вЖТ\n 294вЖТtest('test-state: createTestPlan creates plan file', async () => {\n 295вЖТ  const { plansDir, cleanup } = await createTestPipelineDirs();\n 296вЖТ\n 297вЖТ  const planContent = {\n 298вЖТ    $schema: 'dev-pipeline-feature-list-v1',\n 299вЖТ    app_name: 'TestApp',\n 300вЖТ    features: []\n 301вЖТ  };\n 302вЖТ\n 303вЖТ  const planPath = await createTestPlan(plansDir, 'feature-list', planContent);\n 304вЖТ  const loaded = await readTestState(planPath);\n 305вЖТ\n 306вЖТ  assert.equal(loaded.app_name, 'TestApp');\n 307вЖТ\n 308вЖТ  await cleanup();\n 309вЖТ});\n 310вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebbe129071f3187ba256d7076c9","__timestamp":"2026-03-11T21:10:17.992Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
