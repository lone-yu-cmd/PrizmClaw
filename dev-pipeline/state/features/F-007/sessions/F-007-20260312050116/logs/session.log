{"type":"user","uuid":"3661c641-86c0-49b8-826e-0810c15c9e41","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"call_79710c7dfc244d0882e2c5bd","content":[{"type":"text","text":"   1вЖТimport fs from 'node:fs';\n   2вЖТimport { EventEmitter } from 'node:events';\n   3вЖТimport { createLockManager, getDefaultLockManager } from '../pipeline-infra/lock-manager.js';\n   4вЖТimport { createStateManager, getDefaultStateManager } from '../pipeline-infra/state-manager.js';\n   5вЖТimport { executePipelineCommand, buildPipelineCommand } from '../pipeline-infra/script-runner.js';\n   6вЖТimport { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   7вЖТimport { resolveDaemonLogPaths } from '../pipeline-infra/path-policy.js';\n   8вЖТimport { INFRA_ERROR_CODES } from '../pipeline-infra/error-codes.js';\n   9вЖТ\n  10вЖТconst DEFAULT_LOG_LINES = 100;\n  11вЖТconst DEFAULT_STOP_TIMEOUT_MS = 10000;\n  12вЖТ\n  13вЖТ/**\n  14вЖТ * Build an error result object.\n  15вЖТ * @param {string} errorCode - Error code\n  16вЖТ * @param {string} message - Error message\n  17вЖТ * @param {Object} [options] - Additional options\n  18вЖТ * @param {string} [options.hint] - Hint for resolving the error\n  19вЖТ * @param {Object} [options.context] - Additional context\n  20вЖТ * @returns {Object} Error result\n  21вЖТ */\n  22вЖТfunction buildError(errorCode, message, options = {}) {\n  23вЖТ  return {\n  24вЖТ    ok: false,\n  25вЖТ    errorCode,\n  26вЖТ    message,\n  27вЖТ    ...(options.hint ? { hint: options.hint } : {}),\n  28вЖТ    ...(options.context ? { context: options.context } : {})\n  29вЖТ  };\n  30вЖТ}\n  31вЖТ\n  32вЖТ/**\n  33вЖТ * Build a success result object.\n  34вЖТ * @param {string} message - Success message\n  35вЖТ * @param {Object} [extra] - Additional fields\n  36вЖТ * @returns {Object} Success result\n  37вЖТ */\n  38вЖТfunction buildResult(message, extra = {}) {\n  39вЖТ  return {\n  40вЖТ    ok: true,\n  41вЖТ    message,\n  42вЖТ    ...extra\n  43вЖТ  };\n  44вЖТ}\n  45вЖТ\n  46вЖТ/**\n  47вЖТ * Generate a unique run ID.\n  48вЖТ * @returns {string} Run ID\n  49вЖТ */\n  50вЖТfunction generateRunId() {\n  51вЖТ  const now = new Date();\n  52вЖТ  const timestamp = now.toISOString().replace(/[-:T]/g, '').slice(0, 15);\n  53вЖТ  return `run-${timestamp}`;\n  54вЖТ}\n  55вЖТ\n  56вЖТ/**\n  57вЖТ * Read last N lines from a file.\n  58вЖТ * @param {string} filePath - Path to file\n  59вЖТ * @param {number} lines - Number of lines to read\n  60вЖТ * @returns {string} File content\n  61вЖТ */\n  62вЖТfunction readLastLines(filePath, lines) {\n  63вЖТ  try {\n  64вЖТ    const content = fs.readFileSync(filePath, 'utf8');\n  65вЖТ    const allLines = content.split('\\n');\n  66вЖТ    const selectedLines = allLines.slice(-lines);\n  67вЖТ    return selectedLines.join('\\n');\n  68вЖТ  } catch {\n  69вЖТ    return '';\n  70вЖТ  }\n  71вЖТ}\n  72вЖТ\n  73вЖТ/**\n  74вЖТ * Create a pipeline controller instance.\n  75вЖТ * @param {Object} options - Options\n  76вЖТ * @param {Object} [options.lockManager] - Lock manager instance\n  77вЖТ * @param {Object} [options.stateManager] - State manager instance\n  78вЖТ * @param {Function} [options.scriptRunner] - Script runner function\n  79вЖТ * @param {Object} [options.config] - Pipeline config\n  80вЖТ * @returns {Object} Pipeline controller interface\n  81вЖТ */\n  82вЖТexport function createPipelineController(options = {}) {\n  83вЖТ  const lockManager = options.lockManager || getDefaultLockManager();\n  84вЖТ  const stateManager = options.stateManager || getDefaultStateManager();\n  85вЖТ  const scriptRunner = options.scriptRunner || executePipelineCommand;\n  86вЖТ  const config = options.config || loadPipelineInfraConfig();\n  87вЖТ\n  88вЖТ  // F-005: Lifecycle event emitter for heartbeat and notifications\n  89вЖТ  const eventEmitter = new EventEmitter();\n  90вЖТ\n  91вЖТ  /**\n  92вЖТ   * Internal: Acquire lock and return result.\n  93вЖТ   * @param {string} type - Pipeline type\n  94вЖТ   * @returns {Promise<Object|null>} Lock result or null on success\n  95вЖТ   */\n  96вЖТ  async function _acquireLock(type) {\n  97вЖТ    const lockResult = await lockManager.acquireLock(type);\n  98вЖТ    if (!lockResult.ok) {\n  99вЖТ      return buildError(\n 100вЖТ        INFRA_ERROR_CODES.LOCK_ACQUISITION_FAILED,\n 101вЖТ        `Pipeline ${type} is already running`,\n 102вЖТ        {\n 103вЖТ          hint: 'Stop the current pipeline first or use forceUnlock',\n 104вЖТ          context: { currentHolder: lockResult.currentHolder }\n 105вЖТ        }\n 106вЖТ      );\n 107вЖТ    }\n 108вЖТ    return null;\n 109вЖТ  }\n 110вЖТ\n 111вЖТ  /**\n 112вЖТ   * Internal: Release lock.\n 113вЖТ   * @param {string} type - Pipeline type\n 114вЖТ   */\n 115вЖТ  async function _releaseLock(type) {\n 116вЖТ    await lockManager.releaseLock(type);\n 117вЖТ  }\n 118вЖТ\n 119вЖТ  return {\n 120вЖТ    // Internal methods (exposed for testing)\n 121вЖТ    _acquireLock,\n 122вЖТ    _releaseLock,\n 123вЖТ\n 124вЖТ    // F-005: Lifecycle event emitter\n 125вЖТ    eventEmitter,\n 126вЖТ\n 127вЖТ    // Event names\n 128вЖТ    events: {\n 129вЖТ      PIPELINE_START: 'pipeline:start',\n 130вЖТ      PIPELINE_STOP: 'pipeline:stop',\n 131вЖТ      FEATURE_COMPLETE: 'feature:complete',\n 132вЖТ      FEATURE_ERROR: 'feature:error'\n 133вЖТ    },\n 134вЖТ\n 135вЖТ    /**\n 136вЖТ     * Register a lifecycle hook.\n 137вЖТ     * @param {string} event - Event name\n 138вЖТ     * @param {Function} callback - Callback function\n 139вЖТ     */\n 140вЖТ    on(event, callback) {\n 141вЖТ      eventEmitter.on(event, callback);\n 142вЖТ    },\n 143вЖТ\n 144вЖТ    /**\n 145вЖТ     * Remove a lifecycle hook.\n 146вЖТ     * @param {string} event - Event name\n 147вЖТ     * @param {Function} callback - Callback function\n 148вЖТ     */\n 149вЖТ    off(event, callback) {\n 150вЖТ      eventEmitter.off(event, callback);\n 151вЖТ    },\n 152вЖТ\n 153вЖТ    /**\n 154вЖТ     * Start a pipeline.\n 155вЖТ     * @param {Object} params - Parameters\n 156вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 157вЖТ     * @param {string} [params.targetId] - Optional target ID to start with\n 158вЖТ     * @param {string} [params.listPath] - Optional list path\n 159вЖТ     * @param {boolean} [params.daemon=true] - Run in daemon mode\n 160вЖТ     * @param {Object} [params.envOverrides] - Environment overrides\n 161вЖТ     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 162вЖТ     * @returns {Promise<Object>} Start result\n 163вЖТ     */\n 164вЖТ    async startPipeline(params) {\n 165вЖТ      const { type = 'feature', targetId, listPath, daemon = true, envOverrides, timeoutMs } = params;\n 166вЖТ\n 167вЖТ      // Acquire lock\n 168вЖТ      const lockError = await _acquireLock(type);\n 169вЖТ      if (lockError) {\n 170вЖТ        return lockError;\n 171вЖТ      }\n 172вЖТ\n 173вЖТ      // Build and execute command\n 174вЖТ      const runId = generateRunId();\n 175вЖТ\n 176вЖТ      try {\n 177вЖТ        const result = await scriptRunner({\n 178вЖТ          pipelineType: type,\n 179вЖТ          action: 'run',\n 180вЖТ          targetId,\n 181вЖТ          listPath,\n 182вЖТ          envOverrides,\n 183вЖТ          timeoutMs\n 184вЖТ        });\n 185вЖТ\n 186вЖТ        if (!result.ok) {\n 187вЖТ          // Release lock on failure\n 188вЖТ          await _releaseLock(type);\n 189вЖТ          return buildError(\n 190вЖТ            result.errorCode || INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 191вЖТ            result.stderr || 'Failed to start pipeline',\n 192вЖТ            { context: { exitCode: result.exitCode } }\n 193вЖТ          );\n 194вЖТ        }\n 195вЖТ\n 196вЖТ        // F-005: Emit pipeline:start event for heartbeat pusher\n 197вЖТ        eventEmitter.emit('pipeline:start', {\n 198вЖТ          type,\n 199вЖТ          runId,\n 200вЖТ          startedAt: new Date().toISOString(),\n 201вЖТ          targetId,\n 202вЖТ          listPath\n 203вЖТ        });\n 204вЖТ\n 205вЖТ        return buildResult(`Pipeline ${type} started successfully`, {\n 206вЖТ          runId,\n 207вЖТ          pid: daemon ? process.pid : undefined,\n 208вЖТ          stdout: result.stdout\n 209вЖТ        });\n 210вЖТ      } catch (error) {\n 211вЖТ        await _releaseLock(type);\n 212вЖТ        return buildError(\n 213вЖТ          INFRA_ERROR_CODES.DAEMON_START_FAILED,\n 214вЖТ          error.message,\n 215вЖТ          { hint: 'Check pipeline scripts and configuration' }\n 216вЖТ        );\n 217вЖТ      }\n 218вЖТ    },\n 219вЖТ\n 220вЖТ    /**\n 221вЖТ     * Stop a pipeline.\n 222вЖТ     * @param {Object} params - Parameters\n 223вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 224вЖТ     * @param {number} [params.timeoutMs=10000] - Timeout in milliseconds\n 225вЖТ     * @returns {Promise<Object>} Stop result\n 226вЖТ     */\n 227вЖТ    async stopPipeline(params) {\n 228вЖТ      const { type = 'feature', timeoutMs = DEFAULT_STOP_TIMEOUT_MS } = params;\n 229вЖТ\n 230вЖТ      // Check if daemon is running\n 231вЖТ      const isRunning = await stateManager.isDaemonRunning(type);\n 232вЖТ      const previousPid = await stateManager.getDaemonPid(type);\n 233вЖТ\n 234вЖТ      if (!isRunning) {\n 235вЖТ        // Already stopped\n 236вЖТ        return buildResult(`Pipeline ${type} is not running`, {\n 237вЖТ          errorCode: INFRA_ERROR_CODES.ALREADY_STOPPED,\n 238вЖТ          previousPid\n 239вЖТ        });\n 240вЖТ      }\n 241вЖТ\n 242вЖТ      try {\n 243вЖТ        // Execute stop command\n 244вЖТ        const result = await scriptRunner({\n 245вЖТ          pipelineType: type,\n 246вЖТ          action: 'stop',\n 247вЖТ          timeoutMs\n 248вЖТ        });\n 249вЖТ\n 250вЖТ        // Release lock\n 251вЖТ        await _releaseLock(type);\n 252вЖТ\n 253вЖТ        if (!result.ok) {\n 254вЖТ          return buildError(\n 255вЖТ            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 256вЖТ            result.stderr || 'Failed to stop pipeline',\n 257вЖТ            { context: { previousPid } }\n 258вЖТ          );\n 259вЖТ        }\n 260вЖТ\n 261вЖТ        // F-005: Emit pipeline:stop event for heartbeat pusher\n 262вЖТ        eventEmitter.emit('pipeline:stop', {\n 263вЖТ          type,\n 264вЖТ          stoppedAt: new Date().toISOString(),\n 265вЖТ          previousPid\n 266вЖТ        });\n 267вЖТ\n 268вЖТ        return buildResult(`Pipeline ${type} stopped successfully`, {\n 269вЖТ          previousPid\n 270вЖТ        });\n 271вЖТ      } catch (error) {\n 272вЖТ        // Still release lock on error\n 273вЖТ        await _releaseLock(type);\n 274вЖТ        return buildError(\n 275вЖТ          INFRA_ERROR_CODES.EXEC_FAILED,\n 276вЖТ          error.message,\n 277вЖТ          { context: { previousPid } }\n 278вЖТ        );\n 279вЖТ      }\n 280вЖТ    },\n 281вЖТ\n 282вЖТ    /**\n 283вЖТ     * Retry a target.\n 284вЖТ     * @param {Object} params - Parameters\n 285вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 286вЖТ     * @param {string} params.targetId - Target ID to retry\n 287вЖТ     * @param {string} [params.listPath] - Optional list path\n 288вЖТ     * @param {boolean} [params.daemon=false] - Run in daemon mode\n 289вЖТ     * @param {Object} [params.envOverrides] - Environment overrides\n 290вЖТ     * @returns {Promise<Object>} Retry result\n 291вЖТ     */\n 292вЖТ    async retryTarget(params) {\n 293вЖТ      const { type = 'feature', targetId, listPath, daemon = false, envOverrides } = params;\n 294вЖТ\n 295вЖТ      // Validate targetId\n 296вЖТ      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 297вЖТ        return buildError(\n 298вЖТ          INFRA_ERROR_CODES.INVALID_TARGET,\n 299вЖТ          'targetId is required for retry',\n 300вЖТ          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 301вЖТ        );\n 302вЖТ      }\n 303вЖТ\n 304вЖТ      // For daemon mode, acquire lock\n 305вЖТ      if (daemon) {\n 306вЖТ        const lockError = await _acquireLock(type);\n 307вЖТ        if (lockError) {\n 308вЖТ          return lockError;\n 309вЖТ        }\n 310вЖТ      }\n 311вЖТ\n 312вЖТ      try {\n 313вЖТ        const result = await scriptRunner({\n 314вЖТ          pipelineType: type,\n 315вЖТ          action: 'retry',\n 316вЖТ          targetId: targetId.trim(),\n 317вЖТ          listPath,\n 318вЖТ          envOverrides\n 319вЖТ        });\n 320вЖТ\n 321вЖТ        if (daemon) {\n 322вЖТ          await _releaseLock(type);\n 323вЖТ        }\n 324вЖТ\n 325вЖТ        if (!result.ok) {\n 326вЖТ          return buildError(\n 327вЖТ            result.errorCode || INFRA_ERROR_CODES.EXEC_FAILED,\n 328вЖТ            result.stderr || `Failed to retry target ${targetId}`,\n 329вЖТ            { context: { targetId } }\n 330вЖТ          );\n 331вЖТ        }\n 332вЖТ\n 333вЖТ        return buildResult(`Target ${targetId} retry completed`, {\n 334вЖТ          targetId,\n 335вЖТ          stdout: result.stdout\n 336вЖТ        });\n 337вЖТ      } catch (error) {\n 338вЖТ        if (daemon) {\n 339вЖТ          await _releaseLock(type);\n 340вЖТ        }\n 341вЖТ        return buildError(\n 342вЖТ          INFRA_ERROR_CODES.EXEC_FAILED,\n 343вЖТ          error.message,\n 344вЖТ          { context: { targetId } }\n 345вЖТ        );\n 346вЖТ      }\n 347вЖТ    },\n 348вЖТ\n 349вЖТ    /**\n 350вЖТ     * Run a single target without affecting pipeline state.\n 351вЖТ     * @param {Object} params - Parameters\n 352вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 353вЖТ     * @param {string} params.targetId - Target ID to run\n 354вЖТ     * @param {string} [params.listPath] - Optional list path\n 355вЖТ     * @param {number} [params.timeoutMs] - Timeout in milliseconds\n 356вЖТ     * @param {Object} [params.envOverrides] - Environment overrides\n 357вЖТ     * @returns {Promise<Object>} Run result\n 358вЖТ     */\n 359вЖТ    async runSingle(params) {\n 360вЖТ      const { type = 'feature', targetId, listPath, timeoutMs, envOverrides } = params;\n 361вЖТ\n 362вЖТ      // Validate targetId\n 363вЖТ      if (!targetId || typeof targetId !== 'string' || targetId.trim() === '') {\n 364вЖТ        return buildError(\n 365вЖТ          INFRA_ERROR_CODES.INVALID_TARGET,\n 366вЖТ          'targetId is required for runSingle',\n 367вЖТ          { hint: 'Provide a valid target ID (e.g., F-001 or B-001)' }\n 368вЖТ        );\n 369вЖТ      }\n 370вЖТ\n 371вЖТ      // Note: runSingle does NOT acquire lock (independent execution per D5)\n 372вЖТ\n 373вЖТ      try {\n 374вЖТ        const result = await scriptRunner({\n 375вЖТ          pipelineType: type,\n 376вЖТ          action: 'run',\n 377вЖТ          targetId: targetId.trim(),\n 378вЖТ          listPath,\n 379вЖТ          timeoutMs,\n 380вЖТ          envOverrides\n 381вЖТ        });\n 382вЖТ\n 383вЖТ        return {\n 384вЖТ          ok: result.ok,\n 385вЖТ          targetId,\n 386вЖТ          message: result.ok\n 387вЖТ            ? `Target ${targetId} completed successfully`\n 388вЖТ            : `Target ${targetId} failed`,\n 389вЖТ          stdout: result.stdout,\n 390вЖТ          stderr: result.stderr,\n 391вЖТ          exitCode: result.exitCode,\n 392вЖТ          errorCode: result.errorCode\n 393вЖТ        };\n 394вЖТ      } catch (error) {\n 395вЖТ        return buildError(\n 396вЖТ          INFRA_ERROR_CODES.EXEC_FAILED,\n 397вЖТ          error.message,\n 398вЖТ          { context: { targetId } }\n 399вЖТ        );\n 400вЖТ      }\n 401вЖТ    },\n 402вЖТ\n 403вЖТ    /**\n 404вЖТ     * Get pipeline status.\n 405вЖТ     * @param {Object} params - Parameters\n 406вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 407вЖТ     * @returns {Promise<Object>} Status result\n 408вЖТ     */\n 409вЖТ    async getStatus(params) {\n 410вЖТ      const { type = 'feature' } = params;\n 411вЖТ\n 412вЖТ      const isRunning = await stateManager.isDaemonRunning(type);\n 413вЖТ      const pid = await stateManager.getDaemonPid(type);\n 414вЖТ      const pipelineState = await stateManager.readPipelineState(type);\n 415вЖТ      const currentSession = await stateManager.readCurrentSession(type);\n 416вЖТ      const lastResult = await stateManager.getLastResult(type);\n 417вЖТ      const lockInfo = await lockManager.getLockInfo(type);\n 418вЖТ\n 419вЖТ      const result = {\n 420вЖТ        ok: true,\n 421вЖТ        isRunning,\n 422вЖТ        pid: isRunning ? pid : undefined,\n 423вЖТ        message: isRunning\n 424вЖТ          ? `Pipeline ${type} is running`\n 425вЖТ          : `Pipeline ${type} is not running`\n 426вЖТ      };\n 427вЖТ\n 428вЖТ      // Add current feature info if running\n 429вЖТ      if (isRunning && currentSession) {\n 430вЖТ        result.currentFeature = currentSession.feature_id;\n 431вЖТ        result.startedAt = currentSession.started_at;\n 432вЖТ      }\n 433вЖТ\n 434вЖТ      // Add last result if not running\n 435вЖТ      if (!isRunning && lastResult) {\n 436вЖТ        result.lastResult = lastResult;\n 437вЖТ      }\n 438вЖТ\n 439вЖТ      // Add lock info\n 440вЖТ      if (lockInfo) {\n 441вЖТ        result.lockInfo = lockInfo;\n 442вЖТ      }\n 443вЖТ\n 444вЖТ      return result;\n 445вЖТ    },\n 446вЖТ\n 447вЖТ    /**\n 448вЖТ     * Get pipeline logs.\n 449вЖТ     * @param {Object} params - Parameters\n 450вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 451вЖТ     * @param {number} [params.lines=100] - Number of lines to read\n 452вЖТ     * @returns {Promise<Object>} Logs result\n 453вЖТ     */\n 454вЖТ    async getLogs(params) {\n 455вЖТ      const { type = 'feature', lines = DEFAULT_LOG_LINES } = params;\n 456вЖТ\n 457вЖТ      const logPaths = resolveDaemonLogPaths(config.projectRoot);\n 458вЖТ      const logPath = type === 'feature'\n 459вЖТ        ? logPaths.featureDaemonLog\n 460вЖТ        : logPaths.bugfixDaemonLog;\n 461вЖТ\n 462вЖТ      const logs = readLastLines(logPath, lines);\n 463вЖТ\n 464вЖТ      return buildResult(`Retrieved ${lines} lines from ${type} log`, {\n 465вЖТ        logs,\n 466вЖТ        logPath,\n 467вЖТ        lines\n 468вЖТ      });\n 469вЖТ    },\n 470вЖТ\n 471вЖТ    /**\n 472вЖТ     * Force unlock a pipeline (admin operation).\n 473вЖТ     * @param {Object} params - Parameters\n 474вЖТ     * @param {string} params.type - Pipeline type ('feature' or 'bugfix')\n 475вЖТ     * @returns {Promise<Object>} Unlock result\n 476вЖТ     */\n 477вЖТ    async forceUnlock(params) {\n 478вЖТ      const { type = 'feature' } = params;\n 479вЖТ\n 480вЖТ      const result = await lockManager.forceUnlock(type);\n 481вЖТ\n 482вЖТ      return buildResult(`Lock released for ${type} pipeline`, {\n 483вЖТ        previousPid: result.previousPid\n 484вЖТ      });\n 485вЖТ    }\n 486вЖТ  };\n 487вЖТ}\n 488вЖТ\n 489вЖТ// Default instance\n 490вЖТlet defaultController = null;\n 491вЖТ\n 492вЖТ/**\n 493вЖТ * Get the default pipeline controller instance.\n 494вЖТ * @returns {Object} Pipeline controller instance\n 495вЖТ */\n 496вЖТexport function getDefaultPipelineController() {\n 497вЖТ  if (!defaultController) {\n 498вЖТ    defaultController = createPipelineController();\n 499вЖТ  }\n 500вЖТ  return defaultController;\n 501вЖТ}\n 502вЖТ\n 503вЖТ// Export convenience methods that use default controller\n 504вЖТexport async function startPipeline(params) {\n 505вЖТ  return getDefaultPipelineController().startPipeline(params);\n 506вЖТ}\n 507вЖТ\n 508вЖТexport async function stopPipeline(params) {\n 509вЖТ  return getDefaultPipelineController().stopPipeline(params);\n 510вЖТ}\n 511вЖТ\n 512вЖТexport async function retryTarget(params) {\n 513вЖТ  return getDefaultPipelineController().retryTarget(params);\n 514вЖТ}\n 515вЖТ\n 516вЖТexport async function runSingle(params) {\n 517вЖТ  return getDefaultPipelineController().runSingle(params);\n 518вЖТ}\n 519вЖТ\n 520вЖТexport async function getStatus(params) {\n 521вЖТ  return getDefaultPipelineController().getStatus(params);\n 522вЖТ}\n 523вЖТ\n 524вЖТexport async function getLogs(params) {\n 525вЖТ  return getDefaultPipelineController().getLogs(params);\n 526вЖТ}\n 527вЖТ\n 528вЖТexport async function forceUnlock(params) {\n 529вЖТ  return getDefaultPipelineController().forceUnlock(params);\n 530вЖТ}\n 531вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:05:23.398Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"6e3bd4d3-ee86-4bc8-89bd-2625d18d58ee","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"call_c7ad58e50a5d4bc99ce2cc61","content":[{"type":"text","text":"   1вЖТimport { executePipelineCommand } from '../pipeline-infra/script-runner.js';\n   2вЖТimport { createPlanIngestionService } from './plan-ingestion-service.js';\n   3вЖТimport { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n   4вЖТ\n   5вЖТfunction buildRequest(params = {}, action) {\n   6вЖТ  return {\n   7вЖТ    pipelineType: params.pipelineType ?? 'feature',\n   8вЖТ    action,\n   9вЖТ    ...(params.targetId ? { targetId: params.targetId } : {}),\n  10вЖТ    ...(params.listPath ? { listPath: params.listPath } : {}),\n  11вЖТ    ...(params.envOverrides ? { envOverrides: params.envOverrides } : {}),\n  12вЖТ    ...(params.timeoutMs ? { timeoutMs: params.timeoutMs } : {})\n  13вЖТ  };\n  14вЖТ}\n  15вЖТ\n  16вЖТ/**\n  17вЖТ * T-015: Resolve list path for plan type and optional version.\n  18вЖТ * @param {Object} options - Options\n  19вЖТ * @param {string} options.planType - 'feature-list' or 'bug-fix-list'\n  20вЖТ * @param {string} [options.version] - Optional version string\n  21вЖТ * @param {Object} [options.config] - Optional config (will load if not provided)\n  22вЖТ * @param {Object} [options.planService] - Optional plan service instance\n  23вЖТ * @returns {Promise<string|null>} Resolved path or null\n  24вЖТ */\n  25вЖТexport async function resolvePlanListPath({ planType, version, config, planService }) {\n  26вЖТ  const actualConfig = config ?? loadPipelineInfraConfig();\n  27вЖТ  const service = planService ?? createPlanIngestionService({ plansDir: actualConfig.plansDir });\n  28вЖТ\n  29вЖТ  // If version is specified, get that specific version\n  30вЖТ  if (version) {\n  31вЖТ    return service.getVersion(planType, version).then(content => {\n  32вЖТ      if (!content) return null;\n  33вЖТ      // Return the path to the version file\n  34вЖТ      const plansDir = actualConfig.plansDir;\n  35вЖТ      return `${plansDir}/${planType}/v${version.replace(/^v/, '')}.json`;\n  36вЖТ    });\n  37вЖТ  }\n  38вЖТ\n  39вЖТ  // Otherwise, use the active path from registry\n  40вЖТ  return service.getActivePath(planType);\n  41вЖТ}\n  42вЖТ\n  43вЖТexport function createPipelineControlService({ runner = executePipelineCommand } = {}) {\n  44вЖТ  return {\n  45вЖТ    runner,\n  46вЖТ    async startPipeline(params) {\n  47вЖТ      return runner(buildRequest(params, 'run'));\n  48вЖТ    },\n  49вЖТ    async getPipelineStatus(params) {\n  50вЖТ      return runner(buildRequest(params, 'status'));\n  51вЖТ    },\n  52вЖТ    async stopPipeline(params) {\n  53вЖТ      return runner(buildRequest(params, 'stop'));\n  54вЖТ    },\n  55вЖТ    async retryTarget(params) {\n  56вЖТ      return runner(buildRequest(params, 'retry'));\n  57вЖТ    },\n  58вЖТ    async getPipelineLogs(params) {\n  59вЖТ      return runner(buildRequest(params, 'logs'));\n  60вЖТ    },\n  61вЖТ    async resetTarget(params) {\n  62вЖТ      return runner(buildRequest(params, 'reset'));\n  63вЖТ    }\n  64вЖТ  };\n  65вЖТ}\n  66вЖТ\n  67вЖТconst defaultService = createPipelineControlService();\n  68вЖТ\n  69вЖТexport async function startPipeline(params) {\n  70вЖТ  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  71вЖТ  return service.startPipeline(params);\n  72вЖТ}\n  73вЖТ\n  74вЖТexport async function getPipelineStatus(params) {\n  75вЖТ  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  76вЖТ  return service.getPipelineStatus(params);\n  77вЖТ}\n  78вЖТ\n  79вЖТexport async function stopPipeline(params) {\n  80вЖТ  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  81вЖТ  return service.stopPipeline(params);\n  82вЖТ}\n  83вЖТ\n  84вЖТexport async function retryTarget(params) {\n  85вЖТ  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  86вЖТ  return service.retryTarget(params);\n  87вЖТ}\n  88вЖТ\n  89вЖТexport async function getPipelineLogs(params) {\n  90вЖТ  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  91вЖТ  return service.getPipelineLogs(params);\n  92вЖТ}\n  93вЖТ\n  94вЖТexport async function resetTarget(params) {\n  95вЖТ  const service = createPipelineControlService({ runner: params?.runner ?? defaultService.runner });\n  96вЖТ  return service.resetTarget(params);\n  97вЖТ}\n  98вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:05:23.405Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"ac10ee35-c81f-4352-b015-bba114161174","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"call_c72952024cd84e0285e1ba19","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Pipeline Controller Unit Tests\n   3вЖТ * Tests for src/services/pipeline-controller.js\n   4вЖТ *\n   5вЖТ * F-004: Pipeline Process Controller - All User Stories\n   6вЖТ */\n   7вЖТ\n   8вЖТimport test from 'node:test';\n   9вЖТimport assert from 'node:assert/strict';\n  10вЖТimport fs from 'node:fs';\n  11вЖТimport path from 'node:path';\n  12вЖТimport os from 'node:os';\n  13вЖТ\n  14вЖТimport { createPipelineController } from '../../src/services/pipeline-controller.js';\n  15вЖТimport { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n  16вЖТimport { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  17вЖТ\n  18вЖТ/**\n  19вЖТ * Helper to create temp directory for test state\n  20вЖТ */\n  21вЖТfunction createTempStateDir() {\n  22вЖТ  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'pipeline-controller-test-'));\n  23вЖТ  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  24вЖТ  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  25вЖТ  fs.mkdirSync(stateDir, { recursive: true });\n  26вЖТ  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  27вЖТ  return {\n  28вЖТ    tempDir,\n  29вЖТ    stateDir,\n  30вЖТ    bugfixStateDir,\n  31вЖТ    cleanup: () => {\n  32вЖТ      fs.rmSync(tempDir, { recursive: true, force: true });\n  33вЖТ    }\n  34вЖТ  };\n  35вЖТ}\n  36вЖТ\n  37вЖТ/**\n  38вЖТ * Helper to create a mock config\n  39вЖТ */\n  40вЖТfunction createMockConfig(stateDir, bugfixStateDir) {\n  41вЖТ  const projectRoot = path.dirname(path.dirname(stateDir));\n  42вЖТ  return {\n  43вЖТ    projectRoot,\n  44вЖТ    stateDir,\n  45вЖТ    bugfixStateDir\n  46вЖТ  };\n  47вЖТ}\n  48вЖТ\n  49вЖТ/**\n  50вЖТ * Helper to create a mock script runner\n  51вЖТ */\n  52вЖТfunction createMockScriptRunner() {\n  53вЖТ  return async (req) => ({\n  54вЖТ    ok: true,\n  55вЖТ    exitCode: 0,\n  56вЖТ    stdout: 'Mock output',\n  57вЖТ    stderr: '',\n  58вЖТ    normalizedStatus: 'success'\n  59вЖТ  });\n  60вЖТ}\n  61вЖТ\n  62вЖТ// ============================================================\n  63вЖТ// Factory Tests\n  64вЖТ// ============================================================\n  65вЖТ\n  66вЖТtest('createPipelineController should be a factory function', () => {\n  67вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  68вЖТ  try {\n  69вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n  70вЖТ    const controller = createPipelineController({\n  71вЖТ      config,\n  72вЖТ      lockManager: createLockManager({ config }),\n  73вЖТ      stateManager: createStateManager({ config }),\n  74вЖТ      scriptRunner: createMockScriptRunner()\n  75вЖТ    });\n  76вЖТ\n  77вЖТ    assert.equal(typeof controller.startPipeline, 'function');\n  78вЖТ    assert.equal(typeof controller.stopPipeline, 'function');\n  79вЖТ    assert.equal(typeof controller.retryTarget, 'function');\n  80вЖТ    assert.equal(typeof controller.runSingle, 'function');\n  81вЖТ    assert.equal(typeof controller.getStatus, 'function');\n  82вЖТ    assert.equal(typeof controller.getLogs, 'function');\n  83вЖТ    assert.equal(typeof controller.forceUnlock, 'function');\n  84вЖТ    assert.equal(typeof controller._acquireLock, 'function');\n  85вЖТ    assert.equal(typeof controller._releaseLock, 'function');\n  86вЖТ  } finally {\n  87вЖТ    cleanup();\n  88вЖТ  }\n  89вЖТ});\n  90вЖТ\n  91вЖТtest('createPipelineController should accept dependency injection', () => {\n  92вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  93вЖТ  try {\n  94вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n  95вЖТ    const lockManager = createLockManager({ config });\n  96вЖТ    const stateManager = createStateManager({ config });\n  97вЖТ    const scriptRunner = createMockScriptRunner();\n  98вЖТ\n  99вЖТ    const controller = createPipelineController({\n 100вЖТ      lockManager,\n 101вЖТ      stateManager,\n 102вЖТ      scriptRunner,\n 103вЖТ      config\n 104вЖТ    });\n 105вЖТ\n 106вЖТ    assert.ok(controller);\n 107вЖТ  } finally {\n 108вЖТ    cleanup();\n 109вЖТ  }\n 110вЖТ});\n 111вЖТ\n 112вЖТ// ============================================================\n 113вЖТ// US-1: startPipeline Tests\n 114вЖТ// ============================================================\n 115вЖТ\n 116вЖТtest('startPipeline should acquire lock before starting daemon', async () => {\n 117вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 118вЖТ  try {\n 119вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 120вЖТ    const lockManager = createLockManager({ config });\n 121вЖТ    const stateManager = createStateManager({ config });\n 122вЖТ    const scriptRunner = createMockScriptRunner();\n 123вЖТ\n 124вЖТ    const controller = createPipelineController({\n 125вЖТ      lockManager,\n 126вЖТ      stateManager,\n 127вЖТ      scriptRunner,\n 128вЖТ      config\n 129вЖТ    });\n 130вЖТ\n 131вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 132вЖТ    assert.equal(result.ok, true);\n 133вЖТ\n 134вЖТ    // Lock should be held\n 135вЖТ    const isLocked = await lockManager.isLocked('feature');\n 136вЖТ    assert.equal(isLocked, true);\n 137вЖТ  } finally {\n 138вЖТ    cleanup();\n 139вЖТ  }\n 140вЖТ});\n 141вЖТ\n 142вЖТtest('startPipeline should handle LOCK_ACQUISITION_FAILED error', async () => {\n 143вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 144вЖТ  try {\n 145вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 146вЖТ    const lockManager = createLockManager({ config });\n 147вЖТ    const stateManager = createStateManager({ config });\n 148вЖТ    const scriptRunner = createMockScriptRunner();\n 149вЖТ\n 150вЖТ    const controller = createPipelineController({\n 151вЖТ      lockManager,\n 152вЖТ      stateManager,\n 153вЖТ      scriptRunner,\n 154вЖТ      config\n 155вЖТ    });\n 156вЖТ\n 157вЖТ    // Acquire lock first\n 158вЖТ    await lockManager.acquireLock('feature', process.pid);\n 159вЖТ\n 160вЖТ    // Try to start again\n 161вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 162вЖТ    assert.equal(result.ok, false);\n 163вЖТ    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n 164вЖТ    assert.ok(result.hint);\n 165вЖТ    assert.ok(result.context);\n 166вЖТ  } finally {\n 167вЖТ    cleanup();\n 168вЖТ  }\n 169вЖТ});\n 170вЖТ\n 171вЖТtest('startPipeline should support daemon mode (default)', async () => {\n 172вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 173вЖТ  try {\n 174вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 175вЖТ    const lockManager = createLockManager({ config });\n 176вЖТ    const stateManager = createStateManager({ config });\n 177вЖТ    const scriptRunner = createMockScriptRunner();\n 178вЖТ\n 179вЖТ    const controller = createPipelineController({\n 180вЖТ      lockManager,\n 181вЖТ      stateManager,\n 182вЖТ      scriptRunner,\n 183вЖТ      config\n 184вЖТ    });\n 185вЖТ\n 186вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 187вЖТ    assert.equal(result.ok, true);\n 188вЖТ    assert.ok(result.runId);\n 189вЖТ  } finally {\n 190вЖТ    cleanup();\n 191вЖТ  }\n 192вЖТ});\n 193вЖТ\n 194вЖТtest('startPipeline should support targetId parameter', async () => {\n 195вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 196вЖТ  try {\n 197вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 198вЖТ    const lockManager = createLockManager({ config });\n 199вЖТ    const stateManager = createStateManager({ config });\n 200вЖТ\n 201вЖТ    let capturedTargetId = null;\n 202вЖТ    const scriptRunner = async (req) => {\n 203вЖТ      capturedTargetId = req.targetId;\n 204вЖТ      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n 205вЖТ    };\n 206вЖТ\n 207вЖТ    const controller = createPipelineController({\n 208вЖТ      lockManager,\n 209вЖТ      stateManager,\n 210вЖТ      scriptRunner,\n 211вЖТ      config\n 212вЖТ    });\n 213вЖТ\n 214вЖТ    const result = await controller.startPipeline({ type: 'feature', targetId: 'F-001' });\n 215вЖТ    assert.equal(result.ok, true);\n 216вЖТ    assert.equal(capturedTargetId, 'F-001');\n 217вЖТ  } finally {\n 218вЖТ    cleanup();\n 219вЖТ  }\n 220вЖТ});\n 221вЖТ\n 222вЖТtest('startPipeline should work for both feature and bugfix types', async () => {\n 223вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 224вЖТ  try {\n 225вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 226вЖТ    const lockManager = createLockManager({ config });\n 227вЖТ    const stateManager = createStateManager({ config });\n 228вЖТ    const scriptRunner = createMockScriptRunner();\n 229вЖТ\n 230вЖТ    const controller = createPipelineController({\n 231вЖТ      lockManager,\n 232вЖТ      stateManager,\n 233вЖТ      scriptRunner,\n 234вЖТ      config\n 235вЖТ    });\n 236вЖТ\n 237вЖТ    const featureResult = await controller.startPipeline({ type: 'feature' });\n 238вЖТ    assert.equal(featureResult.ok, true);\n 239вЖТ\n 240вЖТ    const bugfixResult = await controller.startPipeline({ type: 'bugfix' });\n 241вЖТ    assert.equal(bugfixResult.ok, true);\n 242вЖТ  } finally {\n 243вЖТ    cleanup();\n 244вЖТ  }\n 245вЖТ});\n 246вЖТ\n 247вЖТ// ============================================================\n 248вЖТ// US-2: stopPipeline Tests\n 249вЖТ// ============================================================\n 250вЖТ\n 251вЖТtest('stopPipeline should release lock after stop', async () => {\n 252вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 253вЖТ  try {\n 254вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 255вЖТ    const lockManager = createLockManager({ config });\n 256вЖТ    const stateManager = createStateManager({ config });\n 257вЖТ    const scriptRunner = createMockScriptRunner();\n 258вЖТ\n 259вЖТ    const controller = createPipelineController({\n 260вЖТ      lockManager,\n 261вЖТ      stateManager,\n 262вЖТ      scriptRunner,\n 263вЖТ      config\n 264вЖТ    });\n 265вЖТ\n 266вЖТ    // Start first (this acquires the lock)\n 267вЖТ    await controller.startPipeline({ type: 'feature' });\n 268вЖТ    assert.equal(await lockManager.isLocked('feature'), true);\n 269вЖТ\n 270вЖТ    // Write daemon meta to simulate running daemon\n 271вЖТ    await stateManager.writeDaemonMeta('feature', {\n 272вЖТ      pid: process.pid,\n 273вЖТ      started_at: new Date().toISOString(),\n 274вЖТ      feature_list: '/path/to/list.json',\n 275вЖТ      env_overrides: '',\n 276вЖТ      log_file: '/path/to/log'\n 277вЖТ    });\n 278вЖТ\n 279вЖТ    // Stop\n 280вЖТ    const result = await controller.stopPipeline({ type: 'feature' });\n 281вЖТ    assert.equal(result.ok, true);\n 282вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 283вЖТ  } finally {\n 284вЖТ    cleanup();\n 285вЖТ  }\n 286вЖТ});\n 287вЖТ\n 288вЖТtest('stopPipeline should return ALREADY_STOPPED if not running', async () => {\n 289вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 290вЖТ  try {\n 291вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 292вЖТ    const lockManager = createLockManager({ config });\n 293вЖТ    const stateManager = createStateManager({ config });\n 294вЖТ    const scriptRunner = createMockScriptRunner();\n 295вЖТ\n 296вЖТ    const controller = createPipelineController({\n 297вЖТ      lockManager,\n 298вЖТ      stateManager,\n 299вЖТ      scriptRunner,\n 300вЖТ      config\n 301вЖТ    });\n 302вЖТ\n 303вЖТ    // Stop without starting\n 304вЖТ    const result = await controller.stopPipeline({ type: 'feature' });\n 305вЖТ    assert.equal(result.ok, true);\n 306вЖТ    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 307вЖТ  } finally {\n 308вЖТ    cleanup();\n 309вЖТ  }\n 310вЖТ});\n 311вЖТ\n 312вЖТ// ============================================================\n 313вЖТ// US-3: retryTarget Tests\n 314вЖТ// ============================================================\n 315вЖТ\n 316вЖТtest('retryTarget should validate targetId is provided', async () => {\n 317вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 318вЖТ  try {\n 319вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 320вЖТ    const lockManager = createLockManager({ config });\n 321вЖТ    const stateManager = createStateManager({ config });\n 322вЖТ    const scriptRunner = createMockScriptRunner();\n 323вЖТ\n 324вЖТ    const controller = createPipelineController({\n 325вЖТ      lockManager,\n 326вЖТ      stateManager,\n 327вЖТ      scriptRunner,\n 328вЖТ      config\n 329вЖТ    });\n 330вЖТ\n 331вЖТ    const result = await controller.retryTarget({ type: 'feature' });\n 332вЖТ    assert.equal(result.ok, false);\n 333вЖТ    assert.equal(result.errorCode, 'INVALID_TARGET');\n 334вЖТ    assert.ok(result.hint);\n 335вЖТ  } finally {\n 336вЖТ    cleanup();\n 337вЖТ  }\n 338вЖТ});\n 339вЖТ\n 340вЖТtest('retryTarget should support foreground mode (default)', async () => {\n 341вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 342вЖТ  try {\n 343вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 344вЖТ    const lockManager = createLockManager({ config });\n 345вЖТ    const stateManager = createStateManager({ config });\n 346вЖТ    const scriptRunner = createMockScriptRunner();\n 347вЖТ\n 348вЖТ    const controller = createPipelineController({\n 349вЖТ      lockManager,\n 350вЖТ      stateManager,\n 351вЖТ      scriptRunner,\n 352вЖТ      config\n 353вЖТ    });\n 354вЖТ\n 355вЖТ    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n 356вЖТ    assert.equal(result.ok, true);\n 357вЖТ    assert.equal(result.targetId, 'F-001');\n 358вЖТ\n 359вЖТ    // Should not hold lock (foreground mode)\n 360вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 361вЖТ  } finally {\n 362вЖТ    cleanup();\n 363вЖТ  }\n 364вЖТ});\n 365вЖТ\n 366вЖТ// ============================================================\n 367вЖТ// US-4: runSingle Tests\n 368вЖТ// ============================================================\n 369вЖТ\n 370вЖТtest('runSingle should NOT acquire lock', async () => {\n 371вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 372вЖТ  try {\n 373вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 374вЖТ    const lockManager = createLockManager({ config });\n 375вЖТ    const stateManager = createStateManager({ config });\n 376вЖТ    const scriptRunner = createMockScriptRunner();\n 377вЖТ\n 378вЖТ    const controller = createPipelineController({\n 379вЖТ      lockManager,\n 380вЖТ      stateManager,\n 381вЖТ      scriptRunner,\n 382вЖТ      config\n 383вЖТ    });\n 384вЖТ\n 385вЖТ    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 386вЖТ    assert.equal(result.ok, true);\n 387вЖТ\n 388вЖТ    // Should not hold lock\n 389вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 390вЖТ  } finally {\n 391вЖТ    cleanup();\n 392вЖТ  }\n 393вЖТ});\n 394вЖТ\n 395вЖТtest('runSingle should return full execution details', async () => {\n 396вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 397вЖТ  try {\n 398вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 399вЖТ    const lockManager = createLockManager({ config });\n 400вЖТ    const stateManager = createStateManager({ config });\n 401вЖТ\n 402вЖТ    const scriptRunner = async () => ({\n 403вЖТ      ok: true,\n 404вЖТ      exitCode: 0,\n 405вЖТ      stdout: 'Test stdout',\n 406вЖТ      stderr: 'Test stderr',\n 407вЖТ      normalizedStatus: 'success'\n 408вЖТ    });\n 409вЖТ\n 410вЖТ    const controller = createPipelineController({\n 411вЖТ      lockManager,\n 412вЖТ      stateManager,\n 413вЖТ      scriptRunner,\n 414вЖТ      config\n 415вЖТ    });\n 416вЖТ\n 417вЖТ    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 418вЖТ    assert.equal(result.ok, true);\n 419вЖТ    assert.equal(result.targetId, 'F-001');\n 420вЖТ    assert.equal(result.stdout, 'Test stdout');\n 421вЖТ    assert.equal(result.stderr, 'Test stderr');\n 422вЖТ    assert.equal(result.exitCode, 0);\n 423вЖТ  } finally {\n 424вЖТ    cleanup();\n 425вЖТ  }\n 426вЖТ});\n 427вЖТ\n 428вЖТtest('runSingle should validate targetId', async () => {\n 429вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 430вЖТ  try {\n 431вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 432вЖТ    const lockManager = createLockManager({ config });\n 433вЖТ    const stateManager = createStateManager({ config });\n 434вЖТ    const scriptRunner = createMockScriptRunner();\n 435вЖТ\n 436вЖТ    const controller = createPipelineController({\n 437вЖТ      lockManager,\n 438вЖТ      stateManager,\n 439вЖТ      scriptRunner,\n 440вЖТ      config\n 441вЖТ    });\n 442вЖТ\n 443вЖТ    const result = await controller.runSingle({ type: 'feature' });\n 444вЖТ    assert.equal(result.ok, false);\n 445вЖТ    assert.equal(result.errorCode, 'INVALID_TARGET');\n 446вЖТ  } finally {\n 447вЖТ    cleanup();\n 448вЖТ  }\n 449вЖТ});\n 450вЖТ\n 451вЖТ// ============================================================\n 452вЖТ// US-5: getStatus Tests\n 453вЖТ// ============================================================\n 454вЖТ\n 455вЖТtest('getStatus should return isRunning boolean', async () => {\n 456вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 457вЖТ  try {\n 458вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 459вЖТ    const lockManager = createLockManager({ config });\n 460вЖТ    const stateManager = createStateManager({ config });\n 461вЖТ    const scriptRunner = createMockScriptRunner();\n 462вЖТ\n 463вЖТ    const controller = createPipelineController({\n 464вЖТ      lockManager,\n 465вЖТ      stateManager,\n 466вЖТ      scriptRunner,\n 467вЖТ      config\n 468вЖТ    });\n 469вЖТ\n 470вЖТ    const result = await controller.getStatus({ type: 'feature' });\n 471вЖТ    assert.equal(result.ok, true);\n 472вЖТ    assert.equal(typeof result.isRunning, 'boolean');\n 473вЖТ  } finally {\n 474вЖТ    cleanup();\n 475вЖТ  }\n 476вЖТ});\n 477вЖТ\n 478вЖТtest('getStatus should return lastResult when not running', async () => {\n 479вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 480вЖТ  try {\n 481вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 482вЖТ    const lockManager = createLockManager({ config });\n 483вЖТ    const stateManager = createStateManager({ config });\n 484вЖТ    const scriptRunner = createMockScriptRunner();\n 485вЖТ\n 486вЖТ    // Write last result\n 487вЖТ    const lastResult = {\n 488вЖТ      runId: 'run-test',\n 489вЖТ      completedAt: new Date().toISOString(),\n 490вЖТ      status: 'success',\n 491вЖТ      featuresTotal: 8,\n 492вЖТ      featuresCompleted: 8\n 493вЖТ    };\n 494вЖТ    await stateManager.writeLastResult('feature', lastResult);\n 495вЖТ\n 496вЖТ    const controller = createPipelineController({\n 497вЖТ      lockManager,\n 498вЖТ      stateManager,\n 499вЖТ      scriptRunner,\n 500вЖТ      config\n 501вЖТ    });\n 502вЖТ\n 503вЖТ    const result = await controller.getStatus({ type: 'feature' });\n 504вЖТ    assert.equal(result.ok, true);\n 505вЖТ    assert.deepEqual(result.lastResult, lastResult);\n 506вЖТ  } finally {\n 507вЖТ    cleanup();\n 508вЖТ  }\n 509вЖТ});\n 510вЖТ\n 511вЖТtest('getStatus should return lockInfo', async () => {\n 512вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 513вЖТ  try {\n 514вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 515вЖТ    const lockManager = createLockManager({ config });\n 516вЖТ    const stateManager = createStateManager({ config });\n 517вЖТ    const scriptRunner = createMockScriptRunner();\n 518вЖТ\n 519вЖТ    // Acquire lock\n 520вЖТ    await lockManager.acquireLock('feature', 12345);\n 521вЖТ\n 522вЖТ    const controller = createPipelineController({\n 523вЖТ      lockManager,\n 524вЖТ      stateManager,\n 525вЖТ      scriptRunner,\n 526вЖТ      config\n 527вЖТ    });\n 528вЖТ\n 529вЖТ    const result = await controller.getStatus({ type: 'feature' });\n 530вЖТ    assert.equal(result.ok, true);\n 531вЖТ    assert.ok(result.lockInfo);\n 532вЖТ    assert.equal(result.lockInfo.pid, 12345);\n 533вЖТ  } finally {\n 534вЖТ    cleanup();\n 535вЖТ  }\n 536вЖТ});\n 537вЖТ\n 538вЖТ// ============================================================\n 539вЖТ// US-6: getLogs Tests\n 540вЖТ// ============================================================\n 541вЖТ\n 542вЖТtest('getLogs should return log content', async () => {\n 543вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 544вЖТ  try {\n 545вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 546вЖТ    const lockManager = createLockManager({ config });\n 547вЖТ    const stateManager = createStateManager({ config });\n 548вЖТ    const scriptRunner = createMockScriptRunner();\n 549вЖТ\n 550вЖТ    // Write log file\n 551вЖТ    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), 'Line 1\\nLine 2\\nLine 3');\n 552вЖТ\n 553вЖТ    const controller = createPipelineController({\n 554вЖТ      lockManager,\n 555вЖТ      stateManager,\n 556вЖТ      scriptRunner,\n 557вЖТ      config\n 558вЖТ    });\n 559вЖТ\n 560вЖТ    const result = await controller.getLogs({ type: 'feature', lines: 10 });\n 561вЖТ    assert.equal(result.ok, true);\n 562вЖТ    assert.ok(result.logs);\n 563вЖТ    assert.ok(result.logPath);\n 564вЖТ    assert.ok(result.lines);\n 565вЖТ  } finally {\n 566вЖТ    cleanup();\n 567вЖТ  }\n 568вЖТ});\n 569вЖТ\n 570вЖТtest('getLogs should handle missing log file gracefully', async () => {\n 571вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 572вЖТ  try {\n 573вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 574вЖТ    const lockManager = createLockManager({ config });\n 575вЖТ    const stateManager = createStateManager({ config });\n 576вЖТ    const scriptRunner = createMockScriptRunner();\n 577вЖТ\n 578вЖТ    const controller = createPipelineController({\n 579вЖТ      lockManager,\n 580вЖТ      stateManager,\n 581вЖТ      scriptRunner,\n 582вЖТ      config\n 583вЖТ    });\n 584вЖТ\n 585вЖТ    const result = await controller.getLogs({ type: 'feature' });\n 586вЖТ    assert.equal(result.ok, true);\n 587вЖТ    assert.equal(result.logs, '');\n 588вЖТ  } finally {\n 589вЖТ    cleanup();\n 590вЖТ  }\n 591вЖТ});\n 592вЖТ\n 593вЖТ// ============================================================\n 594вЖТ// US-7: forceUnlock Tests\n 595вЖТ// ============================================================\n 596вЖТ\n 597вЖТtest('forceUnlock should remove lock regardless of owner', async () => {\n 598вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 599вЖТ  try {\n 600вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 601вЖТ    const lockManager = createLockManager({ config });\n 602вЖТ    const stateManager = createStateManager({ config });\n 603вЖТ    const scriptRunner = createMockScriptRunner();\n 604вЖТ\n 605вЖТ    // Create a lock with a different PID\n 606вЖТ    await lockManager.acquireLock('feature', 99999);\n 607вЖТ\n 608вЖТ    const controller = createPipelineController({\n 609вЖТ      lockManager,\n 610вЖТ      stateManager,\n 611вЖТ      scriptRunner,\n 612вЖТ      config\n 613вЖТ    });\n 614вЖТ\n 615вЖТ    const result = await controller.forceUnlock({ type: 'feature' });\n 616вЖТ    assert.equal(result.ok, true);\n 617вЖТ    assert.equal(result.previousPid, 99999);\n 618вЖТ\n 619вЖТ    // Lock should be released\n 620вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 621вЖТ  } finally {\n 622вЖТ    cleanup();\n 623вЖТ  }\n 624вЖТ});\n 625вЖТ\n 626вЖТ// ============================================================\n 627вЖТ// US-8: Error Mapping Tests\n 628вЖТ// ============================================================\n 629вЖТ\n 630вЖТtest('all methods should return JSON-serializable results', async () => {\n 631вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 632вЖТ  try {\n 633вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 634вЖТ    const lockManager = createLockManager({ config });\n 635вЖТ    const stateManager = createStateManager({ config });\n 636вЖТ    const scriptRunner = createMockScriptRunner();\n 637вЖТ\n 638вЖТ    const controller = createPipelineController({\n 639вЖТ      lockManager,\n 640вЖТ      stateManager,\n 641вЖТ      scriptRunner,\n 642вЖТ      config\n 643вЖТ    });\n 644вЖТ\n 645вЖТ    const results = await Promise.all([\n 646вЖТ      controller.startPipeline({ type: 'feature' }),\n 647вЖТ      controller.getStatus({ type: 'feature' }),\n 648вЖТ      controller.getLogs({ type: 'feature' })\n 649вЖТ    ]);\n 650вЖТ\n 651вЖТ    for (const result of results) {\n 652вЖТ      assert.doesNotThrow(() => JSON.stringify(result));\n 653вЖТ    }\n 654вЖТ  } finally {\n 655вЖТ    cleanup();\n 656вЖТ  }\n 657вЖТ});\n 658вЖТ\n 659вЖТtest('errors should include hint field', async () => {\n 660вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 661вЖТ  try {\n 662вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 663вЖТ    const lockManager = createLockManager({ config });\n 664вЖТ    const stateManager = createStateManager({ config });\n 665вЖТ    const scriptRunner = createMockScriptRunner();\n 666вЖТ\n 667вЖТ    // Lock first\n 668вЖТ    await lockManager.acquireLock('feature', process.pid);\n 669вЖТ\n 670вЖТ    const controller = createPipelineController({\n 671вЖТ      lockManager,\n 672вЖТ      stateManager,\n 673вЖТ      scriptRunner,\n 674вЖТ      config\n 675вЖТ    });\n 676вЖТ\n 677вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 678вЖТ    assert.equal(result.ok, false);\n 679вЖТ    assert.ok(result.hint);\n 680вЖТ  } finally {\n 681вЖТ    cleanup();\n 682вЖТ  }\n 683вЖТ});\n 684вЖТ\n 685вЖТtest('errors should include context field', async () => {\n 686вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 687вЖТ  try {\n 688вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 689вЖТ    const lockManager = createLockManager({ config });\n 690вЖТ    const stateManager = createStateManager({ config });\n 691вЖТ    const scriptRunner = createMockScriptRunner();\n 692вЖТ\n 693вЖТ    // Lock first\n 694вЖТ    await lockManager.acquireLock('feature', process.pid);\n 695вЖТ\n 696вЖТ    const controller = createPipelineController({\n 697вЖТ      lockManager,\n 698вЖТ      stateManager,\n 699вЖТ      scriptRunner,\n 700вЖТ      config\n 701вЖТ    });\n 702вЖТ\n 703вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 704вЖТ    assert.equal(result.ok, false);\n 705вЖТ    assert.ok(result.context);\n 706вЖТ  } finally {\n 707вЖТ    cleanup();\n 708вЖТ  }\n 709вЖТ});\n 710вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:05:23.406Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
