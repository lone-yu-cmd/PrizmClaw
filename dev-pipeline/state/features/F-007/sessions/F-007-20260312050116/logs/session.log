{"type":"assistant","uuid":"20260312050523047c3fd9118c44db","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"id":"20260312050523047c3fd9118c44db","content":[{"type":"tool_use","id":"call_273993b1d9284e2eb920a134","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/plan-ingestion-service.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":50484,"output_tokens":262,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:05:29.037Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"a0b3987c-d998-47ab-9932-6c5d73ce5736","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"call_09a842a1431446f99e43fe88","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Plan Ingestion Service\n   3вЖТ * Manages plan file validation, versioning, and registry.\n   4вЖТ * Implements T-010 to T-014 for F-003.\n   5вЖТ */\n   6вЖТ\n   7вЖТimport fs from 'node:fs';\n   8вЖТimport path from 'node:path';\n   9вЖТimport Ajv from 'ajv';\n  10вЖТ\n  11вЖТ/**\n  12вЖТ * Schema type identifiers\n  13вЖТ * @typedef {'feature-list' | 'bug-fix-list'} PlanType\n  14вЖТ */\n  15вЖТ\n  16вЖТ/**\n  17вЖТ * @typedef {Object} ValidationResult\n  18вЖТ * @property {boolean} valid - Whether validation passed\n  19вЖТ * @property {PlanType | 'unknown'} type - Detected plan type\n  20вЖТ * @property {ValidationError[]} errors - Validation errors\n  21вЖТ * @property {PlanSummary} [summary] - Content summary if valid\n  22вЖТ */\n  23вЖТ\n  24вЖТ/**\n  25вЖТ * @typedef {Object} ValidationError\n  26вЖТ * @property {string} path - JSON path to the error\n  27вЖТ * @property {string} message - Human-readable error message\n  28вЖТ * @property {string} [keyword] - JSON Schema keyword\n  29вЖТ */\n  30вЖТ\n  31вЖТ/**\n  32вЖТ * @typedef {Object} PlanSummary\n  33вЖТ * @property {PlanType} type - Plan type\n  34вЖТ * @property {string} name - App/project name\n  35вЖТ * @property {number} itemCount - Number of features/bugs\n  36вЖТ * @property {Record<string, number>} statusBreakdown - Status counts\n  37вЖТ */\n  38вЖТ\n  39вЖТ/**\n  40вЖТ * @typedef {Object} VersionInfo\n  41вЖТ * @property {string} version - Version identifier\n  42вЖТ * @property {Date} timestamp - Creation timestamp\n  43вЖТ * @property {number} size - File size in bytes\n  44вЖТ * @property {number} itemCount - Number of items\n  45вЖТ * @property {boolean} isValid - Whether file is valid\n  46вЖТ */\n  47вЖТ\n  48вЖТ/**\n  49вЖТ * @typedef {Object} SaveResult\n  50вЖТ * @property {boolean} success - Whether save succeeded\n  51вЖТ * @property {string} [version] - Version identifier\n  52вЖТ * @property {string} [error] - Error message\n  53вЖТ */\n  54вЖТ\n  55вЖТ/**\n  56вЖТ * @typedef {Object} ActiveMeta\n  57вЖТ * @property {string} version - Current version\n  58вЖТ * @property {string} path - Path to current version file\n  59вЖТ * @property {Date} lastModified - Last modification time\n  60вЖТ * @property {number} itemCount - Number of items\n  61вЖТ */\n  62вЖТ\n  63вЖТ/**\n  64вЖТ * @typedef {Object} RollbackResult\n  65вЖТ * @property {string} previousVersion - Version we rolled back from\n  66вЖТ * @property {string} currentVersion - Version we rolled back to\n  67вЖТ */\n  68вЖТ\n  69вЖТ/**\n  70вЖТ * Schema mapping from $schema value to type\n  71вЖТ */\n  72вЖТconst SCHEMA_TYPE_MAP = {\n  73вЖТ  'dev-pipeline-feature-list-v1': 'feature-list',\n  74вЖТ  'dev-pipeline-bug-fix-list-v1': 'bug-fix-list'\n  75вЖТ};\n  76вЖТ\n  77вЖТ/**\n  78вЖТ * Schema file paths relative to project root\n  79вЖТ */\n  80вЖТconst SCHEMA_PATHS = {\n  81вЖТ  'feature-list': 'dev-pipeline/templates/feature-list-schema.json',\n  82вЖТ  'bug-fix-list': 'dev-pipeline/templates/bug-fix-list-schema.json'\n  83вЖТ};\n  84вЖТ\n  85вЖТ/**\n  86вЖТ * Create plan ingestion service.\n  87вЖТ * @param {Object} config - Service configuration\n  88вЖТ * @param {string} [config.projectRoot] - Project root directory\n  89вЖТ * @param {string} [config.plansDir] - Plans directory (overrides projectRoot)\n  90вЖТ * @returns {Object} Service instance\n  91вЖТ */\n  92вЖТexport function createPlanIngestionService(config = {}) {\n  93вЖТ  const projectRoot = config.projectRoot || process.cwd();\n  94вЖТ  const plansDir = config.plansDir || path.join(projectRoot, 'plans');\n  95вЖТ\n  96вЖТ  // Cached Ajv instance and compiled schemas\n  97вЖТ  const ajv = new Ajv({ allErrors: true, strict: false });\n  98вЖТ  const compiledSchemaCache = new Map();\n  99вЖТ\n 100вЖТ  /**\n 101вЖТ   * Load and compile schema by type.\n 102вЖТ   * @param {PlanType} type - Schema type\n 103вЖТ   * @returns {Object} Schema object\n 104вЖТ   */\n 105вЖТ  function loadSchema(type) {\n 106вЖТ    // Check if we have a valid schema type first\n 107вЖТ    if (!SCHEMA_PATHS[type]) {\n 108вЖТ      throw new Error(`Unknown schema type: ${type}`);\n 109вЖТ    }\n 110вЖТ\n 111вЖТ    const schemaPath = path.join(projectRoot, SCHEMA_PATHS[type]);\n 112вЖТ    if (!fs.existsSync(schemaPath)) {\n 113вЖТ      throw new Error(`Schema file not found for type: ${type}`);\n 114вЖТ    }\n 115вЖТ\n 116вЖТ    const schemaContent = fs.readFileSync(schemaPath, 'utf-8');\n 117вЖТ    return JSON.parse(schemaContent);\n 118вЖТ  }\n 119вЖТ\n 120вЖТ  /**\n 121вЖТ   * Get compiled validator for schema type (internal).\n 122вЖТ   * @param {PlanType} type - Schema type\n 123вЖТ   * @returns {Function} Compiled validator function\n 124вЖТ   */\n 125вЖТ  function getCompiledValidator(type) {\n 126вЖТ    if (compiledSchemaCache.has(type)) {\n 127вЖТ      return compiledSchemaCache.get(type);\n 128вЖТ    }\n 129вЖТ\n 130вЖТ    const schema = loadSchema(type);\n 131вЖТ    const compiled = ajv.compile(schema);\n 132вЖТ    compiledSchemaCache.set(type, compiled);\n 133вЖТ    return compiled;\n 134вЖТ  }\n 135вЖТ\n 136вЖТ  /**\n 137вЖТ   * Detect plan type from $schema field.\n 138вЖТ   * @param {Object} parsed - Parsed JSON content\n 139вЖТ   * @returns {PlanType | 'unknown'}\n 140вЖТ   */\n 141вЖТ  function detectType(parsed) {\n 142вЖТ    if (!parsed || typeof parsed !== 'object') {\n 143вЖТ      return 'unknown';\n 144вЖТ    }\n 145вЖТ\n 146вЖТ    const schemaValue = parsed.$schema;\n 147вЖТ    if (typeof schemaValue !== 'string') {\n 148вЖТ      return 'unknown';\n 149вЖТ    }\n 150вЖТ\n 151вЖТ    return SCHEMA_TYPE_MAP[schemaValue] || 'unknown';\n 152вЖТ  }\n 153вЖТ\n 154вЖТ  /**\n 155вЖТ   * Generate summary from parsed content.\n 156вЖТ   * @param {PlanType} type - Plan type\n 157вЖТ   * @param {Object} parsed - Parsed content\n 158вЖТ   * @returns {PlanSummary}\n 159вЖТ   */\n 160вЖТ  function generateSummary(type, parsed) {\n 161вЖТ    const name = type === 'feature-list' ? parsed.app_name : parsed.project_name;\n 162вЖТ    const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 163вЖТ    const itemCount = Array.isArray(items) ? items.length : 0;\n 164вЖТ\n 165вЖТ    const statusBreakdown = {};\n 166вЖТ    if (Array.isArray(items)) {\n 167вЖТ      for (const item of items) {\n 168вЖТ        const status = item.status || 'unknown';\n 169вЖТ        statusBreakdown[status] = (statusBreakdown[status] || 0) + 1;\n 170вЖТ      }\n 171вЖТ    }\n 172вЖТ\n 173вЖТ    return { type, name: name || 'Unknown', itemCount, statusBreakdown };\n 174вЖТ  }\n 175вЖТ\n 176вЖТ  /**\n 177вЖТ   * Convert Ajv errors to ValidationError format.\n 178вЖТ   * @param {Array} ajvErrors - Ajv error objects\n 179вЖТ   * @returns {ValidationError[]}\n 180вЖТ   */\n 181вЖТ  function convertAjvErrors(ajvErrors) {\n 182вЖТ    if (!Array.isArray(ajvErrors)) {\n 183вЖТ      return [];\n 184вЖТ    }\n 185вЖТ\n 186вЖТ    return ajvErrors.map((err) => ({\n 187вЖТ      path: err.instancePath || err.schemaPath || '/',\n 188вЖТ      message: err.message || 'Validation error',\n 189вЖТ      keyword: err.keyword\n 190вЖТ    }));\n 191вЖТ  }\n 192вЖТ\n 193вЖТ  /**\n 194вЖТ   * Validate plan content.\n 195вЖТ   * @param {string} content - JSON string content\n 196вЖТ   * @returns {ValidationResult}\n 197вЖТ   */\n 198вЖТ  function validate(content) {\n 199вЖТ    // Try to parse JSON\n 200вЖТ    let parsed;\n 201вЖТ    try {\n 202вЖТ      parsed = JSON.parse(content);\n 203вЖТ    } catch (e) {\n 204вЖТ      return {\n 205вЖТ        valid: false,\n 206вЖТ        type: 'unknown',\n 207вЖТ        errors: [{ path: '/', message: `Invalid JSON: ${e.message}` }]\n 208вЖТ      };\n 209вЖТ    }\n 210вЖТ\n 211вЖТ    // Detect type\n 212вЖТ    const type = detectType(parsed);\n 213вЖТ    if (type === 'unknown') {\n 214вЖТ      return {\n 215вЖТ        valid: false,\n 216вЖТ        type: 'unknown',\n 217вЖТ        errors: [{ path: '/$schema', message: 'Unknown or missing $schema field' }]\n 218вЖТ      };\n 219вЖТ    }\n 220вЖТ\n 221вЖТ    // Load and run schema validation\n 222вЖТ    const validator = getCompiledValidator(type);\n 223вЖТ    const valid = validator(parsed);\n 224вЖТ\n 225вЖТ    if (!valid) {\n 226вЖТ      return {\n 227вЖТ        valid: false,\n 228вЖТ        type,\n 229вЖТ        errors: convertAjvErrors(validator.errors)\n 230вЖТ      };\n 231вЖТ    }\n 232вЖТ\n 233вЖТ    // Generate summary\n 234вЖТ    const summary = generateSummary(type, parsed);\n 235вЖТ\n 236вЖТ    return { valid: true, type, errors: [], summary };\n 237вЖТ  }\n 238вЖТ\n 239вЖТ  /**\n 240вЖТ   * Format validation errors for display.\n 241вЖТ   * @param {ValidationError[]} errors - Validation errors\n 242вЖТ   * @returns {string} Formatted error message\n 243вЖТ   */\n 244вЖТ  function formatValidationErrors(errors) {\n 245вЖТ    if (!Array.isArray(errors) || errors.length === 0) {\n 246вЖТ      return '';\n 247вЖТ    }\n 248вЖТ\n 249вЖТ    const lines = ['\\u274c \\u6821\\u9a8c\\u5931\\u8d25:'];\n 250вЖТ\n 251вЖТ    for (const error of errors) {\n 252вЖТ      const path = error.path || '/';\n 253вЖТ      const message = error.message || 'Unknown error';\n 254вЖТ      lines.push(`\\u2022 ${path}: ${message}`);\n 255вЖТ    }\n 256вЖТ\n 257вЖТ    return lines.join('\\n');\n 258вЖТ  }\n 259вЖТ\n 260вЖТ  /**\n 261вЖТ   * Get type directory path.\n 262вЖТ   * @param {PlanType} type - Plan type\n 263вЖТ   * @returns {string}\n 264вЖТ   */\n 265вЖТ  function getTypeDir(type) {\n 266вЖТ    return path.join(plansDir, type);\n 267вЖТ  }\n 268вЖТ\n 269вЖТ  /**\n 270вЖТ   * Generate version string from timestamp.\n 271вЖТ   * @param {Date} date - Timestamp\n 272вЖТ   * @returns {string} Version string like v20260312-143052\n 273вЖТ   */\n 274вЖТ  function generateVersion(date = new Date()) {\n 275вЖТ    const pad = (n) => String(n).padStart(2, '0');\n 276вЖТ    const year = date.getFullYear();\n 277вЖТ    const month = pad(date.getMonth() + 1);\n 278вЖТ    const day = pad(date.getDate());\n 279вЖТ    const hour = pad(date.getHours());\n 280вЖТ    const minute = pad(date.getMinutes());\n 281вЖТ    const second = pad(date.getSeconds());\n 282вЖТ    return `v${year}${month}${day}-${hour}${minute}${second}`;\n 283вЖТ  }\n 284вЖТ\n 285вЖТ  /**\n 286вЖТ   * Ensure type directory exists.\n 287вЖТ   * @param {PlanType} type - Plan type\n 288вЖТ   */\n 289вЖТ  function ensureTypeDir(type) {\n 290вЖТ    const typeDir = getTypeDir(type);\n 291вЖТ    fs.mkdirSync(typeDir, { recursive: true });\n 292вЖТ  }\n 293вЖТ\n 294вЖТ  /**\n 295вЖТ   * Save plan content as new version.\n 296вЖТ   * @param {PlanType} type - Plan type\n 297вЖТ   * @param {string} content - JSON content\n 298вЖТ   * @param {Object} meta - Upload metadata\n 299вЖТ   * @param {number} meta.uploadedBy - User ID who uploaded\n 300вЖТ   * @returns {Promise<SaveResult>}\n 301вЖТ   */\n 302вЖТ  async function save(type, content, meta = {}) {\n 303вЖТ    try {\n 304вЖТ      ensureTypeDir(type);\n 305вЖТ\n 306вЖТ      const version = generateVersion();\n 307вЖТ      const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 308вЖТ\n 309вЖТ      // Count items\n 310вЖТ      let itemCount = 0;\n 311вЖТ      try {\n 312вЖТ        const parsed = JSON.parse(content);\n 313вЖТ        const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 314вЖТ        itemCount = Array.isArray(items) ? items.length : 0;\n 315вЖТ      } catch {\n 316вЖТ        // Ignore parse errors, already validated\n 317вЖТ      }\n 318вЖТ\n 319вЖТ      // Write file\n 320вЖТ      fs.writeFileSync(versionPath, content, 'utf-8');\n 321вЖТ\n 322вЖТ      return { success: true, version };\n 323вЖТ    } catch (e) {\n 324вЖТ      return { success: false, error: e.message };\n 325вЖТ    }\n 326вЖТ  }\n 327вЖТ\n 328вЖТ  /**\n 329вЖТ   * List all versions for a plan type.\n 330вЖТ   * @param {PlanType} type - Plan type\n 331вЖТ   * @returns {Promise<VersionInfo[]>}\n 332вЖТ   */\n 333вЖТ  async function listVersions(type) {\n 334вЖТ    const typeDir = getTypeDir(type);\n 335вЖТ    if (!fs.existsSync(typeDir)) {\n 336вЖТ      return [];\n 337вЖТ    }\n 338вЖТ\n 339вЖТ    const files = fs.readdirSync(typeDir);\n 340вЖТ    const versions = [];\n 341вЖТ\n 342вЖТ    for (const file of files) {\n 343вЖТ      if (!file.endsWith('.json') || file === '_current.json') {\n 344вЖТ        continue;\n 345вЖТ      }\n 346вЖТ\n 347вЖТ      const match = file.match(/^(v\\d{8}-\\d{6})\\.json$/);\n 348вЖТ      if (!match) {\n 349вЖТ        continue;\n 350вЖТ      }\n 351вЖТ\n 352вЖТ      const version = match[1];\n 353вЖТ      const filePath = path.join(typeDir, file);\n 354вЖТ      const stat = fs.statSync(filePath);\n 355вЖТ\n 356вЖТ      // Try to read and count items\n 357вЖТ      let itemCount = 0;\n 358вЖТ      let isValid = true;\n 359вЖТ      try {\n 360вЖТ        const content = fs.readFileSync(filePath, 'utf-8');\n 361вЖТ        const parsed = JSON.parse(content);\n 362вЖТ        const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 363вЖТ        itemCount = Array.isArray(items) ? items.length : 0;\n 364вЖТ      } catch {\n 365вЖТ        isValid = false;\n 366вЖТ      }\n 367вЖТ\n 368вЖТ      versions.push({\n 369вЖТ        version,\n 370вЖТ        timestamp: stat.mtime,\n 371вЖТ        size: stat.size,\n 372вЖТ        itemCount,\n 373вЖТ        isValid\n 374вЖТ      });\n 375вЖТ    }\n 376вЖТ\n 377вЖТ    // Sort by version descending (newest first)\n 378вЖТ    versions.sort((a, b) => b.version.localeCompare(a.version));\n 379вЖТ\n 380вЖТ    return versions;\n 381вЖТ  }\n 382вЖТ\n 383вЖТ  /**\n 384вЖТ   * Get content of a specific version.\n 385вЖТ   * @param {PlanType} type - Plan type\n 386вЖТ   * @param {string} version - Version identifier\n 387вЖТ   * @returns {Promise<string | null>}\n 388вЖТ   */\n 389вЖТ  async function getVersion(type, version) {\n 390вЖТ    const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 391вЖТ    if (!fs.existsSync(versionPath)) {\n 392вЖТ      return null;\n 393вЖТ    }\n 394вЖТ    return fs.readFileSync(versionPath, 'utf-8');\n 395вЖТ  }\n 396вЖТ\n 397вЖТ  /**\n 398вЖТ   * Get path to _current.json file.\n 399вЖТ   * @param {PlanType} type - Plan type\n 400вЖТ   * @returns {string}\n 401вЖТ   */\n 402вЖТ  function getCurrentMetaPath(type) {\n 403вЖТ    return path.join(getTypeDir(type), '_current.json');\n 404вЖТ  }\n 405вЖТ\n 406вЖТ  /**\n 407вЖТ   * Set the current active version.\n 408вЖТ   * @param {PlanType} type - Plan type\n 409вЖТ   * @param {string} version - Version to activate\n 410вЖТ   * @returns {Promise<boolean>}\n 411вЖТ   */\n 412вЖТ  async function setCurrent(type, version) {\n 413вЖТ    // Verify version exists\n 414вЖТ    const versionPath = path.join(getTypeDir(type), `${version}.json`);\n 415вЖТ    if (!fs.existsSync(versionPath)) {\n 416вЖТ      return false;\n 417вЖТ    }\n 418вЖТ\n 419вЖТ    // Read content to get item count\n 420вЖТ    let itemCount = 0;\n 421вЖТ    try {\n 422вЖТ      const content = fs.readFileSync(versionPath, 'utf-8');\n 423вЖТ      const parsed = JSON.parse(content);\n 424вЖТ      const items = type === 'feature-list' ? parsed.features : parsed.bugs;\n 425вЖТ      itemCount = Array.isArray(items) ? items.length : 0;\n 426вЖТ    } catch {\n 427вЖТ      // Ignore\n 428вЖТ    }\n 429вЖТ\n 430вЖТ    // Write _current.json\n 431вЖТ    const currentMeta = {\n 432вЖТ      version,\n 433вЖТ      activatedAt: new Date().toISOString(),\n 434вЖТ      path: versionPath,\n 435вЖТ      itemCount\n 436вЖТ    };\n 437вЖТ\n 438вЖТ    const currentMetaPath = getCurrentMetaPath(type);\n 439вЖТ    fs.writeFileSync(currentMetaPath, JSON.stringify(currentMeta, null, 2), 'utf-8');\n 440вЖТ\n 441вЖТ    return true;\n 442вЖТ  }\n 443вЖТ\n 444вЖТ  /**\n 445вЖТ   * Get current active version metadata.\n 446вЖТ   * @param {PlanType} type - Plan type\n 447вЖТ   * @returns {Promise<ActiveMeta | null>}\n 448вЖТ   */\n 449вЖТ  async function getCurrent(type) {\n 450вЖТ    const currentMetaPath = getCurrentMetaPath(type);\n 451вЖТ    if (!fs.existsSync(currentMetaPath)) {\n 452вЖТ      return null;\n 453вЖТ    }\n 454вЖТ\n 455вЖТ    try {\n 456вЖТ      const content = fs.readFileSync(currentMetaPath, 'utf-8');\n 457вЖТ      const meta = JSON.parse(content);\n 458вЖТ\n 459вЖТ      return {\n 460вЖТ        version: meta.version,\n 461вЖТ        path: meta.path,\n 462вЖТ        lastModified: new Date(meta.activatedAt),\n 463вЖТ        itemCount: meta.itemCount || 0\n 464вЖТ      };\n 465вЖТ    } catch {\n 466вЖТ      return null;\n 467вЖТ    }\n 468вЖТ  }\n 469вЖТ\n 470вЖТ  /**\n 471вЖТ   * Get path to the current active version file.\n 472вЖТ   * @param {PlanType} type - Plan type\n 473вЖТ   * @returns {string | null}\n 474вЖТ   */\n 475вЖТ  function getActivePath(type) {\n 476вЖТ    const currentMetaPath = getCurrentMetaPath(type);\n 477вЖТ    if (!fs.existsSync(currentMetaPath)) {\n 478вЖТ      return null;\n 479вЖТ    }\n 480вЖТ\n 481вЖТ    try {\n 482вЖТ      const content = fs.readFileSync(currentMetaPath, 'utf-8');\n 483вЖТ      const meta = JSON.parse(content);\n 484вЖТ      return meta.path || null;\n 485вЖТ    } catch {\n 486вЖТ      return null;\n 487вЖТ    }\n 488вЖТ  }\n 489вЖТ\n 490вЖТ  /**\n 491вЖТ   * Rollback to previous version.\n 492вЖТ   * @param {PlanType} type - Plan type\n 493вЖТ   * @returns {Promise<RollbackResult | null>}\n 494вЖТ   */\n 495вЖТ  async function rollback(type) {\n 496вЖТ    const versions = await listVersions(type);\n 497вЖТ    if (versions.length < 2) {\n 498вЖТ      return null;\n 499вЖТ    }\n 500вЖТ\n 501вЖТ    const current = await getCurrent(type);\n 502вЖТ    if (!current) {\n 503вЖТ      return null;\n 504вЖТ    }\n 505вЖТ\n 506вЖТ    // Find current version index\n 507вЖТ    const currentIndex = versions.findIndex((v) => v.version === current.version);\n 508вЖТ    if (currentIndex === -1 || currentIndex >= versions.length - 1) {\n 509вЖТ      return null;\n 510вЖТ    }\n 511вЖТ\n 512вЖТ    // Get previous version\n 513вЖТ    const previousVersion = versions[currentIndex + 1];\n 514вЖТ    if (!previousVersion) {\n 515вЖТ      return null;\n 516вЖТ    }\n 517вЖТ\n 518вЖТ    // Set previous as current\n 519вЖТ    const success = await setCurrent(type, previousVersion.version);\n 520вЖТ    if (!success) {\n 521вЖТ      return null;\n 522вЖТ    }\n 523вЖТ\n 524вЖТ    return {\n 525вЖТ      previousVersion: current.version,\n 526вЖТ      currentVersion: previousVersion.version\n 527вЖТ    };\n 528вЖТ  }\n 529вЖТ\n 530вЖТ  return {\n 531вЖТ    loadSchema,\n 532вЖТ    validate,\n 533вЖТ    formatValidationErrors,\n 534вЖТ    save,\n 535вЖТ    listVersions,\n 536вЖТ    getVersion,\n 537вЖТ    setCurrent,\n 538вЖТ    getCurrent,\n 539вЖТ    getActivePath,\n 540вЖТ    rollback\n 541вЖТ  };\n 542вЖТ}\n 543вЖТ\n 544вЖТexport default createPlanIngestionService;\n 545вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:05:29.052Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"c293fe26-4cb4-4eab-b723-8d9bade7a16d","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"call_273993b1d9284e2eb920a134","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Tests for plan-ingestion-service.js\n   3вЖТ * Covers T-010 (schema loader), T-011 (plan validator), T-012 (version manager),\n   4вЖТ * T-013 (plan registry), T-014 (error formatting)\n   5вЖТ */\n   6вЖТimport test from 'node:test';\n   7вЖТimport assert from 'node:assert/strict';\n   8вЖТimport os from 'node:os';\n   9вЖТimport path from 'node:path';\n  10вЖТimport fs from 'node:fs';\n  11вЖТimport { fileURLToPath } from 'node:url';\n  12вЖТ\n  13вЖТconst __dirname = path.dirname(fileURLToPath(import.meta.url));\n  14вЖТconst PROJECT_ROOT = path.resolve(__dirname, '../..');\n  15вЖТ\n  16вЖТ// We'll import dynamically after setup\n  17вЖТlet createPlanIngestionService;\n  18вЖТ\n  19вЖТfunction createTempPlansDir() {\n  20вЖТ  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'prizmclaw-plans-'));\n  21вЖТ  fs.mkdirSync(path.join(tempDir, 'feature-list'), { recursive: true });\n  22вЖТ  fs.mkdirSync(path.join(tempDir, 'bug-fix-list'), { recursive: true });\n  23вЖТ  return tempDir;\n  24вЖТ}\n  25вЖТ\n  26вЖТfunction createValidFeatureList() {\n  27вЖТ  return JSON.stringify({\n  28вЖТ    $schema: 'dev-pipeline-feature-list-v1',\n  29вЖТ    app_name: 'TestApp',\n  30вЖТ    app_description: 'A test application',\n  31вЖТ    features: [\n  32вЖТ      {\n  33вЖТ        id: 'F-001',\n  34вЖТ        title: 'Test Feature',\n  35вЖТ        description: 'A test feature',\n  36вЖТ        priority: 1,\n  37вЖТ        dependencies: [],\n  38вЖТ        acceptance_criteria: ['AC1: Test passes'],\n  39вЖТ        status: 'pending'\n  40вЖТ      }\n  41вЖТ    ]\n  42вЖТ  });\n  43вЖТ}\n  44вЖТ\n  45вЖТfunction createValidBugFixList() {\n  46вЖТ  return JSON.stringify({\n  47вЖТ    $schema: 'dev-pipeline-bug-fix-list-v1',\n  48вЖТ    project_name: 'TestProject',\n  49вЖТ    bugs: [\n  50вЖТ      {\n  51вЖТ        id: 'B-001',\n  52вЖТ        title: 'Test Bug',\n  53вЖТ        description: 'A test bug',\n  54вЖТ        severity: 'medium',\n  55вЖТ        error_source: { type: 'user_report' },\n  56вЖТ        verification_type: 'manual',\n  57вЖТ        acceptance_criteria: ['AC1: Bug is fixed'],\n  58вЖТ        status: 'pending'\n  59вЖТ      }\n  60вЖТ    ]\n  61вЖТ  });\n  62вЖТ}\n  63вЖТ\n  64вЖТ// ============================================================\n  65вЖТ// T-010: Schema Loader Tests\n  66вЖТ// ============================================================\n  67вЖТtest('T-010: loadSchema should load feature-list schema', async () => {\n  68вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  69вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  70вЖТ\n  71вЖТ  const schema = service.loadSchema('feature-list');\n  72вЖТ  assert.ok(schema);\n  73вЖТ  assert.equal(typeof schema, 'object'); // Raw schema object\n  74вЖТ});\n  75вЖТ\n  76вЖТtest('T-010: loadSchema should load bug-fix-list schema', async () => {\n  77вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  78вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  79вЖТ\n  80вЖТ  const schema = service.loadSchema('bug-fix-list');\n  81вЖТ  assert.ok(schema);\n  82вЖТ  assert.equal(typeof schema, 'object'); // Raw schema object\n  83вЖТ});\n  84вЖТ\n  85вЖТtest('T-010: loadSchema should throw for unknown schema type', async () => {\n  86вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n  87вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n  88вЖТ\n  89вЖТ  assert.throws(\n  90вЖТ    () => service.loadSchema('unknown-type'),\n  91вЖТ    /unknown.*schema/i\n  92вЖТ  );\n  93вЖТ});\n  94вЖТ\n  95вЖТ// ============================================================\n  96вЖТ// T-011: Plan Validator Tests\n  97вЖТ// ============================================================\n  98вЖТtest('T-011: validate should identify feature-list type', async () => {\n  99вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 100вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 101вЖТ\n 102вЖТ  const result = service.validate(createValidFeatureList());\n 103вЖТ\n 104вЖТ  assert.equal(result.valid, true);\n 105вЖТ  assert.equal(result.type, 'feature-list');\n 106вЖТ  assert.ok(result.summary);\n 107вЖТ  assert.equal(result.summary.name, 'TestApp');\n 108вЖТ  assert.equal(result.summary.itemCount, 1);\n 109вЖТ});\n 110вЖТ\n 111вЖТtest('T-011: validate should identify bug-fix-list type', async () => {\n 112вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 113вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 114вЖТ\n 115вЖТ  const result = service.validate(createValidBugFixList());\n 116вЖТ\n 117вЖТ  assert.equal(result.valid, true);\n 118вЖТ  assert.equal(result.type, 'bug-fix-list');\n 119вЖТ  assert.ok(result.summary);\n 120вЖТ  assert.equal(result.summary.name, 'TestProject');\n 121вЖТ  assert.equal(result.summary.itemCount, 1);\n 122вЖТ});\n 123вЖТ\n 124вЖТtest('T-011: validate should return unknown type for missing schema', async () => {\n 125вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 126вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 127вЖТ\n 128вЖТ  const result = service.validate(JSON.stringify({ foo: 'bar' }));\n 129вЖТ\n 130вЖТ  assert.equal(result.valid, false);\n 131вЖТ  assert.equal(result.type, 'unknown');\n 132вЖТ});\n 133вЖТ\n 134вЖТtest('T-011: validate should return field-level errors', async () => {\n 135вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 136вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 137вЖТ\n 138вЖТ  const invalidContent = JSON.stringify({\n 139вЖТ    $schema: 'dev-pipeline-feature-list-v1',\n 140вЖТ    app_name: 'TestApp',\n 141вЖТ    features: [\n 142вЖТ      {\n 143вЖТ        id: 'INVALID-ID', // Should match F-\\\\d{3}\n 144вЖТ        title: 'Test',\n 145вЖТ        description: 'Test',\n 146вЖТ        priority: -1, // Should be >= 1\n 147вЖТ        dependencies: [],\n 148вЖТ        acceptance_criteria: [],\n 149вЖТ        status: 'invalid-status'\n 150вЖТ      }\n 151вЖТ    ]\n 152вЖТ  });\n 153вЖТ\n 154вЖТ  const result = service.validate(invalidContent);\n 155вЖТ\n 156вЖТ  assert.equal(result.valid, false);\n 157вЖТ  assert.ok(result.errors.length > 0);\n 158вЖТ  // Check that errors have path and message\n 159вЖТ  for (const error of result.errors) {\n 160вЖТ    assert.ok(error.path, 'Error should have path');\n 161вЖТ    assert.ok(error.message, 'Error should have message');\n 162вЖТ  }\n 163вЖТ});\n 164вЖТ\n 165вЖТtest('T-011: validate should return status breakdown in summary', async () => {\n 166вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 167вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 168вЖТ\n 169вЖТ  const content = JSON.stringify({\n 170вЖТ    $schema: 'dev-pipeline-feature-list-v1',\n 171вЖТ    app_name: 'TestApp',\n 172вЖТ    features: [\n 173вЖТ      { id: 'F-001', title: 'A', description: 'A', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' },\n 174вЖТ      { id: 'F-002', title: 'B', description: 'B', priority: 2, dependencies: [], acceptance_criteria: ['AC'], status: 'in_progress' },\n 175вЖТ      { id: 'F-003', title: 'C', description: 'C', priority: 3, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 176вЖТ    ]\n 177вЖТ  });\n 178вЖТ\n 179вЖТ  const result = service.validate(content);\n 180вЖТ\n 181вЖТ  assert.equal(result.valid, true);\n 182вЖТ  assert.deepEqual(result.summary.statusBreakdown, { pending: 2, in_progress: 1 });\n 183вЖТ});\n 184вЖТ\n 185вЖТtest('T-011: validate should handle invalid JSON', async () => {\n 186вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 187вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 188вЖТ\n 189вЖТ  const result = service.validate('not valid json');\n 190вЖТ\n 191вЖТ  assert.equal(result.valid, false);\n 192вЖТ  assert.equal(result.type, 'unknown');\n 193вЖТ  assert.ok(result.errors.length > 0);\n 194вЖТ  assert.match(result.errors[0].message, /json/i);\n 195вЖТ});\n 196вЖТ\n 197вЖТ// ============================================================\n 198вЖТ// T-014: Error Formatting Tests\n 199вЖТ// ============================================================\n 200вЖТtest('T-014: formatValidationErrors should format errors with field paths', async () => {\n 201вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 202вЖТ  const service = createPlanIngestionService({ projectRoot: PROJECT_ROOT });\n 203вЖТ\n 204вЖТ  const errors = [\n 205вЖТ    { path: 'features[0].id', message: 'Invalid ID format' },\n 206вЖТ    { path: 'features[1].priority', message: 'Must be positive' }\n 207вЖТ  ];\n 208вЖТ\n 209вЖТ  const formatted = service.formatValidationErrors(errors);\n 210вЖТ\n 211вЖТ  assert.match(formatted, /features\\[0\\].id/);\n 212вЖТ  assert.match(formatted, /Invalid ID format/);\n 213вЖТ  assert.match(formatted, /features\\[1\\].priority/);\n 214вЖТ  assert.match(formatted, /Must be positive/);\n 215вЖТ});\n 216вЖТ\n 217вЖТ// ============================================================\n 218вЖТ// T-012: Version Manager Tests\n 219вЖТ// ============================================================\n 220вЖТtest('T-012: save should create versioned file', async () => {\n 221вЖТ  const plansDir = createTempPlansDir();\n 222вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 223вЖТ  const service = createPlanIngestionService({ plansDir });\n 224вЖТ\n 225вЖТ  const result = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 226вЖТ\n 227вЖТ  assert.equal(result.success, true);\n 228вЖТ  assert.ok(result.version);\n 229вЖТ  assert.match(result.version, /^v\\d{8}-\\d{6}$/);\n 230вЖТ\n 231вЖТ  // Cleanup\n 232вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 233вЖТ});\n 234вЖТ\n 235вЖТtest('T-012: listVersions should return version list', async () => {\n 236вЖТ  const plansDir = createTempPlansDir();\n 237вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 238вЖТ  const service = createPlanIngestionService({ plansDir });\n 239вЖТ\n 240вЖТ  // Save two versions\n 241вЖТ  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 242вЖТ  await new Promise(r => setTimeout(r, 1100)); // Ensure different timestamp\n 243вЖТ  await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 244вЖТ\n 245вЖТ  const versions = await service.listVersions('feature-list');\n 246вЖТ\n 247вЖТ  assert.equal(versions.length, 2);\n 248вЖТ  assert.ok(versions[0].version);\n 249вЖТ  assert.ok(versions[0].timestamp);\n 250вЖТ  assert.ok(versions[0].itemCount);\n 251вЖТ\n 252вЖТ  // Cleanup\n 253вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 254вЖТ});\n 255вЖТ\n 256вЖТtest('T-012: getVersion should return content', async () => {\n 257вЖТ  const plansDir = createTempPlansDir();\n 258вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 259вЖТ  const service = createPlanIngestionService({ plansDir });\n 260вЖТ\n 261вЖТ  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 262вЖТ  const content = await service.getVersion('feature-list', saved.version);\n 263вЖТ\n 264вЖТ  assert.ok(content);\n 265вЖТ  const parsed = JSON.parse(content);\n 266вЖТ  assert.equal(parsed.app_name, 'TestApp');\n 267вЖТ\n 268вЖТ  // Cleanup\n 269вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 270вЖТ});\n 271вЖТ\n 272вЖТtest('T-012: getVersion should return null for non-existent version', async () => {\n 273вЖТ  const plansDir = createTempPlansDir();\n 274вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 275вЖТ  const service = createPlanIngestionService({ plansDir });\n 276вЖТ\n 277вЖТ  const content = await service.getVersion('feature-list', 'v99999999-999999');\n 278вЖТ\n 279вЖТ  assert.equal(content, null);\n 280вЖТ\n 281вЖТ  // Cleanup\n 282вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 283вЖТ});\n 284вЖТ\n 285вЖТ// ============================================================\n 286вЖТ// T-013: Plan Registry Tests\n 287вЖТ// ============================================================\n 288вЖТtest('T-013: setCurrent should update _current.json', async () => {\n 289вЖТ  const plansDir = createTempPlansDir();\n 290вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 291вЖТ  const service = createPlanIngestionService({ plansDir });\n 292вЖТ\n 293вЖТ  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 294вЖТ  const success = await service.setCurrent('feature-list', saved.version);\n 295вЖТ\n 296вЖТ  assert.equal(success, true);\n 297вЖТ\n 298вЖТ  const current = await service.getCurrent('feature-list');\n 299вЖТ  assert.ok(current);\n 300вЖТ  assert.equal(current.version, saved.version);\n 301вЖТ\n 302вЖТ  // Cleanup\n 303вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 304вЖТ});\n 305вЖТ\n 306вЖТtest('T-013: getActivePath should return path to current version', async () => {\n 307вЖТ  const plansDir = createTempPlansDir();\n 308вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 309вЖТ  const service = createPlanIngestionService({ plansDir });\n 310вЖТ\n 311вЖТ  const saved = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 312вЖТ  await service.setCurrent('feature-list', saved.version);\n 313вЖТ\n 314вЖТ  const activePath = service.getActivePath('feature-list');\n 315вЖТ\n 316вЖТ  assert.ok(activePath);\n 317вЖТ  assert.match(activePath, /feature-list/);\n 318вЖТ  assert.match(activePath, new RegExp(saved.version));\n 319вЖТ\n 320вЖТ  // Cleanup\n 321вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 322вЖТ});\n 323вЖТ\n 324вЖТtest('T-013: rollback should switch to previous version', async () => {\n 325вЖТ  const plansDir = createTempPlansDir();\n 326вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 327вЖТ  const service = createPlanIngestionService({ plansDir });\n 328вЖТ\n 329вЖТ  // Save and set first version\n 330вЖТ  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 331вЖТ  await service.setCurrent('feature-list', v1.version);\n 332вЖТ\n 333вЖТ  // Save and set second version\n 334вЖТ  await new Promise(r => setTimeout(r, 1100));\n 335вЖТ  const v2 = await service.save('feature-list', JSON.stringify({\n 336вЖТ    $schema: 'dev-pipeline-feature-list-v1',\n 337вЖТ    app_name: 'TestApp2',\n 338вЖТ    features: [\n 339вЖТ      { id: 'F-001', title: 'Test', description: 'Test', priority: 1, dependencies: [], acceptance_criteria: ['AC'], status: 'pending' }\n 340вЖТ    ]\n 341вЖТ  }), { uploadedBy: 12345 });\n 342вЖТ  await service.setCurrent('feature-list', v2.version);\n 343вЖТ\n 344вЖТ  // Rollback\n 345вЖТ  const result = await service.rollback('feature-list');\n 346вЖТ\n 347вЖТ  assert.ok(result);\n 348вЖТ  assert.equal(result.previousVersion, v2.version);\n 349вЖТ  assert.equal(result.currentVersion, v1.version);\n 350вЖТ\n 351вЖТ  // Cleanup\n 352вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 353вЖТ});\n 354вЖТ\n 355вЖТtest('T-013: rollback should return null when no previous version', async () => {\n 356вЖТ  const plansDir = createTempPlansDir();\n 357вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 358вЖТ  const service = createPlanIngestionService({ plansDir });\n 359вЖТ\n 360вЖТ  // Only one version\n 361вЖТ  const v1 = await service.save('feature-list', createValidFeatureList(), { uploadedBy: 12345 });\n 362вЖТ  await service.setCurrent('feature-list', v1.version);\n 363вЖТ\n 364вЖТ  const result = await service.rollback('feature-list');\n 365вЖТ\n 366вЖТ  assert.equal(result, null);\n 367вЖТ\n 368вЖТ  // Cleanup\n 369вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 370вЖТ});\n 371вЖТ\n 372вЖТtest('T-013: getCurrent should return null when no version set', async () => {\n 373вЖТ  const plansDir = createTempPlansDir();\n 374вЖТ  const { createPlanIngestionService } = await import('../../src/services/plan-ingestion-service.js');\n 375вЖТ  const service = createPlanIngestionService({ plansDir });\n 376вЖТ\n 377вЖТ  const current = await service.getCurrent('feature-list');\n 378вЖТ\n 379вЖТ  assert.equal(current, null);\n 380вЖТ\n 381вЖТ  // Cleanup\n 382вЖТ  fs.rmSync(plansDir, { recursive: true, force: true });\n 383вЖТ});\n 384вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb77959cce91c4c30f48375af46","__timestamp":"2026-03-11T21:05:29.062Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
