{"type":"user","uuid":"e6d491f5-b263-4d4e-adbb-06588826e163","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeb56df429d2334b03265a4e374a","content":[{"type":"text","text":"   1вЖТimport test from 'node:test';\n   2вЖТimport assert from 'node:assert/strict';\n   3вЖТimport { parseCommand } from '../../../src/bot/commands/parser.js';\n   4вЖТ\n   5вЖТtest('parseCommand returns null for non-command text', () => {\n   6вЖТ  assert.equal(parseCommand('hello world'), null);\n   7вЖТ  assert.equal(parseCommand(''), null);\n   8вЖТ  assert.equal(parseCommand(null), null);\n   9вЖТ  assert.equal(parseCommand(undefined), null);\n  10вЖТ});\n  11вЖТ\n  12вЖТtest('parseCommand parses basic command', () => {\n  13вЖТ  const result = parseCommand('/start');\n  14вЖТ  assert.deepEqual(result, {\n  15вЖТ    command: 'start',\n  16вЖТ    subcommand: undefined,\n  17вЖТ    args: [],\n  18вЖТ    options: {},\n  19вЖТ    raw: '/start'\n  20вЖТ  });\n  21вЖТ});\n  22вЖТ\n  23вЖТtest('parseCommand parses command with subcommand', () => {\n  24вЖТ  const result = parseCommand('/pipeline run');\n  25вЖТ  assert.equal(result.command, 'pipeline');\n  26вЖТ  assert.equal(result.subcommand, 'run');\n  27вЖТ});\n  28вЖТ\n  29вЖТtest('parseCommand parses command with positional args', () => {\n  30вЖТ  const result = parseCommand('/bugfix session-123');\n  31вЖТ  assert.equal(result.command, 'bugfix');\n  32вЖТ  assert.deepEqual(result.args, []);\n  33вЖТ  // First token after command is treated as subcommand if it doesn't start with --\n  34вЖТ  assert.equal(result.subcommand, 'session-123');\n  35вЖТ});\n  36вЖТ\n  37вЖТtest('parseCommand parses --key=value options', () => {\n  38вЖТ  const result = parseCommand('/pipeline run --type=bugfix');\n  39вЖТ  assert.equal(result.command, 'pipeline');\n  40вЖТ  assert.equal(result.subcommand, 'run');\n  41вЖТ  assert.deepEqual(result.options, { type: 'bugfix' });\n  42вЖТ});\n  43вЖТ\n  44вЖТtest('parseCommand parses multiple options', () => {\n  45вЖТ  const result = parseCommand('/pipeline run --type=feature --verbose');\n  46вЖТ  assert.deepEqual(result.options, { type: 'feature', verbose: 'true' });\n  47вЖТ});\n  48вЖТ\n  49вЖТtest('parseCommand parses key=value without --', () => {\n  50вЖТ  const result = parseCommand('/pipeline run type=bugfix');\n  51вЖТ  assert.deepEqual(result.options, { type: 'bugfix' });\n  52вЖТ});\n  53вЖТ\n  54вЖТtest('parseCommand applies alias mapping', () => {\n  55вЖТ  const aliasMap = { p: 'pipeline', b: 'bugfix' };\n  56вЖТ  const result = parseCommand('/p run', aliasMap);\n  57вЖТ  assert.equal(result.command, 'pipeline');\n  58вЖТ  assert.equal(result.subcommand, 'run');\n  59вЖТ});\n  60вЖТ\n  61вЖТtest('parseCommand handles @bot suffix', () => {\n  62вЖТ  const result = parseCommand('/start@mybot');\n  63вЖТ  assert.equal(result.command, 'start');\n  64вЖТ});\n  65вЖТ\n  66вЖТtest('parseCommand normalizes command to lowercase', () => {\n  67вЖТ  const result = parseCommand('/PIPELINE RUN');\n  68вЖТ  assert.equal(result.command, 'pipeline');\n  69вЖТ  assert.equal(result.subcommand, 'run');\n  70вЖТ});\n  71вЖТ\n  72вЖТtest('parseCommand collects positional args after options', () => {\n  73вЖТ  const result = parseCommand('/pipeline run my-feature --type=bugfix');\n  74вЖТ  assert.equal(result.subcommand, 'run');\n  75вЖТ  assert.deepEqual(result.options, { type: 'bugfix' });\n  76вЖТ  // Args should be empty since first token after subcommand is captured\n  77вЖТ});\n  78вЖТ\n  79вЖТtest('parseCommand handles complex command', () => {\n  80вЖТ  const aliasMap = { p: 'pipeline' };\n  81вЖТ  const result = parseCommand('/p run my-feature --type=bugfix --verbose', aliasMap);\n  82вЖТ  assert.equal(result.command, 'pipeline');\n  83вЖТ  assert.equal(result.subcommand, 'run');\n  84вЖТ  assert.deepEqual(result.options, { type: 'bugfix', verbose: 'true' });\n  85вЖТ});\n  86вЖТ\n  87вЖТtest('parseCommand preserves raw text', () => {\n  88вЖТ  const text = '/pipeline run --type=bugfix';\n  89вЖТ  const result = parseCommand(text);\n  90вЖТ  assert.equal(result.raw, text);\n  91вЖТ});\n  92вЖТ\n  93вЖТtest('parseCommand handles empty options gracefully', () => {\n  94вЖТ  const result = parseCommand('/status');\n  95вЖТ  assert.deepEqual(result.options, {});\n  96вЖТ  assert.deepEqual(result.args, []);\n  97вЖТ});\n  98вЖТ\n  99вЖТtest('parseCommand parses /logs with target', () => {\n 100вЖТ  const result = parseCommand('/logs session-123');\n 101вЖТ  assert.equal(result.command, 'logs');\n 102вЖТ  assert.equal(result.subcommand, 'session-123');\n 103вЖТ});\n 104вЖТ\n 105вЖТtest('parseCommand parses /stop with target', () => {\n 106вЖТ  const result = parseCommand('/stop my-feature');\n 107вЖТ  assert.equal(result.command, 'stop');\n 108вЖТ  assert.equal(result.subcommand, 'my-feature');\n 109вЖТ});\n 110вЖТ\n 111вЖТtest('parseCommand handles alias /s for status', () => {\n 112вЖТ  const aliasMap = { s: 'status' };\n 113вЖТ  const result = parseCommand('/s', aliasMap);\n 114вЖТ  assert.equal(result.command, 'status');\n 115вЖТ});\n 116вЖТ\n 117вЖТtest('parseCommand handles alias /l for logs', () => {\n 118вЖТ  const aliasMap = { l: 'logs' };\n 119вЖТ  const result = parseCommand('/l session-123', aliasMap);\n 120вЖТ  assert.equal(result.command, 'logs');\n 121вЖТ});\n 122вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb501d230bfbd675b221fe70d04","__timestamp":"2026-03-11T21:02:39.664Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"1fbf89da-3c2f-4d40-8f69-e9623906ff40","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeb56f6a156ddf827a3ac9377e02","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Tests for permission-guard.js\n   3вЖТ * F-006: Safety and Permission Guard\n   4вЖТ */\n   5вЖТ\n   6вЖТimport test from 'node:test';\n   7вЖТimport assert from 'node:assert/strict';\n   8вЖТimport {\n   9вЖТ  getUserRole,\n  10вЖТ  checkCommandPermission,\n  11вЖТ  isAdmin,\n  12вЖТ  ROLE_HIERARCHY,\n  13вЖТ  setConfigForTesting,\n  14вЖТ  resetConfig\n  15вЖТ} from '../../src/security/permission-guard.js';\n  16вЖТ\n  17вЖТ// Helper to create test config\n  18вЖТfunction createTestConfig(overrides = {}) {\n  19вЖТ  return {\n  20вЖТ    userPermissions: new Map(),\n  21вЖТ    allowAdminSkipConfirm: true,\n  22вЖТ    enableSystemExec: false,\n  23вЖТ    allowedUserIds: new Set(),\n  24вЖТ    ...overrides\n  25вЖТ  };\n  26вЖТ}\n  27вЖТ\n  28вЖТ// ROLE_HIERARCHY tests\n  29вЖТtest('ROLE_HIERARCHY defines correct hierarchy levels', () => {\n  30вЖТ  resetConfig();\n  31вЖТ  assert.equal(ROLE_HIERARCHY.viewer, 0);\n  32вЖТ  assert.equal(ROLE_HIERARCHY.operator, 1);\n  33вЖТ  assert.equal(ROLE_HIERARCHY.admin, 2);\n  34вЖТ});\n  35вЖТ\n  36вЖТ// getUserRole tests\n  37вЖТtest('getUserRole returns admin for configured admin user', () => {\n  38вЖТ  resetConfig();\n  39вЖТ  const config = createTestConfig();\n  40вЖТ  config.userPermissions.set('123456789', 'admin');\n  41вЖТ  setConfigForTesting(config);\n  42вЖТ\n  43вЖТ  assert.equal(getUserRole('123456789'), 'admin');\n  44вЖТ});\n  45вЖТ\n  46вЖТtest('getUserRole returns operator for configured operator user', () => {\n  47вЖТ  resetConfig();\n  48вЖТ  const config = createTestConfig();\n  49вЖТ  config.userPermissions.set('987654321', 'operator');\n  50вЖТ  setConfigForTesting(config);\n  51вЖТ\n  52вЖТ  assert.equal(getUserRole('987654321'), 'operator');\n  53вЖТ});\n  54вЖТ\n  55вЖТtest('getUserRole returns viewer for configured viewer user', () => {\n  56вЖТ  resetConfig();\n  57вЖТ  const config = createTestConfig();\n  58вЖТ  config.userPermissions.set('111222333', 'viewer');\n  59вЖТ  setConfigForTesting(config);\n  60вЖТ\n  61вЖТ  assert.equal(getUserRole('111222333'), 'viewer');\n  62вЖТ});\n  63вЖТ\n  64вЖТtest('getUserRole returns operator as default for unknown users (AC-1.3)', () => {\n  65вЖТ  resetConfig();\n  66вЖТ  setConfigForTesting(createTestConfig());\n  67вЖТ  assert.equal(getUserRole('unknown-user'), 'operator');\n  68вЖТ});\n  69вЖТ\n  70вЖТtest('getUserRole handles numeric userId', () => {\n  71вЖТ  resetConfig();\n  72вЖТ  const config = createTestConfig();\n  73вЖТ  config.userPermissions.set('123456789', 'admin');\n  74вЖТ  setConfigForTesting(config);\n  75вЖТ\n  76вЖТ  assert.equal(getUserRole(123456789), 'admin');\n  77вЖТ});\n  78вЖТ\n  79вЖТ// isAdmin tests\n  80вЖТtest('isAdmin returns true for admin user', () => {\n  81вЖТ  resetConfig();\n  82вЖТ  const config = createTestConfig();\n  83вЖТ  config.userPermissions.set('123456789', 'admin');\n  84вЖТ  setConfigForTesting(config);\n  85вЖТ\n  86вЖТ  assert.equal(isAdmin('123456789'), true);\n  87вЖТ});\n  88вЖТ\n  89вЖТtest('isAdmin returns false for operator user', () => {\n  90вЖТ  resetConfig();\n  91вЖТ  const config = createTestConfig();\n  92вЖТ  config.userPermissions.set('987654321', 'operator');\n  93вЖТ  setConfigForTesting(config);\n  94вЖТ\n  95вЖТ  assert.equal(isAdmin('987654321'), false);\n  96вЖТ});\n  97вЖТ\n  98вЖТtest('isAdmin returns false for viewer user', () => {\n  99вЖТ  resetConfig();\n 100вЖТ  const config = createTestConfig();\n 101вЖТ  config.userPermissions.set('111222333', 'viewer');\n 102вЖТ  setConfigForTesting(config);\n 103вЖТ\n 104вЖТ  assert.equal(isAdmin('111222333'), false);\n 105вЖТ});\n 106вЖТ\n 107вЖТtest('isAdmin returns false for unknown user (default is operator)', () => {\n 108вЖТ  resetConfig();\n 109вЖТ  setConfigForTesting(createTestConfig());\n 110вЖТ  assert.equal(isAdmin('unknown-user'), false);\n 111вЖТ});\n 112вЖТ\n 113вЖТ// checkCommandPermission - status command (viewer)\n 114вЖТtest('checkCommandPermission allows viewer to execute status', () => {\n 115вЖТ  resetConfig();\n 116вЖТ  const config = createTestConfig();\n 117вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 118вЖТ  setConfigForTesting(config);\n 119вЖТ\n 120вЖТ  const result = checkCommandPermission('viewer-user', 'status');\n 121вЖТ  assert.equal(result.allowed, true);\n 122вЖТ  assert.equal(result.requiresConfirmation, false);\n 123вЖТ});\n 124вЖТ\n 125вЖТ// checkCommandPermission - logs command (viewer)\n 126вЖТtest('checkCommandPermission allows viewer to execute logs', () => {\n 127вЖТ  resetConfig();\n 128вЖТ  const config = createTestConfig();\n 129вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 130вЖТ  setConfigForTesting(config);\n 131вЖТ\n 132вЖТ  const result = checkCommandPermission('viewer-user', 'logs');\n 133вЖТ  assert.equal(result.allowed, true);\n 134вЖТ  assert.equal(result.requiresConfirmation, false);\n 135вЖТ});\n 136вЖТ\n 137вЖТ// checkCommandPermission - pipeline command (operator)\n 138вЖТtest('checkCommandPermission allows operator to execute pipeline', () => {\n 139вЖТ  resetConfig();\n 140вЖТ  const config = createTestConfig();\n 141вЖТ  config.userPermissions.set('op-user', 'operator');\n 142вЖТ  setConfigForTesting(config);\n 143вЖТ\n 144вЖТ  const result = checkCommandPermission('op-user', 'pipeline');\n 145вЖТ  assert.equal(result.allowed, true);\n 146вЖТ});\n 147вЖТ\n 148вЖТtest('checkCommandPermission denies viewer for pipeline', () => {\n 149вЖТ  resetConfig();\n 150вЖТ  const config = createTestConfig();\n 151вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 152вЖТ  setConfigForTesting(config);\n 153вЖТ\n 154вЖТ  const result = checkCommandPermission('viewer-user', 'pipeline');\n 155вЖТ  assert.equal(result.allowed, false);\n 156вЖТ  assert.ok(result.reason.includes('жЭГйЩРдЄНиґ≥'));\n 157вЖТ});\n 158вЖТ\n 159вЖТ// checkCommandPermission - retry command (operator) - AC-2.3\n 160вЖТtest('checkCommandPermission allows operator for retry without confirmation', () => {\n 161вЖТ  resetConfig();\n 162вЖТ  const config = createTestConfig();\n 163вЖТ  config.userPermissions.set('op-user', 'operator');\n 164вЖТ  setConfigForTesting(config);\n 165вЖТ\n 166вЖТ  const result = checkCommandPermission('op-user', 'retry');\n 167вЖТ  assert.equal(result.allowed, true);\n 168вЖТ  assert.equal(result.requiresConfirmation, false);\n 169вЖТ});\n 170вЖТ\n 171вЖТtest('checkCommandPermission denies viewer for retry', () => {\n 172вЖТ  resetConfig();\n 173вЖТ  const config = createTestConfig();\n 174вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 175вЖТ  setConfigForTesting(config);\n 176вЖТ\n 177вЖТ  const result = checkCommandPermission('viewer-user', 'retry');\n 178вЖТ  assert.equal(result.allowed, false);\n 179вЖТ});\n 180вЖТ\n 181вЖТ// checkCommandPermission - stop command (admin) - AC-2.2\n 182вЖТtest('checkCommandPermission allows admin for stop with confirmation', () => {\n 183вЖТ  resetConfig();\n 184вЖТ  const config = createTestConfig();\n 185вЖТ  config.userPermissions.set('admin-user', 'admin');\n 186вЖТ  setConfigForTesting(config);\n 187вЖТ\n 188вЖТ  const result = checkCommandPermission('admin-user', 'stop');\n 189вЖТ  assert.equal(result.allowed, true);\n 190вЖТ  assert.equal(result.requiresConfirmation, true);\n 191вЖТ});\n 192вЖТ\n 193вЖТtest('checkCommandPermission denies operator for stop', () => {\n 194вЖТ  resetConfig();\n 195вЖТ  const config = createTestConfig();\n 196вЖТ  config.userPermissions.set('op-user', 'operator');\n 197вЖТ  setConfigForTesting(config);\n 198вЖТ\n 199вЖТ  const result = checkCommandPermission('op-user', 'stop');\n 200вЖТ  assert.equal(result.allowed, false);\n 201вЖТ  assert.ok(result.reason.includes('жЭГйЩРдЄНиґ≥'));\n 202вЖТ});\n 203вЖТ\n 204вЖТtest('checkCommandPermission denies viewer for stop', () => {\n 205вЖТ  resetConfig();\n 206вЖТ  const config = createTestConfig();\n 207вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 208вЖТ  setConfigForTesting(config);\n 209вЖТ\n 210вЖТ  const result = checkCommandPermission('viewer-user', 'stop');\n 211вЖТ  assert.equal(result.allowed, false);\n 212вЖТ});\n 213вЖТ\n 214вЖТ// checkCommandPermission - reset command (admin) - AC-2.2\n 215вЖТtest('checkCommandPermission allows admin for reset with confirmation', () => {\n 216вЖТ  resetConfig();\n 217вЖТ  const config = createTestConfig();\n 218вЖТ  config.userPermissions.set('admin-user', 'admin');\n 219вЖТ  setConfigForTesting(config);\n 220вЖТ\n 221вЖТ  const result = checkCommandPermission('admin-user', 'reset');\n 222вЖТ  assert.equal(result.allowed, true);\n 223вЖТ  assert.equal(result.requiresConfirmation, true);\n 224вЖТ});\n 225вЖТ\n 226вЖТtest('checkCommandPermission denies operator for reset', () => {\n 227вЖТ  resetConfig();\n 228вЖТ  const config = createTestConfig();\n 229вЖТ  config.userPermissions.set('op-user', 'operator');\n 230вЖТ  setConfigForTesting(config);\n 231вЖТ\n 232вЖТ  const result = checkCommandPermission('op-user', 'reset');\n 233вЖТ  assert.equal(result.allowed, false);\n 234вЖТ});\n 235вЖТ\n 236вЖТ// checkCommandPermission - force-unlock command (admin) - F-001\n 237вЖТtest('checkCommandPermission requires admin for force-unlock', () => {\n 238вЖТ  resetConfig();\n 239вЖТ  const config = createTestConfig();\n 240вЖТ  config.userPermissions.set('admin-user', 'admin');\n 241вЖТ  setConfigForTesting(config);\n 242вЖТ\n 243вЖТ  const result = checkCommandPermission('admin-user', 'force-unlock');\n 244вЖТ  assert.equal(result.allowed, true);\n 245вЖТ  assert.equal(result.requiresConfirmation, true);\n 246вЖТ});\n 247вЖТ\n 248вЖТtest('checkCommandPermission denies operator for force-unlock', () => {\n 249вЖТ  resetConfig();\n 250вЖТ  const config = createTestConfig();\n 251вЖТ  config.userPermissions.set('op-user', 'operator');\n 252вЖТ  setConfigForTesting(config);\n 253вЖТ\n 254вЖТ  const result = checkCommandPermission('op-user', 'force-unlock');\n 255вЖТ  assert.equal(result.allowed, false);\n 256вЖТ  assert.ok(result.reason.includes('жЭГйЩРдЄНиґ≥'));\n 257вЖТ});\n 258вЖТ\n 259вЖТ// checkCommandPermission - exec command (admin + ENABLE_SYSTEM_EXEC) - AC-2.4, F-002\n 260вЖТtest('checkCommandPermission denies exec when ENABLE_SYSTEM_EXEC is false', () => {\n 261вЖТ  resetConfig();\n 262вЖТ  const config = createTestConfig({ enableSystemExec: false });\n 263вЖТ  config.userPermissions.set('admin-user', 'admin');\n 264вЖТ  setConfigForTesting(config);\n 265вЖТ\n 266вЖТ  const result = checkCommandPermission('admin-user', 'exec');\n 267вЖТ  assert.equal(result.allowed, false);\n 268вЖТ  assert.ok(result.reason.includes('з≥їзїЯеСљдї§жЙІи°МжЬ™еРѓзФ®'));\n 269вЖТ});\n 270вЖТ\n 271вЖТtest('checkCommandPermission allows admin for exec when ENABLE_SYSTEM_EXEC is true', () => {\n 272вЖТ  resetConfig();\n 273вЖТ  const config = createTestConfig({ enableSystemExec: true });\n 274вЖТ  config.userPermissions.set('admin-user', 'admin');\n 275вЖТ  setConfigForTesting(config);\n 276вЖТ\n 277вЖТ  const result = checkCommandPermission('admin-user', 'exec');\n 278вЖТ  assert.equal(result.allowed, true);\n 279вЖТ  assert.equal(result.requiresConfirmation, false);\n 280вЖТ});\n 281вЖТ\n 282вЖТtest('checkCommandPermission denies operator for exec even when ENABLE_SYSTEM_EXEC is true', () => {\n 283вЖТ  resetConfig();\n 284вЖТ  const config = createTestConfig({ enableSystemExec: true });\n 285вЖТ  config.userPermissions.set('op-user', 'operator');\n 286вЖТ  setConfigForTesting(config);\n 287вЖТ\n 288вЖТ  const result = checkCommandPermission('op-user', 'exec');\n 289вЖТ  assert.equal(result.allowed, false);\n 290вЖТ});\n 291вЖТ\n 292вЖТ// checkCommandPermission - unknown command\n 293вЖТtest('checkCommandPermission allows unknown command by default (defensive but permissive)', () => {\n 294вЖТ  resetConfig();\n 295вЖТ  const config = createTestConfig();\n 296вЖТ  config.userPermissions.set('op-user', 'operator');\n 297вЖТ  setConfigForTesting(config);\n 298вЖТ\n 299вЖТ  const result = checkCommandPermission('op-user', 'unknown-command');\n 300вЖТ  assert.equal(result.allowed, true);\n 301вЖТ  assert.equal(result.requiresConfirmation, false);\n 302вЖТ});\n 303вЖТ\n 304вЖТ// error message security - AC-2.5\n 305вЖТtest('checkCommandPermission does not expose internal paths in error messages', () => {\n 306вЖТ  resetConfig();\n 307вЖТ  const config = createTestConfig();\n 308вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 309вЖТ  setConfigForTesting(config);\n 310вЖТ\n 311вЖТ  const result = checkCommandPermission('viewer-user', 'stop');\n 312вЖТ  assert.ok(!result.reason.includes('/var/'));\n 313вЖТ  assert.ok(!result.reason.includes('/home/'));\n 314вЖТ  assert.ok(!result.reason.includes('config'));\n 315вЖТ});\n 316вЖТ\n 317вЖТtest('checkCommandPermission provides unified denial message', () => {\n 318вЖТ  resetConfig();\n 319вЖТ  const config = createTestConfig();\n 320вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 321вЖТ  setConfigForTesting(config);\n 322вЖТ\n 323вЖТ  const result = checkCommandPermission('viewer-user', 'stop');\n 324вЖТ  assert.ok(result.reason.match(/жЭГйЩРдЄНиґ≥|жЬ™жОИжЭГ/));\n 325вЖТ});\n 326вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb501d230bfbd675b221fe70d04","__timestamp":"2026-03-11T21:02:39.665Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"32fbd938-c49e-4326-9e9f-cbee85c36209","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeb570e125f926b3d6fe3fd61e6e","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Pipeline Controller Unit Tests\n   3вЖТ * Tests for src/services/pipeline-controller.js\n   4вЖТ *\n   5вЖТ * F-004: Pipeline Process Controller - All User Stories\n   6вЖТ */\n   7вЖТ\n   8вЖТimport test from 'node:test';\n   9вЖТimport assert from 'node:assert/strict';\n  10вЖТimport fs from 'node:fs';\n  11вЖТimport path from 'node:path';\n  12вЖТimport os from 'node:os';\n  13вЖТ\n  14вЖТimport { createPipelineController } from '../../src/services/pipeline-controller.js';\n  15вЖТimport { createLockManager } from '../../src/pipeline-infra/lock-manager.js';\n  16вЖТimport { createStateManager } from '../../src/pipeline-infra/state-manager.js';\n  17вЖТ\n  18вЖТ/**\n  19вЖТ * Helper to create temp directory for test state\n  20вЖТ */\n  21вЖТfunction createTempStateDir() {\n  22вЖТ  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'pipeline-controller-test-'));\n  23вЖТ  const stateDir = path.join(tempDir, 'dev-pipeline', 'state');\n  24вЖТ  const bugfixStateDir = path.join(tempDir, 'dev-pipeline', 'bugfix-state');\n  25вЖТ  fs.mkdirSync(stateDir, { recursive: true });\n  26вЖТ  fs.mkdirSync(bugfixStateDir, { recursive: true });\n  27вЖТ  return {\n  28вЖТ    tempDir,\n  29вЖТ    stateDir,\n  30вЖТ    bugfixStateDir,\n  31вЖТ    cleanup: () => {\n  32вЖТ      fs.rmSync(tempDir, { recursive: true, force: true });\n  33вЖТ    }\n  34вЖТ  };\n  35вЖТ}\n  36вЖТ\n  37вЖТ/**\n  38вЖТ * Helper to create a mock config\n  39вЖТ */\n  40вЖТfunction createMockConfig(stateDir, bugfixStateDir) {\n  41вЖТ  const projectRoot = path.dirname(path.dirname(stateDir));\n  42вЖТ  return {\n  43вЖТ    projectRoot,\n  44вЖТ    stateDir,\n  45вЖТ    bugfixStateDir\n  46вЖТ  };\n  47вЖТ}\n  48вЖТ\n  49вЖТ/**\n  50вЖТ * Helper to create a mock script runner\n  51вЖТ */\n  52вЖТfunction createMockScriptRunner() {\n  53вЖТ  return async (req) => ({\n  54вЖТ    ok: true,\n  55вЖТ    exitCode: 0,\n  56вЖТ    stdout: 'Mock output',\n  57вЖТ    stderr: '',\n  58вЖТ    normalizedStatus: 'success'\n  59вЖТ  });\n  60вЖТ}\n  61вЖТ\n  62вЖТ// ============================================================\n  63вЖТ// Factory Tests\n  64вЖТ// ============================================================\n  65вЖТ\n  66вЖТtest('createPipelineController should be a factory function', () => {\n  67вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  68вЖТ  try {\n  69вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n  70вЖТ    const controller = createPipelineController({\n  71вЖТ      config,\n  72вЖТ      lockManager: createLockManager({ config }),\n  73вЖТ      stateManager: createStateManager({ config }),\n  74вЖТ      scriptRunner: createMockScriptRunner()\n  75вЖТ    });\n  76вЖТ\n  77вЖТ    assert.equal(typeof controller.startPipeline, 'function');\n  78вЖТ    assert.equal(typeof controller.stopPipeline, 'function');\n  79вЖТ    assert.equal(typeof controller.retryTarget, 'function');\n  80вЖТ    assert.equal(typeof controller.runSingle, 'function');\n  81вЖТ    assert.equal(typeof controller.getStatus, 'function');\n  82вЖТ    assert.equal(typeof controller.getLogs, 'function');\n  83вЖТ    assert.equal(typeof controller.forceUnlock, 'function');\n  84вЖТ    assert.equal(typeof controller._acquireLock, 'function');\n  85вЖТ    assert.equal(typeof controller._releaseLock, 'function');\n  86вЖТ  } finally {\n  87вЖТ    cleanup();\n  88вЖТ  }\n  89вЖТ});\n  90вЖТ\n  91вЖТtest('createPipelineController should accept dependency injection', () => {\n  92вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n  93вЖТ  try {\n  94вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n  95вЖТ    const lockManager = createLockManager({ config });\n  96вЖТ    const stateManager = createStateManager({ config });\n  97вЖТ    const scriptRunner = createMockScriptRunner();\n  98вЖТ\n  99вЖТ    const controller = createPipelineController({\n 100вЖТ      lockManager,\n 101вЖТ      stateManager,\n 102вЖТ      scriptRunner,\n 103вЖТ      config\n 104вЖТ    });\n 105вЖТ\n 106вЖТ    assert.ok(controller);\n 107вЖТ  } finally {\n 108вЖТ    cleanup();\n 109вЖТ  }\n 110вЖТ});\n 111вЖТ\n 112вЖТ// ============================================================\n 113вЖТ// US-1: startPipeline Tests\n 114вЖТ// ============================================================\n 115вЖТ\n 116вЖТtest('startPipeline should acquire lock before starting daemon', async () => {\n 117вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 118вЖТ  try {\n 119вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 120вЖТ    const lockManager = createLockManager({ config });\n 121вЖТ    const stateManager = createStateManager({ config });\n 122вЖТ    const scriptRunner = createMockScriptRunner();\n 123вЖТ\n 124вЖТ    const controller = createPipelineController({\n 125вЖТ      lockManager,\n 126вЖТ      stateManager,\n 127вЖТ      scriptRunner,\n 128вЖТ      config\n 129вЖТ    });\n 130вЖТ\n 131вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 132вЖТ    assert.equal(result.ok, true);\n 133вЖТ\n 134вЖТ    // Lock should be held\n 135вЖТ    const isLocked = await lockManager.isLocked('feature');\n 136вЖТ    assert.equal(isLocked, true);\n 137вЖТ  } finally {\n 138вЖТ    cleanup();\n 139вЖТ  }\n 140вЖТ});\n 141вЖТ\n 142вЖТtest('startPipeline should handle LOCK_ACQUISITION_FAILED error', async () => {\n 143вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 144вЖТ  try {\n 145вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 146вЖТ    const lockManager = createLockManager({ config });\n 147вЖТ    const stateManager = createStateManager({ config });\n 148вЖТ    const scriptRunner = createMockScriptRunner();\n 149вЖТ\n 150вЖТ    const controller = createPipelineController({\n 151вЖТ      lockManager,\n 152вЖТ      stateManager,\n 153вЖТ      scriptRunner,\n 154вЖТ      config\n 155вЖТ    });\n 156вЖТ\n 157вЖТ    // Acquire lock first\n 158вЖТ    await lockManager.acquireLock('feature', process.pid);\n 159вЖТ\n 160вЖТ    // Try to start again\n 161вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 162вЖТ    assert.equal(result.ok, false);\n 163вЖТ    assert.equal(result.errorCode, 'LOCK_ACQUISITION_FAILED');\n 164вЖТ    assert.ok(result.hint);\n 165вЖТ    assert.ok(result.context);\n 166вЖТ  } finally {\n 167вЖТ    cleanup();\n 168вЖТ  }\n 169вЖТ});\n 170вЖТ\n 171вЖТtest('startPipeline should support daemon mode (default)', async () => {\n 172вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 173вЖТ  try {\n 174вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 175вЖТ    const lockManager = createLockManager({ config });\n 176вЖТ    const stateManager = createStateManager({ config });\n 177вЖТ    const scriptRunner = createMockScriptRunner();\n 178вЖТ\n 179вЖТ    const controller = createPipelineController({\n 180вЖТ      lockManager,\n 181вЖТ      stateManager,\n 182вЖТ      scriptRunner,\n 183вЖТ      config\n 184вЖТ    });\n 185вЖТ\n 186вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 187вЖТ    assert.equal(result.ok, true);\n 188вЖТ    assert.ok(result.runId);\n 189вЖТ  } finally {\n 190вЖТ    cleanup();\n 191вЖТ  }\n 192вЖТ});\n 193вЖТ\n 194вЖТtest('startPipeline should support targetId parameter', async () => {\n 195вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 196вЖТ  try {\n 197вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 198вЖТ    const lockManager = createLockManager({ config });\n 199вЖТ    const stateManager = createStateManager({ config });\n 200вЖТ\n 201вЖТ    let capturedTargetId = null;\n 202вЖТ    const scriptRunner = async (req) => {\n 203вЖТ      capturedTargetId = req.targetId;\n 204вЖТ      return { ok: true, exitCode: 0, stdout: '', stderr: '' };\n 205вЖТ    };\n 206вЖТ\n 207вЖТ    const controller = createPipelineController({\n 208вЖТ      lockManager,\n 209вЖТ      stateManager,\n 210вЖТ      scriptRunner,\n 211вЖТ      config\n 212вЖТ    });\n 213вЖТ\n 214вЖТ    const result = await controller.startPipeline({ type: 'feature', targetId: 'F-001' });\n 215вЖТ    assert.equal(result.ok, true);\n 216вЖТ    assert.equal(capturedTargetId, 'F-001');\n 217вЖТ  } finally {\n 218вЖТ    cleanup();\n 219вЖТ  }\n 220вЖТ});\n 221вЖТ\n 222вЖТtest('startPipeline should work for both feature and bugfix types', async () => {\n 223вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 224вЖТ  try {\n 225вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 226вЖТ    const lockManager = createLockManager({ config });\n 227вЖТ    const stateManager = createStateManager({ config });\n 228вЖТ    const scriptRunner = createMockScriptRunner();\n 229вЖТ\n 230вЖТ    const controller = createPipelineController({\n 231вЖТ      lockManager,\n 232вЖТ      stateManager,\n 233вЖТ      scriptRunner,\n 234вЖТ      config\n 235вЖТ    });\n 236вЖТ\n 237вЖТ    const featureResult = await controller.startPipeline({ type: 'feature' });\n 238вЖТ    assert.equal(featureResult.ok, true);\n 239вЖТ\n 240вЖТ    const bugfixResult = await controller.startPipeline({ type: 'bugfix' });\n 241вЖТ    assert.equal(bugfixResult.ok, true);\n 242вЖТ  } finally {\n 243вЖТ    cleanup();\n 244вЖТ  }\n 245вЖТ});\n 246вЖТ\n 247вЖТ// ============================================================\n 248вЖТ// US-2: stopPipeline Tests\n 249вЖТ// ============================================================\n 250вЖТ\n 251вЖТtest('stopPipeline should release lock after stop', async () => {\n 252вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 253вЖТ  try {\n 254вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 255вЖТ    const lockManager = createLockManager({ config });\n 256вЖТ    const stateManager = createStateManager({ config });\n 257вЖТ    const scriptRunner = createMockScriptRunner();\n 258вЖТ\n 259вЖТ    const controller = createPipelineController({\n 260вЖТ      lockManager,\n 261вЖТ      stateManager,\n 262вЖТ      scriptRunner,\n 263вЖТ      config\n 264вЖТ    });\n 265вЖТ\n 266вЖТ    // Start first (this acquires the lock)\n 267вЖТ    await controller.startPipeline({ type: 'feature' });\n 268вЖТ    assert.equal(await lockManager.isLocked('feature'), true);\n 269вЖТ\n 270вЖТ    // Write daemon meta to simulate running daemon\n 271вЖТ    await stateManager.writeDaemonMeta('feature', {\n 272вЖТ      pid: process.pid,\n 273вЖТ      started_at: new Date().toISOString(),\n 274вЖТ      feature_list: '/path/to/list.json',\n 275вЖТ      env_overrides: '',\n 276вЖТ      log_file: '/path/to/log'\n 277вЖТ    });\n 278вЖТ\n 279вЖТ    // Stop\n 280вЖТ    const result = await controller.stopPipeline({ type: 'feature' });\n 281вЖТ    assert.equal(result.ok, true);\n 282вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 283вЖТ  } finally {\n 284вЖТ    cleanup();\n 285вЖТ  }\n 286вЖТ});\n 287вЖТ\n 288вЖТtest('stopPipeline should return ALREADY_STOPPED if not running', async () => {\n 289вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 290вЖТ  try {\n 291вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 292вЖТ    const lockManager = createLockManager({ config });\n 293вЖТ    const stateManager = createStateManager({ config });\n 294вЖТ    const scriptRunner = createMockScriptRunner();\n 295вЖТ\n 296вЖТ    const controller = createPipelineController({\n 297вЖТ      lockManager,\n 298вЖТ      stateManager,\n 299вЖТ      scriptRunner,\n 300вЖТ      config\n 301вЖТ    });\n 302вЖТ\n 303вЖТ    // Stop without starting\n 304вЖТ    const result = await controller.stopPipeline({ type: 'feature' });\n 305вЖТ    assert.equal(result.ok, true);\n 306вЖТ    assert.equal(result.errorCode, 'ALREADY_STOPPED');\n 307вЖТ  } finally {\n 308вЖТ    cleanup();\n 309вЖТ  }\n 310вЖТ});\n 311вЖТ\n 312вЖТ// ============================================================\n 313вЖТ// US-3: retryTarget Tests\n 314вЖТ// ============================================================\n 315вЖТ\n 316вЖТtest('retryTarget should validate targetId is provided', async () => {\n 317вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 318вЖТ  try {\n 319вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 320вЖТ    const lockManager = createLockManager({ config });\n 321вЖТ    const stateManager = createStateManager({ config });\n 322вЖТ    const scriptRunner = createMockScriptRunner();\n 323вЖТ\n 324вЖТ    const controller = createPipelineController({\n 325вЖТ      lockManager,\n 326вЖТ      stateManager,\n 327вЖТ      scriptRunner,\n 328вЖТ      config\n 329вЖТ    });\n 330вЖТ\n 331вЖТ    const result = await controller.retryTarget({ type: 'feature' });\n 332вЖТ    assert.equal(result.ok, false);\n 333вЖТ    assert.equal(result.errorCode, 'INVALID_TARGET');\n 334вЖТ    assert.ok(result.hint);\n 335вЖТ  } finally {\n 336вЖТ    cleanup();\n 337вЖТ  }\n 338вЖТ});\n 339вЖТ\n 340вЖТtest('retryTarget should support foreground mode (default)', async () => {\n 341вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 342вЖТ  try {\n 343вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 344вЖТ    const lockManager = createLockManager({ config });\n 345вЖТ    const stateManager = createStateManager({ config });\n 346вЖТ    const scriptRunner = createMockScriptRunner();\n 347вЖТ\n 348вЖТ    const controller = createPipelineController({\n 349вЖТ      lockManager,\n 350вЖТ      stateManager,\n 351вЖТ      scriptRunner,\n 352вЖТ      config\n 353вЖТ    });\n 354вЖТ\n 355вЖТ    const result = await controller.retryTarget({ type: 'feature', targetId: 'F-001' });\n 356вЖТ    assert.equal(result.ok, true);\n 357вЖТ    assert.equal(result.targetId, 'F-001');\n 358вЖТ\n 359вЖТ    // Should not hold lock (foreground mode)\n 360вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 361вЖТ  } finally {\n 362вЖТ    cleanup();\n 363вЖТ  }\n 364вЖТ});\n 365вЖТ\n 366вЖТ// ============================================================\n 367вЖТ// US-4: runSingle Tests\n 368вЖТ// ============================================================\n 369вЖТ\n 370вЖТtest('runSingle should NOT acquire lock', async () => {\n 371вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 372вЖТ  try {\n 373вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 374вЖТ    const lockManager = createLockManager({ config });\n 375вЖТ    const stateManager = createStateManager({ config });\n 376вЖТ    const scriptRunner = createMockScriptRunner();\n 377вЖТ\n 378вЖТ    const controller = createPipelineController({\n 379вЖТ      lockManager,\n 380вЖТ      stateManager,\n 381вЖТ      scriptRunner,\n 382вЖТ      config\n 383вЖТ    });\n 384вЖТ\n 385вЖТ    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 386вЖТ    assert.equal(result.ok, true);\n 387вЖТ\n 388вЖТ    // Should not hold lock\n 389вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 390вЖТ  } finally {\n 391вЖТ    cleanup();\n 392вЖТ  }\n 393вЖТ});\n 394вЖТ\n 395вЖТtest('runSingle should return full execution details', async () => {\n 396вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 397вЖТ  try {\n 398вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 399вЖТ    const lockManager = createLockManager({ config });\n 400вЖТ    const stateManager = createStateManager({ config });\n 401вЖТ\n 402вЖТ    const scriptRunner = async () => ({\n 403вЖТ      ok: true,\n 404вЖТ      exitCode: 0,\n 405вЖТ      stdout: 'Test stdout',\n 406вЖТ      stderr: 'Test stderr',\n 407вЖТ      normalizedStatus: 'success'\n 408вЖТ    });\n 409вЖТ\n 410вЖТ    const controller = createPipelineController({\n 411вЖТ      lockManager,\n 412вЖТ      stateManager,\n 413вЖТ      scriptRunner,\n 414вЖТ      config\n 415вЖТ    });\n 416вЖТ\n 417вЖТ    const result = await controller.runSingle({ type: 'feature', targetId: 'F-001' });\n 418вЖТ    assert.equal(result.ok, true);\n 419вЖТ    assert.equal(result.targetId, 'F-001');\n 420вЖТ    assert.equal(result.stdout, 'Test stdout');\n 421вЖТ    assert.equal(result.stderr, 'Test stderr');\n 422вЖТ    assert.equal(result.exitCode, 0);\n 423вЖТ  } finally {\n 424вЖТ    cleanup();\n 425вЖТ  }\n 426вЖТ});\n 427вЖТ\n 428вЖТtest('runSingle should validate targetId', async () => {\n 429вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 430вЖТ  try {\n 431вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 432вЖТ    const lockManager = createLockManager({ config });\n 433вЖТ    const stateManager = createStateManager({ config });\n 434вЖТ    const scriptRunner = createMockScriptRunner();\n 435вЖТ\n 436вЖТ    const controller = createPipelineController({\n 437вЖТ      lockManager,\n 438вЖТ      stateManager,\n 439вЖТ      scriptRunner,\n 440вЖТ      config\n 441вЖТ    });\n 442вЖТ\n 443вЖТ    const result = await controller.runSingle({ type: 'feature' });\n 444вЖТ    assert.equal(result.ok, false);\n 445вЖТ    assert.equal(result.errorCode, 'INVALID_TARGET');\n 446вЖТ  } finally {\n 447вЖТ    cleanup();\n 448вЖТ  }\n 449вЖТ});\n 450вЖТ\n 451вЖТ// ============================================================\n 452вЖТ// US-5: getStatus Tests\n 453вЖТ// ============================================================\n 454вЖТ\n 455вЖТtest('getStatus should return isRunning boolean', async () => {\n 456вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 457вЖТ  try {\n 458вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 459вЖТ    const lockManager = createLockManager({ config });\n 460вЖТ    const stateManager = createStateManager({ config });\n 461вЖТ    const scriptRunner = createMockScriptRunner();\n 462вЖТ\n 463вЖТ    const controller = createPipelineController({\n 464вЖТ      lockManager,\n 465вЖТ      stateManager,\n 466вЖТ      scriptRunner,\n 467вЖТ      config\n 468вЖТ    });\n 469вЖТ\n 470вЖТ    const result = await controller.getStatus({ type: 'feature' });\n 471вЖТ    assert.equal(result.ok, true);\n 472вЖТ    assert.equal(typeof result.isRunning, 'boolean');\n 473вЖТ  } finally {\n 474вЖТ    cleanup();\n 475вЖТ  }\n 476вЖТ});\n 477вЖТ\n 478вЖТtest('getStatus should return lastResult when not running', async () => {\n 479вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 480вЖТ  try {\n 481вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 482вЖТ    const lockManager = createLockManager({ config });\n 483вЖТ    const stateManager = createStateManager({ config });\n 484вЖТ    const scriptRunner = createMockScriptRunner();\n 485вЖТ\n 486вЖТ    // Write last result\n 487вЖТ    const lastResult = {\n 488вЖТ      runId: 'run-test',\n 489вЖТ      completedAt: new Date().toISOString(),\n 490вЖТ      status: 'success',\n 491вЖТ      featuresTotal: 8,\n 492вЖТ      featuresCompleted: 8\n 493вЖТ    };\n 494вЖТ    await stateManager.writeLastResult('feature', lastResult);\n 495вЖТ\n 496вЖТ    const controller = createPipelineController({\n 497вЖТ      lockManager,\n 498вЖТ      stateManager,\n 499вЖТ      scriptRunner,\n 500вЖТ      config\n 501вЖТ    });\n 502вЖТ\n 503вЖТ    const result = await controller.getStatus({ type: 'feature' });\n 504вЖТ    assert.equal(result.ok, true);\n 505вЖТ    assert.deepEqual(result.lastResult, lastResult);\n 506вЖТ  } finally {\n 507вЖТ    cleanup();\n 508вЖТ  }\n 509вЖТ});\n 510вЖТ\n 511вЖТtest('getStatus should return lockInfo', async () => {\n 512вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 513вЖТ  try {\n 514вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 515вЖТ    const lockManager = createLockManager({ config });\n 516вЖТ    const stateManager = createStateManager({ config });\n 517вЖТ    const scriptRunner = createMockScriptRunner();\n 518вЖТ\n 519вЖТ    // Acquire lock\n 520вЖТ    await lockManager.acquireLock('feature', 12345);\n 521вЖТ\n 522вЖТ    const controller = createPipelineController({\n 523вЖТ      lockManager,\n 524вЖТ      stateManager,\n 525вЖТ      scriptRunner,\n 526вЖТ      config\n 527вЖТ    });\n 528вЖТ\n 529вЖТ    const result = await controller.getStatus({ type: 'feature' });\n 530вЖТ    assert.equal(result.ok, true);\n 531вЖТ    assert.ok(result.lockInfo);\n 532вЖТ    assert.equal(result.lockInfo.pid, 12345);\n 533вЖТ  } finally {\n 534вЖТ    cleanup();\n 535вЖТ  }\n 536вЖТ});\n 537вЖТ\n 538вЖТ// ============================================================\n 539вЖТ// US-6: getLogs Tests\n 540вЖТ// ============================================================\n 541вЖТ\n 542вЖТtest('getLogs should return log content', async () => {\n 543вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 544вЖТ  try {\n 545вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 546вЖТ    const lockManager = createLockManager({ config });\n 547вЖТ    const stateManager = createStateManager({ config });\n 548вЖТ    const scriptRunner = createMockScriptRunner();\n 549вЖТ\n 550вЖТ    // Write log file\n 551вЖТ    fs.writeFileSync(path.join(stateDir, 'pipeline-daemon.log'), 'Line 1\\nLine 2\\nLine 3');\n 552вЖТ\n 553вЖТ    const controller = createPipelineController({\n 554вЖТ      lockManager,\n 555вЖТ      stateManager,\n 556вЖТ      scriptRunner,\n 557вЖТ      config\n 558вЖТ    });\n 559вЖТ\n 560вЖТ    const result = await controller.getLogs({ type: 'feature', lines: 10 });\n 561вЖТ    assert.equal(result.ok, true);\n 562вЖТ    assert.ok(result.logs);\n 563вЖТ    assert.ok(result.logPath);\n 564вЖТ    assert.ok(result.lines);\n 565вЖТ  } finally {\n 566вЖТ    cleanup();\n 567вЖТ  }\n 568вЖТ});\n 569вЖТ\n 570вЖТtest('getLogs should handle missing log file gracefully', async () => {\n 571вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 572вЖТ  try {\n 573вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 574вЖТ    const lockManager = createLockManager({ config });\n 575вЖТ    const stateManager = createStateManager({ config });\n 576вЖТ    const scriptRunner = createMockScriptRunner();\n 577вЖТ\n 578вЖТ    const controller = createPipelineController({\n 579вЖТ      lockManager,\n 580вЖТ      stateManager,\n 581вЖТ      scriptRunner,\n 582вЖТ      config\n 583вЖТ    });\n 584вЖТ\n 585вЖТ    const result = await controller.getLogs({ type: 'feature' });\n 586вЖТ    assert.equal(result.ok, true);\n 587вЖТ    assert.equal(result.logs, '');\n 588вЖТ  } finally {\n 589вЖТ    cleanup();\n 590вЖТ  }\n 591вЖТ});\n 592вЖТ\n 593вЖТ// ============================================================\n 594вЖТ// US-7: forceUnlock Tests\n 595вЖТ// ============================================================\n 596вЖТ\n 597вЖТtest('forceUnlock should remove lock regardless of owner', async () => {\n 598вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 599вЖТ  try {\n 600вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 601вЖТ    const lockManager = createLockManager({ config });\n 602вЖТ    const stateManager = createStateManager({ config });\n 603вЖТ    const scriptRunner = createMockScriptRunner();\n 604вЖТ\n 605вЖТ    // Create a lock with a different PID\n 606вЖТ    await lockManager.acquireLock('feature', 99999);\n 607вЖТ\n 608вЖТ    const controller = createPipelineController({\n 609вЖТ      lockManager,\n 610вЖТ      stateManager,\n 611вЖТ      scriptRunner,\n 612вЖТ      config\n 613вЖТ    });\n 614вЖТ\n 615вЖТ    const result = await controller.forceUnlock({ type: 'feature' });\n 616вЖТ    assert.equal(result.ok, true);\n 617вЖТ    assert.equal(result.previousPid, 99999);\n 618вЖТ\n 619вЖТ    // Lock should be released\n 620вЖТ    assert.equal(await lockManager.isLocked('feature'), false);\n 621вЖТ  } finally {\n 622вЖТ    cleanup();\n 623вЖТ  }\n 624вЖТ});\n 625вЖТ\n 626вЖТ// ============================================================\n 627вЖТ// US-8: Error Mapping Tests\n 628вЖТ// ============================================================\n 629вЖТ\n 630вЖТtest('all methods should return JSON-serializable results', async () => {\n 631вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 632вЖТ  try {\n 633вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 634вЖТ    const lockManager = createLockManager({ config });\n 635вЖТ    const stateManager = createStateManager({ config });\n 636вЖТ    const scriptRunner = createMockScriptRunner();\n 637вЖТ\n 638вЖТ    const controller = createPipelineController({\n 639вЖТ      lockManager,\n 640вЖТ      stateManager,\n 641вЖТ      scriptRunner,\n 642вЖТ      config\n 643вЖТ    });\n 644вЖТ\n 645вЖТ    const results = await Promise.all([\n 646вЖТ      controller.startPipeline({ type: 'feature' }),\n 647вЖТ      controller.getStatus({ type: 'feature' }),\n 648вЖТ      controller.getLogs({ type: 'feature' })\n 649вЖТ    ]);\n 650вЖТ\n 651вЖТ    for (const result of results) {\n 652вЖТ      assert.doesNotThrow(() => JSON.stringify(result));\n 653вЖТ    }\n 654вЖТ  } finally {\n 655вЖТ    cleanup();\n 656вЖТ  }\n 657вЖТ});\n 658вЖТ\n 659вЖТtest('errors should include hint field', async () => {\n 660вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 661вЖТ  try {\n 662вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 663вЖТ    const lockManager = createLockManager({ config });\n 664вЖТ    const stateManager = createStateManager({ config });\n 665вЖТ    const scriptRunner = createMockScriptRunner();\n 666вЖТ\n 667вЖТ    // Lock first\n 668вЖТ    await lockManager.acquireLock('feature', process.pid);\n 669вЖТ\n 670вЖТ    const controller = createPipelineController({\n 671вЖТ      lockManager,\n 672вЖТ      stateManager,\n 673вЖТ      scriptRunner,\n 674вЖТ      config\n 675вЖТ    });\n 676вЖТ\n 677вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 678вЖТ    assert.equal(result.ok, false);\n 679вЖТ    assert.ok(result.hint);\n 680вЖТ  } finally {\n 681вЖТ    cleanup();\n 682вЖТ  }\n 683вЖТ});\n 684вЖТ\n 685вЖТtest('errors should include context field', async () => {\n 686вЖТ  const { cleanup, stateDir, bugfixStateDir } = createTempStateDir();\n 687вЖТ  try {\n 688вЖТ    const config = createMockConfig(stateDir, bugfixStateDir);\n 689вЖТ    const lockManager = createLockManager({ config });\n 690вЖТ    const stateManager = createStateManager({ config });\n 691вЖТ    const scriptRunner = createMockScriptRunner();\n 692вЖТ\n 693вЖТ    // Lock first\n 694вЖТ    await lockManager.acquireLock('feature', process.pid);\n 695вЖТ\n 696вЖТ    const controller = createPipelineController({\n 697вЖТ      lockManager,\n 698вЖТ      stateManager,\n 699вЖТ      scriptRunner,\n 700вЖТ      config\n 701вЖТ    });\n 702вЖТ\n 703вЖТ    const result = await controller.startPipeline({ type: 'feature' });\n 704вЖТ    assert.equal(result.ok, false);\n 705вЖТ    assert.ok(result.context);\n 706вЖТ  } finally {\n 707вЖТ    cleanup();\n 708вЖТ  }\n 709вЖТ});\n 710вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb501d230bfbd675b221fe70d04","__timestamp":"2026-03-11T21:02:39.665Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
{"type":"user","uuid":"ba2135b6-de62-4e5e-8be1-57267c7aac24","session_id":"c6ab4c40-f23c-4402-ad6f-43b903645b0a","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeb57274c4c6608b9a0e66d641a7","content":[{"type":"text","text":"   1вЖТ/**\n   2вЖТ * Integration Test for F-006: Safety and Permission Guard\n   3вЖТ * Tests the full security flow end-to-end.\n   4вЖТ */\n   5вЖТ\n   6вЖТimport test from 'node:test';\n   7вЖТimport assert from 'node:assert/strict';\n   8вЖТimport { mkdtemp, rm } from 'node:fs/promises';\n   9вЖТimport { join } from 'node:path';\n  10вЖТimport { tmpdir } from 'node:os';\n  11вЖТimport {\n  12вЖТ  checkCommandPermission,\n  13вЖТ  getUserRole,\n  14вЖТ  isAdmin,\n  15вЖТ  setConfigForTesting,\n  16вЖТ  resetConfig as resetPermConfig\n  17вЖТ} from '../../src/security/permission-guard.js';\n  18вЖТimport {\n  19вЖТ  createConfirmation,\n  20вЖТ  checkConfirmation,\n  21вЖТ  confirmAction,\n  22вЖТ  cancelConfirmation,\n  23вЖТ  clearExpiredConfirmations\n  24вЖТ} from '../../src/security/confirmation-manager.js';\n  25вЖТimport { sanitizeParam, validatePath, detectDangerousPatterns } from '../../src/security/param-sanitizer.js';\n  26вЖТimport {\n  27вЖТ  initAuditLogService,\n  28вЖТ  logAuditEntry,\n  29вЖТ  queryAuditLogs,\n  30вЖТ  resetAuditLogService\n  31вЖТ} from '../../src/services/audit-log-service.js';\n  32вЖТ\n  33вЖТ// Helper to create test config\n  34вЖТfunction createTestConfig(overrides = {}) {\n  35вЖТ  return {\n  36вЖТ    userPermissions: new Map(),\n  37вЖТ    allowAdminSkipConfirm: true,\n  38вЖТ    enableSystemExec: false,\n  39вЖТ    allowedUserIds: new Set(),\n  40вЖТ    ...overrides\n  41вЖТ  };\n  42вЖТ}\n  43вЖТ\n  44вЖТ// Helper to create temp directory for audit log tests\n  45вЖТasync function withTempDir(fn) {\n  46вЖТ  const tempDir = await mkdtemp(join(tmpdir(), 'security-integration-'));\n  47вЖТ  try {\n  48вЖТ    return await fn(tempDir);\n  49вЖТ  } finally {\n  50вЖТ    await rm(tempDir, { recursive: true, force: true });\n  51вЖТ  }\n  52вЖТ}\n  53вЖТ\n  54вЖТ// US-1: User Permission Levels\n  55вЖТtest('US-1: User permission levels work correctly', async () => {\n  56вЖТ  resetPermConfig();\n  57вЖТ  resetAuditLogService();\n  58вЖТ  clearExpiredConfirmations();\n  59вЖТ\n  60вЖТ  const config = createTestConfig();\n  61вЖТ  config.userPermissions.set('admin-user', 'admin');\n  62вЖТ  config.userPermissions.set('op-user', 'operator');\n  63вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n  64вЖТ  setConfigForTesting(config);\n  65вЖТ\n  66вЖТ  // Test role retrieval\n  67вЖТ  assert.equal(getUserRole('admin-user'), 'admin');\n  68вЖТ  assert.equal(getUserRole('op-user'), 'operator');\n  69вЖТ  assert.equal(getUserRole('viewer-user'), 'viewer');\n  70вЖТ  assert.equal(getUserRole('unknown-user'), 'operator'); // Default\n  71вЖТ\n  72вЖТ  // Test isAdmin\n  73вЖТ  assert.equal(isAdmin('admin-user'), true);\n  74вЖТ  assert.equal(isAdmin('op-user'), false);\n  75вЖТ  assert.equal(isAdmin('viewer-user'), false);\n  76вЖТ});\n  77вЖТ\n  78вЖТ// US-2: High-Risk Command Authorization\n  79вЖТtest('US-2: High-risk command authorization works correctly', async () => {\n  80вЖТ  resetPermConfig();\n  81вЖТ  resetAuditLogService();\n  82вЖТ  clearExpiredConfirmations();\n  83вЖТ\n  84вЖТ  const config = createTestConfig();\n  85вЖТ  config.userPermissions.set('admin-user', 'admin');\n  86вЖТ  config.userPermissions.set('op-user', 'operator');\n  87вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n  88вЖТ  setConfigForTesting(config);\n  89вЖТ\n  90вЖТ  // stop command - admin only\n  91вЖТ  const adminStopResult = checkCommandPermission('admin-user', 'stop');\n  92вЖТ  assert.equal(adminStopResult.allowed, true);\n  93вЖТ  assert.equal(adminStopResult.requiresConfirmation, true);\n  94вЖТ\n  95вЖТ  const opStopResult = checkCommandPermission('op-user', 'stop');\n  96вЖТ  assert.equal(opStopResult.allowed, false);\n  97вЖТ\n  98вЖТ  // retry command - operator level\n  99вЖТ  const opRetryResult = checkCommandPermission('op-user', 'retry');\n 100вЖТ  assert.equal(opRetryResult.allowed, true);\n 101вЖТ  assert.equal(opRetryResult.requiresConfirmation, false);\n 102вЖТ\n 103вЖТ  const viewerRetryResult = checkCommandPermission('viewer-user', 'retry');\n 104вЖТ  assert.equal(viewerRetryResult.allowed, false);\n 105вЖТ});\n 106вЖТ\n 107вЖТ// US-3: Parameter Sanitization\n 108вЖТtest('US-3: Parameter sanitization works correctly', async () => {\n 109вЖТ  resetPermConfig();\n 110вЖТ  resetAuditLogService();\n 111вЖТ  clearExpiredConfirmations();\n 112вЖТ\n 113вЖТ  // Valid input passes\n 114вЖТ  const validResult = sanitizeParam('my-feature-123', { maxLength: 100 });\n 115вЖТ  assert.equal(validResult.ok, true);\n 116вЖТ\n 117вЖТ  // Dangerous patterns are blocked\n 118вЖТ  const traversalResult = sanitizeParam('../../../etc/passwd');\n 119вЖТ  assert.equal(traversalResult.ok, false);\n 120вЖТ\n 121вЖТ  const shellInjectionResult = sanitizeParam('$(whoami)');\n 122вЖТ  assert.equal(shellInjectionResult.ok, false);\n 123вЖТ\n 124вЖТ  // TargetId format validation\n 125вЖТ  const validTargetId = sanitizeParam('feature-branch_123', { isTargetId: true });\n 126вЖТ  assert.equal(validTargetId.ok, true);\n 127вЖТ\n 128вЖТ  const invalidTargetId = sanitizeParam('feature/branch', { isTargetId: true });\n 129вЖТ  assert.equal(invalidTargetId.ok, false);\n 130вЖТ\n 131вЖТ  // Path validation\n 132вЖТ  const validPath = validatePath('/project/src/file.js', ['/project']);\n 133вЖТ  assert.equal(validPath.ok, true);\n 134вЖТ\n 135вЖТ  const invalidPath = validatePath('/etc/passwd', ['/project']);\n 136вЖТ  assert.equal(invalidPath.ok, false);\n 137вЖТ});\n 138вЖТ\n 139вЖТ// US-4: Confirmation Flow\n 140вЖТtest('US-4: Confirmation flow works correctly', async () => {\n 141вЖТ  resetPermConfig();\n 142вЖТ  resetAuditLogService();\n 143вЖТ  clearExpiredConfirmations();\n 144вЖТ\n 145вЖТ  // Create confirmation\n 146вЖТ  const { confirmId, message } = createConfirmation('test-user', 'stop', { type: 'feature' });\n 147вЖТ  assert.ok(confirmId);\n 148вЖТ  assert.ok(message);\n 149вЖТ\n 150вЖТ  // Check pending status\n 151вЖТ  const pendingResult = checkConfirmation(confirmId, 'test-user');\n 152вЖТ  assert.equal(pendingResult.status, 'pending');\n 153вЖТ  assert.equal(pendingResult.action, 'stop');\n 154вЖТ\n 155вЖТ  // Confirm action\n 156вЖТ  const confirmResult = confirmAction(confirmId, 'test-user');\n 157вЖТ  assert.equal(confirmResult.ok, true);\n 158вЖТ  assert.equal(confirmResult.action, 'stop');\n 159вЖТ\n 160вЖТ  // Verify consumed\n 161вЖТ  const consumedResult = checkConfirmation(confirmId, 'test-user');\n 162вЖТ  assert.equal(consumedResult.status, 'not_found');\n 163вЖТ});\n 164вЖТ\n 165вЖТtest('US-4: Confirmation cancel works correctly', () => {\n 166вЖТ  resetPermConfig();\n 167вЖТ  resetAuditLogService();\n 168вЖТ  clearExpiredConfirmations();\n 169вЖТ\n 170вЖТ  const { confirmId } = createConfirmation('test-user', 'reset', {});\n 171вЖТ\n 172вЖТ  cancelConfirmation(confirmId, 'test-user');\n 173вЖТ\n 174вЖТ  const result = checkConfirmation(confirmId, 'test-user');\n 175вЖТ  assert.equal(result.status, 'not_found');\n 176вЖТ});\n 177вЖТ\n 178вЖТtest('US-4: Wrong user cannot confirm', () => {\n 179вЖТ  resetPermConfig();\n 180вЖТ  resetAuditLogService();\n 181вЖТ  clearExpiredConfirmations();\n 182вЖТ\n 183вЖТ  const { confirmId } = createConfirmation('user-1', 'stop', {});\n 184вЖТ\n 185вЖТ  const result = confirmAction(confirmId, 'user-2');\n 186вЖТ  assert.equal(result.ok, false);\n 187вЖТ});\n 188вЖТ\n 189вЖТ// US-5: Audit Logging\n 190вЖТtest('US-5: Audit logging works correctly', async () => {\n 191вЖТ  resetPermConfig();\n 192вЖТ  resetAuditLogService();\n 193вЖТ  clearExpiredConfirmations();\n 194вЖТ\n 195вЖТ  await withTempDir(async (tempDir) => {\n 196вЖТ    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 197вЖТ\n 198вЖТ    // Log entry\n 199вЖТ    await logAuditEntry({\n 200вЖТ      userId: '123456789',\n 201вЖТ      action: 'stop',\n 202вЖТ      params: { type: 'feature' },\n 203вЖТ      result: 'success'\n 204вЖТ    });\n 205вЖТ\n 206вЖТ    // Query logs\n 207вЖТ    const entries = await queryAuditLogs({ userId: '123456789' });\n 208вЖТ    assert.ok(entries.length >= 1);\n 209вЖТ\n 210вЖТ    const entry = entries.find((e) => e.action === 'stop');\n 211вЖТ    assert.ok(entry);\n 212вЖТ    assert.equal(entry.userId, '123456789');\n 213вЖТ    assert.equal(entry.result, 'success');\n 214вЖТ  });\n 215вЖТ});\n 216вЖТ\n 217вЖТtest('US-5: Audit log query filters work', async () => {\n 218вЖТ  resetPermConfig();\n 219вЖТ  resetAuditLogService();\n 220вЖТ  clearExpiredConfirmations();\n 221вЖТ\n 222вЖТ  await withTempDir(async (tempDir) => {\n 223вЖТ    await initAuditLogService({ logDir: tempDir, maxFileSizeMb: 10, maxFiles: 5 });\n 224вЖТ\n 225вЖТ    await logAuditEntry({ userId: 'user-1', action: 'stop', params: {}, result: 'success' });\n 226вЖТ    await logAuditEntry({ userId: 'user-1', action: 'reset', params: {}, result: 'success' });\n 227вЖТ    await logAuditEntry({ userId: 'user-2', action: 'stop', params: {}, result: 'denied' });\n 228вЖТ\n 229вЖТ    const user1Entries = await queryAuditLogs({ userId: 'user-1' });\n 230вЖТ    assert.ok(user1Entries.every((e) => e.userId === 'user-1'));\n 231вЖТ\n 232вЖТ    const stopEntries = await queryAuditLogs({ action: 'stop' });\n 233вЖТ    assert.ok(stopEntries.every((e) => e.action === 'stop'));\n 234вЖТ  });\n 235вЖТ});\n 236вЖТ\n 237вЖТ// F-001: force-unlock command\n 238вЖТtest('F-001: force-unlock command requires admin and confirmation', async () => {\n 239вЖТ  resetPermConfig();\n 240вЖТ  resetAuditLogService();\n 241вЖТ  clearExpiredConfirmations();\n 242вЖТ\n 243вЖТ  const config = createTestConfig();\n 244вЖТ  config.userPermissions.set('admin-user', 'admin');\n 245вЖТ  config.userPermissions.set('op-user', 'operator');\n 246вЖТ  setConfigForTesting(config);\n 247вЖТ\n 248вЖТ  const adminResult = checkCommandPermission('admin-user', 'force-unlock');\n 249вЖТ  assert.equal(adminResult.allowed, true);\n 250вЖТ  assert.equal(adminResult.requiresConfirmation, true);\n 251вЖТ\n 252вЖТ  const opResult = checkCommandPermission('op-user', 'force-unlock');\n 253вЖТ  assert.equal(opResult.allowed, false);\n 254вЖТ});\n 255вЖТ\n 256вЖТ// F-002: exec command with ENABLE_SYSTEM_EXEC\n 257вЖТtest('F-002: exec command requires ENABLE_SYSTEM_EXEC', async () => {\n 258вЖТ  resetPermConfig();\n 259вЖТ  resetAuditLogService();\n 260вЖТ  clearExpiredConfirmations();\n 261вЖТ\n 262вЖТ  const config = createTestConfig({ enableSystemExec: false });\n 263вЖТ  config.userPermissions.set('admin-user', 'admin');\n 264вЖТ  setConfigForTesting(config);\n 265вЖТ\n 266вЖТ  const disabledResult = checkCommandPermission('admin-user', 'exec');\n 267вЖТ  assert.equal(disabledResult.allowed, false);\n 268вЖТ  assert.ok(disabledResult.reason.includes('з≥їзїЯеСљдї§жЙІи°МжЬ™еРѓзФ®'));\n 269вЖТ\n 270вЖТ  // Enable system exec\n 271вЖТ  config.enableSystemExec = true;\n 272вЖТ  setConfigForTesting(config);\n 273вЖТ\n 274вЖТ  const enabledResult = checkCommandPermission('admin-user', 'exec');\n 275вЖТ  assert.equal(enabledResult.allowed, true);\n 276вЖТ});\n 277вЖТ\n 278вЖТ// Full flow test: Operator stop flow (should be denied)\n 279вЖТtest('Integration: Operator cannot execute stop command', async () => {\n 280вЖТ  resetPermConfig();\n 281вЖТ  resetAuditLogService();\n 282вЖТ  clearExpiredConfirmations();\n 283вЖТ\n 284вЖТ  await withTempDir(async (tempDir) => {\n 285вЖТ    const config = createTestConfig();\n 286вЖТ    config.userPermissions.set('op-user', 'operator');\n 287вЖТ    setConfigForTesting(config);\n 288вЖТ\n 289вЖТ    const result = checkCommandPermission('op-user', 'stop');\n 290вЖТ    assert.equal(result.allowed, false);\n 291вЖТ\n 292вЖТ    // Log denial\n 293вЖТ    await initAuditLogService({ logDir: tempDir });\n 294вЖТ    await logAuditEntry({\n 295вЖТ      userId: 'op-user',\n 296вЖТ      action: 'stop',\n 297вЖТ      params: {},\n 298вЖТ      result: 'denied',\n 299вЖТ      reason: result.reason\n 300вЖТ    });\n 301вЖТ\n 302вЖТ    const entries = await queryAuditLogs({ action: 'stop', userId: 'op-user' });\n 303вЖТ    assert.ok(entries.some((e) => e.result === 'denied'));\n 304вЖТ  });\n 305вЖТ});\n 306вЖТ\n 307вЖТ// Full flow test: Admin stop with confirmation\n 308вЖТtest('Integration: Admin stop with confirmation flow', async () => {\n 309вЖТ  resetPermConfig();\n 310вЖТ  resetAuditLogService();\n 311вЖТ  clearExpiredConfirmations();\n 312вЖТ\n 313вЖТ  await withTempDir(async (tempDir) => {\n 314вЖТ    const config = createTestConfig();\n 315вЖТ    config.userPermissions.set('admin-user', 'admin');\n 316вЖТ    setConfigForTesting(config);\n 317вЖТ\n 318вЖТ    // 1. Check permission\n 319вЖТ    const permResult = checkCommandPermission('admin-user', 'stop');\n 320вЖТ    assert.equal(permResult.allowed, true);\n 321вЖТ    assert.equal(permResult.requiresConfirmation, true);\n 322вЖТ\n 323вЖТ    // 2. Create confirmation\n 324вЖТ    const { confirmId } = createConfirmation('admin-user', 'stop', { type: 'feature' });\n 325вЖТ\n 326вЖТ    // 3. Confirm\n 327вЖТ    const confirmResult = confirmAction(confirmId, 'admin-user');\n 328вЖТ    assert.equal(confirmResult.ok, true);\n 329вЖТ\n 330вЖТ    // 4. Log success\n 331вЖТ    await initAuditLogService({ logDir: tempDir });\n 332вЖТ    await logAuditEntry({\n 333вЖТ      userId: 'admin-user',\n 334вЖТ      action: 'stop',\n 335вЖТ      params: { type: 'feature' },\n 336вЖТ      result: 'success'\n 337вЖТ    });\n 338вЖТ\n 339вЖТ    const entries = await queryAuditLogs({ userId: 'admin-user', action: 'stop' });\n 340вЖТ    assert.ok(entries.some((e) => e.result === 'success'));\n 341вЖТ  });\n 342вЖТ});\n 343вЖТ\n 344вЖТ// AC-2.5: Error message security\n 345вЖТtest('AC-2.5: Error messages do not expose sensitive info', async () => {\n 346вЖТ  resetPermConfig();\n 347вЖТ  resetAuditLogService();\n 348вЖТ  clearExpiredConfirmations();\n 349вЖТ\n 350вЖТ  const config = createTestConfig();\n 351вЖТ  config.userPermissions.set('viewer-user', 'viewer');\n 352вЖТ  setConfigForTesting(config);\n 353вЖТ\n 354вЖТ  const result = checkCommandPermission('viewer-user', 'stop');\n 355вЖТ  assert.equal(result.allowed, false);\n 356вЖТ  assert.ok(!result.reason.includes('/'));\n 357вЖТ  assert.ok(!result.reason.includes('config'));\n 358вЖТ  assert.ok(!result.reason.includes('password'));\n 359вЖТ});\n 360вЖТ\n 361вЖТ// NFR-1: Performance\n 362вЖТtest('NFR-1: Permission check is fast', () => {\n 363вЖТ  resetPermConfig();\n 364вЖТ  resetAuditLogService();\n 365вЖТ  clearExpiredConfirmations();\n 366вЖТ\n 367вЖТ  const config = createTestConfig();\n 368вЖТ  config.userPermissions.set('test-user', 'admin');\n 369вЖТ  setConfigForTesting(config);\n 370вЖТ\n 371вЖТ  const start = Date.now();\n 372вЖТ  for (let i = 0; i < 1000; i++) {\n 373вЖТ    checkCommandPermission('test-user', 'stop');\n 374вЖТ  }\n 375вЖТ  const duration = Date.now() - start;\n 376вЖТ\n 377вЖТ  // 1000 checks should take < 50ms total (< 0.05ms per check, well under 5ms requirement)\n 378вЖТ  assert.ok(duration < 50, `Permission check too slow: ${duration}ms for 1000 checks`);\n 379вЖТ});\n 380вЖТ\n 381вЖТtest('NFR-1: Param sanitization is fast', () => {\n 382вЖТ  resetPermConfig();\n 383вЖТ  resetAuditLogService();\n 384вЖТ  clearExpiredConfirmations();\n 385вЖТ\n 386вЖТ  const start = Date.now();\n 387вЖТ  for (let i = 0; i < 1000; i++) {\n 388вЖТ    sanitizeParam('test-input-with-moderate-length', { maxLength: 100 });\n 389вЖТ  }\n 390вЖТ  const duration = Date.now() - start;\n 391вЖТ\n 392вЖТ  // 1000 sanitizations should take < 20ms total (< 0.02ms per check, well under 2ms requirement)\n 393вЖТ  assert.ok(duration < 20, `Sanitization too slow: ${duration}ms for 1000 checks`);\n 394вЖТ});\n 395вЖТ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdeb501d230bfbd675b221fe70d04","__timestamp":"2026-03-11T21:02:39.667Z","_requestId":"1b6b97b85f114aa389b904b402a47efc"}
