9→function sanitizeMarkerPath(raw) {\n  70→  return String(raw ?? '')\n  71→    .trim()\n  72→    .replace(/^['\"`]+/, '')\n  73→    .replace(/['\"`]+$/, '');\n  74→}\n  75→\n  76→function extractFileMarkers(text = '') {\n  77→  const fileRefs = [];\n  78→\n  79→  const withSendFileRemoved = text.replace(\n  80→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  81→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdec32d7c15d0f91483a9f4d163da","__timestamp":"2026-03-11T21:29:35.852Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
