{"type":"assistant","uuid":"20260312051423169b760ac9a74046","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"id":"20260312051423169b760ac9a74046","content":[{"type":"tool_use","id":"019cdec0397d2d262acbea3b18ccbbb3","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/security/confirmation-manager.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":25781,"output_tokens":81,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdebfd06760b7d02cd331bbc03246","__timestamp":"2026-03-11T21:14:25.989Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"9cace7db-0ac2-4e6f-89e9-b08dbd3076c0","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"019cdec037eae5e0615313ae1c3cee5d","content":[{"type":"text","text":"   1→/**\n   2→ * Permission Guard Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides user permission tiers and command authorization checking.\n   6→ */\n   7→\n   8→import { config } from '../config.js';\n   9→\n  10→/**\n  11→ * Role hierarchy levels (higher = more permissions)\n  12→ */\n  13→export const ROLE_HIERARCHY = {\n  14→  viewer: 0,\n  15→  operator: 1,\n  16→  admin: 2\n  17→};\n  18→\n  19→/**\n  20→ * Minimum required role for each command\n  21→ */\n  22→const COMMAND_MIN_ROLE = {\n  23→  status: 'viewer',\n  24→  logs: 'viewer',\n  25→  pipeline: 'operator',\n  26→  bugfix: 'operator',\n  27→  planner: 'operator',\n  28→  retry: 'operator',\n  29→  stop: 'admin',\n  30→  reset: 'admin',\n  31→  'force-unlock': 'admin',\n  32→  exec: 'admin'\n  33→};\n  34→\n  35→/**\n  36→ * High-risk commands that require confirmation\n  37→ */\n  38→const HIGH_RISK_COMMANDS = new Set(['stop', 'reset', 'force-unlock']);\n  39→\n  40→/**\n  41→ * Internal config reference - can be overridden for testing\n  42→ * @type {Object}\n  43→ */\n  44→let _config = config;\n  45→\n  46→/**\n  47→ * Set config for testing purposes\n  48→ * @param {Object} testConfig\n  49→ */\n  50→export function setConfigForTesting(testConfig) {\n  51→  _config = testConfig;\n  52→}\n  53→\n  54→/**\n  55→ * Reset config to original (for testing cleanup)\n  56→ */\n  57→export function resetConfig() {\n  58→  _config = config;\n  59→}\n  60→\n  61→/**\n  62→ * Get user permission level\n  63→ * @param {string|number} userId - Telegram user ID\n  64→ * @returns {'admin'|'operator'|'viewer'}\n  65→ */\n  66→export function getUserRole(userId) {\n  67→  const userIdStr = String(userId);\n  68→  const configuredRole = _config.userPermissions.get(userIdStr);\n  69→\n  70→  if (configuredRole) {\n  71→    return configuredRole;\n  72→  }\n  73→\n  74→  // Default to operator for unknown users (AC-1.3)\n  75→  return 'operator';\n  76→}\n  77→\n  78→/**\n  79→ * Check if user is admin\n  80→ * @param {string|number} userId\n  81→ * @returns {boolean}\n  82→ */\n  83→export function isAdmin(userId) {\n  84→  return getUserRole(userId) === 'admin';\n  85→}\n  86→\n  87→/**\n  88→ * Check if user can execute command\n  89→ * @param {string|number} userId\n  90→ * @param {string} command - Command name\n  91→ * @returns {{ allowed: boolean, requiresConfirmation: boolean, reason?: string }}\n  92→ */\n  93→export function checkCommandPermission(userId, command) {\n  94→  const userRole = getUserRole(userId);\n  95→  const minRole = COMMAND_MIN_ROLE[command] || 'viewer';\n  96→\n  97→  // Special handling for exec command (AC-2.4, F-002)\n  98→  if (command === 'exec' && !_config.enableSystemExec) {\n  99→    return {\n 100→      allowed: false,\n 101→      requiresConfirmation: false,\n 102→      reason: '系统命令执行未启用。请在 .env 中设置 ENABLE_SYSTEM_EXEC=true。'\n 103→    };\n 104→  }\n 105→\n 106→  // Check role hierarchy\n 107→  const userLevel = ROLE_HIERARCHY[userRole];\n 108→  const requiredLevel = ROLE_HIERARCHY[minRole];\n 109→\n 110→  if (userLevel < requiredLevel) {\n 111→    return {\n 112→      allowed: false,\n 113→      requiresConfirmation: false,\n 114→      reason: `权限不足。此命令需要 ${minRole} 权限，当前权限: ${userRole}。`\n 115→    };\n 116→  }\n 117→\n 118→  // Check if this is a high-risk command requiring confirmation\n 119→  const requiresConfirmation = HIGH_RISK_COMMANDS.has(command);\n 120→\n 121→  return {\n 122→    allowed: true,\n 123→    requiresConfirmation\n 124→  };\n 125→}\n 126→\n 127→export default {\n 128→  getUserRole,\n 129→  checkCommandPermission,\n 130→  isAdmin,\n 131→  ROLE_HIERARCHY,\n 132→  setConfigForTesting,\n 133→  resetConfig\n 134→};\n 135→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebfd06760b7d02cd331bbc03246","__timestamp":"2026-03-11T21:14:25.993Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"09d9d022-2d5a-4c08-94ea-60ee30bc1c41","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"019cdec0397d2d262acbea3b18ccbbb3","content":[{"type":"text","text":"   1→/**\n   2→ * Confirmation Manager Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Manages confirmation flow for high-risk actions.\n   6→ * AC-4: Confirmation for Sensitive Actions\n   7→ */\n   8→\n   9→import { randomUUID } from 'node:crypto';\n  10→\n  11→/**\n  12→ * Default confirmation timeout (60 seconds per AC-4.3)\n  13→ */\n  14→const DEFAULT_TIMEOUT_MS = 60000;\n  15→\n  16→/**\n  17→ * Pending confirmations storage\n  18→ * Map<confirmId, ConfirmationEntry>\n  19→ */\n  20→const pendingConfirmations = new Map();\n  21→\n  22→/**\n  23→ * @typedef {Object} ConfirmationEntry\n  24→ * @property {string} confirmId\n  25→ * @property {string|number} userId\n  26→ * @property {string} action\n  27→ * @property {Object} params\n  28→ * @property {number} createdAt\n  29→ * @property {number} expiresAt\n  30→ */\n  31→\n  32→/**\n  33→ * Create pending confirmation\n  34→ * @param {string|number} userId\n  35→ * @param {string} action - Action name\n  36→ * @param {Object} params - Action parameters\n  37→ * @param {number} [timeoutMs=60000]\n  38→ * @returns {{ confirmId: string, message: string }}\n  39→ */\n  40→export function createConfirmation(userId, action, params, timeoutMs = DEFAULT_TIMEOUT_MS) {\n  41→  const confirmId = randomUUID();\n  42→  const now = Date.now();\n  43→\n  44→  const entry = {\n  45→    confirmId,\n  46→    userId: String(userId),\n  47→    action,\n  48→    params,\n  49→    createdAt: now,\n  50→    expiresAt: now + timeoutMs\n  51→  };\n  52→\n  53→  pendingConfirmations.set(confirmId, entry);\n  54→\n  55→  const message = `⚠️ 确认执行操作: ${action}\\n参数: ${JSON.stringify(params)}\\n请在 60 秒内回复 CONFIRM 确认，或回复 CANCEL 取消。`;\n  56→\n  57→  return { confirmId, message };\n  58→}\n  59→\n  60→/**\n  61→ * Check confirmation status\n  62→ * @param {string} confirmId\n  63→ * @param {string|number} userId\n  64→ * @returns {{ status: 'pending'|'confirmed'|'expired'|'not_found', action?: string, params?: Object }}\n  65→ */\n  66→export function checkConfirmation(confirmId, userId) {\n  67→  const entry = pendingConfirmations.get(confirmId);\n  68→\n  69→  if (!entry) {\n  70→    return { status: 'not_found' };\n  71→  }\n  72→\n  73→  // Verify userId matches\n  74→  if (entry.userId !== String(userId)) {\n  75→    return { status: 'not_found' };\n  76→  }\n  77→\n  78→  // Check if expired\n  79→  if (Date.now() > entry.expiresAt) {\n  80→    return { status: 'expired', action: entry.action, params: entry.params };\n  81→  }\n  82→\n  83→  return {\n  84→    status: 'pending',\n  85→    action: entry.action,\n  86→    params: entry.params\n  87→  };\n  88→}\n  89→\n  90→/**\n  91→ * Confirm pending action\n  92→ * @param {string} confirmId\n  93→ * @param {string|number} userId\n  94→ * @returns {{ ok: boolean, action?: string, params?: Object, error?: string }}\n  95→ */\n  96→export function confirmAction(confirmId, userId) {\n  97→  const entry = pendingConfirmations.get(confirmId);\n  98→\n  99→  if (!entry) {\n 100→    return { ok: false, error: '确认请求不存在或已过期' };\n 101→  }\n 102→\n 103→  // Verify userId matches\n 104→  if (entry.userId !== String(userId)) {\n 105→    return { ok: false, error: '无权确认此操作' };\n 106→  }\n 107→\n 108→  // Check if expired\n 109→  if (Date.now() > entry.expiresAt) {\n 110→    return { ok: false, error: '确认请求已过期' };\n 111→  }\n 112→\n 113→  // Remove from pending (consumed)\n 114→  pendingConfirmations.delete(confirmId);\n 115→\n 116→  return {\n 117→    ok: true,\n 118→    action: entry.action,\n 119→    params: entry.params\n 120→  };\n 121→}\n 122→\n 123→/**\n 124→ * Cancel pending confirmation\n 125→ * @param {string} confirmId\n 126→ * @param {string|number} userId\n 127→ */\n 128→export function cancelConfirmation(confirmId, userId) {\n 129→  const entry = pendingConfirmations.get(confirmId);\n 130→\n 131→  if (!entry) {\n 132→    return;\n 133→  }\n 134→\n 135→  // Only allow creator to cancel\n 136→  if (entry.userId === String(userId)) {\n 137→    pendingConfirmations.delete(confirmId);\n 138→  }\n 139→}\n 140→\n 141→/**\n 142→ * Clear all expired confirmations\n 143→ * Should be called periodically\n 144→ */\n 145→export function clearExpiredConfirmations() {\n 146→  const now = Date.now();\n 147→\n 148→  for (const [confirmId, entry] of pendingConfirmations) {\n 149→    if (entry.expiresAt <= now) {\n 150→      pendingConfirmations.delete(confirmId);\n 151→    }\n 152→  }\n 153→}\n 154→\n 155→export default {\n 156→  createConfirmation,\n 157→  checkConfirmation,\n 158→  confirmAction,\n 159→  cancelConfirmation,\n 160→  clearExpiredConfirmations\n 161→};\n 162→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdebfd06760b7d02cd331bbc03246","__timestamp":"2026-03-11T21:14:26.007Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
