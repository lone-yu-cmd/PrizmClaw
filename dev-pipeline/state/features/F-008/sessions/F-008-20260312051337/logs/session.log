{"type":"user","uuid":"3c3d2239-4eac-4b98-b911-6ceb2cbcaae1","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_eb0b2d592886402c87a7f474","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for test helpers\n   3→ * F-007: Test and Validation Suite\n   4→ *\n   5→ * Verifies that all test helper modules work correctly.\n   6→ */\n   7→\n   8→import test from 'node:test';\n   9→import assert from 'node:assert/strict';\n  10→import { join } from 'node:path';\n  11→\n  12→// Import all helpers at module level\n  13→import {\n  14→  getFixturePath,\n  15→  loadFixture,\n  16→  loadJsonFixture,\n  17→  fixtureExists\n  18→} from './fixture-loader.js';\n  19→\n  20→import {\n  21→  createMockRunner,\n  22→  createStatefulMockRunner\n  23→} from './mock-runner.js';\n  24→\n  25→import {\n  26→  createMockContext,\n  27→  createAdminContext,\n  28→  createOperatorContext,\n  29→  createViewerContext,\n  30→  createDocumentContext,\n  31→  createCommandContext\n  32→} from './mock-telegram.js';\n  33→\n  34→import {\n  35→  createTestStateDir,\n  36→  createTestPipelineDirs,\n  37→  writeTestState,\n  38→  readTestState,\n  39→  createTestPlan\n  40→} from './test-state.js';\n  41→\n  42→// ============================================================\n  43→// Fixture Loader Tests\n  44→// ============================================================\n  45→\n  46→test('fixture-loader: getFixturePath returns correct path', () => {\n  47→  const path = getFixturePath('plans/valid-feature-list.json');\n  48→  assert.ok(path.includes('fixtures'));\n  49→  assert.ok(path.includes('plans'));\n  50→  assert.ok(path.includes('valid-feature-list.json'));\n  51→});\n  52→\n  53→test('fixture-loader: loadFixture loads file content', () => {\n  54→  const content = loadFixture('plans/valid-feature-list.json');\n  55→  assert.ok(content.includes('$schema'));\n  56→  assert.ok(content.includes('TestApp'));\n  57→});\n  58→\n  59→test('fixture-loader: loadFixture throws for non-existent file', () => {\n  60→  assert.throws(\n  61→    () => loadFixture('non-existent-file.json'),\n  62→    /Fixture not found/\n  63→  );\n  64→});\n  65→\n  66→test('fixture-loader: loadJsonFixture parses JSON correctly', () => {\n  67→  const data = loadJsonFixture('plans/valid-feature-list.json');\n  68→  assert.equal(data.$schema, 'dev-pipeline-feature-list-v1');\n  69→  assert.equal(data.app_name, 'TestApp');\n  70→  assert.ok(Array.isArray(data.features));\n  71→});\n  72→\n  73→test('fixture-loader: loadJsonFixture throws for invalid JSON', () => {\n  74→  assert.throws(\n  75→    () => loadJsonFixture('plans/invalid-bad-json.json'),\n  76→    /Invalid JSON/\n  77→  );\n  78→});\n  79→\n  80→test('fixture-loader: fixtureExists returns true for existing fixture', () => {\n  81→  assert.equal(fixtureExists('plans/valid-feature-list.json'), true);\n  82→});\n  83→\n  84→test('fixture-loader: fixtureExists returns false for non-existing fixture', () => {\n  85→  assert.equal(fixtureExists('non-existent.json'), false);\n  86→});\n  87→\n  88→// ============================================================\n  89→// Mock Runner Tests\n  90→// ============================================================\n  91→\n  92→test('mock-runner: createMockRunner returns function', () => {\n  93→  const runner = createMockRunner();\n  94→  assert.equal(typeof runner, 'function');\n  95→});\n  96→\n  97→test('mock-runner: returns default response for unmocked action', async () => {\n  98→  const runner = createMockRunner();\n  99→  const result = await runner({ action: 'unknown' });\n 100→\n 101→  assert.equal(result.ok, true);\n 102→  assert.equal(result.normalizedStatus, 'success');\n 103→});\n 104→\n 105→test('mock-runner: returns configured response', async () => {\n 106→  const runner = createMockRunner({\n 107→    run: { ok: true, pid: 12345, runId: 'run-001' }\n 108→  });\n 109→\n 110→  const result = await runner({ action: 'run' });\n 111→  assert.equal(result.ok, true);\n 112→  assert.equal(result.pid, 12345);\n 113→  assert.equal(result.runId, 'run-001');\n 114→});\n 115→\n 116→test('mock-runner: supports response sequencing', async () => {\n 117→  const runner = createMockRunner({\n 118→    status: [\n 119→      { ok: true, isRunning: true },\n 120→      { ok: true, isRunning: false }\n 121→    ]\n 122→  });\n 123→\n 124→  const result1 = await runner({ action: 'status' });\n 125→  assert.equal(result1.isRunning, true);\n 126→\n 127→  const result2 = await runner({ action: 'status' });\n 128→  assert.equal(result2.isRunning, false);\n 129→});\n 130→\n 131→test('mock-runner: callLog tracks calls', async () => {\n 132→  const runner = createMockRunner();\n 133→  await runner({ action: 'run', targetId: 'F-001' });\n 134→  await runner({ action: 'status' });\n 135→\n 136→  const log = runner.getCallLog();\n 137→  assert.equal(log.length, 2);\n 138→  assert.equal(log[0].action, 'run');\n 139→  assert.equal(log[0].params.targetId, 'F-001');\n 140→});\n 141→\n 142→test('mock-runner: getCalls filters by action', async () => {\n 143→  const runner = createMockRunner();\n 144→  await runner({ action: 'run' });\n 145→  await runner({ action: 'status' });\n 146→  await runner({ action: 'run' });\n 147→\n 148→  const runCalls = runner.getCalls('run');\n 149→  assert.equal(runCalls.length, 2);\n 150→});\n 151→\n 152→test('mock-runner: addResponse adds new response', async () => {\n 153→  const runner = createMockRunner();\n 154→  runner.addResponse('run', { ok: true, pid: 999 });\n 155→\n 156→  const result = await runner({ action: 'run' });\n 157→  assert.equal(result.pid, 999);\n 158→});\n 159→\n 160→test('mock-runner: createStatefulMockRunner tracks state', async () => {\n 161→  const runner = createStatefulMockRunner();\n 162→  let state = runner.getState();\n 163→  assert.equal(state.isRunning, false);\n 164→\n 165→  await runner({ action: 'run' });\n 166→  state = runner.getState();\n 167→  assert.equal(state.isRunning, true);\n 168→\n 169→  await runner({ action: 'stop' });\n 170→  state = runner.getState();\n 171→  assert.equal(state.isRunning, false);\n 172→});\n 173→\n 174→test('mock-runner: createStatefulMockRunner prevents duplicate start', async () => {\n 175→  const runner = createStatefulMockRunner({ startRunning: true });\n 176→  const result = await runner({ action: 'run' });\n 177→\n 178→  assert.equal(result.ok, false);\n 179→  assert.equal(result.errorCode, 'ALREADY_RUNNING');\n 180→});\n 181→\n 182→// ============================================================\n 183→// Mock Telegram Tests\n 184→// ============================================================\n 185→\n 186→test('mock-telegram: createMockContext creates context', () => {\n 187→  const ctx = createMockContext();\n 188→  assert.ok(ctx.message);\n 189→  assert.ok(ctx.chat);\n 190→  assert.ok(ctx.from);\n 191→  assert.equal(typeof ctx.reply, 'function');\n 192→});\n 193→\n 194→test('mock-telegram: createMockContext applies overrides', () => {\n 195→  const ctx = createMockContext({\n 196→    message: { text: '/start' }\n 197→  });\n 198→\n 199→  assert.equal(ctx.message.text, '/start');\n 200→});\n 201→\n 202→test('mock-telegram: reply captures messages', async () => {\n 203→  const ctx = createMockContext();\n 204→  await ctx.reply('Hello');\n 205→  await ctx.reply('World');\n 206→\n 207→  const replies = ctx._getReplies();\n 208→  assert.equal(replies.length, 2);\n 209→  assert.equal(replies[0].text, 'Hello');\n 210→  assert.equal(replies[1].text, 'World');\n 211→});\n 212→\n 213→test('mock-telegram: _getLastReply returns last reply', async () => {\n 214→  const ctx = createMockContext();\n 215→  await ctx.reply('First');\n 216→  await ctx.reply('Last');\n 217→\n 218→  const last = ctx._getLastReply();\n 219→  assert.equal(last.text, 'Last');\n 220→});\n 221→\n 222→test('mock-telegram: createAdminContext sets admin permission', () => {\n 223→  const ctx = createAdminContext();\n 224→  assert.equal(ctx.state.permission, 'admin');\n 225→});\n 226→\n 227→test('mock-telegram: createOperatorContext sets operator permission', () => {\n 228→  const ctx = createOperatorContext();\n 229→  assert.equal(ctx.state.permission, 'operator');\n 230→});\n 231→\n 232→test('mock-telegram: createViewerContext sets viewer permission', () => {\n 233→  const ctx = createViewerContext();\n 234→  assert.equal(ctx.state.permission, 'viewer');\n 235→});\n 236→\n 237→test('mock-telegram: createDocumentContext creates document message', () => {\n 238→  const ctx = createDocumentContext({\n 239→    file_name: 'test-plan.json',\n 240→    file_size: 2048\n 241→  });\n 242→\n 243→  assert.ok(ctx.message.document);\n 244→  assert.equal(ctx.message.document.file_name, 'test-plan.json');\n 245→  assert.equal(ctx.message.document.file_size, 2048);\n 246→});\n 247→\n 248→test('mock-telegram: createCommandContext creates command message', () => {\n 249→  const ctx = createCommandContext('/pipeline run --type=feature');\n 250→  assert.equal(ctx.message.text, '/pipeline run --type=feature');\n 251→});\n 252→\n 253→// ============================================================\n 254→// Test State Tests\n 255→// ============================================================\n 256→\n 257→test('test-state: createTestStateDir creates directory', async () => {\n 258→  const { path, cleanup } = await createTestStateDir();\n 259→  assert.ok(path);\n 260→\n 261→  await cleanup();\n 262→});\n 263→\n 264→test('test-state: createTestPipelineDirs creates full structure', async () => {\n 265→  const { tempDir, stateDir, bugfixStateDir, plansDir, cleanup } = await createTestPipelineDirs();\n 266→\n 267→  assert.ok(tempDir);\n 268→  assert.ok(stateDir);\n 269→  assert.ok(bugfixStateDir);\n 270→  assert.ok(plansDir);\n 271→\n 272→  await cleanup();\n 273→});\n 274→\n 275→test('test-state: writeTestState and readTestState work together', async () => {\n 276→  const { path, cleanup } = await createTestStateDir();\n 277→\n 278→  const testData = { foo: 'bar', nested: { value: 42 } };\n 279→  const filePath = join(path, 'test.json');\n 280→\n 281→  await writeTestState(filePath, testData);\n 282→  const loaded = await readTestState(filePath);\n 283→\n 284→  assert.deepEqual(loaded, testData);\n 285→\n 286→  await cleanup();\n 287→});\n 288→\n 289→test('test-state: readTestState returns null for non-existent file', async () => {\n 290→  const result = await readTestState('/non/existent/path.json');\n 291→  assert.equal(result, null);\n 292→});\n 293→\n 294→test('test-state: createTestPlan creates plan file', async () => {\n 295→  const { plansDir, cleanup } = await createTestPipelineDirs();\n 296→\n 297→  const planContent = {\n 298→    $schema: 'dev-pipeline-feature-list-v1',\n 299→    app_name: 'TestApp',\n 300→    features: []\n 301→  };\n 302→\n 303→  const planPath = await createTestPlan(plansDir, 'feature-list', planContent);\n 304→  const loaded = await readTestState(planPath);\n 305→\n 306→  assert.equal(loaded.app_name, 'TestApp');\n 307→\n 308→  await cleanup();\n 309→});\n 310→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:32:12.387Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
