{"type":"assistant","uuid":"202603120531414eb69012fa1f4a40","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"id":"202603120531414eb69012fa1f4a40","content":[{"type":"tool_use","id":"call_e463b2e9ebc7476498823467","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/commits.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":26834,"output_tokens":192,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:45.392Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"2c817463-6925-41c3-9701-ee5f2f658a21","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_0cf6f652e3f54ee2b060dd38","content":[{"type":"text","text":"   1→/**\n   2→ * GitService Module\n   3→ * F-008: Commit Workflow Integration\n   4→ *\n   5→ * Wraps simple-git library for git operations.\n   6→ * Provides typed interfaces for commit workflow.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D1: Use simple-git to avoid shell injection risks\n  10→ * - D5: Design for mockability in tests\n  11→ */\n  12→\n  13→import simpleGit from 'simple-git';\n  14→\n  15→/**\n  16→ * Validation error codes with messages and suggestions\n  17→ */\n  18→export const GIT_ERRORS = {\n  19→  NOTHING_TO_COMMIT: {\n  20→    code: 'NOTHING_TO_COMMIT',\n  21→    message: '没有待提交的变更',\n  22→    suggestion: '请先进行代码修改'\n  23→  },\n  24→  MERGE_CONFLICT: {\n  25→    code: 'MERGE_CONFLICT',\n  26→    message: '存在合并冲突',\n  27→    suggestion: '请先解决冲突文件'\n  28→  },\n  29→  COMMIT_FAILED: {\n  30→    code: 'COMMIT_FAILED',\n  31→    message: '提交失败',\n  32→    suggestion: '请检查 git 状态'\n  33→  },\n  34→  AMEND_FAILED: {\n  35→    code: 'AMEND_FAILED',\n  36→    message: '修改提交失败',\n  37→    suggestion: '请确认有提交可修改'\n  38→  }\n  39→};\n  40→\n  41→/**\n  42→ * Create a GitService instance\n  43→ * @param {Object} options - Configuration options\n  44→ * @param {string} [options.baseDir] - Base directory for git operations\n  45→ * @param {Object} [options.git] - Custom simple-git instance (for testing)\n  46→ * @returns {Object} GitService interface\n  47→ */\n  48→export function createGitService(options = {}) {\n  49→  const baseDir = options.baseDir || process.cwd();\n  50→  const git = options.git || simpleGit(baseDir);\n  51→\n  52→  /**\n  53→   * Get git working directory status\n  54→   * @returns {Promise<GitStatus>}\n  55→   */\n  56→  async function getStatus() {\n  57→    const status = await git.status();\n  58→\n  59→    return {\n  60→      clean: status.isClean(),\n  61→      staged: status.staged,\n  62→      modified: status.modified,\n  63→      untracked: status.not_added,\n  64→      conflicts: status.conflicted,\n  65→      ahead: status.ahead,\n  66→      behind: status.behind,\n  67→      currentBranch: status.current\n  68→    };\n  69→  }\n  70→\n  71→  /**\n  72→   * Check if working directory is clean\n  73→   * @returns {Promise<boolean>}\n  74→   */\n  75→  async function isClean() {\n  76→    const status = await git.status();\n  77→    return status.isClean();\n  78→  }\n  79→\n  80→  /**\n  81→   * Get list of changed files\n  82→   * @returns {Promise<string[]>}\n  83→   */\n  84→  async function getChangedFiles() {\n  85→    const status = await git.status();\n  86→    return [\n  87→      ...status.staged,\n  88→      ...status.modified,\n  89→      ...status.not_added,\n  90→      ...status.conflicted\n  91→    ];\n  92→  }\n  93→\n  94→  /**\n  95→   * Execute a git commit\n  96→   * @param {string} message - Commit message\n  97→   * @param {Object} [commitOptions] - Commit options\n  98→   * @param {boolean} [commitOptions.amend] - Whether to amend last commit\n  99→   * @param {boolean} [commitOptions.allowEmpty] - Allow empty commit\n 100→   * @returns {Promise<CommitResult>}\n 101→   */\n 102→  async function commit(message, commitOptions = {}) {\n 103→    try {\n 104→      const status = await git.status();\n 105→\n 106→      // Check for nothing to commit\n 107→      if (status.isClean() && !commitOptions.allowEmpty) {\n 108→        return {\n 109→          success: false,\n 110→          error: GIT_ERRORS.NOTHING_TO_COMMIT.message,\n 111→          code: GIT_ERRORS.NOTHING_TO_COMMIT.code,\n 112→          suggestion: GIT_ERRORS.NOTHING_TO_COMMIT.suggestion\n 113→        };\n 114→      }\n 115→\n 116→      // Check for conflicts\n 117→      if (status.conflicted.length > 0) {\n 118→        return {\n 119→          success: false,\n 120→          error: GIT_ERRORS.MERGE_CONFLICT.message,\n 121→          code: GIT_ERRORS.MERGE_CONFLICT.code,\n 122→          suggestion: `${GIT_ERRORS.MERGE_CONFLICT.suggestion}: ${status.conflicted.join(', ')}`,\n 123→          conflicts: status.conflicted\n 124→        };\n 125→      }\n 126→\n 127→      // Build commit options\n 128→      const gitOptions = [];\n 129→      if (commitOptions.amend) {\n 130→        gitOptions.push('--amend');\n 131→      }\n 132→      if (commitOptions.allowEmpty) {\n 133→        gitOptions.push('--allow-empty');\n 134→      }\n 135→\n 136→      // Execute commit\n 137→      const result = await git.commit(message, gitOptions);\n 138→\n 139→      if (!result.commit) {\n 140→        return {\n 141→          success: false,\n 142→          error: GIT_ERRORS.COMMIT_FAILED.message,\n 143→          code: GIT_ERRORS.COMMIT_FAILED.code,\n 144→          suggestion: GIT_ERRORS.COMMIT_FAILED.suggestion\n 145→        };\n 146→      }\n 147→\n 148→      return {\n 149→        success: true,\n 150→        hash: result.commit,\n 151→        shortHash: getShortHash(result.commit),\n 152→        message: message,\n 153→        filesChanged: result.summary.changes || 0\n 154→      };\n 155→    } catch (error) {\n 156→      return {\n 157→        success: false,\n 158→        error: error.message,\n 159→        suggestion: GIT_ERRORS.COMMIT_FAILED.suggestion\n 160→      };\n 161→    }\n 162→  }\n 163→\n 164→  /**\n 165→   * Amend the last commit\n 166→   * @param {string} message - New commit message\n 167→   * @returns {Promise<CommitResult>}\n 168→   */\n 169→  async function amendCommit(message) {\n 170→    try {\n 171→      const result = await git.commit(message, ['--amend', '--no-edit']);\n 172→\n 173→      if (!result.commit) {\n 174→        // Amend without changes might return same hash\n 175→        const lastCommit = await getLastCommit();\n 176→        return {\n 177→          success: true,\n 178→          hash: lastCommit.hash,\n 179→          shortHash: lastCommit.shortHash,\n 180→          message: message,\n 181→          filesChanged: 0\n 182→        };\n 183→      }\n 184→\n 185→      return {\n 186→        success: true,\n 187→        hash: result.commit,\n 188→        shortHash: getShortHash(result.commit),\n 189→        message: message,\n 190→        filesChanged: result.summary.changes || 0\n 191→      };\n 192→    } catch (error) {\n 193→      return {\n 194→        success: false,\n 195→        error: error.message,\n 196→        code: GIT_ERRORS.AMEND_FAILED.code,\n 197→        suggestion: GIT_ERRORS.AMEND_FAILED.suggestion\n 198→      };\n 199→    }\n 200→  }\n 201→\n 202→  /**\n 203→   * Get the last commit info\n 204→   * @returns {Promise<CommitInfo>}\n 205→   */\n 206→  async function getLastCommit() {\n 207→    const log = await git.log(['-1']);\n 208→    const latest = log.latest;\n 209→\n 210→    if (!latest) {\n 211→      return null;\n 212→    }\n 213→\n 214→    return {\n 215→      hash: latest.hash,\n 216→      shortHash: getShortHash(latest.hash),\n 217→      message: latest.message,\n 218→      author: latest.author_name,\n 219→      date: latest.date\n 220→    };\n 221→  }\n 222→\n 223→  /**\n 224→   * Get commit history\n 225→   * @param {number} [count=10] - Number of commits to retrieve\n 226→   * @returns {Promise<CommitInfo[]>}\n 227→   */\n 228→  async function getCommitLog(count = 10) {\n 229→    const log = await git.log([`-${count}`]);\n 230→\n 231→    return log.all.map(commit => ({\n 232→      hash: commit.hash,\n 233→      shortHash: getShortHash(commit.hash),\n 234→      message: commit.message,\n 235→      author: commit.author_name,\n 236→      date: commit.date\n 237→    }));\n 238→  }\n 239→\n 240→  /**\n 241→   * Get short hash from full hash\n 242→   * @param {string} hash - Full commit hash\n 243→   * @returns {string} 7-character short hash\n 244→   */\n 245→  function getShortHash(hash) {\n 246→    return hash ? hash.substring(0, 7) : '';\n 247→  }\n 248→\n 249→  return {\n 250→    getStatus,\n 251→    isClean,\n 252→    getChangedFiles,\n 253→    commit,\n 254→    amendCommit,\n 255→    getLastCommit,\n 256→    getCommitLog,\n 257→    getShortHash\n 258→  };\n 259→}\n 260→\n 261→export default createGitService;\n 262→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:45.393Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"b3adb427-17a4-4d5d-a472-aafa4f3fcf36","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_73da76890f5f491e8eee556c","content":[{"type":"text","text":"   1→/**\n   2→ * CommitService Module\n   3→ * F-008: Commit Workflow Integration\n   4→ *\n   5→ * Orchestrates commit workflow: validation → execution → recording.\n   6→ * Coordinates GitService, StatusAggregator, and SessionStore.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D2: Pre-commit validation includes pipeline and test status checks\n  10→ * - D3: Commit records stored in session state file\n  11→ * - AC-5.3: All commit operations are logged to audit log\n  12→ */\n  13→\n  14→import fs from 'node:fs';\n  15→import path from 'node:path';\n  16→\n  17→import { createGitService } from './git-service.js';\n  18→import { createStatusAggregator } from './status-aggregator.js';\n  19→import { logAuditEntry } from './audit-log-service.js';\n  20→\n  21→/**\n  22→ * Validation error codes with messages and suggestions\n  23→ */\n  24→export const VALIDATION_ERRORS = {\n  25→  PIPELINE_RUNNING: {\n  26→    code: 'PIPELINE_RUNNING',\n  27→    message: 'Pipeline 正在运行中',\n  28→    suggestion: '请等待 pipeline 完成或使用 /stop 停止'\n  29→  },\n  30→  TEST_FAILED: {\n  31→    code: 'TEST_FAILED',\n  32→    message: '测试未通过',\n  33→    suggestion: '请检查测试结果或使用 --force 跳过（仅 admin）'\n  34→  },\n  35→  NOTHING_TO_COMMIT: {\n  36→    code: 'NOTHING_TO_COMMIT',\n  37→    message: '没有待提交的变更',\n  38→    suggestion: '请先进行代码修改'\n  39→  },\n  40→  MERGE_CONFLICT: {\n  41→    code: 'MERGE_CONFLICT',\n  42→    message: '存在合并冲突',\n  43→    suggestion: '请先解决以下冲突文件'\n  44→  }\n  45→};\n  46→\n  47→/**\n  48→ * Default test status path\n  49→ */\n  50→const DEFAULT_TEST_STATUS_PATH = 'dev-pipeline/state/test-status.json';\n  51→\n  52→/**\n  53→ * Get error suggestion by error code (standalone function)\n  54→ * @param {string} code - Error code\n  55→ * @returns {Object} Error with suggestion\n  56→ */\n  57→export function getErrorSuggestion(code) {\n  58→  return VALIDATION_ERRORS[code] || {\n  59→    code,\n  60→    message: '未知错误',\n  61→    suggestion: '请检查错误日志'\n  62→  };\n  63→}\n  64→\n  65→/**\n  66→ * Create a CommitService instance\n  67→ * @param {Object} options - Configuration options\n  68→ * @param {Object} [options.gitService] - GitService instance\n  69→ * @param {Object} [options.statusAggregator] - StatusAggregator instance\n  70→ * @param {Object} [options.sessionStore] - SessionStore instance\n  71→ * @param {string} [options.testStatusPath] - Path to test status file\n  72→ * @param {string} [options.projectRoot] - Project root directory\n  73→ * @returns {Object} CommitService interface\n  74→ */\n  75→export function createCommitService(options = {}) {\n  76→  const gitService = options.gitService || createGitService({ baseDir: options.projectRoot });\n  77→  const statusAggregator = options.statusAggregator || createStatusAggregator();\n  78→  const sessionStore = options.sessionStore;\n  79→  const testStatusPath = options.testStatusPath || DEFAULT_TEST_STATUS_PATH;\n  80→\n  81→  /**\n  82→   * Read test status from file\n  83→   * @returns {Object|null} Test status or null if file doesn't exist\n  84→   */\n  85→  function readTestStatus() {\n  86→    try {\n  87→      const fullPath = path.resolve(testStatusPath);\n  88→      if (!fs.existsSync(fullPath)) {\n  89→        return null;\n  90→      }\n  91→      const content = fs.readFileSync(fullPath, 'utf8');\n  92→      return JSON.parse(content);\n  93→    } catch {\n  94→      return null;\n  95→    }\n  96→  }\n  97→\n  98→  /**\n  99→   * Check pipeline status helper\n 100→   * @returns {Promise<{isRunning: boolean, phase: string}>}\n 101→   */\n 102→  async function checkPipelineStatus() {\n 103→    try {\n 104→      const featureStatus = await statusAggregator.aggregateStatus('feature');\n 105→      const bugfixStatus = await statusAggregator.aggregateStatus('bugfix');\n 106→\n 107→      const isRunning = featureStatus.stage === 'running' || bugfixStatus.stage === 'running';\n 108→      const phase = featureStatus.stage === 'running' ? featureStatus.stage :\n 109→                    bugfixStatus.stage === 'running' ? bugfixStatus.stage : 'idle';\n 110→\n 111→      return { isRunning, phase };\n 112→    } catch {\n 113→      return { isRunning: false, phase: 'unknown' };\n 114→    }\n 115→  }\n 116→\n 117→  /**\n 118→   * Check test status helper\n 119→   * @returns {{passed: boolean, failed: number, total: number}}\n 120→   */\n 121→  function checkTestStatus() {\n 122→    const status = readTestStatus();\n 123→\n 124→    if (!status) {\n 125→      return { passed: true, failed: 0, total: 0 };\n 126→    }\n 127→\n 128→    return {\n 129→      passed: status.failed === 0,\n 130→      failed: status.failed || 0,\n 131→      total: (status.passed || 0) + (status.failed || 0) + (status.skipped || 0)\n 132→    };\n 133→  }\n 134→\n 135→  /**\n 136→   * Validate pre-commit conditions\n 137→   * @param {Object} validationOptions - Validation options\n 138→   * @param {boolean} [validationOptions.skipPipelineCheck] - Skip pipeline status check\n 139→   * @param {boolean} [validationOptions.skipTestCheck] - Skip test status check\n 140→   * @returns {Promise<ValidationResult>}\n 141→   */\n 142→  async function validatePreConditions(validationOptions = {}) {\n 143→    const errors = [];\n 144→    const warnings = [];\n 145→\n 146→    // 1. Check pipeline status\n 147→    if (!validationOptions.skipPipelineCheck) {\n 148→      const pipelineCheck = await checkPipelineStatus();\n 149→      if (pipelineCheck.isRunning) {\n 150→        errors.push({\n 151→          ...VALIDATION_ERRORS.PIPELINE_RUNNING,\n 152→          phase: pipelineCheck.phase\n 153→        });\n 154→      }\n 155→    }\n 156→\n 157→    // 2. Check test status\n 158→    if (!validationOptions.skipTestCheck) {\n 159→      const testCheck = checkTestStatus();\n 160→      if (!testCheck.passed && testCheck.total > 0) {\n 161→        errors.push({\n 162→          ...VALIDATION_ERRORS.TEST_FAILED,\n 163→          failed: testCheck.failed,\n 164→          total: testCheck.total\n 165→        });\n 166→      }\n 167→    }\n 168→\n 169→    // 3. Check git status\n 170→    const gitStatus = await gitService.getStatus();\n 171→\n 172→    if (gitStatus.clean) {\n 173→      errors.push(VALIDATION_ERRORS.NOTHING_TO_COMMIT);\n 174→    }\n 175→\n 176→    if (gitStatus.conflicts.length > 0) {\n 177→      errors.push({\n 178→        ...VALIDATION_ERRORS.MERGE_CONFLICT,\n 179→        files: gitStatus.conflicts\n 180→      });\n 181→    }\n 182→\n 183→    return {\n 184→      valid: errors.length === 0,\n 185→      errors,\n 186→      warnings,\n 187→      gitStatus\n 188→    };\n 189→  }\n 190→\n 191→  /**\n 192→   * Build commit message with footer\n 193→   * @param {string} userMessage - User-provided commit message\n 194→   * @param {Object} context - Commit context\n 195→   * @param {string} [context.featureId] - Feature ID\n 196→   * @param {string} [context.bugfixId] - Bugfix ID\n 197→   * @returns {string} Full commit message\n 198→   */\n 199→  function buildCommitMessage(userMessage, context = {}) {\n 200→    const lines = [userMessage];\n 201→\n 202→    if (context.featureId) {\n 203→      lines.push('');\n 204→      lines.push(`Feature: ${context.featureId}`);\n 205→    }\n 206→\n 207→    if (context.bugfixId) {\n 208→      lines.push('');\n 209→      lines.push(`Bugfix: ${context.bugfixId}`);\n 210→    }\n 211→\n 212→    return lines.join('\\n');\n 213→  }\n 214→\n 215→  /**\n 216→   * Record commit to session store\n 217→   * @param {string} sessionId - Session ID\n 218→   * @param {Object} commitInfo - Commit information\n 219→   */\n 220→  async function recordCommit(sessionId, commitInfo) {\n 221→    if (!sessionStore) {\n 222→      return;\n 223→    }\n 224→\n 225→    const record = {\n 226→      hash: commitInfo.hash,\n 227→      shortHash: commitInfo.shortHash,\n 228→      message: commitInfo.message,\n 229→      timestamp: Date.now(),\n 230→      author: commitInfo.author || 'unknown',\n 231→      featureId: commitInfo.featureId || null,\n 232→      bugfixId: commitInfo.bugfixId || null,\n 233→      filesChanged: commitInfo.filesChanged || 0\n 234→    };\n 235→\n 236→    if (typeof sessionStore.addCommit === 'function') {\n 237→      sessionStore.addCommit(sessionId, record);\n 238→    }\n 239→  }\n 240→\n 241→  /**\n 242→   * Get commits for a session\n 243→   * @param {string} sessionId - Session ID\n 244→   * @returns {Promise<CommitRecord[]>}\n 245→   */\n 246→  async function getSessionCommits(sessionId) {\n 247→    if (!sessionStore) {\n 248→      return [];\n 249→    }\n 250→\n 251→    if (typeof sessionStore.getCommits === 'function') {\n 252→      return sessionStore.getCommits(sessionId);\n 253→    }\n 254→\n 255→    return [];\n 256→  }\n 257→\n 258→  /**\n 259→   * Main commit function\n 260→   * @param {Object} params - Commit parameters\n 261→   * @param {string} params.sessionId - Session ID\n 262→   * @param {string} params.userId - User ID\n 263→   * @param {string} [params.message] - Commit message\n 264→   * @param {boolean} [params.amend] - Whether to amend last commit\n 265→   * @param {boolean} [params.force] - Skip validation\n 266→   * @param {string} [params.featureId] - Feature ID\n 267→   * @param {string} [params.bugfixId] - Bugfix ID\n 268→   * @param {string} [params.userRole] - User role for audit log\n 269→   * @returns {Promise<CommitResult>}\n 270→   */\n 271→  async function commit(params) {\n 272→    const {\n 273→      sessionId,\n 274→      userId,\n 275→      message = 'chore: commit',\n 276→      amend = false,\n 277→      force = false,\n 278→      featureId,\n 279→      bugfixId,\n 280→      userRole = 'operator'\n 281→    } = params;\n 282→\n 283→    // Validate pre-conditions (unless force is true)\n 284→    if (!force) {\n 285→      const validation = await validatePreConditions({});\n 286→\n 287→      if (!validation.valid) {\n 288→        // Log failed commit attempt (AC-5.3)\n 289→        await logAuditEntry({\n 290→          userId,\n 291→          role: userRole,\n 292→          action: amend ? 'commit:amend' : 'commit',\n 293→          params: { message, featureId, bugfixId, force },\n 294→          result: 'denied',\n 295→          reason: validation.errors.map(e => e.code).join(', '),\n 296→          sessionId\n 297→        });\n 298→\n 299→        return {\n 300→          success: false,\n 301→          errors: validation.errors,\n 302→          gitStatus: validation.gitStatus\n 303→        };\n 304→      }\n 305→    }\n 306→\n 307→    // Build full commit message\n 308→    const fullMessage = buildCommitMessage(message, { featureId, bugfixId });\n 309→\n 310→    // Execute commit\n 311→    let result;\n 312→    if (amend) {\n 313→      result = await gitService.amendCommit(fullMessage);\n 314→    } else {\n 315→      result = await gitService.commit(fullMessage);\n 316→    }\n 317→\n 318→    // Record commit to session (if successful)\n 319→    if (result.success) {\n 320→      await recordCommit(sessionId, {\n 321→        hash: result.hash,\n 322→        shortHash: result.shortHash,\n 323→        message: fullMessage,\n 324→        author: userId,\n 325→        featureId,\n 326→        bugfixId,\n 327→        filesChanged: result.filesChanged\n 328→      });\n 329→\n 330→      // Log successful commit (AC-5.3)\n 331→      await logAuditEntry({\n 332→        userId,\n 333→        role: userRole,\n 334→        action: amend ? 'commit:amend' : 'commit',\n 335→        params: { message: fullMessage, featureId, bugfixId, force },\n 336→        result: 'success',\n 337→        sessionId\n 338→      });\n 339→    } else {\n 340→      // Log failed commit (AC-5.3)\n 341→      await logAuditEntry({\n 342→        userId,\n 343→        role: userRole,\n 344→        action: amend ? 'commit:amend' : 'commit',\n 345→        params: { message: fullMessage, featureId, bugfixId, force },\n 346→        result: 'failed',\n 347→        reason: result.error,\n 348→        sessionId\n 349→      });\n 350→    }\n 351→\n 352→    return result;\n 353→  }\n 354→\n 355→  return {\n 356→    validatePreConditions,\n 357→    commit,\n 358→    recordCommit,\n 359→    getSessionCommits,\n 360→    checkPipelineStatus,\n 361→    checkTestStatus,\n 362→    buildCommitMessage,\n 363→    getErrorSuggestion\n 364→  };\n 365→}\n 366→\n 367→export default createCommitService;\n 368→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:45.394Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"75def220-5a47-40a2-9891-043872a709ce","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_f109f651b7fd480697f362b4","content":[{"type":"text","text":"   1→/**\n   2→ * Commit Command Handler\n   3→ * F-008: Commit Workflow Integration\n   4→ *\n   5→ * Handles /commit command with optional --message, --amend, --force flags.\n   6→ * Integrated with F-006 security layer for permission checks and confirmations.\n   7→ */\n   8→\n   9→import { createCommitService } from '../../../services/commit-service.js';\n  10→import { createGitService } from '../../../services/git-service.js';\n  11→import { sessionStore } from '../../../services/session-store.js';\n  12→import { isAdmin } from '../../../security/permission-guard.js';\n  13→import {\n  14→  createConfirmation,\n  15→  confirmAction,\n  16→  cancelConfirmation\n  17→} from '../../../security/confirmation-manager.js';\n  18→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n  19→import { logAuditEntry } from '../../../services/audit-log-service.js';\n  20→\n  21→// Store pending confirmations for amend/force operations\n  22→const pendingConfirmations = new Map();\n  23→\n  24→// Create commit service instance\n  25→const commitService = createCommitService({\n  26→  sessionStore: {\n  27→    addCommit: (sessionId, commitInfo) => sessionStore.addCommit(sessionId, commitInfo),\n  28→    getCommits: (sessionId) => sessionStore.getCommits(sessionId)\n  29→  }\n  30→});\n  31→\n  32→/**\n  33→ * Commit command metadata\n  34→ */\n  35→export const commitMeta = {\n  36→  name: 'commit',\n  37→  aliases: ['c'],\n  38→  description: '提交代码变更',\n  39→  usage: '/commit [--message=\"...\"] [--amend] [--force]',\n  40→  examples: [\n  41→    '/commit',\n  42→    '/commit --message=\"feat: add new feature\"',\n  43→    '/commit --amend',\n  44→    '/commit --force'\n  45→  ],\n  46→  params: [\n  47→    {\n  48→      name: 'message',\n  49→      type: 'string',\n  50→      required: false,\n  51→      description: '提交信息',\n  52→      aliases: ['m']\n  53→    },\n  54→    {\n  55→      name: 'amend',\n  56→      type: 'boolean',\n  57→      required: false,\n  58→      description: '修改最近一次提交（仅 admin）'\n  59→    },\n  60→    {\n  61→      name: 'force',\n  62→      type: 'boolean',\n  63→      required: false,\n  64→      description: '跳过前置校验（仅 admin）'\n  65→    }\n  66→  ],\n  67→  requiresAuth: true,\n  68→  minRole: 'operator',\n  69→  helpText: '/commit [--message=\"...\"] [--amend] [--force] - 提交代码变更'\n  70→};\n  71→\n  72→/**\n  73→ * Handle commit command\n  74→ * @param {Object} handlerCtx - Handler context\n  75→ */\n  76→export async function handleCommit(handlerCtx) {\n  77→  const { ctx, parsed, params, reply, userId, userRole, requiresConfirmation } = handlerCtx;\n  78→\n  79→  // Parse parameters\n  80→  const message = params.message || params.m || getDefaultCommitMessage();\n  81→  const amend = params.amend === true || parsed?.flags?.amend === true;\n  82→  const force = params.force === true || parsed?.flags?.force === true;\n  83→\n  84→  // Validate message length\n  85→  if (message.length > 500) {\n  86→    await reply('❌ 提交信息过长，请限制在 500 字符以内。');\n  87→    return;\n  88→  }\n  89→\n  90→  // Sanitize message\n  91→  const messageResult = sanitizeParam(message, { maxLength: 500 });\n  92→  if (!messageResult.ok) {\n  93→    await reply(`❌ 提交信息无效: ${messageResult.error}`);\n  94→    return;\n  95→  }\n  96→\n  97→  // Check amend/force permissions\n  98→  if (amend && !isAdmin(userId)) {\n  99→    await reply('❌ --amend 需要 admin 权限。');\n 100→    await logAuditEntry({\n 101→      userId,\n 102→      role: userRole,\n 103→      action: 'commit:amend',\n 104→      params: { message: messageResult.value },\n 105→      result: 'denied',\n 106→      reason: 'Insufficient permissions'\n 107→    });\n 108→    return;\n 109→  }\n 110→\n 111→  if (force && !isAdmin(userId)) {\n 112→    await reply('❌ --force 需要 admin 权限。');\n 113→    await logAuditEntry({\n 114→      userId,\n 115→      role: userRole,\n 116→      action: 'commit:force',\n 117→      params: { message: messageResult.value },\n 118→      result: 'denied',\n 119→      reason: 'Insufficient permissions'\n 120→    });\n 121→    return;\n 122→  }\n 123→\n 124→  // Handle confirmation flow for amend/force\n 125→  if ((amend || force) && requiresConfirmation) {\n 126→    const confirmKey = `commit:${amend ? 'amend' : 'force'}:${userId}`;\n 127→\n 128→    // Check if this is a CONFIRM response\n 129→    const rawArg = params._args?.[0];\n 130→    if (rawArg === 'CONFIRM') {\n 131→      const confirmId = pendingConfirmations.get(confirmKey);\n 132→      if (confirmId) {\n 133→        const result = confirmAction(confirmId, userId);\n 134→        if (result.ok) {\n 135→          pendingConfirmations.delete(confirmKey);\n 136→          await executeCommit(handlerCtx, messageResult.value, amend, force);\n 137→        } else {\n 138→          await reply(`❌ 确认失败: ${result.error}`);\n 139→        }\n 140→        return;\n 141→      } else {\n 142→        await reply('❌ 没有待确认的 commit 操作，或操作已过期。');\n 143→        return;\n 144→      }\n 145→    }\n 146→\n 147→    // Check if this is a CANCEL response\n 148→    if (rawArg === 'CANCEL') {\n 149→      const confirmId = pendingConfirmations.get(confirmKey);\n 150→      if (confirmId) {\n 151→        cancelConfirmation(confirmId, userId);\n 152→        pendingConfirmations.delete(confirmKey);\n 153→        await reply('✅ 已取消 commit 操作。');\n 154→      } else {\n 155→        await reply('没有待确认的 commit 操作。');\n 156→      }\n 157→      return;\n 158→    }\n 159→\n 160→    // Create new confirmation\n 161→    const actionType = amend ? 'commit --amend' : 'commit --force';\n 162→    const { confirmId, message: confirmMessage } = createConfirmation(\n 163→      userId,\n 164→      actionType,\n 165→      { message: messageResult.value, amend, force }\n 166→    );\n 167→    pendingConfirmations.set(confirmKey, confirmId);\n 168→\n 169→    const flagDesc = amend ? '--amend' : '--force';\n 170→    await reply(`⚠️ 高风险操作确认\\n\\n${confirmMessage}\\n\\n请回复 /commit ${flagDesc} CONFIRM 确认，或 /commit ${flagDesc} CANCEL 取消。`);\n 171→    return;\n 172→  }\n 173→\n 174→  // Execute commit directly\n 175→  await executeCommit(handlerCtx, messageResult.value, amend, force);\n 176→}\n 177→\n 178→/**\n 179→ * Execute commit operation\n 180→ */\n 181→async function executeCommit(handlerCtx, message, amend, force) {\n 182→  const { reply, userId, userRole, ctx } = handlerCtx;\n 183→\n 184→  // Get session ID from context or use default\n 185→  const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n 186→\n 187→  // Get feature/bugfix ID from session if available\n 188→  const sessionState = ctx?.state?.session || {};\n 189→  const featureId = sessionState.featureId || null;\n 190→  const bugfixId = sessionState.bugfixId || null;\n 191→\n 192→  try {\n 193→    const result = await commitService.commit({\n 194→      sessionId,\n 195→      userId: String(userId),\n 196→      message,\n 197→      amend,\n 198→      force,\n 199→      featureId,\n 200→      bugfixId,\n 201→      userRole\n 202→    });\n 203→\n 204→    if (result.success) {\n 205→      // Format success message\n 206→      const successMsg = formatSuccessResult(result);\n 207→      await reply(successMsg);\n 208→    } else {\n 209→      // Format error message\n 210→      const errorMsg = formatErrorResult(result);\n 211→      await reply(errorMsg);\n 212→    }\n 213→  } catch (error) {\n 214→    await logAuditEntry({\n 215→      userId,\n 216→      role: userRole,\n 217→      action: amend ? 'commit:amend' : 'commit',\n 218→      params: { message, amend, force },\n 219→      result: 'failed',\n 220→      reason: error.message\n 221→    });\n 222→    await reply(`❌ 提交失败: ${error.message}`);\n 223→  }\n 224→}\n 225→\n 226→/**\n 227→ * Get default commit message\n 228→ */\n 229→function getDefaultCommitMessage() {\n 230→  return `chore: update ${new Date().toISOString().split('T')[0]}`;\n 231→}\n 232→\n 233→/**\n 234→ * Format success result for Telegram\n 235→ */\n 236→function formatSuccessResult(result) {\n 237→  const lines = [\n 238→    '✅ 提交成功',\n 239→    '',\n 240→    `📦 Hash: \\`${result.shortHash}\\``,\n 241→    `📝 消息: ${result.message?.split('\\n')[0] || '(无)'}`,\n 242→    `📁 变更文件: ${result.filesChanged || 0} 个`\n 243→  ];\n 244→\n 245→  return lines.join('\\n');\n 246→}\n 247→\n 248→/**\n 249→ * Format error result for Telegram\n 250→ */\n 251→function formatErrorResult(result) {\n 252→  const lines = ['❌ 提交失败', ''];\n 253→\n 254→  if (result.errors && result.errors.length > 0) {\n 255→    lines.push('**错误详情:**');\n 256→    for (const error of result.errors) {\n 257→      lines.push(`• ${error.message}`);\n 258→      if (error.suggestion) {\n 259→        lines.push(`  💡 ${error.suggestion}`);\n 260→      }\n 261→    }\n 262→  } else if (result.error) {\n 263→    lines.push(`原因: ${result.error}`);\n 264→    if (result.suggestion) {\n 265→      lines.push(`💡 建议: ${result.suggestion}`);\n 266→    }\n 267→  }\n 268→\n 269→  return lines.join('\\n');\n 270→}\n 271→\n 272→export default handleCommit;\n 273→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:45.394Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"06db15d6-a6d4-4b82-bb98-7f7f7ab41dac","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_e463b2e9ebc7476498823467","content":[{"type":"text","text":"   1→/**\n   2→ * Commits Command Handler\n   3→ * F-008: Commit Workflow Integration\n   4→ *\n   5→ * Handles /commits command to view session commit history.\n   6→ */\n   7→\n   8→import { sessionStore } from '../../../services/session-store.js';\n   9→\n  10→/**\n  11→ * Commits command metadata\n  12→ */\n  13→export const commitsMeta = {\n  14→  name: 'commits',\n  15→  aliases: ['history'],\n  16→  description: '查看会话提交历史',\n  17→  usage: '/commits [--count=10]',\n  18→  examples: [\n  19→    '/commits',\n  20→    '/commits --count=5'\n  21→  ],\n  22→  params: [\n  23→    {\n  24→      name: 'count',\n  25→      type: 'number',\n  26→      required: false,\n  27→      default: 10,\n  28→      description: '显示的提交数量'\n  29→    }\n  30→  ],\n  31→  requiresAuth: true,\n  32→  minRole: 'viewer',\n  33→  helpText: '/commits [--count=N] - 查看会话提交历史'\n  34→};\n  35→\n  36→/**\n  37→ * Handle commits command\n  38→ * @param {Object} handlerCtx - Handler context\n  39→ */\n  40→export async function handleCommits(handlerCtx) {\n  41→  const { ctx, params, reply, userId } = handlerCtx;\n  42→\n  43→  // Get session ID from context\n  44→  const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n  45→\n  46→  // Get count parameter\n  47→  const count = Math.min(params.count || 10, 20); // Max 20\n  48→\n  49→  try {\n  50→    // Get commits from session store\n  51→    const commits = sessionStore.getCommits(sessionId);\n  52→\n  53→    if (!commits || commits.length === 0) {\n  54→      await reply('📭 当前会话暂无提交记录。');\n  55→      return;\n  56→    }\n  57→\n  58→    // Format commit history\n  59→    const formattedCommits = commits.slice(-count).reverse();\n  60→    const message = formatCommitsList(formattedCommits);\n  61→\n  62→    await reply(message);\n  63→  } catch (error) {\n  64→    await reply(`❌ 获取提交历史失败: ${error.message}`);\n  65→  }\n  66→}\n  67→\n  68→/**\n  69→ * Format commits list for Telegram\n  70→ * @param {Object[]} commits - Array of commit records\n  71→ * @returns {string} Formatted message\n  72→ */\n  73→function formatCommitsList(commits) {\n  74→  const lines = ['📋 **提交历史**', ''];\n  75→\n  76→  for (const commit of commits) {\n  77→    const time = formatTimestamp(commit.timestamp);\n  78→    const shortMsg = commit.message?.split('\\n')[0] || '(无消息)';\n  79→\n  80→    lines.push(`\\`${commit.shortHash}\\` ${shortMsg}`);\n  81→    lines.push(`   📅 ${time} | 📁 ${commit.filesChanged || 0} 文件`);\n  82→\n  83→    if (commit.featureId) {\n  84→      lines.push(`   🏷️ Feature: ${commit.featureId}`);\n  85→    }\n  86→    if (commit.bugfixId) {\n  87→      lines.push(`   🐛 Bugfix: ${commit.bugfixId}`);\n  88→    }\n  89→\n  90→    lines.push('');\n  91→  }\n  92→\n  93→  lines.push(`_共 ${commits.length} 条提交记录_`);\n  94→\n  95→  return lines.join('\\n');\n  96→}\n  97→\n  98→/**\n  99→ * Format timestamp for display\n 100→ * @param {number} timestamp - Unix timestamp in milliseconds\n 101→ * @returns {string} Formatted date string\n 102→ */\n 103→function formatTimestamp(timestamp) {\n 104→  if (!timestamp) return '未知时间';\n 105→\n 106→  const date = new Date(timestamp);\n 107→  const now = new Date();\n 108→  const diffMs = now - date;\n 109→  const diffMins = Math.floor(diffMs / 60000);\n 110→  const diffHours = Math.floor(diffMs / 3600000);\n 111→  const diffDays = Math.floor(diffMs / 86400000);\n 112→\n 113→  if (diffMins < 1) return '刚刚';\n 114→  if (diffMins < 60) return `${diffMins} 分钟前`;\n 115→  if (diffHours < 24) return `${diffHours} 小时前`;\n 116→  if (diffDays < 7) return `${diffDays} 天前`;\n 117→\n 118→  return date.toLocaleDateString('zh-CN', {\n 119→    month: 'short',\n 120→    day: 'numeric',\n 121→    hour: '2-digit',\n 122→    minute: '2-digit'\n 123→  });\n 124→}\n 125→\n 126→export default handleCommits;\n 127→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:45.395Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
