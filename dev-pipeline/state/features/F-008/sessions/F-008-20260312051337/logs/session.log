28→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  29→const STREAM_MIN_CHARS = 220;\n  30→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  31→const TYPING_INTERVAL_MS = 3500;\n  32→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  33→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  34→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  35→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  36→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  37→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  38→const TMP_DIR = path.resolve(os.tmpdir());\n  39→const HOME_DIR = path.resolve(os.homedir());\n  40→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  41→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  42→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  43→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  44→\n  45→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  46→  const normalized = configuredDirs\n  47→    .map((dir) => String(dir ?? '').trim())\n  48→    .filter(Boolean)\n  49→    .map((dir) => path.resolve(dir));\n  50→\n  51→  if (normalized.length > 0) {\n  52→    return [...new Set(normalized)];\n  53→  }\n  54→\n  55→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  56→}\n  57→\n  58→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  59→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  60→\n  61→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  62→  const chunks = [];\n  63→  for (let i = 0; i < text.length; i += chunkSize) {\n  64→    chunks.push(text.slice(i, i + chunkSize));\n  65→  }\n  66→  return chunks;\n  67→}\n  68→\n  69→function sanitizeMarkerPath(raw) {\n  70→  return String(raw ?? '')\n  71→    .trim()\n  72→    .replace(/^['\"`]+/, '')\n  73→    .replace(/['\"`]+$/, '');\n  74→}\n  75→\n  76→function extractFileMarkers(text = '') {\n  77→  const fileRefs = [];\n  78→\n  79→  const withSendFileRemoved = text.replace(\n  80→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  81→    (_full, rawRef) => {\n  82→      const ref = sanitizeMarkerPath(rawRef);\n  83→      if (ref) {\n  84→        fileRefs.push(ref);\n  85→      }\n  86→      return '\\n';\n  87→    }\n  88→  );\n  89→\n  90→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  91→    const ref = sanitizeMarkerPath(rawRef);\n  92→    if (ref) {\n  93→      fileRefs.push(ref);\n  94→    }\n  95→    return '';\n  96→  });\n  97→\n  98→  const withBacktickPathRemoved = withImageRemoved.replace(\n  99→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 100→    (_full, rawRef) => {\n 101→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:32:37.856Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
