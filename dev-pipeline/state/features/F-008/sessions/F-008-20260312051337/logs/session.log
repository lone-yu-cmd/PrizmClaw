{"type":"user","uuid":"77014c4b-f0bf-41e9-ab7c-6eed7bb61c23","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_cca4e94fcbd545649009210a","content":[{"type":"text","text":"   1→/**\n   2→ * Commit Handler Unit Tests\n   3→ * F-008: Commit Workflow Integration\n   4→ */\n   5→\n   6→import { describe, it, beforeEach, afterEach } from 'node:test';\n   7→import assert from 'node:assert';\n   8→import { handleCommit, commitMeta } from '../../../../src/bot/commands/handlers/commit.js';\n   9→import { createMockContext } from '../../../helpers/mock-telegram.js';\n  10→import { setConfigForTesting, resetConfig } from '../../../../src/security/permission-guard.js';\n  11→\n  12→function createMockHandlerCtx(overrides = {}) {\n  13→  const ctx = createMockContext(overrides.ctx);\n  14→  const replies = [];\n  15→\n  16→  return {\n  17→    ctx,\n  18→    parsed: { flags: {} },\n  19→    params: {},\n  20→    userId: 123456789,\n  21→    userRole: 'operator',\n  22→    requiresConfirmation: false,\n  23→    reply: async (text) => {\n  24→      replies.push(text);\n  25→      return { message_id: replies.length };\n  26→    },\n  27→    _getReplies: () => replies,\n  28→    _getLastReply: () => replies[replies.length - 1],\n  29→    ...overrides\n  30→  };\n  31→}\n  32→\n  33→describe('commitMeta', () => {\n  34→  it('should have correct name', () => {\n  35→    assert.strictEqual(commitMeta.name, 'commit');\n  36→  });\n  37→\n  38→  it('should have aliases', () => {\n  39→    assert.ok(commitMeta.aliases.includes('c'));\n  40→  });\n  41→\n  42→  it('should have minRole of operator', () => {\n  43→    assert.strictEqual(commitMeta.minRole, 'operator');\n  44→  });\n  45→\n  46→  it('should have params defined', () => {\n  47→    assert.ok(commitMeta.params.length > 0);\n  48→  });\n  49→\n  50→  it('should have help text', () => {\n  51→    assert.ok(commitMeta.helpText);\n  52→  });\n  53→});\n  54→\n  55→describe('handleCommit - Parameter Validation', () => {\n  56→  it('should reject commit message over 500 characters', async () => {\n  57→    const longMessage = 'a'.repeat(501);\n  58→    const handlerCtx = createMockHandlerCtx({\n  59→      params: { message: longMessage }\n  60→    });\n  61→\n  62→    await handleCommit(handlerCtx);\n  63→\n  64→    const lastReply = handlerCtx._getLastReply();\n  65→    assert.ok(lastReply.includes('过长'));\n  66→  });\n  67→\n  68→  it('should accept commit message at 500 characters', async () => {\n  69→    const maxMessage = 'a'.repeat(500);\n  70→    const handlerCtx = createMockHandlerCtx({\n  71→      params: { message: maxMessage }\n  72→    });\n  73→\n  74→    await handleCommit(handlerCtx);\n  75→\n  76→    // Should not reject for length (may fail for other reasons)\n  77→    const lastReply = handlerCtx._getLastReply();\n  78→    assert.ok(!lastReply.includes('过长'));\n  79→  });\n  80→});\n  81→\n  82→describe('handleCommit - Permission Checks', () => {\n  83→  it('should reject amend from non-admin', async () => {\n  84→    // User is not in the admin list\n  85→    const handlerCtx = createMockHandlerCtx({\n  86→      params: { amend: true },\n  87→      userId: 888888888,\n  88→      userRole: 'operator'\n  89→    });\n  90→\n  91→    await handleCommit(handlerCtx);\n  92→\n  93→    const lastReply = handlerCtx._getLastReply();\n  94→    assert.ok(lastReply.includes('admin'));\n  95→  });\n  96→\n  97→  it('should reject force from non-admin', async () => {\n  98→    const handlerCtx = createMockHandlerCtx({\n  99→      params: { force: true },\n 100→      userId: 888888888,\n 101→      userRole: 'operator'\n 102→    });\n 103→\n 104→    await handleCommit(handlerCtx);\n 105→\n 106→    const lastReply = handlerCtx._getLastReply();\n 107→    assert.ok(lastReply.includes('admin'));\n 108→  });\n 109→});\n 110→\n 111→describe('handleCommit - Confirmation Flow', () => {\n 112→  beforeEach(() => {\n 113→    // Set up test config with admin user\n 114→    setConfigForTesting({\n 115→      userPermissions: new Map([\n 116→        ['999999999', 'admin']\n 117→      ])\n 118→    });\n 119→  });\n 120→\n 121→  afterEach(() => {\n 122→    resetConfig();\n 123→  });\n 124→\n 125→  it('should create confirmation for amend operation', async () => {\n 126→    const handlerCtx = createMockHandlerCtx({\n 127→      params: { amend: true },\n 128→      userId: 999999999,\n 129→      userRole: 'admin',\n 130→      requiresConfirmation: true\n 131→    });\n 132→\n 133→    await handleCommit(handlerCtx);\n 134→\n 135→    const lastReply = handlerCtx._getLastReply();\n 136→    assert.ok(lastReply.includes('确认'));\n 137→  });\n 138→\n 139→  it('should create confirmation for force operation', async () => {\n 140→    const handlerCtx = createMockHandlerCtx({\n 141→      params: { force: true },\n 142→      userId: 999999999,\n 143→      userRole: 'admin',\n 144→      requiresConfirmation: true\n 145→    });\n 146→\n 147→    await handleCommit(handlerCtx);\n 148→\n 149→    const lastReply = handlerCtx._getLastReply();\n 150→    assert.ok(lastReply.includes('确认'));\n 151→  });\n 152→});\n 153→\n 154→describe('handleCommit - Error Handling', () => {\n 155→  it('should handle commit failure gracefully', async () => {\n 156→    const handlerCtx = createMockHandlerCtx({\n 157→      params: { message: 'test commit' }\n 158→    });\n 159→\n 160→    await handleCommit(handlerCtx);\n 161→\n 162→    // Should have a reply (either success or failure)\n 163→    const replies = handlerCtx._getReplies();\n 164→    assert.ok(replies.length > 0);\n 165→  });\n 166→});\n 167→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:58.688Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
{"type":"user","uuid":"a1ed0887-91d9-40dc-8af7-bcfdbf0eb7b5","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"call_0cadef1d917b4fdfb121a525","content":[{"type":"text","text":"   1→/**\n   2→ * Commits Handler Unit Tests\n   3→ * F-008: Commit Workflow Integration\n   4→ */\n   5→\n   6→import { describe, it, beforeEach } from 'node:test';\n   7→import assert from 'node:assert';\n   8→import { handleCommits, commitsMeta } from '../../../../src/bot/commands/handlers/commits.js';\n   9→import { createMockContext } from '../../../helpers/mock-telegram.js';\n  10→import { sessionStore } from '../../../../src/services/session-store.js';\n  11→\n  12→function createMockHandlerCtx(overrides = {}) {\n  13→  const ctx = createMockContext(overrides.ctx);\n  14→  const replies = [];\n  15→\n  16→  return {\n  17→    ctx,\n  18→    parsed: { flags: {} },\n  19→    params: {},\n  20→    userId: 123456789,\n  21→    userRole: 'viewer',\n  22→    reply: async (text) => {\n  23→      replies.push(text);\n  24→      return { message_id: replies.length };\n  25→    },\n  26→    _getReplies: () => replies,\n  27→    _getLastReply: () => replies[replies.length - 1],\n  28→    ...overrides\n  29→  };\n  30→}\n  31→\n  32→describe('commitsMeta', () => {\n  33→  it('should have correct name', () => {\n  34→    assert.strictEqual(commitsMeta.name, 'commits');\n  35→  });\n  36→\n  37→  it('should have aliases', () => {\n  38→    assert.ok(commitsMeta.aliases.includes('history'));\n  39→  });\n  40→\n  41→  it('should have minRole of viewer', () => {\n  42→    assert.strictEqual(commitsMeta.minRole, 'viewer');\n  43→  });\n  44→});\n  45→\n  46→describe('handleCommits', () => {\n  47→  const testSessionId = '123456789';\n  48→\n  49→  beforeEach(() => {\n  50→    // Clear session commits\n  51→    sessionStore.clear(testSessionId);\n  52→  });\n  53→\n  54→  it('should show empty message when no commits', async () => {\n  55→    const handlerCtx = createMockHandlerCtx();\n  56→    await handleCommits(handlerCtx);\n  57→\n  58→    const lastReply = handlerCtx._getLastReply();\n  59→    assert.ok(lastReply.includes('暂无提交记录'));\n  60→  });\n  61→\n  62→  it('should show commits list when commits exist', async () => {\n  63→    // Add test commits\n  64→    sessionStore.addCommit(testSessionId, {\n  65→      hash: 'abc123def456',\n  66→      shortHash: 'abc123d',\n  67→      message: 'test commit 1',\n  68→      filesChanged: 2,\n  69→      timestamp: Date.now()\n  70→    });\n  71→\n  72→    const handlerCtx = createMockHandlerCtx();\n  73→    await handleCommits(handlerCtx);\n  74→\n  75→    const lastReply = handlerCtx._getLastReply();\n  76→    assert.ok(lastReply.includes('提交历史'));\n  77→    assert.ok(lastReply.includes('abc123d'));\n  78→  });\n  79→\n  80→  it('should respect count parameter', async () => {\n  81→    // Add multiple commits\n  82→    for (let i = 0; i < 15; i++) {\n  83→      sessionStore.addCommit(testSessionId, {\n  84→        hash: `hash${i}`,\n  85→        shortHash: `short${i}`,\n  86→        message: `commit ${i}`,\n  87→        filesChanged: 1,\n  88→        timestamp: Date.now() + i\n  89→      });\n  90→    }\n  91→\n  92→    const handlerCtx = createMockHandlerCtx({\n  93→      params: { count: 5 }\n  94→    });\n  95→    await handleCommits(handlerCtx);\n  96→\n  97→    const lastReply = handlerCtx._getLastReply();\n  98→    // Should only show 5 commits\n  99→    assert.ok(lastReply.includes('5 条提交记录'));\n 100→  });\n 101→\n 102→  it('should show feature ID if present', async () => {\n 103→    sessionStore.addCommit(testSessionId, {\n 104→      hash: 'abc123',\n 105→      shortHash: 'abc1234',\n 106→      message: 'test',\n 107→      filesChanged: 1,\n 108→      featureId: 'F-008',\n 109→      timestamp: Date.now()\n 110→    });\n 111→\n 112→    const handlerCtx = createMockHandlerCtx();\n 113→    await handleCommits(handlerCtx);\n 114→\n 115→    const lastReply = handlerCtx._getLastReply();\n 116→    assert.ok(lastReply.includes('Feature: F-008'));\n 117→  });\n 118→\n 119→  it('should show bugfix ID if present', async () => {\n 120→    sessionStore.addCommit(testSessionId, {\n 121→      hash: 'abc123',\n 122→      shortHash: 'abc1234',\n 123→      message: 'test',\n 124→      filesChanged: 1,\n 125→      bugfixId: 'BF-001',\n 126→      timestamp: Date.now()\n 127→    });\n 128→\n 129→    const handlerCtx = createMockHandlerCtx();\n 130→    await handleCommits(handlerCtx);\n 131→\n 132→    const lastReply = handlerCtx._getLastReply();\n 133→    assert.ok(lastReply.includes('Bugfix: BF-001'));\n 134→  });\n 135→});\n 136→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdecfd1ead857ee9a7ed5cb47e1f3","__timestamp":"2026-03-11T21:31:58.692Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
