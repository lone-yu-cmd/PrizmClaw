{"type":"user","uuid":"cb68d305-2e65-481e-baa4-87c338db5858","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"019cdece4389ae019cf12793551aaec8","content":[{"type":"text","text":"   1→/**\n   2→ * Help Text Generator\n   3→ * Generates help text for commands.\n   4→ */\n   5→\n   6→import { getCommand, getAllCommands } from './registry.js';\n   7→\n   8→/**\n   9→ * Generate help text for all commands or a specific command.\n  10→ * @param {string} [commandName] - Optional command name\n  11→ * @returns {string} Help text\n  12→ */\n  13→export function generateHelp(commandName) {\n  14→  if (commandName) {\n  15→    return generateCommandHelp(commandName);\n  16→  }\n  17→  return generateGeneralHelp();\n  18→}\n  19→\n  20→/**\n  21→ * Generate general help text listing all commands.\n  22→ * @returns {string} Help text\n  23→ */\n  24→function generateGeneralHelp() {\n  25→  const commands = getAllCommands();\n  26→\n  27→  if (commands.length === 0) {\n  28→    return '暂无可用命令。';\n  29→  }\n  30→\n  31→  const lines = ['可用命令：', ''];\n  32→\n  33→  for (const entry of commands) {\n  34→    const { meta } = entry;\n  35→    const aliases = meta.aliases?.length ? ` (${meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n  36→    lines.push(`/${meta.name}${aliases}`);\n  37→    lines.push(`  ${meta.description}`);\n  38→    lines.push('');\n  39→  }\n  40→\n  41→  lines.push('输入 /help <命令> 查看详细用法。');\n  42→\n  43→  return lines.join('\\n');\n  44→}\n  45→\n  46→/**\n  47→ * Generate detailed help text for a specific command.\n  48→ * @param {string} commandName - Command name\n  49→ * @returns {string} Help text\n  50→ */\n  51→function generateCommandHelp(commandName) {\n  52→  const entry = getCommand(commandName);\n  53→\n  54→  if (!entry) {\n  55→    return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n  56→  }\n  57→\n  58→  const { meta } = entry;\n  59→  const lines = [];\n  60→\n  61→  // Command name and description\n  62→  lines.push(`/${meta.name} - ${meta.description}`);\n  63→  lines.push('');\n  64→\n  65→  // Aliases\n  66→  if (meta.aliases?.length) {\n  67→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n  68→    lines.push('');\n  69→  }\n  70→\n  71→  // Usage\n  72→  if (meta.usage) {\n  73→    lines.push(`用法: ${meta.usage}`);\n  74→    lines.push('');\n  75→  }\n  76→\n  77→  // Subcommands\n  78→  if (meta.subcommands?.length) {\n  79→    lines.push('子命令:');\n  80→    for (const sub of meta.subcommands) {\n  81→      lines.push(`  ${sub.name} - ${sub.description}`);\n  82→    }\n  83→    lines.push('');\n  84→  }\n  85→\n  86→  // Parameters\n  87→  if (meta.params?.length) {\n  88→    lines.push('参数:');\n  89→    for (const param of meta.params) {\n  90→      const required = param.required ? '(必填)' : '(可选)';\n  91→      const type = param.type ? ` [${param.type}]` : '';\n  92→      const enumValues = param.enum ? ` {${param.enum.join(', ')}}` : '';\n  93→      const defaultVal = param.default !== undefined ? ` = ${param.default}` : '';\n  94→      lines.push(`  ${param.name}${type}${enumValues}${defaultVal} ${required}`);\n  95→      lines.push(`    ${param.description}`);\n  96→    }\n  97→    lines.push('');\n  98→  }\n  99→\n 100→  // Examples\n 101→  if (meta.examples?.length) {\n 102→    lines.push('示例:');\n 103→    for (const example of meta.examples) {\n 104→      lines.push(`  ${example}`);\n 105→    }\n 106→    lines.push('');\n 107→  }\n 108→\n 109→  return lines.join('\\n').trim();\n 110→}\n 111→\n 112→/**\n 113→ * Generate quick reference for all commands.\n 114→ * @returns {string} Quick reference text\n 115→ */\n 116→export function generateQuickReference() {\n 117→  const commands = getAllCommands();\n 118→\n 119→  if (commands.length === 0) {\n 120→    return '暂无可用命令。';\n 121→  }\n 122→\n 123→  const lines = commands.map((entry) => {\n 124→    const { meta } = entry;\n 125→    const aliases = meta.aliases?.length ? ` /${meta.aliases.join(' /')}` : '';\n 126→    return `/${meta.name}${aliases} - ${meta.description}`;\n 127→  });\n 128→\n 129→  return lines.join('\\n');\n 130→}\n 131→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdec32d7c15d0f91483a9f4d163da","__timestamp":"2026-03-11T21:29:46.072Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
