{"type":"user","uuid":"32e4b57c-749a-451d-9f90-cc41f12a2236","session_id":"45bd4fe9-d12f-4930-90bb-1615d208ca29","message":{"content":[{"type":"tool_result","tool_use_id":"019cdec9abd5fab4169ea7d9775c40ba","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ * F-006: Integrated with security guard\n   5→ */\n   6→\n   7→import {\n   8→  startPipeline,\n   9→  stopPipeline,\n  10→  getStatus,\n  11→  getLogs,\n  12→  forceUnlock\n  13→} from '../../../services/pipeline-controller.js';\n  14→import { formatValidationErrors, formatError, ErrorCodes } from '../formatter.js';\n  15→import { logAuditEntry } from '../../../services/audit-log-service.js';\n  16→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n  17→import { isAdmin } from '../../../security/permission-guard.js';\n  18→import {\n  19→  createConfirmation,\n  20→  checkConfirmation,\n  21→  confirmAction,\n  22→  cancelConfirmation\n  23→} from '../../../security/confirmation-manager.js';\n  24→\n  25→// Store pending confirmations for text-based flow\n  26→const pendingConfirmations = new Map();\n  27→\n  28→/**\n  29→ * Pipeline command metadata.\n  30→ * T-102: minRole added\n  31→ */\n  32→export const pipelineMeta = {\n  33→  name: 'pipeline',\n  34→  aliases: ['p'],\n  35→  description: '管理管道任务',\n  36→  usage: '/pipeline <action> [target] [--type=<type>]',\n  37→  examples: [\n  38→    '/pipeline run my-feature',\n  39→    '/pipeline run my-feature --type=bugfix',\n  40→    '/pipeline status',\n  41→    '/pipeline logs my-feature',\n  42→    '/pipeline stop my-feature',\n  43→    '/pipeline force-unlock'\n  44→  ],\n  45→  subcommands: [\n  46→    { name: 'run', description: '启动管道' },\n  47→    { name: 'status', description: '查询状态' },\n  48→    { name: 'logs', description: '查看日志' },\n  49→    { name: 'stop', description: '停止管道' },\n  50→    { name: 'force-unlock', description: '强制释放锁' }\n  51→  ],\n  52→  params: [\n  53→    {\n  54→      name: 'target',\n  55→      type: 'string',\n  56→      required: false,\n  57→      description: '目标标识符'\n  58→    },\n  59→    {\n  60→      name: 'type',\n  61→      type: 'enum',\n  62→      enum: ['feature', 'bugfix', 'planner'],\n  63→      required: false,\n  64→      default: 'feature',\n  65→      description: '管道类型'\n  66→    }\n  67→  ],\n  68→  requiresAuth: true,\n  69→  minRole: 'operator',\n  70→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  71→};\n  72→\n  73→/**\n  74→ * Handle pipeline command.\n  75→ * @param {Object} handlerCtx - Handler context\n  76→ * @param {Object} handlerCtx.ctx - Telegraf context\n  77→ * @param {Object} handlerCtx.parsed - Parsed command\n  78→ * @param {Object} handlerCtx.params - Normalized parameters\n  79→ * @param {Function} handlerCtx.reply - Reply function\n  80→ */\n  81→export async function handlePipeline(handlerCtx) {\n  82→  const { ctx, parsed, params, reply } = handlerCtx;\n  83→\n  84→  // Determine action from subcommand or default to status\n  85→  const action = parsed.subcommand || 'status';\n  86→\n  87→  switch (action) {\n  88→    case 'run':\n  89→      return handleRun(handlerCtx);\n  90→    case 'status':\n  91→      return handleStatus(handlerCtx);\n  92→    case 'logs':\n  93→      return handleLogs(handlerCtx);\n  94→    case 'stop':\n  95→      return handlePipelineStop(handlerCtx);\n  96→    case 'force-unlock':\n  97→      return handleForceUnlock(handlerCtx);\n  98→    default:\n  99→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop, force-unlock`);\n 100→  }\n 101→}\n 102→\n 103→/**\n 104→ * Handle run subcommand.\n 105→ * T-103: Added parameter sanitization and audit logging\n 106→ */\n 107→async function handleRun({ params, reply, parsed, userId, userRole }) {\n 108→  const target = params._args?.[0] || params.target;\n 109→  const pipelineType = params.type || 'feature';\n 110→\n 111→  // T-103: Sanitize target parameter\n 112→  if (target) {\n 113→    const targetResult = sanitizeParam(target, { maxLength: 100 });\n 114→    if (!targetResult.ok) {\n 115→      await reply(`❌ 目标参数无效: ${targetResult.error}`);\n 116→      return;\n 117→    }\n 118→  }\n 119→\n 120→  // T-103: Sanitize type parameter\n 121→  const typeResult = sanitizeParam(pipelineType, { maxLength: 50 });\n 122→  if (!typeResult.ok) {\n 123→    await reply(`❌ 类型参数无效: ${typeResult.error}`);\n 124→    return;\n 125→  }\n 126→\n 127→  try {\n 128→    const result = await startPipeline({\n 129→      type: typeResult.value,\n 130→      targetId: target,\n 131→      daemon: true\n 132→    });\n 133→\n 134→    if (result.ok) {\n 135→      // T-107: Audit logging\n 136→      await logAuditEntry({\n 137→        userId,\n 138→        role: userRole,\n 139→        action: 'pipeline_run',\n 140→        params: { type: typeResult.value, target },\n 141→        result: 'success'\n 142→      });\n 143→\n 144→      const pidInfo = result.pid ? ` (PID: ${result.pid})` : '';\n 145→      await reply(`✅ 已启动 ${typeResult.value} 管道${target ? `: ${target}` : ''}${pidInfo}`);\n 146→    } else {\n 147→      const errorMsg = result.message || result.stderr || '未知错误';\n 148→      const hint = result.hint ? `\\n💡 提示: ${result.hint}` : '';\n 149→\n 150→      await logAuditEntry({\n 151→        userId,\n 152→        role: userRole,\n 153→        action: 'pipeline_run',\n 154→        params: { type: typeResult.value, target },\n 155→        result: 'failed',\n 156→        reason: errorMsg\n 157→      });\n 158→\n 159→      await reply(`❌ 启动失败: ${errorMsg}${hint}`);\n 160→    }\n 161→  } catch (error) {\n 162→    await logAuditEntry({\n 163→      userId,\n 164→      role: userRole,\n 165→      action: 'pipeline_run',\n 166→      params: { type: pipelineType, target },\n 167→      result: 'failed',\n 168→      reason: error.message\n 169→    });\n 170→    await reply(`❌ 启动失败: ${error.message}`);\n 171→  }\n 172→}\n 173→\n 174→/**\n 175→ * Handle status subcommand.\n 176→ */\n 177→async function handleStatus({ params, reply }) {\n 178→  const pipelineType = params.type || 'feature';\n 179→\n 180→  try {\n 181→    const result = await getStatus({ type: pipelineType });\n 182→\n 183→    if (result.ok) {\n 184→      const status = formatStatusOutput(result);\n 185→      await reply(status);\n 186→    } else {\n 187→      const errorMsg = result.message || result.stderr || '未知错误';\n 188→      await reply(`❌ 查询失败: ${errorMsg}`);\n 189→    }\n 190→  } catch (error) {\n 191→    await reply(`❌ 查询失败: ${error.message}`);\n 192→  }\n 193→}\n 194→\n 195→/**\n 196→ * Handle logs subcommand.\n 197→ */\n 198→async function handleLogs({ params, reply, replyFile, parsed }) {\n 199→  const target = params._args?.[0] || params.target;\n 200→  const pipelineType = params.type || 'feature';\n 201→\n 202→  try {\n 203→    const result = await getLogs({ type: pipelineType, lines: 100 });\n 204→\n 205→    if (result.ok) {\n 206→      const logs = result.logs || '';\n 207→\n 208→      if (logs.length >= 4000) {\n 209→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n 210→      } else {\n 211→        await reply(logs || '暂无日志');\n 212→      }\n 213→    } else {\n 214→      const errorMsg = result.message || '未知错误';\n 215→      await reply(`❌ 获取日志失败: ${errorMsg}`);\n 216→    }\n 217→  } catch (error) {\n 218→    await reply(`❌ 获取日志失败: ${error.message}`);\n 219→  }\n 220→}\n 221→\n 222→/**\n 223→ * Handle stop subcommand (pipeline stop).\n 224→ * T-104, T-106: Added confirmation flow\n 225→ * T-107: Added audit logging\n 226→ */\n 227→async function handlePipelineStop(handlerCtx) {\n 228→  const { params, reply, parsed, userId, userRole, requiresConfirmation } = handlerCtx;\n 229→\n 230→  // Sanitize type parameter (T-103)\n 231→  const pipelineType = params.type || 'feature';\n 232→  const typeResult = sanitizeParam(pipelineType, { maxLength: 50 });\n 233→  if (!typeResult.ok) {\n 234→    await reply(`❌ 类型参数无效: ${typeResult.error}`);\n 235→    return;\n 236→  }\n 237→\n 238→  // Check if force flag is set\n 239→  const forceFlag = params.force === true || parsed?.flags?.force === true;\n 240→  const canSkipConfirmation = isAdmin(userId) && forceFlag;\n 241→\n 242→  // Handle confirmation flow\n 243→  if (requiresConfirmation && !canSkipConfirmation) {\n 244→    const rawTarget = params._args?.[0] || params.target;\n 245→\n 246→    // Check if this is a CONFIRM response\n 247→    if (rawTarget === 'CONFIRM') {\n 248→      const pendingKey = `pipeline-stop:${userId}`;\n 249→      const confirmId = pendingConfirmations.get(pendingKey);\n 250→\n 251→      if (confirmId) {\n 252→        const result = confirmAction(confirmId, userId);\n 253→        if (result.ok) {\n 254→          pendingConfirmations.delete(pendingKey);\n 255→          await executePipelineStop(handlerCtx, result.params.type, userId, userRole, reply);\n 256→        } else {\n 257→          await reply(`❌ 确认失败: ${result.error}`);\n 258→        }\n 259→        return;\n 260→      } else {\n 261→        await reply('❌ 没有待确认的 stop 操作，或操作已过期。');\n 262→        return;\n 263→      }\n 264→    }\n 265→\n 266→    // Check if this is a CANCEL response\n 267→    if (rawTarget === 'CANCEL') {\n 268→      const pendingKey = `pipeline-stop:${userId}`;\n 269→      const confirmId = pendingConfirmations.get(pendingKey);\n 270→      if (confirmId) {\n 271→        cancelConfirmation(confirmId, userId);\n 272→        pendingConfirmations.delete(pendingKey);\n 273→        await reply('✅ 已取消 stop 操作。');\n 274→      } else {\n 275→        await reply('没有待确认的 stop 操作。');\n 276→      }\n 277→      return;\n 278→    }\n 279→\n 280→    // Create new confirmation\n 281→    const { confirmId, message } = createConfirmation(userId, 'pipeline-stop', { type: typeResult.value });\n 282→    pendingConfirmations.set(`pipeline-stop:${userId}`, confirmId);\n 283→\n 284→    await reply(`⚠️ 高风险操作确认\\n\\n${message}\\n\\n请回复 /pipeline stop CONFIRM 确认，或 /pipeline stop CANCEL 取消。`);\n 285→    return;\n 286→  }\n 287→\n 288→  // Execute directly\n 289→  await executePipelineStop(handlerCtx, typeResult.value, userId, userRole, reply);\n 290→}\n 291→\n 292→/**\n 293→ * Execute pipeline stop operation\n 294→ */\n 295→async function executePipelineStop(handlerCtx, pipelineType, userId, userRole, reply) {\n 296→  try {\n 297→    const result = await stopPipeline({ type: pipelineType });\n 298→\n 299→    if (result.ok) {\n 300→      await logAuditEntry({\n 301→        userId,\n 302→        role: userRole,\n 303→        action: 'pipeline_stop',\n 304→        params: { type: pipelineType },\n 305→        result: 'success'\n 306→      });\n 307→\n 308→      if (result.errorCode === 'ALREADY_STOPPED') {\n 309→        await reply(`⚠️ ${pipelineType} 管道未在运行。`);\n 310→      } else {\n 311→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n 312→        await reply(`✅ 已停止 ${pipelineType} 管道${pidInfo}`);\n 313→      }\n 314→    } else {\n 315→      const errorMsg = result.message || '未知错误';\n 316→      await logAuditEntry({\n 317→        userId,\n 318→        role: userRole,\n 319→        action: 'pipeline_stop',\n 320→        params: { type: pipelineType },\n 321→        result: 'failed',\n 322→        reason: errorMsg\n 323→      });\n 324→      await reply(`❌ 停止失败: ${errorMsg}`);\n 325→    }\n 326→  } catch (error) {\n 327→    await logAuditEntry({\n 328→      userId,\n 329→      role: userRole,\n 330→      action: 'pipeline_stop',\n 331→      params: { type: pipelineType },\n 332→      result: 'failed',\n 333→      reason: error.message\n 334→    });\n 335→    await reply(`❌ 停止失败: ${error.message}`);\n 336→  }\n 337→}\n 338→\n 339→/**\n 340→ * Handle force-unlock subcommand.\n 341→ * T-105: Force-unlock command handler\n 342→ * T-104: Confirmation flow\n 343→ * T-107: Audit logging\n 344→ */\n 345→async function handleForceUnlock(handlerCtx) {\n 346→  const { params, reply, parsed, userId, userRole, requiresConfirmation } = handlerCtx;\n 347→\n 348→  // Sanitize type parameter (T-103)\n 349→  const pipelineType = params.type || 'feature';\n 350→  const typeResult = sanitizeParam(pipelineType, { maxLength: 50 });\n 351→  if (!typeResult.ok) {\n 352→    await reply(`❌ 类型参数无效: ${typeResult.error}`);\n 353→    return;\n 354→  }\n 355→\n 356→  // Check if force flag is set\n 357→  const forceFlag = params.force === true || parsed?.flags?.force === true;\n 358→  const canSkipConfirmation = isAdmin(userId) && forceFlag;\n 359→\n 360→  // Handle confirmation flow\n 361→  if (requiresConfirmation && !canSkipConfirmation) {\n 362→    const rawTarget = params._args?.[0] || params.target;\n 363→\n 364→    // Check if this is a CONFIRM response\n 365→    if (rawTarget === 'CONFIRM') {\n 366→      const pendingKey = `force-unlock:${userId}`;\n 367→      const confirmId = pendingConfirmations.get(pendingKey);\n 368→\n 369→      if (confirmId) {\n 370→        const result = confirmAction(confirmId, userId);\n 371→        if (result.ok) {\n 372→          pendingConfirmations.delete(pendingKey);\n 373→          await executeForceUnlock(handlerCtx, result.params.type, userId, userRole, reply);\n 374→        } else {\n 375→          await reply(`❌ 确认失败: ${result.error}`);\n 376→        }\n 377→        return;\n 378→      } else {\n 379→        await reply('❌ 没有待确认的 force-unlock 操作，或操作已过期。');\n 380→        return;\n 381→      }\n 382→    }\n 383→\n 384→    // Check if this is a CANCEL response\n 385→    if (rawTarget === 'CANCEL') {\n 386→      const pendingKey = `force-unlock:${userId}`;\n 387→      const confirmId = pendingConfirmations.get(pendingKey);\n 388→      if (confirmId) {\n 389→        cancelConfirmation(confirmId, userId);\n 390→        pendingConfirmations.delete(pendingKey);\n 391→        await reply('✅ 已取消 force-unlock 操作。');\n 392→      } else {\n 393→        await reply('没有待确认的 force-unlock 操作。');\n 394→      }\n 395→      return;\n 396→    }\n 397→\n 398→    // Create new confirmation\n 399→    const { confirmId, message } = createConfirmation(userId, 'force-unlock', { type: typeResult.value });\n 400→    pendingConfirmations.set(`force-unlock:${userId}`, confirmId);\n 401→\n 402→    await reply(`⚠️ 高风险操作确认\\n\\n${message}\\n\\n请回复 /pipeline force-unlock CONFIRM 确认，或 /pipeline force-unlock CANCEL 取消。`);\n 403→    return;\n 404→  }\n 405→\n 406→  // Execute directly\n 407→  await executeForceUnlock(handlerCtx, typeResult.value, userId, userRole, reply);\n 408→}\n 409→\n 410→/**\n 411→ * Execute force-unlock operation\n 412→ */\n 413→async function executeForceUnlock(handlerCtx, pipelineType, userId, userRole, reply) {\n 414→  try {\n 415→    const result = await forceUnlock({ type: pipelineType });\n 416→\n 417→    if (result.ok) {\n 418→      await logAuditEntry({\n 419→        userId,\n 420→        role: userRole,\n 421→        action: 'force-unlock',\n 422→        params: { type: pipelineType },\n 423→        result: 'success'\n 424→      });\n 425→\n 426→      if (result.wasLocked) {\n 427→        await reply(`✅ 已强制释放 ${pipelineType} 管道的锁 (原 PID: ${result.previousPid || '未知'})`);\n 428→      } else {\n 429→        await reply(`⚠️ ${pipelineType} 管道未被锁定。`);\n 430→      }\n 431→    } else {\n 432→      const errorMsg = result.message || '未知错误';\n 433→      await logAuditEntry({\n 434→        userId,\n 435→        role: userRole,\n 436→        action: 'force-unlock',\n 437→        params: { type: pipelineType },\n 438→        result: 'failed',\n 439→        reason: errorMsg\n 440→      });\n 441→      await reply(`❌ 释放锁失败: ${errorMsg}`);\n 442→    }\n 443→  } catch (error) {\n 444→    await logAuditEntry({\n 445→      userId,\n 446→      role: userRole,\n 447→      action: 'force-unlock',\n 448→      params: { type: pipelineType },\n 449→      result: 'failed',\n 450→      reason: error.message\n 451→    });\n 452→    await reply(`❌ 释放锁失败: ${error.message}`);\n 453→  }\n 454→}\n 455→\n 456→/**\n 457→ * Format status output.\n 458→ * @param {Object} result - Status result\n 459→ * @returns {string} Formatted status\n 460→ */\n 461→function formatStatusOutput(result) {\n 462→  if (!result.isRunning) {\n 463→    const lastResultInfo = result.lastResult\n 464→      ? `\\n最后一次运行: ${result.lastResult.status} (${result.lastResult.featuresCompleted}/${result.lastResult.featuresTotal})`\n 465→      : '';\n 466→    return `✅ ${result.message}${lastResultInfo}`;\n 467→  }\n 468→\n 469→  const lines = [`🔄 ${result.message}`, ''];\n 470→\n 471→  if (result.pid) {\n 472→    lines.push(`• PID: ${result.pid}`);\n 473→  }\n 474→\n 475→  if (result.currentFeature) {\n 476→    lines.push(`• 当前目标: ${result.currentFeature}`);\n 477→  }\n 478→\n 479→  if (result.startedAt) {\n 480→    lines.push(`• 开始时间: ${result.startedAt}`);\n 481→  }\n 482→\n 483→  if (result.lockInfo) {\n 484→    lines.push(`• 锁持有者 PID: ${result.lockInfo.pid}`);\n 485→  }\n 486→\n 487→  return lines.join('\\n');\n 488→}\n 489→\n 490→export default handlePipeline;\n 491→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019cdec32d7c15d0f91483a9f4d163da","__timestamp":"2026-03-11T21:24:45.149Z","_requestId":"831488a1f0e5461b9b01219ae792e61e"}
