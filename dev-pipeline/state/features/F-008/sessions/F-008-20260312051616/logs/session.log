TERVAL_MS = 1200;\n  29Ôćĺconst TYPING_INTERVAL_MS = 3500;\n  30Ôćĺconst PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  31Ôćĺconst DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  32Ôćĺconst ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  33Ôćĺconst TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  34Ôćĺconst TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  35Ôćĺconst TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  36Ôćĺconst TMP_DIR = path.resolve(os.tmpdir());\n  37Ôćĺconst HOME_DIR = path.resolve(os.homedir());\n  38Ôćĺconst DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  39Ôćĺconst DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  40Ôćĺconst DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  41Ôćĺconst DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  42Ôćĺ\n  43Ôćĺfunction resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  44Ôćĺ  const normalized = configuredDirs\n  45Ôćĺ    .map((dir) => String(dir ?? '').trim())\n  46Ôćĺ    .filter(Boolean)\n  47Ôćĺ    .map((dir) => path.resolve(dir));\n  48Ôćĺ\n  49Ôćĺ  if (normalized.length > 0) {\n  50Ôćĺ    return [...new Set(normalized)];\n  51Ôćĺ  }\n  52Ôćĺ\n  53Ôćĺ  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  54Ôćĺ}\n  55Ôćĺ\n  56Ôćĺconst ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  57Ôćĺconst FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  58Ôćĺ\n  59Ôćĺfunction splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  60Ôćĺ  const chunks = [];\n  61Ôćĺ  for (let i = 0; i < text.length; i += chunkSize) {\n  62Ôćĺ    chunks.push(text.slice(i, i + chunkSize));\n  63Ôćĺ  }\n  64Ôćĺ  return chunks;\n  65Ôćĺ}\n  66Ôćĺ\n  67Ôćĺfunction sanitizeMarkerPath(raw) {\n  68Ôćĺ  return String(raw ?? '')\n  69Ôćĺ    .trim()\n  70Ôćĺ    .replace(/^['\"`]+/, '')\n  71Ôćĺ    .replace(/['\"`]+$/, '');\n  72Ôćĺ}\n  73Ôćĺ\n  74Ôćĺfunction extractFileMarkers(text = '') {\n  75Ôćĺ  const fileRefs = [];\n  76Ôćĺ\n  77Ôćĺ  const withSendFileRemoved = text.replace(\n  78Ôćĺ    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  79Ôćĺ    (_full, rawRef) => {\n  80Ôćĺ      const ref = sanitizeMarkerPath(rawRef);\n  81Ôćĺ      if (ref) {\n  82Ôćĺ        fileRefs.push(ref);\n  83Ôćĺ      }\n  84Ôćĺ      return '\\n';\n  85Ôćĺ    }\n  86Ôćĺ  );\n  87Ôćĺ\n  88Ôćĺ  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  89Ôćĺ    const ref = sanitizeMarkerPath(rawRef);\n  90Ôćĺ    if (ref) {\n  91Ôćĺ      fileRefs.push(ref);\n  92Ôćĺ    }\n  93Ôćĺ    return '';\n  94Ôćĺ  });\n  95Ôćĺ\n  96Ôćĺ  const withBacktickPathRemoved = withImageRemoved.replace(\n  97Ôćĺ    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n  98Ôćĺ    (_full, rawRef) => {\n  99Ôćĺ      const ref = sanitizeMarkerPath(rawRef);\n 100Ôćĺ      if (ref) {\n 101Ôćĺ        fileRefs.push(ref);\n 102Ôćĺ      }\n 103Ôćĺ      return '';\n 104Ôćĺ    }\n 105Ôćĺ  );\n 106Ôćĺ\n 107Ôćĺ  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 108Ôćĺ    /(?:Šľçń╗ÂŔĚ»ňżä|path)\\s*[:´╝Ü]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 109Ôćĺ    (_full, rawRef) => {\n 110Ôćĺ      const ref = sanitizeMarkerPath(rawRef);\n 111Ôćĺ      if (ref) {\n 112Ôćĺ        fileRefs.push(ref);\n 113Ôćĺ      }\n 114Ôćĺ      return '';\n 115Ôćĺ    }\n 116Ôćĺ  );\n 117Ôćĺ\n 118Ôćĺ  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 119Ôćĺ    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 120Ôćĺ    (_full, rawRef) => {\n 121Ôćĺ      const ref = sanitizeMarkerPath(rawRef);\n 122Ôćĺ      if (ref) {\n 123Ôćĺ        fileRefs.push(ref);\n 124Ôćĺ      }\n 125Ôćĺ      return '\\n';\n 126Ôćĺ    }\n 127Ôćĺ  );\n 128Ôćĺ\n 129Ôćĺ  return {\n 130Ôćĺ    fileRefs: [...new Set(fileRefs)],\n 131Ôćĺ    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 132Ôćĺ  };\n 133Ôćĺ}\n 134Ôćĺ\n 135Ôćĺfunction isPathWithinRoot(targetPath, rootPath) {\n 136Ôćĺ  const relative = path.relative(rootPath, targetPath);\n 137Ôćĺ  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 138Ôćĺ}\n 139Ôćĺ\n 140Ôćĺfunction isAllowedFilePath(filePath) {\n 141Ôćĺ  const resolved = path.resolve(filePath);\n 142Ôćĺ  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 143Ôćĺ}\n 144Ôćĺ\n 145Ôćĺfunction buildFileCandidates(normalizedPath) {\n 146Ôćĺ  if (path.isAbsolute(normalizedPath)) {\n 147Ôćĺ    return [normalizedPath];\n 148Ôćĺ  }\n 149Ôćĺ\n 150Ôćĺ  const baseName = path.basename(normalizedPath);\n 151Ôćĺ  const candidates = [\n 152Ôćĺ    path.resolve(process.cwd(), normalizedPath),\n 153Ôćĺ    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 154Ôćĺ  ];\n 155Ôćĺ\n 156Ôćĺ  return [...new Set(candidates)];\n 157Ôćĺ}\n 158Ôćĺ\n 159Ôćĺasync function resolveLocalFilePath(fileRef) {\n 160Ôćĺ  const normalized = sanitizeMarkerPath(fileRef);\n 161Ôćĺ  if (!normalized) {\n 162Ôćĺ    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 163Ôćĺ  }\n 164Ôćĺ\n 165Ôćĺ  if (!path.isAbsolute(normalized)) {\n 166Ôćĺ    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 167Ôćĺ  }\n 168Ôćĺ\n 169Ôćĺ  const candidates = buildFileCandidates(normalized);\n 170Ôćĺ\n 171Ôćĺ  for (const candidate of candidates) {\n 172Ôćĺ    try {\n 173Ôćĺ      await access(candidate);\n 174Ôćĺ      return { filePath: candidate, triedPaths: candidates };\n 175Ôćĺ    } catch {\n 176Ôćĺ      // ignore\n 177Ôćĺ    }\n 178Ôćĺ  }\n 179Ôćĺ\n 180Ôćĺ  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 181Ôćĺ}\n 182Ôćĺ\n 183Ôćĺasync function validateFileForTelegram(filePath) {\n 184Ôćĺ  const resolvedPath = path.resolve(filePath);\n 185Ôćĺ  if (!isAllowedFilePath(resolvedPath)) {\n 186Ôćĺ    return { ok: false, reason: `ŔĚ»ňżäńŞŹňťĘňůüŔ«ŞŔîâňŤ┤´╝Ü${resolvedPath}` };\n 187Ôćĺ  }\n 188Ôćĺ\n 189Ôćĺ  const ext = path.extname(resolvedPath).toLowerCase();\n 190Ôćĺ  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 191Ôćĺ    return { ok: false, reason: `ńŞŹŠö»ŠîüšÜäŠľçń╗Âš▒╗ň×ő´╝Ü${ext || '(unknown)'}` };\n 192Ôćĺ  }\n 193Ôćĺ\n 194Ôćĺ  const fileStat = await stat(resolvedPath);\n 195Ôćĺ  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 196Ôćĺ  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 197Ôćĺ\n 198Ôćĺ  if (fileStat.size > maxSize) {\n 199Ôćĺ    return {\n 200Ôćĺ      ok: false,\n 201Ôćĺ      reason: `Šľçń╗ÂŔ┐çňĄž´╝Ü${Math.ceil(fileStat.size / 1024 / 1024)}MB´╝îÚÖÉňłÂ ${Math.floor(maxSize / 1024 / 1024)}MB`\n 202Ôćĺ    };\n 203Ôćĺ  }\n 204Ôćĺ\n 205Ôćĺ  return { ok: true, isPhoto, resolvedPath };\n 206Ôćĺ}\n 207Ôćĺ\n 208Ôćĺfunction isTimeoutLikeError(message = '') {\n 209Ôćĺ  const normalized = String(message).toLowerCase();\n 210Ôćĺ  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 211Ôćĺ}\n 212Ôćĺ\n 213Ôćĺfunction sleep(ms) {\n 214Ôćĺ  return new Promise((resolve) => setTimeout(resolve, ms));\n 215Ôćĺ}\n 216Ôćĺ\n 217Ôćĺasync function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 218Ôćĺ  if (isPhoto) {\n 219Ôćĺ    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 220Ôćĺ    return;\n 221Ôćĺ  }\n 222Ôćĺ\n 223Ôćĺ  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 224Ôćĺ}\n 225Ôćĺ\n 226Ôćĺasync function replyFiles(ctx, fileRefs = []) {\n 227Ôćĺ  const results = [];\n 228Ôćĺ\n 229Ôćĺ  for (const fileRef of fileRefs) {\n 230Ôćĺ    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 231Ôćĺ    if (!filePath) {\n 232Ôćĺ      const reason = rejectReason || 'not_found';\n 233Ôćĺ      results.push({ fileRef, sent: false, reason, triedPaths });\n 234Ôćĺ      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 235Ôćĺ      continue;\n 236Ôćĺ    }\n 237Ôćĺ\n 238Ôćĺ    try {\n 239Ôćĺ      const validation = await validateFileForTelegram(filePath);\n 240Ôćĺ      if (!validation.ok) {\n 241Ôćĺ        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 242Ôćĺ        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 243Ôćĺ        continue;\n 244Ôćĺ      }\n 245Ôćĺ\n 246Ôćĺ      const actualPath = validation.resolvedPath;\n 247Ôćĺ      let sent = false;\n 248Ôćĺ      let lastReason = '';\n 249Ôćĺ\n 250Ôćĺ      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 251Ôćĺ        try {\n 252Ôćĺ          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 253Ôćĺ          sent = true;\n 254Ôćĺ          logger.info(\n 255Ôćĺ            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 256Ôćĺ            'Telegram file sent'\n 257Ôćĺ          );\n 258Ôćĺ          break;\n 259Ôćĺ        } catch (error) {\n 260Ôćĺ          lastReason = error instanceof Error ? error.message : String(error);\n 261Ôćĺ          logger.warn(\n 262Ôćĺ            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 263Ôćĺ            'Telegram file send attempt failed'\n 264Ôćĺ          );\n 265Ôćĺ\n 266Ôćĺ          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 267Ôćĺ            await sleep(600);\n 268Ôćĺ            continue;\n 269Ôćĺ          }\n 270Ôćĺ\n 271Ôćĺ          break;\n 272Ôćĺ        }\n 273Ôćĺ      }\n 274Ôćĺ\n 275Ôćĺ      if (!sent) {\n 276Ôćĺ        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 277Ôćĺ        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 278Ôćĺ        continue;\n 279Ôćĺ      }\n 280Ôćĺ\n 281Ôćĺ      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 282Ôćĺ    } catch (error) {\n 283Ôćĺ      const reason = error instanceof Error ? error.message : String(error);\n 284Ôćĺ      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 285Ôćĺ      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 286Ôćĺ    }\n 287Ôćĺ  }\n 288Ôćĺ\n 289Ôćĺ  return results;\n 290Ôćĺ}\n 291Ôćĺ\n 292Ôćĺasync function safeReply(ctx, text) {\n 293Ôćĺ  try {\n 294Ôćĺ    await ctx.reply(text);\n 295Ôćĺ    return true;\n 296Ôćĺ  } catch (error) {\n 297Ôćĺ    const reason = error instanceof Error ? error.message : String(error);\n 298Ôćĺ    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 299Ôćĺ    return false;\n 300Ôćĺ  }\n 301Ôćĺ}\n 302Ôćĺ\n 303Ôćĺasync function replyLargeText(ctx, text) {\n 304Ôćĺ  const chunks = splitMessage(text);\n 305Ôćĺ  for (const chunk of chunks) {\n 306Ôćĺ    const ok = await safeReply(ctx, chunk);\n 307Ôćĺ    if (!ok) {\n 308Ôćĺ      break;\n 309Ôćĺ    }\n 310Ôćĺ  }\n 311Ôćĺ}\n 312Ôćĺ\n 313Ôćĺasync function safeEditMessageText(ctx, messageId, text) {\n 314Ôćĺ  const nextText = text && text.trim() ? text : ' ';\n 315Ôćĺ\n 316Ôćĺ  try {\n 317Ôćĺ    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 318Ôćĺ  } catch (error) {\n 319Ôćĺ    const message = error instanceof Error ? error.message : String(error);\n 320Ôćĺ    if (message.includes('message is not modified')) {\n 321Ôćĺ      return;\n 322Ôćĺ    }\n 323Ôćĺ    throw error;\n 324Ôćĺ  }\n 325Ôćĺ}\n 326Ôćĺ\n 327Ôćĺfunction createEditableStreamPublisher(ctx) {\n 328Ôćĺ  let fullText = '';\n 329Ôćĺ  let renderedText = '';\n 330Ôćĺ  let pendingChars = 0;\n 331Ôćĺ  let lastFlushAt = 0;\n 332Ôćĺ  let flushChain = Promise.resolve();\n 333Ôćĺ  let activeMessage = null;\n 334Ôćĺ  let activeSegmentIndex = 0;\n 335Ôćĺ  let publishedMessageCount = 0;\n 336Ôćĺ\n 337Ôćĺ  async function ensureActiveMessage() {\n 338Ôćĺ    if (activeMessage) {\n 339Ôćĺ      return;\n 340Ôćĺ    }\n 341Ôćĺ    activeMessage = await ctx.reply('ňĄäšÉćńŞş...');\n 342Ôćĺ    activeSegmentIndex = 0;\n 343Ôćĺ    publishedMessageCount += 1;\n 344Ôćĺ  }\n 345Ôćĺ\n 346Ôćĺ  async function render(force = false) {\n 347Ôćĺ    const now = Date.now();\n 348Ôćĺ\n 349Ôćĺ    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 350Ôćĺ      return;\n 351Ôćĺ    }\n 352Ôćĺ\n 353Ôćĺ    if (fullText === renderedText) {\n 354Ôćĺ      pendingChars = 0;\n 355Ôćĺ      return;\n 356Ôćĺ    }\n 357Ôćĺ\n 358Ôćĺ    await ensureActiveMessage();\n 359Ôćĺ\n 360Ôćĺ    const segments = splitMessage(fullText);\n 361Ôćĺ    const targetLastIndex = Math.max(segments.length - 1, 0);\n 362Ôćĺ\n 363Ôćĺ    while (activeSegmentIndex < targetLastIndex) {\n 364Ôćĺ      const text = segments[activeSegmentIndex] ?? ' ';\n 365Ôćĺ      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 366Ôćĺ\n 367Ôćĺ      activeMessage = await ctx.reply('š╗žš╗şŔżôňç║ńŞş...');\n 368Ôćĺ      activeSegmentIndex += 1;\n 369Ôćĺ      publishedMessageCount += 1;\n 370Ôćĺ    }\n 371Ôćĺ\n 372Ôćĺ    const activeText = segments[targetLastIndex] ?? ' ';\n 373Ôćĺ    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 374Ôćĺ\n 375Ôćĺ    renderedText = fullText;\n 376Ôćĺ    pendingChars = 0;\n 377Ôćĺ    lastFlushAt = now;\n 378Ôćĺ  }\n 379Ôćĺ\n 380Ôćĺ  function enqueueRender(force = false) {\n 381Ôćĺ    flushChain = flushChain.then(() => render(force));\n 382Ôćĺ  }\n 383Ôćĺ\n 384Ôćĺ  return {\n 385Ôćĺ    push(text) {\n 386Ôćĺ      const appendText = text ?? '';\n 387Ôćĺ      if (!appendText) {\n 388Ôćĺ        return;\n 389Ôćĺ      }\n 390Ôćĺ      fullText += appendText;\n 391Ôćĺ      pendingChars += appendText.length;\n 392Ôćĺ      enqueueRender(false);\n 393Ôćĺ    },\n 394Ôćĺ    setFinalText(text) {\n 395Ôćĺ      fullText = text ?? '';\n 396Ôćĺ      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 397Ôćĺ      enqueueRender(true);\n 398Ôćĺ    },\n 399Ôćĺ    async finish() {\n 400Ôćĺ      enqueueRender(true);\n 401Ôćĺ      await flushChain;\n 402Ôćĺ      return {\n 403Ôćĺ        outputLength: renderedText.length,\n 404Ôćĺ        messageCount: publishedMessageCount\n 405Ôćĺ      };\n 406Ôćĺ    }\n 407Ôćĺ  };\n 408Ôćĺ}\n 409Ôćĺ\n 410Ôćĺfunction buildSessionId(ctx) {\n 411Ôćĺ  return String(ctx.chat.id);\n 412Ôćĺ}\n 413Ôćĺ\n 414Ôćĺfunction ensureAllowed(ctx) {\n 415Ôćĺ  const userId = ctx.from?.id;\n 416Ôćĺ  if (!isAllowedUser(userId)) {\n 417Ôćĺ    throw new Error('ňŻôňëŹŔ┤ŽňĆĚŠť¬ŔóźŠÄłŠŁâńŻ┐šöĘŔ»ąŠť║ňÖĘń║║ŃÇé');\n 418Ôćĺ  }\n 419Ôćĺ}\n 420Ôćĺ\n 421Ôćĺ/**\n 422Ôćĺ * Register all pipeline-related commands.\n 423Ôćĺ */\n 424Ôćĺfunction registerPipelineCommands() {\n 425Ôćĺ  registerCommand(pipelineMeta, handlePipeline);\n 426Ôćĺ  registerCommand(bugfixMeta, handleBugfix);\n 427Ôćĺ  registerCommand(plannerMeta, handlePlanner);\n 428Ôćĺ  registerCommand(statusMeta, handleStatus);\n 429Ôćĺ  registerCommand(logsMeta, handleLogs);\n 430Ôćĺ  registerCommand(stopMeta, handleStop);\n 431Ôćĺ  registerCommand(planMeta, handlePlan);\n 432Ôćĺ  registerCommand(auditMeta, handleAudit);\n 433Ôćĺ}\n 434Ôćĺ\n 435Ôćĺexport function createTelegramBot() {\n 436Ôćĺ  const bot = new Telegraf(config.telegramBotToken, {\n 437Ôćĺ    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 438Ôćĺ  });\n 439Ôćĺ\n 440Ôćĺ  // Register pipeline commands\n 441Ôćĺ  registerPipelineCommands();\n 442Ôćĺ\n 443Ôćĺ  bot.catch((error, ctx) => {\n 444Ôćĺ    const message = error instanceof Error ? error.message : String(error);\n 445Ôćĺ    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 446Ôćĺ  });\n 447Ôćĺ\n 448Ôćĺ  bot.start(async (ctx) => {\n 449Ôćĺ    await ctx.reply('PrizmClaw ňĚ▓ňÉ»ňŐĘŃÇéňĆ»šŤ┤ŠÄąŔüŐňĄę´╝îń╣čňĆ»šöĘ /help ŠčąšťőňĆ»šöĘňĹŻń╗ĄŃÇé');\n 450Ôćĺ  });\n 451Ôćĺ\n 452Ôćĺ  bot.help(async (ctx) => {\n 453Ôćĺ    const helpText = generateHelp();\n 454Ôćĺ    await ctx.reply(helpText);\n 455Ôćĺ  });\n 456Ôćĺ\n 457Ôćĺ  bot.command('reset', async (ctx) => {\n 458Ôćĺ    try {\n 459Ôćĺ      ensureAllowed(ctx);\n 460Ôćĺ      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 461Ôćĺ      await ctx.reply('ňĚ▓ŠŞůšę║ňŻôňëŹń╝ÜŔ»ŁńŞŐńŞőŠľçŃÇé');\n 462Ôćĺ    } catch (error) {\n 463Ôćĺ      await ctx.reply(error instanceof Error ? error.message : String(error));\n 464Ôćĺ    }\n 465Ôćĺ  });\n 466Ôćĺ\n 467Ôćĺ  bot.command('screenshot', async (ctx) => {\n 468Ôćĺ    try {\n 469Ôćĺ      ensureAllowed(ctx);\n 470Ôćĺ      await ctx.reply('ŠşúňťĘŔÄĚňĆľŠł¬ňŤżŃÇé');\n 471Ôćĺ      const { buffer } = await captureScreenshot();\n 472Ôćĺ      await ctx.replyWithPhoto({ source: buffer }, { caption: 'ňŻôňëŹŠťČňť░ň▒Ćň╣ĽŠł¬ňŤż' });\n 473Ôćĺ    } catch (error) {\n 474Ôćĺ      const message = error instanceof Error ? error.message : String(error);\n 475Ôćĺ      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 476Ôćĺ      await ctx.reply(`Šł¬ňŤżňĄ▒Ŕ┤ą´╝Ü${message}`);\n 477Ôćĺ    }\n 478Ôćĺ  });\n 479Ôćĺ\n 480Ôćĺ  bot.command('exec', async (ctx) => {\n 481Ôćĺ    try {\n 482Ôćĺ      ensureAllowed(ctx);\n 483Ôćĺ      const payload = ctx.message.text.replace('/exec', '').trim();\n 484Ôćĺ      if (!payload) {\n 485Ôćĺ        await ctx.reply('Ŕ»ĚŠĆÉńżŤňĹŻń╗Ą´╝îńżőňŽé /exec pwd');\n 486Ôćĺ        return;\n 487Ôćĺ      }\n 488Ôćĺ\n 489Ôćĺ      await ctx.reply('ŠşúňťĘŠëžŔíîňĹŻń╗ĄŃÇé');\n 490Ôćĺ      const result = await executeSystemCommand(payload);\n 491Ôćĺ      const output = [\n 492Ôćĺ        `exitCode: ${result.exitCode}`,\n 493Ôćĺ        result.stdout ? `stdout:\\n${result.stdout}` : 'stdout: (empty)',\n 494Ôćĺ        result.stderr ? `stderr:\\n${result.stderr}` : 'stderr: (empty)'\n 495Ôćĺ      ].join('\\n\\n');\n 496Ôćĺ\n 497Ôćĺ      await replyLargeText(ctx, output);\n 498Ôćĺ    } catch (error) {\n 499Ôćĺ      const message = error instanceof Error ? error.message : String(error);\n 500Ôćĺ      logger.error({ err: message }, 'Failed to exec command in telegram');\n 501Ôćĺ      await ctx.reply(`ŠëžŔíîňĄ▒Ŕ┤ą´╝Ü${message}`);\n 502Ôćĺ    }\n 503Ôćĺ  });\n 504Ôćĺ\n 505Ôćĺ  // T-100: Document upload handler for plan files\n 506Ôćĺ  bot.on('document', async (ctx) => {\n 507Ôćĺ    try {\n 508Ôćĺ      ensureAllowed(ctx);\n 509Ôćĺ\n 510Ôćĺ      const document = ctx.message?.document;\n 511Ôćĺ      if (!document) {\n 512Ôćĺ        return;\n 513Ôćĺ      }\n 514Ôćĺ\n 515Ôćĺ      // Check file extension\n 516Ôćĺ      const fileName = document.file_name || '';\n 517Ôćĺ      const ext = path.extname(fileName).toLowerCase();\n 518Ôćĺ\n 519Ôćĺ      if (ext !== '.json') {\n 520Ôćĺ        // Not a JSON file, ignore silently (other handlers may process it)\n 521Ôćĺ        return;\n 522Ôćĺ      }\n 523Ôćĺ\n 524Ôćĺ      // Check file size\n 525Ôćĺ      const fileSize = document.file_size || 0;\n 526Ôćĺ      if (fileSize > 1024 * 1024) { // 1MB limit\n 527Ôćĺ        await ctx.reply('ÔŁî Šľçń╗ÂŔ┐çňĄž´╝îÚÖÉňłÂ 1MBŃÇé');\n 528Ôćĺ        return;\n 529Ôćĺ      }\n 530Ôćĺ\n 531Ôćĺ      await ctx.reply('ŠşúňťĘňĄäšÉćńŞŐń╝ášÜäŔ«íňłĺŠľçń╗Â...');\n 532Ôćĺ\n 533Ôćĺ      // Download file content\n 534Ôćĺ      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 535Ôćĺ      const fileUrl = fileLink.href || fileLink.toString();\n 536Ôćĺ\n 537Ôćĺ      const response = await fetch(fileUrl);\n 538Ôćĺ      if (!response.ok) {\n 539Ôćĺ        throw new Error(`ńŞőŔŻŻŠľçń╗ÂňĄ▒Ŕ┤ą: ${response.status}`);\n 540Ôćĺ      }\n 541Ôćĺ\n 542Ôćĺ      const content = await response.text();\n 543Ôćĺ\n 544Ôćĺ      // Validate and save using plan-ingestion-service\n 545Ôćĺ      const infraConfig = loadPipelineInfraConfig();\n 546Ôćĺ      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 547Ôćĺ\n 548Ôćĺ      const validationResult = planService.validate(content);\n 549Ôćĺ\n 550Ôćĺ      if (!validationResult.valid) {\n 551Ôćĺ        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 552Ôćĺ        await ctx.reply(errorMsg);\n 553Ôćĺ        return;\n 554Ôćĺ      }\n 555Ôćĺ\n 556Ôćĺ      // Save the plan\n 557Ôćĺ      const saveResult = await planService.save(\n 558Ôćĺ        validationResult.type,\n 559Ôćĺ        content,\n 560Ôćĺ        { uploadedBy: ctx.from?.id }\n 561Ôćĺ      );\n 562Ôćĺ\n 563Ôćĺ      if (!saveResult.success) {\n 564Ôćĺ        await ctx.reply('ÔŁî ń┐ŁňşśňĄ▒Ŕ┤ą´╝îŔ»ĚšĘŹňÉÄÚçŹŔ»ĽŃÇé');\n 565Ôćĺ        return;\n 566Ôćĺ      }\n 567Ôćĺ\n 568Ôćĺ      // Set as current version\n 569Ôćĺ      await planService.setCurrent(validationResult.type, saveResult.version);\n 570Ôćĺ\n 571Ôćĺ      // Format success message\n 572Ôćĺ      const typeDisplay = validationResult.type === 'feature-list' ? 'šë╣ŠÇžňłŚŔíĘ' : 'Bugń┐«ňĄŹňłŚŔíĘ';\n 573Ôćĺ      const summary = validationResult.summary;\n 574Ôćĺ\n 575Ôćĺ      await ctx.reply([\n 576Ôćĺ        `Ôťů ${typeDisplay}ňĚ▓ń┐Łňşśň╣ÂŠ┐ÇŠ┤╗`,\n 577Ôćĺ        `šëłŠťČ: ${saveResult.version}`,\n 578Ôćĺ        `ňÉŹšž░: ${summary?.name || 'Šť¬ščą'}`,\n 579Ôćĺ        `Úí╣šŤ«ŠĽ░: ${summary?.itemCount || 0}`,\n 580Ôćĺ        '',\n 581Ôćĺ        summary?.statusBreakdown ? 'šŐÂŠÇüňłćňŞâ:' : '',\n 582Ôćĺ        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 583Ôćĺ      ].filter(Boolean).join('\\n'));\n 584Ôćĺ\n 585Ôćĺ    } catch (error) {\n 586Ôćĺ      const message = error instanceof Error ? error.message : String(error);\n 587Ôćĺ      logger.error({ err: message }, 'Failed to process document upload');\n 588Ôćĺ      await ctx.reply(`ÔŁî ňĄäšÉćňĄ▒Ŕ┤ą´╝Ü${message}`);\n 589Ôćĺ    }\n 590Ôćĺ  });\n 591Ôćĺ\n 592Ôćĺ  bot.on('text', async (ctx) => {\n 593Ôćĺ    // Check for pipeline commands first\n 594Ôćĺ    const handled = await routeCommand(ctx);\n 595Ôćĺ    if (handled) {\n 596Ôćĺ      return;\n 597Ôćĺ    }\n 598Ôćĺ\n 599Ôćĺ    const sessionId = buildSessionId(ctx);\n 600Ôćĺ\n 601Ôćĺ    let typingTimer = null;\n 602Ôćĺ\n 603Ôćĺ    try {\n 604Ôćĺ      ensureAllowed(ctx);\n 605Ôćĺ      await ctx.sendChatAction('typing');\n 606Ôćĺ\n 607Ôćĺ      const streamPublisher = createEditableStreamPublisher(ctx);\n 608Ôćĺ      typingTimer = setInterval(() => {\n 609Ôćĺ        ctx.sendChatAction('typing').catch(() => undefined);\n 610Ôćĺ      }, TYPING_INTERVAL_MS);\n 611Ôćĺ\n 612Ôćĺ      const reply = await chatWithSession({\n 613Ôćĺ        channel: 'telegram',\n 614Ôćĺ        sessionId,\n 615Ôćĺ        message: ctx.message.text,\n 616Ôćĺ        realtimeHooks: {\n 617Ôćĺ          onStatus: ({ stage }) => {\n 618Ôćĺ            if (stage === 'running') {\n 619Ôćĺ              ctx.sendChatAction('typing').catch(() => undefined);\n 620Ôćĺ            }\n 621Ôćĺ          },\n 622Ôćĺ          onAssistantChunk: ({ text }) => {\n 623Ôćĺ            streamPublisher.push(text);\n 624Ôćĺ          }\n 625Ôćĺ        }\n 626Ôćĺ      });\n 627Ôćĺ\n 628Ôćĺ      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 629Ôćĺ      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 630Ôćĺ      const finalText = cleanedText || (fileRefs.length > 0 ? 'ňĚ▓ŠëžŔíî´╝îŠşúňťĘňĆĹÚÇüŠľçń╗ÂŃÇé' : 'ňĚ▓ŠëžŔíîŃÇé');\n 631Ôćĺ\n 632Ôćĺ      streamPublisher.setFinalText(finalText);\n 633Ôćĺ      const streamed = await streamPublisher.finish();\n 634Ôćĺ      if (streamed.outputLength === 0) {\n 635Ôćĺ        await replyLargeText(ctx, finalText);\n 636Ôćĺ      }\n 637Ôćĺ\n 638Ôćĺ      if (fileRefs.length > 0) {\n 639Ôćĺ        const fileSendResults = await replyFiles(ctx, fileRefs);\n 640Ôćĺ        const failed = fileSendResults.filter((item) => !