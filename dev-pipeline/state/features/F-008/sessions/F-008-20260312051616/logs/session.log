{"type":"user","uuid":"09a8d68e-6113-4732-ab8d-f83608066b8c","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cdecb14f861eb354509e9566a0e2e","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Commit Command Handler\n   3Ôćĺ * F-008: Commit Workflow Integration\n   4Ôćĺ *\n   5Ôćĺ * Handles /commit command with optional --message, --amend, --force flags.\n   6Ôćĺ * Integrated with F-006 security layer for permission checks and confirmations.\n   7Ôćĺ */\n   8Ôćĺ\n   9Ôćĺimport { createCommitService } from '../../../services/commit-service.js';\n  10Ôćĺimport { createGitService } from '../../../services/git-service.js';\n  11Ôćĺimport { sessionStore } from '../../../services/session-store.js';\n  12Ôćĺimport { isAdmin } from '../../../security/permission-guard.js';\n  13Ôćĺimport {\n  14Ôćĺ  createConfirmation,\n  15Ôćĺ  confirmAction,\n  16Ôćĺ  cancelConfirmation\n  17Ôćĺ} from '../../../security/confirmation-manager.js';\n  18Ôćĺimport { sanitizeParam } from '../../../security/param-sanitizer.js';\n  19Ôćĺimport { logAuditEntry } from '../../../services/audit-log-service.js';\n  20Ôćĺ\n  21Ôćĺ// Store pending confirmations for amend/force operations\n  22Ôćĺconst pendingConfirmations = new Map();\n  23Ôćĺ\n  24Ôćĺ// Create commit service instance\n  25Ôćĺconst commitService = createCommitService({\n  26Ôćĺ  sessionStore: {\n  27Ôćĺ    addCommit: (sessionId, commitInfo) => sessionStore.addCommit(sessionId, commitInfo),\n  28Ôćĺ    getCommits: (sessionId) => sessionStore.getCommits(sessionId)\n  29Ôćĺ  }\n  30Ôćĺ});\n  31Ôćĺ\n  32Ôćĺ/**\n  33Ôćĺ * Commit command metadata\n  34Ôćĺ */\n  35Ôćĺexport const commitMeta = {\n  36Ôćĺ  name: 'commit',\n  37Ôćĺ  aliases: ['c'],\n  38Ôćĺ  description: 'ŠĆÉń║Ąń╗úšáüňĆśŠŤ┤',\n  39Ôćĺ  usage: '/commit [--message=\"...\"] [--amend] [--force]',\n  40Ôćĺ  examples: [\n  41Ôćĺ    '/commit',\n  42Ôćĺ    '/commit --message=\"feat: add new feature\"',\n  43Ôćĺ    '/commit --amend',\n  44Ôćĺ    '/commit --force'\n  45Ôćĺ  ],\n  46Ôćĺ  params: [\n  47Ôćĺ    {\n  48Ôćĺ      name: 'message',\n  49Ôćĺ      type: 'string',\n  50Ôćĺ      required: false,\n  51Ôćĺ      description: 'ŠĆÉń║Ąń┐íŠü»',\n  52Ôćĺ      aliases: ['m']\n  53Ôćĺ    },\n  54Ôćĺ    {\n  55Ôćĺ      name: 'amend',\n  56Ôćĺ      type: 'boolean',\n  57Ôćĺ      required: false,\n  58Ôćĺ      description: 'ń┐«Šö╣ŠťÇŔ┐ĹńŞÇŠČíŠĆÉń║Ą´╝łń╗ů admin´╝ë'\n  59Ôćĺ    },\n  60Ôćĺ    {\n  61Ôćĺ      name: 'force',\n  62Ôćĺ      type: 'boolean',\n  63Ôćĺ      required: false,\n  64Ôćĺ      description: 'ŔĚ│Ŕ┐çňëŹšŻ«ŠáíÚ¬î´╝łń╗ů admin´╝ë'\n  65Ôćĺ    }\n  66Ôćĺ  ],\n  67Ôćĺ  requiresAuth: true,\n  68Ôćĺ  minRole: 'operator',\n  69Ôćĺ  helpText: '/commit [--message=\"...\"] [--amend] [--force] - ŠĆÉń║Ąń╗úšáüňĆśŠŤ┤'\n  70Ôćĺ};\n  71Ôćĺ\n  72Ôćĺ/**\n  73Ôćĺ * Handle commit command\n  74Ôćĺ * @param {Object} handlerCtx - Handler context\n  75Ôćĺ */\n  76Ôćĺexport async function handleCommit(handlerCtx) {\n  77Ôćĺ  const { ctx, parsed, params, reply, userId, userRole, requiresConfirmation } = handlerCtx;\n  78Ôćĺ\n  79Ôćĺ  // Parse parameters\n  80Ôćĺ  const message = params.message || params.m || getDefaultCommitMessage();\n  81Ôćĺ  const amend = params.amend === true || parsed?.flags?.amend === true;\n  82Ôćĺ  const force = params.force === true || parsed?.flags?.force === true;\n  83Ôćĺ\n  84Ôćĺ  // Validate message length\n  85Ôćĺ  if (message.length > 500) {\n  86Ôćĺ    await reply('ÔŁî ŠĆÉń║Ąń┐íŠü»Ŕ┐çÚĽ┐´╝îŔ»ĚÚÖÉňłÂňťĘ 500 ňşŚšČŽń╗ąňćůŃÇé');\n  87Ôćĺ    return;\n  88Ôćĺ  }\n  89Ôćĺ\n  90Ôćĺ  // Sanitize message\n  91Ôćĺ  const messageResult = sanitizeParam(message, { maxLength: 500 });\n  92Ôćĺ  if (!messageResult.ok) {\n  93Ôćĺ    await reply(`ÔŁî ŠĆÉń║Ąń┐íŠü»ŠŚáŠĽł: ${messageResult.error}`);\n  94Ôćĺ    return;\n  95Ôćĺ  }\n  96Ôćĺ\n  97Ôćĺ  // Check amend/force permissions\n  98Ôćĺ  if (amend && !isAdmin(userId)) {\n  99Ôćĺ    await reply('ÔŁî --amend ÚťÇŔŽü admin ŠŁâÚÖÉŃÇé');\n 100Ôćĺ    await logAuditEntry({\n 101Ôćĺ      userId,\n 102Ôćĺ      role: userRole,\n 103Ôćĺ      action: 'commit:amend',\n 104Ôćĺ      params: { message: messageResult.value },\n 105Ôćĺ      result: 'denied',\n 106Ôćĺ      reason: 'Insufficient permissions'\n 107Ôćĺ    });\n 108Ôćĺ    return;\n 109Ôćĺ  }\n 110Ôćĺ\n 111Ôćĺ  if (force && !isAdmin(userId)) {\n 112Ôćĺ    await reply('ÔŁî --force ÚťÇŔŽü admin ŠŁâÚÖÉŃÇé');\n 113Ôćĺ    await logAuditEntry({\n 114Ôćĺ      userId,\n 115Ôćĺ      role: userRole,\n 116Ôćĺ      action: 'commit:force',\n 117Ôćĺ      params: { message: messageResult.value },\n 118Ôćĺ      result: 'denied',\n 119Ôćĺ      reason: 'Insufficient permissions'\n 120Ôćĺ    });\n 121Ôćĺ    return;\n 122Ôćĺ  }\n 123Ôćĺ\n 124Ôćĺ  // Handle confirmation flow for amend/force\n 125Ôćĺ  if ((amend || force) && requiresConfirmation) {\n 126Ôćĺ    const confirmKey = `commit:${amend ? 'amend' : 'force'}:${userId}`;\n 127Ôćĺ\n 128Ôćĺ    // Check if this is a CONFIRM response\n 129Ôćĺ    const rawArg = params._args?.[0];\n 130Ôćĺ    if (rawArg === 'CONFIRM') {\n 131Ôćĺ      const confirmId = pendingConfirmations.get(confirmKey);\n 132Ôćĺ      if (confirmId) {\n 133Ôćĺ        const result = confirmAction(confirmId, userId);\n 134Ôćĺ        if (result.ok) {\n 135Ôćĺ          pendingConfirmations.delete(confirmKey);\n 136Ôćĺ          await executeCommit(handlerCtx, messageResult.value, amend, force);\n 137Ôćĺ        } else {\n 138Ôćĺ          await reply(`ÔŁî ší«Ŕ«ĄňĄ▒Ŕ┤ą: ${result.error}`);\n 139Ôćĺ        }\n 140Ôćĺ        return;\n 141Ôćĺ      } else {\n 142Ôćĺ        await reply('ÔŁî Š▓íŠťëňżůší«Ŕ«ĄšÜä commit ŠôŹńŻť´╝îŠłľŠôŹńŻťňĚ▓Ŕ┐çŠťčŃÇé');\n 143Ôćĺ        return;\n 144Ôćĺ      }\n 145Ôćĺ    }\n 146Ôćĺ\n 147Ôćĺ    // Check if this is a CANCEL response\n 148Ôćĺ    if (rawArg === 'CANCEL') {\n 149Ôćĺ      const confirmId = pendingConfirmations.get(confirmKey);\n 150Ôćĺ      if (confirmId) {\n 151Ôćĺ        cancelConfirmation(confirmId, userId);\n 152Ôćĺ        pendingConfirmations.delete(confirmKey);\n 153Ôćĺ        await reply('Ôťů ňĚ▓ňĆľŠÂł commit ŠôŹńŻťŃÇé');\n 154Ôćĺ      } else {\n 155Ôćĺ        await reply('Š▓íŠťëňżůší«Ŕ«ĄšÜä commit ŠôŹńŻťŃÇé');\n 156Ôćĺ      }\n 157Ôćĺ      return;\n 158Ôćĺ    }\n 159Ôćĺ\n 160Ôćĺ    // Create new confirmation\n 161Ôćĺ    const actionType = amend ? 'commit --amend' : 'commit --force';\n 162Ôćĺ    const { confirmId, message: confirmMessage } = createConfirmation(\n 163Ôćĺ      userId,\n 164Ôćĺ      actionType,\n 165Ôćĺ      { message: messageResult.value, amend, force }\n 166Ôćĺ    );\n 167Ôćĺ    pendingConfirmations.set(confirmKey, confirmId);\n 168Ôćĺ\n 169Ôćĺ    const flagDesc = amend ? '--amend' : '--force';\n 170Ôćĺ    await reply(`ÔÜá´ŞĆ ÚźśÚúÄÚÖęŠôŹńŻťší«Ŕ«Ą\\n\\n${confirmMessage}\\n\\nŔ»ĚňŤ×ňĄŹ /commit ${flagDesc} CONFIRM ší«Ŕ«Ą´╝îŠłľ /commit ${flagDesc} CANCEL ňĆľŠÂłŃÇé`);\n 171Ôćĺ    return;\n 172Ôćĺ  }\n 173Ôćĺ\n 174Ôćĺ  // Execute commit directly\n 175Ôćĺ  await executeCommit(handlerCtx, messageResult.value, amend, force);\n 176Ôćĺ}\n 177Ôćĺ\n 178Ôćĺ/**\n 179Ôćĺ * Execute commit operation\n 180Ôćĺ */\n 181Ôćĺasync function executeCommit(handlerCtx, message, amend, force) {\n 182Ôćĺ  const { reply, userId, userRole, ctx } = handlerCtx;\n 183Ôćĺ\n 184Ôćĺ  // Get session ID from context or use default\n 185Ôćĺ  const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n 186Ôćĺ\n 187Ôćĺ  // Get feature/bugfix ID from session if available\n 188Ôćĺ  const sessionState = ctx?.state?.session || {};\n 189Ôćĺ  const featureId = sessionState.featureId || null;\n 190Ôćĺ  const bugfixId = sessionState.bugfixId || null;\n 191Ôćĺ\n 192Ôćĺ  try {\n 193Ôćĺ    const result = await commitService.commit({\n 194Ôćĺ      sessionId,\n 195Ôćĺ      userId: String(userId),\n 196Ôćĺ      message,\n 197Ôćĺ      amend,\n 198Ôćĺ      force,\n 199Ôćĺ      featureId,\n 200Ôćĺ      bugfixId,\n 201Ôćĺ      userRole\n 202Ôćĺ    });\n 203Ôćĺ\n 204Ôćĺ    if (result.success) {\n 205Ôćĺ      // Format success message\n 206Ôćĺ      const successMsg = formatSuccessResult(result);\n 207Ôćĺ      await reply(successMsg);\n 208Ôćĺ    } else {\n 209Ôćĺ      // Format error message\n 210Ôćĺ      const errorMsg = formatErrorResult(result);\n 211Ôćĺ      await reply(errorMsg);\n 212Ôćĺ    }\n 213Ôćĺ  } catch (error) {\n 214Ôćĺ    await logAuditEntry({\n 215Ôćĺ      userId,\n 216Ôćĺ      role: userRole,\n 217Ôćĺ      action: amend ? 'commit:amend' : 'commit',\n 218Ôćĺ      params: { message, amend, force },\n 219Ôćĺ      result: 'failed',\n 220Ôćĺ      reason: error.message\n 221Ôćĺ    });\n 222Ôćĺ    await reply(`ÔŁî ŠĆÉń║ĄňĄ▒Ŕ┤ą: ${error.message}`);\n 223Ôćĺ  }\n 224Ôćĺ}\n 225Ôćĺ\n 226Ôćĺ/**\n 227Ôćĺ * Get default commit message\n 228Ôćĺ */\n 229Ôćĺfunction getDefaultCommitMessage() {\n 230Ôćĺ  return `chore: update ${new Date().toISOString().split('T')[0]}`;\n 231Ôćĺ}\n 232Ôćĺ\n 233Ôćĺ/**\n 234Ôćĺ * Format success result for Telegram\n 235Ôćĺ */\n 236Ôćĺfunction formatSuccessResult(result) {\n 237Ôćĺ  const lines = [\n 238Ôćĺ    'Ôťů ŠĆÉń║ĄŠłÉňŐč',\n 239Ôćĺ    '',\n 240Ôćĺ    `­čôŽ Hash: \\`${result.shortHash}\\``,\n 241Ôćĺ    `­čôŁ ŠÂłŠü»: ${result.message?.split('\\n')[0] || '(ŠŚá)'}`,\n 242Ôćĺ    `­čôü ňĆśŠŤ┤Šľçń╗Â: ${result.filesChanged || 0} ńŞ¬`\n 243Ôćĺ  ];\n 244Ôćĺ\n 245Ôćĺ  return lines.join('\\n');\n 246Ôćĺ}\n 247Ôćĺ\n 248Ôćĺ/**\n 249Ôćĺ * Format error result for Telegram\n 250Ôćĺ */\n 251Ôćĺfunction formatErrorResult(result) {\n 252Ôćĺ  const lines = ['ÔŁî ŠĆÉń║ĄňĄ▒Ŕ┤ą', ''];\n 253Ôćĺ\n 254Ôćĺ  if (result.errors && result.errors.length > 0) {\n 255Ôćĺ    lines.push('**ÚöÖŔ»»Ŕ»ŽŠâů:**');\n 256Ôćĺ    for (const error of result.errors) {\n 257Ôćĺ      lines.push(`ÔÇó ${error.message}`);\n 258Ôćĺ      if (error.suggestion) {\n 259Ôćĺ        lines.push(`  ­čĺí ${error.suggestion}`);\n 260Ôćĺ      }\n 261Ôćĺ    }\n 262Ôćĺ  } else if (result.error) {\n 263Ôćĺ    lines.push(`ňÄčňŤá: ${result.error}`);\n 264Ôćĺ    if (result.suggestion) {\n 265Ôćĺ      lines.push(`­čĺí ň╗║Ŕ««: ${result.suggestion}`);\n 266Ôćĺ    }\n 267Ôćĺ  }\n 268Ôćĺ\n 269Ôćĺ  return lines.join('\\n');\n 270Ôćĺ}\n 271Ôćĺ\n 272Ôćĺexport default handleCommit;\n 273Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:26:17.671Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
