nt Design\n  41Ôćĺ\n  42Ôćĺ### C-1: GitService (`src/services/git-service.js`)\n  43Ôćĺ\n  44Ôćĺ**Purpose:** ň░üŔúůŠëÇŠťë git ŠôŹńŻť´╝îŠĆÉńżŤš╗čńŞÇ API\n  45Ôćĺ\n  46Ôćĺ**Methods:**\n  47Ôćĺ```javascript\n  48Ôćĺinterface GitService {\n  49Ôćĺ  // šŐÂŠÇüŠúÇŠčą\n  50Ôćĺ  getStatus(): Promise<GitStatus>\n  51Ôćĺ  isClean(): Promise<boolean>\n  52Ôćĺ  getChangedFiles(): Promise<string[]>\n  53Ôćĺ  \n  54Ôćĺ  // ŠĆÉń║ĄŠôŹńŻť\n  55Ôćĺ  commit(message: string, options?: CommitOptions): Promise<CommitResult>\n  56Ôćĺ  amendCommit(message: string): Promise<CommitResult>\n  57Ôćĺ  getLastCommit(): Promise<CommitInfo>\n  58Ôćĺ  \n  59Ôćĺ  // ń┐íŠü»ŔÄĚňĆľ\n  60Ôćĺ  getCommitLog(count?: number): Promise<CommitInfo[]>\n  61Ôćĺ  getShortHash(hash: string): string\n  62Ôćĺ}\n  63Ôćĺ\n  64Ôćĺinterface GitStatus {\n  65Ôćĺ  clean: boolean\n  66Ôćĺ  staged: string[]\n  67Ôćĺ  modified: string[]\n  68Ôćĺ  untracked: string[]\n  69Ôćĺ  conflicts: string[]\n  70Ôćĺ  ahead: number\n  71Ôćĺ  behind: number\n  72Ôćĺ  currentBranch: string\n  73Ôćĺ}\n  74Ôćĺ\n  75Ôćĺinterface CommitResult {\n  76Ôćĺ  success: boolean\n  77Ôćĺ  hash?: string\n  78Ôćĺ  shortHash?: string\n  79Ôćĺ  message?: string\n  80Ôćĺ  filesChanged?: number\n  81Ôćĺ  error?: string\n  82Ôćĺ  suggestion?: string\n  83Ôćĺ}\n  84Ôćĺ\n  85Ôćĺinterface CommitOptions {\n  86Ôćĺ  amend?: boolean\n  87Ôćĺ  allowEmpty?: boolean\n  88Ôćĺ}\n  89Ôćĺ```\n  90Ôćĺ\n  91Ôćĺ### C-2: CommitService (`src/services/commit-service.js`)\n  92Ôćĺ\n  93Ôćĺ**Purpose:** ŠĆÉń║ĄńŞÜňŐíÚÇ╗ŔżĹš╝ľŠÄĺ´╝îňŹĆŔ░âŠáíÚ¬îŃÇüŠëžŔíîŃÇüŔ«░ňŻĽ\n  94Ôćĺ\n  95Ôćĺ**Methods:**\n  96Ôćĺ```javascript\n  97Ôćĺinterface CommitService {\n  98Ôćĺ  // ńŞ╗ňůąňĆú\n  99Ôćĺ  commit(params: CommitParams): Promise<CommitResult>\n 100Ôćĺ  \n 101Ôćĺ  // ŠáíÚ¬î\n 102Ôćĺ  validatePreConditions(options: ValidationOptions): Promise<ValidationResult>\n 103Ôćĺ  \n 104Ôćĺ  // Ŕ«░ňŻĽ\n 105Ôćĺ  recordCommit(sessionId: string, commitInfo: CommitInfo): Promise<void>\n 106Ôćĺ  getSessionCommits(sessionId: string): Promise<CommitRecord[]>\n 107Ôćĺ}\n 108Ôćĺ\n 109Ôćĺinterface CommitParams {\n 110Ôćĺ  sessionId: string\n 111Ôćĺ  userId: string\n 112Ôćĺ  message?: string\n 113Ôćĺ  amend?: boolean\n 114Ôćĺ  force?: boolean\n 115Ôćĺ  featureId?: string\n 116Ôćĺ  bugfixId?: string\n 117Ôćĺ}\n 118Ôćĺ\n 119Ôćĺinterface ValidationOptions {\n 120Ôćĺ  skipPipelineCheck?: boolean\n 121Ôćĺ  skipTestCheck?: boolean\n 122Ôćĺ}\n 123Ôćĺ\n 124Ôćĺinterface ValidationResult {\n 125Ôćĺ  valid: boolean\n 126Ôćĺ  errors: ValidationError[]\n 127Ôćĺ  warnings: ValidationWarning[]\n 128Ôćĺ}\n 129Ôćĺ\n 130Ôćĺinterface ValidationError {\n 131Ôćĺ  code: string\n 132Ôćĺ  message: string\n 133Ôćĺ  suggestion: string\n 134Ôćĺ}\n 135Ôćĺ\n 136Ôćĺinterface CommitRecord {\n 137Ôćĺ  hash: string\n 138Ôćĺ  shortHash: string\n 139Ôćĺ  message: string\n 140Ôćĺ  timestamp: number\n 141Ôćĺ  author: string\n 142Ôćĺ  featureId?: string\n 143Ôćĺ  bugfixId?: string\n 144Ôćĺ  filesChanged: number\n 145Ôćĺ}\n 146Ôćĺ```\n 147Ôćĺ\n 148Ôćĺ### C-3: Commit Handler (`src/bot/commands/handlers/commit.js`)\n 149Ôćĺ\n 150Ôćĺ**Purpose:** Telegram ňĹŻń╗ĄňĄäšÉćňůąňĆú\n 151Ôćĺ\n 152Ôćĺ**Flow:**\n 153Ôćĺ1. ŔžúŠ×ÉňĹŻń╗ĄňĆéŠĽ░ (`--message`, `--amend`, `--force`)\n 154Ôćĺ2. ŠŁâÚÖÉŠúÇŠčą (`operator` for commit, `admin` for amend/force)\n 155Ôćĺ3. ÚźśÚúÄÚÖęŠôŹńŻťší«Ŕ«ĄŠÁüšĘő (amend/force)\n 156Ôćĺ4. Ŕ░âšöĘ CommitService.commit()\n 157Ôćĺ5. Šá╝ň╝ĆňîľŔ┐öňŤ×š╗ôŠ×ť\n 158Ôćĺ6. Ŕ«░ňŻĽň«íŔ«íŠŚąň┐Ś\n 159Ôćĺ\n 160Ôćĺ### C-4: Commits Handler (`src/bot/commands/handlers/commits.js`)\n 161Ôćĺ\n 162Ôćĺ**Purpose:** Ščąšťőń╝ÜŔ»ŁŠĆÉń║ĄňÄćňĆ▓\n 163Ôćĺ\n 164Ôćĺ**Flow:**\n 165Ôćĺ1. ŔÄĚňĆľňŻôňëŹń╝ÜŔ»Ł ID\n 166Ôćĺ2. Ŕ░âšöĘ CommitService.getSessionCommits()\n 167Ôćĺ3. Šá╝ň╝ĆňîľňÄćňĆ▓ňłŚŔíĘŔ┐öňŤ×\n 168Ôćĺ\n 169Ôćĺ---\n 170Ôćĺ\n 171Ôćĺ## Interface Design\n 172Ôćĺ\n 173Ôćĺ### I-1: Pre-Commit Validation API\n 174Ôćĺ\n 175Ôćĺ```javascript\n 176Ôćĺ// src/services/commit-service.js\n 177Ôćĺ\n 178Ôćĺconst VALIDATION_ERRORS = {\n 179Ôćĺ  PIPELINE_RUNNING: {\n 180Ôćĺ    code: 'PIPELINE_RUNNING',\n 181Ôćĺ    message: 'Pipeline ŠşúňťĘŔ┐ÉŔíîńŞş',\n 182Ôćĺ    suggestion: 'Ŕ»Ěšşëňżů pipeline ň«îŠłÉŠłľńŻ┐šöĘ /stop ňüťŠşó'\n 183Ôćĺ  },\n 184Ôćĺ  TEST_FAILED: {\n 185Ôćĺ    code: 'TEST_FAILED',\n 186Ôćĺ    message: 'ŠÁőŔ»ĽŠť¬ÚÇÜŔ┐ç',\n 187Ôćĺ    suggestion: 'Ŕ»ĚŠúÇŠčąŠÁőŔ»Ľš╗ôŠ×ťŠłľńŻ┐šöĘ --force ŔĚ│Ŕ┐ç´╝łń╗ů admin´╝ë'\n 188Ôćĺ  },\n 189Ôćĺ  NOTHING_TO_COMMIT: {\n 190Ôćĺ    code: 'NOTHING_TO_COMMIT',\n 191Ôćĺ    message: 'Š▓íŠťëňżůŠĆÉń║ĄšÜäňĆśŠŤ┤',\n 192Ôćĺ    suggestion: 'Ŕ»ĚňůłŔ┐ŤŔíîń╗úšáüń┐«Šö╣'\n 193Ôćĺ  },\n 194Ôćĺ  MERGE_CONFLICT: {\n 195Ôćĺ    code: 'MERGE_CONFLICT',\n 196Ôćĺ    message: 'ňşśňťĘňÉłň╣Âňć▓š¬ü',\n 197Ôćĺ    suggestion: 'Ŕ»ĚňůłŔžúňć│ń╗ąńŞőňć▓š¬üŠľçń╗Â´╝Ü{files}'\n 198Ôćĺ  }\n 199Ôćĺ};\n 200Ôćĺ\n 201Ôćĺasync function validatePreConditions(options) {\n 202Ôćĺ  const errors = [];\n 203Ôćĺ  const warnings = [];\n 204Ôćĺ  \n 205Ôćĺ  // 1. Check pipeline status (via status-aggregator)\n 206Ôćĺ  const pipelineStatus = await statusAggregator.aggregateStatus();\n 207Ôćĺ  if (pipelineStatus.phase === 'running' && !options.skipPipelineCheck) {\n 208Ôćĺ    errors.push(VALIDATION_ERRORS.PIPELINE_RUNNING);\n 209Ôćĺ  }\n 210Ôćĺ  \n 211Ôćĺ  // 2. Check test status (from state file)\n 212Ôćĺ  const testStatus = await getTestStatus();\n 213Ôćĺ  if (testStatus.failed > 0 && !options.skipTestCheck) {\n 214Ôćĺ    errors.push(VALIDATION_ERRORS.TEST_FAILED);\n 215Ôćĺ  }\n 216Ôćĺ  \n 217Ôćĺ  // 3. Check git status\n 218Ôćĺ  const gitStatus = await gitService.getStatus();\n 219Ôćĺ  if (gitStatus.clean) {\n 220Ôćĺ    errors.push(VALIDATION_ERRORS.NOTHING_TO_COMMIT);\n 221Ôćĺ  }\n 222Ôćĺ  if (gitStatus.conflicts.length > 0) {\n 223Ôćĺ    errors.push({\n 224Ôćĺ      ...VALIDATION_ERRORS.MERGE_CONFLICT,\n 225Ôćĺ      files: gitStatus.conflicts\n 226Ôćĺ    });\n 227Ôćĺ  }\n 228Ôćĺ  \n 229Ôćĺ  return {\n 230Ôćĺ    valid: errors.length === 0,\n 231Ôćĺ    errors,\n 232Ôćĺ    warnings,\n 233Ôćĺ    gitStatus\n 234Ôćĺ  };\n 235Ôćĺ}\n 236Ôćĺ```\n 237Ôćĺ\n 238Ôćĺ### I-2: Commit Execution API\n 239Ôćĺ\n 240Ôćĺ```javascript\n 241Ôćĺ// src/services/git-service.js\n 242Ôćĺ\n 243Ôćĺasync function commit(message, options = {}) {\n 244Ôćĺ  try {\n 245Ôćĺ    // Build commit message with footer\n 246Ôćĺ    const fullMessage = buildCommitMessage(message, options);\n 247Ôćĺ    \n 248Ôćĺ    // Execute git commit\n 249Ôćĺ    const result = await git.commit(fullMessage);\n 250Ôćĺ    \n 251Ôćĺ    if (!result.commit) {\n 252Ôćĺ      return {\n 253Ôćĺ        success: false,\n 254Ôćĺ        error: 'ŠĆÉń║ĄňĄ▒Ŕ┤ą',\n 255Ôćĺ        suggestion: 'Ŕ»ĚŠúÇŠčą git šŐÂŠÇü'\n 256Ôćĺ      };\n 257Ôćĺ    }\n 258Ôćĺ    \n 259Ôćĺ    return {\n 260Ôćĺ      success: true,\n 261Ôćĺ      hash: result.commit,\n 262Ôćĺ      shortHash: result.commit.substring(0, 7),\n 263Ôćĺ      message: fullMessage,\n 264Ôćĺ      filesChanged: result.summary.changes\n 265Ôćĺ    };\n 266Ôćĺ  } catch (error) {\n 267Ôćĺ    return {\n 268Ôćĺ      success: false,\n 269Ôćĺ      error: error.message,\n 270Ôćĺ      suggestion: getSuggestion(error)\n 271Ôćĺ    };\n 272Ôćĺ  }\n 273Ôćĺ}\n 274Ôćĺ```\n 275Ôćĺ\n 276Ôćĺ### I-3: Session Commit Tracking\n 277Ôćĺ\n 278Ôćĺ```javascript\n 279Ôćĺ// Šëęň▒Ľ src/services/session-store.js\n 280Ôćĺ\n 281Ôćĺ// Session state structure (JSON file)\n 282Ôćĺ{\n 283Ôćĺ  \"sessionId\": \"abc123\",\n 284Ôćĺ  \"featureId\": \"F-008\",\n 285Ôćĺ  \"createdAt\": 1710489600000,\n 286Ôćĺ  \"commits\": [\n 287Ôćĺ    {\n 288Ôćĺ      \"hash\": \"a1b2c3d4e5f6...\",\n 289Ôćĺ      \"shortHash\": \"a1b2c3d\",\n 290Ôćĺ      \"message\": \"feat: add commit workflow\",\n 291Ôćĺ      \"timestamp\": 1710489700000,\n 292Ôćĺ      \"author\": \"user\",\n 293Ôćĺ      \"filesChanged\": 5\n 294Ôćĺ    }\n 295Ôćĺ  ]\n 296Ôćĺ}\n 297Ôćĺ\n 298Ôćĺ// API\n 299Ôćĺasync function addCommitToSession(sessionId, commitInfo) {\n 300Ôćĺ  const session = await loadSession(sessionId);\n 301Ôćĺ  session.commits = session.commits || [];\n 302Ôćĺ  session.commits.push({\n 303Ôćĺ    ...commitInfo,\n 304Ôćĺ    timestamp: Date.now()\n 305Ôćĺ  });\n 306Ôćĺ  await saveSession(session);\n 307Ôćĺ}\n 308Ôćĺ\n 309Ôćĺasync function getSessionCommits(sessionId) {\n 310Ôćĺ  const session = await loadSession(sessionId);\n 311Ôćĺ  return session.commits || [];\n 312Ôćĺ}\n 313Ôćĺ```\n 314Ôćĺ\n 315Ôćĺ---\n 316Ôćĺ\n 317Ôćĺ## Data Model\n 318Ôćĺ\n 319Ôćĺ### D-1: Session State (Extended)\n 320Ôćĺ\n 321Ôćĺ```javascript\n 322Ôćĺ// File: data/sessions/{sessionId}.json\n 323Ôćĺ{\n 324Ôćĺ  \"sessionId\": \"string\",\n 325Ôćĺ  \"featureId\": \"string | null\",\n 326Ôćĺ  \"bugfixId\": \"string | null\",\n 327Ôćĺ  \"createdAt\": \"number (timestamp)\",\n 328Ôćĺ  \"updatedAt\": \"number (timestamp)\",\n 329Ôćĺ  \"commits\": [\n 330Ôćĺ    {\n 331Ôćĺ      \"hash\": \"string (full hash)\",\n 332Ôćĺ      \"shortHash\": \"string (7 chars)\",\n 333Ôćĺ      \"message\": \"string\",\n 334Ôćĺ      \"timestamp\": \"number\",\n 335Ôćĺ      \"author\": \"string\",\n 336Ôćĺ      \"filesChanged\": \"number\"\n 337Ôćĺ    }\n 338Ôćĺ  ]\n 339Ôćĺ}\n 340Ôćĺ```\n 341Ôćĺ\n 342Ôćĺ### D-2: Test Status (Existing)\n 343Ôćĺ\n 344Ôćĺ```javascript\n 345Ôćĺ// File: dev-pipeline/state/test-status.json (šö▒ F-007 ňłŤň╗║)\n 346Ôćĺ{\n 347Ôćĺ  \"lastRun\": \"number (timestamp)\",\n 348Ôćĺ  \"passed\": \"number\",\n 349Ôćĺ  \"failed\": \"number\",\n 350Ôćĺ  \"skipped\": \"number\",\n 351Ôćĺ  \"duration\": \"number (ms)\"\n 352Ôćĺ}\n 353Ôćĺ```\n 354Ôćĺ\n 355Ôćĺ---\n 356Ôćĺ\n 357Ôćĺ## Command Permission Matrix\n 358Ôćĺ\n 359Ôćĺ| Command | Min Role | Confirmation | Notes |\n 360Ôćĺ|---------|----------|--------------|-------|\n 361Ôćĺ| `/commit` | operator | No | ŠáçňçćŠĆÉń║Ą |\n 362Ôćĺ| `/commit --amend` | admin | Yes | ń┐«Šö╣ŠťÇŔ┐ĹŠĆÉń║Ą |\n 363Ôćĺ| `/commit --force` | admin | Yes | ŔĚ│Ŕ┐çŠáíÚ¬î |\n 364Ôćĺ| `/commits` | viewer | No | ŠčąšťőňÄćňĆ▓ |\n 365Ôćĺ\n 366Ôćĺ---\n 367Ôćĺ\n 368Ôćĺ## Testing Strategy\n 369Ôćĺ\n 370Ôćĺ### Unit Tests\n 371Ôćĺ\n 372Ôćĺ| Module | Test File | Coverage Target |\n 373Ôćĺ|--------|-----------|-----------------|\n 374Ôćĺ| GitService | tests/services/git-service.test.js | 90% |\n 375Ôćĺ| CommitService | tests/services/commit-service.test.js | 90% |\n 376Ôćĺ| commit handler | tests/bot/commands/handlers/commit.test.js | 85% |\n 377Ôćĺ| commits handler | tests/bot/commands/handlers/commits.test.js | 85% |\n 378Ôćĺ\n 379Ôćĺ### Integration Tests\n 380Ôćĺ\n 381Ôćĺ| Scenario | Test File | Priority |\n 382Ôćĺ|----------|-----------|----------|\n 383Ôćĺ| commit Ôćĺ success flow | tests/integration/commit-flow.test.js | High |\n 384Ôćĺ| commit Ôćĺ validation failure | tests/integration/commit-validation.test.js | High |\n 385Ôćĺ| commit Ôćĺ amend flow | tests/integration/commit-amend.test.js | Medium |\n 386Ôćĺ| commit Ôćĺ force flow | tests/integration/commit-force.test.js | Medium |\n 387Ôćĺ\n 388Ôćĺ### Mock Strategy\n 389Ôćĺ\n 390Ôćĺ- GitService: ńŻ┐šöĘ mock git responses´╝îńŞŹŠëžŔíîšťčň«× git ňĹŻń╗Ą\n 391Ôćĺ- StatusAggregator: ňĄŹšöĘ F-005 mock šşľšĽą\n 392Ôćĺ- SessionStore: ńŻ┐šöĘńŞ┤ŠŚÂšŤ«ňŻĽ\n 393Ôćĺ\n 394Ôćĺ---\n 395Ôćĺ\n 396Ôćĺ## File Structure\n 397Ôćĺ\n 398Ôćĺ```\n 399Ôćĺsrc/\n 400ÔćĺÔöťÔöÇÔöÇ services/\n 401ÔćĺÔöé   ÔöťÔöÇÔöÇ git-service.js          # NEW - git ŠôŹńŻťň░üŔúů\n 402ÔćĺÔöé   ÔöťÔöÇÔöÇ commit-service.js       # NEW - ŠĆÉń║ĄńŞÜňŐíÚÇ╗ŔżĹ\n 403ÔćĺÔöé   ÔööÔöÇÔöÇ session-store.js        # EXTEND - ŠĚ╗ňŐá commit tracking\n 404ÔćĺÔöťÔöÇÔöÇ bot/\n 405ÔćĺÔöé   ÔööÔöÇÔöÇ commands/\n 406ÔćĺÔöé       ÔööÔöÇÔöÇ handlers/\n 407ÔćĺÔöé           ÔöťÔöÇÔöÇ commit.js       # NEW - /commit ňĹŻń╗Ą\n 408ÔćĺÔöé           ÔööÔöÇÔöÇ commits.js      # NEW - /commits ňĹŻń╗Ą\n 409Ôćĺtests/\n 410ÔćĺÔöťÔöÇÔöÇ services/\n 411ÔćĺÔöé   ÔöťÔöÇÔöÇ git-service.test.js     # NEW\n 412ÔćĺÔöé   ÔööÔöÇÔöÇ commit-service.test.js  # NEW\n 413ÔćĺÔöťÔöÇÔöÇ bot/\n 414ÔćĺÔöé   ÔööÔöÇÔöÇ commands/\n 415ÔćĺÔöé       ÔööÔöÇÔöÇ handlers/\n 416ÔćĺÔöé           ÔöťÔöÇÔöÇ commit.test.js  # NEW\n 417ÔćĺÔöé           ÔööÔöÇÔöÇ commits.test.js # NEW\n 418ÔćĺÔööÔöÇÔöÇ integration/\n 419Ôćĺ    ÔöťÔöÇÔöÇ commit-flow.test.js     # NEW\n 420Ôćĺ    ÔööÔöÇÔöÇ commit-validation.test.js # NEW\n 421Ôćĺ```\n 422Ôćĺ\n 423Ôćĺ---\n 424Ôćĺ\n 425Ôćĺ## User Story Mapping\n 426Ôćĺ\n 427Ôćĺ| User Story | Components | Key Files |\n 428Ôćĺ|------------|------------|-----------|\n 429Ôćĺ| US-1: Telegram Commit Trigger | C-3, C-2 | commit.js, commit-service.js |\n 430Ôćĺ| US-2: Pre-Commit Validation | C-2 | commit-service.js |\n 431Ôćĺ| US-3: Commit Result Feedback | C-1, C-3 | git-service.js, commit.js |\n 432Ôćĺ| US-4: Session Commit Tracking | C-2, C-4 | commit-service.js, session-store.js, commits.js |\n 433Ôćĺ| US-5: High-Risk Commit Protection | Security Layer | commit.js, permission-guard.js |\n 434Ôćĺ\n 435Ôćĺ---\n 436Ôćĺ\n 437Ôćĺ## Risk Mitigation\n 438Ôćĺ\n 439Ôćĺ| Risk | Mitigation Strategy |\n 440Ôćĺ|------|---------------------|\n 441Ôćĺ| Git ŠôŹńŻťňĄ▒Ŕ┤ą | GitService Ŕ┐öňŤ×Ŕ»Žš╗ćÚöÖŔ»» + ň╗║Ŕ««ŠôŹńŻť |\n 442Ôćĺ| ňĚąńŻťšŤ«ňŻĽŔäĆšŐÂŠÇü | ŠĆÉń║ĄňëŹ isClean() ŠúÇŠčą |\n 443Ôćĺ| ŠÁőŔ»ĽšŐÂŠÇüŠľçń╗Âš╝║ňĄ▒ | ň«╣ÚöÖňĄäšÉć´╝îŔžćńŞ║\"Šť¬Ŕ┐ÉŔíîŠÁőŔ»Ľ\"ŔşŽňĹŐ |\n 444Ôćĺ| ń╝ÜŔ»ŁŠľçń╗ÂŠŹčňŁĆ | try-catch + šę║ŠĽ░š╗äňŤ×ÚÇÇ |\n 445Ôćĺ\n 446Ôćĺ---\n 447Ôćĺ\n 448Ôćĺ## Dependencies Check\n 449Ôćĺ\n 450Ôćĺ| Dependency | Required By | Install Command |\n 451Ôćĺ|------------|-------------|-----------------|\n 452Ôćĺ| simple-git | GitService | `npm install simple-git` |\n 453Ôćĺ\n 454Ôćĺ---\n 455Ôćĺ\n 456Ôćĺ## Decisions\n 457Ôćĺ\n 458Ôćĺ| ID | Date | Decision |\n 459Ôćĺ|----|------|----------|\n 460Ôćĺ| D1 | 2026-03-15 | ńŻ┐šöĘ simple-git ň║ôň░üŔúů git ŠôŹńŻť´╝îÚü┐ňůŹ shell Š│ĘňůąÚúÄÚÖę |\n 461Ôćĺ| D2 | 2026-03-15 | Pre-commit ŠáíÚ¬îňîůňÉź pipeline šŐÂŠÇüňĺîŠÁőŔ»ĽšŐÂŠÇüňĆîÚçŹŠúÇŠčą |\n 462Ôćĺ| D3 | 2026-03-15 | ŠĆÉń║ĄŔ«░ňŻĽňşśňéĘń║Äń╝ÜŔ»ŁšŐÂŠÇüŠľçń╗Â´╝îńŞŹŠľ░ň╗║šőČšźőňşśňéĘ |\n 463Ôćĺ| D4 | 2026-03-15 | ňĄŹšöĘ F-006 ší«Ŕ«ĄŠť║ňłÂňĄäšÉć amend/force ÚźśÚúÄÚÖęŠôŹńŻť |\n 464Ôćĺ| D5 | 2026-03-15 | GitService Ŕ«żŔ«íńŞ║ňĆ» mock´╝îńż┐ń║ÄňŹĽňůâŠÁőŔ»Ľ |\n 465Ôćĺ"}],"is_error":false