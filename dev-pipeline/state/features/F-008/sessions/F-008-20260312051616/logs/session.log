{"type":"user","uuid":"f8975a9c-0f36-4050-9a71-6884f609062f","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cdec8547eefe46e9116d0a0e404dc","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Git Service Unit Tests\n   3Ôćĺ *\n   4Ôćĺ * F-008: Commit Workflow Integration\n   5Ôćĺ * Tests for GitService module\n   6Ôćĺ */\n   7Ôćĺ\n   8Ôćĺimport { describe, it, beforeEach, afterEach } from 'node:test';\n   9Ôćĺimport assert from 'node:assert';\n  10Ôćĺimport { createGitService } from '../../src/services/git-service.js';\n  11Ôćĺ\n  12Ôćĺdescribe('GitService', () => {\n  13Ôćĺ  let gitService;\n  14Ôćĺ  let mockGit;\n  15Ôćĺ\n  16Ôćĺ  beforeEach(() => {\n  17Ôćĺ    // Create mock git instance\n  18Ôćĺ    mockGit = {\n  19Ôćĺ      status: async () => ({\n  20Ôćĺ        isClean: () => true,\n  21Ôćĺ        staged: [],\n  22Ôćĺ        modified: [],\n  23Ôćĺ        not_added: [],\n  24Ôćĺ        conflicted: [],\n  25Ôćĺ        ahead: 0,\n  26Ôćĺ        behind: 0,\n  27Ôćĺ        current: 'main'\n  28Ôćĺ      }),\n  29Ôćĺ      commit: async () => ({ commit: 'abc123def456', summary: { changes: 2 } }),\n  30Ôćĺ      log: async () => ({ latest: { hash: 'abc123', message: 'test', author_name: 'user', date: new Date().toISOString() }, all: [] }),\n  31Ôćĺ      diff: async () => ''\n  32Ôćĺ    };\n  33Ôćĺ\n  34Ôćĺ    gitService = createGitService({ git: mockGit });\n  35Ôćĺ  });\n  36Ôćĺ\n  37Ôćĺ  describe('getStatus()', () => {\n  38Ôćĺ    it('should return GitStatus object with correct structure', async () => {\n  39Ôćĺ      const result = await gitService.getStatus();\n  40Ôćĺ\n  41Ôćĺ      assert.ok(result);\n  42Ôćĺ      assert.ok(typeof result.clean === 'boolean');\n  43Ôćĺ      assert.ok(Array.isArray(result.staged));\n  44Ôćĺ      assert.ok(Array.isArray(result.modified));\n  45Ôćĺ      assert.ok(Array.isArray(result.untracked));\n  46Ôćĺ      assert.ok(Array.isArray(result.conflicts));\n  47Ôćĺ      assert.ok(typeof result.ahead === 'number');\n  48Ôćĺ      assert.ok(typeof result.behind === 'number');\n  49Ôćĺ      assert.ok(typeof result.currentBranch === 'string');\n  50Ôćĺ    });\n  51Ôćĺ\n  52Ôćĺ    it('should return clean: true when working directory is clean', async () => {\n  53Ôćĺ      mockGit.status = async () => ({\n  54Ôćĺ        isClean: () => true,\n  55Ôćĺ        staged: [],\n  56Ôćĺ        modified: [],\n  57Ôćĺ        not_added: [],\n  58Ôćĺ        conflicted: [],\n  59Ôćĺ        ahead: 0,\n  60Ôćĺ        behind: 0,\n  61Ôćĺ        current: 'main'\n  62Ôćĺ      });\n  63Ôćĺ      gitService = createGitService({ git: mockGit });\n  64Ôćĺ\n  65Ôćĺ      const result = await gitService.getStatus();\n  66Ôćĺ      assert.strictEqual(result.clean, true);\n  67Ôćĺ    });\n  68Ôćĺ\n  69Ôćĺ    it('should return clean: false when there are changes', async () => {\n  70Ôćĺ      mockGit.status = async () => ({\n  71Ôćĺ        isClean: () => false,\n  72Ôćĺ        staged: ['file1.js'],\n  73Ôćĺ        modified: ['file2.js'],\n  74Ôćĺ        not_added: ['file3.js'],\n  75Ôćĺ        conflicted: [],\n  76Ôćĺ        ahead: 0,\n  77Ôćĺ        behind: 0,\n  78Ôćĺ        current: 'feature-branch'\n  79Ôćĺ      });\n  80Ôćĺ      gitService = createGitService({ git: mockGit });\n  81Ôćĺ\n  82Ôćĺ      const result = await gitService.getStatus();\n  83Ôćĺ      assert.strictEqual(result.clean, false);\n  84Ôćĺ      assert.deepStrictEqual(result.staged, ['file1.js']);\n  85Ôćĺ      assert.deepStrictEqual(result.modified, ['file2.js']);\n  86Ôćĺ      assert.deepStrictEqual(result.untracked, ['file3.js']);\n  87Ôćĺ      assert.strictEqual(result.currentBranch, 'feature-branch');\n  88Ôćĺ    });\n  89Ôćĺ\n  90Ôćĺ    it('should detect merge conflicts', async () => {\n  91Ôćĺ      mockGit.status = async () => ({\n  92Ôćĺ        isClean: () => false,\n  93Ôćĺ        staged: [],\n  94Ôćĺ        modified: [],\n  95Ôćĺ        not_added: [],\n  96Ôćĺ        conflicted: ['conflicted-file.js'],\n  97Ôćĺ        ahead: 0,\n  98Ôćĺ        behind: 0,\n  99Ôćĺ        current: 'main'\n 100Ôćĺ      });\n 101Ôćĺ      gitService = createGitService({ git: mockGit });\n 102Ôćĺ\n 103Ôćĺ      const result = await gitService.getStatus();\n 104Ôćĺ      assert.deepStrictEqual(result.conflicts, ['conflicted-file.js']);\n 105Ôćĺ    });\n 106Ôćĺ\n 107Ôćĺ    it('should return ahead/behind counts', async () => {\n 108Ôćĺ      mockGit.status = async () => ({\n 109Ôćĺ        isClean: () => true,\n 110Ôćĺ        staged: [],\n 111Ôćĺ        modified: [],\n 112Ôćĺ        not_added: [],\n 113Ôćĺ        conflicted: [],\n 114Ôćĺ        ahead: 2,\n 115Ôćĺ        behind: 1,\n 116Ôćĺ        current: 'main'\n 117Ôćĺ      });\n 118Ôćĺ      gitService = createGitService({ git: mockGit });\n 119Ôćĺ\n 120Ôćĺ      const result = await gitService.getStatus();\n 121Ôćĺ      assert.strictEqual(result.ahead, 2);\n 122Ôćĺ      assert.strictEqual(result.behind, 1);\n 123Ôćĺ    });\n 124Ôćĺ  });\n 125Ôćĺ\n 126Ôćĺ  describe('isClean()', () => {\n 127Ôćĺ    it('should return true when working directory is clean', async () => {\n 128Ôćĺ      mockGit.status = async () => ({ isClean: () => true });\n 129Ôćĺ      gitService = createGitService({ git: mockGit });\n 130Ôćĺ\n 131Ôćĺ      const result = await gitService.isClean();\n 132Ôćĺ      assert.strictEqual(result, true);\n 133Ôćĺ    });\n 134Ôćĺ\n 135Ôćĺ    it('should return false when there are changes', async () => {\n 136Ôćĺ      mockGit.status = async () => ({ isClean: () => false });\n 137Ôćĺ      gitService = createGitService({ git: mockGit });\n 138Ôćĺ\n 139Ôćĺ      const result = await gitService.isClean();\n 140Ôćĺ      assert.strictEqual(result, false);\n 141Ôćĺ    });\n 142Ôćĺ  });\n 143Ôćĺ\n 144Ôćĺ  describe('getChangedFiles()', () => {\n 145Ôćĺ    it('should return array of changed file paths', async () => {\n 146Ôćĺ      mockGit.status = async () => ({\n 147Ôćĺ        isClean: () => false,\n 148Ôćĺ        staged: ['staged.js'],\n 149Ôćĺ        modified: ['modified.js'],\n 150Ôćĺ        not_added: ['untracked.js'],\n 151Ôćĺ        conflicted: []\n 152Ôćĺ      });\n 153Ôćĺ      gitService = createGitService({ git: mockGit });\n 154Ôćĺ\n 155Ôćĺ      const result = await gitService.getChangedFiles();\n 156Ôćĺ      assert.ok(result.includes('staged.js'));\n 157Ôćĺ      assert.ok(result.includes('modified.js'));\n 158Ôćĺ      assert.ok(result.includes('untracked.js'));\n 159Ôćĺ    });\n 160Ôćĺ\n 161Ôćĺ    it('should return empty array when clean', async () => {\n 162Ôćĺ      mockGit.status = async () => ({\n 163Ôćĺ        isClean: () => true,\n 164Ôćĺ        staged: [],\n 165Ôćĺ        modified: [],\n 166Ôćĺ        not_added: [],\n 167Ôćĺ        conflicted: []\n 168Ôćĺ      });\n 169Ôćĺ      gitService = createGitService({ git: mockGit });\n 170Ôćĺ\n 171Ôćĺ      const result = await gitService.getChangedFiles();\n 172Ôćĺ      assert.deepStrictEqual(result, []);\n 173Ôćĺ    });\n 174Ôćĺ  });\n 175Ôćĺ\n 176Ôćĺ  describe('commit()', () => {\n 177Ôćĺ    it('should return CommitResult with hash on success', async () => {\n 178Ôćĺ      mockGit.commit = async () => ({\n 179Ôćĺ        commit: 'abc123def456789',\n 180Ôćĺ        summary: { changes: 3 }\n 181Ôćĺ      });\n 182Ôćĺ      gitService = createGitService({ git: mockGit });\n 183Ôćĺ\n 184Ôćĺ      const result = await gitService.commit('test message');\n 185Ôćĺ\n 186Ôćĺ      assert.strictEqual(result.success, true);\n 187Ôćĺ      assert.strictEqual(result.hash, 'abc123def456789');\n 188Ôćĺ      assert.strictEqual(result.shortHash, 'abc123d');\n 189Ôćĺ      assert.strictEqual(result.filesChanged, 3);\n 190Ôćĺ    });\n 191Ôćĺ\n 192Ôćĺ    it('should return error when commit fails', async () => {\n 193Ôćĺ      mockGit.commit = async () => {\n 194Ôćĺ        throw new Error('Nothing to commit');\n 195Ôćĺ      };\n 196Ôćĺ      gitService = createGitService({ git: mockGit });\n 197Ôćĺ\n 198Ôćĺ      const result = await gitService.commit('test message');\n 199Ôćĺ\n 200Ôćĺ      assert.strictEqual(result.success, false);\n 201Ôćĺ      assert.ok(result.error);\n 202Ôćĺ    });\n 203Ôćĺ\n 204Ôćĺ    it('should return error when no commit hash returned', async () => {\n 205Ôćĺ      mockGit.commit = async () => ({ commit: null });\n 206Ôćĺ      gitService = createGitService({ git: mockGit });\n 207Ôćĺ\n 208Ôćĺ      const result = await gitService.commit('test message');\n 209Ôćĺ\n 210Ôćĺ      assert.strictEqual(result.success, false);\n 211Ôćĺ      assert.ok(result.error);\n 212Ôćĺ    });\n 213Ôćĺ  });\n 214Ôćĺ\n 215Ôćĺ  describe('amendCommit()', () => {\n 216Ôćĺ    it('should amend last commit successfully', async () => {\n 217Ôćĺ      mockGit.commit = async (msg, opts) => {\n 218Ôćĺ        if (opts && opts['--amend']) {\n 219Ôćĺ          return { commit: 'amended123', summary: { changes: 1 } };\n 220Ôćĺ        }\n 221Ôćĺ        return { commit: 'new123' };\n 222Ôćĺ      };\n 223Ôćĺ      gitService = createGitService({ git: mockGit });\n 224Ôćĺ\n 225Ôćĺ      const result = await gitService.amendCommit('amended message');\n 226Ôćĺ\n 227Ôćĺ      assert.strictEqual(result.success, true);\n 228Ôćĺ      assert.strictEqual(result.hash, 'amended123');\n 229Ôćĺ    });\n 230Ôćĺ\n 231Ôćĺ    it('should return error when amend fails', async () => {\n 232Ôćĺ      mockGit.commit = async () => {\n 233Ôćĺ        throw new Error('Cannot amend');\n 234Ôćĺ      };\n 235Ôćĺ      gitService = createGitService({ git: mockGit });\n 236Ôćĺ\n 237Ôćĺ      const result = await gitService.amendCommit('amended message');\n 238Ôćĺ\n 239Ôćĺ      assert.strictEqual(result.success, false);\n 240Ôćĺ      assert.ok(result.error);\n 241Ôćĺ    });\n 242Ôćĺ  });\n 243Ôćĺ\n 244Ôćĺ  describe('getLastCommit()', () => {\n 245Ôćĺ    it('should return last commit info', async () => {\n 246Ôćĺ      mockGit.log = async () => ({\n 247Ôćĺ        latest: {\n 248Ôćĺ          hash: 'abc123def456',\n 249Ôćĺ          message: 'Last commit message',\n 250Ôćĺ          author_name: 'Test Author',\n 251Ôćĺ          date: '2024-01-15T10:30:00Z'\n 252Ôćĺ        }\n 253Ôćĺ      });\n 254Ôćĺ      gitService = createGitService({ git: mockGit });\n 255Ôćĺ\n 256Ôćĺ      const result = await gitService.getLastCommit();\n 257Ôćĺ\n 258Ôćĺ      assert.strictEqual(result.hash, 'abc123def456');\n 259Ôćĺ      assert.strictEqual(result.shortHash, 'abc123d');\n 260Ôćĺ      assert.strictEqual(result.message, 'Last commit message');\n 261Ôćĺ      assert.strictEqual(result.author, 'Test Author');\n 262Ôćĺ      assert.ok(result.date);\n 263Ôćĺ    });\n 264Ôćĺ\n 265Ôćĺ    it('should handle empty log', async () => {\n 266Ôćĺ      mockGit.log = async () => ({ latest: null });\n 267Ôćĺ      gitService = createGitService({ git: mockGit });\n 268Ôćĺ\n 269Ôćĺ      const result = await gitService.getLastCommit();\n 270Ôćĺ\n 271Ôćĺ      assert.strictEqual(result, null);\n 272Ôćĺ    });\n 273Ôćĺ  });\n 274Ôćĺ\n 275Ôćĺ  describe('getCommitLog()', () => {\n 276Ôćĺ    it('should return array of commit info', async () => {\n 277Ôćĺ      mockGit.log = async (opts) => ({\n 278Ôćĺ        all: [\n 279Ôćĺ          { hash: 'commit1', message: 'msg1', author_name: 'author1', date: '2024-01-01' },\n 280Ôćĺ          { hash: 'commit2', message: 'msg2', author_name: 'author2', date: '2024-01-02' }\n 281Ôćĺ        ]\n 282Ôćĺ      });\n 283Ôćĺ      gitService = createGitService({ git: mockGit });\n 284Ôćĺ\n 285Ôćĺ      const result = await gitService.getCommitLog(2);\n 286Ôćĺ\n 287Ôćĺ      assert.strictEqual(result.length, 2);\n 288Ôćĺ      assert.strictEqual(result[0].hash, 'commit1');\n 289Ôćĺ      assert.strictEqual(result[1].message, 'msg2');\n 290Ôćĺ    });\n 291Ôćĺ\n 292Ôćĺ    it('should default to 10 commits', async () => {\n 293Ôćĺ      let capturedOpts;\n 294Ôćĺ      mockGit.log = async (opts) => {\n 295Ôćĺ        capturedOpts = opts;\n 296Ôćĺ        return { all: [] };\n 297Ôćĺ      };\n 298Ôćĺ      gitService = createGitService({ git: mockGit });\n 299Ôćĺ\n 300Ôćĺ      await gitService.getCommitLog();\n 301Ôćĺ\n 302Ôćĺ      assert.strictEqual(capturedOpts['-n'], 10);\n 303Ôćĺ    });\n 304Ôćĺ  });\n 305Ôćĺ\n 306Ôćĺ  describe('getShortHash()', () => {\n 307Ôćĺ    it('should return 7-character short hash', () => {\n 308Ôćĺ      const result = gitService.getShortHash('a1b2c3d4e5f6g7h8');\n 309Ôćĺ      assert.strictEqual(result, 'a1b2c3d');\n 310Ôćĺ    });\n 311Ôćĺ\n 312Ôćĺ    it('should return empty string for null input', () => {\n 313Ôćĺ      const result = gitService.getShortHash(null);\n 314Ôćĺ      assert.strictEqual(result, '');\n 315Ôćĺ    });\n 316Ôćĺ\n 317Ôćĺ    it('should handle short hashes', () => {\n 318Ôćĺ      const result = gitService.getShortHash('abc');\n 319Ôćĺ      assert.strictEqual(result, 'abc');\n 320Ôćĺ    });\n 321Ôćĺ  });\n 322Ôćĺ});\n 323Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:23:17.184Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
