{"type":"user","uuid":"b617f8a5-67d0-4b7e-9b9b-cbb3e8bb4b9d","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cdecb273cf3701fbb841e62b6c6cc","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Commits Command Handler\n   3Ôćĺ * F-008: Commit Workflow Integration\n   4Ôćĺ *\n   5Ôćĺ * Handles /commits command to view session commit history.\n   6Ôćĺ */\n   7Ôćĺ\n   8Ôćĺimport { sessionStore } from '../../../services/session-store.js';\n   9Ôćĺ\n  10Ôćĺ/**\n  11Ôćĺ * Commits command metadata\n  12Ôćĺ */\n  13Ôćĺexport const commitsMeta = {\n  14Ôćĺ  name: 'commits',\n  15Ôćĺ  aliases: ['history'],\n  16Ôćĺ  description: 'Ščąšťőń╝ÜŔ»ŁŠĆÉń║ĄňÄćňĆ▓',\n  17Ôćĺ  usage: '/commits [--count=10]',\n  18Ôćĺ  examples: [\n  19Ôćĺ    '/commits',\n  20Ôćĺ    '/commits --count=5'\n  21Ôćĺ  ],\n  22Ôćĺ  params: [\n  23Ôćĺ    {\n  24Ôćĺ      name: 'count',\n  25Ôćĺ      type: 'number',\n  26Ôćĺ      required: false,\n  27Ôćĺ      default: 10,\n  28Ôćĺ      description: 'ŠśżšĄ║šÜäŠĆÉń║ĄŠĽ░ÚçĆ'\n  29Ôćĺ    }\n  30Ôćĺ  ],\n  31Ôćĺ  requiresAuth: true,\n  32Ôćĺ  minRole: 'viewer',\n  33Ôćĺ  helpText: '/commits [--count=N] - Ščąšťőń╝ÜŔ»ŁŠĆÉń║ĄňÄćňĆ▓'\n  34Ôćĺ};\n  35Ôćĺ\n  36Ôćĺ/**\n  37Ôćĺ * Handle commits command\n  38Ôćĺ * @param {Object} handlerCtx - Handler context\n  39Ôćĺ */\n  40Ôćĺexport async function handleCommits(handlerCtx) {\n  41Ôćĺ  const { ctx, params, reply, userId } = handlerCtx;\n  42Ôćĺ\n  43Ôćĺ  // Get session ID from context\n  44Ôćĺ  const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n  45Ôćĺ\n  46Ôćĺ  // Get count parameter\n  47Ôćĺ  const count = Math.min(params.count || 10, 20); // Max 20\n  48Ôćĺ\n  49Ôćĺ  try {\n  50Ôćĺ    // Get commits from session store\n  51Ôćĺ    const commits = sessionStore.getCommits(sessionId);\n  52Ôćĺ\n  53Ôćĺ    if (!commits || commits.length === 0) {\n  54Ôćĺ      await reply('­čôş ňŻôňëŹń╝ÜŔ»ŁŠÜéŠŚáŠĆÉń║ĄŔ«░ňŻĽŃÇé');\n  55Ôćĺ      return;\n  56Ôćĺ    }\n  57Ôćĺ\n  58Ôćĺ    // Format commit history\n  59Ôćĺ    const formattedCommits = commits.slice(-count).reverse();\n  60Ôćĺ    const message = formatCommitsList(formattedCommits);\n  61Ôćĺ\n  62Ôćĺ    await reply(message);\n  63Ôćĺ  } catch (error) {\n  64Ôćĺ    await reply(`ÔŁî ŔÄĚňĆľŠĆÉń║ĄňÄćňĆ▓ňĄ▒Ŕ┤ą: ${error.message}`);\n  65Ôćĺ  }\n  66Ôćĺ}\n  67Ôćĺ\n  68Ôćĺ/**\n  69Ôćĺ * Format commits list for Telegram\n  70Ôćĺ * @param {Object[]} commits - Array of commit records\n  71Ôćĺ * @returns {string} Formatted message\n  72Ôćĺ */\n  73Ôćĺfunction formatCommitsList(commits) {\n  74Ôćĺ  const lines = ['­čôő **ŠĆÉń║ĄňÄćňĆ▓**', ''];\n  75Ôćĺ\n  76Ôćĺ  for (const commit of commits) {\n  77Ôćĺ    const time = formatTimestamp(commit.timestamp);\n  78Ôćĺ    const shortMsg = commit.message?.split('\\n')[0] || '(ŠŚáŠÂłŠü»)';\n  79Ôćĺ\n  80Ôćĺ    lines.push(`\\`${commit.shortHash}\\` ${shortMsg}`);\n  81Ôćĺ    lines.push(`   ­čôů ${time} | ­čôü ${commit.filesChanged || 0} Šľçń╗Â`);\n  82Ôćĺ\n  83Ôćĺ    if (commit.featureId) {\n  84Ôćĺ      lines.push(`   ­čĆĚ´ŞĆ Feature: ${commit.featureId}`);\n  85Ôćĺ    }\n  86Ôćĺ    if (commit.bugfixId) {\n  87Ôćĺ      lines.push(`   ­čÉŤ Bugfix: ${commit.bugfixId}`);\n  88Ôćĺ    }\n  89Ôćĺ\n  90Ôćĺ    lines.push('');\n  91Ôćĺ  }\n  92Ôćĺ\n  93Ôćĺ  lines.push(`_ňů▒ ${commits.length} ŠŁíŠĆÉń║ĄŔ«░ňŻĽ_`);\n  94Ôćĺ\n  95Ôćĺ  return lines.join('\\n');\n  96Ôćĺ}\n  97Ôćĺ\n  98Ôćĺ/**\n  99Ôćĺ * Format timestamp for display\n 100Ôćĺ * @param {number} timestamp - Unix timestamp in milliseconds\n 101Ôćĺ * @returns {string} Formatted date string\n 102Ôćĺ */\n 103Ôćĺfunction formatTimestamp(timestamp) {\n 104Ôćĺ  if (!timestamp) return 'Šť¬ščąŠŚÂÚŚ┤';\n 105Ôćĺ\n 106Ôćĺ  const date = new Date(timestamp);\n 107Ôćĺ  const now = new Date();\n 108Ôćĺ  const diffMs = now - date;\n 109Ôćĺ  const diffMins = Math.floor(diffMs / 60000);\n 110Ôćĺ  const diffHours = Math.floor(diffMs / 3600000);\n 111Ôćĺ  const diffDays = Math.floor(diffMs / 86400000);\n 112Ôćĺ\n 113Ôćĺ  if (diffMins < 1) return 'ňłÜňłÜ';\n 114Ôćĺ  if (diffMins < 60) return `${diffMins} ňłćÚĺčňëŹ`;\n 115Ôćĺ  if (diffHours < 24) return `${diffHours} ň░ĆŠŚÂňëŹ`;\n 116Ôćĺ  if (diffDays < 7) return `${diffDays} ňĄęňëŹ`;\n 117Ôćĺ\n 118Ôćĺ  return date.toLocaleDateString('zh-CN', {\n 119Ôćĺ    month: 'short',\n 120Ôćĺ    day: 'numeric',\n 121Ôćĺ    hour: '2-digit',\n 122Ôćĺ    minute: '2-digit'\n 123Ôćĺ  });\n 124Ôćĺ}\n 125Ôćĺ\n 126Ôćĺexport default handleCommits;\n 127Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:26:22.316Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
