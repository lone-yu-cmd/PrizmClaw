eGit(baseDir);\n  51Ôćĺ\n  52Ôćĺ  /**\n  53Ôćĺ   * Get git working directory status\n  54Ôćĺ   * @returns {Promise<GitStatus>}\n  55Ôćĺ   */\n  56Ôćĺ  async function getStatus() {\n  57Ôćĺ    const status = await git.status();\n  58Ôćĺ\n  59Ôćĺ    return {\n  60Ôćĺ      clean: status.isClean(),\n  61Ôćĺ      staged: status.staged,\n  62Ôćĺ      modified: status.modified,\n  63Ôćĺ      untracked: status.not_added,\n  64Ôćĺ      conflicts: status.conflicted,\n  65Ôćĺ      ahead: status.ahead,\n  66Ôćĺ      behind: status.behind,\n  67Ôćĺ      currentBranch: status.current\n  68Ôćĺ    };\n  69Ôćĺ  }\n  70Ôćĺ\n  71Ôćĺ  /**\n  72Ôćĺ   * Check if working directory is clean\n  73Ôćĺ   * @returns {Promise<boolean>}\n  74Ôćĺ   */\n  75Ôćĺ  async function isClean() {\n  76Ôćĺ    const status = await git.status();\n  77Ôćĺ    return status.isClean();\n  78Ôćĺ  }\n  79Ôćĺ\n  80Ôćĺ  /**\n  81Ôćĺ   * Get list of changed files\n  82Ôćĺ   * @returns {Promise<string[]>}\n  83Ôćĺ   */\n  84Ôćĺ  async function getChangedFiles() {\n  85Ôćĺ    const status = await git.status();\n  86Ôćĺ    return [\n  87Ôćĺ      ...status.staged,\n  88Ôćĺ      ...status.modified,\n  89Ôćĺ      ...status.not_added,\n  90Ôćĺ      ...status.conflicted\n  91Ôćĺ    ];\n  92Ôćĺ  }\n  93Ôćĺ\n  94Ôćĺ  /**\n  95Ôćĺ   * Execute a git commit\n  96Ôćĺ   * @param {string} message - Commit message\n  97Ôćĺ   * @param {Object} [commitOptions] - Commit options\n  98Ôćĺ   * @param {boolean} [commitOptions.amend] - Whether to amend last commit\n  99Ôćĺ   * @param {boolean} [commitOptions.allowEmpty] - Allow empty commit\n 100Ôćĺ   * @returns {Promise<CommitResult>}\n 101Ôćĺ   */\n 102Ôćĺ  async function commit(message, commitOptions = {}) {\n 103Ôćĺ    try {\n 104Ôćĺ      const status = await git.status();\n 105Ôćĺ\n 106Ôćĺ      // Check for nothing to commit\n 107Ôćĺ      if (status.isClean() && !commitOptions.allowEmpty) {\n 108Ôćĺ        return {\n 109Ôćĺ          success: false,\n 110Ôćĺ          error: GIT_ERRORS.NOTHING_TO_COMMIT.message,\n 111Ôćĺ          code: GIT_ERRORS.NOTHING_TO_COMMIT.code,\n 112Ôćĺ          suggestion: GIT_ERRORS.NOTHING_TO_COMMIT.suggestion\n 113Ôćĺ        };\n 114Ôćĺ      }\n 115Ôćĺ\n 116Ôćĺ      // Check for conflicts\n 117Ôćĺ      if (status.conflicted.length > 0) {\n 118Ôćĺ        return {\n 119Ôćĺ          success: false,\n 120Ôćĺ          error: GIT_ERRORS.MERGE_CONFLICT.message,\n 121Ôćĺ          code: GIT_ERRORS.MERGE_CONFLICT.code,\n 122Ôćĺ          suggestion: `${GIT_ERRORS.MERGE_CONFLICT.suggestion}: ${status.conflicted.join(', ')}`,\n 123Ôćĺ          conflicts: status.conflicted\n 124Ôćĺ        };\n 125Ôćĺ      }\n 126Ôćĺ\n 127Ôćĺ      // Build commit options\n 128Ôćĺ      const gitOptions = [];\n 129Ôćĺ      if (commitOptions.amend) {\n 130Ôćĺ        gitOptions.push('--amend');\n 131Ôćĺ      }\n 132Ôćĺ      if (commitOptions.allowEmpty) {\n 133Ôćĺ        gitOptions.push('--allow-empty');\n 134Ôćĺ      }\n 135Ôćĺ\n 136Ôćĺ      // Execute commit\n 137Ôćĺ      const result = await git.commit(message, gitOptions);\n 138Ôćĺ\n 139Ôćĺ      if (!result.commit) {\n 140Ôćĺ        return {\n 141Ôćĺ          success: false,\n 142Ôćĺ          error: GIT_ERRORS.COMMIT_FAILED.message,\n 143Ôćĺ          code: GIT_ERRORS.COMMIT_FAILED.code,\n 144Ôćĺ          suggestion: GIT_ERRORS.COMMIT_FAILED.suggestion\n 145Ôćĺ        };\n 146Ôćĺ      }\n 147Ôćĺ\n 148Ôćĺ      return {\n 149Ôćĺ        success: true,\n 150Ôćĺ        hash: result.commit,\n 151Ôćĺ        shortHash: getShortHash(result.commit),\n 152Ôćĺ        message: message,\n 153Ôćĺ        filesChanged: result.summary.changes || 0\n 154Ôćĺ      };\n 155Ôćĺ    } catch (error) {\n 156Ôćĺ      return {\n 157Ôćĺ        success: false,\n 158Ôćĺ        error: error.message,\n 159Ôćĺ        suggestion: GIT_ERRORS.COMMIT_FAILED.suggestion\n 160Ôćĺ      };\n 161Ôćĺ    }\n 162Ôćĺ  }\n 163Ôćĺ\n 164Ôćĺ  /**\n 165Ôćĺ   * Amend the last commit\n 166Ôćĺ   * @param {string} message - New commit message\n 167Ôćĺ   * @returns {Promise<CommitResult>}\n 168Ôćĺ   */\n 169Ôćĺ  async function amendCommit(message) {\n 170Ôćĺ    try {\n 171Ôćĺ      const result = await git.commit(message, ['--amend', '--no-edit']);\n 172Ôćĺ\n 173Ôćĺ      if (!result.commit) {\n 174Ôćĺ        // Amend without changes might return same hash\n 175Ôćĺ        const lastCommit = await getLastCommit();\n 176Ôćĺ        return {\n 177Ôćĺ          success: true,\n 178Ôćĺ          hash: lastCommit.hash,\n 179Ôćĺ          shortHash: lastCommit.shortHash,\n 180Ôćĺ          message: message,\n 181Ôćĺ          filesChanged: 0\n 182Ôćĺ        };\n 183Ôćĺ      }\n 184Ôćĺ\n 185Ôćĺ      return {\n 186Ôćĺ        success: true,\n 187Ôćĺ        hash: result.commit,\n 188Ôćĺ        shortHash: getShortHash(result.commit),\n 189Ôćĺ        message: message,\n 190Ôćĺ        filesChanged: result.summary.changes || 0\n 191Ôćĺ      };\n 192Ôćĺ    } catch (error) {\n 193Ôćĺ      return {\n 194Ôćĺ        success: false,\n 195Ôćĺ        error: error.message,\n 196Ôćĺ        code: GIT_ERRORS.AMEND_FAILED.code,\n 197Ôćĺ        suggestion: GIT_ERRORS.AMEND_FAILED.suggestion\n 198Ôćĺ      };\n 199Ôćĺ    }\n 200Ôćĺ  }\n 201Ôćĺ\n 202Ôćĺ  /**\n 203Ôćĺ   * Get the last commit info\n 204Ôćĺ   * @returns {Promise<CommitInfo>}\n 205Ôćĺ   */\n 206Ôćĺ  async function getLastCommit() {\n 207Ôćĺ    const log = await git.log(['-1']);\n 208Ôćĺ    const latest = log.latest;\n 209Ôćĺ\n 210Ôćĺ    if (!latest) {\n 211Ôćĺ      return null;\n 212Ôćĺ    }\n 213Ôćĺ\n 214Ôćĺ    return {\n 215Ôćĺ      hash: latest.hash,\n 216Ôćĺ      shortHash: getShortHash(latest.hash),\n 217Ôćĺ      message: latest.message,\n 218Ôćĺ      author: latest.author_name,\n 219Ôćĺ      date: latest.date\n 220Ôćĺ    };\n 221Ôćĺ  }\n 222Ôćĺ\n 223Ôćĺ  /**\n 224Ôćĺ   * Get commit history\n 225Ôćĺ   * @param {number} [count=10] - Number of commits to retrieve\n 226Ôćĺ   * @returns {Promise<CommitInfo[]>}\n 227Ôćĺ   */\n 228Ôćĺ  async function getCommitLog(count = 10) {\n 229Ôćĺ    const log