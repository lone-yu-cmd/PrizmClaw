{"type":"user","uuid":"9c3be30a-1df6-4a4e-92fa-b34606ce4d29","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeca40cf5c986d828f57fd8136bd","content":[{"type":"text","text":"   1Ôćĺimport { config } from '../config.js';\n   2Ôćĺ\n   3Ôćĺclass SessionStore {\n   4Ôćĺ  #messagesBySessionKey = new Map();\n   5Ôćĺ  #commitsBySessionKey = new Map();\n   6Ôćĺ\n   7Ôćĺ  get(sessionKey) {\n   8Ôćĺ    if (!this.#messagesBySessionKey.has(sessionKey)) {\n   9Ôćĺ      this.#messagesBySessionKey.set(sessionKey, []);\n  10Ôćĺ    }\n  11Ôćĺ    return this.#messagesBySessionKey.get(sessionKey);\n  12Ôćĺ  }\n  13Ôćĺ\n  14Ôćĺ  append(sessionKey, role, content) {\n  15Ôćĺ    const messages = this.get(sessionKey);\n  16Ôćĺ    messages.push({ role, content });\n  17Ôćĺ\n  18Ôćĺ    const maxMessages = config.maxHistoryTurns * 2;\n  19Ôćĺ    if (messages.length > maxMessages) {\n  20Ôćĺ      messages.splice(0, messages.length - maxMessages);\n  21Ôćĺ    }\n  22Ôćĺ  }\n  23Ôćĺ\n  24Ôćĺ  clear(sessionKey) {\n  25Ôćĺ    this.#messagesBySessionKey.delete(sessionKey);\n  26Ôćĺ    this.#commitsBySessionKey.delete(sessionKey);\n  27Ôćĺ  }\n  28Ôćĺ\n  29Ôćĺ  toPrompt(sessionKey, channel = 'unknown') {\n  30Ôćĺ    const messages = this.get(sessionKey);\n  31Ôćĺ\n  32Ôćĺ    return [\n  33Ôćĺ      `ńŻáŠşúňťĘÚÇÜŔ┐ç ${channel} ŠŞáÚüôŠĆÉńżŤšöÁŔäĹňŐęŠëőŠťŹňŐíŃÇé`,\n  34Ôćĺ      'Ŕ»ĚńŻ┐šöĘŔç¬šäÂŃÇüš«ÇŠ┤üŃÇüňĆ»ŠëžŔíîšÜäŔíĘŔżżŃÇé',\n  35Ôćĺ      'ňŽéŠ×ťšöĘŠłĚŔ»ĚŠ▒éš│╗š╗čŠôŹńŻťŠłľŠł¬ňŤż´╝îŠśÄší«Ŕ»┤ŠśÄŠşąÚ¬ĄńŞÄš╗ôŠ×ťŃÇé',\n  36Ôćĺ      'ňŻôńŻáń║žňç║ŠťČňť░Šľçń╗Â´╝łŠł¬ňŤż/ŠľçŠíú´╝ëŠŚÂ´╝îň┐ůÚí╗ÚóŁňĄľŔżôňç║šőČšźőŔíî´╝ÜSEND_FILE:<š╗Łň»╣ŔĚ»ňżä>ŃÇé',\n  37Ôćĺ      'šŽüŠşóń╗ůŔżôňç║ @image:xxx ŠłľšŤŞň»╣ŔĚ»ňżä´╝ŤŔĚ»ňżäň┐ůÚí╗Šś»š╗Łň»╣ŔĚ»ňżä´╝łńżőňŽé /var/folders/... Šłľ /home/...´╝ëŃÇé',\n  38Ôćĺ      'ń╗ąńŞőŠś»ŠťÇŔ┐Ĺň»╣Ŕ»ŁńŞŐńŞőŠľç´╝Ü',\n  39Ôćĺ      ...messages.map((msg) => `${msg.role === 'user' ? 'šöĘŠłĚ' : 'ňŐęŠëő'}: ${msg.content}`),\n  40Ôćĺ      'Ŕ»Ěš╗žš╗şňŤ×šşöŠťÇňÉÄńŞÇŠŁíšöĘŠłĚŠÂłŠü»ŃÇé'\n  41Ôćĺ    ].join('\\n');\n  42Ôćĺ  }\n  43Ôćĺ\n  44Ôćĺ  /**\n  45Ôćĺ   * Add a commit record to a session.\n  46Ôćĺ   * @param {string} sessionKey - Session identifier\n  47Ôćĺ   * @param {Object} commitInfo - Commit information\n  48Ôćĺ   */\n  49Ôćĺ  addCommit(sessionKey, commitInfo) {\n  50Ôćĺ    if (!this.#commitsBySessionKey.has(sessionKey)) {\n  51Ôćĺ      this.#commitsBySessionKey.set(sessionKey, []);\n  52Ôćĺ    }\n  53Ôćĺ    const commits = this.#commitsBySessionKey.get(sessionKey);\n  54Ôćĺ    commits.push({\n  55Ôćĺ      ...commitInfo,\n  56Ôćĺ      timestamp: commitInfo.timestamp || Date.now()\n  57Ôćĺ    });\n  58Ôćĺ  }\n  59Ôćĺ\n  60Ôćĺ  /**\n  61Ôćĺ   * Get commits for a session.\n  62Ôćĺ   * @param {string} sessionKey - Session identifier\n  63Ôćĺ   * @returns {Object[]} Array of commit records\n  64Ôćĺ   */\n  65Ôćĺ  getCommits(sessionKey) {\n  66Ôćĺ    return this.#commitsBySessionKey.get(sessionKey) || [];\n  67Ôćĺ  }\n  68Ôćĺ\n  69Ôćĺ  /**\n  70Ôćĺ   * Get the last commit for a session.\n  71Ôćĺ   * @param {string} sessionKey - Session identifier\n  72Ôćĺ   * @returns {Object|null} Last commit record or null\n  73Ôćĺ   */\n  74Ôćĺ  getLastCommit(sessionKey) {\n  75Ôćĺ    const commits = this.getCommits(sessionKey);\n  76Ôćĺ    return commits.length > 0 ? commits[commits.length - 1] : null;\n  77Ôćĺ  }\n  78Ôćĺ}\n  79Ôćĺ\n  80Ôćĺexport const sessionStore = new SessionStore();\n  81Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:25:23.290Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
