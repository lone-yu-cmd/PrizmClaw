cts(\n        async () => commitService.validatePreConditions(),\n        /Not implemented/\n      );\n    });\n  });\n\n  describe('checkPipelineStatus()', () => {\n    it('should return isRunning false when pipeline is idle', async () => {\n      // T-210: Test to be implemented\n      await assert.rejects(\n        async () => commitService.checkPipelineStatus(),\n        /Not implemented/\n      );\n    });\n  });\n\n  describe('checkTestStatus()', () => {\n    it('should return test status from state file', async () => {\n      // T-210: Test to be implemented\n      await assert.rejects(\n        async () => commitService.checkTestStatus(),\n        /Not implemented/\n      );\n    });\n  });\n\n  describe('commit()', () => {\n    it('should execute commit with validation', async () => {\n      // T-211: Test to be implemented\n      await assert.rejects(\n        async () => commitService.commit({ sessionId: 'test', userId: 'user1' }),\n        /Not implemented/\n      );\n    });\n  });\n\n  describe('recordCommit()', () => {\n    it('should record commit to session', async () => {\n      // T-211: Test to be implemented\n      await assert.rejects(\n        async () => commitService.recordCommit('session1', { hash: 'abc' }),\n        /Not implemented/\n      );\n    });\n  });\n\n  describe('getSessionCommits()', () => {\n    it('should return empty array for new session', async () => {\n      // T-211: Test to be implemented\n      await assert.rejects(\n        async () => commitService.getSessionCommits('new-session'),\n        /Not implemented/\n      );\n    });\n  });\n\n  describe('getErrorSuggestion()', () => {\n    it('should return error with suggestion', () => {\n      const result = commitService.getErrorSuggestion('PIPELINE_RUNNING');\n      assert.strictEqual(result.code, 'PIPELINE_RUNNING');\n      assert.ok(result.suggestion);\n    });\n\n    it('should return default for unknown code', () => {\n      const result = commitService.getErrorSuggestion('UNKNOWN');\n      assert.strictEqual(result.code, 'UNKNOWN');\n      assert.strictEqual(result.message, 'Šť¬ščąÚöÖŔ»»');\n    });\n  });\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/commit-service.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:21:28.405Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
