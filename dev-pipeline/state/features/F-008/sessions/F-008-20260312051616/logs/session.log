{"type":"user","uuid":"866583a8-5a47-4a1e-9e51-3c7730af9f38","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cded08b8bac3ee372486f33b89523","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Commit Handler Unit Tests\n   3Ôćĺ * F-008: Commit Workflow Integration\n   4Ôćĺ */\n   5Ôćĺ\n   6Ôćĺimport { describe, it, beforeEach, afterEach } from 'node:test';\n   7Ôćĺimport assert from 'node:assert';\n   8Ôćĺimport { handleCommit, commitMeta } from '../../../../src/bot/commands/handlers/commit.js';\n   9Ôćĺimport { createMockContext } from '../../../helpers/mock-telegram.js';\n  10Ôćĺimport { setConfigForTesting, resetConfig } from '../../../../src/security/permission-guard.js';\n  11Ôćĺ\n  12Ôćĺfunction createMockHandlerCtx(overrides = {}) {\n  13Ôćĺ  const ctx = createMockContext(overrides.ctx);\n  14Ôćĺ  const replies = [];\n  15Ôćĺ\n  16Ôćĺ  return {\n  17Ôćĺ    ctx,\n  18Ôćĺ    parsed: { flags: {} },\n  19Ôćĺ    params: {},\n  20Ôćĺ    userId: 123456789,\n  21Ôćĺ    userRole: 'operator',\n  22Ôćĺ    requiresConfirmation: false,\n  23Ôćĺ    reply: async (text) => {\n  24Ôćĺ      replies.push(text);\n  25Ôćĺ      return { message_id: replies.length };\n  26Ôćĺ    },\n  27Ôćĺ    _getReplies: () => replies,\n  28Ôćĺ    _getLastReply: () => replies[replies.length - 1],\n  29Ôćĺ    ...overrides\n  30Ôćĺ  };\n  31Ôćĺ}\n  32Ôćĺ\n  33Ôćĺdescribe('commitMeta', () => {\n  34Ôćĺ  it('should have correct name', () => {\n  35Ôćĺ    assert.strictEqual(commitMeta.name, 'commit');\n  36Ôćĺ  });\n  37Ôćĺ\n  38Ôćĺ  it('should have aliases', () => {\n  39Ôćĺ    assert.ok(commitMeta.aliases.includes('c'));\n  40Ôćĺ  });\n  41Ôćĺ\n  42Ôćĺ  it('should have minRole of operator', () => {\n  43Ôćĺ    assert.strictEqual(commitMeta.minRole, 'operator');\n  44Ôćĺ  });\n  45Ôćĺ\n  46Ôćĺ  it('should have params defined', () => {\n  47Ôćĺ    assert.ok(commitMeta.params.length > 0);\n  48Ôćĺ  });\n  49Ôćĺ\n  50Ôćĺ  it('should have help text', () => {\n  51Ôćĺ    assert.ok(commitMeta.helpText);\n  52Ôćĺ  });\n  53Ôćĺ});\n  54Ôćĺ\n  55Ôćĺdescribe('handleCommit - Parameter Validation', () => {\n  56Ôćĺ  it('should reject commit message over 500 characters', async () => {\n  57Ôćĺ    const longMessage = 'a'.repeat(501);\n  58Ôćĺ    const handlerCtx = createMockHandlerCtx({\n  59Ôćĺ      params: { message: longMessage }\n  60Ôćĺ    });\n  61Ôćĺ\n  62Ôćĺ    await handleCommit(handlerCtx);\n  63Ôćĺ\n  64Ôćĺ    const lastReply = handlerCtx._getLastReply();\n  65Ôćĺ    assert.ok(lastReply.includes('Ŕ┐çÚĽ┐'));\n  66Ôćĺ  });\n  67Ôćĺ\n  68Ôćĺ  it('should accept commit message at 500 characters', async () => {\n  69Ôćĺ    const maxMessage = 'a'.repeat(500);\n  70Ôćĺ    const handlerCtx = createMockHandlerCtx({\n  71Ôćĺ      params: { message: maxMessage }\n  72Ôćĺ    });\n  73Ôćĺ\n  74Ôćĺ    await handleCommit(handlerCtx);\n  75Ôćĺ\n  76Ôćĺ    // Should not reject for length (may fail for other reasons)\n  77Ôćĺ    const lastReply = handlerCtx._getLastReply();\n  78Ôćĺ    assert.ok(!lastReply.includes('Ŕ┐çÚĽ┐'));\n  79Ôćĺ  });\n  80Ôćĺ});\n  81Ôćĺ\n  82Ôćĺdescribe('handleCommit - Permission Checks', () => {\n  83Ôćĺ  it('should reject amend from non-admin', async () => {\n  84Ôćĺ    // User is not in the admin list\n  85Ôćĺ    const handlerCtx = createMockHandlerCtx({\n  86Ôćĺ      params: { amend: true },\n  87Ôćĺ      userId: 888888888,\n  88Ôćĺ      userRole: 'operator'\n  89Ôćĺ    });\n  90Ôćĺ\n  91Ôćĺ    await handleCommit(handlerCtx);\n  92Ôćĺ\n  93Ôćĺ    const lastReply = handlerCtx._getLastReply();\n  94Ôćĺ    assert.ok(lastReply.includes('admin'));\n  95Ôćĺ  });\n  96Ôćĺ\n  97Ôćĺ  it('should reject force from non-admin', async () => {\n  98Ôćĺ    const handlerCtx = createMockHandlerCtx({\n  99Ôćĺ      params: { force: true },\n 100Ôćĺ      userId: 888888888,\n 101Ôćĺ      userRole: 'operator'\n 102Ôćĺ    });\n 103Ôćĺ\n 104Ôćĺ    await handleCommit(handlerCtx);\n 105Ôćĺ\n 106Ôćĺ    const lastReply = handlerCtx._getLastReply();\n 107Ôćĺ    assert.ok(lastReply.includes('admin'));\n 108Ôćĺ  });\n 109Ôćĺ});\n 110Ôćĺ\n 111Ôćĺdescribe('handleCommit - Confirmation Flow', () => {\n 112Ôćĺ  beforeEach(() => {\n 113Ôćĺ    // Set up test config with admin user\n 114Ôćĺ    setConfigForTesting({\n 115Ôćĺ      userPermissions: new Map([\n 116Ôćĺ        ['999999999', 'admin']\n 117Ôćĺ      ])\n 118Ôćĺ    });\n 119Ôćĺ  });\n 120Ôćĺ\n 121Ôćĺ  afterEach(() => {\n 122Ôćĺ    resetConfig();\n 123Ôćĺ  });\n 124Ôćĺ\n 125Ôćĺ  it('should create confirmation for amend operation', async () => {\n 126Ôćĺ    const handlerCtx = createMockHandlerCtx({\n 127Ôćĺ      params: { amend: true },\n 128Ôćĺ      userId: 999999999,\n 129Ôćĺ      userRole: 'admin',\n 130Ôćĺ      requiresConfirmation: true\n 131Ôćĺ    });\n 132Ôćĺ\n 133Ôćĺ    await handleCommit(handlerCtx);\n 134Ôćĺ\n 135Ôćĺ    const lastReply = handlerCtx._getLastReply();\n 136Ôćĺ    assert.ok(lastReply.includes('ší«Ŕ«Ą'));\n 137Ôćĺ  });\n 138Ôćĺ\n 139Ôćĺ  it('should create confirmation for force operation', async () => {\n 140Ôćĺ    const handlerCtx = createMockHandlerCtx({\n 141Ôćĺ      params: { force: true },\n 142Ôćĺ      userId: 999999999,\n 143Ôćĺ      userRole: 'admin',\n 144Ôćĺ      requiresConfirmation: true\n 145Ôćĺ    });\n 146Ôćĺ\n 147Ôćĺ    await handleCommit(handlerCtx);\n 148Ôćĺ\n 149Ôćĺ    const lastReply = handlerCtx._getLastReply();\n 150Ôćĺ    assert.ok(lastReply.includes('ší«Ŕ«Ą'));\n 151Ôćĺ  });\n 152Ôćĺ});\n 153Ôćĺ\n 154Ôćĺdescribe('handleCommit - Error Handling', () => {\n 155Ôćĺ  it('should handle commit failure gracefully', async () => {\n 156Ôćĺ    const handlerCtx = createMockHandlerCtx({\n 157Ôćĺ      params: { message: 'test commit' }\n 158Ôćĺ    });\n 159Ôćĺ\n 160Ôćĺ    await handleCommit(handlerCtx);\n 161Ôćĺ\n 162Ôćĺ    // Should have a reply (either success or failure)\n 163Ôćĺ    const replies = handlerCtx._getReplies();\n 164Ôćĺ    assert.ok(replies.length > 0);\n 165Ôćĺ  });\n 166Ôćĺ});\n 167Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_6dd6624e56464f3aa14c1444","__timestamp":"2026-03-11T21:32:16.107Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
{"type":"user","uuid":"83dd9fbd-221e-4d8a-933f-97e057bcac02","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cded08d51571d213031aed7e411c3","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Commits Handler Unit Tests\n   3Ôćĺ * F-008: Commit Workflow Integration\n   4Ôćĺ */\n   5Ôćĺ\n   6Ôćĺimport { describe, it, beforeEach } from 'node:test';\n   7Ôćĺimport assert from 'node:assert';\n   8Ôćĺimport { handleCommits, commitsMeta } from '../../../../src/bot/commands/handlers/commits.js';\n   9Ôćĺimport { createMockContext } from '../../../helpers/mock-telegram.js';\n  10Ôćĺimport { sessionStore } from '../../../../src/services/session-store.js';\n  11Ôćĺ\n  12Ôćĺfunction createMockHandlerCtx(overrides = {}) {\n  13Ôćĺ  const ctx = createMockContext(overrides.ctx);\n  14Ôćĺ  const replies = [];\n  15Ôćĺ\n  16Ôćĺ  return {\n  17Ôćĺ    ctx,\n  18Ôćĺ    parsed: { flags: {} },\n  19Ôćĺ    params: {},\n  20Ôćĺ    userId: 123456789,\n  21Ôćĺ    userRole: 'viewer',\n  22Ôćĺ    reply: async (text) => {\n  23Ôćĺ      replies.push(text);\n  24Ôćĺ      return { message_id: replies.length };\n  25Ôćĺ    },\n  26Ôćĺ    _getReplies: () => replies,\n  27Ôćĺ    _getLastReply: () => replies[replies.length - 1],\n  28Ôćĺ    ...overrides\n  29Ôćĺ  };\n  30Ôćĺ}\n  31Ôćĺ\n  32Ôćĺdescribe('commitsMeta', () => {\n  33Ôćĺ  it('should have correct name', () => {\n  34Ôćĺ    assert.strictEqual(commitsMeta.name, 'commits');\n  35Ôćĺ  });\n  36Ôćĺ\n  37Ôćĺ  it('should have aliases', () => {\n  38Ôćĺ    assert.ok(commitsMeta.aliases.includes('history'));\n  39Ôćĺ  });\n  40Ôćĺ\n  41Ôćĺ  it('should have minRole of viewer', () => {\n  42Ôćĺ    assert.strictEqual(commitsMeta.minRole, 'viewer');\n  43Ôćĺ  });\n  44Ôćĺ});\n  45Ôćĺ\n  46Ôćĺdescribe('handleCommits', () => {\n  47Ôćĺ  const testSessionId = '123456789';\n  48Ôćĺ\n  49Ôćĺ  beforeEach(() => {\n  50Ôćĺ    // Clear session commits\n  51Ôćĺ    sessionStore.clear(testSessionId);\n  52Ôćĺ  });\n  53Ôćĺ\n  54Ôćĺ  it('should show empty message when no commits', async () => {\n  55Ôćĺ    const handlerCtx = createMockHandlerCtx();\n  56Ôćĺ    await handleCommits(handlerCtx);\n  57Ôćĺ\n  58Ôćĺ    const lastReply = handlerCtx._getLastReply();\n  59Ôćĺ    assert.ok(lastReply.includes('ŠÜéŠŚáŠĆÉń║ĄŔ«░ňŻĽ'));\n  60Ôćĺ  });\n  61Ôćĺ\n  62Ôćĺ  it('should show commits list when commits exist', async () => {\n  63Ôćĺ    // Add test commits\n  64Ôćĺ    sessionStore.addCommit(testSessionId, {\n  65Ôćĺ      hash: 'abc123def456',\n  66Ôćĺ      shortHash: 'abc123d',\n  67Ôćĺ      message: 'test commit 1',\n  68Ôćĺ      filesChanged: 2,\n  69Ôćĺ      timestamp: Date.now()\n  70Ôćĺ    });\n  71Ôćĺ\n  72Ôćĺ    const handlerCtx = createMockHandlerCtx();\n  73Ôćĺ    await handleCommits(handlerCtx);\n  74Ôćĺ\n  75Ôćĺ    const lastReply = handlerCtx._getLastReply();\n  76Ôćĺ    assert.ok(lastReply.includes('ŠĆÉń║ĄňÄćňĆ▓'));\n  77Ôćĺ    assert.ok(lastReply.includes('abc123d'));\n  78Ôćĺ  });\n  79Ôćĺ\n  80Ôćĺ  it('should respect count parameter', async () => {\n  81Ôćĺ    // Add multiple commits\n  82Ôćĺ    for (let i = 0; i < 15; i++) {\n  83Ôćĺ      sessionStore.addCommit(testSessionId, {\n  84Ôćĺ        hash: `hash${i}`,\n  85Ôćĺ        shortHash: `short${i}`,\n  86Ôćĺ        message: `commit ${i}`,\n  87Ôćĺ        filesChanged: 1,\n  88Ôćĺ        timestamp: Date.now() + i\n  89Ôćĺ      });\n  90Ôćĺ    }\n  91Ôćĺ\n  92Ôćĺ    const handlerCtx = createMockHandlerCtx({\n  93Ôćĺ      params: { count: 5 }\n  94Ôćĺ    });\n  95Ôćĺ    await handleCommits(handlerCtx);\n  96Ôćĺ\n  97Ôćĺ    const lastReply = handlerCtx._getLastReply();\n  98Ôćĺ    // Should only show 5 commits\n  99Ôćĺ    assert.ok(lastReply.includes('5 ŠŁíŠĆÉń║ĄŔ«░ňŻĽ'));\n 100Ôćĺ  });\n 101Ôćĺ\n 102Ôćĺ  it('should show feature ID if present', async () => {\n 103Ôćĺ    sessionStore.addCommit(testSessionId, {\n 104Ôćĺ      hash: 'abc123',\n 105Ôćĺ      shortHash: 'abc1234',\n 106Ôćĺ      message: 'test',\n 107Ôćĺ      filesChanged: 1,\n 108Ôćĺ      featureId: 'F-008',\n 109Ôćĺ      timestamp: Date.now()\n 110Ôćĺ    });\n 111Ôćĺ\n 112Ôćĺ    const handlerCtx = createMockHandlerCtx();\n 113Ôćĺ    await handleCommits(handlerCtx);\n 114Ôćĺ\n 115Ôćĺ    const lastReply = handlerCtx._getLastReply();\n 116Ôćĺ    assert.ok(lastReply.includes('Feature: F-008'));\n 117Ôćĺ  });\n 118Ôćĺ\n 119Ôćĺ  it('should show bugfix ID if present', async () => {\n 120Ôćĺ    sessionStore.addCommit(testSessionId, {\n 121Ôćĺ      hash: 'abc123',\n 122Ôćĺ      shortHash: 'abc1234',\n 123Ôćĺ      message: 'test',\n 124Ôćĺ      filesChanged: 1,\n 125Ôćĺ      bugfixId: 'BF-001',\n 126Ôćĺ      timestamp: Date.now()\n 127Ôćĺ    });\n 128Ôćĺ\n 129Ôćĺ    const handlerCtx = createMockHandlerCtx();\n 130Ôćĺ    await handleCommits(handlerCtx);\n 131Ôćĺ\n 132Ôćĺ    const lastReply = handlerCtx._getLastReply();\n 133Ôćĺ    assert.ok(lastReply.includes('Bugfix: BF-001'));\n 134Ôćĺ  });\n 135Ôćĺ});\n 136Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_6dd6624e56464f3aa14c1444","__timestamp":"2026-03-11T21:32:16.108Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
