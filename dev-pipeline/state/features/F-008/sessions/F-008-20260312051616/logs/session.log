{"type":"user","uuid":"79e58f62-4a07-4861-88df-a21e6504a561","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cdecdad7292af2c328a80d214e15a","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Help Text Generator\n   3Ôćĺ * Generates help text for commands.\n   4Ôćĺ */\n   5Ôćĺ\n   6Ôćĺimport { getCommand, getAllCommands } from './registry.js';\n   7Ôćĺ\n   8Ôćĺ/**\n   9Ôćĺ * Generate help text for all commands or a specific command.\n  10Ôćĺ * @param {string} [commandName] - Optional command name\n  11Ôćĺ * @returns {string} Help text\n  12Ôćĺ */\n  13Ôćĺexport function generateHelp(commandName) {\n  14Ôćĺ  if (commandName) {\n  15Ôćĺ    return generateCommandHelp(commandName);\n  16Ôćĺ  }\n  17Ôćĺ  return generateGeneralHelp();\n  18Ôćĺ}\n  19Ôćĺ\n  20Ôćĺ/**\n  21Ôćĺ * Generate general help text listing all commands.\n  22Ôćĺ * @returns {string} Help text\n  23Ôćĺ */\n  24Ôćĺfunction generateGeneralHelp() {\n  25Ôćĺ  const commands = getAllCommands();\n  26Ôćĺ\n  27Ôćĺ  if (commands.length === 0) {\n  28Ôćĺ    return 'ŠÜéŠŚáňĆ»šöĘňĹŻń╗ĄŃÇé';\n  29Ôćĺ  }\n  30Ôćĺ\n  31Ôćĺ  const lines = ['ňĆ»šöĘňĹŻń╗Ą´╝Ü', ''];\n  32Ôćĺ\n  33Ôćĺ  for (const entry of commands) {\n  34Ôćĺ    const { meta } = entry;\n  35Ôćĺ    const aliases = meta.aliases?.length ? ` (${meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n  36Ôćĺ    lines.push(`/${meta.name}${aliases}`);\n  37Ôćĺ    lines.push(`  ${meta.description}`);\n  38Ôćĺ    lines.push('');\n  39Ôćĺ  }\n  40Ôćĺ\n  41Ôćĺ  lines.push('Ŕżôňůą /help <ňĹŻń╗Ą> ŠčąšťőŔ»Žš╗ćšöĘŠ│ĽŃÇé');\n  42Ôćĺ\n  43Ôćĺ  return lines.join('\\n');\n  44Ôćĺ}\n  45Ôćĺ\n  46Ôćĺ/**\n  47Ôćĺ * Generate detailed help text for a specific command.\n  48Ôćĺ * @param {string} commandName - Command name\n  49Ôćĺ * @returns {string} Help text\n  50Ôćĺ */\n  51Ôćĺfunction generateCommandHelp(commandName) {\n  52Ôćĺ  const entry = getCommand(commandName);\n  53Ôćĺ\n  54Ôćĺ  if (!entry) {\n  55Ôćĺ    return `Šť¬ščąňĹŻń╗Ą '${commandName}'ŃÇéŔżôňůą /help ŠčąšťőňĆ»šöĘňĹŻń╗ĄŃÇé`;\n  56Ôćĺ  }\n  57Ôćĺ\n  58Ôćĺ  const { meta } = entry;\n  59Ôćĺ  const lines = [];\n  60Ôćĺ\n  61Ôćĺ  // Command name and description\n  62Ôćĺ  lines.push(`/${meta.name} - ${meta.description}`);\n  63Ôćĺ  lines.push('');\n  64Ôćĺ\n  65Ôćĺ  // Aliases\n  66Ôćĺ  if (meta.aliases?.length) {\n  67Ôćĺ    lines.push(`ňłźňÉŹ: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n  68Ôćĺ    lines.push('');\n  69Ôćĺ  }\n  70Ôćĺ\n  71Ôćĺ  // Usage\n  72Ôćĺ  if (meta.usage) {\n  73Ôćĺ    lines.push(`šöĘŠ│Ľ: ${meta.usage}`);\n  74Ôćĺ    lines.push('');\n  75Ôćĺ  }\n  76Ôćĺ\n  77Ôćĺ  // Subcommands\n  78Ôćĺ  if (meta.subcommands?.length) {\n  79Ôćĺ    lines.push('ňşÉňĹŻń╗Ą:');\n  80Ôćĺ    for (const sub of meta.subcommands) {\n  81Ôćĺ      lines.push(`  ${sub.name} - ${sub.description}`);\n  82Ôćĺ    }\n  83Ôćĺ    lines.push('');\n  84Ôćĺ  }\n  85Ôćĺ\n  86Ôćĺ  // Parameters\n  87Ôćĺ  if (meta.params?.length) {\n  88Ôćĺ    lines.push('ňĆéŠĽ░:');\n  89Ôćĺ    for (const param of meta.params) {\n  90Ôćĺ      const required = param.required ? '(ň┐ůňíź)' : '(ňĆ»ÚÇë)';\n  91Ôćĺ      const type = param.type ? ` [${param.type}]` : '';\n  92Ôćĺ      const enumValues = param.enum ? ` {${param.enum.join(', ')}}` : '';\n  93Ôćĺ      const defaultVal = param.default !== undefined ? ` = ${param.default}` : '';\n  94Ôćĺ      lines.push(`  ${param.name}${type}${enumValues}${defaultVal} ${required}`);\n  95Ôćĺ      lines.push(`    ${param.description}`);\n  96Ôćĺ    }\n  97Ôćĺ    lines.push('');\n  98Ôćĺ  }\n  99Ôćĺ\n 100Ôćĺ  // Examples\n 101Ôćĺ  if (meta.examples?.length) {\n 102Ôćĺ    lines.push('šĄ║ńżő:');\n 103Ôćĺ    for (const example of meta.examples) {\n 104Ôćĺ      lines.push(`  ${example}`);\n 105Ôćĺ    }\n 106Ôćĺ    lines.push('');\n 107Ôćĺ  }\n 108Ôćĺ\n 109Ôćĺ  return lines.join('\\n').trim();\n 110Ôćĺ}\n 111Ôćĺ\n 112Ôćĺ/**\n 113Ôćĺ * Generate quick reference for all commands.\n 114Ôćĺ * @returns {string} Quick reference text\n 115Ôćĺ */\n 116Ôćĺexport function generateQuickReference() {\n 117Ôćĺ  const commands = getAllCommands();\n 118Ôćĺ\n 119Ôćĺ  if (commands.length === 0) {\n 120Ôćĺ    return 'ŠÜéŠŚáňĆ»šöĘňĹŻń╗ĄŃÇé';\n 121Ôćĺ  }\n 122Ôćĺ\n 123Ôćĺ  const lines = commands.map((entry) => {\n 124Ôćĺ    const { meta } = entry;\n 125Ôćĺ    const aliases = meta.aliases?.length ? ` /${meta.aliases.join(' /')}` : '';\n 126Ôćĺ    return `/${meta.name}${aliases} - ${meta.description}`;\n 127Ôćĺ  });\n 128Ôćĺ\n 129Ôćĺ  return lines.join('\\n');\n 130Ôćĺ}\n 131Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:29:07.663Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
