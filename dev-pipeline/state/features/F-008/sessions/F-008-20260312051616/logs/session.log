{"type":"user","uuid":"c351852b-8794-4977-933c-196b8f26b46a","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cded140b363a793d3002d3d3a015d","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * Status Command Handler\n   3Ôćĺ * Handles /status command to show aggregated pipeline status.\n   4Ôćĺ *\n   5Ôćĺ * F-005: Pipeline Status Aggregation and Log Streaming - US-1: Aggregated Status Query\n   6Ôćĺ * F-008: T-120 - Added last commit display\n   7Ôćĺ */\n   8Ôćĺ\n   9Ôćĺimport { createStatusAggregator } from '../../../services/status-aggregator.js';\n  10Ôćĺimport { createGitService } from '../../../services/git-service.js';\n  11Ôćĺimport { sessionStore } from '../../../services/session-store.js';\n  12Ôćĺ\n  13Ôćĺ/**\n  14Ôćĺ * Status command metadata.\n  15Ôćĺ */\n  16Ôćĺexport const statusMeta = {\n  17Ôćĺ  name: 'status',\n  18Ôćĺ  aliases: ['s'],\n  19Ôćĺ  description: 'Ščąšťőš«íÚüôšŐÂŠÇü',\n  20Ôćĺ  usage: '/status [--type=feature|bugfix]',\n  21Ôćĺ  examples: ['/status', '/status --type=bugfix', '/status -t feature'],\n  22Ôćĺ  params: [\n  23Ôćĺ    {\n  24Ôćĺ      name: 'type',\n  25Ôćĺ      type: 'string',\n  26Ôćĺ      required: false,\n  27Ôćĺ      description: 'Pipeline š▒╗ň×ő (feature Šłľ bugfix)',\n  28Ôćĺ      default: 'feature',\n  29Ôćĺ      aliases: ['t']\n  30Ôćĺ    }\n  31Ôćĺ  ],\n  32Ôćĺ  requiresAuth: true,\n  33Ôćĺ  minRole: 'viewer',\n  34Ôćĺ  helpText: '/status [--type=feature|bugfix] - Ščąšťőš«íÚüôšŐÂŠÇü'\n  35Ôćĺ};\n  36Ôćĺ\n  37Ôćĺ/**\n  38Ôćĺ * Handle status command.\n  39Ôćĺ * @param {Object} handlerCtx - Handler context\n  40Ôćĺ */\n  41Ôćĺexport async function handleStatus(handlerCtx) {\n  42Ôćĺ  const { reply, params, ctx, userId } = handlerCtx;\n  43Ôćĺ  const pipelineType = params.type || params.t || 'feature';\n  44Ôćĺ\n  45Ôćĺ  // Validate pipeline type\n  46Ôćĺ  if (pipelineType !== 'feature' && pipelineType !== 'bugfix') {\n  47Ôćĺ    await reply(`ÔŁî ŠŚáŠĽłšÜä pipeline š▒╗ň×ő: ${pipelineType}ŃÇéŔ»ĚńŻ┐šöĘ 'feature' Šłľ 'bugfix'ŃÇé`);\n  48Ôćĺ    return;\n  49Ôćĺ  }\n  50Ôćĺ\n  51Ôćĺ  try {\n  52Ôćĺ    const aggregator = createStatusAggregator();\n  53Ôćĺ    const status = await aggregator.aggregateStatus(pipelineType);\n  54Ôćĺ    let formatted = aggregator.formatStatusForTelegram(status);\n  55Ôćĺ\n  56Ôćĺ    // T-120: Add last commit info\n  57Ôćĺ    const gitService = createGitService();\n  58Ôćĺ    const lastCommit = await gitService.getLastCommit();\n  59Ôćĺ\n  60Ôćĺ    if (lastCommit) {\n  61Ôćĺ      formatted += '\\n\\n­čôŽ **ŠťÇŔ┐ĹŠĆÉń║Ą**';\n  62Ôćĺ      formatted += `\\n\\`${lastCommit.shortHash}\\` ${lastCommit.message.split('\\n')[0]}`;\n  63Ôćĺ      formatted += `\\n­čĹĄ ${lastCommit.author} | ­čôů ${formatDate(lastCommit.date)}`;\n  64Ôćĺ    }\n  65Ôćĺ\n  66Ôćĺ    // Also show session last commit if available\n  67Ôćĺ    const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n  68Ôćĺ    const sessionLastCommit = sessionStore.getLastCommit(sessionId);\n  69Ôćĺ\n  70Ôćĺ    if (sessionLastCommit) {\n  71Ôćĺ      formatted += '\\n\\n­čôŁ **ń╝ÜŔ»ŁŠťÇŔ┐ĹŠĆÉń║Ą**';\n  72Ôćĺ      formatted += `\\n\\`${sessionLastCommit.shortHash}\\` ${sessionLastCommit.message?.split('\\n')[0] || '(ŠŚáŠÂłŠü»)'}`;\n  73Ôćĺ      if (sessionLastCommit.featureId) {\n  74Ôćĺ        formatted += `\\n­čĆĚ´ŞĆ Feature: ${sessionLastCommit.featureId}`;\n  75Ôćĺ      }\n  76Ôćĺ    }\n  77Ôćĺ\n  78Ôćĺ    await reply(formatted);\n  79Ôćĺ  } catch (error) {\n  80Ôćĺ    await reply(`ÔŁî ŠčąŔ»óňĄ▒Ŕ┤ą: ${error.message}`);\n  81Ôćĺ  }\n  82Ôćĺ}\n  83Ôćĺ\n  84Ôćĺ/**\n  85Ôćĺ * Format date for display.\n  86Ôćĺ * @param {string} dateStr - ISO date string\n  87Ôćĺ * @returns {string} Formatted date\n  88Ôćĺ */\n  89Ôćĺfunction formatDate(dateStr) {\n  90Ôćĺ  if (!dateStr) return 'Šť¬ščą';\n  91Ôćĺ  const date = new Date(dateStr);\n  92Ôćĺ  return date.toLocaleDateString('zh-CN', {\n  93Ôćĺ    month: 'short',\n  94Ôćĺ    day: 'numeric',\n  95Ôćĺ    hour: '2-digit',\n  96Ôćĺ    minute: '2-digit'\n  97Ôćĺ  });\n  98Ôćĺ}\n  99Ôćĺ\n 100Ôćĺexport default handleStatus;\n 101Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_6dd6624e56464f3aa14c1444","__timestamp":"2026-03-11T21:33:02.474Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
