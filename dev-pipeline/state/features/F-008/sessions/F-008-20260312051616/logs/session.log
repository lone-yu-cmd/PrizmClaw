ns = {}) => {\n  56Ôćĺ      replies.push({ text, options, timestamp: Date.now() });\n  57Ôćĺ      return { message_id: replies.length };\n  58Ôćĺ    },\n  59Ôćĺ    replyWithDocument: async (document, options = {}) => {\n  60Ôćĺ      documents.push({ document, options, timestamp: Date.now() });\n  61Ôćĺ      return { message_id: documents.length };\n  62Ôćĺ    },\n  63Ôćĺ    deleteMessage: async () => true,\n  64Ôćĺ    editMessageText: async (text, options = {}) => {\n  65Ôćĺ      replies.push({ text, options, edited: true, timestamp: Date.now() });\n  66Ôćĺ      return true;\n  67Ôćĺ    }\n  68Ôćĺ  };\n  69Ôćĺ\n  70Ôćĺ  const context = {\n  71Ôćĺ    ...defaultContext,\n  72Ôćĺ    ...overrides,\n  73Ôćĺ    message: {\n  74Ôćĺ      ...defaultContext.message,\n  75Ôćĺ      ...(overrides.message || {}),\n  76Ôćĺ      from: {\n  77Ôćĺ        ...defaultContext.message.from,\n  78Ôćĺ        ...(overrides.message?.from || {})\n  79Ôćĺ      },\n  80Ôćĺ      chat: {\n  81Ôćĺ        ...defaultContext.message.chat,\n  82Ôćĺ        ...(overrides.message?.chat || {})\n  83Ôćĺ      }\n  84Ôćĺ    },\n  85Ôćĺ    chat: {\n  86Ôćĺ      ...defaultContext.chat,\n  87Ôćĺ      ...(overrides.chat || {})\n  88Ôćĺ    },\n  89Ôćĺ    from: {\n  90Ôćĺ      ...defaultContext.from,\n  91Ôćĺ      ...(overrides.from || {})\n  92Ôćĺ    },\n  93Ôćĺ    state: overrides.state || {}\n  94Ôćĺ  };\n  95Ôćĺ\n  96Ôćĺ  // Attach helper methods\n  97Ôćĺ  context._getReplies = () => [...replies];\n  98Ôćĺ  context._getLastReply = () => replies[replies.length - 1] || null;\n  99Ôćĺ  context._getDocuments = () => [...documents];\n 100Ôćĺ  context._getLastDocument = () => documents[documents.length - 1] || null;\n 101Ôćĺ  context._clearReplies = () => {\n 102Ôćĺ    replies.length = 0;\n 103Ôćĺ    documents.length = 0;\n 104Ôćĺ  };\n 105Ôćĺ\n 106Ôćĺ  return context;\n 107Ôćĺ}\n 108Ôćĺ\n 109Ôćĺ/**\n 110Ôćĺ * Create a mock context with admin user\n 111Ôćĺ * @param {Object} overrides - Override properties\n 112Ôćĺ * @returns {MockContext}\n 113Ôćĺ */\n 114Ôćĺexport function createAdminContext(overrides = {}) {\n 115Ôćĺ  return createMockContext({\n 116Ôćĺ    from: {\n 117Ôćĺ      id: 999999999,\n 118Ôćĺ      username: 'admin_user',\n 119Ôćĺ      first_name: 'Admin'\n 120Ôćĺ    },\n 121Ôćĺ    message: {\n 122Ôćĺ      from: {\n 123Ôćĺ        id: 999999999,\n 124Ôćĺ        username: 'admin_user',\n 125Ôćĺ        first_name: 'Admin'\n 126Ôćĺ      }\n 127Ôćĺ    },\n 128Ôćĺ    state: {\n 129Ôćĺ      permission: 'admin'\n 130Ôćĺ    },\n 131Ôćĺ    ...overrides\n 132Ôćĺ  });\n 133Ôćĺ}\n 134Ôćĺ\n 135Ôćĺ/**\n 136Ôćĺ * Create a mock context with operator user\n 137Ôćĺ * @param {Object} overrides - Override properties\n 138Ôćĺ * @returns {MockContext}\n 139Ôćĺ */\n 140Ôćĺexport function createOperatorContext(overrides = {}) {\n 141Ôćĺ  return createMockContext({\n 142Ôćĺ    from: {\n 143Ôćĺ      id: 888888888,\n 144Ôćĺ      username: 'operator_user',\n 145Ôćĺ      first_name: 'Operator'\n 146Ôćĺ    },\n 147Ôćĺ    message: {\n 148Ôćĺ      from: {\n 149Ôćĺ        id: 888888888,\n 150Ôćĺ        username: 'operator_user',\n 151Ôćĺ        first_name: 'Operator'\n 152Ôćĺ      }\n 153Ôćĺ    },\n 154Ôćĺ    state: {\n 155Ôćĺ      permission: 'operator'\n 156Ôćĺ    },\n 157Ôćĺ    ...overrides\n 158Ôćĺ  });\n 159Ôćĺ}\n 160Ôćĺ\n 161Ôćĺ/**\n 162Ôćĺ * Create a mock context with viewer user\n 163Ôćĺ * @param {Object} overrides - Override properties\n 164Ôćĺ * @returns {MockContext}\n 165Ôćĺ */\n 166Ôćĺexport function createViewerContext(overrides = {}) {\n 167Ôćĺ  return createMockContext({\n 168Ôćĺ    from: {\n 169Ôćĺ      id: 777777777,\n 170Ôćĺ      username: 'viewer_user',\n 171Ôćĺ      first_name: 'Viewer'\n 172Ôćĺ    },\n 173Ôćĺ    message: {\n 174Ôćĺ      from: {\n 175Ôćĺ        id: 777777777,\n 176Ôćĺ        username: 'viewer_user',\n 177Ôćĺ        first_name: 'Viewer'\n 178Ôćĺ      }\n 179Ôćĺ    },\n 180Ôćĺ    state: {\n 181Ôćĺ      permission: 'viewer'\n 182Ôćĺ    },\n 183Ôćĺ    ...overrides\n 184Ôćĺ  });\n 185Ôćĺ}\n 186Ôćĺ\n 187Ôćĺ/**\n 188Ôćĺ * Create a mock context with document upload\n 189Ôćĺ * @param {Object} documentInfo - Document information\n 190Ôćĺ * @param {Object} overrides - Override properties\n 191Ôćĺ * @returns {MockContext}\n 192Ôćĺ */\n 193Ôćĺexport function createDocumentContext(documentInfo = {}, overrides = {}) {\n 194Ôćĺ  const defaultDocument = {\n 195Ôćĺ    file_id: 'test-file-id-123',\n 196Ôćĺ    file_unique_id: 'test-unique-id-123',\n 197Ôćĺ    file_name: 'test-plan.json',\n 198Ôćĺ    mime_type: 'application/json',\n 199Ôćĺ    file_size: 1024\n 200Ôćĺ  };\n 201Ôćĺ\n 202Ôćĺ  return createMockContext({\n 203Ôćĺ    message: {\n 204Ôćĺ      document: {\n 205Ôćĺ        ...defaultDocument,\n 206Ôćĺ        ...documentInfo\n 207Ôćĺ      },\n 208Ôćĺ      caption: overrides.caption || '',\n 209Ôćĺ      from: overrides.message?.from || {\n 210Ôćĺ        id: 123456789,\n 211Ôćĺ        username: 'testuser',\n 212Ôćĺ        first_name: 'Test'\n 213Ôćĺ      }\n 214Ôćĺ    },\n 215Ôćĺ    ...overrides\n 216Ôćĺ  });\n 217Ôćĺ}\n 218Ôćĺ\n 219Ôćĺ/**\n 220Ôćĺ * Create a mock context with command text\n 221Ôćĺ * @param {string} commandText - The command text (e.g., \"/pipeline run --type=feature\")\n 222Ôćĺ * @param {Object} overrides - Override properties\n 223Ôćĺ * @returns {MockContext}\n 224Ôćĺ */\n 225Ôćĺexport function createCommandContext(commandText, overrides = {}) {\n 226Ôćĺ  return createMockContext({\n 227Ôćĺ    message: {\n 228Ôćĺ      text: commandText,\n 229Ôćĺ      ...overrides.message\n 230Ôćĺ    },\n 231Ôćĺ    ...overrides\n 232Ôćĺ  });\n 233Ôćĺ}\n 234Ôćĺ\n 235Ôćĺexport default {\n 236Ôćĺ  createMockContext,\n 237Ôćĺ  createAdminContext,\n 238Ôćĺ  createOperatorContext,\n 239Ôćĺ  createViewerContext,\n 240Ôćĺ  createDocumentContext,\n 241Ôćĺ  createCommandContext\n 242Ôćĺ};\n 243Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_6dd6624e56464f3aa14c1444","__timestamp":"2026-03-11T21:32:30.216Z","_requestId":"b07a63a169