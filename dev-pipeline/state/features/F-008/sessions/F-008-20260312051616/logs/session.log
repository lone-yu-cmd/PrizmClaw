ess, true);\n      assert.strictEqual(result.hash, 'amended123');\n    });\n\n    it('should return error when amend fails', async () => {\n      mockGit.commit = async () => {\n        throw new Error('Cannot amend');\n      };\n      gitService = createGitService({ git: mockGit });\n\n      const result = await gitService.amendCommit('amended message');\n\n      assert.strictEqual(result.success, false);\n      assert.ok(result.error);\n    });\n  });"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":84106,"output_tokens":612,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:24:35.013Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
