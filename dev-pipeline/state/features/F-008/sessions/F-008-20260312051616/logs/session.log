{"type":"user","uuid":"8164a18c-b843-4811-a451-a90d07d308c3","session_id":"b2229cc3-f35d-4fe4-8e7e-67c19086b8f2","message":{"content":[{"type":"tool_result","tool_use_id":"019cdeca0d09c7d79727809b114d1b20","content":[{"type":"text","text":"   1Ôćĺ/**\n   2Ôćĺ * CommitService Module\n   3Ôćĺ * F-008: Commit Workflow Integration\n   4Ôćĺ *\n   5Ôćĺ * Orchestrates commit workflow: validation Ôćĺ execution Ôćĺ recording.\n   6Ôćĺ * Coordinates GitService, StatusAggregator, and SessionStore.\n   7Ôćĺ *\n   8Ôćĺ * Design Decisions:\n   9Ôćĺ * - D2: Pre-commit validation includes pipeline and test status checks\n  10Ôćĺ * - D3: Commit records stored in session state file\n  11Ôćĺ * - AC-5.3: All commit operations are logged to audit log\n  12Ôćĺ */\n  13Ôćĺ\n  14Ôćĺimport fs from 'node:fs';\n  15Ôćĺimport path from 'node:path';\n  16Ôćĺ\n  17Ôćĺimport { createGitService } from './git-service.js';\n  18Ôćĺimport { createStatusAggregator } from './status-aggregator.js';\n  19Ôćĺimport { logAuditEntry } from './audit-log-service.js';\n  20Ôćĺ\n  21Ôćĺ/**\n  22Ôćĺ * Validation error codes with messages and suggestions\n  23Ôćĺ */\n  24Ôćĺexport const VALIDATION_ERRORS = {\n  25Ôćĺ  PIPELINE_RUNNING: {\n  26Ôćĺ    code: 'PIPELINE_RUNNING',\n  27Ôćĺ    message: 'Pipeline ŠşúňťĘŔ┐ÉŔíîńŞş',\n  28Ôćĺ    suggestion: 'Ŕ»Ěšşëňżů pipeline ň«îŠłÉŠłľńŻ┐šöĘ /stop ňüťŠşó'\n  29Ôćĺ  },\n  30Ôćĺ  TEST_FAILED: {\n  31Ôćĺ    code: 'TEST_FAILED',\n  32Ôćĺ    message: 'ŠÁőŔ»ĽŠť¬ÚÇÜŔ┐ç',\n  33Ôćĺ    suggestion: 'Ŕ»ĚŠúÇŠčąŠÁőŔ»Ľš╗ôŠ×ťŠłľńŻ┐šöĘ --force ŔĚ│Ŕ┐ç´╝łń╗ů admin´╝ë'\n  34Ôćĺ  },\n  35Ôćĺ  NOTHING_TO_COMMIT: {\n  36Ôćĺ    code: 'NOTHING_TO_COMMIT',\n  37Ôćĺ    message: 'Š▓íŠťëňżůŠĆÉń║ĄšÜäňĆśŠŤ┤',\n  38Ôćĺ    suggestion: 'Ŕ»ĚňůłŔ┐ŤŔíîń╗úšáüń┐«Šö╣'\n  39Ôćĺ  },\n  40Ôćĺ  MERGE_CONFLICT: {\n  41Ôćĺ    code: 'MERGE_CONFLICT',\n  42Ôćĺ    message: 'ňşśňťĘňÉłň╣Âňć▓š¬ü',\n  43Ôćĺ    suggestion: 'Ŕ»ĚňůłŔžúňć│ń╗ąńŞőňć▓š¬üŠľçń╗Â'\n  44Ôćĺ  }\n  45Ôćĺ};\n  46Ôćĺ\n  47Ôćĺ/**\n  48Ôćĺ * Default test status path\n  49Ôćĺ */\n  50Ôćĺconst DEFAULT_TEST_STATUS_PATH = 'dev-pipeline/state/test-status.json';\n  51Ôćĺ\n  52Ôćĺ/**\n  53Ôćĺ * Get error suggestion by error code (standalone function)\n  54Ôćĺ * @param {string} code - Error code\n  55Ôćĺ * @returns {Object} Error with suggestion\n  56Ôćĺ */\n  57Ôćĺexport function getErrorSuggestion(code) {\n  58Ôćĺ  return VALIDATION_ERRORS[code] || {\n  59Ôćĺ    code,\n  60Ôćĺ    message: 'Šť¬ščąÚöÖŔ»»',\n  61Ôćĺ    suggestion: 'Ŕ»ĚŠúÇŠčąÚöÖŔ»»ŠŚąň┐Ś'\n  62Ôćĺ  };\n  63Ôćĺ}\n  64Ôćĺ\n  65Ôćĺ/**\n  66Ôćĺ * Create a CommitService instance\n  67Ôćĺ * @param {Object} options - Configuration options\n  68Ôćĺ * @param {Object} [options.gitService] - GitService instance\n  69Ôćĺ * @param {Object} [options.statusAggregator] - StatusAggregator instance\n  70Ôćĺ * @param {Object} [options.sessionStore] - SessionStore instance\n  71Ôćĺ * @param {string} [options.testStatusPath] - Path to test status file\n  72Ôćĺ * @param {string} [options.projectRoot] - Project root directory\n  73Ôćĺ * @returns {Object} CommitService interface\n  74Ôćĺ */\n  75Ôćĺexport function createCommitService(options = {}) {\n  76Ôćĺ  const gitService = options.gitService || createGitService({ baseDir: options.projectRoot });\n  77Ôćĺ  const statusAggregator = options.statusAggregator || createStatusAggregator();\n  78Ôćĺ  const sessionStore = options.sessionStore;\n  79Ôćĺ  const testStatusPath = options.testStatusPath || DEFAULT_TEST_STATUS_PATH;\n  80Ôćĺ\n  81Ôćĺ  /**\n  82Ôćĺ   * Read test status from file\n  83Ôćĺ   * @returns {Object|null} Test status or null if file doesn't exist\n  84Ôćĺ   */\n  85Ôćĺ  function readTestStatus() {\n  86Ôćĺ    try {\n  87Ôćĺ      const fullPath = path.resolve(testStatusPath);\n  88Ôćĺ      if (!fs.existsSync(fullPath)) {\n  89Ôćĺ        return null;\n  90Ôćĺ      }\n  91Ôćĺ      const content = fs.readFileSync(fullPath, 'utf8');\n  92Ôćĺ      return JSON.parse(content);\n  93Ôćĺ    } catch {\n  94Ôćĺ      return null;\n  95Ôćĺ    }\n  96Ôćĺ  }\n  97Ôćĺ\n  98Ôćĺ  /**\n  99Ôćĺ   * Check pipeline status helper\n 100Ôćĺ   * @returns {Promise<{isRunning: boolean, phase: string}>}\n 101Ôćĺ   */\n 102Ôćĺ  async function checkPipelineStatus() {\n 103Ôćĺ    try {\n 104Ôćĺ      const featureStatus = await statusAggregator.aggregateStatus('feature');\n 105Ôćĺ      const bugfixStatus = await statusAggregator.aggregateStatus('bugfix');\n 106Ôćĺ\n 107Ôćĺ      const isRunning = featureStatus.stage === 'running' || bugfixStatus.stage === 'running';\n 108Ôćĺ      const phase = featureStatus.stage === 'running' ? featureStatus.stage :\n 109Ôćĺ                    bugfixStatus.stage === 'running' ? bugfixStatus.stage : 'idle';\n 110Ôćĺ\n 111Ôćĺ      return { isRunning, phase };\n 112Ôćĺ    } catch {\n 113Ôćĺ      return { isRunning: false, phase: 'unknown' };\n 114Ôćĺ    }\n 115Ôćĺ  }\n 116Ôćĺ\n 117Ôćĺ  /**\n 118Ôćĺ   * Check test status helper\n 119Ôćĺ   * @returns {{passed: boolean, failed: number, total: number}}\n 120Ôćĺ   */\n 121Ôćĺ  function checkTestStatus() {\n 122Ôćĺ    const status = readTestStatus();\n 123Ôćĺ\n 124Ôćĺ    if (!status) {\n 125Ôćĺ      return { passed: true, failed: 0, total: 0 };\n 126Ôćĺ    }\n 127Ôćĺ\n 128Ôćĺ    return {\n 129Ôćĺ      passed: status.failed === 0,\n 130Ôćĺ      failed: status.failed || 0,\n 131Ôćĺ      total: (status.passed || 0) + (status.failed || 0) + (status.skipped || 0)\n 132Ôćĺ    };\n 133Ôćĺ  }\n 134Ôćĺ\n 135Ôćĺ  /**\n 136Ôćĺ   * Validate pre-commit conditions\n 137Ôćĺ   * @param {Object} validationOptions - Validation options\n 138Ôćĺ   * @param {boolean} [validationOptions.skipPipelineCheck] - Skip pipeline status check\n 139Ôćĺ   * @param {boolean} [validationOptions.skipTestCheck] - Skip test status check\n 140Ôćĺ   * @returns {Promise<ValidationResult>}\n 141Ôćĺ   */\n 142Ôćĺ  async function validatePreConditions(validationOptions = {}) {\n 143Ôćĺ    const errors = [];\n 144Ôćĺ    const warnings = [];\n 145Ôćĺ\n 146Ôćĺ    // 1. Check pipeline status\n 147Ôćĺ    if (!validationOptions.skipPipelineCheck) {\n 148Ôćĺ      const pipelineCheck = await checkPipelineStatus();\n 149Ôćĺ      if (pipelineCheck.isRunning) {\n 150Ôćĺ        errors.push({\n 151Ôćĺ          ...VALIDATION_ERRORS.PIPELINE_RUNNING,\n 152Ôćĺ          phase: pipelineCheck.phase\n 153Ôćĺ        });\n 154Ôćĺ      }\n 155Ôćĺ    }\n 156Ôćĺ\n 157Ôćĺ    // 2. Check test status\n 158Ôćĺ    if (!validationOptions.skipTestCheck) {\n 159Ôćĺ      const testCheck = checkTestStatus();\n 160Ôćĺ      if (!testCheck.passed && testCheck.total > 0) {\n 161Ôćĺ        errors.push({\n 162Ôćĺ          ...VALIDATION_ERRORS.TEST_FAILED,\n 163Ôćĺ          failed: testCheck.failed,\n 164Ôćĺ          total: testCheck.total\n 165Ôćĺ        });\n 166Ôćĺ      }\n 167Ôćĺ    }\n 168Ôćĺ\n 169Ôćĺ    // 3. Check git status\n 170Ôćĺ    const gitStatus = await gitService.getStatus();\n 171Ôćĺ\n 172Ôćĺ    if (gitStatus.clean) {\n 173Ôćĺ      errors.push(VALIDATION_ERRORS.NOTHING_TO_COMMIT);\n 174Ôćĺ    }\n 175Ôćĺ\n 176Ôćĺ    if (gitStatus.conflicts.length > 0) {\n 177Ôćĺ      errors.push({\n 178Ôćĺ        ...VALIDATION_ERRORS.MERGE_CONFLICT,\n 179Ôćĺ        files: gitStatus.conflicts\n 180Ôćĺ      });\n 181Ôćĺ    }\n 182Ôćĺ\n 183Ôćĺ    return {\n 184Ôćĺ      valid: errors.length === 0,\n 185Ôćĺ      errors,\n 186Ôćĺ      warnings,\n 187Ôćĺ      gitStatus\n 188Ôćĺ    };\n 189Ôćĺ  }\n 190Ôćĺ\n 191Ôćĺ  /**\n 192Ôćĺ   * Build commit message with footer\n 193Ôćĺ   * @param {string} userMessage - User-provided commit message\n 194Ôćĺ   * @param {Object} context - Commit context\n 195Ôćĺ   * @param {string} [context.featureId] - Feature ID\n 196Ôćĺ   * @param {string} [context.bugfixId] - Bugfix ID\n 197Ôćĺ   * @returns {string} Full commit message\n 198Ôćĺ   */\n 199Ôćĺ  function buildCommitMessage(userMessage, context = {}) {\n 200Ôćĺ    const lines = [userMessage];\n 201Ôćĺ\n 202Ôćĺ    if (context.featureId) {\n 203Ôćĺ      lines.push('');\n 204Ôćĺ      lines.push(`Feature: ${context.featureId}`);\n 205Ôćĺ    }\n 206Ôćĺ\n 207Ôćĺ    if (context.bugfixId) {\n 208Ôćĺ      lines.push('');\n 209Ôćĺ      lines.push(`Bugfix: ${context.bugfixId}`);\n 210Ôćĺ    }\n 211Ôćĺ\n 212Ôćĺ    return lines.join('\\n');\n 213Ôćĺ  }\n 214Ôćĺ\n 215Ôćĺ  /**\n 216Ôćĺ   * Record commit to session store\n 217Ôćĺ   * @param {string} sessionId - Session ID\n 218Ôćĺ   * @param {Object} commitInfo - Commit information\n 219Ôćĺ   */\n 220Ôćĺ  async function recordCommit(sessionId, commitInfo) {\n 221Ôćĺ    if (!sessionStore) {\n 222Ôćĺ      return;\n 223Ôćĺ    }\n 224Ôćĺ\n 225Ôćĺ    const record = {\n 226Ôćĺ      hash: commitInfo.hash,\n 227Ôćĺ      shortHash: commitInfo.shortHash,\n 228Ôćĺ      message: commitInfo.message,\n 229Ôćĺ      timestamp: Date.now(),\n 230Ôćĺ      author: commitInfo.author || 'unknown',\n 231Ôćĺ      featureId: commitInfo.featureId || null,\n 232Ôćĺ      bugfixId: commitInfo.bugfixId || null,\n 233Ôćĺ      filesChanged: commitInfo.filesChanged || 0\n 234Ôćĺ    };\n 235Ôćĺ\n 236Ôćĺ    if (typeof sessionStore.addCommit === 'function') {\n 237Ôćĺ      sessionStore.addCommit(sessionId, record);\n 238Ôćĺ    }\n 239Ôćĺ  }\n 240Ôćĺ\n 241Ôćĺ  /**\n 242Ôćĺ   * Get commits for a session\n 243Ôćĺ   * @param {string} sessionId - Session ID\n 244Ôćĺ   * @returns {Promise<CommitRecord[]>}\n 245Ôćĺ   */\n 246Ôćĺ  async function getSessionCommits(sessionId) {\n 247Ôćĺ    if (!sessionStore) {\n 248Ôćĺ      return [];\n 249Ôćĺ    }\n 250Ôćĺ\n 251Ôćĺ    if (typeof sessionStore.getCommits === 'function') {\n 252Ôćĺ      return sessionStore.getCommits(sessionId);\n 253Ôćĺ    }\n 254Ôćĺ\n 255Ôćĺ    return [];\n 256Ôćĺ  }\n 257Ôćĺ\n 258Ôćĺ  /**\n 259Ôćĺ   * Main commit function\n 260Ôćĺ   * @param {Object} params - Commit parameters\n 261Ôćĺ   * @param {string} params.sessionId - Session ID\n 262Ôćĺ   * @param {string} params.userId - User ID\n 263Ôćĺ   * @param {string} [params.message] - Commit message\n 264Ôćĺ   * @param {boolean} [params.amend] - Whether to amend last commit\n 265Ôćĺ   * @param {boolean} [params.force] - Skip validation\n 266Ôćĺ   * @param {string} [params.featureId] - Feature ID\n 267Ôćĺ   * @param {string} [params.bugfixId] - Bugfix ID\n 268Ôćĺ   * @param {string} [params.userRole] - User role for audit log\n 269Ôćĺ   * @returns {Promise<CommitResult>}\n 270Ôćĺ   */\n 271Ôćĺ  async function commit(params) {\n 272Ôćĺ    const {\n 273Ôćĺ      sessionId,\n 274Ôćĺ      userId,\n 275Ôćĺ      message = 'chore: commit',\n 276Ôćĺ      amend = false,\n 277Ôćĺ      force = false,\n 278Ôćĺ      featureId,\n 279Ôćĺ      bugfixId,\n 280Ôćĺ      userRole = 'operator'\n 281Ôćĺ    } = params;\n 282Ôćĺ\n 283Ôćĺ    // Validate pre-conditions (unless force is true)\n 284Ôćĺ    if (!force) {\n 285Ôćĺ      const validation = await validatePreConditions({});\n 286Ôćĺ\n 287Ôćĺ      if (!validation.valid) {\n 288Ôćĺ        // Log failed commit attempt (AC-5.3)\n 289Ôćĺ        await logAuditEntry({\n 290Ôćĺ          userId,\n 291Ôćĺ          role: userRole,\n 292Ôćĺ          action: amend ? 'commit:amend' : 'commit',\n 293Ôćĺ          params: { message, featureId, bugfixId, force },\n 294Ôćĺ          result: 'denied',\n 295Ôćĺ          reason: validation.errors.map(e => e.code).join(', '),\n 296Ôćĺ          sessionId\n 297Ôćĺ        });\n 298Ôćĺ\n 299Ôćĺ        return {\n 300Ôćĺ          success: false,\n 301Ôćĺ          errors: validation.errors,\n 302Ôćĺ          gitStatus: validation.gitStatus\n 303Ôćĺ        };\n 304Ôćĺ      }\n 305Ôćĺ    }\n 306Ôćĺ\n 307Ôćĺ    // Build full commit message\n 308Ôćĺ    const fullMessage = buildCommitMessage(message, { featureId, bugfixId });\n 309Ôćĺ\n 310Ôćĺ    // Execute commit\n 311Ôćĺ    let result;\n 312Ôćĺ    if (amend) {\n 313Ôćĺ      result = await gitService.amendCommit(fullMessage);\n 314Ôćĺ    } else {\n 315Ôćĺ      result = await gitService.commit(fullMessage);\n 316Ôćĺ    }\n 317Ôćĺ\n 318Ôćĺ    // Record commit to session (if successful)\n 319Ôćĺ    if (result.success) {\n 320Ôćĺ      await recordCommit(sessionId, {\n 321Ôćĺ        hash: result.hash,\n 322Ôćĺ        shortHash: result.shortHash,\n 323Ôćĺ        message: fullMessage,\n 324Ôćĺ        author: userId,\n 325Ôćĺ        featureId,\n 326Ôćĺ        bugfixId,\n 327Ôćĺ        filesChanged: result.filesChanged\n 328Ôćĺ      });\n 329Ôćĺ\n 330Ôćĺ      // Log successful commit (AC-5.3)\n 331Ôćĺ      await logAuditEntry({\n 332Ôćĺ        userId,\n 333Ôćĺ        role: userRole,\n 334Ôćĺ        action: amend ? 'commit:amend' : 'commit',\n 335Ôćĺ        params: { message: fullMessage, featureId, bugfixId, force },\n 336Ôćĺ        result: 'success',\n 337Ôćĺ        sessionId\n 338Ôćĺ      });\n 339Ôćĺ    } else {\n 340Ôćĺ      // Log failed commit (AC-5.3)\n 341Ôćĺ      await logAuditEntry({\n 342Ôćĺ        userId,\n 343Ôćĺ        role: userRole,\n 344Ôćĺ        action: amend ? 'commit:amend' : 'commit',\n 345Ôćĺ        params: { message: fullMessage, featureId, bugfixId, force },\n 346Ôćĺ        result: 'failed',\n 347Ôćĺ        reason: result.error,\n 348Ôćĺ        sessionId\n 349Ôćĺ      });\n 350Ôćĺ    }\n 351Ôćĺ\n 352Ôćĺ    return result;\n 353Ôćĺ  }\n 354Ôćĺ\n 355Ôćĺ  return {\n 356Ôćĺ    validatePreConditions,\n 357Ôćĺ    commit,\n 358Ôćĺ    recordCommit,\n 359Ôćĺ    getSessionCommits,\n 360Ôćĺ    checkPipelineStatus,\n 361Ôćĺ    checkTestStatus,\n 362Ôćĺ    buildCommitMessage,\n 363Ôćĺ    getErrorSuggestion\n 364Ôćĺ  };\n 365Ôćĺ}\n 366Ôćĺ\n 367Ôćĺexport default createCommitService;\n 368Ôćĺ"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_0205ff99439e49bba2f8aa57","__timestamp":"2026-03-11T21:25:09.977Z","_requestId":"b07a63a169934f4593711d9842f5a228"}
