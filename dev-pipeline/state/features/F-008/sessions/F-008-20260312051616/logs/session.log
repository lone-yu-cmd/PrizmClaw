                       Ôöé\\\\nÔöé  src/services/session-store.js                                   Ôöé\\\\nÔööÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöÇÔöś\\\\n```\\\\n\\\\n---\\\\n\\\\n## Component Design\\\\n\\\\n### C-1: GitService (`src/services/git-service.js`)\\\\n\\\\n**Purpose:** ň░üŔúůŠëÇŠťë git ŠôŹńŻť´╝îŠĆÉńżŤš╗čńŞÇ API\\\\n\\\\n**Methods:**\\\\n```javascript\\\\ninterface GitService {\\\\n  // šŐÂŠÇüŠúÇŠčą\\\\n  getStatus(): Promise<GitStatus>\\\\n  isClean(): Promise<boolean>\\\\n  getChangedFiles(): Promise<string[]>\\\\n  \\\\n  // ŠĆÉń║ĄŠôŹńŻť\\\\n  commit(message: string, options?: CommitOptions): Promise<CommitResult>\\\\n  amendCommit(message: string): Promise<CommitResult>\\\\n  getLastCommit(): Promise<CommitInfo>\\\\n  \\\\n  // ń┐íŠü»ŔÄĚňĆľ\\\\n  getCommitLog(count?: number): Promise<CommitInfo[]>\\\\n  getShortHash(hash: string): string\\\\n}\\\\n\\\\ninterface GitStatus {\\\\n  clean: boolean\\\\n  staged: string[]\\\\n  modified: string[]\\\\n  untracked: string[]\\\\n  conflicts: string[]\\\\n  ahead: number\\\\n  behind: number\\\\n  currentBranch: string\\\\n}\\\\n\\\\ninterface CommitResult {\\\\n  success: boolean\\\\n  hash?: string\\\\n  shortHash?: string\\\\n  message?: string\\\\n  filesChanged?: number\\\\n  error?: string\\\\n  suggestion?: string\\\\n}\\\\n\\\\ninterface CommitOptions {\\\\n  amend?: boolean\\\\n  allowEmpty?: boolean\\\\n}\\\\n```\\\\n\\\\n### C-2: CommitService (`src/services/commit-service.js`)\\\\n\\\\n**Purpose:** ŠĆÉń║ĄńŞÜňŐíÚÇ╗ŔżĹš╝ľŠÄĺ´╝îňŹĆŔ░âŠáíÚ¬îŃÇüŠëžŔíîŃÇüŔ«░ňŻĽ\\\\n\\\\n**Methods:**\\\\n```javascript\\\\ninterface CommitService {\\\\n  // ńŞ╗ňůąňĆú\\\\n  commit(params: CommitParams): Promise<CommitResult>\\\\n  \\\\n  // ŠáíÚ¬î\\\\n  validatePreConditions(options: ValidationOptions): Promise<ValidationResult>\\\\n  \\\\n  // Ŕ«░ňŻĽ\\\\n  recordCommit(sessionId: string, commitInfo: CommitInfo): Promise<void>\\\\n  getSessionCommits(sessionId: string): Promise<CommitRecord[]>\\\\n}\\\\n\\\\ninterface CommitParams {\\\\n  sessionId: string\\\\n  userId: string\\\\n  message?: string\\\\n  amend?: boolean\\\\n  force?: boolean\\\\n  featureId?: string\\\\n  bugfixId?: string\\\\n}\\\\n\\\\ninterface ValidationOptions {\\\\n  skipPipelineCheck?: boolean\\\\n  skipTestCheck?: boolean\\\\n}\\\\n\\\\ninterface ValidationResult {\\\\n  valid: boolean\\\\n  errors: ValidationError[]\\\\n  warnings: ValidationWarning[]\\\\n}\\\\n\\\\ninterface ValidationError {\\\\n  code: string\\\\n  message: string\\\\n  suggestion: string\\\\n}\\\\n\\\\ninterface CommitRecord {\\\\n  hash: string\\\\n  shortHash: string\\\\n  message: string\\\\n  timestamp: number\\\\n  author: string\\\\n  featureId?: string\\\\n  bugfixId?: string\\\\n  filesChanged: number\\\\n}\\\\n```\\\\n\\\\n### C-3: Commit Handler (`src/bot/commands/handlers/commit.js`)\\\\n\\\\n**Purpose:** Telegram ňĹŻń╗ĄňĄäšÉćňůąňĆú\\\\n\\\\n**Flow:**\\\\n1. ŔžúŠ×ÉňĹŻń╗ĄňĆéŠĽ░ (`--message`, `--amend`, `--force`)\\\\n2. ŠŁâÚÖÉŠúÇŠčą (`operator` for commit, `admin` for amend/force)\\\\n3. ÚźśÚúÄÚÖęŠôŹńŻťší«Ŕ«ĄŠÁüšĘő (amend/force)\\\\n4. Ŕ░âšöĘ CommitService.commit()\\\\n5. Šá╝ň╝ĆňîľŔ┐öňŤ×š╗ôŠ×ť\\\\n6. Ŕ«░ňŻĽň«íŔ«íŠŚąň┐Ś\\\\n\\\\n### C-4: Commits Handler (`src/bot/commands/handlers/commits.js`)\\\\n\\\\n**Purpose:** Ščąšťőń╝ÜŔ»ŁŠĆÉń║ĄňÄćňĆ▓\\\\n\\\\n**Flow:**\\\\n1. ŔÄĚňĆľňŻôňëŹń╝ÜŔ»Ł ID\\\\n2. Ŕ░âšöĘ CommitService.getSessionCommits()\\\\n3. Šá╝ň╝ĆňîľňÄćňĆ▓ňłŚŔíĘŔ┐öňŤ×\\\\n\\\\n---\\\\n\\\\n## Interface Design\\\\n\\\\n### I-1: Pre-Commit Validation API\\\\n\\\\n```javascript\\\\n// src/services/commit-service.js\\\\n\\\\nconst VALIDATION_ERRORS = {\\\\n  PIPELINE_RUNNING: {\\\\n    code: 'PIPELINE_RUNNING',\\\\n    message: 'Pipeline ŠşúňťĘŔ┐ÉŔíîńŞş',\\\\n    suggestion: 'Ŕ»Ěšşëňżů pipeline ň«îŠłÉŠłľńŻ┐šöĘ /stop ňüťŠşó'\\\\n  },\\\\n  TEST_FAILED: {\\\\n    code: 'TEST_FAILED',\\\\n    message: 'ŠÁőŔ»ĽŠť¬ÚÇÜŔ┐ç',\\\\n    suggestion: 'Ŕ»ĚŠúÇŠčąŠÁőŔ»Ľš╗ôŠ×ťŠłľńŻ┐šöĘ --force ŔĚ│Ŕ┐ç´╝łń╗ů admin´╝ë'\\\\n  },\\\\n  NOTHING_TO_COMMIT: {\\\\n    code: 'NOTHING_TO_COMMIT',\\\\n    message: 'Š▓íŠťëňżůŠĆÉń║ĄšÜäňĆśŠŤ┤',\\\\n    suggestion: 'Ŕ»ĚňůłŔ┐ŤŔíîń╗úšáüń┐«Šö╣'\\\\n  },\\\\n  MERGE_CONFLICT: {\\\\n    code: 'MERGE_CONFLICT',\\\\n    message: 'ňşśňťĘňÉłň╣Âňć▓š¬ü',\\\\n    suggestion: 'Ŕ»ĚňůłŔžúňć│ń╗ąńŞőňć▓š¬üŠľçń╗Â´╝Ü{files}'\\\\n  }\\\\n};\\\\n\\\\nasync function validatePreConditions(options) {\\\\n  const errors = [];\\\\n  const warnings = [];\\\\n  \\\\n  // 1. Check pipeline status (via status-aggregator)\\\\n  const pipelineStatus = await statusAggregator.aggregateStatus();\\\\n  if (pipelineStatus.phase === 'running' && !options.skipPipelineCheck) {\\\\n    errors.push(VALIDATION_ERRORS.PIPELINE_RUNNING);\\\\n  }\\\\n  \\\\n  // 2. Check test status (from state file)\\\\n  const testStatus = await getTestStatus();\\\\n  if (testStatus.failed > 0 && !options.skipTestCheck) {\\\\n    errors.push(VALIDATION_ERRORS.TEST_FAILED);\\\\n  }\\\\n  \\\\n  // 3. Check git status\\\\n  const gitStatus = await gitService.getStatus();\\\\n  if (gitStatus.clean) {\\\\n    errors.push(VALIDATION_ERRORS.NOTHING_TO_COMMIT);\\\\n  }\\\\n  if (gitStatus.conflicts.length > 0) {\\\\n    errors.push({\\\\n      ...VALIDATION_ERRORS.MERGE_CONFLICT,\\\\n      files: gitStatus.conflicts\\\\n    });\\\\n  }\\\\n  \\\\n  return {\\\\n    valid: errors.length === 0,\\\\n    errors,\\\\n    warnings,\\\\n    gitStatus\\\\n  };\\\\n}\\\\n```\\\\n\\\\n### I-2: Commit Execution API\\\\n\\\\n```javascript\\\\n// src/services/git-service.js\\\\n\\\\nasync function commit(message, options = {}) {\\\\n  try {\\\\n    // Build commit message with footer\\\\n    const fullMessage = buildCommitMessage(message, options);\\\\n    \\\\n    // Execute git commit\\\\n    const result = await git.commit(fullMessage);\\\\n    \\\\n    if (!result.commit) {\\\\n      return {\\\\n        success: false,\\\\n        error: 'ŠĆÉń║ĄňĄ▒Ŕ┤ą',\\\\n        suggestion: 'Ŕ»ĚŠúÇŠčą git šŐÂŠÇü'\\\\n      };\\\\n    }\\\\n    \\\\n    return {\\\\n      success: true,\\\\n      hash: result.commit,\\\\n      shortHash: result.commit.substring(0, 7),\\\\n      message: fullMessage,\\\\n      filesChanged: result.summary.changes\\\\n    };\\\\n  } catch (error) {\\\\n    return {\\\\n      success: false,\\\\n      error: error.message,\\\\n      suggestion: getSuggestion(error)\\\\n    };\\\\n  }\\\\n}\\\\n```\\\\n\\\\n### I-3: Session Commit Tracking\\\\n\\\\n```javascript\\\\n// Šëęň▒Ľ src/services/session-store.js\\\\n\\\\n// Session state structure (JSON file)\\\\n{\\\\n  \\\\\\\"sessionId\\\\\\\": \\\\\\\"abc123\\\\\\\",\\\\n  \\\\\\\"featureId\\\\\\\": \\\\\\\"F-008\\\\\\\",\\\\n  \\\\\\\"createdAt\\\\\\\": 1710489600000,\\\\n  \\\\\\\"commits\\\\\\\": [\\\\n    {\\\\n      \\\\\\\"hash\\\\\\\": \\\\\\\"a1b2c3d4e5f6...\\\\\\\",\\\\n      \\\\\\\"shortHash\\\\\\\": \\\\\\\"a1b2c3d\\\\\\\",\\\\n      \\\\\\\"message\\\\\\\": \\\\\\\"feat: add commit workflow\\\\\\\",\\\\n      \\\\\\\"timestamp\\\\\\\": 1710489700000,\\\\n      \\\\\\\"author\\\\\\\": \\\\\\\"user\\\\\\\",\\\\n      \\\\\\\"filesChanged\\\\\\\": 5\\\\n    }\\\\n  ]\\\\n}\\\\n\\\\n// API\\\\nasync function addCommitToSession(sessionId, commitInfo) {\\\\n  const session = await loadSession(sessionId);\\\\n  session.commits = session.commits || [];\\\\n  session.commits.push({\\\\n    ...commitInfo,\\\\n    timestamp: Date.now()\\\\n  });\\\\n  await saveSession(session);\\\\n}\\\\n\\\\nasync function getSessionCommits(sessionId) {\\\\n  const session = await loadSession(sessionId);\\\\n  return session.commits || [];\\\\n}\\\\n```\\\\n\\\\n---\\\\n\\\\n## Data Model\\\\n\\\\n### D-1: Session State (Extended)\\\\n\\\\n```javascript\\\\n// File: data/sessions/{sessionId}.json\\\\n{\\\\n  \\\\\\\"sessionId\\\\\\\": \\\\\\\"string\\\\\\\",\\\\n  \\\\\\\"featureId\\\\\\\": \\\\\\\"string | null\\\\\\\",\\\\n  \\\\\\\"bugfixId\\\\\\\": \\\\\\\"string | null\\\\\\\",\\\\n  \\\\\\\"createdAt\\\\\\\": \\\\\\\"number (timestamp)\\\\\\\",\\\\n  \\\\\\\"updatedAt\\\\\\\": \\\\\\\"number (timestamp)\\\\\\\",\\\\n  \\\\\\\"commits\\\\\\\": [\\\\n    {\\\\n      \\\\\\\"hash\\\\\\\": \\\\\\\"string (full hash)\\\\\\\",\\\\n      \\\\\\\"shortHash\\\\\\\": \\\\\\\"string (7 chars)\\\\\\\",\\\\n      \\\\\\\"message\\\\\\\": \\\\\\\"string\\\\\\\",\\\\n      \\\\\\\"timestamp\\\\\\\": \\\\\\\"number\\\\\\\",\\\\n      \\\\\\\"author\\\\\\\": \\\\\\\"string\\\\\\\",\\\\n      \\\\\\\"filesChanged\\\\\\\": \\\\\\\"number\\\\\\\"\\\\n    }\\\\n  ]\\\\n}\\\\n```\\\\n\\\\n### D-2: Test Status (Existing)\\\\n\\\\n```javascript\\\\n// File: dev-pipeline/state/test-status.json (šö▒ F-007 ňłŤň╗║)\\\\n{\\\\n  \\\\\\\"lastRun\\\\\\\": \\\\\\\"number (timestamp)\\\\\\\",\\\\n  \\\\\\\"passed\\\\\\\": \\\\\\\"number\\\\\\\",\\\\n  \\\\\\\"failed\\\\\\\": \\\\\\\"number\\\\\\\",\\\\n  \\\\\\\"skipped\\\\\\\": \\\\\\\"number\\\\\\\",\\\\n  \\\\\\\"duration\\\\\\\": \\\\\\\"number (ms)\\\\\\\"\\\\n}\\\\n```\\\\n\\\\n---\\\\n\\\\n## Command Permission Matrix\\\\n\\\\n| Command | Min Role | Confirmation | Notes |\\\\n|---------|----------|--------------|-------|\\\\n| `/commit` | operator | No | ŠáçňçćŠĆÉń║Ą |\\\\n| `/commit --amend` | admin | Yes | ń┐«Šö╣ŠťÇŔ┐ĹŠĆÉń║Ą |\\\\n| `/commit --force` | admin | Yes | ŔĚ│Ŕ┐çŠáíÚ¬î |\\\\n| `/commits` | viewer | No | ŠčąšťőňÄćňĆ▓ |\\\\n\\\\n---\\\\n\\\\n## Testing Strategy\\\\n\\\\n### Unit Tests\\\\n\\\\n| Module | Test File | Coverage Target |\\\\n|--------|-----------|-----------------|\\\\n| GitService | tests/services/git-service.test.js | 90% |\\\\n| CommitService | tests/services/commit-service.test.js | 90% |\\\\n| commit handler | tests/bot/commands/handlers/commit.test.js | 85% |\\\\n| commits handler | tests/bot/commands/handlers/commits.test.js | 85% |\\\\n\\\\n### Integration Tests\\\\n\\\\n| Scenario | Test File | Priority |\\\\n|----------|-----------|----------|\\\\n| commit Ôćĺ success flow | tests/integration/commit-flow.test.js | High |\\\\n| commit Ôćĺ validation failure | tests/integration/commit-validation.test.js | High |\\\\n| commit Ôćĺ amend flow | tests/integration/commit-amend.test.js | Medium |\\\\n| commit Ôćĺ force flow | tests/integration/commit-force.test.js | Medium |\\\\n\\\\n### Mock Strategy\\\\n\\\\n- GitService: ńŻ┐šöĘ mock git responses´╝îńŞŹŠëžŔíîšťčň«× git ňĹŻń╗Ą\\\\n- StatusAggregator: ňĄŹšöĘ F-005 mock šşľšĽą\\\\n- SessionStore: ńŻ┐šöĘńŞ┤ŠŚÂšŤ«ňŻĽ\\\\n\\\\n---\\\\n\\\\n## File Structure\\\\n\\\\n```\\\\nsrc/\\\\nÔöťÔöÇÔöÇ services/\\\\nÔöé   ÔöťÔöÇÔöÇ git-service.js          # NEW - git ŠôŹńŻťň░üŔúů\\\\nÔöé   ÔöťÔöÇÔöÇ commit-service.js       # NEW - ŠĆÉń║ĄńŞÜňŐíÚÇ╗ŔżĹ\\\\nÔöé   ÔööÔöÇÔöÇ session-store.js        # EXTEND - ŠĚ╗ňŐá commit tracking\\\\nÔöťÔöÇÔöÇ bot/\\\\nÔöé   ÔööÔöÇÔöÇ commands/\\\\nÔöé       ÔööÔöÇÔöÇ handlers/\\\\nÔöé           ÔöťÔöÇÔöÇ commit.js       # NEW - /commit ňĹŻń╗Ą\\\\nÔöé           ÔööÔöÇÔöÇ commits.js      # NEW - /commits ňĹŻń╗Ą\\\\ntests/\\\\nÔöťÔöÇÔöÇ services/\\\\nÔöé   ÔöťÔöÇÔöÇ git-service.test.js     # NEW\\\\nÔöé   ÔööÔöÇÔöÇ commit-service.test.js  # NEW\\\\nÔöťÔöÇÔöÇ bot/\\\\nÔöé   ÔööÔöÇÔöÇ commands/\\\\nÔöé       ÔööÔöÇÔöÇ handlers/\\\\nÔöé           ÔöťÔöÇÔöÇ commit.test.js  # NEW\\\\nÔöé           ÔööÔöÇÔöÇ commits.test.js # NEW\\\\nÔööÔöÇÔöÇ integration/\\\\n    ÔöťÔöÇÔöÇ commit-flow.test.js     # NEW\\\\n    ÔööÔöÇÔöÇ commit-validation.test.js # NEW\\\\n```\\\\n\\\\n---\\\\n\\\\n## User Story Mapping\\\\n\\\\n| User Story | Components | Key Files |\\\\n|------------|------------|-----------|\\\\n| US-1: Telegram Commit Trigger | C-3, C-2 | commit.js, commit-service.js |\\\\n| US-2: Pre-Commit Validation | C-2 | commit-service.js |\\\\n| US-3: Commit Result Feedback | C-1, C-3 | git-service.js, commit.js |\\\\n| US-4: Session Commit Tracking | C-2, C-4 | commit-service.js, session-store.js, commits.js |\\\\n| US-5: High-Risk Commit Protection | Security Layer | commit.js, permission-guard.js |\\\\n\\\\n---\\\\n\\\\n## Risk Mitigation\\\\n\\\\n| Risk | Mitigation Strategy |\\\\n|------|---------------------|\\\\n| Git ŠôŹńŻťňĄ▒Ŕ┤ą | GitService Ŕ┐öňŤ×Ŕ»Žš╗ćÚöÖŔ»» + ň╗║Ŕ««ŠôŹńŻť |\\\\n| ňĚąńŻťšŤ«ňŻĽŔäĆšŐÂŠÇü | ŠĆÉń║ĄňëŹ isClean() ŠúÇŠčą |\\\\n| ŠÁőŔ»ĽšŐÂŠÇüŠľçń╗Âš╝║ňĄ▒ | ň«╣ÚöÖňĄäšÉć´╝îŔžćńŞ║\\\\\\\"Šť¬Ŕ┐ÉŔíîŠÁőŔ»Ľ\\\\\\\"ŔşŽňĹŐ |\\\\n| ń╝ÜŔ»ŁŠľçń╗ÂŠŹčňŁĆ | try-catch + šę║ŠĽ░š╗äňŤ×ÚÇÇ |\\\\n\\\\n---\\\\n\\\\n## Dependencies Check\\\\n\\\\n| Dependency | Required By | Install Command |\\\\n|------------|-------------|-----------------|\\\\n| simple-git | GitService | `npm install simple-git` |\\\\n\\\\n---\\\\n\\\\n## Decisions\\\\n\\\\n| ID | Date | Decision |\\\\n|----|------|----------|\\\\n| D1 | 2026-03-15 | ńŻ┐šöĘ simple-git ň║ôň░üŔúů git ŠôŹńŻť´╝îÚü┐ňůŹ shell Š│ĘňůąÚúÄÚÖę |\\\\n| D2 | 2026-03-15 | Pre-commit ŠáíÚ¬îňîůňÉź pipeline šŐÂŠÇüňĺîŠÁőŔ»ĽšŐÂŠÇüňĆîÚçŹŠúÇŠčą |\\\\n| D3 | 2026-03-15 | ŠĆÉń║ĄŔ«░ňŻĽňşśňéĘń║Äń╝ÜŔ»ŁšŐÂŠÇüŠľçń╗Â´╝îńŞŹŠľ░ň╗║šőČšźőňşśňéĘ |\\\\n| D4 | 2026-03-15 | ňĄŹšöĘ F-006 ší«Ŕ«ĄŠť║ňłÂňĄäšÉć amend/force ÚźśÚúÄÚÖęŠôŹńŻť |\\\\n| D5 | 2026-03-15 | GitService Ŕ«żŔ«íńŞ║ňĆ» mock´╝îńż┐ń║ÄňŹĽňůâŠÁőŔ»Ľ |\\\\n\\\"}}],\\\"model\\\":\\\"glm-5.0\\\",\\\"role\\\":\\\"assistant\\\",\\\"stop_reason\\\":\\\"tool_use\\\",\\\"stop_sequence\\\":null,\\\"type\\\":\\\"message\\\",\\\"usage\\\":{\\\"input_tokens\\\":30260,\\\"output_tokens\\\":3265,\\\"cache_creation_input_tokens\\\":null,\\\"cache_read_input_tokens\\\":null,\\\"cache_creation\\\":null,\\\"server_tool_use\\\":null,\\\"service_tier\\\":null}},\\\"parent_tool_use_id\\\":\\\"019cdebfd06760b7d02cd331bbc03246\\\",\\\"__timestamp\\\":\\\"2026-03-11T21:15:38.941Z\\\",\\\"_requestId\\\":\\\"831488a1f0e5461b9b01219ae792e61e\\\"}\",\"/Users/loneyu/SelfProjects/PrizmClaw/dev-pipeline/state/features/F-008/sessions/F-008-20260312051337/logs/session.log:52:{\\\"type\\\":\\\"assistant\\\",\\\"uuid\\\":\\\"2026031205153999fde7