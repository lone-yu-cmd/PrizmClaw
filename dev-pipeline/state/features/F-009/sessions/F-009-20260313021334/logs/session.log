{"type":"user","uuid":"21855055-97a4-4456-8856-99ebc69739c7","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"call_28aab1457c8c457383b55cd4","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Test for F-009: General Command Executor\n   3→ * Tests the full command execution flow end-to-end.\n   4→ */\n   5→\n   6→import test from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdtemp, rm, mkdir, writeFile, access } from 'node:fs/promises';\n   9→import { join, resolve } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→\n  12→// Services\n  13→import { executeCommand, confirmHighRiskCommand } from '../../src/services/command-executor-service.js';\n  14→import { paginateOutput, storeOutputPages, getNextPage, clearPages, hasMorePages } from '../../src/services/output-pager-service.js';\n  15→import { sessionStore } from '../../src/services/session-store.js';\n  16→import { checkCommandBlacklist, detectHighRiskKeywords } from '../../src/security/system-guard.js';\n  17→import {\n  18→  createConfirmation,\n  19→  checkConfirmation,\n  20→  confirmAction,\n  21→  clearExpiredConfirmations\n  22→} from '../../src/security/confirmation-manager.js';\n  23→import {\n  24→  initAuditLogService,\n  25→  logAuditEntry,\n  26→  queryAuditLogs,\n  27→  resetAuditLogService\n  28→} from '../../src/services/audit-log-service.js';\n  29→import {\n  30→  setConfigForTesting,\n  31→  resetConfig as resetPermConfig,\n  32→  getUserRole,\n  33→  checkCommandPermission\n  34→} from '../../src/security/permission-guard.js';\n  35→\n  36→// Helpers\n  37→async function withTempDir(fn) {\n  38→  const tempDir = await mkdtemp(join(tmpdir(), 'f009-integration-'));\n  39→  try {\n  40→    return await fn(tempDir);\n  41→  } finally {\n  42→    await rm(tempDir, { recursive: true, force: true });\n  43→  }\n  44→}\n  45→\n  46→function createTestConfig(overrides = {}) {\n  47→  return {\n  48→    userPermissions: new Map(),\n  49→    allowAdminSkipConfirm: true,\n  50→    enableSystemExec: true,\n  51→    allowedUserIds: new Set(),\n  52→    allowedCommandPrefixes: ['ls', 'pwd', 'echo', 'cat', 'node'],\n  53→    systemExecTimeoutMs: 30000,\n  54→    commandBlacklist: ['rm -rf', 'mkfs', 'dd if='],\n  55→    highRiskKeywords: ['sudo', 'kill', 'chmod -R', 'chown'],\n  56→    ...overrides\n  57→  };\n  58→}\n  59→\n  60→// Reset state before each test\n  61→function resetState() {\n  62→  resetPermConfig();\n  63→  resetAuditLogService();\n  64→  clearExpiredConfirmations();\n  65→}\n  66→\n  67→// ============================================================\n  68→// AC-1: Execute shell command and return stdout/stderr\n  69→// ============================================================\n  70→\n  71→test('AC-1: Execute simple command and return output', async () => {\n  72→  resetState();\n  73→\n  74→  const config = createTestConfig();\n  75→  config.userPermissions.set('test-admin', 'admin');\n  76→  setConfigForTesting(config);\n  77→\n  78→  try {\n  79→    const result = await executeCommand({\n  80→      command: 'echo hello world',\n  81→      sessionId: 'test-ac1-1',\n  82→      userId: 'test-admin'\n  83→    });\n  84→\n  85→    assert.equal(result.needsConfirmation, false);\n  86→    assert.ok('stdout' in result);\n  87→    assert.ok('stderr' in result);\n  88→    assert.ok('exitCode' in result);\n  89→    assert.equal(result.exitCode, 0);\n  90→    assert.ok(result.stdout.includes('hello world'));\n  91→  } catch (error) {\n  92→    // May fail if system exec not enabled in environment\n  93→    if (!error.message.includes('系统命令执行未启用')) {\n  94→      throw error;\n  95→    }\n  96→  }\n  97→});\n  98→\n  99→test('AC-1: Execute command with stderr output', async () => {\n 100→  resetState();\n 101→\n 102→  const config = createTestConfig();\n 103→  config.userPermissions.set('test-admin', 'admin');\n 104→  setConfigForTesting(config);\n 105→\n 106→  try {\n 107→    // Use a command that writes to stderr (node -e with console.error)\n 108→    const result = await executeCommand({\n 109→      command: 'node -e \"console.error(\\'test stderr\\')\"',\n 110→      sessionId: 'test-ac1-2',\n 111→      userId: 'test-admin'\n 112→    });\n 113→\n 114→    assert.equal(result.needsConfirmation, false);\n 115→    assert.ok(result.stderr.includes('test stderr'));\n 116→  } catch (error) {\n 117→    if (!error.message.includes('系统命令执行未启用') && !error.message.includes('白名单')) {\n 118→      throw error;\n 119→    }\n 120→  }\n 121→});\n 122→\n 123→// ============================================================\n 124→// AC-2: Whitelist/blacklist security\n 125→// ============================================================\n 126→\n 127→test('AC-2: Blacklisted command is rejected', async () => {\n 128→  resetState();\n 129→\n 130→  // Test the checkCommandBlacklist function directly since executeCommand\n 131→  // uses config.commandBlacklist which is frozen at startup\n 132→  const blacklist = ['rm -rf', 'mkfs', 'dd if='];\n 133→  const result = checkCommandBlacklist('rm -rf /some/path', blacklist);\n 134→\n 135→  assert.equal(result.blocked, true);\n 136→  assert.equal(result.matchedCommand, 'rm -rf');\n 137→  assert.ok(result.reason.includes('黑名单'));\n 138→});\n 139→\n 140→test('AC-2: checkCommandBlacklist function works correctly', () => {\n 141→  const blacklist = ['rm -rf', 'mkfs', 'dd if='];\n 142→\n 143→  // Should block\n 144→  const blocked1 = checkCommandBlacklist('rm -rf /tmp', blacklist);\n 145→  assert.equal(blocked1.blocked, true);\n 146→  assert.equal(blocked1.matchedCommand, 'rm -rf');\n 147→\n 148→  const blocked2 = checkCommandBlacklist('mkfs.ext4 /dev/sda1', blacklist);\n 149→  assert.equal(blocked2.blocked, true);\n 150→\n 151→  // Should allow\n 152→  const allowed1 = checkCommandBlacklist('ls -la', blacklist);\n 153→  assert.equal(allowed1.blocked, false);\n 154→\n 155→  const allowed2 = checkCommandBlacklist('echo hello', []);\n 156→  assert.equal(allowed2.blocked, false);\n 157→});\n 158→\n 159→test('AC-2: Whitelist enforcement via allowedCommandPrefixes', async () => {\n 160→  resetState();\n 161→\n 162→  // Test system-guard directly since executeCommand uses frozen config\n 163→  // The whitelist is enforced in system-exec-service.js via assertAllowedCommand\n 164→  const config = createTestConfig();\n 165→  config.userPermissions.set('test-admin', 'admin');\n 166→  setConfigForTesting(config);\n 167→\n 168→  // Import system-exec-service to test whitelist\n 169→  const { executeSystemCommand } = await import('../../src/services/system-exec-service.js');\n 170→\n 171→  // Should fail - 'cat' is not in the default allowedCommandPrefixes\n 172→  // Note: Default config only allows: ls, pwd, echo, cat, node (from test config above)\n 173→  // but actual config is frozen, so we test the concept via checkCommandBlacklist\n 174→  // This test validates the whitelist concept works\n 175→\n 176→  // For integration test, verify that when prefix doesn't match, error is thrown\n 177→  // We can't easily mock the frozen config, so test the behavior\n 178→  try {\n 179→    await executeSystemCommand('nonexistent-cmd-that-starts-with-xyz', {});\n 180→    // If this succeeds, the system might not have whitelist configured\n 181→  } catch (error) {\n 182→    // Should fail with whitelist error\n 183→    assert.ok(\n 184→      error.message.includes('白名单') ||\n 185→      error.message.includes('前缀') ||\n 186→      error.message.includes('系统命令执行未启用'),\n 187→      `Expected whitelist error, got: ${error.message}`\n 188→    );\n 189→  }\n 190→});\n 191→\n 192→// ============================================================\n 193→// AC-3: Timeout with process termination\n 194→// ============================================================\n 195→\n 196→test('AC-3: Command timeout triggers SIGTERM', async () => {\n 197→  resetState();\n 198→\n 199→  const config = createTestConfig();\n 200→  config.userPermissions.set('test-admin', 'admin');\n 201→  config.systemExecTimeoutMs = 1000; // 1 second timeout\n 202→  setConfigForTesting(config);\n 203→\n 204→  try {\n 205→    // Sleep for 3 seconds (longer than timeout)\n 206→    const result = await executeCommand({\n 207→      command: 'node -e \"setTimeout(() => {}, 3000)\"',\n 208→      sessionId: 'test-ac3-1',\n 209→      userId: 'test-admin'\n 210→    });\n 211→\n 212→    // Should have timed out\n 213→    assert.equal(result.timedOut, true);\n 214→    assert.ok(result.output.includes('超时'));\n 215→  } catch (error) {\n 216→    if (!error.message.includes('系统命令执行未启用') && !error.message.includes('白名单')) {\n 217→      throw error;\n 218→    }\n 219→  }\n 220→});\n 221→\n 222→// ============================================================\n 223→// AC-4: Long output pagination with /more\n 224→// ============================================================\n 225→\n 226→test('AC-4: Long output is paginated', async () => {\n 227→  resetState();\n 228→\n 229→  const longText = 'A'.repeat(10000);\n 230→  const pages = paginateOutput(longText, 4000);\n 231→\n 232→  assert.ok(pages.length > 1);\n 233→  assert.equal(pages[0].length, 4000);\n 234→  assert.equal(pages[pages.length - 1].length, 2000);\n 235→});\n 236→\n 237→test('AC-4: /more command retrieves next page', async () => {\n 238→  resetState();\n 239→\n 240→  const pages = ['Page 1 content', 'Page 2 content', 'Page 3 content'];\n 241→  const sessionId = 'test-ac4-2';\n 242→\n 243→  storeOutputPages(sessionId, pages);\n 244→\n 245→  assert.equal(hasMorePages(sessionId), true);\n 246→\n 247→  const page1 = getNextPage(sessionId);\n 248→  assert.equal(page1, 'Page 1 content');\n 249→\n 250→  const page2 = getNextPage(sessionId);\n 251→  assert.equal(page2, 'Page 2 content');\n 252→\n 253→  const page3 = getNextPage(sessionId);\n 254→  assert.equal(page3, 'Page 3 content');\n 255→\n 256→  assert.equal(hasMorePages(sessionId), false);\n 257→\n 258→  const page4 = getNextPage(sessionId);\n 259→  assert.equal(page4, null);\n 260→});\n 261→\n 262→test('AC-4: clearPages removes all stored pages', async () => {\n 263→  resetState();\n 264→\n 265→  const sessionId = 'test-ac4-3';\n 266→  storeOutputPages(sessionId, ['Page 1', 'Page 2']);\n 267→\n 268→  assert.equal(hasMorePages(sessionId), true);\n 269→\n 270→  clearPages(sessionId);\n 271→\n 272→  assert.equal(hasMorePages(sessionId), false);\n 273→});\n 274→\n 275→// ============================================================\n 276→// AC-5: /cd for working directory with session persistence\n 277→// ============================================================\n 278→\n 279→test('AC-5: Session cwd is persisted and used in commands', async () => {\n 280→  resetState();\n 281→\n 282→  await withTempDir(async (tempDir) => {\n 283→    const config = createTestConfig();\n 284→    config.userPermissions.set('test-admin', 'admin');\n 285→    setConfigForTesting(config);\n 286→\n 287→    const sessionId = 'test-ac5-1';\n 288→    sessionStore.setCwd(sessionId, tempDir);\n 289→\n 290→    try {\n 291→      const result = await executeCommand({\n 292→        command: 'pwd',\n 293→        sessionId,\n 294→        userId: 'test-admin'\n 295→      });\n 296→\n 297→      assert.ok(result.stdout.includes(tempDir) || result.stdout.includes(tempDir.replace(/\\\\/g, '/')));\n 298→    } catch (error) {\n 299→      if (!error.message.includes('系统命令执行未启用') && !error.message.includes('白名单')) {\n 300→        throw error;\n 301→      }\n 302→    }\n 303→  });\n 304→});\n 305→\n 306→test('AC-5: getCwd returns null when not set', async () => {\n 307→  resetState();\n 308→\n 309→  const cwd = sessionStore.getCwd('non-existent-session');\n 310→  assert.equal(cwd, null);\n 311→});\n 312→\n 313→test('AC-5: setCwd and getCwd work correctly', async () => {\n 314→  resetState();\n 315→\n 316→  const sessionId = 'test-ac5-3';\n 317→  sessionStore.setCwd(sessionId, '/tmp');\n 318→\n 319→  const cwd = sessionStore.getCwd(sessionId);\n 320→  assert.equal(cwd, '/tmp');\n 321→});\n 322→\n 323→// ============================================================\n 324→// AC-6: High-risk command confirmation\n 325→// ============================================================\n 326→\n 327→test('AC-6: High-risk command requires confirmation', async () => {\n 328→  resetState();\n 329→\n 330→  const config = createTestConfig();\n 331→  config.userPermissions.set('test-admin', 'admin');\n 332→  setConfigForTesting(config);\n 333→\n 334→  try {\n 335→    const result = await executeCommand({\n 336→      command: 'sudo ls',\n 337→      sessionId: 'test-ac6-1',\n 338→      userId: 'test-admin'\n 339→    });\n 340→\n 341→    // Should require confirmation\n 342→    assert.equal(result.needsConfirmation, true);\n 343→    assert.ok(result.confirmationId);\n 344→    assert.ok(result.confirmationMessage);\n 345→    assert.ok(result.detectedKeywords.includes('sudo'));\n 346→  } catch (error) {\n 347→    if (!error.message.includes('系统命令执行未启用') && !error.message.includes('白名单')) {\n 348→      throw error;\n 349→    }\n 350→  }\n 351→});\n 352→\n 353→test('AC-6: detectHighRiskKeywords identifies dangerous commands', () => {\n 354→  const keywords = ['sudo', 'kill', 'chmod -R', 'chown'];\n 355→\n 356→  const result1 = detectHighRiskKeywords('sudo rm /etc/passwd', keywords);\n 357→  assert.equal(result1.isHighRisk, true);\n 358→  assert.ok(result1.detectedKeywords.includes('sudo'));\n 359→\n 360→  const result2 = detectHighRiskKeywords('kill -9 1234', keywords);\n 361→  assert.equal(result2.isHighRisk, true);\n 362→  assert.ok(result2.detectedKeywords.includes('kill'));\n 363→\n 364→  const result3 = detectHighRiskKeywords('ls -la', keywords);\n 365→  assert.equal(result3.isHighRisk, false);\n 366→  assert.deepEqual(result3.detectedKeywords, []);\n 367→});\n 368→\n 369→test('AC-6: Confirmation flow works for high-risk command', async () => {\n 370→  resetState();\n 371→\n 372→  const config = createTestConfig();\n 373→  config.userPermissions.set('test-admin', 'admin');\n 374→  setConfigForTesting(config);\n 375→\n 376→  try {\n 377→    // Step 1: Execute triggers confirmation requirement\n 378→    const execResult = await executeCommand({\n 379→      command: 'sudo echo test',\n 380→      sessionId: 'test-ac6-3',\n 381→      userId: 'test-admin'\n 382→    });\n 383→\n 384→    if (execResult.needsConfirmation) {\n 385→      // Step 2: Check confirmation exists\n 386→      const checkResult = checkConfirmation(execResult.confirmationId, 'test-admin');\n 387→      assert.equal(checkResult.status, 'pending');\n 388→\n 389→      // Step 3: Confirm and execute\n 390→      const confirmResult = await confirmHighRiskCommand(\n 391→        execResult.confirmationId,\n 392→        'test-admin',\n 393→        'test-ac6-3'\n 394→      );\n 395→\n 396→      // Should now have executed\n 397→      assert.equal(confirmResult.needsConfirmation, false);\n 398→    }\n 399→  } catch (error) {\n 400→    if (!error.message.includes('系统命令执行未启用') && !error.message.includes('白名单')) {\n 401→      throw error;\n 402→    }\n 403→  }\n 404→});\n 405→\n 406→test('AC-6: Wrong user cannot confirm', async () => {\n 407→  resetState();\n 408→\n 409→  const config = createTestConfig();\n 410→  config.userPermissions.set('user-1', 'admin');\n 411→  config.userPermissions.set('user-2', 'admin');\n 412→  setConfigForTesting(config);\n 413→\n 414→  // Create confirmation for user-1\n 415→  const { confirmId } = createConfirmation('user-1', 'exec', { command: 'sudo ls' });\n 416→\n 417→  // user-2 tries to confirm - should fail\n 418→  const result = confirmAction(confirmId, 'user-2');\n 419→  assert.equal(result.ok, false);\n 420→});\n 421→\n 422→// ============================================================\n 423→// Integration: Permission check with exec\n 424→// ============================================================\n 425→\n 426→test('Integration: exec command requires admin role', async () => {\n 427→  resetState();\n 428→\n 429→  const config = createTestConfig({ enableSystemExec: true });\n 430→  config.userPermissions.set('admin-user', 'admin');\n 431→  config.userPermissions.set('op-user', 'operator');\n 432→  setConfigForTesting(config);\n 433→\n 434→  // Admin can execute\n 435→  const adminResult = checkCommandPermission('admin-user', 'exec');\n 436→  assert.equal(adminResult.allowed, true);\n 437→\n 438→  // Operator cannot\n 439→  const opResult = checkCommandPermission('op-user', 'exec');\n 440→  assert.equal(opResult.allowed, false);\n 441→});\n 442→\n 443→test('Integration: cd and more command permissions', async () => {\n 444→  resetState();\n 445→\n 446→  const config = createTestConfig();\n 447→  config.userPermissions.set('viewer-user', 'viewer');\n 448→  config.userPermissions.set('op-user', 'operator');\n 449→  setConfigForTesting(config);\n 450→\n 451→  // Viewer can use 'more'\n 452→  const viewerMore = checkCommandPermission('viewer-user', 'more');\n 453→  assert.equal(viewerMore.allowed, true);\n 454→\n 455→  // Operator can use 'cd'\n 456→  const opCd = checkCommandPermission('op-user', 'cd');\n 457→  assert.equal(opCd.allowed, true);\n 458→\n 459→  // Viewer cannot use 'cd'\n 460→  const viewerCd = checkCommandPermission('viewer-user', 'cd');\n 461→  assert.equal(viewerCd.allowed, false);\n 462→});\n 463→\n 464→// ============================================================\n 465→// Integration: Audit logging\n 466→// ============================================================\n 467→\n 468→test('Integration: Command execution is logged to audit trail', async () => {\n 469→  resetState();\n 470→\n 471→  await withTempDir(async (tempDir) => {\n 472→    const config = createTestConfig();\n 473→    config.userPermissions.set('test-admin', 'admin');\n 474→    setConfigForTesting(config);\n 475→\n 476→    await initAuditLogService({ logDir: tempDir });\n 477→\n 478→    try {\n 479→      await executeCommand({\n 480→        command: 'echo test',\n 481→        sessionId: 'test-audit-1',\n 482→        userId: 'test-admin'\n 483→      });\n 484→\n 485→      // Query audit logs\n 486→      const entries = await queryAuditLogs({ action: 'exec' });\n 487→      assert.ok(entries.length >= 1);\n 488→\n 489→      const entry = entries.find(e => e.userId === 'test-admin');\n 490→      assert.ok(entry);\n 491→      assert.equal(entry.action, 'exec');\n 492→    } catch (error) {\n 493→      if (!error.message.includes('系统命令执行未启用') && !error.message.includes('白名单')) {\n 494→        throw error;\n 495→      }\n 496→    }\n 497→  });\n 498→});\n 499→\n 500→test('Integration: Blacklisted command is logged as denied', async () => {\n 501→  resetState();\n 502→\n 503→  await withTempDir(async (tempDir) => {\n 504→    const config = createTestConfig();\n 505→    config.userPermissions.set('test-admin', 'admin');\n 506→    setConfigForTesting(config);\n 507→\n 508→    await initAuditLogService({ logDir: tempDir });\n 509→\n 510→    // Test the blacklist function directly since config is frozen\n 511→    const blacklist = ['rm -rf', 'mkfs'];\n 512→    const result = checkCommandBlacklist('rm -rf /something', blacklist);\n 513→\n 514→    assert.equal(result.blocked, true);\n 515→\n 516→    // Manually log to simulate what command-executor-service would do\n 517→    await logAuditEntry({\n 518→      userId: 'test-admin',\n 519→      role: 'admin',\n 520→      action: 'exec',\n 521→      params: { command: 'rm -rf /something' },\n 522→      result: 'denied',\n 523→      reason: `Blacklisted command: rm -rf`,\n 524→      sessionId: 'test-audit-2'\n 525→    });\n 526→\n 527→    // Query audit logs\n 528→    const entries = await queryAuditLogs({ action: 'exec' });\n 529→    const deniedEntry = entries.find(e => e.result === 'denied');\n 530→\n 531→    assert.ok(deniedEntry);\n 532→    assert.ok(deniedEntry.reason.includes('Blacklist') || deniedEntry.reason.includes('黑名单'));\n 533→  });\n 534→});\n 535→\n 536→// ============================================================\n 537→// Performance tests\n 538→// ============================================================\n 539→\n 540→test('Performance: Pagination is fast', () => {\n 541→  const longText = 'X'.repeat(100000);\n 542→  const start = Date.now();\n 543→\n 544→  for (let i = 0; i < 100; i++) {\n 545→    paginateOutput(longText, 4000);\n 546→  }\n 547→\n 548→  const duration = Date.now() - start;\n 549→  // 100 paginations of 100KB should take < 100ms\n 550→  assert.ok(duration < 100, `Pagination too slow: ${duration}ms for 100 iterations`);\n 551→});\n 552→\n 553→test('Performance: Blacklist check is fast', () => {\n 554→  const blacklist = ['rm -rf', 'mkfs', 'dd if=', 'shutdown', 'reboot', 'halt'];\n 555→  const command = 'ls -la /some/very/long/path/that/goes/on/and/on';\n 556→\n 557→  const start = Date.now();\n 558→  for (let i = 0; i < 1000; i++) {\n 559→    checkCommandBlacklist(command, blacklist);\n 560→  }\n 561→  const duration = Date.now() - start;\n 562→\n 563→  // 1000 checks should take < 10ms\n 564→  assert.ok(duration < 10, `Blacklist check too slow: ${duration}ms for 1000 checks`);\n 565→});\n 566→\n 567→test('Performance: High-risk detection is fast', () => {\n 568→  const keywords = ['sudo', 'kill', 'chmod -R', 'chown', 'dd', 'mkfs'];\n 569→  const command = 'find /tmp -name \"*.log\" -delete';\n 570→\n 571→  const start = Date.now();\n 572→  for (let i = 0; i < 1000; i++) {\n 573→    detectHighRiskKeywords(command, keywords);\n 574→  }\n 575→  const duration = Date.now() - start;\n 576→\n 577→  // 1000 checks should take < 20ms\n 578→  assert.ok(duration < 20, `High-risk detection too slow: ${duration}ms for 1000 checks`);\n 579→});\n 580→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce354b726b8a4df5dbec4c5680ecb","__timestamp":"2026-03-12T18:35:51.425Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"cb4b8a23-9292-417f-9d82-429425384860","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"call_87cf3277283449c284154d16","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for F-009 command executor service\n   3→ * T-3.2: Create command-executor-service.js\n   4→ */\n   5→\n   6→import { describe, test, beforeEach, afterEach } from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→\n   9→describe('F-009 Command Executor Service', () => {\n  10→  let commandExecutorService;\n  11→  let sessionStore;\n  12→\n  13→  beforeEach(async () => {\n  14→    const module = await import('../../src/services/command-executor-service.js');\n  15→    commandExecutorService = module;\n  16→    const sessionModule = await import('../../src/services/session-store.js');\n  17→    sessionStore = sessionModule.sessionStore;\n  18→  });\n  19→\n  20→  describe('executeCommand', () => {\n  21→    test('should be exported', async () => {\n  22→      assert.ok(commandExecutorService.executeCommand);\n  23→      assert.ok(typeof commandExecutorService.executeCommand === 'function');\n  24→    });\n  25→\n  26→    test('should return result object with required fields', async () => {\n  27→      const { executeCommand } = commandExecutorService;\n  28→\n  29→      try {\n  30→        const result = await executeCommand({\n  31→          command: 'echo test',\n  32→          sessionId: 'test-session-1',\n  33→          userId: 'test-user'\n  34→        });\n  35→\n  36→        assert.ok('stdout' in result);\n  37→        assert.ok('stderr' in result);\n  38→        assert.ok('exitCode' in result);\n  39→        assert.ok('timedOut' in result);\n  40→        assert.ok('needsConfirmation' in result);\n  41→      } catch (error) {\n  42→        // Expected if system exec not enabled\n  43→        assert.ok(\n  44→          error.message.includes('系统命令执行未启用') ||\n  45→          error.message.includes('白名单')\n  46→        );\n  47→      }\n  48→    });\n  49→  });\n  50→\n  51→  describe('blacklist check', () => {\n  52→    test('should reject blacklisted command when blacklist is configured', async () => {\n  53→      const { executeCommand } = commandExecutorService;\n  54→\n  55→      // Since default blacklist is empty, we need to test with a configured blacklist\n  56→      // For now, test that when system exec is enabled, commands work\n  57→      try {\n  58→        await executeCommand({\n  59→          command: 'echo test',\n  60→          sessionId: 'test-session-2b',\n  61→          userId: 'test-user'\n  62→        });\n  63→        // If this succeeds, blacklist is empty or command not blocked\n  64→      } catch (error) {\n  65→        // Could be blacklist rejection or system exec disabled\n  66→        assert.ok(\n  67→          error.message.includes('黑名单') ||\n  68→          error.message.includes('系统命令执行未启用') ||\n  69→          error.message.includes('白名单')\n  70→        );\n  71→      }\n  72→    });\n  73→  });\n  74→\n  75→  describe('high-risk detection', () => {\n  76→    test('should detect high-risk command and set needsConfirmation', async () => {\n  77→      const { executeCommand } = commandExecutorService;\n  78→\n  79→      try {\n  80→        const result = await executeCommand({\n  81→          command: 'sudo ls',\n  82→          sessionId: 'test-session-3',\n  83→          userId: 'test-user'\n  84→        });\n  85→\n  86→        // If command was executed, check for confirmation flag\n  87→        if (result.needsConfirmation) {\n  88→          assert.ok(result.confirmationMessage);\n  89→        }\n  90→      } catch (error) {\n  91→        // Expected if system exec not enabled or blacklist hit\n  92→        assert.ok(\n  93→          error.message.includes('系统命令执行未启用') ||\n  94→          error.message.includes('白名单') ||\n  95→          error.message.includes('黑名单')\n  96→        );\n  97→      }\n  98→    });\n  99→  });\n 100→\n 101→  describe('session cwd', () => {\n 102→    test('should use session cwd when set', async () => {\n 103→      const { executeCommand } = commandExecutorService;\n 104→\n 105→      sessionStore.setCwd('test-session-4', '/tmp');\n 106→\n 107→      try {\n 108→        const result = await executeCommand({\n 109→          command: 'pwd',\n 110→          sessionId: 'test-session-4',\n 111→          userId: 'test-user'\n 112→        });\n 113→\n 114→        // Result should be from /tmp directory\n 115→        assert.ok(result.stdout);\n 116→      } catch (error) {\n 117→        // Expected if system exec not enabled\n 118→        assert.ok(\n 119→          error.message.includes('系统命令执行未启用') ||\n 120→          error.message.includes('白名单')\n 121→        );\n 122→      }\n 123→    });\n 124→  });\n 125→\n 126→  describe('output pagination', () => {\n 127→    test('should store paginated output when output is long', async () => {\n 128→      const { executeCommand } = commandExecutorService;\n 129→\n 130→      try {\n 131→        const result = await executeCommand({\n 132→          command: 'echo test',\n 133→          sessionId: 'test-session-5',\n 134→          userId: 'test-user'\n 135→        });\n 136→\n 137→        // Check if pagination info is available\n 138→        assert.ok('hasMorePages' in result);\n 139→      } catch (error) {\n 140→        // Expected if system exec not enabled\n 141→        assert.ok(\n 142→          error.message.includes('系统命令执行未启用') ||\n 143→          error.message.includes('白名单')\n 144→        );\n 145→      }\n 146→    });\n 147→  });\n 148→\n 149→  describe('confirmation flow', () => {\n 150→    test('confirmHighRiskCommand should be exported', async () => {\n 151→      assert.ok(commandExecutorService.confirmHighRiskCommand);\n 152→      assert.ok(typeof commandExecutorService.confirmHighRiskCommand === 'function');\n 153→    });\n 154→\n 155→    test('should return pending confirmation info for high-risk command', async () => {\n 156→      const { executeCommand } = commandExecutorService;\n 157→\n 158→      try {\n 159→        // Use a command with high-risk keyword\n 160→        const result = await executeCommand({\n 161→          command: 'sudo echo test',\n 162→          sessionId: 'test-session-6',\n 163→          userId: 'test-user',\n 164→          skipConfirmation: false\n 165→        });\n 166→\n 167→        // Should indicate confirmation needed\n 168→        if (result.needsConfirmation) {\n 169→          assert.ok(result.confirmationId);\n 170→          assert.ok(result.confirmationMessage);\n 171→        }\n 172→      } catch (error) {\n 173→        // Expected if system exec not enabled\n 174→        assert.ok(\n 175→          error.message.includes('系统命令执行未启用') ||\n 176→          error.message.includes('白名单') ||\n 177→          error.message.includes('黑名单')\n 178→        );\n 179→      }\n 180→    });\n 181→  });\n 182→});\n 183→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce354b726b8a4df5dbec4c5680ecb","__timestamp":"2026-03-12T18:35:51.433Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
