{"type":"assistant","uuid":"20260313021402fbf4612ab2c84873","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"id":"20260313021402fbf4612ab2c84873","content":[{"type":"tool_use","id":"019ce34178855fb87be3e19d7e9369e0","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/registry.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":null,"__timestamp":"2026-03-12T18:14:05.814Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"assistant","uuid":"20260313021402fbf4612ab2c84873","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"id":"20260313021402fbf4612ab2c84873","content":[{"type":"tool_use","id":"019ce3417ab8cd32fb22190efcb2911f","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/session-store.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":51500,"output_tokens":97,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":null,"__timestamp":"2026-03-12T18:14:05.817Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"b83fed0f-f32e-489c-8a4d-ff825f3d10c9","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"019ce34176546e55baea5f5365c64673","content":[{"type":"text","text":"   1→/**\n   2→ * Command Router\n   3→ * Main entry point for command routing and dispatch.\n   4→ */\n   5→\n   6→import { parseCommand } from './parser.js';\n   7→import { getCommand, getAliasMap, registerCommand } from './registry.js';\n   8→import { validateCommand } from './validator.js';\n   9→import { formatError, formatValidationErrors, ErrorCodes } from './formatter.js';\n  10→import { isAllowedUser } from '../../security/guard.js';\n  11→import { checkCommandPermission, getUserRole } from '../../security/permission-guard.js';\n  12→import { logAuditEntry } from '../../services/audit-log-service.js';\n  13→\n  14→/**\n  15→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  16→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  17→ * @typedef {import('./registry.js').CommandEntry} CommandEntry\n  18→ */\n  19→\n  20→/**\n  21→ * Route and dispatch a command from Telegram context.\n  22→ * @param {Object} ctx - Telegraf context\n  23→ * @returns {Promise<boolean>} True if command was handled\n  24→ */\n  25→export async function routeCommand(ctx) {\n  26→  const text = ctx.message?.text;\n  27→\n  28→  if (!text || !text.startsWith('/')) {\n  29→    return false;\n  30→  }\n  31→\n  32→  // Authorization check\n  33→  const userId = ctx.from?.id;\n  34→  if (!isAuthorized(userId)) {\n  35→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n  36→    return true;\n  37→  }\n  38→\n  39→  // Parse command\n  40→  const aliasMap = getAliasMap();\n  41→  const parsed = parseCommand(text, aliasMap);\n  42→\n  43→  if (!parsed) {\n  44→    await ctx.reply('无法解析命令。');\n  45→    return true;\n  46→  }\n  47→\n  48→  // Lookup command\n  49→  const entry = getCommand(parsed.command);\n  50→\n  51→  if (!entry) {\n  52→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n  53→    return true;\n  54→  }\n  55→\n  56→  const { meta, handler } = entry;\n  57→\n  58→  // T-101: Permission check\n  59→  const commandName = meta.name;\n  60→  const permResult = checkCommandPermission(userId, commandName);\n  61→\n  62→  if (!permResult.allowed) {\n  63→    // Log denied access\n  64→    await logAuditEntry({\n  65→      userId,\n  66→      action: commandName,\n  67→      params: {},\n  68→      result: 'denied',\n  69→      reason: permResult.reason\n  70→    });\n  71→\n  72→    await ctx.reply(`⛔ ${permResult.reason}`);\n  73→    return true;\n  74→  }\n  75→\n  76→  // Validate command\n  77→  const validation = validateCommand(parsed, meta);\n  78→\n  79→  if (!validation.valid) {\n  80→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n  81→    await ctx.reply(errorMsg);\n  82→    return true;\n  83→  }\n  84→\n  85→  // Create handler context\n  86→  const handlerContext = {\n  87→    ctx,\n  88→    parsed,\n  89→    meta,\n  90→    params: validation.normalized || {},\n  91→    userId,\n  92→    userRole: getUserRole(userId),\n  93→    requiresConfirmation: permResult.requiresConfirmation,\n  94→    reply: async (text) => ctx.reply(text),\n  95→    replyFile: async (content, filename) => {\n  96→      // Will be implemented with proper file handling\n  97→      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n  98→    }\n  99→  };\n 100→\n 101→  // Dispatch to handler\n 102→  try {\n 103→    await handler(handlerContext);\n 104→  } catch (error) {\n 105→    const message = error instanceof Error ? error.message : String(error);\n 106→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n 107→  }\n 108→\n 109→  return true;\n 110→}\n 111→\n 112→/**\n 113→ * Check if user is authorized.\n 114→ * @param {number|string|undefined} userId - User ID\n 115→ * @returns {boolean} True if authorized\n 116→ */\n 117→function isAuthorized(userId) {\n 118→  return isAllowedUser(userId);\n 119→}\n 120→\n 121→/**\n 122→ * Format error response for display.\n 123→ * @param {Object} error - Error object\n 124→ * @returns {string} Formatted error\n 125→ */\n 126→function formatErrorResponse(error) {\n 127→  const lines = [`❌ ${error.message}`];\n 128→\n 129→  if (error.suggestion) {\n 130→    lines.push(`💡 ${error.suggestion}`);\n 131→  }\n 132→\n 133→  if (error.usage) {\n 134→    lines.push(`用法: ${error.usage}`);\n 135→  }\n 136→\n 137→  return lines.join('\\n');\n 138→}\n 139→\n 140→/**\n 141→ * Register all default commands.\n 142→ */\n 143→export function registerDefaultCommands() {\n 144→  // Commands will be registered by individual handlers\n 145→  // This is called during initialization\n 146→}\n 147→\n 148→/**\n 149→ * Create middleware for command routing.\n 150→ * @returns {Function} Middleware function\n 151→ */\n 152→export function createCommandMiddleware() {\n 153→  return async (ctx, next) => {\n 154→    const handled = await routeCommand(ctx);\n 155→    if (!handled) {\n 156→      return next();\n 157→    }\n 158→  };\n 159→}\n 160→\n 161→// Re-export for convenience\n 162→export { registerCommand, getCommand, getAliasMap };\n 163→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce34176546e55baea5f5365c64673","__timestamp":"2026-03-12T18:14:05.818Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"b8f10ed1-d501-4105-b22b-e0a883648774","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"019ce34178855fb87be3e19d7e9369e0","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  /** @type {Record<string, string>} */\n 215→  const map = {};\n 216→  for (const [alias, command] of aliasToCommand) {\n 217→    map[alias] = command;\n 218→  }\n 219→  return map;\n 220→}\n 221→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce34178855fb87be3e19d7e9369e0","__timestamp":"2026-03-12T18:14:05.820Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"8662a285-b979-4510-8c72-59baeabfe5d3","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3417ab8cd32fb22190efcb2911f","content":[{"type":"text","text":"   1→import { config } from '../config.js';\n   2→\n   3→class SessionStore {\n   4→  #messagesBySessionKey = new Map();\n   5→  #commitsBySessionKey = new Map();\n   6→\n   7→  get(sessionKey) {\n   8→    if (!this.#messagesBySessionKey.has(sessionKey)) {\n   9→      this.#messagesBySessionKey.set(sessionKey, []);\n  10→    }\n  11→    return this.#messagesBySessionKey.get(sessionKey);\n  12→  }\n  13→\n  14→  append(sessionKey, role, content) {\n  15→    const messages = this.get(sessionKey);\n  16→    messages.push({ role, content });\n  17→\n  18→    const maxMessages = config.maxHistoryTurns * 2;\n  19→    if (messages.length > maxMessages) {\n  20→      messages.splice(0, messages.length - maxMessages);\n  21→    }\n  22→  }\n  23→\n  24→  clear(sessionKey) {\n  25→    this.#messagesBySessionKey.delete(sessionKey);\n  26→    this.#commitsBySessionKey.delete(sessionKey);\n  27→  }\n  28→\n  29→  toPrompt(sessionKey, channel = 'unknown') {\n  30→    const messages = this.get(sessionKey);\n  31→\n  32→    return [\n  33→      `你正在通过 ${channel} 渠道提供电脑助手服务。`,\n  34→      '请使用自然、简洁、可执行的表达。',\n  35→      '如果用户请求系统操作或截图，明确说明步骤与结果。',\n  36→      '当你产出本地文件（截图/文档）时，必须额外输出独立行：SEND_FILE:<绝对路径>。',\n  37→      '禁止仅输出 @image:xxx 或相对路径；路径必须是绝对路径（例如 /var/folders/... 或 /home/...）。',\n  38→      '以下是最近对话上下文：',\n  39→      ...messages.map((msg) => `${msg.role === 'user' ? '用户' : '助手'}: ${msg.content}`),\n  40→      '请继续回答最后一条用户消息。'\n  41→    ].join('\\n');\n  42→  }\n  43→\n  44→  /**\n  45→   * Add a commit record to a session.\n  46→   * @param {string} sessionKey - Session identifier\n  47→   * @param {Object} commitInfo - Commit information\n  48→   */\n  49→  addCommit(sessionKey, commitInfo) {\n  50→    if (!this.#commitsBySessionKey.has(sessionKey)) {\n  51→      this.#commitsBySessionKey.set(sessionKey, []);\n  52→    }\n  53→    const commits = this.#commitsBySessionKey.get(sessionKey);\n  54→    commits.push({\n  55→      ...commitInfo,\n  56→      timestamp: commitInfo.timestamp || Date.now()\n  57→    });\n  58→  }\n  59→\n  60→  /**\n  61→   * Get commits for a session.\n  62→   * @param {string} sessionKey - Session identifier\n  63→   * @returns {Object[]} Array of commit records\n  64→   */\n  65→  getCommits(sessionKey) {\n  66→    return this.#commitsBySessionKey.get(sessionKey) || [];\n  67→  }\n  68→\n  69→  /**\n  70→   * Get the last commit for a session.\n  71→   * @param {string} sessionKey - Session identifier\n  72→   * @returns {Object|null} Last commit record or null\n  73→   */\n  74→  getLastCommit(sessionKey) {\n  75→    const commits = this.getCommits(sessionKey);\n  76→    return commits.length > 0 ? commits[commits.length - 1] : null;\n  77→  }\n  78→}\n  79→\n  80→export const sessionStore = new SessionStore();\n  81→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3417ab8cd32fb22190efcb2911f","__timestamp":"2026-03-12T18:14:05.821Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
