{"type":"user","uuid":"d683d5ff-3c3d-4ff6-a312-576a87383045","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"019ce344620841ecbecd9ceb4a67a2fc","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { captureScreenshot } from '../services/screenshot-service.js';\n  11→import { executeSystemCommand } from '../services/system-exec-service.js';\n  12→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  13→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  14→import { registerCommand } from './commands/index.js';\n  15→import { routeCommand } from './commands/index.js';\n  16→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  17→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  18→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  19→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  20→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  21→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  22→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  23→import { auditMeta, handleAudit } from './commands/handlers/audit.js';\n  24→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n  25→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n  26→import { generateHelp } from './commands/help.js';\n  27→\n  28→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  29→const STREAM_MIN_CHARS = 220;\n  30→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  31→const TYPING_INTERVAL_MS = 3500;\n  32→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  33→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  34→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  35→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  36→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  37→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  38→const TMP_DIR = path.resolve(os.tmpdir());\n  39→const HOME_DIR = path.resolve(os.homedir());\n  40→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  41→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  42→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  43→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  44→\n  45→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  46→  const normalized = configuredDirs\n  47→    .map((dir) => String(dir ?? '').trim())\n  48→    .filter(Boolean)\n  49→    .map((dir) => path.resolve(dir));\n  50→\n  51→  if (normalized.length > 0) {\n  52→    return [...new Set(normalized)];\n  53→  }\n  54→\n  55→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  56→}\n  57→\n  58→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  59→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  60→\n  61→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  62→  const chunks = [];\n  63→  for (let i = 0; i < text.length; i += chunkSize) {\n  64→    chunks.push(text.slice(i, i + chunkSize));\n  65→  }\n  66→  return chunks;\n  67→}\n  68→\n  69→function sanitizeMarkerPath(raw) {\n  70→  return String(raw ?? '')\n  71→    .trim()\n  72→    .replace(/^['\"`]+/, '')\n  73→    .replace(/['\"`]+$/, '');\n  74→}\n  75→\n  76→function extractFileMarkers(text = '') {\n  77→  const fileRefs = [];\n  78→\n  79→  const withSendFileRemoved = text.replace(\n  80→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  81→    (_full, rawRef) => {\n  82→      const ref = sanitizeMarkerPath(rawRef);\n  83→      if (ref) {\n  84→        fileRefs.push(ref);\n  85→      }\n  86→      return '\\n';\n  87→    }\n  88→  );\n  89→\n  90→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  91→    const ref = sanitizeMarkerPath(rawRef);\n  92→    if (ref) {\n  93→      fileRefs.push(ref);\n  94→    }\n  95→    return '';\n  96→  });\n  97→\n  98→  const withBacktickPathRemoved = withImageRemoved.replace(\n  99→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 100→    (_full, rawRef) => {\n 101→      const ref = sanitizeMarkerPath(rawRef);\n 102→      if (ref) {\n 103→        fileRefs.push(ref);\n 104→      }\n 105→      return '';\n 106→    }\n 107→  );\n 108→\n 109→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 110→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 111→    (_full, rawRef) => {\n 112→      const ref = sanitizeMarkerPath(rawRef);\n 113→      if (ref) {\n 114→        fileRefs.push(ref);\n 115→      }\n 116→      return '';\n 117→    }\n 118→  );\n 119→\n 120→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 121→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 122→    (_full, rawRef) => {\n 123→      const ref = sanitizeMarkerPath(rawRef);\n 124→      if (ref) {\n 125→        fileRefs.push(ref);\n 126→      }\n 127→      return '\\n';\n 128→    }\n 129→  );\n 130→\n 131→  return {\n 132→    fileRefs: [...new Set(fileRefs)],\n 133→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 134→  };\n 135→}\n 136→\n 137→function isPathWithinRoot(targetPath, rootPath) {\n 138→  const relative = path.relative(rootPath, targetPath);\n 139→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 140→}\n 141→\n 142→function isAllowedFilePath(filePath) {\n 143→  const resolved = path.resolve(filePath);\n 144→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 145→}\n 146→\n 147→function buildFileCandidates(normalizedPath) {\n 148→  if (path.isAbsolute(normalizedPath)) {\n 149→    return [normalizedPath];\n 150→  }\n 151→\n 152→  const baseName = path.basename(normalizedPath);\n 153→  const candidates = [\n 154→    path.resolve(process.cwd(), normalizedPath),\n 155→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 156→  ];\n 157→\n 158→  return [...new Set(candidates)];\n 159→}\n 160→\n 161→async function resolveLocalFilePath(fileRef) {\n 162→  const normalized = sanitizeMarkerPath(fileRef);\n 163→  if (!normalized) {\n 164→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 165→  }\n 166→\n 167→  if (!path.isAbsolute(normalized)) {\n 168→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 169→  }\n 170→\n 171→  const candidates = buildFileCandidates(normalized);\n 172→\n 173→  for (const candidate of candidates) {\n 174→    try {\n 175→      await access(candidate);\n 176→      return { filePath: candidate, triedPaths: candidates };\n 177→    } catch {\n 178→      // ignore\n 179→    }\n 180→  }\n 181→\n 182→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 183→}\n 184→\n 185→async function validateFileForTelegram(filePath) {\n 186→  const resolvedPath = path.resolve(filePath);\n 187→  if (!isAllowedFilePath(resolvedPath)) {\n 188→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 189→  }\n 190→\n 191→  const ext = path.extname(resolvedPath).toLowerCase();\n 192→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 193→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 194→  }\n 195→\n 196→  const fileStat = await stat(resolvedPath);\n 197→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 198→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 199→\n 200→  if (fileStat.size > maxSize) {\n 201→    return {\n 202→      ok: false,\n 203→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 204→    };\n 205→  }\n 206→\n 207→  return { ok: true, isPhoto, resolvedPath };\n 208→}\n 209→\n 210→function isTimeoutLikeError(message = '') {\n 211→  const normalized = String(message).toLowerCase();\n 212→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 213→}\n 214→\n 215→function sleep(ms) {\n 216→  return new Promise((resolve) => setTimeout(resolve, ms));\n 217→}\n 218→\n 219→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 220→  if (isPhoto) {\n 221→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 222→    return;\n 223→  }\n 224→\n 225→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 226→}\n 227→\n 228→async function replyFiles(ctx, fileRefs = []) {\n 229→  const results = [];\n 230→\n 231→  for (const fileRef of fileRefs) {\n 232→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 233→    if (!filePath) {\n 234→      const reason = rejectReason || 'not_found';\n 235→      results.push({ fileRef, sent: false, reason, triedPaths });\n 236→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 237→      continue;\n 238→    }\n 239→\n 240→    try {\n 241→      const validation = await validateFileForTelegram(filePath);\n 242→      if (!validation.ok) {\n 243→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 244→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 245→        continue;\n 246→      }\n 247→\n 248→      const actualPath = validation.resolvedPath;\n 249→      let sent = false;\n 250→      let lastReason = '';\n 251→\n 252→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 253→        try {\n 254→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 255→          sent = true;\n 256→          logger.info(\n 257→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 258→            'Telegram file sent'\n 259→          );\n 260→          break;\n 261→        } catch (error) {\n 262→          lastReason = error instanceof Error ? error.message : String(error);\n 263→          logger.warn(\n 264→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 265→            'Telegram file send attempt failed'\n 266→          );\n 267→\n 268→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 269→            await sleep(600);\n 270→            continue;\n 271→          }\n 272→\n 273→          break;\n 274→        }\n 275→      }\n 276→\n 277→      if (!sent) {\n 278→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 279→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 280→        continue;\n 281→      }\n 282→\n 283→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 284→    } catch (error) {\n 285→      const reason = error instanceof Error ? error.message : String(error);\n 286→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 287→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 288→    }\n 289→  }\n 290→\n 291→  return results;\n 292→}\n 293→\n 294→async function safeReply(ctx, text) {\n 295→  try {\n 296→    await ctx.reply(text);\n 297→    return true;\n 298→  } catch (error) {\n 299→    const reason = error instanceof Error ? error.message : String(error);\n 300→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 301→    return false;\n 302→  }\n 303→}\n 304→\n 305→async function replyLargeText(ctx, text) {\n 306→  const chunks = splitMessage(text);\n 307→  for (const chunk of chunks) {\n 308→    const ok = await safeReply(ctx, chunk);\n 309→    if (!ok) {\n 310→      break;\n 311→    }\n 312→  }\n 313→}\n 314→\n 315→async function safeEditMessageText(ctx, messageId, text) {\n 316→  const nextText = text && text.trim() ? text : ' ';\n 317→\n 318→  try {\n 319→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 320→  } catch (error) {\n 321→    const message = error instanceof Error ? error.message : String(error);\n 322→    if (message.includes('message is not modified')) {\n 323→      return;\n 324→    }\n 325→    throw error;\n 326→  }\n 327→}\n 328→\n 329→function createEditableStreamPublisher(ctx) {\n 330→  let fullText = '';\n 331→  let renderedText = '';\n 332→  let pendingChars = 0;\n 333→  let lastFlushAt = 0;\n 334→  let flushChain = Promise.resolve();\n 335→  let activeMessage = null;\n 336→  let activeSegmentIndex = 0;\n 337→  let publishedMessageCount = 0;\n 338→\n 339→  async function ensureActiveMessage() {\n 340→    if (activeMessage) {\n 341→      return;\n 342→    }\n 343→    activeMessage = await ctx.reply('处理中...');\n 344→    activeSegmentIndex = 0;\n 345→    publishedMessageCount += 1;\n 346→  }\n 347→\n 348→  async function render(force = false) {\n 349→    const now = Date.now();\n 350→\n 351→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 352→      return;\n 353→    }\n 354→\n 355→    if (fullText === renderedText) {\n 356→      pendingChars = 0;\n 357→      return;\n 358→    }\n 359→\n 360→    await ensureActiveMessage();\n 361→\n 362→    const segments = splitMessage(fullText);\n 363→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 364→\n 365→    while (activeSegmentIndex < targetLastIndex) {\n 366→      const text = segments[activeSegmentIndex] ?? ' ';\n 367→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 368→\n 369→      activeMessage = await ctx.reply('继续输出中...');\n 370→      activeSegmentIndex += 1;\n 371→      publishedMessageCount += 1;\n 372→    }\n 373→\n 374→    const activeText = segments[targetLastIndex] ?? ' ';\n 375→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 376→\n 377→    renderedText = fullText;\n 378→    pendingChars = 0;\n 379→    lastFlushAt = now;\n 380→  }\n 381→\n 382→  function enqueueRender(force = false) {\n 383→    flushChain = flushChain.then(() => render(force));\n 384→  }\n 385→\n 386→  return {\n 387→    push(text) {\n 388→      const appendText = text ?? '';\n 389→      if (!appendText) {\n 390→        return;\n 391→      }\n 392→      fullText += appendText;\n 393→      pendingChars += appendText.length;\n 394→      enqueueRender(false);\n 395→    },\n 396→    setFinalText(text) {\n 397→      fullText = text ?? '';\n 398→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 399→      enqueueRender(true);\n 400→    },\n 401→    async finish() {\n 402→      enqueueRender(true);\n 403→      await flushChain;\n 404→      return {\n 405→        outputLength: renderedText.length,\n 406→        messageCount: publishedMessageCount\n 407→      };\n 408→    }\n 409→  };\n 410→}\n 411→\n 412→function buildSessionId(ctx) {\n 413→  return String(ctx.chat.id);\n 414→}\n 415→\n 416→function ensureAllowed(ctx) {\n 417→  const userId = ctx.from?.id;\n 418→  if (!isAllowedUser(userId)) {\n 419→    throw new Error('当前账号未被授权使用该机器人。');\n 420→  }\n 421→}\n 422→\n 423→/**\n 424→ * Register all pipeline-related commands.\n 425→ */\n 426→function registerPipelineCommands() {\n 427→  registerCommand(pipelineMeta, handlePipeline);\n 428→  registerCommand(bugfixMeta, handleBugfix);\n 429→  registerCommand(plannerMeta, handlePlanner);\n 430→  registerCommand(statusMeta, handleStatus);\n 431→  registerCommand(logsMeta, handleLogs);\n 432→  registerCommand(stopMeta, handleStop);\n 433→  registerCommand(planMeta, handlePlan);\n 434→  registerCommand(auditMeta, handleAudit);\n 435→  registerCommand(commitMeta, handleCommit);\n 436→  registerCommand(commitsMeta, handleCommits);\n 437→}\n 438→\n 439→export function createTelegramBot() {\n 440→  const bot = new Telegraf(config.telegramBotToken, {\n 441→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 442→  });\n 443→\n 444→  // Register pipeline commands\n 445→  registerPipelineCommands();\n 446→\n 447→  bot.catch((error, ctx) => {\n 448→    const message = error instanceof Error ? error.message : String(error);\n 449→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 450→  });\n 451→\n 452→  bot.start(async (ctx) => {\n 453→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 454→  });\n 455→\n 456→  bot.help(async (ctx) => {\n 457→    const helpText = generateHelp();\n 458→    await ctx.reply(helpText);\n 459→  });\n 460→\n 461→  bot.command('reset', async (ctx) => {\n 462→    try {\n 463→      ensureAllowed(ctx);\n 464→      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 465→      await ctx.reply('已清空当前会话上下文。');\n 466→    } catch (error) {\n 467→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 468→    }\n 469→  });\n 470→\n 471→  bot.command('screenshot', async (ctx) => {\n 472→    try {\n 473→      ensureAllowed(ctx);\n 474→      await ctx.reply('正在获取截图。');\n 475→      const { buffer } = await captureScreenshot();\n 476→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 477→    } catch (error) {\n 478→      const message = error instanceof Error ? error.message : String(error);\n 479→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 480→      await ctx.reply(`截图失败：${message}`);\n 481→    }\n 482→  });\n 483→\n 484→  bot.command('exec', async (ctx) => {\n 485→    try {\n 486→      ensureAllowed(ctx);\n 487→      const payload = ctx.message.text.replace('/exec', '').trim();\n 488→      if (!payload) {\n 489→        await ctx.reply('请提供命令，例如 /exec pwd');\n 490→        return;\n 491→      }\n 492→\n 493→      await ctx.reply('正在执行命令。');\n 494→      const result = await executeSystemCommand(payload);\n 495→      const output = [\n 496→        `exitCode: ${result.exitCode}`,\n 497→        result.stdout ? `stdout:\\n${result.stdout}` : 'stdout: (empty)',\n 498→        result.stderr ? `stderr:\\n${result.stderr}` : 'stderr: (empty)'\n 499→      ].join('\\n\\n');\n 500→\n 501→      await replyLargeText(ctx, output);\n 502→    } catch (error) {\n 503→      const message = error instanceof Error ? error.message : String(error);\n 504→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 505→      await ctx.reply(`执行失败：${message}`);\n 506→    }\n 507→  });\n 508→\n 509→  // T-100: Document upload handler for plan files\n 510→  bot.on('document', async (ctx) => {\n 511→    try {\n 512→      ensureAllowed(ctx);\n 513→\n 514→      const document = ctx.message?.document;\n 515→      if (!document) {\n 516→        return;\n 517→      }\n 518→\n 519→      // Check file extension\n 520→      const fileName = document.file_name || '';\n 521→      const ext = path.extname(fileName).toLowerCase();\n 522→\n 523→      if (ext !== '.json') {\n 524→        // Not a JSON file, ignore silently (other handlers may process it)\n 525→        return;\n 526→      }\n 527→\n 528→      // Check file size\n 529→      const fileSize = document.file_size || 0;\n 530→      if (fileSize > 1024 * 1024) { // 1MB limit\n 531→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 532→        return;\n 533→      }\n 534→\n 535→      await ctx.reply('正在处理上传的计划文件...');\n 536→\n 537→      // Download file content\n 538→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 539→      const fileUrl = fileLink.href || fileLink.toString();\n 540→\n 541→      const response = await fetch(fileUrl);\n 542→      if (!response.ok) {\n 543→        throw new Error(`下载文件失败: ${response.status}`);\n 544→      }\n 545→\n 546→      const content = await response.text();\n 547→\n 548→      // Validate and save using plan-ingestion-service\n 549→      const infraConfig = loadPipelineInfraConfig();\n 550→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 551→\n 552→      const validationResult = planService.validate(content);\n 553→\n 554→      if (!validationResult.valid) {\n 555→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 556→        await ctx.reply(errorMsg);\n 557→        return;\n 558→      }\n 559→\n 560→      // Save the plan\n 561→      const saveResult = await planService.save(\n 562→        validationResult.type,\n 563→        content,\n 564→        { uploadedBy: ctx.from?.id }\n 565→      );\n 566→\n 567→      if (!saveResult.success) {\n 568→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 569→        return;\n 570→      }\n 571→\n 572→      // Set as current version\n 573→      await planService.setCurrent(validationResult.type, saveResult.version);\n 574→\n 575→      // Format success message\n 576→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 577→      const summary = validationResult.summary;\n 578→\n 579→      await ctx.reply([\n 580→        `✅ ${typeDisplay}已保存并激活`,\n 581→        `版本: ${saveResult.version}`,\n 582→        `名称: ${summary?.name || '未知'}`,\n 583→        `项目数: ${summary?.itemCount || 0}`,\n 584→        '',\n 585→        summary?.statusBreakdown ? '状态分布:' : '',\n 586→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 587→      ].filter(Boolean).join('\\n'));\n 588→\n 589→    } catch (error) {\n 590→      const message = error instanceof Error ? error.message : String(error);\n 591→      logger.error({ err: message }, 'Failed to process document upload');\n 592→      await ctx.reply(`❌ 处理失败：${message}`);\n 593→    }\n 594→  });\n 595→\n 596→  bot.on('text', async (ctx) => {\n 597→    // Check for pipeline commands first\n 598→    const handled = await routeCommand(ctx);\n 599→    if (handled) {\n 600→      return;\n 601→    }\n 602→\n 603→    const sessionId = buildSessionId(ctx);\n 604→\n 605→    let typingTimer = null;\n 606→\n 607→    try {\n 608→      ensureAllowed(ctx);\n 609→      await ctx.sendChatAction('typing');\n 610→\n 611→      const streamPublisher = createEditableStreamPublisher(ctx);\n 612→      typingTimer = setInterval(() => {\n 613→        ctx.sendChatAction('typing').catch(() => undefined);\n 614→      }, TYPING_INTERVAL_MS);\n 615→\n 616→      const reply = await chatWithSession({\n 617→        channel: 'telegram',\n 618→        sessionId,\n 619→        message: ctx.message.text,\n 620→        realtimeHooks: {\n 621→          onStatus: ({ stage }) => {\n 622→            if (stage === 'running') {\n 623→              ctx.sendChatAction('typing').catch(() => undefined);\n 624→            }\n 625→          },\n 626→          onAssistantChunk: ({ text }) => {\n 627→            streamPublisher.push(text);\n 628→          }\n 629→        }\n 630→      });\n 631→\n 632→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 633→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 634→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 635→\n 636→      streamPublisher.setFinalText(finalText);\n 637→      const streamed = await streamPublisher.finish();\n 638→      if (streamed.outputLength === 0) {\n 639→        await replyLargeText(ctx, finalText);\n 640→      }\n 641→\n 642→      if (fileRefs.length > 0) {\n 643→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 644→        const failed = fileSendResults.filter((item) => !item.sent);\n 645→\n 646→        if (failed.length === 0) {\n 647→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 648→        } else {\n 649→          const failedList = failed\n 650→            .map((item) => {\n 651→              const reason =\n 652→                item.reason === 'relative_path_not_allowed'\n 653→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 654→                  : item.reason === 'not_found'\n 655→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 656→                    : item.reason;\n 657→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 658→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 659→            })\n 660→            .join('\\n');\n 661→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 662→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 663→        }\n 664→      }\n 665→    } catch (error) {\n 666→      const message = error instanceof Error ? error.message : String(error);\n 667→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 668→      await safeReply(ctx, `处理失败：${message}`);\n 669→    } finally {\n 670→      if (typingTimer) {\n 671→        clearInterval(typingTimer);\n 672→      }\n 673→    }\n 674→  });\n 675→\n 676→  return bot;\n 677→}\n 678→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce343eca564fbbcc1a3941371d2af","__timestamp":"2026-03-12T18:17:15.930Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
