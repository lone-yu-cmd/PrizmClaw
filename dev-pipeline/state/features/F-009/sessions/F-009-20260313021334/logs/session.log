pt(sessionKey, channel) { /* ... */ }\n 377→  addCommit(sessionKey, commitInfo) { /* ... */ }\n 378→  getCommits(sessionKey) { /* ... */ }\n 379→  getLastCommit(sessionKey) { /* ... */ }\n 380→}\n 381→\n 382→export const sessionStore = new SessionStore();\n 383→```\n 384→\n 385→### src/bot/telegram.js (exec command handler)\n 386→```javascript\n 387→bot.command('exec', async (ctx) => {\n 388→  try {\n 389→    ensureAllowed(ctx);\n 390→    const payload = ctx.message.text.replace('/exec', '').trim();\n 391→    if (!payload) {\n 392→      await ctx.reply('请提供命令，例如 /exec pwd');\n 393→      return;\n 394→    }\n 395→\n 396→    await ctx.reply('正在执行命令。');\n 397→    const result = await executeSystemCommand(payload);\n 398→    const output = [\n 399→      `exitCode: ${result.exitCode}`,\n 400→      result.stdout ? `stdout:\\n${result.stdout}` : 'stdout: (empty)',\n 401→      result.stderr ? `stderr:\\n${result.stderr}` : 'stderr: (empty)'\n 402→    ].join('\\n\\n');\n 403→\n 404→    await replyLargeText(ctx, output);\n 405→  } catch (error) {\n 406→    const message = error instanceof Error ? error.message : String(error);\n 407→    logger.error({ err: message }, 'Failed to exec command in telegram');\n 408→    await ctx.reply(`执行失败：${message}`);\n 409→  }\n 410→});\n 411→```\n 412→\n 413→---\n 414→\n 415→## Section 5 - Existing Tests\n 416→\n 417→### tests/security/permission-guard.test.js (excerpts)\n 418→```javascript\n 419→test('getUserRole returns operator as default for unknown users (AC-1.3)', () => {\n 420→  resetConfig();\n 421→  setConfigForTesting(createTestConfig());\n 422→  assert.equal(getUserRole('unknown-user'), 'operator');\n 423→});\n 424→\n 425→test('checkCommandPermission denies exec when ENABLE_SYSTEM_EXEC is false', () => {\n 426→  const config = createTestConfig({ enableSystemExec: false });\n 427→  config.userPermissions.set('admin-user', 'admin');\n 428→  setConfigForTesting(config);\n 429→  const result = checkCommandPermission('admin-user', 'exec');\n 430→  assert.equal(result.allowed, false);\n 431→  assert.ok(result.reason.includes('系统命令执行未启用'));\n 432→});\n 433→\n 434→test('checkCommandPermission allows admin for exec when ENABLE_SYSTEM_EXEC is true', () => {\n 435→  const config = createTestConfig({ enableSystemExec: true });\n 436→  config.userPermissions.set('admin-user', 'admin');\n 437→  setConfigForTesting(config);\n 438→  const result = checkCommandPermission('admin-user', 'exec');\n 439→  assert.equal(result.allowed, true);\n 440→});\n 441→```\n 442→\n 443→### tests/security/param-sanitizer.test.js (test patterns reference)\n 444→- Tests for path traversal detection\n 445→- Tests for shell injection detection\n 446→- Tests for command chain detection\n 447→- Tests for safe parameter handling\n 448→- Tests for targetId validation\n 449→\n 450→### tests/security/confirmation-manager.test.js (test patterns reference)\n 451→- Tests for confirmation creation with timeout\n 452→- Tests for confirmation confirmation flow\n 453→- Tests for expired confirmation handling\n 454→- Tests for userId verification\n 455→\n 456→---\n 457→\n 458→## Section 6 - Design Notes for F-009\n 459→\n 460→### Key Design Decisions Needed\n 461→\n 462→1. **Direct Text Mode vs /exec Prefix**\n 463→   - When ENABLE_SYSTEM_EXEC=true, plain text messages should be treated as shell commands\n 464→   - Need to distinguish between \"chat with AI\" vs \"execute command\" modes\n 465→   - Option: Use a prefix marker or dedicated mode toggle\n 466→\n 467→2. **Session Working Directory**\n 468→   - Store cwd per session in session-store.js\n 469→   - Default to project root or process.cwd()\n 470→   - /cd command updates session's cwd\n 471→\n 472→3. **Long Output Pagination**\n 473→   - Telegram max message: 4096 chars\n 474→   - Store paginated output in session state\n 475→   - /more command retrieves next chunk\n 476→\n 477→4. **High-Risk Command Detection**\n 478→   - Keywords: rm -rf, sudo, kill, chmod -R, chown, dd, mkfs, etc.\n 479→   - Use confirmation-manager for flow\n 480→   - Blacklist in addition to whitelist\n 481→\n 482→5. **Graceful Timeout Handling**\n 483→   - SIGTERM first, wait for graceful shutdown\n 484→   - SIGKILL after additional grace period\n 485→   - User notification of timeout and termination status\n 486→\n 487→### Files to Create/Modify\n 488→\n 489→**New Files:**\n 490→- `src/services/command-executor-service.js` - Enhanced command execution with cwd, pagination\n 491→- `src/services/output-pager-service.js` - Long output pagination storage\n 492→- `src/bot/commands/handlers/cd.js` - /cd command handler\n 493→- `src/bot/commands/handlers/more.js` - /more command handler\n 494→- `tests/services/command-executor-service.test.js`\n 495→- `tests/services/output-pager-service.test.js`\n 496→- `tests/bot/commands/handlers/cd.test.js`\n 497→- `tests/bot/commands/handlers/more.test.js`\n 498→\n 499→**Modified Files:**\n 500→- `src/config.js` - Add COMMAND_BLACKLIST, HIGH_RISK_KEYWORDS config\n 501→- `src/services/session-store.js` - Add cwd tracking per session\n 502→- `src/bot/telegram.js` - Text handler for direct command mode\n 503→- `src/security/permission-guard.js` - Add 'cd', 'more' command permissions\n 504→- `src/security/system-guard.js` - Add blacklist check, high-risk detection\n 505→- `src/services/system-exec-service.js` - Enhanced timeout with SIGTERM→SIGKILL\n 506→\n 507→---\n 508→\n 509→## Section 7 - Implementation Log\n 510→\n 511→### Files Created\n 512→\n 513→| Path | Purpose |\n 514→|------|---------|\n 515→| `src/services/command-executor-service.js` | Main command execution service with blacklist check, high-risk keyword detection, confirmation flow, session cwd, output pagination |\n 516→| `src/services/output-pager-service.js` | Pagination service for long output (4000 char chunks) |\n 517→| `src/bot/commands/handlers/cd.js` | /cd command handler for changing working directory |\n 518→| `src/bot/commands/handlers/more.js` | /more command handler