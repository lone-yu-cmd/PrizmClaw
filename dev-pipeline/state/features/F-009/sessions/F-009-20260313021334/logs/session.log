{"type":"assistant","uuid":"20260313023542ee042865119546fb","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"id":"20260313023542ee042865119546fb","content":[{"type":"tool_use","id":"call_8f2721b0c9054682aed1a7d1","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/telegram.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":31176,"output_tokens":97,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce354b726b8a4df5dbec4c5680ecb","__timestamp":"2026-03-12T18:35:47.583Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"32e948f2-61f6-4e57-9793-4a47671bc3cd","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"call_27f5b0eb82414fc48044eb5c","content":[{"type":"text","text":"   1→import { spawn } from 'node:child_process';\n   2→import { config } from '../config.js';\n   3→import { assertAllowedCommand, assertSystemExecEnabled } from '../security/system-guard.js';\n   4→\n   5→/**\n   6→ * Grace period after SIGTERM before SIGKILL (in ms)\n   7→ */\n   8→const GRACE_PERIOD_MS = 5000;\n   9→\n  10→/**\n  11→ * Execute a system command with optional working directory.\n  12→ * @param {string} command - Command to execute\n  13→ * @param {Object} [options] - Execution options\n  14→ * @param {string} [options.cwd] - Working directory for the command\n  15→ * @returns {Promise<{ stdout: string, stderr: string, exitCode: number, timedOut: boolean }>}\n  16→ */\n  17→export async function executeSystemCommand(command, options = {}) {\n  18→  assertSystemExecEnabled();\n  19→  const safeCommand = assertAllowedCommand(command);\n  20→\n  21→  const cwd = options.cwd || process.cwd();\n  22→\n  23→  return new Promise((resolve, reject) => {\n  24→    const child = spawn(safeCommand, {\n  25→      shell: true,\n  26→      stdio: ['ignore', 'pipe', 'pipe'],\n  27→      cwd\n  28→    });\n  29→\n  30→    let stdout = '';\n  31→    let stderr = '';\n  32→    let timedOut = false;\n  33→    let sigtermSent = false;\n  34→\n  35→    const timeout = setTimeout(() => {\n  36→      timedOut = true;\n  37→      sigtermSent = true;\n  38→      child.kill('SIGTERM');\n  39→\n  40→      // Schedule SIGKILL after grace period\n  41→      setTimeout(() => {\n  42→        if (!child.killed) {\n  43→          child.kill('SIGKILL');\n  44→        }\n  45→      }, GRACE_PERIOD_MS);\n  46→    }, config.systemExecTimeoutMs);\n  47→\n  48→    child.stdout.on('data', (chunk) => {\n  49→      stdout += chunk.toString();\n  50→    });\n  51→\n  52→    child.stderr.on('data', (chunk) => {\n  53→      stderr += chunk.toString();\n  54→    });\n  55→\n  56→    child.on('error', (error) => {\n  57→      clearTimeout(timeout);\n  58→      reject(new Error(`系统命令执行失败: ${error.message}`));\n  59→    });\n  60→\n  61→    child.on('close', (code) => {\n  62→      clearTimeout(timeout);\n  63→\n  64→      if (timedOut) {\n  65→        // Resolve with timeout status instead of rejecting\n  66→        resolve({\n  67→          stdout: stdout.trim(),\n  68→          stderr: stderr.trim(),\n  69→          exitCode: code ?? -1,\n  70→          timedOut: true\n  71→        });\n  72→      } else {\n  73→        resolve({\n  74→          stdout: stdout.trim(),\n  75→          stderr: stderr.trim(),\n  76→          exitCode: code ?? -1,\n  77→          timedOut: false\n  78→        });\n  79→      }\n  80→    });\n  81→  });\n  82→}\n  83→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce354b726b8a4df5dbec4c5680ecb","__timestamp":"2026-03-12T18:35:47.598Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"26d3dc66-90f1-4b1c-ac6c-a5b0f71317c4","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"call_841b63ba30f54709a33ef5f8","content":[{"type":"text","text":"   1→/**\n   2→ * Permission Guard Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides user permission tiers and command authorization checking.\n   6→ */\n   7→\n   8→import { config } from '../config.js';\n   9→\n  10→/**\n  11→ * Role hierarchy levels (higher = more permissions)\n  12→ */\n  13→export const ROLE_HIERARCHY = {\n  14→  viewer: 0,\n  15→  operator: 1,\n  16→  admin: 2\n  17→};\n  18→\n  19→/**\n  20→ * Minimum required role for each command\n  21→ */\n  22→const COMMAND_MIN_ROLE = {\n  23→  status: 'viewer',\n  24→  logs: 'viewer',\n  25→  commits: 'viewer',\n  26→  // F-009: cd and more commands\n  27→  cd: 'operator',\n  28→  more: 'viewer',\n  29→  pipeline: 'operator',\n  30→  bugfix: 'operator',\n  31→  planner: 'operator',\n  32→  retry: 'operator',\n  33→  commit: 'operator',\n  34→  stop: 'admin',\n  35→  reset: 'admin',\n  36→  'force-unlock': 'admin',\n  37→  exec: 'admin',\n  38→  'commit-amend': 'admin',\n  39→  'commit-force': 'admin'\n  40→};\n  41→\n  42→/**\n  43→ * High-risk commands that require confirmation\n  44→ */\n  45→const HIGH_RISK_COMMANDS = new Set(['stop', 'reset', 'force-unlock', 'commit-amend', 'commit-force']);\n  46→\n  47→/**\n  48→ * Internal config reference - can be overridden for testing\n  49→ * @type {Object}\n  50→ */\n  51→let _config = config;\n  52→\n  53→/**\n  54→ * Set config for testing purposes\n  55→ * @param {Object} testConfig\n  56→ */\n  57→export function setConfigForTesting(testConfig) {\n  58→  _config = testConfig;\n  59→}\n  60→\n  61→/**\n  62→ * Reset config to original (for testing cleanup)\n  63→ */\n  64→export function resetConfig() {\n  65→  _config = config;\n  66→}\n  67→\n  68→/**\n  69→ * Get user permission level\n  70→ * @param {string|number} userId - Telegram user ID\n  71→ * @returns {'admin'|'operator'|'viewer'}\n  72→ */\n  73→export function getUserRole(userId) {\n  74→  const userIdStr = String(userId);\n  75→  const configuredRole = _config.userPermissions.get(userIdStr);\n  76→\n  77→  if (configuredRole) {\n  78→    return configuredRole;\n  79→  }\n  80→\n  81→  // Default to operator for unknown users (AC-1.3)\n  82→  return 'operator';\n  83→}\n  84→\n  85→/**\n  86→ * Check if user is admin\n  87→ * @param {string|number} userId\n  88→ * @returns {boolean}\n  89→ */\n  90→export function isAdmin(userId) {\n  91→  return getUserRole(userId) === 'admin';\n  92→}\n  93→\n  94→/**\n  95→ * Check if user can execute command\n  96→ * @param {string|number} userId\n  97→ * @param {string} command - Command name\n  98→ * @returns {{ allowed: boolean, requiresConfirmation: boolean, reason?: string }}\n  99→ */\n 100→export function checkCommandPermission(userId, command) {\n 101→  const userRole = getUserRole(userId);\n 102→  const minRole = COMMAND_MIN_ROLE[command] || 'viewer';\n 103→\n 104→  // Special handling for exec command (AC-2.4, F-002)\n 105→  if (command === 'exec' && !_config.enableSystemExec) {\n 106→    return {\n 107→      allowed: false,\n 108→      requiresConfirmation: false,\n 109→      reason: '系统命令执行未启用。请在 .env 中设置 ENABLE_SYSTEM_EXEC=true。'\n 110→    };\n 111→  }\n 112→\n 113→  // Check role hierarchy\n 114→  const userLevel = ROLE_HIERARCHY[userRole];\n 115→  const requiredLevel = ROLE_HIERARCHY[minRole];\n 116→\n 117→  if (userLevel < requiredLevel) {\n 118→    return {\n 119→      allowed: false,\n 120→      requiresConfirmation: false,\n 121→      reason: `权限不足。此命令需要 ${minRole} 权限，当前权限: ${userRole}。`\n 122→    };\n 123→  }\n 124→\n 125→  // Check if this is a high-risk command requiring confirmation\n 126→  const requiresConfirmation = HIGH_RISK_COMMANDS.has(command);\n 127→\n 128→  return {\n 129→    allowed: true,\n 130→    requiresConfirmation\n 131→  };\n 132→}\n 133→\n 134→export default {\n 135→  getUserRole,\n 136→  checkCommandPermission,\n 137→  isAdmin,\n 138→  ROLE_HIERARCHY,\n 139→  setConfigForTesting,\n 140→  resetConfig\n 141→};\n 142→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce354b726b8a4df5dbec4c5680ecb","__timestamp":"2026-03-12T18:35:47.605Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
{"type":"user","uuid":"3c52a66c-f981-4404-a767-ab449186200b","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"call_8f2721b0c9054682aed1a7d1","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { captureScreenshot } from '../services/screenshot-service.js';\n  11→import { executeCommand, confirmHighRiskCommand } from '../services/command-executor-service.js';\n  12→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  13→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  14→import { registerCommand } from './commands/index.js';\n  15→import { routeCommand } from './commands/index.js';\n  16→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  17→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  18→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  19→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  20→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  21→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  22→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  23→import { auditMeta, handleAudit } from './commands/handlers/audit.js';\n  24→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n  25→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n  26→// F-009: New command handlers\n  27→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n  28→import { moreMeta, handleMore } from './commands/handlers/more.js';\n  29→import { generateHelp } from './commands/help.js';\n  30→import { sessionStore } from '../services/session-store.js';\n  31→\n  32→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  33→const STREAM_MIN_CHARS = 220;\n  34→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  35→const TYPING_INTERVAL_MS = 3500;\n  36→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  37→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  38→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  39→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  40→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  41→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  42→const TMP_DIR = path.resolve(os.tmpdir());\n  43→const HOME_DIR = path.resolve(os.homedir());\n  44→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  45→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  46→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  47→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  48→\n  49→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  50→  const normalized = configuredDirs\n  51→    .map((dir) => String(dir ?? '').trim())\n  52→    .filter(Boolean)\n  53→    .map((dir) => path.resolve(dir));\n  54→\n  55→  if (normalized.length > 0) {\n  56→    return [...new Set(normalized)];\n  57→  }\n  58→\n  59→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  60→}\n  61→\n  62→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  63→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  64→\n  65→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  66→  const chunks = [];\n  67→  for (let i = 0; i < text.length; i += chunkSize) {\n  68→    chunks.push(text.slice(i, i + chunkSize));\n  69→  }\n  70→  return chunks;\n  71→}\n  72→\n  73→function sanitizeMarkerPath(raw) {\n  74→  return String(raw ?? '')\n  75→    .trim()\n  76→    .replace(/^['\"`]+/, '')\n  77→    .replace(/['\"`]+$/, '');\n  78→}\n  79→\n  80→function extractFileMarkers(text = '') {\n  81→  const fileRefs = [];\n  82→\n  83→  const withSendFileRemoved = text.replace(\n  84→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  85→    (_full, rawRef) => {\n  86→      const ref = sanitizeMarkerPath(rawRef);\n  87→      if (ref) {\n  88→        fileRefs.push(ref);\n  89→      }\n  90→      return '\\n';\n  91→    }\n  92→  );\n  93→\n  94→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n  95→    const ref = sanitizeMarkerPath(rawRef);\n  96→    if (ref) {\n  97→      fileRefs.push(ref);\n  98→    }\n  99→    return '';\n 100→  });\n 101→\n 102→  const withBacktickPathRemoved = withImageRemoved.replace(\n 103→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 104→    (_full, rawRef) => {\n 105→      const ref = sanitizeMarkerPath(rawRef);\n 106→      if (ref) {\n 107→        fileRefs.push(ref);\n 108→      }\n 109→      return '';\n 110→    }\n 111→  );\n 112→\n 113→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 114→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 115→    (_full, rawRef) => {\n 116→      const ref = sanitizeMarkerPath(rawRef);\n 117→      if (ref) {\n 118→        fileRefs.push(ref);\n 119→      }\n 120→      return '';\n 121→    }\n 122→  );\n 123→\n 124→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 125→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 126→    (_full, rawRef) => {\n 127→      const ref = sanitizeMarkerPath(rawRef);\n 128→      if (ref) {\n 129→        fileRefs.push(ref);\n 130→      }\n 131→      return '\\n';\n 132→    }\n 133→  );\n 134→\n 135→  return {\n 136→    fileRefs: [...new Set(fileRefs)],\n 137→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 138→  };\n 139→}\n 140→\n 141→function isPathWithinRoot(targetPath, rootPath) {\n 142→  const relative = path.relative(rootPath, targetPath);\n 143→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 144→}\n 145→\n 146→function isAllowedFilePath(filePath) {\n 147→  const resolved = path.resolve(filePath);\n 148→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 149→}\n 150→\n 151→function buildFileCandidates(normalizedPath) {\n 152→  if (path.isAbsolute(normalizedPath)) {\n 153→    return [normalizedPath];\n 154→  }\n 155→\n 156→  const baseName = path.basename(normalizedPath);\n 157→  const candidates = [\n 158→    path.resolve(process.cwd(), normalizedPath),\n 159→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 160→  ];\n 161→\n 162→  return [...new Set(candidates)];\n 163→}\n 164→\n 165→async function resolveLocalFilePath(fileRef) {\n 166→  const normalized = sanitizeMarkerPath(fileRef);\n 167→  if (!normalized) {\n 168→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 169→  }\n 170→\n 171→  if (!path.isAbsolute(normalized)) {\n 172→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 173→  }\n 174→\n 175→  const candidates = buildFileCandidates(normalized);\n 176→\n 177→  for (const candidate of candidates) {\n 178→    try {\n 179→      await access(candidate);\n 180→      return { filePath: candidate, triedPaths: candidates };\n 181→    } catch {\n 182→      // ignore\n 183→    }\n 184→  }\n 185→\n 186→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 187→}\n 188→\n 189→async function validateFileForTelegram(filePath) {\n 190→  const resolvedPath = path.resolve(filePath);\n 191→  if (!isAllowedFilePath(resolvedPath)) {\n 192→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 193→  }\n 194→\n 195→  const ext = path.extname(resolvedPath).toLowerCase();\n 196→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 197→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 198→  }\n 199→\n 200→  const fileStat = await stat(resolvedPath);\n 201→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 202→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 203→\n 204→  if (fileStat.size > maxSize) {\n 205→    return {\n 206→      ok: false,\n 207→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 208→    };\n 209→  }\n 210→\n 211→  return { ok: true, isPhoto, resolvedPath };\n 212→}\n 213→\n 214→function isTimeoutLikeError(message = '') {\n 215→  const normalized = String(message).toLowerCase();\n 216→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 217→}\n 218→\n 219→function sleep(ms) {\n 220→  return new Promise((resolve) => setTimeout(resolve, ms));\n 221→}\n 222→\n 223→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 224→  if (isPhoto) {\n 225→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 226→    return;\n 227→  }\n 228→\n 229→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 230→}\n 231→\n 232→async function replyFiles(ctx, fileRefs = []) {\n 233→  const results = [];\n 234→\n 235→  for (const fileRef of fileRefs) {\n 236→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 237→    if (!filePath) {\n 238→      const reason = rejectReason || 'not_found';\n 239→      results.push({ fileRef, sent: false, reason, triedPaths });\n 240→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 241→      continue;\n 242→    }\n 243→\n 244→    try {\n 245→      const validation = await validateFileForTelegram(filePath);\n 246→      if (!validation.ok) {\n 247→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 248→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 249→        continue;\n 250→      }\n 251→\n 252→      const actualPath = validation.resolvedPath;\n 253→      let sent = false;\n 254→      let lastReason = '';\n 255→\n 256→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 257→        try {\n 258→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 259→          sent = true;\n 260→          logger.info(\n 261→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 262→            'Telegram file sent'\n 263→          );\n 264→          break;\n 265→        } catch (error) {\n 266→          lastReason = error instanceof Error ? error.message : String(error);\n 267→          logger.warn(\n 268→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 269→            'Telegram file send attempt failed'\n 270→          );\n 271→\n 272→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 273→            await sleep(600);\n 274→            continue;\n 275→          }\n 276→\n 277→          break;\n 278→        }\n 279→      }\n 280→\n 281→      if (!sent) {\n 282→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 283→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 284→        continue;\n 285→      }\n 286→\n 287→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 288→    } catch (error) {\n 289→      const reason = error instanceof Error ? error.message : String(error);\n 290→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 291→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 292→    }\n 293→  }\n 294→\n 295→  return results;\n 296→}\n 297→\n 298→async function safeReply(ctx, text) {\n 299→  try {\n 300→    await ctx.reply(text);\n 301→    return true;\n 302→  } catch (error) {\n 303→    const reason = error instanceof Error ? error.message : String(error);\n 304→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 305→    return false;\n 306→  }\n 307→}\n 308→\n 309→async function replyLargeText(ctx, text) {\n 310→  const chunks = splitMessage(text);\n 311→  for (const chunk of chunks) {\n 312→    const ok = await safeReply(ctx, chunk);\n 313→    if (!ok) {\n 314→      break;\n 315→    }\n 316→  }\n 317→}\n 318→\n 319→async function safeEditMessageText(ctx, messageId, text) {\n 320→  const nextText = text && text.trim() ? text : ' ';\n 321→\n 322→  try {\n 323→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 324→  } catch (error) {\n 325→    const message = error instanceof Error ? error.message : String(error);\n 326→    if (message.includes('message is not modified')) {\n 327→      return;\n 328→    }\n 329→    throw error;\n 330→  }\n 331→}\n 332→\n 333→function createEditableStreamPublisher(ctx) {\n 334→  let fullText = '';\n 335→  let renderedText = '';\n 336→  let pendingChars = 0;\n 337→  let lastFlushAt = 0;\n 338→  let flushChain = Promise.resolve();\n 339→  let activeMessage = null;\n 340→  let activeSegmentIndex = 0;\n 341→  let publishedMessageCount = 0;\n 342→\n 343→  async function ensureActiveMessage() {\n 344→    if (activeMessage) {\n 345→      return;\n 346→    }\n 347→    activeMessage = await ctx.reply('处理中...');\n 348→    activeSegmentIndex = 0;\n 349→    publishedMessageCount += 1;\n 350→  }\n 351→\n 352→  async function render(force = false) {\n 353→    const now = Date.now();\n 354→\n 355→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 356→      return;\n 357→    }\n 358→\n 359→    if (fullText === renderedText) {\n 360→      pendingChars = 0;\n 361→      return;\n 362→    }\n 363→\n 364→    await ensureActiveMessage();\n 365→\n 366→    const segments = splitMessage(fullText);\n 367→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 368→\n 369→    while (activeSegmentIndex < targetLastIndex) {\n 370→      const text = segments[activeSegmentIndex] ?? ' ';\n 371→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 372→\n 373→      activeMessage = await ctx.reply('继续输出中...');\n 374→      activeSegmentIndex += 1;\n 375→      publishedMessageCount += 1;\n 376→    }\n 377→\n 378→    const activeText = segments[targetLastIndex] ?? ' ';\n 379→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 380→\n 381→    renderedText = fullText;\n 382→    pendingChars = 0;\n 383→    lastFlushAt = now;\n 384→  }\n 385→\n 386→  function enqueueRender(force = false) {\n 387→    flushChain = flushChain.then(() => render(force));\n 388→  }\n 389→\n 390→  return {\n 391→    push(text) {\n 392→      const appendText = text ?? '';\n 393→      if (!appendText) {\n 394→        return;\n 395→      }\n 396→      fullText += appendText;\n 397→      pendingChars += appendText.length;\n 398→      enqueueRender(false);\n 399→    },\n 400→    setFinalText(text) {\n 401→      fullText = text ?? '';\n 402→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 403→      enqueueRender(true);\n 404→    },\n 405→    async finish() {\n 406→      enqueueRender(true);\n 407→      await flushChain;\n 408→      return {\n 409→        outputLength: renderedText.length,\n 410→        messageCount: publishedMessageCount\n 411→      };\n 412→    }\n 413→  };\n 414→}\n 415→\n 416→function buildSessionId(ctx) {\n 417→  return String(ctx.chat.id);\n 418→}\n 419→\n 420→function ensureAllowed(ctx) {\n 421→  const userId = ctx.from?.id;\n 422→  if (!isAllowedUser(userId)) {\n 423→    throw new Error('当前账号未被授权使用该机器人。');\n 424→  }\n 425→}\n 426→\n 427→/**\n 428→ * Register all pipeline-related commands.\n 429→ */\n 430→function registerPipelineCommands() {\n 431→  registerCommand(pipelineMeta, handlePipeline);\n 432→  registerCommand(bugfixMeta, handleBugfix);\n 433→  registerCommand(plannerMeta, handlePlanner);\n 434→  registerCommand(statusMeta, handleStatus);\n 435→  registerCommand(logsMeta, handleLogs);\n 436→  registerCommand(stopMeta, handleStop);\n 437→  registerCommand(planMeta, handlePlan);\n 438→  registerCommand(auditMeta, handleAudit);\n 439→  registerCommand(commitMeta, handleCommit);\n 440→  registerCommand(commitsMeta, handleCommits);\n 441→  // F-009: New commands\n 442→  registerCommand(cdMeta, handleCd);\n 443→  registerCommand(moreMeta, handleMore);\n 444→}\n 445→\n 446→export function createTelegramBot() {\n 447→  const bot = new Telegraf(config.telegramBotToken, {\n 448→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 449→  });\n 450→\n 451→  // Register pipeline commands\n 452→  registerPipelineCommands();\n 453→\n 454→  bot.catch((error, ctx) => {\n 455→    const message = error instanceof Error ? error.message : String(error);\n 456→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 457→  });\n 458→\n 459→  bot.start(async (ctx) => {\n 460→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 461→  });\n 462→\n 463→  bot.help(async (ctx) => {\n 464→    const helpText = generateHelp();\n 465→    await ctx.reply(helpText);\n 466→  });\n 467→\n 468→  bot.command('reset', async (ctx) => {\n 469→    try {\n 470→      ensureAllowed(ctx);\n 471→      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 472→      await ctx.reply('已清空当前会话上下文。');\n 473→    } catch (error) {\n 474→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 475→    }\n 476→  });\n 477→\n 478→  bot.command('screenshot', async (ctx) => {\n 479→    try {\n 480→      ensureAllowed(ctx);\n 481→      await ctx.reply('正在获取截图。');\n 482→      const { buffer } = await captureScreenshot();\n 483→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 484→    } catch (error) {\n 485→      const message = error instanceof Error ? error.message : String(error);\n 486→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 487→      await ctx.reply(`截图失败：${message}`);\n 488→    }\n 489→  });\n 490→\n 491→  bot.command('exec', async (ctx) => {\n 492→    try {\n 493→      ensureAllowed(ctx);\n 494→      const payload = ctx.message.text.replace('/exec', '').trim();\n 495→      if (!payload) {\n 496→        await ctx.reply('请提供命令，例如 /exec pwd');\n 497→        return;\n 498→      }\n 499→\n 500→      const sessionId = buildSessionId(ctx);\n 501→      const userId = ctx.from?.id;\n 502→\n 503→      await ctx.reply('正在执行命令...');\n 504→      const result = await executeCommand({\n 505→        command: payload,\n 506→        sessionId,\n 507→        userId\n 508→      });\n 509→\n 510→      // Handle confirmation required\n 511→      if (result.needsConfirmation) {\n 512→        await ctx.reply(result.confirmationMessage);\n 513→        return;\n 514→      }\n 515→\n 516→      // Send output\n 517→      await replyLargeText(ctx, result.output);\n 518→\n 519→      // Indicate if more pages available\n 520→      if (result.hasMorePages) {\n 521→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 522→      }\n 523→    } catch (error) {\n 524→      const message = error instanceof Error ? error.message : String(error);\n 525→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 526→      await ctx.reply(`执行失败：${message}`);\n 527→    }\n 528→  });\n 529→\n 530→  // F-009: /cd command handler\n 531→  bot.command('cd', async (ctx) => {\n 532→    try {\n 533→      ensureAllowed(ctx);\n 534→      const payload = ctx.message.text.replace('/cd', '').trim();\n 535→      const sessionId = buildSessionId(ctx);\n 536→\n 537→      await handleCd({\n 538→        ctx,\n 539→        reply: (msg) => ctx.reply(msg),\n 540→        params: {},\n 541→        userId: ctx.from?.id,\n 542→        sessionId,\n 543→        args: payload ? [payload] : []\n 544→      });\n 545→    } catch (error) {\n 546→      const message = error instanceof Error ? error.message : String(error);\n 547→      logger.error({ err: message }, 'Failed to cd in telegram');\n 548→      await ctx.reply(`切换目录失败：${message}`);\n 549→    }\n 550→  });\n 551→\n 552→  // F-009: /more command handler\n 553→  bot.command('more', async (ctx) => {\n 554→    try {\n 555→      ensureAllowed(ctx);\n 556→      const sessionId = buildSessionId(ctx);\n 557→\n 558→      await handleMore({\n 559→        ctx,\n 560→        reply: (msg) => ctx.reply(msg),\n 561→        params: {},\n 562→        userId: ctx.from?.id,\n 563→        sessionId\n 564→      });\n 565→    } catch (error) {\n 566→      const message = error instanceof Error ? error.message : String(error);\n 567→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 568→      await ctx.reply(`获取更多输出失败：${message}`);\n 569→    }\n 570→  });\n 571→\n 572→  // T-100: Document upload handler for plan files\n 573→  bot.on('document', async (ctx) => {\n 574→    try {\n 575→      ensureAllowed(ctx);\n 576→\n 577→      const document = ctx.message?.document;\n 578→      if (!document) {\n 579→        return;\n 580→      }\n 581→\n 582→      // Check file extension\n 583→      const fileName = document.file_name || '';\n 584→      const ext = path.extname(fileName).toLowerCase();\n 585→\n 586→      if (ext !== '.json') {\n 587→        // Not a JSON file, ignore silently (other handlers may process it)\n 588→        return;\n 589→      }\n 590→\n 591→      // Check file size\n 592→      const fileSize = document.file_size || 0;\n 593→      if (fileSize > 1024 * 1024) { // 1MB limit\n 594→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 595→        return;\n 596→      }\n 597→\n 598→      await ctx.reply('正在处理上传的计划文件...');\n 599→\n 600→      // Download file content\n 601→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 602→      const fileUrl = fileLink.href || fileLink.toString();\n 603→\n 604→      const response = await fetch(fileUrl);\n 605→      if (!response.ok) {\n 606→        throw new Error(`下载文件失败: ${response.status}`);\n 607→      }\n 608→\n 609→      const content = await response.text();\n 610→\n 611→      // Validate and save using plan-ingestion-service\n 612→      const infraConfig = loadPipelineInfraConfig();\n 613→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 614→\n 615→      const validationResult = planService.validate(content);\n 616→\n 617→      if (!validationResult.valid) {\n 618→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 619→        await ctx.reply(errorMsg);\n 620→        return;\n 621→      }\n 622→\n 623→      // Save the plan\n 624→      const saveResult = await planService.save(\n 625→        validationResult.type,\n 626→        content,\n 627→        { uploadedBy: ctx.from?.id }\n 628→      );\n 629→\n 630→      if (!saveResult.success) {\n 631→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 632→        return;\n 633→      }\n 634→\n 635→      // Set as current version\n 636→      await planService.setCurrent(validationResult.type, saveResult.version);\n 637→\n 638→      // Format success message\n 639→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 640→      const summary = validationResult.summary;\n 641→\n 642→      await ctx.reply([\n 643→        `✅ ${typeDisplay}已保存并激活`,\n 644→        `版本: ${saveResult.version}`,\n 645→        `名称: ${summary?.name || '未知'}`,\n 646→        `项目数: ${summary?.itemCount || 0}`,\n 647→        '',\n 648→        summary?.statusBreakdown ? '状态分布:' : '',\n 649→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 650→      ].filter(Boolean).join('\\n'));\n 651→\n 652→    } catch (error) {\n 653→      const message = error instanceof Error ? error.message : String(error);\n 654→      logger.error({ err: message }, 'Failed to process document upload');\n 655→      await ctx.reply(`❌ 处理失败：${message}`);\n 656→    }\n 657→  });\n 658→\n 659→  bot.on('text', async (ctx) => {\n 660→    // Check for pipeline commands first\n 661→    const handled = await routeCommand(ctx);\n 662→    if (handled) {\n 663→      return;\n 664→    }\n 665→\n 666→    const sessionId = buildSessionId(ctx);\n 667→    const userId = ctx.from?.id;\n 668→\n 669→    // F-009: Direct exec mode - treat plain text as command when enabled\n 670→    if (config.directExecMode && config.enableSystemExec) {\n 671→      try {\n 672→        ensureAllowed(ctx);\n 673→        const command = ctx.message.text;\n 674→\n 675→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 676→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 677→\n 678→        if (!isLikelyChat) {\n 679→          await ctx.reply('正在执行命令...');\n 680→          const result = await executeCommand({\n 681→            command,\n 682→            sessionId,\n 683→            userId\n 684→          });\n 685→\n 686→          if (result.needsConfirmation) {\n 687→            await ctx.reply(result.confirmationMessage);\n 688→            return;\n 689→          }\n 690→\n 691→          await replyLargeText(ctx, result.output);\n 692→\n 693→          if (result.hasMorePages) {\n 694→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 695→          }\n 696→          return;\n 697→        }\n 698→      } catch (error) {\n 699→        const message = error instanceof Error ? error.message : String(error);\n 700→        // If exec fails, fall through to chat mode\n 701→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n 702→      }\n 703→    }\n 704→\n 705→    let typingTimer = null;\n 706→\n 707→    try {\n 708→      ensureAllowed(ctx);\n 709→      await ctx.sendChatAction('typing');\n 710→\n 711→      const streamPublisher = createEditableStreamPublisher(ctx);\n 712→      typingTimer = setInterval(() => {\n 713→        ctx.sendChatAction('typing').catch(() => undefined);\n 714→      }, TYPING_INTERVAL_MS);\n 715→\n 716→      const reply = await chatWithSession({\n 717→        channel: 'telegram',\n 718→        sessionId,\n 719→        message: ctx.message.text,\n 720→        realtimeHooks: {\n 721→          onStatus: ({ stage }) => {\n 722→            if (stage === 'running') {\n 723→              ctx.sendChatAction('typing').catch(() => undefined);\n 724→            }\n 725→          },\n 726→          onAssistantChunk: ({ text }) => {\n 727→            streamPublisher.push(text);\n 728→          }\n 729→        }\n 730→      });\n 731→\n 732→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 733→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 734→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 735→\n 736→      streamPublisher.setFinalText(finalText);\n 737→      const streamed = await streamPublisher.finish();\n 738→      if (streamed.outputLength === 0) {\n 739→        await replyLargeText(ctx, finalText);\n 740→      }\n 741→\n 742→      if (fileRefs.length > 0) {\n 743→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 744→        const failed = fileSendResults.filter((item) => !item.sent);\n 745→\n 746→        if (failed.length === 0) {\n 747→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 748→        } else {\n 749→          const failedList = failed\n 750→            .map((item) => {\n 751→              const reason =\n 752→                item.reason === 'relative_path_not_allowed'\n 753→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 754→                  : item.reason === 'not_found'\n 755→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 756→                    : item.reason;\n 757→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 758→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 759→            })\n 760→            .join('\\n');\n 761→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 762→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 763→        }\n 764→      }\n 765→    } catch (error) {\n 766→      const message = error instanceof Error ? error.message : String(error);\n 767→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 768→      await safeReply(ctx, `处理失败：${message}`);\n 769→    } finally {\n 770→      if (typingTimer) {\n 771→        clearInterval(typingTimer);\n 772→      }\n 773→    }\n 774→  });\n 775→\n 776→  return bot;\n 777→}\n 778→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce354b726b8a4df5dbec4c5680ecb","__timestamp":"2026-03-12T18:35:47.606Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
