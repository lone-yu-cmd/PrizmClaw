{"type":"user","uuid":"c0566755-e76a-4d73-9a25-6fd63894e9ec","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3537fa9a8d220f765feed6f361e","content":[{"type":"text","text":"   1→# Channel switches\n   2→ENABLE_TELEGRAM=true\n   3→\n   4→# Telegram\n   5→# 填你的 Bot Token。不要把真实 token 提交到仓库。\n   6→TELEGRAM_BOT_TOKEN=\n   7→# ALLOWED_USER_IDS 留空 = 不限制用户ID（任何能访问你 Bot 的用户都可用）\n   8→# 建议生产环境填写，例如: ALLOWED_USER_IDS=12345678,99887766\n   9→ALLOWED_USER_IDS=\n  10→\n  11→# CodeBuddy CLI\n  12→CODEBUDDY_BIN=codebuddy\n  13→CODEBUDDY_PERMISSION_FLAG=-y\n  14→CODEBUDDY_ECHO_STDIO=true\n  15→CODEBUDDY_HEARTBEAT_MS=15000\n  16→# 可选：覆盖文件发送安全根目录（逗号分隔绝对路径）。留空则用默认值。\n  17→TELEGRAM_FILE_ALLOWED_ROOTS=\n  18→# 可选：覆盖文件候选搜索目录（逗号分隔绝对路径）。留空则用默认值。\n  19→TELEGRAM_FILE_CANDIDATE_DIRS=\n  20→REQUEST_TIMEOUT_MS=120000\n  21→MAX_PROMPT_CHARS=8000\n  22→MAX_HISTORY_TURNS=10\n  23→\n  24→# Web management panel\n  25→WEB_HOST=127.0.0.1\n  26→WEB_PORT=8787\n  27→\n  28→# System operation permissions (DANGEROUS, use whitelist)\n  29→ENABLE_SYSTEM_EXEC=false\n  30→ALLOWED_COMMAND_PREFIXES=ls,pwd,open,codebuddy,node,npm,python3\n  31→SYSTEM_EXEC_TIMEOUT_MS=60000\n  32→# F-009: Command blacklist - comma-separated command prefixes to block (e.g., rm -rf,mkfs,dd if=)\n  33→COMMAND_BLACKLIST=rm -rf,mkfs,dd if=\n  34→# F-009: High-risk keywords - comma-separated keywords that require confirmation before execution\n  35→HIGH_RISK_KEYWORDS=sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot\n  36→# F-009: Direct exec mode - when true, plain text messages are treated as shell commands\n  37→DIRECT_EXEC_MODE=false\n  38→\n  39→# F-009: General Command Executor\n  40→# COMMAND_BLACKLIST: Comma-separated list of blocked command prefixes (e.g., rm,dd,mkfs)\n  41→COMMAND_BLACKLIST=\n  42→# HIGH_RISK_KEYWORDS: Comma-separated keywords that trigger confirmation flow\n  43→HIGH_RISK_KEYWORDS=rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt\n  44→# DIRECT_EXEC_MODE: When true, treat non-command text as shell commands (requires ENABLE_SYSTEM_EXEC=true)\n  45→DIRECT_EXEC_MODE=false\n  46→\n  47→# Pipeline infra\n  48→PIPELINE_PROJECT_ROOT=\n  49→PIPELINE_DIR=\n  50→FEATURE_LIST_PATH=feature-list.json\n  51→BUG_FIX_LIST_PATH=bug-fix-list.json\n  52→MAX_RETRIES=3\n  53→SESSION_TIMEOUT=0\n  54→HEARTBEAT_INTERVAL=30\n  55→AI_CLI=cbc\n  56→PRIZMKIT_PLATFORM=codebuddy\n  57→\n  58→# Logging\n  59→LOG_LEVEL=info\n  60→\n  61→# F-006: Safety and Permission Guard\n  62→# USER_PERMISSIONS format: userId:role,userId:role (roles: admin, operator, viewer)\n  63→# Example: USER_PERMISSIONS=123456789:admin,987654321:operator\n  64→USER_PERMISSIONS=\n  65→# Allow admin users to skip confirmation for high-risk commands\n  66→ALLOW_ADMIN_SKIP_CONFIRM=true\n  67→# Audit log configuration\n  68→AUDIT_LOG_DIR=logs\n  69→AUDIT_LOG_MAX_SIZE_MB=10\n  70→AUDIT_LOG_MAX_FILES=5\n  71→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce34f1a139b27766a463bd810f87d","__timestamp":"2026-03-12T18:33:46.597Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
