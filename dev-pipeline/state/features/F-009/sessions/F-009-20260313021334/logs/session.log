{"type":"user","uuid":"62e4ef6c-38e3-4d3c-bb99-98aee5f04c85","session_id":"40f278db-8cd3-4168-987a-9ae4d774284e","message":{"content":[{"type":"tool_result","tool_use_id":"019ce35269444bc702f839ef1d8865e4","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false')\n  36→});\n  37→\n  38→const parsed = schema.parse(process.env);\n  39→\n  40→function parseAllowedUserIds(input) {\n  41→  return new Set(\n  42→    input\n  43→      .split(',')\n  44→      .map((id) => id.trim())\n  45→      .filter(Boolean)\n  46→  );\n  47→}\n  48→\n  49→function parseCsvList(input) {\n  50→  return input\n  51→    .split(',')\n  52→    .map((item) => item.trim())\n  53→    .filter(Boolean);\n  54→}\n  55→\n  56→function parseBoolean(input) {\n  57→  const normalized = (input ?? '').trim().toLowerCase();\n  58→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  59→}\n  60→\n  61→/**\n  62→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  63→ * Format: \"123456789:admin,987654321:operator\"\n  64→ * @param {string} input\n  65→ * @returns {Map<string, string>}\n  66→ */\n  67→function parseUserPermissions(input) {\n  68→  const permissions = new Map();\n  69→  if (!input || !input.trim()) {\n  70→    return permissions;\n  71→  }\n  72→\n  73→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  74→  for (const entry of entries) {\n  75→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  76→    if (userId && role) {\n  77→      const normalizedRole = role.toLowerCase();\n  78→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  79→        permissions.set(userId, normalizedRole);\n  80→      }\n  81→    }\n  82→  }\n  83→  return permissions;\n  84→}\n  85→\n  86→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n  87→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n  88→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n  89→}\n  90→\n  91→const pipelineInfra = loadPipelineInfraConfig({\n  92→  env: process.env,\n  93→  argv: process.argv.slice(2),\n  94→  cwd: process.cwd()\n  95→});\n  96→\n  97→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n  98→\n  99→export const config = Object.freeze({\n 100→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 101→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce34f1a139b27766a463bd810f87d","__timestamp":"2026-03-12T18:32:35.500Z","_requestId":"28efb2d2223148a8a0cf1e344695caa8"}
