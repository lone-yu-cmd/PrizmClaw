{"type":"user","uuid":"398f984f-784b-4788-934a-081a52b8e13b","session_id":"8cd881af-c16d-4c6e-b6da-7621419a768b","message":{"content":[{"type":"tool_result","tool_use_id":"019ce37fbed99ca9a247cfb8240fbcc7","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for F-010 /upload command handler\n   3→ * T-051: Create upload.test.js unit tests\n   4→ *\n   5→ * F-002: File size validation (50MB limit)\n   6→ * F-003: Overwrite confirmation flow\n   7→ */\n   8→\n   9→import { describe, test, beforeEach } from 'node:test';\n  10→import assert from 'node:assert/strict';\n  11→import path from 'node:path';\n  12→import fs from 'node:fs/promises';\n  13→import os from 'node:os';\n  14→import { confirmAction, createConfirmation } from '../../../security/confirmation-manager.js';\n  15→\n  16→// Constants for file size limits (matching Telegram limits)\n  17→const TELEGRAM_MAX_FILE_SIZE = 50 * 1024 * 1024; // 50MB\n  18→\n  19→describe('F-010 /upload Command Handler', () => {\n  20→  let uploadHandler;\n  21→  let sessionStore;\n  22→\n  23→  beforeEach(async () => {\n  24→    const projectRoot = process.cwd();\n  25→    const uploadModulePath = new URL(`file://${projectRoot}/src/bot/commands/handlers/upload.js`);\n  26→    const sessionModulePath = new URL(`file://${projectRoot}/src/services/session-store.js`);\n  27→\n  28→    const module = await import(uploadModulePath.href);\n  29→    uploadHandler = module;\n  30→    const sessionModule = await import(sessionModulePath.href);\n  31→    sessionStore = sessionModule.sessionStore;\n  32→  });\n  33→\n  34→  describe('uploadMeta', () => {\n  35→    test('should export uploadMeta with command metadata', async () => {\n  36→      assert.ok(uploadHandler.uploadMeta);\n  37→      assert.equal(uploadHandler.uploadMeta.name, 'upload');\n  38→      assert.ok(uploadHandler.uploadMeta.description);\n  39→      assert.ok(uploadHandler.uploadMeta.usage);\n  40→    });\n  41→\n  42→    test('should require operator role', async () => {\n  43→      assert.equal(uploadHandler.uploadMeta.minRole, 'operator');\n  44→    });\n  45→  });\n  46→\n  47→  describe('handleUpload', () => {\n  48→    test('should be exported', async () => {\n  49→      assert.ok(uploadHandler.handleUpload);\n  50→      assert.ok(typeof uploadHandler.handleUpload === 'function');\n  51→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce37fbed99ca9a247cfb8240fbcc7","__timestamp":"2026-03-12T19:22:06.586Z","_requestId":"d4f8b50ec2ac4d7592e7518406c06130"}
