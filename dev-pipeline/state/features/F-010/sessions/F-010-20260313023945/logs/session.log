{"type":"assistant","uuid":"20260313031956b2b2549e9a404121","session_id":"8cd881af-c16d-4c6e-b6da-7621419a768b","message":{"id":"20260313031956b2b2549e9a404121","content":[{"type":"tool_use","id":"call_94fa500ea4fd49098fd4c9c3","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/upload.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":45353,"output_tokens":56,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce37c53e7c7132feeac9cfbb11f32","__timestamp":"2026-03-12T19:19:59.654Z","_requestId":"d4f8b50ec2ac4d7592e7518406c06130"}
{"type":"user","uuid":"a4f13f1c-8025-4aec-b8a6-c7026dfeeca0","session_id":"8cd881af-c16d-4c6e-b6da-7621419a768b","message":{"content":[{"type":"tool_result","tool_use_id":"call_94fa500ea4fd49098fd4c9c3","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for F-010 /upload command handler\n   3→ * T-051: Create upload.test.js unit tests\n   4→ *\n   5→ * F-002: File size validation (50MB limit)\n   6→ * F-003: Overwrite confirmation flow\n   7→ */\n   8→\n   9→import { describe, test, beforeEach } from 'node:test';\n  10→import assert from 'node:assert/strict';\n  11→import path from 'node:path';\n  12→import fs from 'node:fs/promises';\n  13→import os from 'node:os';\n  14→\n  15→// Constants for file size limits (matching Telegram limits)\n  16→const TELEGRAM_MAX_FILE_SIZE = 50 * 1024 * 1024; // 50MB\n  17→\n  18→describe('F-010 /upload Command Handler', () => {\n  19→  let uploadHandler;\n  20→  let sessionStore;\n  21→\n  22→  beforeEach(async () => {\n  23→    const projectRoot = process.cwd();\n  24→    const uploadModulePath = new URL(`file://${projectRoot}/src/bot/commands/handlers/upload.js`);\n  25→    const sessionModulePath = new URL(`file://${projectRoot}/src/services/session-store.js`);\n  26→\n  27→    const module = await import(uploadModulePath.href);\n  28→    uploadHandler = module;\n  29→    const sessionModule = await import(sessionModulePath.href);\n  30→    sessionStore = sessionModule.sessionStore;\n  31→  });\n  32→\n  33→  describe('uploadMeta', () => {\n  34→    test('should export uploadMeta with command metadata', async () => {\n  35→      assert.ok(uploadHandler.uploadMeta);\n  36→      assert.equal(uploadHandler.uploadMeta.name, 'upload');\n  37→      assert.ok(uploadHandler.uploadMeta.description);\n  38→      assert.ok(uploadHandler.uploadMeta.usage);\n  39→    });\n  40→\n  41→    test('should require operator role', async () => {\n  42→      assert.equal(uploadHandler.uploadMeta.minRole, 'operator');\n  43→    });\n  44→  });\n  45→\n  46→  describe('handleUpload', () => {\n  47→    test('should be exported', async () => {\n  48→      assert.ok(uploadHandler.handleUpload);\n  49→      assert.ok(typeof uploadHandler.handleUpload === 'function');\n  50→    });\n  51→\n  52→    test('should reject missing path', async () => {\n  53→      const { handleUpload } = uploadHandler;\n  54→\n  55→      const replies = [];\n  56→      const mockCtx = {\n  57→        message: {\n  58→          reply_to_message: {\n  59→            document: { file_id: 'test-file-id', file_name: 'test.txt' }\n  60→          }\n  61→        },\n  62→        telegram: {\n  63→          getFileLink: async () => ({ href: 'file://test' })\n  64→        }\n  65→      };\n  66→\n  67→      const handlerCtx = {\n  68→        ctx: mockCtx,\n  69→        reply: (msg) => replies.push(msg),\n  70→        params: {},\n  71→        userId: 'test-user-1',\n  72→        sessionId: 'test-session-upload-1',\n  73→        args: []\n  74→      };\n  75→\n  76→      await handleUpload(handlerCtx);\n  77→\n  78→      assert.ok(replies.length > 0);\n  79→      assert.ok(replies[0].includes('请提供') || replies[0].includes('❌'));\n  80→    });\n  81→\n  82→    test('should reject when no document in reply', async () => {\n  83→      const { handleUpload } = uploadHandler;\n  84→\n  85→      const replies = [];\n  86→      const mockCtx = {\n  87→        message: {\n  88→          reply_to_message: null\n  89→        }\n  90→      };\n  91→\n  92→      const handlerCtx = {\n  93→        ctx: mockCtx,\n  94→        reply: (msg) => replies.push(msg),\n  95→        params: {},\n  96→        userId: 'test-user-2',\n  97→        sessionId: 'test-session-upload-2',\n  98→        args: ['/tmp/test.txt']\n  99→      };\n 100→\n 101→      await handleUpload(handlerCtx);\n 102→\n 103→      assert.ok(replies.length > 0);\n 104→      assert.ok(replies[0].includes('回复') || replies[0].includes('文档') || replies[0].includes('❌'));\n 105→    });\n 106→\n 107→    test('should require operator role', async () => {\n 108→      // The role check is done by the command routing layer, not the handler itself\n 109→      // This test verifies the metadata is correct\n 110→      assert.equal(uploadHandler.uploadMeta.minRole, 'operator');\n 111→    });\n 112→\n 113→    // F-002: File size validation tests\n 114→    describe('F-002: File size validation', () => {\n 115→      test('should reject files exceeding 50MB limit', async () => {\n 116→        const { handleUpload } = uploadHandler;\n 117→\n 118→        const replies = [];\n 119→        // Create a mock document with file_size exceeding 50MB\n 120→        const oversizedFileSize = TELEGRAM_MAX_FILE_SIZE + 1; // 50MB + 1 byte\n 121→        const mockCtx = {\n 122→          message: {\n 123→            reply_to_message: {\n 124→              document: {\n 125→                file_id: 'test-file-id-oversized',\n 126→                file_name: 'large-file.bin',\n 127→                file_size: oversizedFileSize\n 128→              }\n 129→            }\n 130→          },\n 131→          telegram: {\n 132→            getFileLink: async () => ({ href: 'file://test' })\n 133→          }\n 134→        };\n 135→\n 136→        const handlerCtx = {\n 137→          ctx: mockCtx,\n 138→          reply: (msg) => replies.push(msg),\n 139→          params: {},\n 140→          userId: 'test-user-f002-1',\n 141→          sessionId: 'test-session-f002-1',\n 142→          args: ['/tmp/large-file.bin']\n 143→        };\n 144→\n 145→        await handleUpload(handlerCtx);\n 146→\n 147→        assert.ok(replies.length > 0);\n 148→        const replyText = replies[0];\n 149→        // Should mention size limit or rejection\n 150→        assert.ok(\n 151→          replyText.includes('50MB') ||\n 152→          replyText.includes('过大') ||\n 153→          replyText.includes('超过') ||\n 154→          replyText.includes('❌'),\n 155→          `Expected rejection message about size limit, got: ${replyText}`\n 156→        );\n 157→      });\n 158→\n 159→      test('should accept files at exactly 50MB', async () => {\n 160→        const { handleUpload } = uploadHandler;\n 161→\n 162→        const replies = [];\n 163→        const exactLimitFileSize = TELEGRAM_MAX_FILE_SIZE; // Exactly 50MB\n 164→        const mockCtx = {\n 165→          message: {\n 166→            reply_to_message: {\n 167→              document: {\n 168→                file_id: 'test-file-id-exact',\n 169→                file_name: 'exact-limit.bin',\n 170→                file_size: exactLimitFileSize\n 171→              }\n 172→            }\n 173→          },\n 174→          telegram: {\n 175→            getFileLink: async () => {\n 176→              // Return a valid file URL that fetch can handle\n 177→              // We'll use a data URL with minimal content for testing\n 178→              return { href: 'data:application/octet-stream;base64,dGVzdA==' };\n 179→            }\n 180→          }\n 181→        };\n 182→\n 183→        const tmpDir = await fs.mkdtemp(path.join(os.tmpdir(), 'upload-test-exact-'));\n 184→        const targetPath = path.join(tmpDir, 'exact-limit.bin');\n 185→\n 186→        const handlerCtx = {\n 187→          ctx: mockCtx,\n 188→          reply: (msg) => replies.push(msg),\n 189→          params: {},\n 190→          userId: 'test-user-f002-2',\n 191→          sessionId: 'test-session-f002-2',\n 192→          args: [targetPath]\n 193→        };\n 194→\n 195→        await handleUpload(handlerCtx);\n 196→\n 197→        // Should not reject based on size - might fail for other reasons (fetch, etc)\n 198→        // but should NOT have a \"file too large\" message\n 199→        const hasSizeRejection = replies.some(r =>\n 200→          r.includes('过大') || r.includes('超过') && r.includes('限制')\n 201→        );\n 202→        assert.ok(!hasSizeRejection, 'Should not reject file at exactly 50MB');\n 203→\n 204→        // Cleanup\n 205→        try {\n 206→          await fs.rm(tmpDir, { recursive: true });\n 207→        } catch {\n 208→          // Ignore cleanup errors\n 209→        }\n 210→      });\n 211→\n 212→      test('should accept files under 50MB', async () => {\n 213→        const { handleUpload } = uploadHandler;\n 214→\n 215→        const replies = [];\n 216→        const smallFileSize = 1024; // 1KB\n 217→        const mockCtx = {\n 218→          message: {\n 219→            reply_to_message: {\n 220→              document: {\n 221→                file_id: 'test-file-id-small',\n 222→                file_name: 'small-file.txt',\n 223→                file_size: smallFileSize\n 224→              }\n 225→            }\n 226→          },\n 227→          telegram: {\n 228→            getFileLink: async () => ({ href: 'data:text/plain;base64,dGVzdCBjb250ZW50' })\n 229→          }\n 230→        };\n 231→\n 232→        const tmpDir = await fs.mkdtemp(path.join(os.tmpdir(), 'upload-test-small-'));\n 233→        const targetPath = path.join(tmpDir, 'small-file.txt');\n 234→\n 235→        const handlerCtx = {\n 236→          ctx: mockCtx,\n 237→          reply: (msg) => replies.push(msg),\n 238→          params: {},\n 239→          userId: 'test-user-f002-3',\n 240→          sessionId: 'test-session-f002-3',\n 241→          args: [targetPath]\n 242→        };\n 243→\n 244→        await handleUpload(handlerCtx);\n 245→\n 246→        // Should not reject based on size\n 247→        const hasSizeRejection = replies.some(r =>\n 248→          r.includes('过大') || (r.includes('超过') && r.includes('限制'))\n 249→        );\n 250→        assert.ok(!hasSizeRejection, 'Should not reject small file');\n 251→\n 252→        // Cleanup\n 253→        try {\n 254→          await fs.rm(tmpDir, { recursive: true });\n 255→        } catch {\n 256→          // Ignore cleanup errors\n 257→        }\n 258→      });\n 259→\n 260→      test('should handle missing file_size gracefully', async () => {\n 261→        const { handleUpload } = uploadHandler;\n 262→\n 263→        const replies = [];\n 264→        const mockCtx = {\n 265→          message: {\n 266→            reply_to_message: {\n 267→              document: {\n 268→                file_id: 'test-file-id-no-size',\n 269→                file_name: 'no-size-file.txt'\n 270→                // file_size is undefined\n 271→              }\n 272→            }\n 273→          },\n 274→          telegram: {\n 275→            getFileLink: async () => ({ href: 'data:text/plain;base64,dGVzdA==' })\n 276→          }\n 277→        };\n 278→\n 279→        const tmpDir = await fs.mkdtemp(path.join(os.tmpdir(), 'upload-test-nosize-'));\n 280→        const targetPath = path.join(tmpDir, 'no-size-file.txt');\n 281→\n 282→        const handlerCtx = {\n 283→          ctx: mockCtx,\n 284→          reply: (msg) => replies.push(msg),\n 285→          params: {},\n 286→          userId: 'test-user-f002-4',\n 287→          sessionId: 'test-session-f002-4',\n 288→          args: [targetPath]\n 289→        };\n 290→\n 291→        await handleUpload(handlerCtx);\n 292→\n 293→        // Should proceed without size check (missing file_size is allowed)\n 294→        // The upload may succeed or fail for other reasons, but not due to size check\n 295→        const hasSizeRejection = replies.some(r =>\n 296→          r.includes('过大') || (r.includes('超过') && r.includes('限制'))\n 297→        );\n 298→        assert.ok(!hasSizeRejection, 'Should not reject file with missing file_size');\n 299→\n 300→        // Cleanup\n 301→        try {\n 302→          await fs.rm(tmpDir, { recursive: true });\n 303→        } catch {\n 304→          // Ignore cleanup errors\n 305→        }\n 306→      });\n 307→    });\n 308→  });\n 309→});\n 310→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce37c53e7c7132feeac9cfbb11f32","__timestamp":"2026-03-12T19:19:59.662Z","_requestId":"d4f8b50ec2ac4d7592e7518406c06130"}
