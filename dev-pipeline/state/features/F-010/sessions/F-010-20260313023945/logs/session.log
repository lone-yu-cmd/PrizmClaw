{"type":"assistant","uuid":"202603130315021e9f36fe9fec48ee","session_id":"8cd881af-c16d-4c6e-b6da-7621419a768b","message":{"id":"202603130315021e9f36fe9fec48ee","content":[{"type":"tool_use","id":"019ce3794fd7c11a5a20cb4d33509572","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/registry.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":60712,"output_tokens":55,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce378caca454e9924d63fde4cb32b","__timestamp":"2026-03-12T19:15:04.921Z","_requestId":"d4f8b50ec2ac4d7592e7518406c06130"}
{"type":"user","uuid":"7445dfcd-4fa3-434c-8187-2f73bf4b3aae","session_id":"8cd881af-c16d-4c6e-b6da-7621419a768b","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3794e3065c2ffe0395f3c4f7bde","content":[{"type":"text","text":"   1→import { config } from '../config.js';\n   2→\n   3→class SessionStore {\n   4→  #messagesBySessionKey = new Map();\n   5→  #commitsBySessionKey = new Map();\n   6→  // F-009: Command executor extensions\n   7→  #cwdBySessionKey = new Map();\n   8→  #outputPagesBySessionKey = new Map();\n   9→  // F-010: File search results state for pagination\n  10→  #searchResultsBySessionKey = new Map();\n  11→\n  12→  get(sessionKey) {\n  13→    if (!this.#messagesBySessionKey.has(sessionKey)) {\n  14→      this.#messagesBySessionKey.set(sessionKey, []);\n  15→    }\n  16→    return this.#messagesBySessionKey.get(sessionKey);\n  17→  }\n  18→\n  19→  append(sessionKey, role, content) {\n  20→    const messages = this.get(sessionKey);\n  21→    messages.push({ role, content });\n  22→\n  23→    const maxMessages = config.maxHistoryTurns * 2;\n  24→    if (messages.length > maxMessages) {\n  25→      messages.splice(0, messages.length - maxMessages);\n  26→    }\n  27→  }\n  28→\n  29→  clear(sessionKey) {\n  30→    this.#messagesBySessionKey.delete(sessionKey);\n  31→    this.#commitsBySessionKey.delete(sessionKey);\n  32→    // F-009: Clear cwd and output pages\n  33→    this.#cwdBySessionKey.delete(sessionKey);\n  34→    this.#outputPagesBySessionKey.delete(sessionKey);\n  35→    // F-010: Clear search results\n  36→    this.#searchResultsBySessionKey.delete(sessionKey);\n  37→  }\n  38→\n  39→  toPrompt(sessionKey, channel = 'unknown') {\n  40→    const messages = this.get(sessionKey);\n  41→\n  42→    return [\n  43→      `你正在通过 ${channel} 渠道提供电脑助手服务。`,\n  44→      '请使用自然、简洁、可执行的表达。',\n  45→      '如果用户请求系统操作或截图，明确说明步骤与结果。',\n  46→      '当你产出本地文件（截图/文档）时，必须额外输出独立行：SEND_FILE:<绝对路径>。',\n  47→      '禁止仅输出 @image:xxx 或相对路径；路径必须是绝对路径（例如 /var/folders/... 或 /home/...）。',\n  48→      '以下是最近对话上下文：',\n  49→      ...messages.map((msg) => `${msg.role === 'user' ? '用户' : '助手'}: ${msg.content}`),\n  50→      '请继续回答最后一条用户消息。'\n  51→    ].join('\\n');\n  52→  }\n  53→\n  54→  /**\n  55→   * Add a commit record to a session.\n  56→   * @param {string} sessionKey - Session identifier\n  57→   * @param {Object} commitInfo - Commit information\n  58→   */\n  59→  addCommit(sessionKey, commitInfo) {\n  60→    if (!this.#commitsBySessionKey.has(sessionKey)) {\n  61→      this.#commitsBySessionKey.set(sessionKey, []);\n  62→    }\n  63→    const commits = this.#commitsBySessionKey.get(sessionKey);\n  64→    commits.push({\n  65→      ...commitInfo,\n  66→      timestamp: commitInfo.timestamp || Date.now()\n  67→    });\n  68→  }\n  69→\n  70→  /**\n  71→   * Get commits for a session.\n  72→   * @param {string} sessionKey - Session identifier\n  73→   * @returns {Object[]} Array of commit records\n  74→   */\n  75→  getCommits(sessionKey) {\n  76→    return this.#commitsBySessionKey.get(sessionKey) || [];\n  77→  }\n  78→\n  79→  /**\n  80→   * Get the last commit for a session.\n  81→   * @param {string} sessionKey - Session identifier\n  82→   * @returns {Object|null} Last commit record or null\n  83→   */\n  84→  getLastCommit(sessionKey) {\n  85→    const commits = this.getCommits(sessionKey);\n  86→    return commits.length > 0 ? commits[commits.length - 1] : null;\n  87→  }\n  88→\n  89→  // F-009: Command executor methods\n  90→\n  91→  /**\n  92→   * Get current working directory for a session.\n  93→   * @param {string} sessionKey - Session identifier\n  94→   * @returns {string|null} Current working directory or null\n  95→   */\n  96→  getCwd(sessionKey) {\n  97→    return this.#cwdBySessionKey.get(sessionKey) || null;\n  98→  }\n  99→\n 100→  /**\n 101→   * Set current working directory for a session.\n 102→   * @param {string} sessionKey - Session identifier\n 103→   * @param {string} cwd - Working directory path\n 104→   */\n 105→  setCwd(sessionKey, cwd) {\n 106→    this.#cwdBySessionKey.set(sessionKey, cwd);\n 107→  }\n 108→\n 109→  /**\n 110→   * Get output pages for a session (for /more pagination).\n 111→   * @param {string} sessionKey - Session identifier\n 112→   * @returns {string[]|null} Array of output pages or null\n 113→   */\n 114→  getOutputPages(sessionKey) {\n 115→    return this.#outputPagesBySessionKey.get(sessionKey) || null;\n 116→  }\n 117→\n 118→  /**\n 119→   * Set output pages for a session.\n 120→   * @param {string} sessionKey - Session identifier\n 121→   * @param {string[]} pages - Array of output page strings\n 122→   */\n 123→  setOutputPages(sessionKey, pages) {\n 124→    this.#outputPagesBySessionKey.set(sessionKey, pages);\n 125→  }\n 126→\n 127→  /**\n 128→   * Clear output pages for a session.\n 129→   * @param {string} sessionKey - Session identifier\n 130→   */\n 131→  clearOutputPages(sessionKey) {\n 132→    this.#outputPagesBySessionKey.delete(sessionKey);\n 133→  }\n 134→\n 135→  // F-010: File search results methods\n 136→\n 137→  /**\n 138→   * Get search results for a session.\n 139→   * @param {string} sessionKey - Session identifier\n 140→   * @returns {Object[]|null} Array of search results or null\n 141→   */\n 142→  getSearchResults(sessionKey) {\n 143→    return this.#searchResultsBySessionKey.get(sessionKey) || null;\n 144→  }\n 145→\n 146→  /**\n 147→   * Set search results for a session.\n 148→   * @param {string} sessionKey - Session identifier\n 149→   * @param {Object[]} results - Array of search result objects\n 150→   */\n 151→  setSearchResults(sessionKey, results) {\n 152→    this.#searchResultsBySessionKey.set(sessionKey, results);\n 153→  }\n 154→\n 155→  /**\n 156→   * Clear search results for a session.\n 157→   * @param {string} sessionKey - Session identifier\n 158→   */\n 159→  clearSearchResults(sessionKey) {\n 160→    this.#searchResultsBySessionKey.delete(sessionKey);\n 161→  }\n 162→}\n 163→\n 164→export const sessionStore = new SessionStore();\n 165→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce378caca454e9924d63fde4cb32b","__timestamp":"2026-03-12T19:15:04.924Z","_requestId":"d4f8b50ec2ac4d7592e7518406c06130"}
{"type":"user","uuid":"015575d0-0ac1-43cc-89cb-3b4f9d2e1bf3","session_id":"8cd881af-c16d-4c6e-b6da-7621419a768b","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3794fd7c11a5a20cb4d33509572","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  /** @type {Record<string, string>} */\n 215→  const map = {};\n 216→  for (const [alias, command] of aliasToCommand) {\n 217→    map[alias] = command;\n 218→  }\n 219→  return map;\n 220→}\n 221→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce378caca454e9924d63fde4cb32b","__timestamp":"2026-03-12T19:15:04.940Z","_requestId":"d4f8b50ec2ac4d7592e7518406c06130"}
