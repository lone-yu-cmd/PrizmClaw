{"type":"user","uuid":"d9a4c836-fe6b-431c-bc60-4edfdd7b012b","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"call_f31cea84cb71437d9e92ce01","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20),\n  43→  // F-011: AI CLI Proxy\n  44→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n  45→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n  46→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true')\n  47→});\n  48→\n  49→const parsed = schema.parse(process.env);\n  50→\n  51→function parseAllowedUserIds(input) {\n  52→  return new Set(\n  53→    input\n  54→      .split(',')\n  55→      .map((id) => id.trim())\n  56→      .filter(Boolean)\n  57→  );\n  58→}\n  59→\n  60→function parseCsvList(input) {\n  61→  return input\n  62→    .split(',')\n  63→    .map((item) => item.trim())\n  64→    .filter(Boolean);\n  65→}\n  66→\n  67→function parseBoolean(input) {\n  68→  const normalized = (input ?? '').trim().toLowerCase();\n  69→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  70→}\n  71→\n  72→/**\n  73→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  74→ * Format: \"123456789:admin,987654321:operator\"\n  75→ * @param {string} input\n  76→ * @returns {Map<string, string>}\n  77→ */\n  78→function parseUserPermissions(input) {\n  79→  const permissions = new Map();\n  80→  if (!input || !input.trim()) {\n  81→    return permissions;\n  82→  }\n  83→\n  84→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  85→  for (const entry of entries) {\n  86→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  87→    if (userId && role) {\n  88→      const normalizedRole = role.toLowerCase();\n  89→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  90→        permissions.set(userId, normalizedRole);\n  91→      }\n  92→    }\n  93→  }\n  94→  return permissions;\n  95→}\n  96→\n  97→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n  98→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n  99→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 100→}\n 101→\n 102→const pipelineInfra = loadPipelineInfraConfig({\n 103→  env: process.env,\n 104→  argv: process.argv.slice(2),\n 105→  cwd: process.cwd()\n 106→});\n 107→\n 108→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 109→\n 110→export const config = Object.freeze({\n 111→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 112→  enableTelegram,\n 113→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 114→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 115→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 116→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 117→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 118→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 119→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 120→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 121→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 122→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 123→  webHost: parsed.WEB_HOST,\n 124→  webPort: parsed.WEB_PORT,\n 125→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 126→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 127→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 128→  logLevel: parsed.LOG_LEVEL,\n 129→  // F-006: Safety and Permission Guard\n 130→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 131→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 132→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 133→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 134→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 135→  // F-009: General Command Executor\n 136→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 137→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 138→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 139→  // F-010: File Manager\n 140→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 141→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 142→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 143→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 144→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 145→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 146→  // F-011: AI CLI Proxy\n 147→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 148→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 149→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 150→  pipelineInfra: Object.freeze({\n 151→    ...pipelineInfra,\n 152→    daemonLogPaths\n 153→  })\n 154→});\n 155→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:01:34.263Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
