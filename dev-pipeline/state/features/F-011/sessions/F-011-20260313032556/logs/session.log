T-010: Create AI CLI service skeleton","activeForm":"Creating AI CLI service skeleton","status":"completed"},{"content":"T-012: Implement streaming output handling","activeForm":"Implementing streaming output handling","status":"completed"},{"content":"T-014: Implement process interrupt mechanism","activeForm":"Implementing process interrupt mechanism","status":"completed"},{"content":"T-015: Implement AbortSignal support","activeForm":"Implementing AbortSignal support","status":"completed"},{"content":"T-016: Implement heartbeat progress","activeForm":"Implementing heartbeat progress","status":"completed"},{"content":"T-017: Implement enhanced error handling","activeForm":"Implementing enhanced error handling","status":"completed"},{"content":"T-030: Integrate AI CLI service with Telegram text handler","activeForm":"Integrating AI CLI service with Telegram text handler","status":"completed"},{"content":"T-032: Extend /stop command for AI CLI tasks","activeForm":"Extending /stop command for AI CLI tasks","status":"completed"},{"content":"T-034: Add heartbeat progress to Telegram","activeForm":"Adding heartbeat progress to Telegram","status":"completed"},{"content":"T-036: Integrate MarkdownV2 formatting","activeForm":"Integrating MarkdownV2 formatting","status":"completed"},{"content":"T-038: Add session reset clears active process","activeForm":"Adding session reset clears active process","status":"completed"},{"content":"T-008: Write fixtures for MarkdownV2 tests","activeForm":"Writing MarkdownV2 test fixtures","status":"completed"},{"content":"T-022: Create mock CodeBuddy for testing","activeForm":"Creating mock CodeBuddy helper","status":"completed"},{"content":"T-033: Add permission check for AI CLI interrupt","activeForm":"Adding permission check for AI CLI interrupt","status":"completed"},{"content":"T-039: Write integration tests for Telegram flow","activeForm":"Writing Telegram flow integration tests","status":"pending"},{"content":"T-040: Write integration tests for MarkdownV2 output","activeForm":"Writing MarkdownV2 output integration tests","status":"pending"},{"content":"T-051: Add metrics for monitoring","activeForm":"Adding monitoring metrics","status":"in_progress"},{"content":"T-053: Write integration test for heartbeat","activeForm":"Writing heartbeat integration tests","status":"pending"},{"content":"T-054: Test error recovery scenarios","activeForm":"Testing error recovery scenarios","status":"pending"},{"content":"T-056: Update README with F-011 features","activeForm":"Updating README with F-011 features","status":"pending"},{"content":"T-057: Run full test suite","activeForm":"Running full test suite","status":"pending"},{"content":"T-058: Code review preparation","activeForm":"Preparing for code review","status":"pending"},{"content":"T-059: Update REGISTRY.md","activeForm":"Updating REGISTRY.md","status":"pending"},{"content":"T-060: Final verification of acceptance criteria","activeForm":"Verifying acceptance criteria","status":"pending"}]},"renderer":{"type":"todo"}}}],"role":"user"},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:59:03.942Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"ec917eb9-116a-4739-9eb8-58790a7e40de","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3a19532711ee884ca67651d3f66","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: AI CLI Service\n   3→ *\n   4→ * Encapsulates AI CLI execution logic with process tracking,\n   5→ * heartbeat, and interrupt support.\n   6→ */\n   7→\n   8→import { spawn } from 'node:child_process';\n   9→import { config } from '../config.js';\n  10→import { logger } from '../utils/logger.js';\n  11→import { sessionStore } from './session-store.js';\n  12→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n  13→\n  14→/**\n  15→ * @typedef {Object} AiCliExecutionOptions\n  16→ * @property {string} sessionId - Session identifier\n  17→ * @property {string} prompt - User prompt/input\n  18→ * @property {string} [userId] - User ID who initiated the task (for permission checks)\n  19→ * @property {Object} [hooks] - Callback hooks\n  20→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n  21→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n  22→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n  23→ * @property {AbortSignal} [signal] - Optional abort signal\n  24→ * @property {number} [timeoutMs] - Optional timeout override\n  25→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n  26→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n  27→ * @property {string} [bin] - Optional binary override (for testing)\n  28→ */\n  29→\n  30→/**\n  31→ * @typedef {Object} AiCliExecutionResult\n  32→ * @property {string} output - Final output text\n  33→ * @property {boolean} timedOut - Whether execution timed out\n  34→ * @property {boolean} interrupted - Whether execution was interrupted\n  35→ * @property {number} elapsedMs - Execution time in milliseconds\n  36→ * @property {number|null} exitCode - Process exit code (if completed)\n  37→ * @property {string} stderr - Error output if any\n  38→ */\n  39→\n  40→/**\n  41→ * @typedef {Object} HeartbeatInfo\n  42→ * @property {number} elapsedMs - Elapsed time in milliseconds\n  43→ * @property {number} stdoutBytes - Bytes received so far\n  44→ * @property {string} status - Current status ('running', 'streaming')\n  45→ */\n  46→\n  47→/**\n  48→ * Write text to echo output for debugging.\n  49→ * @param {string} tag - Tag for the output\n  50→ * @param {string} text - Text to write\n  51→ */\n  52→function writeEcho(tag, text) {\n  53→  const normalized = String(text ?? '');\n  54→  if (!normalized) {\n  55→    return;\n  56→  }\n  57→\n  58→  const lines = normalized.split(/\\r?\\n/);\n  59→  for (const line of lines) {\n  60→    if (!line) {\n  61→      continue;\n  62→    }\n  63→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  64→  }\n  65→}\n  66→\n  67→/**\n  68→ * Execute AI CLI with session context and process tracking.\n  69→ * @param {AiCliExecutionOptions} options\n  70→ * @returns {Promise<AiCliExecutionResult>}\n  71→ */\n  72→export async function executeAiCli(options) {\n  73→  const {\n  74→    sessionId,\n  75→    prompt,\n  76→    userId,\n  77→    hooks = {},\n  78→    signal,\n  79→    timeoutMs,\n  80→    heartbeatThresholdMs,\n  81→    heartbeatIntervalMs,\n  82→    bin\n  83→  } = options;\n  84→\n  85→  const effectiveBin = bin || config.codebuddyBin;\n  86→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n  87→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n  88→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n  89→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n  90→\n  91→  const args = ['-p', prompt];\n  92→  if (config.codebuddyPermissionFlag) {\n  93→    args.push(config.codebuddyPermissionFlag);\n  94→  }\n  95→\n  96→  return new Promise((resolve) => {\n  97→    let stdout = '';\n  98→    let stderr = '';\n  99→    let stdoutBytes = 0;\n 100→    let interrupted = false;\n 101→    let timedOut = false;\n 102→    const startedAt = Date.now();\n 103→    const sessionKey = sessionId;\n 104→\n 105→    // Heartbeat manager\n 106→    const heartbeatManager = createHeartbeatManager();\n 107→\n 108→    // Spawn process\n 109→    let child;\n 110→    try {\n 111→      child = spawn(effectiveBin, args, {\n 112→        stdio: ['ignore', 'pipe', 'pipe']\n 113→      });\n 114→    } catch (err) {\n 115→      resolve({\n 116→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 117→        timedOut: false,\n 118→        interrupted: false,\n 119→        elapsedMs: Date.now() - startedAt,\n 120→        exitCode: null,\n 121→        stderr: ''\n 122→      });\n 123→      return;\n 124→    }\n 125→\n 126→    // Track process in session store\n 127→    sessionStore.setActiveProcess(sessionKey, {\n 128→      pid: child.pid,\n 129→      startedAt,\n 130→      childProcess: child,\n 131→      interrupted: false,\n 132→      timedOut: false,\n 133→      userId\n 134→    });\n 135→\n 136→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n 137→\n 138→    // Handle process error\n 139→    child.on('error', (err) => {\n 140→      cleanup();\n 141→      resolve({\n 142→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 143→        timedOut: false,\n 144→        interrupted: false,\n 145→        elapsedMs: Date.now() - startedAt,\n 146→        exitCode: null,\n 147→        stderr\n 148→      });\n 149→    });\n 150→\n 151→    // Handle stdout\n 152→    child.stdout.on('data', (chunk) => {\n 153→      const text = chunk.toString();\n 154→      stdout += text;\n 155→      stdoutBytes += Buffer.byteLength(text);\n 156→\n 157→      // Update session store byte count\n 158→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n 159→\n 160→      // Echo to console if enabled\n 161→      if (config.codebuddyEchoStdio) {\n 162→        writeEcho('stdout', text);\n 163→      }\n 164→\n 165→      // Call onChunk hook\n 166→      if (typeof hooks.onChunk === 'function') {\n 167→        hooks.onChunk(text);\n 168→      }\n 169→    });\n 170→\n 171→    // Handle stderr\n 172→    child.stderr.on('data', (chunk) => {\n 173→      const text = chunk.toString();\n 174→      stderr += text;\n 175→\n 176→      if (config.codebuddyEchoStdio) {\n 177→        writeEcho('stderr', text);\n 178→      }\n 179→    });\n 180→\n 181→    // Timeout handler\n 182→    const timeout = effectiveTimeoutMs > 0\n 183→      ? setTimeout(() => {\n 184→          timedOut = true;\n 185→          const info = sessionStore.getActiveProcess(sessionKey);\n 186→          if (info) {\n 187→            info.timedOut = true;\n 188→          }\n 189→          child.kill('SIGTERM');\n 190→\n 191→          // Schedule SIGKILL if process doesn't exit\n 192→          setTimeout(() => {\n 193→            if (sessionStore.getActiveProcess(sessionKey)) {\n 194→              child.kill('SIGKILL');\n 195→            }\n 196→          }, 5000);\n 197→        }, effectiveTimeoutMs)\n 198→      : null;\n 199→\n 200→    // Abort signal handler\n 201→    const onAbort = () => {\n 202→      interrupted = true;\n 203→      const info = sessionStore.getActiveProcess(sessionKey);\n 204→      if (info) {\n 205→        info.interrupted = true;\n 206→      }\n 207→      child.kill('SIGTERM');\n 208→\n 209→      // Schedule SIGKILL if process doesn't exit\n 210→      setTimeout(() => {\n 211→        if (sessionStore.getActiveProcess(sessionKey)) {\n 212→          child.kill('SIGKILL');\n 213→        }\n 214→      }, 5000);\n 215→    };\n 216→\n 217→    if (signal) {\n 218→      signal.addEventListener('abort', onAbort);\n 219→    }\n 220→\n 221→    // Heartbeat setup\n 222→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n 223→      heartbeatManager.start({\n 224→        callback: () => {\n 225→          const elapsedMs = Date.now() - startedAt;\n 226→          hooks.onHeartbeat({\n 227→            elapsedMs,\n 228→            stdoutBytes,\n 229→            status: 'running'\n 230→          });\n 231→        },\n 232→        intervalMs: effectiveHeartbeatIntervalMs,\n 233→        thresholdMs: effectiveHeartbeatThresholdMs\n 234→      });\n 235→    }\n 236→\n 237→    // Cleanup function\n 238→    function cleanup() {\n 239→      if (timeout) {\n 240→        clearTimeout(timeout);\n 241→      }\n 242→      heartbeatManager.stop();\n 243→      sessionStore.clearActiveProcess(sessionKey);\n 244→      if (signal) {\n 245→        signal.removeEventListener('abort', onAbort);\n 246→      }\n 247→    }\n 248→\n 249→    // Handle process close\n 250→    child.on('close', (code) => {\n 251→      const elapsedMs = Date.now() - startedAt;\n 252→\n 253→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n 254→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n 255→      if (storedInfo) {\n 256→        if (storedInfo.interrupted) {\n 257→          interrupted = true;\n 258→        }\n 259→        if (storedInfo.timedOut) {\n 260→          timedOut = true;\n 261→        }\n 262→      }\n 263→\n 264→      cleanup();\n 265→\n 266→      logger.info(\n 267→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n 268→        'AI CLI process closed'\n 269→      );\n 270→\n 271→      // Build output\n 272→      let output = stdout.trim();\n 273→\n 274→      if (interrupted) {\n 275→        output = output || '任务已被用户中断。';\n 276→      } else if (timedOut) {\n 277→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n 278→      } else if (code !== 0) {\n 279→        output = output || `AI CLI 退出码 ${code}。`;\n 280→        if (stderr.trim()) {\n 281→          output += `\\n错误信息:\\n${stderr.trim()}`;\n 282→        }\n 283→      }\n 284→\n 285→      resolve({\n 286→        output: output || 'AI CLI 未返回文本结果。',\n 287→        timedOut,\n 288→        interrupted,\n 289→        elapsedMs,\n 290→        exitCode: code,\n 291→        stderr: stderr.trim()\n 292→      });\n 293→    });\n 294→  });\n 295→}\n 296→\n 297→/**\n 298→ * Interrupt running AI CLI task for a session.\n 299→ * @param {string} sessionId - Session identifier\n 300→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 301→ */\n 302→export function interruptAiCli(sessionId) {\n 303→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 304→\n 305→  if (!processInfo) {\n 306→    return { ok: false, error: '没有正在执行的任务。' };\n 307→  }\n 308→\n 309→  const { pid, childProcess } = processInfo;\n 310→\n 311→  try {\n 312→    // Mark as interrupted so close handler knows\n 313→    processInfo.interrupted = true;\n 314→\n 315→    // Send SIGTERM first\n 316→    childProcess.kill('SIGTERM');\n 317→\n 318→    // Schedule SIGKILL as backup\n 319→    setTimeout(() => {\n 320→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n 321→      if (stillRunning) {\n 322→        try {\n 323→          childProcess.kill('SIGKILL');\n 324→        } catch {\n 325→          // Process already dead\n 326→        }\n 327→      }\n 328→    }, 5000);\n 329→\n 330→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n 331→\n 332→    return { ok: true, pid };\n 333→  } catch (err) {\n 334→    return { ok: false, error: `中断失败: ${err.message}` };\n 335→  }\n 336→}\n 337→\n 338→/**\n 339→ * Check if AI CLI is running for a session.\n 340→ * @param {string} sessionId\n 341→ * @returns {boolean}\n 342→ */\n 343→export function isAiCliRunning(sessionId) {\n 344→  return sessionStore.getActiveProcess(sessionId) !== null;\n 345→}\n 346→\n 347→/**\n 348→ * Get active process info for a session.\n 349→ * @param {string} sessionId\n 350→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n 351→ */\n 352→export function getActiveProcessInfo(sessionId) {\n 353→  const info = sessionStore.getActiveProcess(sessionId);\n 354→  if (!info) {\n 355→    return null;\n 356→  }\n 357→\n 358→  // Don't expose childProcess to external callers\n 359→  return {\n 360→    pid: info.pid,\n 361→    startedAt: info.startedAt,\n 362→    stdoutBytes: info.stdoutBytes ?? 0,\n 363→    userId: info.userId\n 364→  };\n 365→}\n 366→\n 367→/**\n 368→ * Check if user can interrupt AI CLI task.\n 369→ * @param {string} sessionId - Session identifier\n 370→ * @param {string|number} requestUserId - User requesting interrupt\n 371→ * @param {Function} isAdminFn - Function to check if user is admin\n 372→ * @returns {{ canInterrupt: boolean, reason?: string }}\n 373→ */\n 374→export function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n 375→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 376→\n 377→  if (!processInfo) {\n 378→    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n 379→  }\n 380→\n 381→  // Admin can always interrupt\n 382→  if (isAdminFn && isAdminFn(requestUserId)) {\n 383→    return { canInterrupt: true };\n 384→  }\n 385→\n 386→  // Task owner can interrupt\n 387→  const taskUserId = processInfo.userId;\n 388→  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n 389→    return { canInterrupt: true };\n 390→  }\n 391→\n 392→  // Otherwise, permission denied\n 393→  return {\n 394→    canInterrupt: false,\n 395→    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n 396→  };\n 397→}\n 398→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:59:03.961Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
