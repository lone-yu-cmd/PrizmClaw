{"type":"user","uuid":"5174b400-c005-49cc-8b5d-8f3e9b537085","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3977aebfc8373d402c89d49f852","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { captureScreenshot } from '../services/screenshot-service.js';\n  11→import { executeCommand, confirmHighRiskCommand } from '../services/command-executor-service.js';\n  12→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  13→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  14→import { registerCommand } from './commands/index.js';\n  15→import { routeCommand } from './commands/index.js';\n  16→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  17→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  18→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  19→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  20→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  21→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  22→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  23→import { auditMeta, handleAudit } from './commands/handlers/audit.js';\n  24→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n  25→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n  26→// F-009: New command handlers\n  27→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n  28→import { moreMeta, handleMore } from './commands/handlers/more.js';\n  29→// F-010: File Manager command handlers\n  30→import { lsMeta, handleLs } from './commands/handlers/ls.js';\n  31→import { treeMeta, handleTree } from './commands/handlers/tree.js';\n  32→import { catMeta, handleCat } from './commands/handlers/cat.js';\n  33→import { headMeta, handleHead } from './commands/handlers/head.js';\n  34→import { tailMeta, handleTail } from './commands/handlers/tail.js';\n  35→import { findMeta, handleFind } from './commands/handlers/find.js';\n  36→import { uploadMeta, handleUpload } from './commands/handlers/upload.js';\n  37→import { downloadMeta, handleDownload } from './commands/handlers/download.js';\n  38→import { generateHelp } from './commands/help.js';\n  39→import { sessionStore } from '../services/session-store.js';\n  40→\n  41→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  42→const STREAM_MIN_CHARS = 220;\n  43→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  44→const TYPING_INTERVAL_MS = 3500;\n  45→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  46→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  47→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  48→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  49→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  50→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  51→const TMP_DIR = path.resolve(os.tmpdir());\n  52→const HOME_DIR = path.resolve(os.homedir());\n  53→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  54→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  55→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  56→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  57→\n  58→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  59→  const normalized = configuredDirs\n  60→    .map((dir) => String(dir ?? '').trim())\n  61→    .filter(Boolean)\n  62→    .map((dir) => path.resolve(dir));\n  63→\n  64→  if (normalized.length > 0) {\n  65→    return [...new Set(normalized)];\n  66→  }\n  67→\n  68→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  69→}\n  70→\n  71→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  72→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  73→\n  74→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  75→  const chunks = [];\n  76→  for (let i = 0; i < text.length; i += chunkSize) {\n  77→    chunks.push(text.slice(i, i + chunkSize));\n  78→  }\n  79→  return chunks;\n  80→}\n  81→\n  82→function sanitizeMarkerPath(raw) {\n  83→  return String(raw ?? '')\n  84→    .trim()\n  85→    .replace(/^['\"`]+/, '')\n  86→    .replace(/['\"`]+$/, '');\n  87→}\n  88→\n  89→function extractFileMarkers(text = '') {\n  90→  const fileRefs = [];\n  91→\n  92→  const withSendFileRemoved = text.replace(\n  93→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n  94→    (_full, rawRef) => {\n  95→      const ref = sanitizeMarkerPath(rawRef);\n  96→      if (ref) {\n  97→        fileRefs.push(ref);\n  98→      }\n  99→      return '\\n';\n 100→    }\n 101→  );\n 102→\n 103→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n 104→    const ref = sanitizeMarkerPath(rawRef);\n 105→    if (ref) {\n 106→      fileRefs.push(ref);\n 107→    }\n 108→    return '';\n 109→  });\n 110→\n 111→  const withBacktickPathRemoved = withImageRemoved.replace(\n 112→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 113→    (_full, rawRef) => {\n 114→      const ref = sanitizeMarkerPath(rawRef);\n 115→      if (ref) {\n 116→        fileRefs.push(ref);\n 117→      }\n 118→      return '';\n 119→    }\n 120→  );\n 121→\n 122→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 123→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 124→    (_full, rawRef) => {\n 125→      const ref = sanitizeMarkerPath(rawRef);\n 126→      if (ref) {\n 127→        fileRefs.push(ref);\n 128→      }\n 129→      return '';\n 130→    }\n 131→  );\n 132→\n 133→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 134→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 135→    (_full, rawRef) => {\n 136→      const ref = sanitizeMarkerPath(rawRef);\n 137→      if (ref) {\n 138→        fileRefs.push(ref);\n 139→      }\n 140→      return '\\n';\n 141→    }\n 142→  );\n 143→\n 144→  return {\n 145→    fileRefs: [...new Set(fileRefs)],\n 146→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 147→  };\n 148→}\n 149→\n 150→function isPathWithinRoot(targetPath, rootPath) {\n 151→  const relative = path.relative(rootPath, targetPath);\n 152→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 153→}\n 154→\n 155→function isAllowedFilePath(filePath) {\n 156→  const resolved = path.resolve(filePath);\n 157→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 158→}\n 159→\n 160→function buildFileCandidates(normalizedPath) {\n 161→  if (path.isAbsolute(normalizedPath)) {\n 162→    return [normalizedPath];\n 163→  }\n 164→\n 165→  const baseName = path.basename(normalizedPath);\n 166→  const candidates = [\n 167→    path.resolve(process.cwd(), normalizedPath),\n 168→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 169→  ];\n 170→\n 171→  return [...new Set(candidates)];\n 172→}\n 173→\n 174→async function resolveLocalFilePath(fileRef) {\n 175→  const normalized = sanitizeMarkerPath(fileRef);\n 176→  if (!normalized) {\n 177→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 178→  }\n 179→\n 180→  if (!path.isAbsolute(normalized)) {\n 181→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 182→  }\n 183→\n 184→  const candidates = buildFileCandidates(normalized);\n 185→\n 186→  for (const candidate of candidates) {\n 187→    try {\n 188→      await access(candidate);\n 189→      return { filePath: candidate, triedPaths: candidates };\n 190→    } catch {\n 191→      // ignore\n 192→    }\n 193→  }\n 194→\n 195→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 196→}\n 197→\n 198→async function validateFileForTelegram(filePath) {\n 199→  const resolvedPath = path.resolve(filePath);\n 200→  if (!isAllowedFilePath(resolvedPath)) {\n 201→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 202→  }\n 203→\n 204→  const ext = path.extname(resolvedPath).toLowerCase();\n 205→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 206→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 207→  }\n 208→\n 209→  const fileStat = await stat(resolvedPath);\n 210→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 211→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 212→\n 213→  if (fileStat.size > maxSize) {\n 214→    return {\n 215→      ok: false,\n 216→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 217→    };\n 218→  }\n 219→\n 220→  return { ok: true, isPhoto, resolvedPath };\n 221→}\n 222→\n 223→function isTimeoutLikeError(message = '') {\n 224→  const normalized = String(message).toLowerCase();\n 225→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 226→}\n 227→\n 228→function sleep(ms) {\n 229→  return new Promise((resolve) => setTimeout(resolve, ms));\n 230→}\n 231→\n 232→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 233→  if (isPhoto) {\n 234→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 235→    return;\n 236→  }\n 237→\n 238→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 239→}\n 240→\n 241→async function replyFiles(ctx, fileRefs = []) {\n 242→  const results = [];\n 243→\n 244→  for (const fileRef of fileRefs) {\n 245→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 246→    if (!filePath) {\n 247→      const reason = rejectReason || 'not_found';\n 248→      results.push({ fileRef, sent: false, reason, triedPaths });\n 249→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 250→      continue;\n 251→    }\n 252→\n 253→    try {\n 254→      const validation = await validateFileForTelegram(filePath);\n 255→      if (!validation.ok) {\n 256→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 257→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 258→        continue;\n 259→      }\n 260→\n 261→      const actualPath = validation.resolvedPath;\n 262→      let sent = false;\n 263→      let lastReason = '';\n 264→\n 265→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 266→        try {\n 267→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 268→          sent = true;\n 269→          logger.info(\n 270→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 271→            'Telegram file sent'\n 272→          );\n 273→          break;\n 274→        } catch (error) {\n 275→          lastReason = error instanceof Error ? error.message : String(error);\n 276→          logger.warn(\n 277→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 278→            'Telegram file send attempt failed'\n 279→          );\n 280→\n 281→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 282→            await sleep(600);\n 283→            continue;\n 284→          }\n 285→\n 286→          break;\n 287→        }\n 288→      }\n 289→\n 290→      if (!sent) {\n 291→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 292→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 293→        continue;\n 294→      }\n 295→\n 296→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 297→    } catch (error) {\n 298→      const reason = error instanceof Error ? error.message : String(error);\n 299→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 300→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 301→    }\n 302→  }\n 303→\n 304→  return results;\n 305→}\n 306→\n 307→async function safeReply(ctx, text) {\n 308→  try {\n 309→    await ctx.reply(text);\n 310→    return true;\n 311→  } catch (error) {\n 312→    const reason = error instanceof Error ? error.message : String(error);\n 313→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 314→    return false;\n 315→  }\n 316→}\n 317→\n 318→async function replyLargeText(ctx, text) {\n 319→  const chunks = splitMessage(text);\n 320→  for (const chunk of chunks) {\n 321→    const ok = await safeReply(ctx, chunk);\n 322→    if (!ok) {\n 323→      break;\n 324→    }\n 325→  }\n 326→}\n 327→\n 328→async function safeEditMessageText(ctx, messageId, text) {\n 329→  const nextText = text && text.trim() ? text : ' ';\n 330→\n 331→  try {\n 332→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 333→  } catch (error) {\n 334→    const message = error instanceof Error ? error.message : String(error);\n 335→    if (message.includes('message is not modified')) {\n 336→      return;\n 337→    }\n 338→    throw error;\n 339→  }\n 340→}\n 341→\n 342→function createEditableStreamPublisher(ctx) {\n 343→  let fullText = '';\n 344→  let renderedText = '';\n 345→  let pendingChars = 0;\n 346→  let lastFlushAt = 0;\n 347→  let flushChain = Promise.resolve();\n 348→  let activeMessage = null;\n 349→  let activeSegmentIndex = 0;\n 350→  let publishedMessageCount = 0;\n 351→\n 352→  async function ensureActiveMessage() {\n 353→    if (activeMessage) {\n 354→      return;\n 355→    }\n 356→    activeMessage = await ctx.reply('处理中...');\n 357→    activeSegmentIndex = 0;\n 358→    publishedMessageCount += 1;\n 359→  }\n 360→\n 361→  async function render(force = false) {\n 362→    const now = Date.now();\n 363→\n 364→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 365→      return;\n 366→    }\n 367→\n 368→    if (fullText === renderedText) {\n 369→      pendingChars = 0;\n 370→      return;\n 371→    }\n 372→\n 373→    await ensureActiveMessage();\n 374→\n 375→    const segments = splitMessage(fullText);\n 376→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 377→\n 378→    while (activeSegmentIndex < targetLastIndex) {\n 379→      const text = segments[activeSegmentIndex] ?? ' ';\n 380→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 381→\n 382→      activeMessage = await ctx.reply('继续输出中...');\n 383→      activeSegmentIndex += 1;\n 384→      publishedMessageCount += 1;\n 385→    }\n 386→\n 387→    const activeText = segments[targetLastIndex] ?? ' ';\n 388→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 389→\n 390→    renderedText = fullText;\n 391→    pendingChars = 0;\n 392→    lastFlushAt = now;\n 393→  }\n 394→\n 395→  function enqueueRender(force = false) {\n 396→    flushChain = flushChain.then(() => render(force));\n 397→  }\n 398→\n 399→  return {\n 400→    push(text) {\n 401→      const appendText = text ?? '';\n 402→      if (!appendText) {\n 403→        return;\n 404→      }\n 405→      fullText += appendText;\n 406→      pendingChars += appendText.length;\n 407→      enqueueRender(false);\n 408→    },\n 409→    setFinalText(text) {\n 410→      fullText = text ?? '';\n 411→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 412→      enqueueRender(true);\n 413→    },\n 414→    async finish() {\n 415→      enqueueRender(true);\n 416→      await flushChain;\n 417→      return {\n 418→        outputLength: renderedText.length,\n 419→        messageCount: publishedMessageCount\n 420→      };\n 421→    }\n 422→  };\n 423→}\n 424→\n 425→function buildSessionId(ctx) {\n 426→  return String(ctx.chat.id);\n 427→}\n 428→\n 429→function ensureAllowed(ctx) {\n 430→  const userId = ctx.from?.id;\n 431→  if (!isAllowedUser(userId)) {\n 432→    throw new Error('当前账号未被授权使用该机器人。');\n 433→  }\n 434→}\n 435→\n 436→/**\n 437→ * Register all pipeline-related commands.\n 438→ */\n 439→function registerPipelineCommands() {\n 440→  registerCommand(pipelineMeta, handlePipeline);\n 441→  registerCommand(bugfixMeta, handleBugfix);\n 442→  registerCommand(plannerMeta, handlePlanner);\n 443→  registerCommand(statusMeta, handleStatus);\n 444→  registerCommand(logsMeta, handleLogs);\n 445→  registerCommand(stopMeta, handleStop);\n 446→  registerCommand(planMeta, handlePlan);\n 447→  registerCommand(auditMeta, handleAudit);\n 448→  registerCommand(commitMeta, handleCommit);\n 449→  registerCommand(commitsMeta, handleCommits);\n 450→  // F-009: New commands\n 451→  registerCommand(cdMeta, handleCd);\n 452→  registerCommand(moreMeta, handleMore);\n 453→  // F-010: File Manager commands\n 454→  registerCommand(lsMeta, handleLs);\n 455→  registerCommand(treeMeta, handleTree);\n 456→  registerCommand(catMeta, handleCat);\n 457→  registerCommand(headMeta, handleHead);\n 458→  registerCommand(tailMeta, handleTail);\n 459→  registerCommand(findMeta, handleFind);\n 460→  registerCommand(uploadMeta, handleUpload);\n 461→  registerCommand(downloadMeta, handleDownload);\n 462→}\n 463→\n 464→export function createTelegramBot() {\n 465→  const bot = new Telegraf(config.telegramBotToken, {\n 466→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 467→  });\n 468→\n 469→  // Register pipeline commands\n 470→  registerPipelineCommands();\n 471→\n 472→  bot.catch((error, ctx) => {\n 473→    const message = error instanceof Error ? error.message : String(error);\n 474→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 475→  });\n 476→\n 477→  bot.start(async (ctx) => {\n 478→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 479→  });\n 480→\n 481→  bot.help(async (ctx) => {\n 482→    const helpText = generateHelp();\n 483→    await ctx.reply(helpText);\n 484→  });\n 485→\n 486→  bot.command('reset', async (ctx) => {\n 487→    try {\n 488→      ensureAllowed(ctx);\n 489→      resetSession({ channel: 'telegram', sessionId: buildSessionId(ctx) });\n 490→      await ctx.reply('已清空当前会话上下文。');\n 491→    } catch (error) {\n 492→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 493→    }\n 494→  });\n 495→\n 496→  bot.command('screenshot', async (ctx) => {\n 497→    try {\n 498→      ensureAllowed(ctx);\n 499→      await ctx.reply('正在获取截图。');\n 500→      const { buffer } = await captureScreenshot();\n 501→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 502→    } catch (error) {\n 503→      const message = error instanceof Error ? error.message : String(error);\n 504→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 505→      await ctx.reply(`截图失败：${message}`);\n 506→    }\n 507→  });\n 508→\n 509→  bot.command('exec', async (ctx) => {\n 510→    try {\n 511→      ensureAllowed(ctx);\n 512→      const payload = ctx.message.text.replace('/exec', '').trim();\n 513→      if (!payload) {\n 514→        await ctx.reply('请提供命令，例如 /exec pwd');\n 515→        return;\n 516→      }\n 517→\n 518→      const sessionId = buildSessionId(ctx);\n 519→      const userId = ctx.from?.id;\n 520→\n 521→      await ctx.reply('正在执行命令...');\n 522→      const result = await executeCommand({\n 523→        command: payload,\n 524→        sessionId,\n 525→        userId\n 526→      });\n 527→\n 528→      // Handle confirmation required\n 529→      if (result.needsConfirmation) {\n 530→        await ctx.reply(result.confirmationMessage);\n 531→        return;\n 532→      }\n 533→\n 534→      // Send output\n 535→      await replyLargeText(ctx, result.output);\n 536→\n 537→      // Indicate if more pages available\n 538→      if (result.hasMorePages) {\n 539→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 540→      }\n 541→    } catch (error) {\n 542→      const message = error instanceof Error ? error.message : String(error);\n 543→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 544→      await ctx.reply(`执行失败：${message}`);\n 545→    }\n 546→  });\n 547→\n 548→  // F-009: /cd command handler\n 549→  bot.command('cd', async (ctx) => {\n 550→    try {\n 551→      ensureAllowed(ctx);\n 552→      const payload = ctx.message.text.replace('/cd', '').trim();\n 553→      const sessionId = buildSessionId(ctx);\n 554→\n 555→      await handleCd({\n 556→        ctx,\n 557→        reply: (msg) => ctx.reply(msg),\n 558→        params: {},\n 559→        userId: ctx.from?.id,\n 560→        sessionId,\n 561→        args: payload ? [payload] : []\n 562→      });\n 563→    } catch (error) {\n 564→      const message = error instanceof Error ? error.message : String(error);\n 565→      logger.error({ err: message }, 'Failed to cd in telegram');\n 566→      await ctx.reply(`切换目录失败：${message}`);\n 567→    }\n 568→  });\n 569→\n 570→  // F-009: /more command handler\n 571→  bot.command('more', async (ctx) => {\n 572→    try {\n 573→      ensureAllowed(ctx);\n 574→      const sessionId = buildSessionId(ctx);\n 575→\n 576→      await handleMore({\n 577→        ctx,\n 578→        reply: (msg) => ctx.reply(msg),\n 579→        params: {},\n 580→        userId: ctx.from?.id,\n 581→        sessionId\n 582→      });\n 583→    } catch (error) {\n 584→      const message = error instanceof Error ? error.message : String(error);\n 585→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 586→      await ctx.reply(`获取更多输出失败：${message}`);\n 587→    }\n 588→  });\n 589→\n 590→  // T-100: Document upload handler for plan files\n 591→  bot.on('document', async (ctx) => {\n 592→    try {\n 593→      ensureAllowed(ctx);\n 594→\n 595→      const document = ctx.message?.document;\n 596→      if (!document) {\n 597→        return;\n 598→      }\n 599→\n 600→      // Check file extension\n 601→      const fileName = document.file_name || '';\n 602→      const ext = path.extname(fileName).toLowerCase();\n 603→\n 604→      if (ext !== '.json') {\n 605→        // Not a JSON file, ignore silently (other handlers may process it)\n 606→        return;\n 607→      }\n 608→\n 609→      // Check file size\n 610→      const fileSize = document.file_size || 0;\n 611→      if (fileSize > 1024 * 1024) { // 1MB limit\n 612→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 613→        return;\n 614→      }\n 615→\n 616→      await ctx.reply('正在处理上传的计划文件...');\n 617→\n 618→      // Download file content\n 619→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 620→      const fileUrl = fileLink.href || fileLink.toString();\n 621→\n 622→      const response = await fetch(fileUrl);\n 623→      if (!response.ok) {\n 624→        throw new Error(`下载文件失败: ${response.status}`);\n 625→      }\n 626→\n 627→      const content = await response.text();\n 628→\n 629→      // Validate and save using plan-ingestion-service\n 630→      const infraConfig = loadPipelineInfraConfig();\n 631→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 632→\n 633→      const validationResult = planService.validate(content);\n 634→\n 635→      if (!validationResult.valid) {\n 636→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 637→        await ctx.reply(errorMsg);\n 638→        return;\n 639→      }\n 640→\n 641→      // Save the plan\n 642→      const saveResult = await planService.save(\n 643→        validationResult.type,\n 644→        content,\n 645→        { uploadedBy: ctx.from?.id }\n 646→      );\n 647→\n 648→      if (!saveResult.success) {\n 649→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 650→        return;\n 651→      }\n 652→\n 653→      // Set as current version\n 654→      await planService.setCurrent(validationResult.type, saveResult.version);\n 655→\n 656→      // Format success message\n 657→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 658→      const summary = validationResult.summary;\n 659→\n 660→      await ctx.reply([\n 661→        `✅ ${typeDisplay}已保存并激活`,\n 662→        `版本: ${saveResult.version}`,\n 663→        `名称: ${summary?.name || '未知'}`,\n 664→        `项目数: ${summary?.itemCount || 0}`,\n 665→        '',\n 666→        summary?.statusBreakdown ? '状态分布:' : '',\n 667→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 668→      ].filter(Boolean).join('\\n'));\n 669→\n 670→    } catch (error) {\n 671→      const message = error instanceof Error ? error.message : String(error);\n 672→      logger.error({ err: message }, 'Failed to process document upload');\n 673→      await ctx.reply(`❌ 处理失败：${message}`);\n 674→    }\n 675→  });\n 676→\n 677→  bot.on('text', async (ctx) => {\n 678→    // Check for pipeline commands first\n 679→    const handled = await routeCommand(ctx);\n 680→    if (handled) {\n 681→      return;\n 682→    }\n 683→\n 684→    const sessionId = buildSessionId(ctx);\n 685→    const userId = ctx.from?.id;\n 686→\n 687→    // F-009: Direct exec mode - treat plain text as command when enabled\n 688→    if (config.directExecMode && config.enableSystemExec) {\n 689→      try {\n 690→        ensureAllowed(ctx);\n 691→        const command = ctx.message.text;\n 692→\n 693→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 694→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 695→\n 696→        if (!isLikelyChat) {\n 697→          await ctx.reply('正在执行命令...');\n 698→          const result = await executeCommand({\n 699→            command,\n 700→            sessionId,\n 701→            userId\n 702→          });\n 703→\n 704→          if (result.needsConfirmation) {\n 705→            await ctx.reply(result.confirmationMessage);\n 706→            return;\n 707→          }\n 708→\n 709→          await replyLargeText(ctx, result.output);\n 710→\n 711→          if (result.hasMorePages) {\n 712→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 713→          }\n 714→          return;\n 715→        }\n 716→      } catch (error) {\n 717→        const message = error instanceof Error ? error.message : String(error);\n 718→        // If exec fails, fall through to chat mode\n 719→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n 720→      }\n 721→    }\n 722→\n 723→    let typingTimer = null;\n 724→\n 725→    try {\n 726→      ensureAllowed(ctx);\n 727→      await ctx.sendChatAction('typing');\n 728→\n 729→      const streamPublisher = createEditableStreamPublisher(ctx);\n 730→      typingTimer = setInterval(() => {\n 731→        ctx.sendChatAction('typing').catch(() => undefined);\n 732→      }, TYPING_INTERVAL_MS);\n 733→\n 734→      const reply = await chatWithSession({\n 735→        channel: 'telegram',\n 736→        sessionId,\n 737→        message: ctx.message.text,\n 738→        realtimeHooks: {\n 739→          onStatus: ({ stage }) => {\n 740→            if (stage === 'running') {\n 741→              ctx.sendChatAction('typing').catch(() => undefined);\n 742→            }\n 743→          },\n 744→          onAssistantChunk: ({ text }) => {\n 745→            streamPublisher.push(text);\n 746→          }\n 747→        }\n 748→      });\n 749→\n 750→      const { fileRefs, cleanedText } = extractFileMarkers(reply);\n 751→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 752→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 753→\n 754→      streamPublisher.setFinalText(finalText);\n 755→      const streamed = await streamPublisher.finish();\n 756→      if (streamed.outputLength === 0) {\n 757→        await replyLargeText(ctx, finalText);\n 758→      }\n 759→\n 760→      if (fileRefs.length > 0) {\n 761→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 762→        const failed = fileSendResults.filter((item) => !item.sent);\n 763→\n 764→        if (failed.length === 0) {\n 765→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 766→        } else {\n 767→          const failedList = failed\n 768→            .map((item) => {\n 769→              const reason =\n 770→                item.reason === 'relative_path_not_allowed'\n 771→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 772→                  : item.reason === 'not_found'\n 773→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 774→                    : item.reason;\n 775→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 776→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 777→            })\n 778→            .join('\\n');\n 779→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 780→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 781→        }\n 782→      }\n 783→    } catch (error) {\n 784→      const message = error instanceof Error ? error.message : String(error);\n 785→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 786→      await safeReply(ctx, `处理失败：${message}`);\n 787→    } finally {\n 788→      if (typingTimer) {\n 789→        clearInterval(typingTimer);\n 790→      }\n 791→    }\n 792→  });\n 793→\n 794→  return bot;\n 795→}\n 796→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce38bdd117b44f51df57146b62d27","__timestamp":"2026-03-12T19:48:01.879Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
