{"type":"user","uuid":"68b4c538-d467-42ed-965f-b9a946bf6ac6","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce395b62041bd24a7d55720b24f3f","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: AI CLI Service\n   3→ *\n   4→ * Encapsulates AI CLI execution logic with process tracking,\n   5→ * heartbeat, and interrupt support.\n   6→ */\n   7→\n   8→import { spawn } from 'node:child_process';\n   9→import { config } from '../config.js';\n  10→import { logger } from '../utils/logger.js';\n  11→import { sessionStore } from './session-store.js';\n  12→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n  13→\n  14→/**\n  15→ * @typedef {Object} AiCliExecutionOptions\n  16→ * @property {string} sessionId - Session identifier\n  17→ * @property {string} prompt - User prompt/input\n  18→ * @property {Object} [hooks] - Callback hooks\n  19→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n  20→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n  21→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n  22→ * @property {AbortSignal} [signal] - Optional abort signal\n  23→ * @property {number} [timeoutMs] - Optional timeout override\n  24→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n  25→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n  26→ * @property {string} [bin] - Optional binary override (for testing)\n  27→ */\n  28→\n  29→/**\n  30→ * @typedef {Object} AiCliExecutionResult\n  31→ * @property {string} output - Final output text\n  32→ * @property {boolean} timedOut - Whether execution timed out\n  33→ * @property {boolean} interrupted - Whether execution was interrupted\n  34→ * @property {number} elapsedMs - Execution time in milliseconds\n  35→ * @property {number|null} exitCode - Process exit code (if completed)\n  36→ * @property {string} stderr - Error output if any\n  37→ */\n  38→\n  39→/**\n  40→ * @typedef {Object} HeartbeatInfo\n  41→ * @property {number} elapsedMs - Elapsed time in milliseconds\n  42→ * @property {number} stdoutBytes - Bytes received so far\n  43→ * @property {string} status - Current status ('running', 'streaming')\n  44→ */\n  45→\n  46→/**\n  47→ * Write text to echo output for debugging.\n  48→ * @param {string} tag - Tag for the output\n  49→ * @param {string} text - Text to write\n  50→ */\n  51→function writeEcho(tag, text) {\n  52→  const normalized = String(text ?? '');\n  53→  if (!normalized) {\n  54→    return;\n  55→  }\n  56→\n  57→  const lines = normalized.split(/\\r?\\n/);\n  58→  for (const line of lines) {\n  59→    if (!line) {\n  60→      continue;\n  61→    }\n  62→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  63→  }\n  64→}\n  65→\n  66→/**\n  67→ * Execute AI CLI with session context and process tracking.\n  68→ * @param {AiCliExecutionOptions} options\n  69→ * @returns {Promise<AiCliExecutionResult>}\n  70→ */\n  71→export async function executeAiCli(options) {\n  72→  const {\n  73→    sessionId,\n  74→    prompt,\n  75→    hooks = {},\n  76→    signal,\n  77→    timeoutMs,\n  78→    heartbeatThresholdMs,\n  79→    heartbeatIntervalMs,\n  80→    bin\n  81→  } = options;\n  82→\n  83→  const effectiveBin = bin || config.codebuddyBin;\n  84→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n  85→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n  86→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n  87→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n  88→\n  89→  const args = ['-p', prompt];\n  90→  if (config.codebuddyPermissionFlag) {\n  91→    args.push(config.codebuddyPermissionFlag);\n  92→  }\n  93→\n  94→  return new Promise((resolve) => {\n  95→    let stdout = '';\n  96→    let stderr = '';\n  97→    let stdoutBytes = 0;\n  98→    let interrupted = false;\n  99→    let timedOut = false;\n 100→    const startedAt = Date.now();\n 101→    const sessionKey = sessionId;\n 102→\n 103→    // Heartbeat manager\n 104→    const heartbeatManager = createHeartbeatManager();\n 105→\n 106→    // Spawn process\n 107→    let child;\n 108→    try {\n 109→      child = spawn(effectiveBin, args, {\n 110→        stdio: ['ignore', 'pipe', 'pipe']\n 111→      });\n 112→    } catch (err) {\n 113→      resolve({\n 114→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 115→        timedOut: false,\n 116→        interrupted: false,\n 117→        elapsedMs: Date.now() - startedAt,\n 118→        exitCode: null,\n 119→        stderr: ''\n 120→      });\n 121→      return;\n 122→    }\n 123→\n 124→    // Track process in session store\n 125→    sessionStore.setActiveProcess(sessionKey, {\n 126→      pid: child.pid,\n 127→      startedAt,\n 128→      childProcess: child\n 129→    });\n 130→\n 131→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n 132→\n 133→    // Handle process error\n 134→    child.on('error', (err) => {\n 135→      cleanup();\n 136→      resolve({\n 137→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 138→        timedOut: false,\n 139→        interrupted: false,\n 140→        elapsedMs: Date.now() - startedAt,\n 141→        exitCode: null,\n 142→        stderr\n 143→      });\n 144→    });\n 145→\n 146→    // Handle stdout\n 147→    child.stdout.on('data', (chunk) => {\n 148→      const text = chunk.toString();\n 149→      stdout += text;\n 150→      stdoutBytes += Buffer.byteLength(text);\n 151→\n 152→      // Update session store byte count\n 153→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n 154→\n 155→      // Echo to console if enabled\n 156→      if (config.codebuddyEchoStdio) {\n 157→        writeEcho('stdout', text);\n 158→      }\n 159→\n 160→      // Call onChunk hook\n 161→      if (typeof hooks.onChunk === 'function') {\n 162→        hooks.onChunk(text);\n 163→      }\n 164→    });\n 165→\n 166→    // Handle stderr\n 167→    child.stderr.on('data', (chunk) => {\n 168→      const text = chunk.toString();\n 169→      stderr += text;\n 170→\n 171→      if (config.codebuddyEchoStdio) {\n 172→        writeEcho('stderr', text);\n 173→      }\n 174→    });\n 175→\n 176→    // Timeout handler\n 177→    const timeout = effectiveTimeoutMs > 0\n 178→      ? setTimeout(() => {\n 179→          timedOut = true;\n 180→          child.kill('SIGTERM');\n 181→\n 182→          // Schedule SIGKILL if process doesn't exit\n 183→          setTimeout(() => {\n 184→            if (sessionStore.getActiveProcess(sessionKey)) {\n 185→              child.kill('SIGKILL');\n 186→            }\n 187→          }, 5000);\n 188→        }, effectiveTimeoutMs)\n 189→      : null;\n 190→\n 191→    // Abort signal handler\n 192→    const onAbort = () => {\n 193→      interrupted = true;\n 194→      child.kill('SIGTERM');\n 195→\n 196→      // Schedule SIGKILL if process doesn't exit\n 197→      setTimeout(() => {\n 198→        if (sessionStore.getActiveProcess(sessionKey)) {\n 199→          child.kill('SIGKILL');\n 200→        }\n 201→      }, 5000);\n 202→    };\n 203→\n 204→    if (signal) {\n 205→      signal.addEventListener('abort', onAbort);\n 206→    }\n 207→\n 208→    // Heartbeat setup\n 209→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n 210→      heartbeatManager.start({\n 211→        callback: () => {\n 212→          const elapsedMs = Date.now() - startedAt;\n 213→          hooks.onHeartbeat({\n 214→            elapsedMs,\n 215→            stdoutBytes,\n 216→            status: 'running'\n 217→          });\n 218→        },\n 219→        intervalMs: effectiveHeartbeatIntervalMs,\n 220→        thresholdMs: effectiveHeartbeatThresholdMs\n 221→      });\n 222→    }\n 223→\n 224→    // Cleanup function\n 225→    function cleanup() {\n 226→      if (timeout) {\n 227→        clearTimeout(timeout);\n 228→      }\n 229→      heartbeatManager.stop();\n 230→      sessionStore.clearActiveProcess(sessionKey);\n 231→      if (signal) {\n 232→        signal.removeEventListener('abort', onAbort);\n 233→      }\n 234→    }\n 235→\n 236→    // Handle process close\n 237→    child.on('close', (code) => {\n 238→      const elapsedMs = Date.now() - startedAt;\n 239→\n 240→      cleanup();\n 241→\n 242→      logger.info(\n 243→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n 244→        'AI CLI process closed'\n 245→      );\n 246→\n 247→      // Build output\n 248→      let output = stdout.trim();\n 249→\n 250→      if (interrupted) {\n 251→        output = output || '任务已被用户中断。';\n 252→      } else if (timedOut) {\n 253→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n 254→      } else if (code !== 0) {\n 255→        output = output || `AI CLI 退出码 ${code}。`;\n 256→        if (stderr.trim()) {\n 257→          output += `\\n错误信息:\\n${stderr.trim()}`;\n 258→        }\n 259→      }\n 260→\n 261→      resolve({\n 262→        output: output || 'AI CLI 未返回文本结果。',\n 263→        timedOut,\n 264→        interrupted,\n 265→        elapsedMs,\n 266→        exitCode: code,\n 267→        stderr: stderr.trim()\n 268→      });\n 269→    });\n 270→  });\n 271→}\n 272→\n 273→/**\n 274→ * Interrupt running AI CLI task for a session.\n 275→ * @param {string} sessionId - Session identifier\n 276→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 277→ */\n 278→export function interruptAiCli(sessionId) {\n 279→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 280→\n 281→  if (!processInfo) {\n 282→    return { ok: false, error: '没有正在执行的任务。' };\n 283→  }\n 284→\n 285→  const { pid, childProcess } = processInfo;\n 286→\n 287→  try {\n 288→    // Send SIGTERM first\n 289→    childProcess.kill('SIGTERM');\n 290→\n 291→    // Schedule SIGKILL as backup\n 292→    setTimeout(() => {\n 293→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n 294→      if (stillRunning) {\n 295→        try {\n 296→          childProcess.kill('SIGKILL');\n 297→        } catch {\n 298→          // Process already dead\n 299→        }\n 300→      }\n 301→    }, 5000);\n 302→\n 303→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n 304→\n 305→    return { ok: true, pid };\n 306→  } catch (err) {\n 307→    return { ok: false, error: `中断失败: ${err.message}` };\n 308→  }\n 309→}\n 310→\n 311→/**\n 312→ * Check if AI CLI is running for a session.\n 313→ * @param {string} sessionId\n 314→ * @returns {boolean}\n 315→ */\n 316→export function isAiCliRunning(sessionId) {\n 317→  return sessionStore.getActiveProcess(sessionId) !== null;\n 318→}\n 319→\n 320→/**\n 321→ * Get active process info for a session.\n 322→ * @param {string} sessionId\n 323→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number } | null}\n 324→ */\n 325→export function getActiveProcessInfo(sessionId) {\n 326→  const info = sessionStore.getActiveProcess(sessionId);\n 327→  if (!info) {\n 328→    return null;\n 329→  }\n 330→\n 331→  // Don't expose childProcess to external callers\n 332→  return {\n 333→    pid: info.pid,\n 334→    startedAt: info.startedAt,\n 335→    stdoutBytes: info.stdoutBytes ?? 0\n 336→  };\n 337→}\n 338→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce38bdd117b44f51df57146b62d27","__timestamp":"2026-03-12T19:46:05.967Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
