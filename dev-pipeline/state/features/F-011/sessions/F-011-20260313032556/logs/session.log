{"type":"user","uuid":"e4f41096-6f73-42d1-abfb-f52d3202e037","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"call_aba551a346a74f54a3ccdecf","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Tests for AI CLI Telegram Flow\n   3→ * F-011, T-039: Test full Telegram → AI CLI → output flow\n   4→ */\n   5→\n   6→import { describe, test, beforeEach, afterEach } from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { writeFile, mkdir, rm } from 'node:fs/promises';\n   9→import { join } from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→\n  12→import { sessionStore } from '../../src/services/session-store.js';\n  13→import {\n  14→  executeAiCli,\n  15→  interruptAiCli,\n  16→  isAiCliRunning,\n  17→  getActiveProcessInfo,\n  18→  canInterruptAiCli,\n  19→  resetMetrics,\n  20→  getMetrics\n  21→} from '../../src/services/ai-cli-service.js';\n  22→import { convertToMarkdownV2 } from '../../src/utils/markdown-v2-formatter.js';\n  23→\n  24→describe('F-011 AI CLI Telegram Flow Integration', () => {\n  25→  const testSessionId = 'test-telegram-session-001';\n  26→  const testUserId = '123456789';\n  27→  const adminUserId = '987654321';\n  28→\n  29→  beforeEach(() => {\n  30→    sessionStore.clear(testSessionId);\n  31→    resetMetrics();\n  32→  });\n  33→\n  34→  afterEach(() => {\n  35→    sessionStore.clear(testSessionId);\n  36→  });\n  37→\n  38→  describe('Normal Execution Flow', () => {\n  39→    test('should execute AI CLI and return output', async () => {\n  40→      const chunks = [];\n  41→      const result = await executeAiCli({\n  42→        sessionId: testSessionId,\n  43→        prompt: 'echo hello',\n  44→        userId: testUserId,\n  45→        bin: 'echo',\n  46→        timeoutMs: 5000,\n  47→        hooks: {\n  48→          onChunk: (text) => chunks.push(text)\n  49→        }\n  50→      });\n  51→\n  52→      assert.ok(result.output);\n  53→      assert.equal(result.timedOut, false);\n  54→      assert.equal(result.interrupted, false);\n  55→      assert.ok(result.elapsedMs >= 0);\n  56→      // Exit code from echo should be 0\n  57→      assert.equal(result.exitCode, 0);\n  58→\n  59→      // Check that chunks were received\n  60→      assert.ok(chunks.length > 0 || result.output.includes('hello'));\n  61→    });\n  62→\n  63→    test('should track process during execution', async () => {\n  64→      // Start a long-running process\n  65→      const executionPromise = executeAiCli({\n  66→        sessionId: testSessionId,\n  67→        prompt: 'sleep 0.5',\n  68→        userId: testUserId,\n  69→        bin: 'sleep',\n  70→        timeoutMs: 10000\n  71→      });\n  72→\n  73→      // Give it a moment to start\n  74→      await new Promise((resolve) => setTimeout(resolve, 50));\n  75→\n  76→      // Check process is tracked\n  77→      const isRunning = isAiCliRunning(testSessionId);\n  78→      assert.equal(isRunning, true);\n  79→\n  80→      const processInfo = getActiveProcessInfo(testSessionId);\n  81→      assert.ok(processInfo);\n  82→      assert.ok(processInfo.pid);\n  83→      assert.ok(processInfo.startedAt);\n  84→      assert.equal(processInfo.userId, testUserId);\n  85→\n  86→      // Wait for completion\n  87→      await executionPromise;\n  88→\n  89→      // Check process is cleared\n  90→      assert.equal(isAiCliRunning(testSessionId), false);\n  91→    });\n  92→  });\n  93→\n  94→  describe('Multi-turn Conversation', () => {\n  95→    test('should maintain session context across executions', async () => {\n  96→      // First message\n  97→      const result1 = await executeAiCli({\n  98→        sessionId: testSessionId,\n  99→        prompt: 'echo first message',\n 100→        userId: testUserId,\n 101→        bin: 'echo',\n 102→        timeoutMs: 5000\n 103→      });\n 104→\n 105→      assert.ok(result1.output);\n 106→\n 107→      // Second message - session should still have history\n 108→      const result2 = await executeAiCli({\n 109→        sessionId: testSessionId,\n 110→        prompt: 'echo second message',\n 111→        userId: testUserId,\n 112→        bin: 'echo',\n 113→        timeoutMs: 5000\n 114→      });\n 115→\n 116→      assert.ok(result2.output);\n 117→\n 118→      // Check session store has messages\n 119→      const messages = sessionStore.get(testSessionId);\n 120→      assert.ok(messages.length > 0);\n 121→    });\n 122→  });\n 123→\n 124→  describe('Stop Interrupt', () => {\n 125→    test('should interrupt running process via /stop', async () => {\n 126→      // Start a long-running process\n 127→      const executionPromise = executeAiCli({\n 128→        sessionId: testSessionId,\n 129→        prompt: '10', // sleep for 10 seconds\n 130→        userId: testUserId,\n 131→        bin: 'sleep',\n 132→        timeoutMs: 30000\n 133→      });\n 134→\n 135→      // Give it a moment to start\n 136→      await new Promise((resolve) => setTimeout(resolve, 100));\n 137→\n 138→      // Verify process is running\n 139→      assert.equal(isAiCliRunning(testSessionId), true);\n 140→\n 141→      // Interrupt\n 142→      const interruptResult = interruptAiCli(testSessionId);\n 143→      assert.equal(interruptResult.ok, true);\n 144→      assert.ok(interruptResult.pid);\n 145→\n 146→      // Wait for execution to complete\n 147→      const result = await executionPromise;\n 148→\n 149→      // Should be marked as interrupted\n 150→      assert.equal(result.interrupted, true);\n 151→    });\n 152→  });\n 153→\n 154→  describe('Error Handling', () => {\n 155→    test('should handle process spawn failure gracefully', async () => {\n 156→      const result = await executeAiCli({\n 157→        sessionId: testSessionId,\n 158→        prompt: 'test',\n 159→        userId: testUserId,\n 160→        bin: '/nonexistent/binary/that/does/not/exist',\n 161→        timeoutMs: 5000\n 162→      });\n 163→\n 164→      assert.ok(result.output.includes('无法启动') || result.output.includes('error'));\n 165→      assert.equal(result.timedOut, false);\n 166→      assert.equal(result.interrupted, false);\n 167→    });\n 168→\n 169→    test('should handle non-zero exit code', async () => {\n 170→      const result = await executeAiCli({\n 171→        sessionId: testSessionId,\n 172→        prompt: 'exit 1',\n 173→        userId: testUserId,\n 174→        bin: 'sh',\n 175→        timeoutMs: 5000\n 176→      });\n 177→\n 178→      assert.equal(result.exitCode, 1);\n 179→      assert.ok(result.output);\n 180→    });\n 181→  });\n 182→\n 183→  describe('Permission Checks (T-033)', () => {\n 184→    test('should allow task owner to interrupt', () => {\n 185→      // Simulate a running task\n 186→      sessionStore.setActiveProcess(testSessionId, {\n 187→        pid: 12345,\n 188→        startedAt: Date.now(),\n 189→        childProcess: { kill: () => {} },\n 190→        userId: testUserId\n 191→      });\n 192→\n 193→      const check = canInterruptAiCli(testSessionId, testUserId, () => false);\n 194→      assert.equal(check.canInterrupt, true);\n 195→    });\n 196→\n 197→    test('should allow admin to interrupt', () => {\n 198→      // Simulate a running task owned by another user\n 199→      sessionStore.setActiveProcess(testSessionId, {\n 200→        pid: 12345,\n 201→        startedAt: Date.now(),\n 202→        childProcess: { kill: () => {} },\n 203→        userId: 'other-user-id'\n 204→      });\n 205→\n 206→      const check = canInterruptAiCli(testSessionId, adminUserId, (id) => String(id) === adminUserId);\n 207→      assert.equal(check.canInterrupt, true);\n 208→    });\n 209→\n 210→    test('should deny non-owner non-admin interrupt', () => {\n 211→      // Simulate a running task owned by another user\n 212→      sessionStore.setActiveProcess(testSessionId, {\n 213→        pid: 12345,\n 214→        startedAt: Date.now(),\n 215→        childProcess: { kill: () => {} },\n 216→        userId: testUserId\n 217→      });\n 218→\n 219→      const check = canInterruptAiCli(testSessionId, 'another-user-id', () => false);\n 220→      assert.equal(check.canInterrupt, false);\n 221→      assert.ok(check.reason.includes('权限不足'));\n 222→    });\n 223→  });\n 224→\n 225→  describe('Metrics (T-051)', () => {\n 226→    test('should track execution metrics', async () => {\n 227→      // Execute a simple command\n 228→      await executeAiCli({\n 229→        sessionId: testSessionId,\n 230→        prompt: 'hello',\n 231→        userId: testUserId,\n 232→        bin: 'echo',\n 233→        timeoutMs: 5000\n 234→      });\n 235→\n 236→      const metrics = getMetrics();\n 237→      assert.equal(metrics.totalExecutions, 1);\n 238→      assert.equal(metrics.successCount, 1);\n 239→      assert.ok(metrics.averageDurationMs >= 0);\n 240→    });\n 241→\n 242→    test('should track interrupt metrics', async () => {\n 243→      // Start and interrupt a process\n 244→      const execPromise = executeAiCli({\n 245→        sessionId: testSessionId,\n 246→        prompt: '5',\n 247→        userId: testUserId,\n 248→        bin: 'sleep',\n 249→        timeoutMs: 30000\n 250→      });\n 251→\n 252→      await new Promise((resolve) => setTimeout(resolve, 50));\n 253→      interruptAiCli(testSessionId);\n 254→      await execPromise;\n 255→\n 256→      const metrics = getMetrics();\n 257→      assert.equal(metrics.totalExecutions, 1);\n 258→      assert.equal(metrics.interruptCount, 1);\n 259→    });\n 260→  });\n 261→});\n 262→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:01:06.425Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"973576d7-c820-405f-967b-979c128d18a2","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"call_876b4611d3af465f98fbf46a","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for F-011 AI CLI Service\n   3→ * T-010, T-011, T-012, T-013, T-014, T-015, T-016, T-017\n   4→ */\n   5→\n   6→import { describe, test, beforeEach, afterEach, mock } from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→\n   9→describe('F-011 AI CLI Service', () => {\n  10→  const testSessionId = 'test-session-f011';\n  11→\n  12→  beforeEach(async () => {\n  13→    // Reset modules to get fresh instances\n  14→    const { sessionStore } = await import('../../src/services/session-store.js');\n  15→    sessionStore.clear(testSessionId);\n  16→  });\n  17→\n  18→  afterEach(async () => {\n  19→    const { sessionStore } = await import('../../src/services/session-store.js');\n  20→    sessionStore.clear(testSessionId);\n  21→  });\n  22→\n  23→  describe('executeAiCli', () => {\n  24→    test('should export executeAiCli function', async () => {\n  25→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  26→      assert.ok(typeof executeAiCli === 'function');\n  27→    });\n  28→\n  29→    test('should return result object with required properties', async () => {\n  30→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  31→\n  32→      const result = await executeAiCli({\n  33→        sessionId: testSessionId,\n  34→        prompt: 'echo hello'\n  35→      });\n  36→\n  37→      assert.ok(result);\n  38→      assert.ok('output' in result);\n  39→      assert.ok('elapsedMs' in result);\n  40→      assert.ok('timedOut' in result);\n  41→      assert.ok('interrupted' in result);\n  42→    });\n  43→\n  44→    test('should track active process in session store', async () => {\n  45→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  46→      const { sessionStore } = await import('../../src/services/session-store.js');\n  47→\n  48→      // Start execution (it should track the process)\n  49→      const resultPromise = executeAiCli({\n  50→        sessionId: testSessionId,\n  51→        prompt: 'echo test'\n  52→      });\n  53→\n  54→      // Wait for completion\n  55→      await resultPromise;\n  56→\n  57→      // After completion, process should be cleared\n  58→      const processInfo = sessionStore.getActiveProcess(testSessionId);\n  59→      assert.equal(processInfo, null);\n  60→    });\n  61→\n  62→    test('should call onChunk callback for streaming output', async () => {\n  63→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  64→\n  65→      const chunks = [];\n  66→      const result = await executeAiCli({\n  67→        sessionId: testSessionId,\n  68→        prompt: 'echo hello world',\n  69→        hooks: {\n  70→          onChunk: (text) => { chunks.push(text); }\n  71→        }\n  72→      });\n  73→\n  74→      // Chunks should have been captured\n  75→      assert.ok(Array.isArray(chunks));\n  76→    });\n  77→\n  78→    test('should handle timeout correctly', async () => {\n  79→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  80→\n  81→      // Use a very short timeout\n  82→      const result = await executeAiCli({\n  83→        sessionId: testSessionId,\n  84→        prompt: 'sleep 5 && echo done',\n  85→        timeoutMs: 100  // Very short timeout\n  86→      });\n  87→\n  88→      assert.equal(result.timedOut, true);\n  89→    });\n  90→\n  91→    test('should handle abort signal', async () => {\n  92→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  93→\n  94→      const controller = new AbortController();\n  95→\n  96→      // Start execution\n  97→      const resultPromise = executeAiCli({\n  98→        sessionId: testSessionId,\n  99→        prompt: 'sleep 10 && echo done',\n 100→        signal: controller.signal\n 101→      });\n 102→\n 103→      // Abort after a short delay\n 104→      setTimeout(() => controller.abort(), 100);\n 105→\n 106→      const result = await resultPromise;\n 107→      assert.equal(result.interrupted, true);\n 108→    });\n 109→\n 110→    test('should clean up process on completion', async () => {\n 111→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 112→      const { sessionStore } = await import('../../src/services/session-store.js');\n 113→\n 114→      await executeAiCli({\n 115→        sessionId: testSessionId,\n 116→        prompt: 'echo test'\n 117→      });\n 118→\n 119→      const processInfo = sessionStore.getActiveProcess(testSessionId);\n 120→      assert.equal(processInfo, null);\n 121→    });\n 122→\n 123→    test('should call onHeartbeat callback during long execution', async () => {\n 124→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 125→\n 126→      const heartbeats = [];\n 127→      const result = await executeAiCli({\n 128→        sessionId: testSessionId,\n 129→        prompt: 'sleep 1 && echo done',\n 130→        hooks: {\n 131→          onHeartbeat: (info) => { heartbeats.push(info); }\n 132→        },\n 133→        heartbeatThresholdMs: 10,\n 134→        heartbeatIntervalMs: 100\n 135→      });\n 136→\n 137→      // Heartbeats should have been captured\n 138→      assert.ok(Array.isArray(heartbeats));\n 139→    });\n 140→  });\n 141→\n 142→  describe('interruptAiCli', () => {\n 143→    test('should export interruptAiCli function', async () => {\n 144→      const { interruptAiCli } = await import('../../src/services/ai-cli-service.js');\n 145→      assert.ok(typeof interruptAiCli === 'function');\n 146→    });\n 147→\n 148→    test('should return error if no process running', async () => {\n 149→      const { interruptAiCli } = await import('../../src/services/ai-cli-service.js');\n 150→\n 151→      const result = interruptAiCli('non-existent-session');\n 152→\n 153→      assert.equal(result.ok, false);\n 154→      assert.ok(result.error);\n 155→    });\n 156→\n 157→    test('should clear session store after interrupt', async () => {\n 158→      const { executeAiCli, interruptAiCli } = await import('../../src/services/ai-cli-service.js');\n 159→      const { sessionStore } = await import('../../src/services/session-store.js');\n 160→\n 161→      // Start a long-running execution\n 162→      const execPromise = executeAiCli({\n 163→        sessionId: testSessionId,\n 164→        prompt: 'sleep 10 && echo done',\n 165→        timeoutMs: 20000  // Long timeout\n 166→      });\n 167→\n 168→      // Wait a bit for the process to start\n 169→      await new Promise(resolve => setTimeout(resolve, 200));\n 170→\n 171→      // Verify process is tracked\n 172→      const processInfo = sessionStore.getActiveProcess(testSessionId);\n 173→      assert.ok(processInfo, 'Process should be tracked');\n 174→\n 175→      // Interrupt\n 176→      const result = interruptAiCli(testSessionId);\n 177→      assert.equal(result.ok, true);\n 178→\n 179→      // Wait for execution to complete\n 180→      const execResult = await execPromise;\n 181→      assert.equal(execResult.interrupted, true);\n 182→    });\n 183→  });\n 184→\n 185→  describe('isAiCliRunning', () => {\n 186→    test('should export isAiCliRunning function', async () => {\n 187→      const { isAiCliRunning } = await import('../../src/services/ai-cli-service.js');\n 188→      assert.ok(typeof isAiCliRunning === 'function');\n 189→    });\n 190→\n 191→    test('should return false when no process running', async () => {\n 192→      const { isAiCliRunning } = await import('../../src/services/ai-cli-service.js');\n 193→\n 194→      const running = isAiCliRunning('non-existent-session');\n 195→      assert.equal(running, false);\n 196→    });\n 197→  });\n 198→\n 199→  describe('getActiveProcessInfo', () => {\n 200→    test('should export getActiveProcessInfo function', async () => {\n 201→      const { getActiveProcessInfo } = await import('../../src/services/ai-cli-service.js');\n 202→      assert.ok(typeof getActiveProcessInfo === 'function');\n 203→    });\n 204→\n 205→    test('should return null when no process running', async () => {\n 206→      const { getActiveProcessInfo } = await import('../../src/services/ai-cli-service.js');\n 207→\n 208→      const info = getActiveProcessInfo('non-existent-session');\n 209→      assert.equal(info, null);\n 210→    });\n 211→  });\n 212→\n 213→  describe('Error Handling', () => {\n 214→    test('should return helpful error for process spawn failure', async () => {\n 215→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 216→\n 217→      const result = await executeAiCli({\n 218→        sessionId: testSessionId,\n 219→        prompt: 'test prompt',\n 220→        bin: 'non-existent-command-that-should-fail'\n 221→      });\n 222→\n 223→      assert.ok(result.output);\n 224→      assert.ok(result.output.includes('无法启动') || result.output.includes('error') || result.output.includes('失败'));\n 225→    });\n 226→\n 227→    test('should include suggestion on timeout', async () => {\n 228→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 229→\n 230→      const result = await executeAiCli({\n 231→        sessionId: testSessionId,\n 232→        prompt: 'sleep 5',\n 233→        timeoutMs: 100\n 234→      });\n 235→\n 236→      assert.equal(result.timedOut, true);\n 237→      assert.ok(result.output);\n 238→    });\n 239→  });\n 240→});\n 241→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:01:06.449Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
