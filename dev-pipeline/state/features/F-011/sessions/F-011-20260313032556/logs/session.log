ng/test/index.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/@pinojs/redact/test/prototype-pollution.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/process-warning/test/issue-88.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/@pinojs/redact/test/selective-clone.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino-std-serializers/test/req.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/process-warning/test/jest.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/minlength.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/process-warning/test/no-warnings.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino-std-serializers/test/res.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/mode.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/periodicflush.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/reopen.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/retry.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/sync.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/sonic-boom/test/write.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/base.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/bench.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/bundlers.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/commonjs-fallback.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/context.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/end.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/event.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/indexes.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/pkg/pkg.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/post-message.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/string-limit-2.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/string-limit.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/thread-management.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/transpiled.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/thread-stream/test/ts-node-fallback.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/basic.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/big.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/broken-pipe.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-child.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-disabled.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-early-console-freeze.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-is-level-enabled.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-levels.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-serializers.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-timestamp.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser-transmit.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/browser.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/bundlers-support.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/caller.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/complex-objects.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/core.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/crash.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/crlf.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/custom-levels.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/diagnostics.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/error-key.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/error.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/escaping.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/exit.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/formatters.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/hooks.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/http.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/esm/index.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/is-level-enabled.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/levels.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/metadata.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/mixin-merge-strategy.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/mixin.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/module-link.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/multistream.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/node-options.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/pipeline.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/preload.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/redact.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/repl.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/serializers.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/stdout-protection.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/sync-false.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/sync-true.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/syncfalse.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/targets.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino-abstract-transport/test/base.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino-abstract-transport/test/worker.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/timestamp-nano.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/timestamp.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport-stream.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/node_modules/pino/test/transport/uses-pino-config.test.js\"]"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:15.201Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"5b1b6b8a-e446-46cf-952b-aeea24983a00","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce38473308d583caf754050aafe98","content":[{"type":"text","text":"   1→/**\n   2→ * Permission Guard Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides user permission tiers and command authorization checking.\n   6→ */\n   7→\n   8→import { config } from '../config.js';\n   9→\n  10→/**\n  11→ * Role hierarchy levels (higher = more permissions)\n  12→ */\n  13→export const ROLE_HIERARCHY = {\n  14→  viewer: 0,\n  15→  operator: 1,\n  16→  admin: 2\n  17→};\n  18→\n  19→/**\n  20→ * Minimum required role for each command\n  21→ */\n  22→const COMMAND_MIN_ROLE = {\n  23→  status: 'viewer',\n  24→  logs: 'viewer',\n  25→  commits: 'viewer',\n  26→  // F-009: cd and more commands\n  27→  cd: 'operator',\n  28→  more: 'viewer',\n  29→  // F-010: File Manager commands\n  30→  ls: 'viewer',\n  31→  tree: 'viewer',\n  32→  cat: 'viewer',\n  33→  head: 'viewer',\n  34→  tail: 'viewer',\n  35→  find: 'viewer',\n  36→  upload: 'operator',\n  37→  download: 'operator',\n  38→  pipeline: 'operator',\n  39→  bugfix: 'operator',\n  40→  planner: 'operator',\n  41→  retry: 'operator',\n  42→  commit: 'operator',\n  43→  stop: 'admin',\n  44→  reset: 'admin',\n  45→  'force-unlock': 'admin',\n  46→  exec: 'admin',\n  47→  'commit-amend': 'admin',\n  48→  'commit-force': 'admin'\n  49→};\n  50→\n  51→/**\n  52→ * High-risk commands that require confirmation\n  53→ */\n  54→const HIGH_RISK_COMMANDS = new Set(['stop', 'reset', 'force-unlock', 'commit-amend', 'commit-force']);\n  55→\n  56→/**\n  57→ * Internal config reference - can be overridden for testing\n  58→ * @type {Object}\n  59→ */\n  60→let _config = config;\n  61→\n  62→/**\n  63→ * Set config for testing purposes\n  64→ * @param {Object} testConfig\n  65→ */\n  66→export function setConfigForTesting(testConfig) {\n  67→  _config = testConfig;\n  68→}\n  69→\n  70→/**\n  71→ * Reset config to original (for testing cleanup)\n  72→ */\n  73→export function resetConfig() {\n  74→  _config = config;\n  75→}\n  76→\n  77→/**\n  78→ * Get user permission level\n  79→ * @param {string|number} userId - Telegram user ID\n  80→ * @returns {'admin'|'operator'|'viewer'}\n  81→ */\n  82→export function getUserRole(userId) {\n  83→  const userIdStr = String(userId);\n  84→  const configuredRole = _config.userPermissions.get(userIdStr);\n  85→\n  86→  if (configuredRole) {\n  87→    return configuredRole;\n  88→  }\n  89→\n  90→  // Default to operator for unknown users (AC-1.3)\n  91→  return 'operator';\n  92→}\n  93→\n  94→/**\n  95→ * Check if user is admin\n  96→ * @param {string|number} userId\n  97→ * @returns {boolean}\n  98→ */\n  99→export function isAdmin(userId) {\n 100→  return getUserRole(userId) === 'admin';\n 101→}\n 102→\n 103→/**\n 104→ * Check if user can execute command\n 105→ * @param {string|number} userId\n 106→ * @param {string} command - Command name\n 107→ * @returns {{ allowed: boolean, requiresConfirmation: boolean, reason?: string }}\n 108→ */\n 109→export function checkCommandPermission(userId, command) {\n 110→  const userRole = getUserRole(userId);\n 111→  const minRole = COMMAND_MIN_ROLE[command] || 'viewer';\n 112→\n 113→  // Special handling for exec command (AC-2.4, F-002)\n 114→  if (command === 'exec' && !_config.enableSystemExec) {\n 115→    return {\n 116→      allowed: false,\n 117→      requiresConfirmation: false,\n 118→      reason: '系统命令执行未启用。请在 .env 中设置 ENABLE_SYSTEM_EXEC=true。'\n 119→    };\n 120→  }\n 121→\n 122→  // Check role hierarchy\n 123→  const userLevel = ROLE_HIERARCHY[userRole];\n 124→  const requiredLevel = ROLE_HIERARCHY[minRole];\n 125→\n 126→  if (userLevel < requiredLevel) {\n 127→    return {\n 128→      allowed: false,\n 129→      requiresConfirmation: false,\n 130→      reason: `权限不足。此命令需要 ${minRole} 权限，当前权限: ${userRole}。`\n 131→    };\n 132→  }\n 133→\n 134→  // Check if this is a high-risk command requiring confirmation\n 135→  const requiresConfirmation = HIGH_RISK_COMMANDS.has(command);\n 136→\n 137→  return {\n 138→    allowed: true,\n 139→    requiresConfirmation\n 140→  };\n 141→}\n 142→\n 143→export default {\n 144→  getUserRole,\n 145→  checkCommandPermission,\n 146→  isAdmin,\n 147→  ROLE_HIERARCHY,\n 148→  setConfigForTesting,\n 149→  resetConfig\n 150→};\n 151→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:15.208Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"364a0480-7d9d-4e8b-9e3c-e6b40eda25c2","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce384750018e9cf471ddde82d89ba","content":[{"type":"text","text":"   1→/**\n   2→ * Telegram Pusher Service\n   3→ *\n   4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-4: Heartbeat Progress Push, US-5: Error Summary Push\n   5→ *\n   6→ * Manages Telegram message pushing with throttling, chunking, and heartbeat.\n   7→ *\n   8→ * Design Decisions:\n   9→ * - D2: In-memory queue with retry, non-blocking\n  10→ * - D4: Event-driven heartbeat with time throttle\n  11→ * - D7: Retry strategy: max 3, exponential backoff (1s → 2s → 4s)\n  12→ */\n  13→\n  14→import { randomUUID } from 'node:crypto';\n  15→\n  16→import { loadPipelineInfraConfig as _loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  17→\n  18→const DEFAULT_THROTTLE_INTERVAL = 30 * 1000; // 30 seconds\n  19→const DEFAULT_SEGMENT_INTERVAL = 500; // 500ms between segments\n  20→const DEFAULT_ERROR_LINES_COUNT = 10;\n  21→const MAX_MESSAGE_LENGTH = 4000;\n  22→const MAX_RETRIES = 3;\n  23→\n  24→/**\n  25→ * Create a Telegram pusher instance.\n  26→ * @param {Object} options - Options\n  27→ * @param {Object} options.bot - Telegraf bot instance\n  28→ * @param {number} options.targetChatId - Target chat ID\n  29→ * @param {number} [options.heartbeatInterval] - Heartbeat interval in ms\n  30→ * @param {number} [options.heartbeatFeatureCount] - Features completed before push check\n  31→ * @param {number} [options.errorLinesCount] - Error lines to include\n  32→ * @param {number} [options.throttleInterval] - Throttle interval in ms\n  33→ * @param {number} [options.segmentInterval] - Segment delay in ms\n  34→ * @param {number} [options.maxRetries] - Max retry attempts\n  35→ * @param {Object} [options.heartbeatConfig] - Heartbeat configuration\n  36→ * @returns {Object} Telegram pusher interface\n  37→ */\n  38→// @ts-ignore — options validated at runtime; default {} for destructuring convenience\n  39→export function createTelegramPusher(options = {}) {\n  40→  const bot = options.bot;\n  41→  const targetChatId = options.targetChatId;\n  42→  const heartbeatInterval = options.heartbeatInterval || options.heartbeatConfig?.intervalMs || 30000;\n  43→  const _heartbeatFeatureCount = options.heartbeatFeatureCount || 1;\n  44→  const errorLinesCount = options.errorLinesCount || options.heartbeatConfig?.errorLinesCount || DEFAULT_ERROR_LINES_COUNT;\n  45→  const throttleInterval = options.throttleInterval || DEFAULT_THROTTLE_INTERVAL;\n  46→  const segmentInterval = options.segmentInterval || DEFAULT_SEGMENT_INTERVAL;\n  47→  const maxRetries = options.maxRetries || MAX_RETRIES;\n  48→  const heartbeatConfig = options.heartbeatConfig || {};\n  49→\n  50→  // Internal state\n  51→  const heartbeatTimers = new Map(); // type -> timer\n  52→  const throttleTimestamps = new Map(); // key -> lastExecutionTime\n  53→  const messageQueue = [];\n  54→  let queueProcessing = false;\n  55→\n  56→  /**\n  57→   * Throttle a function call.\n  58→   * @param {string} key - Throttle key\n  59→   * @param {Function} fn - Async function to throttle\n  60→   * @returns {Promise<void>}\n  61→   */\n  62→  async function throttle(key, fn) {\n  63→    const now = Date.now();\n  64→    const lastExecution = throttleTimestamps.get(key) || 0;\n  65→\n  66→    if (now - lastExecution < throttleInterval) {\n  67→      // Throttled, skip execution\n  68→      return;\n  69→    }\n  70→\n  71→    throttleTimestamps.set(key, now);\n  72→    await fn();\n  73→  }\n  74→\n  75→  /**\n  76→   * Split message into chunks respecting Telegram limits.\n  77→   * @param {string} text - Text to split\n  78→   * @returns {Array<string>} Array of chunks\n  79→   */\n  80→  function splitMessage(text) {\n  81→    if (text.length <= MAX_MESSAGE_LENGTH) {\n  82→      return [text];\n  83→    }\n  84→\n  85→    const chunks = [];\n  86→    let remaining = text;\n  87→\n  88→    while (remaining.length > 0) {\n  89→      // Find a good break point\n  90→      let breakPoint = MAX_MESSAGE_LENGTH;\n  91→      if (remaining.length > MAX_MESSAGE_LENGTH) {\n  92→        // Try to break at newline\n  93→        const newlineSearch = remaining.lastIndexOf('\\n', MAX_MESSAGE_LENGTH);\n  94→        if (newlineSearch > MAX_MESSAGE_LENGTH / 2) {\n  95→          breakPoint = newlineSearch + 1;\n  96→        }\n  97→      }\n  98→\n  99→      chunks.push(remaining.slice(0, breakPoint));\n 100→      remaining = remaining.slice(breakPoint);\n 101→    }\n 102→\n 103→    return chunks;\n 104→  }\n 105→\n 106→  /**\n 107→   * Send a message chunked to respect Telegram limits.\n 108→   * @param {number} chatId - Target chat ID\n 109→   * @param {string} text - Message text\n 110→   * @returns {Promise<Array>} Array of message results\n 111→   */\n 112→  async function sendMessageChunked(chatId, text) {\n 113→    const chunks = splitMessage(text);\n 114→    const results = [];\n 115→    const total = chunks.length;\n 116→\n 117→    for (let i = 0; i < chunks.length; i++) {\n 118→      // Add segment numbering for multiple chunks\n 119→      let chunk = chunks[i];\n 120→      if (total > 1) {\n 121→        chunk = `[${i + 1}/${total}] ${chunk}`;\n 122→      }\n 123→\n 124→      try {\n 125→        const result = await bot.telegram.sendMessage(chatId, chunk, {\n 126→          parse_mode: 'Markdown'\n 127→        });\n 128→        results.push(result);\n 129→\n 130→        // Delay between segments\n 131→        if (i < chunks.length - 1 && segmentInterval > 0) {\n 132→          await new Promise(resolve => setTimeout(resolve, segmentInterval));\n 133→        }\n 134→      } catch (error) {\n 135→        // Queue for retry\n 136→        enqueueMessage({\n 137→          id: randomUUID(),\n 138→          chatId,\n 139→          text: chunk,\n 140→          type: 'notification',\n 141→          priority: 10,\n 142→          retryCount: 0\n 143→        });\n 144→        results.push({ error: error.message });\n 145→      }\n 146→    }\n 147→\n 148→    return results;\n 149→  }\n 150→\n 151→  /**\n 152→   * Send a file to chat.\n 153→   * @param {number} chatId - Target chat ID\n 154→   * @param {string} content - File content\n 155→   * @param {string} filename - Filename\n 156→   * @returns {Promise<Object>} Send result\n 157→   */\n 158→  async function sendFile(chatId, content, filename) {\n 159→    try {\n 160→      const { Input } = await import('telegraf');\n 161→      const buffer = Buffer.from(content, 'utf-8');\n 162→      // @ts-ignore — Telegraf Input constructor works at runtime\n 163→      const document = new Input(buffer, filename);\n 164→\n 165→      return await bot.telegram.sendDocument(chatId, document, {\n 166→        filename\n 167→      });\n 168→    } catch (_error) {\n 169→      // Fallback to chunked message if file send fails\n 170→      return sendMessageChunked(chatId, content);\n 171→    }\n 172→  }\n 173→\n 174→  /**\n 175→   * Enqueue a message for async processing.\n 176→   * @param {Object} message - Message object\n 177→   */\n 178→  function enqueueMessage(message) {\n 179→    messageQueue.push(message);\n 180→    processQueue();\n 181→  }\n 182→\n 183→  /**\n 184→   * Process message queue with retry logic.\n 185→   */\n 186→  async function processQueue() {\n 187→    if (queueProcessing) return;\n 188→    queueProcessing = true;\n 189→\n 190→    while (messageQueue.length > 0) {\n 191→      const message = messageQueue.shift();\n 192→\n 193→      try {\n 194→        await bot.telegram.sendMessage(message.chatId, message.text, {\n 195→          parse_mode: 'Markdown'\n 196→        });\n 197→      } catch (_error) {\n 198→        // Retry with exponential backoff\n 199→        if (message.retryCount < maxRetries) {\n 200→          message.retryCount++;\n 201→          const delay = Math.pow(2, message.retryCount - 1) * 1000; // 1s, 2s, 4s\n 202→\n 203→          await new Promise(resolve => setTimeout(resolve, delay));\n 204→          messageQueue.unshift(message); // Re-queue at front\n 205→        }\n 206→        // If max retries exceeded, discard message (non-blocking)\n 207→      }\n 208→    }\n 209→\n 210→    queueProcessing = false;\n 211→  }\n 212→\n 213→  /**\n 214→   * Start heartbeat for a pipeline type.\n 215→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 216→   * @param {Object} aggregator - Status aggregator\n 217→   */\n 218→  function startHeartbeat(type, aggregator) {\n 219→    // Check if heartbeat is enabled\n 220→    if (heartbeatConfig.enabled === false) {\n 221→      return;\n 222→    }\n 223→\n 224→    // Don't start duplicate timers\n 225→    if (heartbeatTimers.has(type)) {\n 226→      return;\n 227→    }\n 228→\n 229→    const timer = setInterval(async () => {\n 230→      await throttle(`heartbeat-${type}`, async () => {\n 231→        try {\n 232→          const status = await aggregator.aggregateStatus(type);\n 233→          const formatted = aggregator.formatStatusForTelegram(status);\n 234→          await sendMessageChunked(targetChatId, formatted);\n 235→        } catch (error) {\n 236→          // Log error but don't block\n 237→          console.error(`Heartbeat error for ${type}:`, error.message);\n 238→        }\n 239→      });\n 240→    }, heartbeatInterval);\n 241→\n 242→    heartbeatTimers.set(type, timer);\n 243→  }\n 244→\n 245→  /**\n 246→   * Stop heartbeat for a pipeline type.\n 247→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 248→   */\n 249→  function stopHeartbeat(type) {\n 250→    const timer = heartbeatTimers.get(type);\n 251→    if (timer) {\n 252→      clearInterval(timer);\n 253→      heartbeatTimers.delete(type);\n 254→    }\n 255→\n 256→    // Process remaining queue\n 257→    processQueue();\n 258→  }\n 259→\n 260→  /**\n 261→   * Handle feature completed event.\n 262→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 263→   * @param {string} featureId - Feature ID\n 264→   * @param {Object} aggregator - Status aggregator\n 265→   */\n 266→  async function onFeatureCompleted(type, featureId, aggregator) {\n 267→    await throttle(`feature-complete-${type}`, async () => {\n 268→      try {\n 269→        const status = await aggregator.aggregateStatus(type);\n 270→        const message = `✅ Feature 完成: ${featureId}\\n\\n` +\n 271→          `📊 进度: ${status.progress.completed}/${status.progress.total} (${status.progress.successRate}%)`;\n 272→        await sendMessageChunked(targetChatId, message);\n 273→      } catch (error) {\n 274→        console.error(`Feature completed notification error:`, error.message);\n 275→      }\n 276→    });\n 277→  }\n 278→\n 279→  /**\n 280→   * Push error summary notification.\n 281→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 282→   * @param {string} featureId - Feature ID\n 283→   * @param {Object} error - Error object\n 284→   * @returns {Promise<Object>} Push result\n 285→   */\n 286→  async function pushErrorSummary(type, featureId, error) {\n 287→    // Check silent mode\n 288→    if (heartbeatConfig.silentMode && error.isExpected) {\n 289→      return { ok: true, skipped: true };\n 290→    }\n 291→\n 292→    const lines = [];\n 293→    lines.push(`❌ **执行失败: ${featureId}**`);\n 294→    lines.push(`类型: ${error.type || 'unknown'}`);\n 295→    lines.push('');\n 296→\n 297→    if (error.message) {\n 298→      lines.push(`**错误信息:**`);\n 299→      lines.push(error.message);\n 300→      lines.push('');\n 301→    }\n 302→\n 303→    // Include execution time/duration\n 304→    if (error.duration) {\n 305→      const mins = Math.floor(error.duration / 60);\n 306→      const secs = error.duration % 60;\n 307→      lines.push(`⏱️ 执行时间: ${mins}m ${secs}s`);\n 308→      lines.push('');\n 309→    }\n 310→\n 311→    // Include error log lines\n 312→    if (error.logLines && error.logLines.length > 0) {\n 313→      lines.push(`**日志片段:** (最后 ${Math.min(errorLinesCount, error.logLines.length)} 行)`);\n 314→      const errorLines = error.logLines.slice(-errorLinesCount);\n 315→      lines.push('```');\n 316→      lines.push(errorLines.join('\\n'));\n 317→      lines.push('```');\n 318→    }\n 319→\n 320→    const message = lines.join('\\n');\n 321→\n 322→    try {\n 323→      const result = await sendMessageChunked(targetChatId, message);\n 324→      return {\n 325→        ok: true,\n 326→        messageId: result[0]?.message_id\n 327→      };\n 328→    } catch (err) {\n 329→      return {\n 330→        ok: false,\n 331→        errorCode: 'SEND_FAILED',\n 332→        message: err.message\n 333→      };\n 334→    }\n 335→  }\n 336→\n 337→  /**\n 338→   * Push startup notification.\n 339→   * @param {'feature' | 'bugfix'} type - Pipeline type\n 340→   * @param {Object} runInfo - Run info object\n 341→   * @returns {Promise<Object>} Push result\n 342→   */\n 343→  async function pushStartupNotification(type, runInfo) {\n 344→    const lines = [];\n 345→    lines.push(`🚀 **Pipeline 启动** (${type})`);\n 346→    lines.push(`Run ID: ${runInfo.runId}`);\n 347→    lines.push(`开始时间: ${runInfo.startedAt}`);\n 348→    lines.push('');\n 349→\n 350→    if (runInfo.targets && runInfo.targets.length > 0) {\n 351→      lines.push(`**目标列表:** (${runInfo.targets.length} 个)`);\n 352→      const displayTargets = runInfo.targets.slice(0, 10);\n 353→      for (const target of displayTargets) {\n 354→        lines.push(`  • ${target}`);\n 355→      }\n 356→      if (runInfo.targets.length > 10) {\n 357→        lines.push(`  ... 及其他 ${runInfo.targets.length - 10} 个`);\n 358→      }\n 359→    }\n 360→\n 361→    const message = lines.join('\\n');\n 362→\n 363→    try {\n 364→      const result = await sendMessageChunked(targetChatId, message);\n 365→      return {\n 366→        ok: true,\n 367→        messageId: result[0]?.message_id\n 368→      };\n 369→    } catch (err) {\n 370→      return {\n 371→        ok: false,\n 372→        errorCode: 'SEND_FAILED',\n 373→        message: err.message\n 374→      };\n 375→    }\n 376→  }\n 377→\n 378→  return {\n 379→    throttle,\n 380→    sendMessageChunked,\n 381→    sendFile,\n 382→    enqueueMessage,\n 383→    processQueue,\n 384→    startHeartbeat,\n 385→    stopHeartbeat,\n 386→    onFeatureCompleted,\n 387→    pushErrorSummary,\n 388→    pushStartupNotification\n 389→  };\n 390→}\n 391→\n 392→export default createTelegramPusher;\n 393→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:15.219Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
