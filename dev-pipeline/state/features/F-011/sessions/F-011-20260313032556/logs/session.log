{"type":"user","uuid":"5427024b-56c4-4daf-85bf-5fc7cad42704","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3845592345dd55bee0b6a39a25f","content":[{"type":"text","text":"   1→import { runCodeBuddy } from '../adapters/codebuddy.js';\n   2→import { sanitizeInput } from '../security/guard.js';\n   3→import { chatQueue } from './chat-queue.js';\n   4→import { sessionStore } from './session-store.js';\n   5→\n   6→export function buildSessionContext(channel, sessionId) {\n   7→  const normalizedChannel = String(channel ?? '').trim();\n   8→  const normalizedSessionId = String(sessionId ?? '').trim();\n   9→\n  10→  if (!normalizedChannel) {\n  11→    throw new Error('channel 不能为空。');\n  12→  }\n  13→\n  14→  if (!normalizedSessionId) {\n  15→    throw new Error('sessionId 不能为空。');\n  16→  }\n  17→\n  18→  return {\n  19→    channel: normalizedChannel,\n  20→    sessionId: normalizedSessionId,\n  21→    sessionKey: `${normalizedChannel}:${normalizedSessionId}`\n  22→  };\n  23→}\n  24→\n  25→/**\n  26→ * @param {Object} params\n  27→ * @param {string} params.channel\n  28→ * @param {string} params.sessionId\n  29→ * @param {string} params.message\n  30→ * @param {{ onStatus?: Function, onAssistantChunk?: Function, onAssistantDone?: Function }} [params.realtimeHooks]\n  31→ */\n  32→export async function chatWithSession({ channel, sessionId, message, realtimeHooks = {} }) {\n  33→  const session = buildSessionContext(channel, sessionId);\n  34→\n  35→  return chatQueue.run(session.sessionKey, async () => {\n  36→    const sanitized = sanitizeInput(message);\n  37→\n  38→    realtimeHooks.onStatus?.({\n  39→      stage: 'accepted',\n  40→      channel: session.channel,\n  41→      sessionId: session.sessionId\n  42→    });\n  43→\n  44→    sessionStore.append(session.sessionKey, 'user', sanitized);\n  45→\n  46→    const prompt = sessionStore.toPrompt(session.sessionKey, session.channel);\n  47→\n  48→    realtimeHooks.onStatus?.({\n  49→      stage: 'running',\n  50→      channel: session.channel,\n  51→      sessionId: session.sessionId\n  52→    });\n  53→\n  54→    const reply = await runCodeBuddy(prompt, {\n  55→      onStdoutChunk: (text) => {\n  56→        realtimeHooks.onAssistantChunk?.({\n  57→          text,\n  58→          channel: session.channel,\n  59→          sessionId: session.sessionId\n  60→        });\n  61→      }\n  62→    });\n  63→\n  64→    sessionStore.append(session.sessionKey, 'assistant', reply);\n  65→\n  66→    realtimeHooks.onAssistantDone?.({\n  67→      reply,\n  68→      channel: session.channel,\n  69→      sessionId: session.sessionId\n  70→    });\n  71→\n  72→    return reply;\n  73→  });\n  74→}\n  75→\n  76→export function resetSession({ channel, sessionId }) {\n  77→  const session = buildSessionContext(channel, sessionId);\n  78→  sessionStore.clear(session.sessionKey);\n  79→}\n  80→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:08.282Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"db697d7e-c31f-4182-9131-34baff8cfce2","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce38456f4522f5d73ae8d83528725","content":[{"type":"text","text":"   1→import { spawn } from 'node:child_process';\n   2→import { config } from '../config.js';\n   3→import { logger } from '../utils/logger.js';\n   4→\n   5→function writeEcho(tag, text) {\n   6→  const normalized = String(text ?? '');\n   7→  if (!normalized) {\n   8→    return;\n   9→  }\n  10→\n  11→  const lines = normalized.split(/\\r?\\n/);\n  12→  for (const line of lines) {\n  13→    if (!line) {\n  14→      continue;\n  15→    }\n  16→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  17→  }\n  18→}\n  19→\n  20→export async function runCodeBuddy(prompt, options = {}) {\n  21→  const { onStdoutChunk } = options;\n  22→  const args = ['-p', prompt];\n  23→\n  24→  if (config.codebuddyPermissionFlag) {\n  25→    args.push(config.codebuddyPermissionFlag);\n  26→  }\n  27→\n  28→  return new Promise((resolve, reject) => {\n  29→    const child = spawn(config.codebuddyBin, args, {\n  30→      stdio: ['ignore', 'pipe', 'pipe']\n  31→    });\n  32→\n  33→    const startedAt = Date.now();\n  34→    logger.info({ pid: child.pid, bin: config.codebuddyBin, args }, 'CodeBuddy process started');\n  35→\n  36→    let stdout = '';\n  37→    let stderr = '';\n  38→\n  39→    const heartbeat =\n  40→      config.codebuddyHeartbeatMs > 0\n  41→        ? setInterval(() => {\n  42→            const elapsedMs = Date.now() - startedAt;\n  43→            logger.info(\n  44→              {\n  45→                pid: child.pid,\n  46→                elapsedSec: Math.floor(elapsedMs / 1000),\n  47→                stdoutBytes: Buffer.byteLength(stdout),\n  48→                stderrBytes: Buffer.byteLength(stderr)\n  49→              },\n  50→              'CodeBuddy still running'\n  51→            );\n  52→          }, config.codebuddyHeartbeatMs)\n  53→        : null;\n  54→\n  55→    const timeout =\n  56→      config.requestTimeoutMs > 0\n  57→        ? setTimeout(() => {\n  58→            child.kill('SIGTERM');\n  59→            reject(new Error(`CodeBuddy 执行超时（>${config.requestTimeoutMs}ms）`));\n  60→          }, config.requestTimeoutMs)\n  61→        : null;\n  62→\n  63→    child.stdout.on('data', (chunk) => {\n  64→      const text = chunk.toString();\n  65→      stdout += text;\n  66→\n  67→      if (config.codebuddyEchoStdio) {\n  68→        writeEcho('stdout', text);\n  69→      }\n  70→\n  71→      if (typeof onStdoutChunk === 'function') {\n  72→        onStdoutChunk(text);\n  73→      }\n  74→    });\n  75→\n  76→    child.stderr.on('data', (chunk) => {\n  77→      const text = chunk.toString();\n  78→      stderr += text;\n  79→\n  80→      if (config.codebuddyEchoStdio) {\n  81→        writeEcho('stderr', text);\n  82→      }\n  83→    });\n  84→\n  85→    child.on('error', (err) => {\n  86→      if (timeout) {\n  87→        clearTimeout(timeout);\n  88→      }\n  89→      if (heartbeat) {\n  90→        clearInterval(heartbeat);\n  91→      }\n  92→      reject(new Error(`无法启动 CodeBuddy: ${err.message}`));\n  93→    });\n  94→\n  95→    child.on('close', (code) => {\n  96→      if (timeout) {\n  97→        clearTimeout(timeout);\n  98→      }\n  99→      if (heartbeat) {\n 100→        clearInterval(heartbeat);\n 101→      }\n 102→\n 103→      const elapsedMs = Date.now() - startedAt;\n 104→      logger.info(\n 105→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000) },\n 106→        'CodeBuddy process closed'\n 107→      );\n 108→\n 109→      if (code === 0) {\n 110→        resolve(stdout.trim() || 'CodeBuddy 未返回文本结果。');\n 111→        return;\n 112→      }\n 113→\n 114→      reject(\n 115→        new Error(`CodeBuddy 退出码 ${code}。${stderr ? `\\n错误信息:\\n${stderr.trim()}` : ''}`)\n 116→      );\n 117→    });\n 118→  });\n 119→}\n 120→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:08.283Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"ed46fc48-0b33-4eb6-8660-80f1e63cefc4","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce384586e8958258120ccc3ef0784","content":[{"type":"text","text":"   1→import { spawn } from 'node:child_process';\n   2→import { config } from '../config.js';\n   3→import { assertAllowedCommand, assertSystemExecEnabled } from '../security/system-guard.js';\n   4→\n   5→/**\n   6→ * Grace period after SIGTERM before SIGKILL (in ms)\n   7→ */\n   8→const GRACE_PERIOD_MS = 5000;\n   9→\n  10→/**\n  11→ * Execute a system command with optional working directory.\n  12→ * @param {string} command - Command to execute\n  13→ * @param {Object} [options] - Execution options\n  14→ * @param {string} [options.cwd] - Working directory for the command\n  15→ * @returns {Promise<{ stdout: string, stderr: string, exitCode: number, timedOut: boolean }>}\n  16→ */\n  17→export async function executeSystemCommand(command, options = {}) {\n  18→  assertSystemExecEnabled();\n  19→  const safeCommand = assertAllowedCommand(command);\n  20→\n  21→  const cwd = options.cwd || process.cwd();\n  22→\n  23→  return new Promise((resolve, reject) => {\n  24→    const child = spawn(safeCommand, {\n  25→      shell: true,\n  26→      stdio: ['ignore', 'pipe', 'pipe'],\n  27→      cwd\n  28→    });\n  29→\n  30→    let stdout = '';\n  31→    let stderr = '';\n  32→    let timedOut = false;\n  33→    let sigtermSent = false;\n  34→\n  35→    const timeout = setTimeout(() => {\n  36→      timedOut = true;\n  37→      sigtermSent = true;\n  38→      child.kill('SIGTERM');\n  39→\n  40→      // Schedule SIGKILL after grace period\n  41→      setTimeout(() => {\n  42→        if (!child.killed) {\n  43→          child.kill('SIGKILL');\n  44→        }\n  45→      }, GRACE_PERIOD_MS);\n  46→    }, config.systemExecTimeoutMs);\n  47→\n  48→    child.stdout.on('data', (chunk) => {\n  49→      stdout += chunk.toString();\n  50→    });\n  51→\n  52→    child.stderr.on('data', (chunk) => {\n  53→      stderr += chunk.toString();\n  54→    });\n  55→\n  56→    child.on('error', (error) => {\n  57→      clearTimeout(timeout);\n  58→      reject(new Error(`系统命令执行失败: ${error.message}`));\n  59→    });\n  60→\n  61→    child.on('close', (code) => {\n  62→      clearTimeout(timeout);\n  63→\n  64→      if (timedOut) {\n  65→        // Resolve with timeout status instead of rejecting\n  66→        resolve({\n  67→          stdout: stdout.trim(),\n  68→          stderr: stderr.trim(),\n  69→          exitCode: code ?? -1,\n  70→          timedOut: true\n  71→        });\n  72→      } else {\n  73→        resolve({\n  74→          stdout: stdout.trim(),\n  75→          stderr: stderr.trim(),\n  76→          exitCode: code ?? -1,\n  77→          timedOut: false\n  78→        });\n  79→      }\n  80→    });\n  81→  });\n  82→}\n  83→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:08.283Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"73f64266-5311-4514-8d86-d229132a18fe","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3845a1d6fa3b63b7283f55e066d","content":[{"type":"text","text":"   1→/**\n   2→ * Output Pager Service\n   3→ * F-009: General Command Executor\n   4→ *\n   5→ * Handles pagination of long command output for Telegram's 4096 character limit.\n   6→ */\n   7→\n   8→import { sessionStore } from './session-store.js';\n   9→\n  10→/**\n  11→ * Default chunk size for Telegram messages (leaving room for formatting)\n  12→ */\n  13→const DEFAULT_CHUNK_SIZE = 4000;\n  14→\n  15→/**\n  16→ * Paginate output text into chunks.\n  17→ * @param {string} text - Text to paginate\n  18→ * @param {number} [chunkSize=4000] - Size of each chunk\n  19→ * @returns {string[]} Array of text chunks\n  20→ */\n  21→export function paginateOutput(text, chunkSize = DEFAULT_CHUNK_SIZE) {\n  22→  const normalized = String(text ?? '');\n  23→\n  24→  if (normalized.length <= chunkSize) {\n  25→    return [normalized];\n  26→  }\n  27→\n  28→  const pages = [];\n  29→  for (let i = 0; i < normalized.length; i += chunkSize) {\n  30→    pages.push(normalized.slice(i, i + chunkSize));\n  31→  }\n  32→\n  33→  return pages;\n  34→}\n  35→\n  36→/**\n  37→ * Store output pages in session for later retrieval via /more.\n  38→ * @param {string} sessionId - Session identifier\n  39→ * @param {string[]} pages - Array of text pages\n  40→ */\n  41→export function storeOutputPages(sessionId, pages) {\n  42→  // Store a copy of the array to avoid mutation issues\n  43→  sessionStore.setOutputPages(sessionId, [...pages]);\n  44→}\n  45→\n  46→/**\n  47→ * Get the next page of output.\n  48→ * Removes and returns the first page from the stored pages.\n  49→ * @param {string} sessionId - Session identifier\n  50→ * @returns {string|null} Next page of output, or null if no pages left\n  51→ */\n  52→export function getNextPage(sessionId) {\n  53→  const pages = sessionStore.getOutputPages(sessionId);\n  54→\n  55→  if (!pages || pages.length === 0) {\n  56→    return null;\n  57→  }\n  58→\n  59→  const nextPage = pages.shift();\n  60→  return nextPage;\n  61→}\n  62→\n  63→/**\n  64→ * Clear stored output pages for a session.\n  65→ * @param {string} sessionId - Session identifier\n  66→ */\n  67→export function clearPages(sessionId) {\n  68→  sessionStore.clearOutputPages(sessionId);\n  69→}\n  70→\n  71→/**\n  72→ * Check if there are more pages available.\n  73→ * @param {string} sessionId - Session identifier\n  74→ * @returns {boolean} True if more pages exist\n  75→ */\n  76→export function hasMorePages(sessionId) {\n  77→  const pages = sessionStore.getOutputPages(sessionId);\n  78→  return pages !== null && pages.length > 0;\n  79→}\n  80→\n  81→export default {\n  82→  paginateOutput,\n  83→  storeOutputPages,\n  84→  getNextPage,\n  85→  clearPages,\n  86→  hasMorePages\n  87→};\n  88→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce383eccc5875defafa9a8dd8fbc3","__timestamp":"2026-03-12T19:27:08.284Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
