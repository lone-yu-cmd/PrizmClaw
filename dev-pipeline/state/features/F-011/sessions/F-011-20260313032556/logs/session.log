{"type":"user","uuid":"e42bdacc-54e9-430a-8b8c-fc0f9b40a9de","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3908fbef58a8ce03444c9039e2d","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: MarkdownV2 Formatter for Telegram\n   3→ *\n   4→ * Telegram MarkdownV2 requires escaping specific characters.\n   5→ * This module provides utilities for converting common Markdown\n   6→ * to Telegram's MarkdownV2 format.\n   7→ *\n   8→ * Reference: https://core.telegram.org/bots/api#markdownv2-style\n   9→ */\n  10→\n  11→/**\n  12→ * Characters that need escaping in MarkdownV2.\n  13→ * All these characters must be escaped with a backslash.\n  14→ */\n  15→const ESCAPE_CHARS = ['_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!'];\n  16→\n  17→/**\n  18→ * Escape text for Telegram MarkdownV2 format.\n  19→ * In MarkdownV2, all special characters must be escaped.\n  20→ * @param {string} text - Text to escape\n  21→ * @returns {string} Escaped text\n  22→ */\n  23→export function escapeMarkdownV2(text) {\n  24→  if (!text) return '';\n  25→\n  26→  let result = text;\n  27→  for (const char of ESCAPE_CHARS) {\n  28→    result = result.split(char).join('\\\\' + char);\n  29→  }\n  30→  return result;\n  31→}\n  32→\n  33→/**\n  34→ * Escape text inside code blocks.\n  35→ * Inside code blocks, only ` and \\ need escaping.\n  36→ * @param {string} code - Code content\n  37→ * @returns {string} Escaped code\n  38→ */\n  39→function escapeCodeContent(code) {\n  40→  if (!code) return '';\n  41→  return code\n  42→    .split('\\\\').join('\\\\\\\\')\n  43→    .split('`').join('\\\\`');\n  44→}\n  45→\n  46→/**\n  47→ * Format code block for Telegram MarkdownV2.\n  48→ * @param {string} code - Code content\n  49→ * @param {string} [language=''] - Optional language identifier\n  50→ * @returns {string} Formatted code block\n  51→ */\n  52→export function formatCodeBlock(code, language = '') {\n  53→  const escapedCode = escapeCodeContent(code ?? '');\n  54→  // Handle empty code case\n  55→  if (!escapedCode) {\n  56→    return '```' + language + '\\n```';\n  57→  }\n  58→  return '```' + language + '\\n' + escapedCode + '\\n```';\n  59→}\n  60→\n  61→/**\n  62→ * Format inline code for Telegram MarkdownV2.\n  63→ * @param {string} code - Code content\n  64→ * @returns {string} Formatted inline code\n  65→ */\n  66→export function formatInlineCode(code) {\n  67→  const escapedCode = escapeCodeContent(code ?? '');\n  68→  return '`' + escapedCode + '`';\n  69→}\n  70→\n  71→/**\n  72→ * Convert common Markdown to Telegram MarkdownV2.\n  73→ * Handles: code blocks, inline code, bold, italic, links.\n  74→ * @param {string} markdown - Input markdown\n  75→ * @returns {string} MarkdownV2 formatted text\n  76→ */\n  77→export function convertToMarkdownV2(markdown) {\n  78→  if (!markdown) return '';\n  79→\n  80→  let result = markdown;\n  81→\n  82→  // Process code blocks first (to protect their content)\n  83→  const codeBlocks = [];\n  84→  result = result.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, (match, lang, code) => {\n  85→    const placeholder = `\\x00CB${codeBlocks.length}\\x00`;\n  86→    codeBlocks.push(formatCodeBlock(code, lang));\n  87→    return placeholder;\n  88→  });\n  89→\n  90→  // Process inline code\n  91→  const inlineCodes = [];\n  92→  result = result.replace(/`([^`]+)`/g, (match, code) => {\n  93→    const placeholder = `\\x00IC${inlineCodes.length}\\x00`;\n  94→    inlineCodes.push(formatInlineCode(code));\n  95→    return placeholder;\n  96→  });\n  97→\n  98→  // Process links [text](url)\n  99→  const links = [];\n 100→  result = result.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/g, (match, text, url) => {\n 101→    const placeholder = `\\x00LK${links.length}\\x00`;\n 102→    // In MarkdownV2, escape the URL but keep the link format\n 103→    links.push(`[${escapeMarkdownV2(text)}](${escapeMarkdownV2(url)})`);\n 104→    return placeholder;\n 105→  });\n 106→\n 107→  // Process bold **text**\n 108→  result = result.replace(/\\*\\*([^*]+)\\*\\*/g, (match, text) => {\n 109→    return '*' + escapeMarkdownV2(text) + '*';\n 110→  });\n 111→\n 112→  // Process italic _text_\n 113→  result = result.replace(/_([^_]+)_/g, (match, text) => {\n 114→    return '_' + escapeMarkdownV2(text) + '_';\n 115→  });\n 116→\n 117→  // Escape remaining special characters\n 118→  result = escapeMarkdownV2(result);\n 119→\n 120→  // Restore protected content (placeholders contain no special chars so they won't be escaped)\n 121→  for (let i = 0; i < codeBlocks.length; i++) {\n 122→    result = result.split(`\\\\x00CB${i}\\\\x00`).join(codeBlocks[i]);\n 123→    result = result.split(`\\x00CB${i}\\x00`).join(codeBlocks[i]);\n 124→  }\n 125→  for (let i = 0; i < inlineCodes.length; i++) {\n 126→    result = result.split(`\\\\x00IC${i}\\\\x00`).join(inlineCodes[i]);\n 127→    result = result.split(`\\x00IC${i}\\x00`).join(inlineCodes[i]);\n 128→  }\n 129→  for (let i = 0; i < links.length; i++) {\n 130→    result = result.split(`\\\\x00LK${i}\\\\x00`).join(links[i]);\n 131→    result = result.split(`\\x00LK${i}\\x00`).join(links[i]);\n 132→  }\n 133→\n 134→  // Remove any remaining null placeholders (for safety)\n 135→  result = result.replace(/\\\\x00[A-Z]+\\d+\\\\x00/g, '');\n 136→  result = result.replace(/\\x00[A-Z]+\\d+\\x00/g, '');\n 137→\n 138→  return result;\n 139→}\n 140→\n 141→/**\n 142→ * Split text into segments respecting code block boundaries.\n 143→ * Useful for splitting long messages without breaking code blocks.\n 144→ * @param {string} text - Text to split\n 145→ * @param {number} maxLength - Maximum length per segment (default 4000)\n 146→ * @returns {string[]} Array of segments\n 147→ */\n 148→export function splitRespectingCodeBlocks(text, maxLength = 4000) {\n 149→  if (!text) return [''];\n 150→  if (text.length <= maxLength) return [text];\n 151→\n 152→  const segments = [];\n 153→  let currentSegment = '';\n 154→\n 155→  // Split text into chunks: code blocks and non-code parts\n 156→  const parts = text.split(/(```[\\s\\S]*?```)/g);\n 157→\n 158→  for (const part of parts) {\n 159→    // If adding this part would exceed maxLength\n 160→    if (currentSegment.length + part.length > maxLength) {\n 161→      // If it's a code block, we need to keep it whole\n 162→      if (part.startsWith('```') && part.endsWith('```')) {\n 163→        // If current segment has content, push it\n 164→        if (currentSegment.trim()) {\n 165→          segments.push(currentSegment);\n 166→          currentSegment = '';\n 167→        }\n 168→        // Check if code block itself exceeds maxLength\n 169→        if (part.length > maxLength) {\n 170→          // We have to split it - but try at a reasonable point\n 171→          // For now, just push it as a single segment (Telegram will truncate)\n 172→          segments.push(part);\n 173→        } else {\n 174→          currentSegment = part;\n 175→        }\n 176→      } else {\n 177→        // Regular text - try to split at paragraph or newline\n 178→        const remaining = maxLength - currentSegment.length;\n 179→        if (remaining > 0) {\n 180→          // Take what we can from this part\n 181→          const chunk = part.slice(0, remaining);\n 182→          const breakPoint = Math.max(\n 183→            chunk.lastIndexOf('\\n\\n'),\n 184→            chunk.lastIndexOf('\\n'),\n 185→            chunk.lastIndexOf(' ')\n 186→          );\n 187→\n 188→          if (breakPoint > 0) {\n 189→            currentSegment += chunk.slice(0, breakPoint + 1);\n 190→            segments.push(currentSegment);\n 191→            currentSegment = part.slice(breakPoint + 1);\n 192→          } else {\n 193→            currentSegment += chunk;\n 194→            segments.push(currentSegment);\n 195→            currentSegment = part.slice(remaining);\n 196→          }\n 197→        } else {\n 198→          if (currentSegment.trim()) {\n 199→            segments.push(currentSegment);\n 200→          }\n 201→          currentSegment = part;\n 202→        }\n 203→\n 204→        // If current segment still exceeds, we need to keep splitting\n 205→        while (currentSegment.length > maxLength) {\n 206→          const chunk = currentSegment.slice(0, maxLength);\n 207→          const breakPoint = Math.max(\n 208→            chunk.lastIndexOf('\\n\\n'),\n 209→            chunk.lastIndexOf('\\n'),\n 210→            chunk.lastIndexOf(' ')\n 211→          );\n 212→\n 213→          if (breakPoint > 0) {\n 214→            segments.push(chunk.slice(0, breakPoint + 1));\n 215→            currentSegment = currentSegment.slice(breakPoint + 1);\n 216→          } else {\n 217→            segments.push(chunk);\n 218→            currentSegment = currentSegment.slice(maxLength);\n 219→          }\n 220→        }\n 221→      }\n 222→    } else {\n 223→      currentSegment += part;\n 224→    }\n 225→  }\n 226→\n 227→  if (currentSegment.trim()) {\n 228→    segments.push(currentSegment);\n 229→  }\n 230→\n 231→  return segments.length > 0 ? segments : [''];\n 232→}\n 233→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce38bdd117b44f51df57146b62d27","__timestamp":"2026-03-12T19:40:28.435Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
