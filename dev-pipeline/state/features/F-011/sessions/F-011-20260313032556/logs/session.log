{"type":"user","uuid":"85de5798-cb81-47a1-8516-99e2f80ba883","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3b522a2bb064fcaded6125f226b","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: AI CLI Service\n   3→ *\n   4→ * Encapsulates AI CLI execution logic with process tracking,\n   5→ * heartbeat, and interrupt support.\n   6→ *\n   7→ * T-051: Metrics tracking for monitoring\n   8→ */\n   9→\n  10→import { spawn } from 'node:child_process';\n  11→import { config } from '../config.js';\n  12→import { logger } from '../utils/logger.js';\n  13→import { sessionStore } from './session-store.js';\n  14→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n  15→\n  16→/**\n  17→ * Metrics for AI CLI execution monitoring.\n  18→ * T-051: Track execution statistics\n  19→ */\n  20→const metrics = {\n  21→  // Execution counts\n  22→  totalExecutions: 0,\n  23→  successCount: 0,\n  24→  failureCount: 0,\n  25→  timeoutCount: 0,\n  26→  interruptCount: 0,\n  27→\n  28→  // Duration tracking (for histogram)\n  29→  durations: [],\n  30→  maxDurations: 100, // Keep last 100 durations\n  31→\n  32→  // Output size tracking\n  33→  outputSizes: [],\n  34→  maxOutputSizes: 100\n  35→};\n  36→\n  37→/**\n  38→ * Get current metrics snapshot.\n  39→ * @returns {Object} Metrics snapshot\n  40→ */\n  41→export function getMetrics() {\n  42→  const durations = [...metrics.durations];\n  43→  const outputSizes = [...metrics.outputSizes];\n  44→\n  45→  return {\n  46→    totalExecutions: metrics.totalExecutions,\n  47→    successCount: metrics.successCount,\n  48→    failureCount: metrics.failureCount,\n  49→    timeoutCount: metrics.timeoutCount,\n  50→    interruptCount: metrics.interruptCount,\n  51→    averageDurationMs: durations.length > 0\n  52→      ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length)\n  53→      : 0,\n  54→    minDurationMs: durations.length > 0 ? Math.min(...durations) : 0,\n  55→    maxDurationMs: durations.length > 0 ? Math.max(...durations) : 0,\n  56→    averageOutputBytes: outputSizes.length > 0\n  57→      ? Math.round(outputSizes.reduce((a, b) => a + b, 0) / outputSizes.length)\n  58→      : 0\n  59→  };\n  60→}\n  61→\n  62→/**\n  63→ * Record execution metrics.\n  64→ * @param {Object} result - Execution result\n  65→ * @param {number} result.elapsedMs - Execution duration\n  66→ * @param {number} result.stdoutBytes - Output size\n  67→ * @param {boolean} result.success - Whether execution succeeded\n  68→ * @param {boolean} result.timedOut - Whether execution timed out\n  69→ * @param {boolean} result.interrupted - Whether execution was interrupted\n  70→ */\n  71→function recordMetrics(result) {\n  72→  metrics.totalExecutions++;\n  73→\n  74→  // Track duration\n  75→  metrics.durations.push(result.elapsedMs);\n  76→  if (metrics.durations.length > metrics.maxDurations) {\n  77→    metrics.durations.shift();\n  78→  }\n  79→\n  80→  // Track output size\n  81→  metrics.outputSizes.push(result.stdoutBytes || 0);\n  82→  if (metrics.outputSizes.length > metrics.maxOutputSizes) {\n  83→    metrics.outputSizes.shift();\n  84→  }\n  85→\n  86→  // Track outcome\n  87→  if (result.interrupted) {\n  88→    metrics.interruptCount++;\n  89→  } else if (result.timedOut) {\n  90→    metrics.timeoutCount++;\n  91→  } else if (result.success) {\n  92→    metrics.successCount++;\n  93→  } else {\n  94→    metrics.failureCount++;\n  95→  }\n  96→\n  97→  // Log metrics at debug level\n  98→  logger.debug(\n  99→    {\n 100→      totalExecutions: metrics.totalExecutions,\n 101→      successRate: `${Math.round((metrics.successCount / metrics.totalExecutions) * 100)}%`,\n 102→      interruptRate: `${Math.round((metrics.interruptCount / metrics.totalExecutions) * 100)}%`,\n 103→      timeoutRate: `${Math.round((metrics.timeoutCount / metrics.totalExecutions) * 100)}%`\n 104→    },\n 105→    'AI CLI metrics updated'\n 106→  );\n 107→}\n 108→\n 109→/**\n 110→ * Reset metrics (useful for testing).\n 111→ */\n 112→export function resetMetrics() {\n 113→  metrics.totalExecutions = 0;\n 114→  metrics.successCount = 0;\n 115→  metrics.failureCount = 0;\n 116→  metrics.timeoutCount = 0;\n 117→  metrics.interruptCount = 0;\n 118→  metrics.durations = [];\n 119→  metrics.outputSizes = [];\n 120→}\n 121→\n 122→/**\n 123→ * @typedef {Object} AiCliExecutionOptions\n 124→ * @property {string} sessionId - Session identifier\n 125→ * @property {string} prompt - User prompt/input\n 126→ * @property {string} [userId] - User ID who initiated the task (for permission checks)\n 127→ * @property {Object} [hooks] - Callback hooks\n 128→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n 129→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n 130→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n 131→ * @property {AbortSignal} [signal] - Optional abort signal\n 132→ * @property {number} [timeoutMs] - Optional timeout override\n 133→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n 134→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n 135→ * @property {string} [bin] - Optional binary override (for testing)\n 136→ * @property {string[]} [args] - Optional args override (for testing, replaces default args)\n 137→ */\n 138→\n 139→/**\n 140→ * @typedef {Object} AiCliExecutionResult\n 141→ * @property {string} output - Final output text\n 142→ * @property {boolean} timedOut - Whether execution timed out\n 143→ * @property {boolean} interrupted - Whether execution was interrupted\n 144→ * @property {number} elapsedMs - Execution time in milliseconds\n 145→ * @property {number|null} exitCode - Process exit code (if completed)\n 146→ * @property {string} stderr - Error output if any\n 147→ */\n 148→\n 149→/**\n 150→ * @typedef {Object} HeartbeatInfo\n 151→ * @property {number} elapsedMs - Elapsed time in milliseconds\n 152→ * @property {number} stdoutBytes - Bytes received so far\n 153→ * @property {string} status - Current status ('running', 'streaming')\n 154→ */\n 155→\n 156→/**\n 157→ * Write text to echo output for debugging.\n 158→ * @param {string} tag - Tag for the output\n 159→ * @param {string} text - Text to write\n 160→ */\n 161→function writeEcho(tag, text) {\n 162→  const normalized = String(text ?? '');\n 163→  if (!normalized) {\n 164→    return;\n 165→  }\n 166→\n 167→  const lines = normalized.split(/\\r?\\n/);\n 168→  for (const line of lines) {\n 169→    if (!line) {\n 170→      continue;\n 171→    }\n 172→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n 173→  }\n 174→}\n 175→\n 176→/**\n 177→ * Execute AI CLI with session context and process tracking.\n 178→ * @param {AiCliExecutionOptions} options\n 179→ * @returns {Promise<AiCliExecutionResult>}\n 180→ */\n 181→export async function executeAiCli(options) {\n 182→  const {\n 183→    sessionId,\n 184→    prompt,\n 185→    userId,\n 186→    hooks = {},\n 187→    signal,\n 188→    timeoutMs,\n 189→    heartbeatThresholdMs,\n 190→    heartbeatIntervalMs,\n 191→    bin,\n 192→    args: customArgs\n 193→  } = options;\n 194→\n 195→  const effectiveBin = bin || config.codebuddyBin;\n 196→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n 197→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n 198→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n 199→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n 200→\n 201→  // Use custom args if provided (for testing), otherwise build default args\n 202→  const args = customArgs ?? (() => {\n 203→    const defaultArgs = ['-p', prompt];\n 204→    if (config.codebuddyPermissionFlag) {\n 205→      defaultArgs.push(config.codebuddyPermissionFlag);\n 206→    }\n 207→    return defaultArgs;\n 208→  })();\n 209→\n 210→  return new Promise((resolve) => {\n 211→    let stdout = '';\n 212→    let stderr = '';\n 213→    let stdoutBytes = 0;\n 214→    let interrupted = false;\n 215→    let timedOut = false;\n 216→    const startedAt = Date.now();\n 217→    const sessionKey = sessionId;\n 218→\n 219→    // Heartbeat manager\n 220→    const heartbeatManager = createHeartbeatManager();\n 221→\n 222→    // Spawn process\n 223→    let child;\n 224→    try {\n 225→      child = spawn(effectiveBin, args, {\n 226→        stdio: ['ignore', 'pipe', 'pipe']\n 227→      });\n 228→    } catch (err) {\n 229→      resolve({\n 230→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 231→        timedOut: false,\n 232→        interrupted: false,\n 233→        elapsedMs: Date.now() - startedAt,\n 234→        exitCode: null,\n 235→        stderr: ''\n 236→      });\n 237→      return;\n 238→    }\n 239→\n 240→    // Track process in session store\n 241→    sessionStore.setActiveProcess(sessionKey, {\n 242→      pid: child.pid,\n 243→      startedAt,\n 244→      childProcess: child,\n 245→      interrupted: false,\n 246→      timedOut: false,\n 247→      userId\n 248→    });\n 249→\n 250→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n 251→\n 252→    // Handle process error\n 253→    child.on('error', (err) => {\n 254→      cleanup();\n 255→      resolve({\n 256→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 257→        timedOut: false,\n 258→        interrupted: false,\n 259→        elapsedMs: Date.now() - startedAt,\n 260→        exitCode: null,\n 261→        stderr\n 262→      });\n 263→    });\n 264→\n 265→    // Handle stdout\n 266→    child.stdout.on('data', (chunk) => {\n 267→      const text = chunk.toString();\n 268→      stdout += text;\n 269→      stdoutBytes += Buffer.byteLength(text);\n 270→\n 271→      // Update session store byte count\n 272→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n 273→\n 274→      // Echo to console if enabled\n 275→      if (config.codebuddyEchoStdio) {\n 276→        writeEcho('stdout', text);\n 277→      }\n 278→\n 279→      // Call onChunk hook\n 280→      if (typeof hooks.onChunk === 'function') {\n 281→        hooks.onChunk(text);\n 282→      }\n 283→    });\n 284→\n 285→    // Handle stderr\n 286→    child.stderr.on('data', (chunk) => {\n 287→      const text = chunk.toString();\n 288→      stderr += text;\n 289→\n 290→      if (config.codebuddyEchoStdio) {\n 291→        writeEcho('stderr', text);\n 292→      }\n 293→    });\n 294→\n 295→    // Timeout handler\n 296→    const timeout = effectiveTimeoutMs > 0\n 297→      ? setTimeout(() => {\n 298→          timedOut = true;\n 299→          const info = sessionStore.getActiveProcess(sessionKey);\n 300→          if (info) {\n 301→            info.timedOut = true;\n 302→          }\n 303→          child.kill('SIGTERM');\n 304→\n 305→          // Schedule SIGKILL if process doesn't exit\n 306→          setTimeout(() => {\n 307→            if (sessionStore.getActiveProcess(sessionKey)) {\n 308→              child.kill('SIGKILL');\n 309→            }\n 310→          }, 5000);\n 311→        }, effectiveTimeoutMs)\n 312→      : null;\n 313→\n 314→    // Abort signal handler\n 315→    const onAbort = () => {\n 316→      interrupted = true;\n 317→      const info = sessionStore.getActiveProcess(sessionKey);\n 318→      if (info) {\n 319→        info.interrupted = true;\n 320→      }\n 321→      child.kill('SIGTERM');\n 322→\n 323→      // Schedule SIGKILL if process doesn't exit\n 324→      setTimeout(() => {\n 325→        if (sessionStore.getActiveProcess(sessionKey)) {\n 326→          child.kill('SIGKILL');\n 327→        }\n 328→      }, 5000);\n 329→    };\n 330→\n 331→    if (signal) {\n 332→      signal.addEventListener('abort', onAbort);\n 333→    }\n 334→\n 335→    // Heartbeat setup\n 336→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n 337→      heartbeatManager.start({\n 338→        callback: () => {\n 339→          const elapsedMs = Date.now() - startedAt;\n 340→          hooks.onHeartbeat({\n 341→            elapsedMs,\n 342→            stdoutBytes,\n 343→            status: 'running'\n 344→          });\n 345→        },\n 346→        intervalMs: effectiveHeartbeatIntervalMs,\n 347→        thresholdMs: effectiveHeartbeatThresholdMs\n 348→      });\n 349→    }\n 350→\n 351→    // Cleanup function\n 352→    function cleanup() {\n 353→      if (timeout) {\n 354→        clearTimeout(timeout);\n 355→      }\n 356→      heartbeatManager.stop();\n 357→      sessionStore.clearActiveProcess(sessionKey);\n 358→      if (signal) {\n 359→        signal.removeEventListener('abort', onAbort);\n 360→      }\n 361→    }\n 362→\n 363→    // Handle process close\n 364→    child.on('close', (code) => {\n 365→      const elapsedMs = Date.now() - startedAt;\n 366→\n 367→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n 368→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n 369→      if (storedInfo) {\n 370→        if (storedInfo.interrupted) {\n 371→          interrupted = true;\n 372→        }\n 373→        if (storedInfo.timedOut) {\n 374→          timedOut = true;\n 375→        }\n 376→      }\n 377→\n 378→      cleanup();\n 379→\n 380→      logger.info(\n 381→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n 382→        'AI CLI process closed'\n 383→      );\n 384→\n 385→      // Build output\n 386→      let output = stdout.trim();\n 387→\n 388→      if (interrupted) {\n 389→        output = output || '任务已被用户中断。';\n 390→      } else if (timedOut) {\n 391→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n 392→      } else if (code !== 0) {\n 393→        output = output || `AI CLI 退出码 ${code}。`;\n 394→        if (stderr.trim()) {\n 395→          output += `\\n错误信息:\\n${stderr.trim()}`;\n 396→        }\n 397→      }\n 398→\n 399→      // Record metrics (T-051)\n 400→      recordMetrics({\n 401→        elapsedMs,\n 402→        stdoutBytes,\n 403→        success: code === 0 && !interrupted && !timedOut,\n 404→        timedOut,\n 405→        interrupted\n 406→      });\n 407→\n 408→      resolve({\n 409→        output: output || 'AI CLI 未返回文本结果。',\n 410→        timedOut,\n 411→        interrupted,\n 412→        elapsedMs,\n 413→        exitCode: code,\n 414→        stderr: stderr.trim()\n 415→      });\n 416→    });\n 417→  });\n 418→}\n 419→\n 420→/**\n 421→ * Interrupt running AI CLI task for a session.\n 422→ * @param {string} sessionId - Session identifier\n 423→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 424→ */\n 425→export function interruptAiCli(sessionId) {\n 426→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 427→\n 428→  if (!processInfo) {\n 429→    return { ok: false, error: '没有正在执行的任务。' };\n 430→  }\n 431→\n 432→  const { pid, childProcess } = processInfo;\n 433→\n 434→  try {\n 435→    // Mark as interrupted so close handler knows\n 436→    processInfo.interrupted = true;\n 437→\n 438→    // Send SIGTERM first\n 439→    childProcess.kill('SIGTERM');\n 440→\n 441→    // Schedule SIGKILL as backup\n 442→    setTimeout(() => {\n 443→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n 444→      if (stillRunning) {\n 445→        try {\n 446→          childProcess.kill('SIGKILL');\n 447→        } catch {\n 448→          // Process already dead\n 449→        }\n 450→      }\n 451→    }, 5000);\n 452→\n 453→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n 454→\n 455→    return { ok: true, pid };\n 456→  } catch (err) {\n 457→    return { ok: false, error: `中断失败: ${err.message}` };\n 458→  }\n 459→}\n 460→\n 461→/**\n 462→ * Check if AI CLI is running for a session.\n 463→ * @param {string} sessionId\n 464→ * @returns {boolean}\n 465→ */\n 466→export function isAiCliRunning(sessionId) {\n 467→  return sessionStore.getActiveProcess(sessionId) !== null;\n 468→}\n 469→\n 470→/**\n 471→ * Get active process info for a session.\n 472→ * @param {string} sessionId\n 473→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n 474→ */\n 475→export function getActiveProcessInfo(sessionId) {\n 476→  const info = sessionStore.getActiveProcess(sessionId);\n 477→  if (!info) {\n 478→    return null;\n 479→  }\n 480→\n 481→  // Don't expose childProcess to external callers\n 482→  return {\n 483→    pid: info.pid,\n 484→    startedAt: info.startedAt,\n 485→    stdoutBytes: info.stdoutBytes ?? 0,\n 486→    userId: info.userId\n 487→  };\n 488→}\n 489→\n 490→/**\n 491→ * Check if user can interrupt AI CLI task.\n 492→ * @param {string} sessionId - Session identifier\n 493→ * @param {string|number} requestUserId - User requesting interrupt\n 494→ * @param {Function} isAdminFn - Function to check if user is admin\n 495→ * @returns {{ canInterrupt: boolean, reason?: string }}\n 496→ */\n 497→export function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n 498→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 499→\n 500→  if (!processInfo) {\n 501→    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n 502→  }\n 503→\n 504→  // Admin can always interrupt\n 505→  if (isAdminFn && isAdminFn(requestUserId)) {\n 506→    return { canInterrupt: true };\n 507→  }\n 508→\n 509→  // Task owner can interrupt\n 510→  const taskUserId = processInfo.userId;\n 511→  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n 512→    return { canInterrupt: true };\n 513→  }\n 514→\n 515→  // Otherwise, permission denied\n 516→  return {\n 517→    canInterrupt: false,\n 518→    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n 519→  };\n 520→}\n 521→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3b4f54dcd7b31cdb68e43e953ad","__timestamp":"2026-03-12T20:20:26.609Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"f0416f2d-2db8-4166-99fa-a6398129e074","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3b52439a04dc6642c4fe5f1fbb3","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: Heartbeat Manager Utility\n   3→ *\n   4→ * Provides reusable heartbeat functionality for long-running tasks.\n   5→ * Supports threshold-based activation and clean stop/cleanup.\n   6→ */\n   7→\n   8→/**\n   9→ * @typedef {Object} HeartbeatOptions\n  10→ * @property {Function} callback - Function to call on each heartbeat\n  11→ * @property {number} intervalMs - Interval between heartbeats in milliseconds\n  12→ * @property {number} thresholdMs - Minimum time before first heartbeat\n  13→ */\n  14→\n  15→/**\n  16→ * @typedef {Object} HeartbeatInfo\n  17→ * @property {number} elapsedMs - Elapsed time since start in milliseconds\n  18→ */\n  19→\n  20→/**\n  21→ * Start a heartbeat timer.\n  22→ * @param {HeartbeatOptions} options\n  23→ * @returns {Function} Stop function to clear the heartbeat\n  24→ */\n  25→export function startHeartbeat({ callback, intervalMs, thresholdMs = 0 }) {\n  26→  const startedAt = Date.now();\n  27→  let thresholdTimer = null;\n  28→  let intervalTimer = null;\n  29→  let stopped = false;\n  30→\n  31→  const clearAll = () => {\n  32→    if (thresholdTimer) {\n  33→      clearTimeout(thresholdTimer);\n  34→      thresholdTimer = null;\n  35→    }\n  36→    if (intervalTimer) {\n  37→      clearInterval(intervalTimer);\n  38→      intervalTimer = null;\n  39→    }\n  40→  };\n  41→\n  42→  const triggerCallback = () => {\n  43→    if (stopped) return;\n  44→    const elapsedMs = Date.now() - startedAt;\n  45→    callback({ elapsedMs });\n  46→  };\n  47→\n  48→  const startInterval = () => {\n  49→    if (stopped) return;\n  50→    // Trigger first heartbeat after threshold\n  51→    triggerCallback();\n  52→    // Then start interval\n  53→    intervalTimer = setInterval(() => {\n  54→      if (stopped) {\n  55→        clearAll();\n  56→        return;\n  57→      }\n  58→      triggerCallback();\n  59→    }, intervalMs);\n  60→  };\n  61→\n  62→  // If threshold is 0, start immediately\n  63→  if (thresholdMs <= 0) {\n  64→    startInterval();\n  65→  } else {\n  66→    // Wait for threshold before starting\n  67→    thresholdTimer = setTimeout(startInterval, thresholdMs);\n  68→  }\n  69→\n  70→  // Return stop function\n  71→  return () => {\n  72→    stopped = true;\n  73→    clearAll();\n  74→  };\n  75→}\n  76→\n  77→/**\n  78→ * Create a heartbeat manager with start/stop lifecycle.\n  79→ * @returns {{ start: Function, stop: Function, isRunning: Function }}\n  80→ */\n  81→export function createHeartbeatManager() {\n  82→  let stopFn = null;\n  83→\n  84→  return {\n  85→    /**\n  86→     * Start heartbeat with given options.\n  87→     * @param {HeartbeatOptions} options\n  88→     */\n  89→    start(options) {\n  90→      // Stop any existing heartbeat\n  91→      this.stop();\n  92→      stopFn = startHeartbeat(options);\n  93→    },\n  94→\n  95→    /**\n  96→     * Stop the current heartbeat.\n  97→     */\n  98→    stop() {\n  99→      if (stopFn) {\n 100→        stopFn();\n 101→        stopFn = null;\n 102→      }\n 103→    },\n 104→\n 105→    /**\n 106→     * Check if heartbeat is currently running.\n 107→     * @returns {boolean}\n 108→     */\n 109→    isRunning() {\n 110→      return stopFn !== null;\n 111→    }\n 112→  };\n 113→}\n 114→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3b4f54dcd7b31cdb68e43e953ad","__timestamp":"2026-03-12T20:20:26.610Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"64c881ab-87e9-48b9-afdb-1130c10a94e4","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3b525b362bfda711009a64a1ebd","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: MarkdownV2 Formatter for Telegram\n   3→ *\n   4→ * Telegram MarkdownV2 requires escaping specific characters.\n   5→ * This module provides utilities for converting common Markdown\n   6→ * to Telegram's MarkdownV2 format.\n   7→ *\n   8→ * Reference: https://core.telegram.org/bots/api#markdownv2-style\n   9→ */\n  10→\n  11→/**\n  12→ * Characters that need escaping in MarkdownV2.\n  13→ * All these characters must be escaped with a backslash.\n  14→ */\n  15→const ESCAPE_CHARS = ['_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!'];\n  16→\n  17→/**\n  18→ * Escape text for Telegram MarkdownV2 format.\n  19→ * In MarkdownV2, all special characters must be escaped.\n  20→ * @param {string} text - Text to escape\n  21→ * @returns {string} Escaped text\n  22→ */\n  23→export function escapeMarkdownV2(text) {\n  24→  if (!text) return '';\n  25→\n  26→  let result = text;\n  27→  for (const char of ESCAPE_CHARS) {\n  28→    result = result.split(char).join('\\\\' + char);\n  29→  }\n  30→  return result;\n  31→}\n  32→\n  33→/**\n  34→ * Escape text inside code blocks.\n  35→ * Inside code blocks, only ` and \\ need escaping.\n  36→ * @param {string} code - Code content\n  37→ * @returns {string} Escaped code\n  38→ */\n  39→function escapeCodeContent(code) {\n  40→  if (!code) return '';\n  41→  return code\n  42→    .split('\\\\').join('\\\\\\\\')\n  43→    .split('`').join('\\\\`');\n  44→}\n  45→\n  46→/**\n  47→ * Format code block for Telegram MarkdownV2.\n  48→ * @param {string} code - Code content\n  49→ * @param {string} [language=''] - Optional language identifier\n  50→ * @returns {string} Formatted code block\n  51→ */\n  52→export function formatCodeBlock(code, language = '') {\n  53→  const escapedCode = escapeCodeContent(code ?? '');\n  54→  // Handle empty code case\n  55→  if (!escapedCode) {\n  56→    return '```' + language + '\\n```';\n  57→  }\n  58→  return '```' + language + '\\n' + escapedCode + '\\n```';\n  59→}\n  60→\n  61→/**\n  62→ * Format inline code for Telegram MarkdownV2.\n  63→ * @param {string} code - Code content\n  64→ * @returns {string} Formatted inline code\n  65→ */\n  66→export function formatInlineCode(code) {\n  67→  const escapedCode = escapeCodeContent(code ?? '');\n  68→  return '`' + escapedCode + '`';\n  69→}\n  70→\n  71→/**\n  72→ * Convert common Markdown to Telegram MarkdownV2.\n  73→ * Handles: code blocks, inline code, bold, italic, links.\n  74→ * @param {string} markdown - Input markdown\n  75→ * @returns {string} MarkdownV2 formatted text\n  76→ */\n  77→export function convertToMarkdownV2(markdown) {\n  78→  if (!markdown) return '';\n  79→\n  80→  let result = markdown;\n  81→\n  82→  // Process code blocks first (to protect their content)\n  83→  const codeBlocks = [];\n  84→  result = result.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, (match, lang, code) => {\n  85→    const placeholder = `\\x00CB${codeBlocks.length}\\x00`;\n  86→    codeBlocks.push(formatCodeBlock(code, lang));\n  87→    return placeholder;\n  88→  });\n  89→\n  90→  // Process inline code\n  91→  const inlineCodes = [];\n  92→  result = result.replace(/`([^`]+)`/g, (match, code) => {\n  93→    const placeholder = `\\x00IC${inlineCodes.length}\\x00`;\n  94→    inlineCodes.push(formatInlineCode(code));\n  95→    return placeholder;\n  96→  });\n  97→\n  98→  // Process links [text](url)\n  99→  const links = [];\n 100→  result = result.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/g, (match, text, url) => {\n 101→    const placeholder = `\\x00LK${links.length}\\x00`;\n 102→    // In MarkdownV2, escape the URL but keep the link format\n 103→    links.push(`[${escapeMarkdownV2(text)}](${escapeMarkdownV2(url)})`);\n 104→    return placeholder;\n 105→  });\n 106→\n 107→  // Process bold **text** - use placeholders to prevent double-escaping\n 108→  const bolds = [];\n 109→  result = result.replace(/\\*\\*([^*]+)\\*\\*/g, (match, text) => {\n 110→    const placeholder = `\\x00BD${bolds.length}\\x00`;\n 111→    bolds.push('*' + escapeMarkdownV2(text) + '*');\n 112→    return placeholder;\n 113→  });\n 114→\n 115→  // Process italic _text_ - use placeholders to prevent double-escaping\n 116→  const italics = [];\n 117→  result = result.replace(/_([^_]+)_/g, (match, text) => {\n 118→    const placeholder = `\\x00IT${italics.length}\\x00`;\n 119→    italics.push('_' + escapeMarkdownV2(text) + '_');\n 120→    return placeholder;\n 121→  });\n 122→\n 123→  // Escape remaining special characters\n 124→  result = escapeMarkdownV2(result);\n 125→\n 126→  // Restore protected content (placeholders contain no special chars so they won't be escaped)\n 127→  for (let i = 0; i < codeBlocks.length; i++) {\n 128→    result = result.split(`\\\\x00CB${i}\\\\x00`).join(codeBlocks[i]);\n 129→    result = result.split(`\\x00CB${i}\\x00`).join(codeBlocks[i]);\n 130→  }\n 131→  for (let i = 0; i < inlineCodes.length; i++) {\n 132→    result = result.split(`\\\\x00IC${i}\\\\x00`).join(inlineCodes[i]);\n 133→    result = result.split(`\\x00IC${i}\\x00`).join(inlineCodes[i]);\n 134→  }\n 135→  for (let i = 0; i < links.length; i++) {\n 136→    result = result.split(`\\\\x00LK${i}\\\\x00`).join(links[i]);\n 137→    result = result.split(`\\x00LK${i}\\x00`).join(links[i]);\n 138→  }\n 139→  for (let i = 0; i < bolds.length; i++) {\n 140→    result = result.split(`\\\\x00BD${i}\\\\x00`).join(bolds[i]);\n 141→    result = result.split(`\\x00BD${i}\\x00`).join(bolds[i]);\n 142→  }\n 143→  for (let i = 0; i < italics.length; i++) {\n 144→    result = result.split(`\\\\x00IT${i}\\\\x00`).join(italics[i]);\n 145→    result = result.split(`\\x00IT${i}\\x00`).join(italics[i]);\n 146→  }\n 147→\n 148→  // Remove any remaining null placeholders (for safety)\n 149→  result = result.replace(/\\\\x00[A-Z]+\\d+\\\\x00/g, '');\n 150→  result = result.replace(/\\x00[A-Z]+\\d+\\x00/g, '');\n 151→\n 152→  return result;\n 153→}\n 154→\n 155→/**\n 156→ * Split text into segments respecting code block boundaries.\n 157→ * Useful for splitting long messages without breaking code blocks.\n 158→ * @param {string} text - Text to split\n 159→ * @param {number} maxLength - Maximum length per segment (default 4000)\n 160→ * @returns {string[]} Array of segments\n 161→ */\n 162→export function splitRespectingCodeBlocks(text, maxLength = 4000) {\n 163→  if (!text) return [''];\n 164→  if (text.length <= maxLength) return [text];\n 165→\n 166→  const segments = [];\n 167→  let currentSegment = '';\n 168→\n 169→  // Split text into chunks: code blocks and non-code parts\n 170→  const parts = text.split(/(```[\\s\\S]*?```)/g);\n 171→\n 172→  for (const part of parts) {\n 173→    // If adding this part would exceed maxLength\n 174→    if (currentSegment.length + part.length > maxLength) {\n 175→      // If it's a code block, we need to keep it whole\n 176→      if (part.startsWith('```') && part.endsWith('```')) {\n 177→        // If current segment has content, push it\n 178→        if (currentSegment.trim()) {\n 179→          segments.push(currentSegment);\n 180→          currentSegment = '';\n 181→        }\n 182→        // Check if code block itself exceeds maxLength\n 183→        if (part.length > maxLength) {\n 184→          // We have to split it - but try at a reasonable point\n 185→          // For now, just push it as a single segment (Telegram will truncate)\n 186→          segments.push(part);\n 187→        } else {\n 188→          currentSegment = part;\n 189→        }\n 190→      } else {\n 191→        // Regular text - try to split at paragraph or newline\n 192→        const remaining = maxLength - currentSegment.length;\n 193→        if (remaining > 0) {\n 194→          // Take what we can from this part\n 195→          const chunk = part.slice(0, remaining);\n 196→          const breakPoint = Math.max(\n 197→            chunk.lastIndexOf('\\n\\n'),\n 198→            chunk.lastIndexOf('\\n'),\n 199→            chunk.lastIndexOf(' ')\n 200→          );\n 201→\n 202→          if (breakPoint > 0) {\n 203→            currentSegment += chunk.slice(0, breakPoint + 1);\n 204→            segments.push(currentSegment);\n 205→            currentSegment = part.slice(breakPoint + 1);\n 206→          } else {\n 207→            currentSegment += chunk;\n 208→            segments.push(currentSegment);\n 209→            currentSegment = part.slice(remaining);\n 210→          }\n 211→        } else {\n 212→          if (currentSegment.trim()) {\n 213→            segments.push(currentSegment);\n 214→          }\n 215→          currentSegment = part;\n 216→        }\n 217→\n 218→        // If current segment still exceeds, we need to keep splitting\n 219→        while (currentSegment.length > maxLength) {\n 220→          const chunk = currentSegment.slice(0, maxLength);\n 221→          const breakPoint = Math.max(\n 222→            chunk.lastIndexOf('\\n\\n'),\n 223→            chunk.lastIndexOf('\\n'),\n 224→            chunk.lastIndexOf(' ')\n 225→          );\n 226→\n 227→          if (breakPoint > 0) {\n 228→            segments.push(chunk.slice(0, breakPoint + 1));\n 229→            currentSegment = currentSegment.slice(breakPoint + 1);\n 230→          } else {\n 231→            segments.push(chunk);\n 232→            currentSegment = currentSegment.slice(maxLength);\n 233→          }\n 234→        }\n 235→      }\n 236→    } else {\n 237→      currentSegment += part;\n 238→    }\n 239→  }\n 240→\n 241→  if (currentSegment.trim()) {\n 242→    segments.push(currentSegment);\n 243→  }\n 244→\n 245→  return segments.length > 0 ? segments : [''];\n 246→}\n 247→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3b4f54dcd7b31cdb68e43e953ad","__timestamp":"2026-03-12T20:20:26.610Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"74a0e818-183d-4170-8585-2824348134a3","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3b527669954b053d86342c88107","content":[{"type":"text","text":"   1→import { config } from '../config.js';\n   2→\n   3→class SessionStore {\n   4→  #messagesBySessionKey = new Map();\n   5→  #commitsBySessionKey = new Map();\n   6→  // F-009: Command executor extensions\n   7→  #cwdBySessionKey = new Map();\n   8→  #outputPagesBySessionKey = new Map();\n   9→  // F-010: File search results state for pagination\n  10→  #searchResultsBySessionKey = new Map();\n  11→  // F-011: AI CLI process tracking\n  12→  #activeProcessBySessionKey = new Map();\n  13→\n  14→  get(sessionKey) {\n  15→    if (!this.#messagesBySessionKey.has(sessionKey)) {\n  16→      this.#messagesBySessionKey.set(sessionKey, []);\n  17→    }\n  18→    return this.#messagesBySessionKey.get(sessionKey);\n  19→  }\n  20→\n  21→  append(sessionKey, role, content) {\n  22→    const messages = this.get(sessionKey);\n  23→    messages.push({ role, content });\n  24→\n  25→    const maxMessages = config.maxHistoryTurns * 2;\n  26→    if (messages.length > maxMessages) {\n  27→      messages.splice(0, messages.length - maxMessages);\n  28→    }\n  29→  }\n  30→\n  31→  clear(sessionKey) {\n  32→    this.#messagesBySessionKey.delete(sessionKey);\n  33→    this.#commitsBySessionKey.delete(sessionKey);\n  34→    // F-009: Clear cwd and output pages\n  35→    this.#cwdBySessionKey.delete(sessionKey);\n  36→    this.#outputPagesBySessionKey.delete(sessionKey);\n  37→    // F-010: Clear search results\n  38→    this.#searchResultsBySessionKey.delete(sessionKey);\n  39→    // F-011: Clear active process\n  40→    this.#activeProcessBySessionKey.delete(sessionKey);\n  41→  }\n  42→\n  43→  toPrompt(sessionKey, channel = 'unknown') {\n  44→    const messages = this.get(sessionKey);\n  45→\n  46→    return [\n  47→      `你正在通过 ${channel} 渠道提供电脑助手服务。`,\n  48→      '请使用自然、简洁、可执行的表达。',\n  49→      '如果用户请求系统操作或截图，明确说明步骤与结果。',\n  50→      '当你产出本地文件（截图/文档）时，必须额外输出独立行：SEND_FILE:<绝对路径>。',\n  51→      '禁止仅输出 @image:xxx 或相对路径；路径必须是绝对路径（例如 /var/folders/... 或 /home/...）。',\n  52→      '以下是最近对话上下文：',\n  53→      ...messages.map((msg) => `${msg.role === 'user' ? '用户' : '助手'}: ${msg.content}`),\n  54→      '请继续回答最后一条用户消息。'\n  55→    ].join('\\n');\n  56→  }\n  57→\n  58→  /**\n  59→   * Add a commit record to a session.\n  60→   * @param {string} sessionKey - Session identifier\n  61→   * @param {Object} commitInfo - Commit information\n  62→   */\n  63→  addCommit(sessionKey, commitInfo) {\n  64→    if (!this.#commitsBySessionKey.has(sessionKey)) {\n  65→      this.#commitsBySessionKey.set(sessionKey, []);\n  66→    }\n  67→    const commits = this.#commitsBySessionKey.get(sessionKey);\n  68→    commits.push({\n  69→      ...commitInfo,\n  70→      timestamp: commitInfo.timestamp || Date.now()\n  71→    });\n  72→  }\n  73→\n  74→  /**\n  75→   * Get commits for a session.\n  76→   * @param {string} sessionKey - Session identifier\n  77→   * @returns {Object[]} Array of commit records\n  78→   */\n  79→  getCommits(sessionKey) {\n  80→    return this.#commitsBySessionKey.get(sessionKey) || [];\n  81→  }\n  82→\n  83→  /**\n  84→   * Get the last commit for a session.\n  85→   * @param {string} sessionKey - Session identifier\n  86→   * @returns {Object|null} Last commit record or null\n  87→   */\n  88→  getLastCommit(sessionKey) {\n  89→    const commits = this.getCommits(sessionKey);\n  90→    return commits.length > 0 ? commits[commits.length - 1] : null;\n  91→  }\n  92→\n  93→  // F-009: Command executor methods\n  94→\n  95→  /**\n  96→   * Get current working directory for a session.\n  97→   * @param {string} sessionKey - Session identifier\n  98→   * @returns {string|null} Current working directory or null\n  99→   */\n 100→  getCwd(sessionKey) {\n 101→    return this.#cwdBySessionKey.get(sessionKey) || null;\n 102→  }\n 103→\n 104→  /**\n 105→   * Set current working directory for a session.\n 106→   * @param {string} sessionKey - Session identifier\n 107→   * @param {string} cwd - Working directory path\n 108→   */\n 109→  setCwd(sessionKey, cwd) {\n 110→    this.#cwdBySessionKey.set(sessionKey, cwd);\n 111→  }\n 112→\n 113→  /**\n 114→   * Get output pages for a session (for /more pagination).\n 115→   * @param {string} sessionKey - Session identifier\n 116→   * @returns {string[]|null} Array of output pages or null\n 117→   */\n 118→  getOutputPages(sessionKey) {\n 119→    return this.#outputPagesBySessionKey.get(sessionKey) || null;\n 120→  }\n 121→\n 122→  /**\n 123→   * Set output pages for a session.\n 124→   * @param {string} sessionKey - Session identifier\n 125→   * @param {string[]} pages - Array of output page strings\n 126→   */\n 127→  setOutputPages(sessionKey, pages) {\n 128→    this.#outputPagesBySessionKey.set(sessionKey, pages);\n 129→  }\n 130→\n 131→  /**\n 132→   * Clear output pages for a session.\n 133→   * @param {string} sessionKey - Session identifier\n 134→   */\n 135→  clearOutputPages(sessionKey) {\n 136→    this.#outputPagesBySessionKey.delete(sessionKey);\n 137→  }\n 138→\n 139→  // F-010: File search results methods\n 140→\n 141→  /**\n 142→   * Get search results for a session.\n 143→   * @param {string} sessionKey - Session identifier\n 144→   * @returns {Object[]|null} Array of search results or null\n 145→   */\n 146→  getSearchResults(sessionKey) {\n 147→    return this.#searchResultsBySessionKey.get(sessionKey) || null;\n 148→  }\n 149→\n 150→  /**\n 151→   * Set search results for a session.\n 152→   * @param {string} sessionKey - Session identifier\n 153→   * @param {Object[]} results - Array of search result objects\n 154→   */\n 155→  setSearchResults(sessionKey, results) {\n 156→    this.#searchResultsBySessionKey.set(sessionKey, results);\n 157→  }\n 158→\n 159→  /**\n 160→   * Clear search results for a session.\n 161→   * @param {string} sessionKey - Session identifier\n 162→   */\n 163→  clearSearchResults(sessionKey) {\n 164→    this.#searchResultsBySessionKey.delete(sessionKey);\n 165→  }\n 166→\n 167→  // F-011: AI CLI process tracking methods\n 168→\n 169→  /**\n 170→   * Get active AI CLI process info.\n 171→   * @param {string} sessionKey - Session identifier\n 172→   * @returns {{ pid: number, startedAt: number, stdoutBytes?: number, childProcess: Object, interrupted?: boolean, timedOut?: boolean, userId?: string } | null}\n 173→   */\n 174→  getActiveProcess(sessionKey) {\n 175→    return this.#activeProcessBySessionKey.get(sessionKey) || null;\n 176→  }\n 177→\n 178→  /**\n 179→   * Set active AI CLI process.\n 180→   * @param {string} sessionKey - Session identifier\n 181→   * @param {{ pid: number, startedAt: number, childProcess: Object, stdoutBytes?: number, userId?: string, interrupted?: boolean, timedOut?: boolean }} info\n 182→   */\n 183→  setActiveProcess(sessionKey, info) {\n 184→    this.#activeProcessBySessionKey.set(sessionKey, {\n 185→      ...info,\n 186→      stdoutBytes: info.stdoutBytes ?? 0\n 187→    });\n 188→  }\n 189→\n 190→  /**\n 191→   * Update stdout bytes for active process.\n 192→   * @param {string} sessionKey - Session identifier\n 193→   * @param {number} bytes - Additional bytes received\n 194→   */\n 195→  updateProcessBytes(sessionKey, bytes) {\n 196→    const info = this.#activeProcessBySessionKey.get(sessionKey);\n 197→    if (info) {\n 198→      info.stdoutBytes = (info.stdoutBytes ?? 0) + bytes;\n 199→    }\n 200→  }\n 201→\n 202→  /**\n 203→   * Clear active process.\n 204→   * @param {string} sessionKey - Session identifier\n 205→   */\n 206→  clearActiveProcess(sessionKey) {\n 207→    this.#activeProcessBySessionKey.delete(sessionKey);\n 208→  }\n 209→}\n 210→\n 211→export const sessionStore = new SessionStore();\n 212→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3b4f54dcd7b31cdb68e43e953ad","__timestamp":"2026-03