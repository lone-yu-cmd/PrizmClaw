{"type":"assistant","uuid":"2026031304011145790150182a4e1d","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"id":"2026031304011145790150182a4e1d","content":[{"type":"text","text":"I can see there are issues with the integration tests. The tests are using `sleep` and `echo` as mock binaries, but the codebuddy args format (`-p`, `-y`) doesn't work with those commands. Let me check the ai-cli-service to understand how it works:"}],"model":"glm-5.0","role":"assistant","stop_reason":null,"stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:01:15.408Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"assistant","uuid":"2026031304011145790150182a4e1d","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"id":"2026031304011145790150182a4e1d","content":[{"type":"tool_use","id":"call_33154cc26aa14136a7e5e7f4","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/ai-cli-service.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":47010,"output_tokens":89,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:01:15.413Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"ee537104-4124-40dd-9667-f2a0fb3b0bdb","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"call_33154cc26aa14136a7e5e7f4","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: AI CLI Service\n   3→ *\n   4→ * Encapsulates AI CLI execution logic with process tracking,\n   5→ * heartbeat, and interrupt support.\n   6→ *\n   7→ * T-051: Metrics tracking for monitoring\n   8→ */\n   9→\n  10→import { spawn } from 'node:child_process';\n  11→import { config } from '../config.js';\n  12→import { logger } from '../utils/logger.js';\n  13→import { sessionStore } from './session-store.js';\n  14→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n  15→\n  16→/**\n  17→ * Metrics for AI CLI execution monitoring.\n  18→ * T-051: Track execution statistics\n  19→ */\n  20→const metrics = {\n  21→  // Execution counts\n  22→  totalExecutions: 0,\n  23→  successCount: 0,\n  24→  failureCount: 0,\n  25→  timeoutCount: 0,\n  26→  interruptCount: 0,\n  27→\n  28→  // Duration tracking (for histogram)\n  29→  durations: [],\n  30→  maxDurations: 100, // Keep last 100 durations\n  31→\n  32→  // Output size tracking\n  33→  outputSizes: [],\n  34→  maxOutputSizes: 100\n  35→};\n  36→\n  37→/**\n  38→ * Get current metrics snapshot.\n  39→ * @returns {Object} Metrics snapshot\n  40→ */\n  41→export function getMetrics() {\n  42→  const durations = [...metrics.durations];\n  43→  const outputSizes = [...metrics.outputSizes];\n  44→\n  45→  return {\n  46→    totalExecutions: metrics.totalExecutions,\n  47→    successCount: metrics.successCount,\n  48→    failureCount: metrics.failureCount,\n  49→    timeoutCount: metrics.timeoutCount,\n  50→    interruptCount: metrics.interruptCount,\n  51→    averageDurationMs: durations.length > 0\n  52→      ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length)\n  53→      : 0,\n  54→    minDurationMs: durations.length > 0 ? Math.min(...durations) : 0,\n  55→    maxDurationMs: durations.length > 0 ? Math.max(...durations) : 0,\n  56→    averageOutputBytes: outputSizes.length > 0\n  57→      ? Math.round(outputSizes.reduce((a, b) => a + b, 0) / outputSizes.length)\n  58→      : 0\n  59→  };\n  60→}\n  61→\n  62→/**\n  63→ * Record execution metrics.\n  64→ * @param {Object} result - Execution result\n  65→ * @param {number} result.elapsedMs - Execution duration\n  66→ * @param {number} result.stdoutBytes - Output size\n  67→ * @param {boolean} result.success - Whether execution succeeded\n  68→ * @param {boolean} result.timedOut - Whether execution timed out\n  69→ * @param {boolean} result.interrupted - Whether execution was interrupted\n  70→ */\n  71→function recordMetrics(result) {\n  72→  metrics.totalExecutions++;\n  73→\n  74→  // Track duration\n  75→  metrics.durations.push(result.elapsedMs);\n  76→  if (metrics.durations.length > metrics.maxDurations) {\n  77→    metrics.durations.shift();\n  78→  }\n  79→\n  80→  // Track output size\n  81→  metrics.outputSizes.push(result.stdoutBytes || 0);\n  82→  if (metrics.outputSizes.length > metrics.maxOutputSizes) {\n  83→    metrics.outputSizes.shift();\n  84→  }\n  85→\n  86→  // Track outcome\n  87→  if (result.interrupted) {\n  88→    metrics.interruptCount++;\n  89→  } else if (result.timedOut) {\n  90→    metrics.timeoutCount++;\n  91→  } else if (result.success) {\n  92→    metrics.successCount++;\n  93→  } else {\n  94→    metrics.failureCount++;\n  95→  }\n  96→\n  97→  // Log metrics at debug level\n  98→  logger.debug(\n  99→    {\n 100→      totalExecutions: metrics.totalExecutions,\n 101→      successRate: `${Math.round((metrics.successCount / metrics.totalExecutions) * 100)}%`,\n 102→      interruptRate: `${Math.round((metrics.interruptCount / metrics.totalExecutions) * 100)}%`,\n 103→      timeoutRate: `${Math.round((metrics.timeoutCount / metrics.totalExecutions) * 100)}%`\n 104→    },\n 105→    'AI CLI metrics updated'\n 106→  );\n 107→}\n 108→\n 109→/**\n 110→ * Reset metrics (useful for testing).\n 111→ */\n 112→export function resetMetrics() {\n 113→  metrics.totalExecutions = 0;\n 114→  metrics.successCount = 0;\n 115→  metrics.failureCount = 0;\n 116→  metrics.timeoutCount = 0;\n 117→  metrics.interruptCount = 0;\n 118→  metrics.durations = [];\n 119→  metrics.outputSizes = [];\n 120→}\n 121→\n 122→/**\n 123→ * @typedef {Object} AiCliExecutionOptions\n 124→ * @property {string} sessionId - Session identifier\n 125→ * @property {string} prompt - User prompt/input\n 126→ * @property {string} [userId] - User ID who initiated the task (for permission checks)\n 127→ * @property {Object} [hooks] - Callback hooks\n 128→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n 129→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n 130→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n 131→ * @property {AbortSignal} [signal] - Optional abort signal\n 132→ * @property {number} [timeoutMs] - Optional timeout override\n 133→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n 134→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n 135→ * @property {string} [bin] - Optional binary override (for testing)\n 136→ */\n 137→\n 138→/**\n 139→ * @typedef {Object} AiCliExecutionResult\n 140→ * @property {string} output - Final output text\n 141→ * @property {boolean} timedOut - Whether execution timed out\n 142→ * @property {boolean} interrupted - Whether execution was interrupted\n 143→ * @property {number} elapsedMs - Execution time in milliseconds\n 144→ * @property {number|null} exitCode - Process exit code (if completed)\n 145→ * @property {string} stderr - Error output if any\n 146→ */\n 147→\n 148→/**\n 149→ * @typedef {Object} HeartbeatInfo\n 150→ * @property {number} elapsedMs - Elapsed time in milliseconds\n 151→ * @property {number} stdoutBytes - Bytes received so far\n 152→ * @property {string} status - Current status ('running', 'streaming')\n 153→ */\n 154→\n 155→/**\n 156→ * Write text to echo output for debugging.\n 157→ * @param {string} tag - Tag for the output\n 158→ * @param {string} text - Text to write\n 159→ */\n 160→function writeEcho(tag, text) {\n 161→  const normalized = String(text ?? '');\n 162→  if (!normalized) {\n 163→    return;\n 164→  }\n 165→\n 166→  const lines = normalized.split(/\\r?\\n/);\n 167→  for (const line of lines) {\n 168→    if (!line) {\n 169→      continue;\n 170→    }\n 171→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n 172→  }\n 173→}\n 174→\n 175→/**\n 176→ * Execute AI CLI with session context and process tracking.\n 177→ * @param {AiCliExecutionOptions} options\n 178→ * @returns {Promise<AiCliExecutionResult>}\n 179→ */\n 180→export async function executeAiCli(options) {\n 181→  const {\n 182→    sessionId,\n 183→    prompt,\n 184→    userId,\n 185→    hooks = {},\n 186→    signal,\n 187→    timeoutMs,\n 188→    heartbeatThresholdMs,\n 189→    heartbeatIntervalMs,\n 190→    bin\n 191→  } = options;\n 192→\n 193→  const effectiveBin = bin || config.codebuddyBin;\n 194→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n 195→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n 196→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n 197→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n 198→\n 199→  const args = ['-p', prompt];\n 200→  if (config.codebuddyPermissionFlag) {\n 201→    args.push(config.codebuddyPermissionFlag);\n 202→  }\n 203→\n 204→  return new Promise((resolve) => {\n 205→    let stdout = '';\n 206→    let stderr = '';\n 207→    let stdoutBytes = 0;\n 208→    let interrupted = false;\n 209→    let timedOut = false;\n 210→    const startedAt = Date.now();\n 211→    const sessionKey = sessionId;\n 212→\n 213→    // Heartbeat manager\n 214→    const heartbeatManager = createHeartbeatManager();\n 215→\n 216→    // Spawn process\n 217→    let child;\n 218→    try {\n 219→      child = spawn(effectiveBin, args, {\n 220→        stdio: ['ignore', 'pipe', 'pipe']\n 221→      });\n 222→    } catch (err) {\n 223→      resolve({\n 224→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 225→        timedOut: false,\n 226→        interrupted: false,\n 227→        elapsedMs: Date.now() - startedAt,\n 228→        exitCode: null,\n 229→        stderr: ''\n 230→      });\n 231→      return;\n 232→    }\n 233→\n 234→    // Track process in session store\n 235→    sessionStore.setActiveProcess(sessionKey, {\n 236→      pid: child.pid,\n 237→      startedAt,\n 238→      childProcess: child,\n 239→      interrupted: false,\n 240→      timedOut: false,\n 241→      userId\n 242→    });\n 243→\n 244→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n 245→\n 246→    // Handle process error\n 247→    child.on('error', (err) => {\n 248→      cleanup();\n 249→      resolve({\n 250→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 251→        timedOut: false,\n 252→        interrupted: false,\n 253→        elapsedMs: Date.now() - startedAt,\n 254→        exitCode: null,\n 255→        stderr\n 256→      });\n 257→    });\n 258→\n 259→    // Handle stdout\n 260→    child.stdout.on('data', (chunk) => {\n 261→      const text = chunk.toString();\n 262→      stdout += text;\n 263→      stdoutBytes += Buffer.byteLength(text);\n 264→\n 265→      // Update session store byte count\n 266→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n 267→\n 268→      // Echo to console if enabled\n 269→      if (config.codebuddyEchoStdio) {\n 270→        writeEcho('stdout', text);\n 271→      }\n 272→\n 273→      // Call onChunk hook\n 274→      if (typeof hooks.onChunk === 'function') {\n 275→        hooks.onChunk(text);\n 276→      }\n 277→    });\n 278→\n 279→    // Handle stderr\n 280→    child.stderr.on('data', (chunk) => {\n 281→      const text = chunk.toString();\n 282→      stderr += text;\n 283→\n 284→      if (config.codebuddyEchoStdio) {\n 285→        writeEcho('stderr', text);\n 286→      }\n 287→    });\n 288→\n 289→    // Timeout handler\n 290→    const timeout = effectiveTimeoutMs > 0\n 291→      ? setTimeout(() => {\n 292→          timedOut = true;\n 293→          const info = sessionStore.getActiveProcess(sessionKey);\n 294→          if (info) {\n 295→            info.timedOut = true;\n 296→          }\n 297→          child.kill('SIGTERM');\n 298→\n 299→          // Schedule SIGKILL if process doesn't exit\n 300→          setTimeout(() => {\n 301→            if (sessionStore.getActiveProcess(sessionKey)) {\n 302→              child.kill('SIGKILL');\n 303→            }\n 304→          }, 5000);\n 305→        }, effectiveTimeoutMs)\n 306→      : null;\n 307→\n 308→    // Abort signal handler\n 309→    const onAbort = () => {\n 310→      interrupted = true;\n 311→      const info = sessionStore.getActiveProcess(sessionKey);\n 312→      if (info) {\n 313→        info.interrupted = true;\n 314→      }\n 315→      child.kill('SIGTERM');\n 316→\n 317→      // Schedule SIGKILL if process doesn't exit\n 318→      setTimeout(() => {\n 319→        if (sessionStore.getActiveProcess(sessionKey)) {\n 320→          child.kill('SIGKILL');\n 321→        }\n 322→      }, 5000);\n 323→    };\n 324→\n 325→    if (signal) {\n 326→      signal.addEventListener('abort', onAbort);\n 327→    }\n 328→\n 329→    // Heartbeat setup\n 330→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n 331→      heartbeatManager.start({\n 332→        callback: () => {\n 333→          const elapsedMs = Date.now() - startedAt;\n 334→          hooks.onHeartbeat({\n 335→            elapsedMs,\n 336→            stdoutBytes,\n 337→            status: 'running'\n 338→          });\n 339→        },\n 340→        intervalMs: effectiveHeartbeatIntervalMs,\n 341→        thresholdMs: effectiveHeartbeatThresholdMs\n 342→      });\n 343→    }\n 344→\n 345→    // Cleanup function\n 346→    function cleanup() {\n 347→      if (timeout) {\n 348→        clearTimeout(timeout);\n 349→      }\n 350→      heartbeatManager.stop();\n 351→      sessionStore.clearActiveProcess(sessionKey);\n 352→      if (signal) {\n 353→        signal.removeEventListener('abort', onAbort);\n 354→      }\n 355→    }\n 356→\n 357→    // Handle process close\n 358→    child.on('close', (code) => {\n 359→      const elapsedMs = Date.now() - startedAt;\n 360→\n 361→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n 362→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n 363→      if (storedInfo) {\n 364→        if (storedInfo.interrupted) {\n 365→          interrupted = true;\n 366→        }\n 367→        if (storedInfo.timedOut) {\n 368→          timedOut = true;\n 369→        }\n 370→      }\n 371→\n 372→      cleanup();\n 373→\n 374→      logger.info(\n 375→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n 376→        'AI CLI process closed'\n 377→      );\n 378→\n 379→      // Build output\n 380→      let output = stdout.trim();\n 381→\n 382→      if (interrupted) {\n 383→        output = output || '任务已被用户中断。';\n 384→      } else if (timedOut) {\n 385→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n 386→      } else if (code !== 0) {\n 387→        output = output || `AI CLI 退出码 ${code}。`;\n 388→        if (stderr.trim()) {\n 389→          output += `\\n错误信息:\\n${stderr.trim()}`;\n 390→        }\n 391→      }\n 392→\n 393→      // Record metrics (T-051)\n 394→      recordMetrics({\n 395→        elapsedMs,\n 396→        stdoutBytes,\n 397→        success: code === 0 && !interrupted && !timedOut,\n 398→        timedOut,\n 399→        interrupted\n 400→      });\n 401→\n 402→      resolve({\n 403→        output: output || 'AI CLI 未返回文本结果。',\n 404→        timedOut,\n 405→        interrupted,\n 406→        elapsedMs,\n 407→        exitCode: code,\n 408→        stderr: stderr.trim()\n 409→      });\n 410→    });\n 411→  });\n 412→}\n 413→\n 414→/**\n 415→ * Interrupt running AI CLI task for a session.\n 416→ * @param {string} sessionId - Session identifier\n 417→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 418→ */\n 419→export function interruptAiCli(sessionId) {\n 420→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 421→\n 422→  if (!processInfo) {\n 423→    return { ok: false, error: '没有正在执行的任务。' };\n 424→  }\n 425→\n 426→  const { pid, childProcess } = processInfo;\n 427→\n 428→  try {\n 429→    // Mark as interrupted so close handler knows\n 430→    processInfo.interrupted = true;\n 431→\n 432→    // Send SIGTERM first\n 433→    childProcess.kill('SIGTERM');\n 434→\n 435→    // Schedule SIGKILL as backup\n 436→    setTimeout(() => {\n 437→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n 438→      if (stillRunning) {\n 439→        try {\n 440→          childProcess.kill('SIGKILL');\n 441→        } catch {\n 442→          // Process already dead\n 443→        }\n 444→      }\n 445→    }, 5000);\n 446→\n 447→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n 448→\n 449→    return { ok: true, pid };\n 450→  } catch (err) {\n 451→    return { ok: false, error: `中断失败: ${err.message}` };\n 452→  }\n 453→}\n 454→\n 455→/**\n 456→ * Check if AI CLI is running for a session.\n 457→ * @param {string} sessionId\n 458→ * @returns {boolean}\n 459→ */\n 460→export function isAiCliRunning(sessionId) {\n 461→  return sessionStore.getActiveProcess(sessionId) !== null;\n 462→}\n 463→\n 464→/**\n 465→ * Get active process info for a session.\n 466→ * @param {string} sessionId\n 467→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n 468→ */\n 469→export function getActiveProcessInfo(sessionId) {\n 470→  const info = sessionStore.getActiveProcess(sessionId);\n 471→  if (!info) {\n 472→    return null;\n 473→  }\n 474→\n 475→  // Don't expose childProcess to external callers\n 476→  return {\n 477→    pid: info.pid,\n 478→    startedAt: info.startedAt,\n 479→    stdoutBytes: info.stdoutBytes ?? 0,\n 480→    userId: info.userId\n 481→  };\n 482→}\n 483→\n 484→/**\n 485→ * Check if user can interrupt AI CLI task.\n 486→ * @param {string} sessionId - Session identifier\n 487→ * @param {string|number} requestUserId - User requesting interrupt\n 488→ * @param {Function} isAdminFn - Function to check if user is admin\n 489→ * @returns {{ canInterrupt: boolean, reason?: string }}\n 490→ */\n 491→export function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n 492→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 493→\n 494→  if (!processInfo) {\n 495→    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n 496→  }\n 497→\n 498→  // Admin can always interrupt\n 499→  if (isAdminFn && isAdminFn(requestUserId)) {\n 500→    return { canInterrupt: true };\n 501→  }\n 502→\n 503→  // Task owner can interrupt\n 504→  const taskUserId = processInfo.userId;\n 505→  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n 506→    return { canInterrupt: true };\n 507→  }\n 508→\n 509→  // Otherwise, permission denied\n 510→  return {\n 511→    canInterrupt: false,\n 512→    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n 513→  };\n 514→}\n 515→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:01:15.416Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
