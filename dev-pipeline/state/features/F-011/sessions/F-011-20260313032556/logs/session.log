{"type":"user","uuid":"5caa3294-6556-4606-ae44-948ea63cda6a","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"call_c1e80ca102e949d6ad0e24df","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Tests for AI CLI Error Recovery\n   3→ * F-011, T-054: Test all error scenarios\n   4→ */\n   5→\n   6→import { describe, test, beforeEach, afterEach } from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→\n   9→import { sessionStore } from '../../src/services/session-store.js';\n  10→import {\n  11→  executeAiCli,\n  12→  interruptAiCli,\n  13→  isAiCliRunning,\n  14→  resetMetrics,\n  15→  getMetrics\n  16→} from '../../src/services/ai-cli-service.js';\n  17→\n  18→describe('F-011 AI CLI Error Recovery Integration', () => {\n  19→  const testSessionId = 'test-error-session-001';\n  20→  const testUserId = '123456789';\n  21→\n  22→  beforeEach(() => {\n  23→    sessionStore.clear(testSessionId);\n  24→    resetMetrics();\n  25→  });\n  26→\n  27→  afterEach(() => {\n  28→    sessionStore.clear(testSessionId);\n  29→  });\n  30→\n  31→  describe('Timeout with Suggestion', () => {\n  32→    test('should handle timeout and provide suggestion', async () => {\n  33→      const result = await executeAiCli({\n  34→        sessionId: testSessionId,\n  35→        prompt: '5', // sleep 5 seconds\n  36→        userId: testUserId,\n  37→        bin: 'sleep',\n  38→        timeoutMs: 500, // 500ms timeout\n  39→        heartbeatThresholdMs: 100,\n  40→        heartbeatIntervalMs: 100\n  41→      });\n  42→\n  43→      assert.equal(result.timedOut, true);\n  44→      assert.ok(result.output.includes('超时'));\n  45→      assert.ok(result.output.includes('建议') || result.output.includes('/stop'));\n  46→    });\n  47→\n  48→    test('should clean up session after timeout', async () => {\n  49→      await executeAiCli({\n  50→        sessionId: testSessionId,\n  51→        prompt: '2',\n  52→        userId: testUserId,\n  53→        bin: 'sleep',\n  54→        timeoutMs: 500\n  55→      });\n  56→\n  57→      // Session should be cleaned up\n  58→      const isRunning = isAiCliRunning(testSessionId);\n  59→      assert.equal(isRunning, false);\n  60→    });\n  61→\n  62→    test('should track timeout in metrics', async () => {\n  63→      await executeAiCli({\n  64→        sessionId: testSessionId,\n  65→        prompt: '2',\n  66→        userId: testUserId,\n  67→        bin: 'sleep',\n  68→        timeoutMs: 500\n  69→      });\n  70→\n  71→      const metrics = getMetrics();\n  72→      assert.equal(metrics.timeoutCount, 1);\n  73→    });\n  74→  });\n  75→\n  76→  describe('Process Crash Recovery', () => {\n  77→    test('should handle non-zero exit code', async () => {\n  78→      const result = await executeAiCli({\n  79→        sessionId: testSessionId,\n  80→        prompt: '-c \"exit 1\"',\n  81→        userId: testUserId,\n  82→        bin: 'sh',\n  83→        timeoutMs: 5000\n  84→      });\n  85→\n  86→      assert.equal(result.exitCode, 1);\n  87→      assert.ok(result.output);\n  88→    });\n  89→\n  90→    test('should handle process that writes to stderr', async () => {\n  91→      const result = await executeAiCli({\n  92→        sessionId: testSessionId,\n  93→        prompt: '-c \"echo error >&2; exit 1\"',\n  94→        userId: testUserId,\n  95→        bin: 'sh',\n  96→        timeoutMs: 5000\n  97→      });\n  98→\n  99→      assert.equal(result.exitCode, 1);\n 100→      assert.ok(result.stderr.includes('error') || result.output.includes('error'));\n 101→    });\n 102→\n 103→    test('should track failures in metrics', async () => {\n 104→      await executeAiCli({\n 105→        sessionId: testSessionId,\n 106→        prompt: '-c \"exit 1\"',\n 107→        userId: testUserId,\n 108→        bin: 'sh',\n 109→        timeoutMs: 5000\n 110→      });\n 111→\n 112→      const metrics = getMetrics();\n 113→      assert.equal(metrics.failureCount, 1);\n 114→    });\n 115→\n 116→    test('should handle process spawn failure', async () => {\n 117→      const result = await executeAiCli({\n 118→        sessionId: testSessionId,\n 119→        prompt: 'test',\n 120→        userId: testUserId,\n 121→        bin: '/nonexistent/binary/path',\n 122→        timeoutMs: 5000\n 123→      });\n 124→\n 125→      assert.ok(result.output.includes('无法启动') || result.output.includes('error') || result.output.includes('ENOENT'));\n 126→      assert.equal(result.exitCode, null);\n 127→    });\n 128→  });\n 129→\n 130→  describe('Interrupt Confirmation', () => {\n 131→    test('should confirm interrupt was successful', async () => {\n 132→      const execPromise = executeAiCli({\n 133→        sessionId: testSessionId,\n 134→        prompt: '10',\n 135→        userId: testUserId,\n 136→        bin: 'sleep',\n 137→        timeoutMs: 30000\n 138→      });\n 139→\n 140→      // Wait for process to start\n 141→      await new Promise((resolve) => setTimeout(resolve, 50));\n 142→\n 143→      // Verify running\n 144→      assert.equal(isAiCliRunning(testSessionId), true);\n 145→\n 146→      // Interrupt\n 147→      const interruptResult = interruptAiCli(testSessionId);\n 148→      assert.equal(interruptResult.ok, true);\n 149→      assert.ok(interruptResult.pid);\n 150→\n 151→      // Wait for completion\n 152→      const result = await execPromise;\n 153→      assert.equal(result.interrupted, true);\n 154→    });\n 155→\n 156→    test('should return error when no process to interrupt', () => {\n 157→      const result = interruptAiCli(testSessionId);\n 158→      assert.equal(result.ok, false);\n 159→      assert.ok(result.error.includes('没有'));\n 160→    });\n 161→\n 162→    test('should track interrupts in metrics', async () => {\n 163→      const execPromise = executeAiCli({\n 164→        sessionId: testSessionId,\n 165→        prompt: '5',\n 166→        userId: testUserId,\n 167→        bin: 'sleep',\n 168→        timeoutMs: 30000\n 169→      });\n 170→\n 171→      await new Promise((resolve) => setTimeout(resolve, 50));\n 172→      interruptAiCli(testSessionId);\n 173→      await execPromise;\n 174→\n 175→      const metrics = getMetrics();\n 176→      assert.equal(metrics.interruptCount, 1);\n 177→    });\n 178→  });\n 179→\n 180→  describe('Session Cleanup', () => {\n 181→    test('should clean up session on successful execution', async () => {\n 182→      await executeAiCli({\n 183→        sessionId: testSessionId,\n 184→        prompt: 'success',\n 185→        userId: testUserId,\n 186→        bin: 'echo',\n 187→        timeoutMs: 5000\n 188→      });\n 189→\n 190→      assert.equal(isAiCliRunning(testSessionId), false);\n 191→    });\n 192→\n 193→    test('should clean up session on error', async () => {\n 194→      await executeAiCli({\n 195→        sessionId: testSessionId,\n 196→        prompt: '-c \"exit 1\"',\n 197→        userId: testUserId,\n 198→        bin: 'sh',\n 199→        timeoutMs: 5000\n 200→      });\n 201→\n 202→      assert.equal(isAiCliRunning(testSessionId), false);\n 203→    });\n 204→\n 205→    test('should clean up session on timeout', async () => {\n 206→      await executeAiCli({\n 207→        sessionId: testSessionId,\n 208→        prompt: '5',\n 209→        userId: testUserId,\n 210→        bin: 'sleep',\n 211→        timeoutMs: 500\n 212→      });\n 213→\n 214→      assert.equal(isAiCliRunning(testSessionId), false);\n 215→    });\n 216→\n 217→    test('should clean up session on interrupt', async () => {\n 218→      const execPromise = executeAiCli({\n 219→        sessionId: testSessionId,\n 220→        prompt: '10',\n 221→        userId: testUserId,\n 222→        bin: 'sleep',\n 223→        timeoutMs: 30000\n 224→      });\n 225→\n 226→      await new Promise((resolve) => setTimeout(resolve, 50));\n 227→      interruptAiCli(testSessionId);\n 228→      await execPromise;\n 229→\n 230→      assert.equal(isAiCliRunning(testSessionId), false);\n 231→    });\n 232→  });\n 233→\n 234→  describe('Error Messages with Recovery Suggestions', () => {\n 235→    test('should suggest /stop for timeout', async () => {\n 236→      const result = await executeAiCli({\n 237→        sessionId: testSessionId,\n 238→        prompt: '5',\n 239→        userId: testUserId,\n 240→        bin: 'sleep',\n 241→        timeoutMs: 500\n 242→      });\n 243→\n 244→      assert.ok(\n 245→        result.output.includes('/stop') || result.output.includes('中断'),\n 246→        'Should mention /stop or interrupt option'\n 247→      );\n 248→    });\n 249→\n 250→    test('should suggest checking config for spawn failure', async () => {\n 251→      const result = await executeAiCli({\n 252→        sessionId: testSessionId,\n 253→        prompt: 'test',\n 254→        userId: testUserId,\n 255→        bin: '/invalid/path',\n 256→        timeoutMs: 5000\n 257→      });\n 258→\n 259→      assert.ok(\n 260→        result.output.includes('CODEBUDDY_BIN') ||\n 261→        result.output.includes('配置') ||\n 262→        result.output.includes('无法启动'),\n 263→        'Should suggest checking config'\n 264→      );\n 265→    });\n 266→\n 267→    test('should include stderr in error message', async () => {\n 268→      const result = await executeAiCli({\n 269→        sessionId: testSessionId,\n 270→        prompt: '-c \"echo test_error >&2; exit 1\"',\n 271→        userId: testUserId,\n 272→        bin: 'sh',\n 273→        timeoutMs: 5000\n 274→      });\n 275→\n 276→      assert.ok(\n 277→        result.stderr.includes('test_error') ||\n 278→        result.output.includes('test_error') ||\n 279→        result.output.includes('错误信息'),\n 280→        'Should include stderr or mention error'\n 281→      );\n 282→    });\n 283→  });\n 284→});\n 285→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3a32437d4af704548a467fd4021","__timestamp":"2026-03-12T20:07:19.134Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
