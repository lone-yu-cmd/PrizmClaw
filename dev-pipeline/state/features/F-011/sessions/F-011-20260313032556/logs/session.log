{"type":"assistant","uuid":"20260313035940c157fd15d4dc422f","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"id":"20260313035940c157fd15d4dc422f","content":[{"type":"text","text":"Now let me create the integration tests for T-039, T-040, T-053, and T-054:</think>"}],"model":"glm-5.0","role":"assistant","stop_reason":null,"stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T20:00:10.281Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"assistant","uuid":"20260313035940c157fd15d4dc422f","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"id":"20260313035940c157fd15d4dc422f","content":[{"type":"tool_use","id":"019ce3a22de4a9699d55517c28b9041c","name":"Write","input":{"content":"/**\n * Integration Tests for AI CLI Telegram Flow\n * F-011, T-039: Test full Telegram → AI CLI → output flow\n */\n\nimport { describe, test, beforeEach, afterEach } from 'node:test';\nimport assert from 'node:assert/strict';\nimport { writeFile, mkdir, rm } from 'node:fs/promises';\nimport { join } from 'node:path';\nimport { tmpdir } from 'node:os';\n\nimport { sessionStore } from '../../src/services/session-store.js';\nimport {\n  executeAiCli,\n  interruptAiCli,\n  isAiCliRunning,\n  getActiveProcessInfo,\n  canInterruptAiCli,\n  resetMetrics,\n  getMetrics\n} from '../../src/services/ai-cli-service.js';\nimport { convertToMarkdownV2 } from '../../src/utils/markdown-v2-formatter.js';\n\ndescribe('F-011 AI CLI Telegram Flow Integration', () => {\n  const testSessionId = 'test-telegram-session-001';\n  const testUserId = '123456789';\n  const adminUserId = '987654321';\n\n  beforeEach(() => {\n    sessionStore.clear(testSessionId);\n    resetMetrics();\n  });\n\n  afterEach(() => {\n    sessionStore.clear(testSessionId);\n  });\n\n  describe('Normal Execution Flow', () => {\n    test('should execute AI CLI and return output', async () => {\n      const chunks = [];\n      const result = await executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'echo hello',\n        userId: testUserId,\n        bin: 'echo',\n        timeoutMs: 5000,\n        hooks: {\n          onChunk: (text) => chunks.push(text)\n        }\n      });\n\n      assert.ok(result.output);\n      assert.equal(result.timedOut, false);\n      assert.equal(result.interrupted, false);\n      assert.ok(result.elapsedMs >= 0);\n      // Exit code from echo should be 0\n      assert.equal(result.exitCode, 0);\n\n      // Check that chunks were received\n      assert.ok(chunks.length > 0 || result.output.includes('hello'));\n    });\n\n    test('should track process during execution', async () => {\n      // Start a long-running process\n      const executionPromise = executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'sleep 0.5',\n        userId: testUserId,\n        bin: 'sleep',\n        timeoutMs: 10000\n      });\n\n      // Give it a moment to start\n      await new Promise((resolve) => setTimeout(resolve, 50));\n\n      // Check process is tracked\n      const isRunning = isAiCliRunning(testSessionId);\n      assert.equal(isRunning, true);\n\n      const processInfo = getActiveProcessInfo(testSessionId);\n      assert.ok(processInfo);\n      assert.ok(processInfo.pid);\n      assert.ok(processInfo.startedAt);\n      assert.equal(processInfo.userId, testUserId);\n\n      // Wait for completion\n      await executionPromise;\n\n      // Check process is cleared\n      assert.equal(isAiCliRunning(testSessionId), false);\n    });\n  });\n\n  describe('Multi-turn Conversation', () => {\n    test('should maintain session context across executions', async () => {\n      // First message\n      const result1 = await executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'echo first message',\n        userId: testUserId,\n        bin: 'echo',\n        timeoutMs: 5000\n      });\n\n      assert.ok(result1.output);\n\n      // Second message - session should still have history\n      const result2 = await executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'echo second message',\n        userId: testUserId,\n        bin: 'echo',\n        timeoutMs: 5000\n      });\n\n      assert.ok(result2.output);\n\n      // Check session store has messages\n      const messages = sessionStore.get(testSessionId);\n      assert.ok(messages.length > 0);\n    });\n  });\n\n  describe('Stop Interrupt', () => {\n    test('should interrupt running process via /stop', async () => {\n      // Start a long-running process\n      const executionPromise = executeAiCli({\n        sessionId: testSessionId,\n        prompt: '10', // sleep for 10 seconds\n        userId: testUserId,\n        bin: 'sleep',\n        timeoutMs: 30000\n      });\n\n      // Give it a moment to start\n      await new Promise((resolve) => setTimeout(resolve, 100));\n\n      // Verify process is running\n      assert.equal(isAiCliRunning(testSessionId), true);\n\n      // Interrupt\n      const interruptResult = interruptAiCli(testSessionId);\n      assert.equal(interruptResult.ok, true);\n      assert.ok(interruptResult.pid);\n\n      // Wait for execution to complete\n      const result = await executionPromise;\n\n      // Should be marked as interrupted\n      assert.equal(result.interrupted, true);\n    });\n  });\n\n  describe('Error Handling', () => {\n    test('should handle process spawn failure gracefully', async () => {\n      const result = await executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'test',\n        userId: testUserId,\n        bin: '/nonexistent/binary/that/does/not/exist',\n        timeoutMs: 5000\n      });\n\n      assert.ok(result.output.includes('无法启动') || result.output.includes('error'));\n      assert.equal(result.timedOut, false);\n      assert.equal(result.interrupted, false);\n    });\n\n    test('should handle non-zero exit code', async () => {\n      const result = await executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'exit 1',\n        userId: testUserId,\n        bin: 'sh',\n        timeoutMs: 5000\n      });\n\n      assert.equal(result.exitCode, 1);\n      assert.ok(result.output);\n    });\n  });\n\n  describe('Permission Checks (T-033)', () => {\n    test('should allow task owner to interrupt', () => {\n      // Simulate a running task\n      sessionStore.setActiveProcess(testSessionId, {\n        pid: 12345,\n        startedAt: Date.now(),\n        childProcess: { kill: () => {} },\n        userId: testUserId\n      });\n\n      const check = canInterruptAiCli(testSessionId, testUserId, () => false);\n      assert.equal(check.canInterrupt, true);\n    });\n\n    test('should allow admin to interrupt', () => {\n      // Simulate a running task owned by another user\n      sessionStore.setActiveProcess(testSessionId, {\n        pid: 12345,\n        startedAt: Date.now(),\n        childProcess: { kill: () => {} },\n        userId: 'other-user-id'\n      });\n\n      const check = canInterruptAiCli(testSessionId, adminUserId, (id) => String(id) === adminUserId);\n      assert.equal(check.canInterrupt, true);\n    });\n\n    test('should deny non-owner non-admin interrupt', () => {\n      // Simulate a running task owned by another user\n      sessionStore.setActiveProcess(testSessionId, {\n        pid: 12345,\n        startedAt: Date.now(),\n        childProcess: { kill: () => {} },\n        userId: testUserId\n      });\n\n      const check = canInterruptAiCli(testSessionId, 'another-user-id', () => false);\n      assert.equal(check.canInterrupt, false);\n      assert.ok(check.reason.includes('权限不足'));\n    });\n  });\n\n  describe('Metrics (T-051)', () => {\n    test('should track execution metrics', async () => {\n      // Execute a simple command\n      await executeAiCli({\n        sessionId: testSessionId,\n        prompt: 'hello',\n        userId: testUserId,\n        bin: 'echo',\n        timeoutMs: 5000\n      });\n\n      const metrics = getMetrics();\n      assert.equal(metrics.totalExecutions, 1);\n      assert.equal(metrics.successCount, 1);\n      assert.ok(metrics.averageDurationMs >= 0);\n    });\n\n    test('should track interrupt metrics', async () => {\n      // Start and interrupt a process\n      const execPromise = executeAiCli({\n        sessionId: testSessionId,\n        prompt: '5',\n        userId: testUserId,\n        bin: 'sleep',\n        timeoutMs: 30000\n      });\n\n      await new Promise((resolve) => setTimeout(resolve, 50));\n      interruptAiCli(testSessionId);\n      await execPromise;\n\n      const metrics = getMetrics();\n      assert.equal(metrics.totalExecutions, 1);\n      assert.equal(metrics.interruptCount, 1);\n    });\n  });\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/ai-cli-telegram.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":84626,"output_tokens":1844,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T20:00:10.287Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
