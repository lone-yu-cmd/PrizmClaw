{"type":"user","uuid":"d6ed7949-e47a-485c-a600-8c6684a5dd56","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce39f3baa77e9b903918851845cf1","content":[{"type":"text","text":"   1→# Technical Implementation Plan: F-011 AI CLI Proxy\n   2→\n   3→**Feature ID**: F-011\n   4→**Feature Name**: AI CLI Proxy\n   5→**Created**: 2026-03-13\n   6→**Status**: Draft\n   7→\n   8→---\n   9→\n  10→## 1. Architecture Overview\n  11→\n  12→### 1.1 Component Diagram\n  13→\n  14→```\n  15→┌─────────────────────────────────────────────────────────────────┐\n  16→│                         Telegram Bot                             │\n  17→│                    (src/bot/telegram.js)                        │\n  18→└─────────────────────────────────────────────────────────────────┘\n  19→                              │\n  20→                              ▼\n  21→┌─────────────────────────────────────────────────────────────────┐\n  22→│                      AI CLI Service                              │\n  23→│                (src/services/ai-cli-service.js)                  │\n  24→│  ┌─────────────┐  ┌──────────────┐  ┌─────────────────────┐     │\n  25→│  │  Process    │  │  Heartbeat   │  │  Stream             │     │\n  26→│  │  Manager    │  │  Manager     │  │  Handler            │     │\n  27→│  └─────────────┘  └──────────────┘  └─────────────────────┘     │\n  28→└─────────────────────────────────────────────────────────────────┘\n  29→         │                    │                    │\n  30→         ▼                    ▼                    ▼\n  31→┌────────────────┐  ┌─────────────────┐  ┌──────────────────────┐\n  32→│ Session Store  │  │ CodeBuddy       │  │ MarkdownV2           │\n  33→│ (extended)     │  │ Adapter         │  │ Formatter            │\n  34→│                │  │ (extended)      │  │                      │\n  35→└────────────────┘  └─────────────────┘  └──────────────────────┘\n  36→                              │\n  37→                              ▼\n  38→                    ┌─────────────────┐\n  39→                    │  CodeBuddy CLI  │\n  40→                    │  (external)     │\n  41→                    └─────────────────┘\n  42→```\n  43→\n  44→### 1.2 Key Design Decisions\n  45→\n  46→| Decision ID | Description | Rationale |\n  47→|-------------|-------------|-----------|\n  48→| D-1 | Create separate `ai-cli-service.js` instead of modifying `chat-service.js` | Separation of concerns; AI CLI execution has different lifecycle than chat |\n  49→| D-2 | Store active process info in `session-store.js` | Consistent with existing session management pattern |\n  50→| D-3 | Use SIGTERM → SIGKILL graceful termination | Standard practice, prevents zombie processes |\n  51→| D-4 | Implement MarkdownV2 formatter as pure utility | Reusable, testable, no side effects |\n  52→| D-5 | Extend `/stop` command instead of creating new `/ai-stop` | Consistent user experience with existing pattern |\n  53→\n  54→---\n  55→\n  56→## 2. Component Design\n  57→\n  58→### 2.1 AI CLI Service (`src/services/ai-cli-service.js`)\n  59→\n  60→**Purpose**: Encapsulate AI CLI execution logic with process tracking, heartbeat, and interrupt support.\n  61→\n  62→**Responsibilities**:\n  63→- Execute CodeBuddy CLI with session context\n  64→- Track active processes per session\n  65→- Provide interrupt capability\n  66→- Manage heartbeat progress notifications\n  67→- Format and return results\n  68→\n  69→**Dependencies**:\n  70→- `src/adapters/codebuddy.js` (extended)\n  71→- `src/services/session-store.js` (extended)\n  72→- `src/utils/markdown-v2-formatter.js` (new)\n  73→- `src/config.js`\n  74→\n  75→**Interface**:\n  76→```javascript\n  77→/**\n  78→ * @typedef {Object} AiCliExecutionOptions\n  79→ * @property {string} sessionId - Session identifier\n  80→ * @property {string} prompt - User prompt/input\n  81→ * @property {Object} [hooks] - Callback hooks\n  82→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n  83→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n  84→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n  85→ * @property {AbortSignal} [signal] - Optional abort signal\n  86→ */\n  87→\n  88→/**\n  89→ * @typedef {Object} AiCliExecutionResult\n  90→ * @property {string} output - Final output text\n  91→ * @property {boolean} timedOut - Whether execution timed out\n  92→ * @property {boolean} interrupted - Whether execution was interrupted\n  93→ * @property {number} elapsedMs - Execution time in milliseconds\n  94→ * @property {number} exitCode - Process exit code (if completed)\n  95→ */\n  96→\n  97→/**\n  98→ * @typedef {Object} HeartbeatInfo\n  99→ * @property {number} elapsedMs - Elapsed time in milliseconds\n 100→ * @property {number} stdoutBytes - Bytes received so far\n 101→ * @property {string} status - Current status ('running', 'streaming')\n 102→ */\n 103→\n 104→/**\n 105→ * Execute AI CLI with session context and process tracking.\n 106→ * @param {AiCliExecutionOptions} options\n 107→ * @returns {Promise<AiCliExecutionResult>}\n 108→ */\n 109→export async function executeAiCli(options) {}\n 110→\n 111→/**\n 112→ * Interrupt running AI CLI task for a session.\n 113→ * @param {string} sessionId - Session identifier\n 114→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 115→ */\n 116→export function interruptAiCli(sessionId) {}\n 117→\n 118→/**\n 119→ * Check if AI CLI is running for a session.\n 120→ * @param {string} sessionId\n 121→ * @returns {boolean}\n 122→ */\n 123→export function isAiCliRunning(sessionId) {}\n 124→\n 125→/**\n 126→ * Get active process info for a session.\n 127→ * @param {string} sessionId\n 128→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number } | null}\n 129→ */\n 130→export function getActiveProcessInfo(sessionId) {}\n 131→```\n 132→\n 133→### 2.2 CodeBuddy Adapter Extensions (`src/adapters/codebuddy.js`)\n 134→\n 135→**Changes**:\n 136→- Add `AbortSignal` support for cancellation\n 137→- Return child process reference for external management\n 138→- Expose process info (PID) during execution\n 139→\n 140→**Extended Interface**:\n 141→```javascript\n 142→/**\n 143→ * @typedef {Object} CodeBuddyOptions\n 144→ * @property {Function} [onStdoutChunk] - Stream chunk callback\n 145→ * @property {Function} [onHeartbeat] - Heartbeat callback\n 146→ * @property {AbortSignal} [signal] - Abort signal for cancellation\n 147→ * @property {Object} [processTracker] - Object to receive process reference\n 148→ */\n 149→\n 150→/**\n 151→ * @typedef {Object} CodeBuddyResult\n 152→ * @property {string} output - Output text\n 153→ * @property {number} exitCode - Exit code\n 154→ * @property {boolean} timedOut - Whether timed out\n 155→ * @property {boolean} interrupted - Whether interrupted by signal\n 156→ * @property {number} elapsedMs - Execution time\n 157→ */\n 158→\n 159→export async function runCodeBuddy(prompt, options = {}) {\n 160→  // Return extended result with process tracking\n 161→}\n 162→```\n 163→\n 164→### 2.3 MarkdownV2 Formatter (`src/utils/markdown-v2-formatter.js`)\n 165→\n 166→**Purpose**: Convert Markdown output to Telegram MarkdownV2 format.\n 167→\n 168→**Interface**:\n 169→```javascript\n 170→/**\n 171→ * Characters that need escaping in MarkdownV2.\n 172→ */\n 173→const ESCAPE_CHARS = ['_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!'];\n 174→\n 175→/**\n 176→ * Escape text for Telegram MarkdownV2 format.\n 177→ * @param {string} text - Text to escape\n 178→ * @returns {string} Escaped text\n 179→ */\n 180→export function escapeMarkdownV2(text) {\n 181→  // Escape all special characters\n 182→}\n 183→\n 184→/**\n 185→ * Format code block for Telegram MarkdownV2.\n 186→ * @param {string} code - Code content\n 187→ * @param {string} [language] - Optional language identifier\n 188→ * @returns {string} Formatted code block\n 189→ */\n 190→export function formatCodeBlock(code, language = '') {\n 191→  // ```language\\ncode\\n```\n 192→  // Note: Inside code blocks, only ` and \\ need escaping\n 193→}\n 194→\n 195→/**\n 196→ * Convert common Markdown to MarkdownV2.\n 197→ * Handles: code blocks, inline code, bold, italic, links.\n 198→ * @param {string} markdown - Input markdown\n 199→ * @returns {string} MarkdownV2 formatted text\n 200→ */\n 201→export function convertToMarkdownV2(markdown) {\n 202→  // Parse and convert each element\n 203→}\n 204→\n 205→/**\n 206→ * Split text into segments respecting code block boundaries.\n 207→ * Useful for splitting long messages.\n 208→ * @param {string} text - Text to split\n 209→ * @param {number} maxLength - Maximum length per segment\n 210→ * @returns {string[]} Array of segments\n 211→ */\n 212→export function splitRespectingCodeBlocks(text, maxLength = 4000) {}\n 213→```\n 214→\n 215→### 2.4 Session Store Extensions (`src/services/session-store.js`)\n 216→\n 217→**New Fields**:\n 218→```javascript\n 219→class SessionStore {\n 220→  // ... existing fields ...\n 221→  \n 222→  /**\n 223→   * Active AI CLI process tracking.\n 224→   * Map<sessionKey, ProcessInfo>\n 225→   * @type {Map<string, { pid: number, startedAt: number, stdoutBytes: number, childProcess: ChildProcess }>}\n 226→   */\n 227→  #activeProcessBySessionKey = new Map();\n 228→}\n 229→```\n 230→\n 231→**New Methods**:\n 232→```javascript\n 233→/**\n 234→ * Get active AI CLI process info.\n 235→ * @param {string} sessionKey\n 236→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number, childProcess: ChildProcess } | null}\n 237→ */\n 238→getActiveProcess(sessionKey) {}\n 239→\n 240→/**\n 241→ * Set active AI CLI process.\n 242→ * @param {string} sessionKey\n 243→ * @param {{ pid: number, startedAt: number, childProcess: ChildProcess }} info\n 244→ */\n 245→setActiveProcess(sessionKey, info) {}\n 246→\n 247→/**\n 248→ * Update stdout bytes for active process.\n 249→ * @param {string} sessionKey\n 250→ * @param {number} bytes\n 251→ */\n 252→updateProcessBytes(sessionKey, bytes) {}\n 253→\n 254→/**\n 255→ * Clear active process.\n 256→ * @param {string} sessionKey\n 257→ */\n 258→clearActiveProcess(sessionKey) {}\n 259→```\n 260→\n 261→---\n 262→\n 263→## 3. Interface Design\n 264→\n 265→### 3.1 Config Schema Extensions\n 266→\n 267→**File**: `src/config.js`\n 268→\n 269→**New Environment Variables**:\n 270→```javascript\n 271→// Add to schema\n 272→const schema = z.object({\n 273→  // ... existing fields ...\n 274→  \n 275→  // F-011: AI CLI Proxy\n 276→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n 277→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n 278→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true'),\n 279→});\n 280→\n 281→// Exported config additions\n 282→export const config = Object.freeze({\n 283→  // ... existing fields ...\n 284→  \n 285→  // F-011: AI CLI Proxy\n 286→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 287→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 288→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 289→});\n 290→```\n 291→\n 292→### 3.2 Telegram Bot Integration\n 293→\n 294→**File**: `src/bot/telegram.js`\n 295→\n 296→**Changes to text message handler**:\n 297→```javascript\n 298→// In bot.on('text', ...) handler\n 299→\n 300→// Check if AI CLI is running for this session\n 301→if (isAiCliRunning(sessionId)) {\n 302→  await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n 303→  return;\n 304→}\n 305→\n 306→// Use ai-cli-service for execution\n 307→const result = await executeAiCli({\n 308→  sessionId,\n 309→  prompt: ctx.message.text,\n 310→  hooks: {\n 311→    onChunk: (text) => streamPublisher.push(text),\n 312→    onHeartbeat: (info) => {\n 313→      // Push heartbeat progress to user\n 314→      ctx.reply(`⏳ 任务执行中... (${Math.floor(info.elapsedMs / 1000)}s)`)\n 315→        .catch(() => {});\n 316→    },\n 317→    onStatus: (status) => {\n 318→      if (status === 'running') {\n 319→        ctx.sendChatAction('typing').catch(() => undefined);\n 320→      }\n 321→    }\n 322→  }\n 323→});\n 324→\n 325→// Format output with MarkdownV2\n 326→const formattedOutput = convertToMarkdownV2(result.output);\n 327→\n 328→// Handle result\n 329→if (result.interrupted) {\n 330→  await ctx.reply('⏹️ 任务已被中断。');\n 331→} else if (result.timedOut) {\n 332→  await ctx.reply(`⏰ 任务执行超时（>${config.requestTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n 333→} else {\n 334→  streamPublisher.setFinalText(formattedOutput);\n 335→}\n 336→```\n 337→\n 338→### 3.3 Stop Command Extension\n 339→\n 340→**File**: `src/bot/commands/handlers/stop.js`\n 341→\n 342→**Changes**:\n 343→```javascript\n 344→import { interruptAiCli, isAiCliRunning } from '../../../services/ai-cli-service.js';\n 345→import { stopPipeline } from '../../../services/pipeline-controller.js';\n 346→\n 347→export async function handleStop(handlerCtx) {\n 348→  const { params, reply, userId, sessionId } = handlerCtx;\n 349→  \n 350→  // First, check for AI CLI task\n 351→  if (isAiCliRunning(sessionId)) {\n 352→    const result = interruptAiCli(sessionId);\n 353→    \n 354→    if (result.ok) {\n 355→      await logAuditEntry({\n 356→        userId,\n 357→        action: 'stop-ai-cli',\n 358→        params: { pid: result.pid },\n 359→        result: 'success',\n 360→        sessionId\n 361→      });\n 362→      \n 363→      await reply(`✅ AI CLI 任务已中断 (PID: ${result.pid})。`);\n 364→      return;\n 365→    } else {\n 366→      await reply(`❌ 中断失败: ${result.error}`);\n 367→      return;\n 368→    }\n 369→  }\n 370→  \n 371→  // Fall back to pipeline stop (existing logic)\n 372→  // ... existing stop pipeline code ...\n 373→}\n 374→```\n 375→\n 376→---\n 377→\n 378→## 4. Data Model\n 379→\n 380→### 4.1 Session Store Schema\n 381→\n 382→```javascript\n 383→// ProcessInfo type\n 384→{\n 385→  pid: number,           // Process ID\n 386→  startedAt: number,     // Timestamp when process started\n 387→  stdoutBytes: number,   // Bytes received so far\n 388→  childProcess: ChildProcess  // Reference to child process for termination\n 389→}\n 390→```\n 391→\n 392→### 4.2 Execution Result Schema\n 393→\n 394→```javascript\n 395→// AiCliExecutionResult\n 396→{\n 397→  output: string,        // Final output text (MarkdownV2 formatted)\n 398→  timedOut: boolean,     // True if timed out\n 399→  interrupted: boolean,  // True if interrupted by user\n 400→  elapsedMs: number,     // Total execution time\n 401→  exitCode: number | null,  // Exit code (null if interrupted)\n 402→  stderr: string         // Error output if any\n 403→}\n 404→```\n 405→\n 406→### 4.3 Heartbeat Info Schema\n 407→\n 408→```javascript\n 409→// HeartbeatInfo\n 410→{\n 411→  elapsedMs: number,     // Elapsed time in ms\n 412→  stdoutBytes: number,   // Bytes received\n 413→  status: 'running' | 'streaming' | 'waiting'\n 414→}\n 415→```\n 416→\n 417→---\n 418→\n 419→## 5. Test Strategy\n 420→\n 421→### 5.1 Unit Tests\n 422→\n 423→**File**: `tests/services/ai-cli-service.test.js`\n 424→```javascript\n 425→describe('AiCliService', () => {\n 426→  describe('executeAiCli', () => {\n 427→    it('should execute CodeBuddy and return output');\n 428→    it('should track active process in session store');\n 429→    it('should call onChunk callback for streaming output');\n 430→    it('should call onHeartbeat callback periodically');\n 431→    it('should handle timeout correctly');\n 432→    it('should handle abort signal');\n 433→    it('should clean up process on completion');\n 434→  });\n 435→  \n 436→  describe('interruptAiCli', () => {\n 437→    it('should interrupt running process');\n 438→    it('should return error if no process running');\n 439→    it('should clean up session store after interrupt');\n 440→  });\n 441→  \n 442→  describe('isAiCliRunning', () => {\n 443→    it('should return true when process is active');\n 444→    it('should return false when no process');\n 445→  });\n 446→});\n 447→```\n 448→\n 449→**File**: `tests/utils/markdown-v2-formatter.test.js`\n 450→```javascript\n 451→describe('MarkdownV2Formatter', () => {\n 452→  describe('escapeMarkdownV2', () => {\n 453→    it('should escape all special characters');\n 454→    it('should handle empty string');\n 455→    it('should handle text with no special chars');\n 456→    it('should handle text with multiple special chars');\n 457→  });\n 458→  \n 459→  describe('formatCodeBlock', () => {\n 460→    it('should format code block without language');\n 461→    it('should format code block with language');\n 462→    it('should escape backticks inside code');\n 463→  });\n 464→  \n 465→  describe('convertToMarkdownV2', () => {\n 466→    it('should convert code blocks');\n 467→    it('should convert inline code');\n 468→    it('should convert bold text');\n 469→    it('should convert italic text');\n 470→    it('should convert links');\n 471→    it('should handle nested formatting');\n 472→    it('should preserve line breaks');\n 473→  });\n 474→  \n 475→  describe('splitRespectingCodeBlocks', () => {\n 476→    it('should not split inside code blocks');\n 477→    it('should split at paragraph boundaries');\n 478→    it('should respect maxLength');\n 479→  });\n 480→});\n 481→```\n 482→\n 483→### 5.2 Integration Tests\n 484→\n 485→**File**: `tests/integration/ai-cli-integration.test.js`\n 486→```javascript\n 487→describe('AI CLI Integration', () => {\n 488→  it('should execute full flow: prompt → execute → stream → result');\n 489→  it('should maintain context across multiple turns');\n 490→  it('should handle /stop during execution');\n 491→  it('should show heartbeat progress');\n 492→  it('should format output correctly for Telegram');\n 493→});\n 494→```\n 495→\n 496→### 5.3 Test Helpers\n 497→\n 498→**File**: `tests/helpers/mock-codebuddy.js`\n 499→```javascript\n 500→/**\n 501→ * Mock CodeBuddy CLI for testing.\n 502→ * Simulates various scenarios: success, timeout, error, slow output.\n 503→ */\n 504→export function createMockCodeBuddy(options = {}) {\n 505→  return {\n 506→    simulateSuccess: (output) => { ... },\n 507→    simulateTimeout: () => { ... },\n 508→    simulateError: (exitCode, stderr) => { ... },\n 509→    simulateSlowOutput: (chunks, interval) => { ... },\n 510→  };\n 511→}\n 512→```\n 513→\n 514→---\n 515→\n 516→## 6. Implementation Phases\n 517→\n 518→### Phase 1: Foundation (T-001 ~ T-009)\n 519→- Add config fields\n 520→- Create MarkdownV2 formatter utility\n 521→- Extend session store with process tracking\n 522→\n 523→### Phase 2: Core Service (T-010 ~ T-029)\n 524→- Create AI CLI service\n 525→- Extend CodeBuddy adapter\n 526→- Implement process tracking\n 527→\n 528→### Phase 3: Integration (T-030 ~ T-049)\n 529→- Integrate with Telegram bot\n 530→- Extend /stop command\n 531→- Add heartbeat progress\n 532→\n 533→### Phase 4: Testing & Polish (T-050 ~ T-069)\n 534→- Unit tests\n 535→- Integration tests\n 536→- Error handling refinement\n 537→\n 538→---\n 539→\n 540→## 7. Risk Assessment\n 541→\n 542→| Risk ID | Description | Impact | Likelihood | Mitigation |\n 543→|---------|-------------|--------|------------|------------|\n 544→| R-1 | Process becomes zombie after SIGTERM | High | Low | Implement SIGKILL after grace period (5s) |\n 545→| R-2 | MarkdownV2 formatting breaks existing output | Medium | Medium | Comprehensive test suite, gradual rollout |\n 546→| R-3 | Heartbeat messages spam user | Medium | Medium | Configurable interval, minimum 10s |\n 547→| R-4 | Race condition in process tracking | High | Low | Use chat-queue for serialization |\n 548→| R-5 | Memory leak from unreleased process refs | Medium | Low | Cleanup on process close, timeout, and session reset |\n 549→\n 550→---\n 551→\n 552→## 8. Rollback Plan\n 553→\n 554→If issues arise:\n 555→1. **Feature flag**: Set `AI_CLI_ENABLE_HEARTBEAT=false` to disable heartbeat\n 556→2. **Fallback to chat-service**: The existing `chat-service.js` remains unchanged, can be used if needed\n 557→3. **Process cleanup**: On restart, all tracked processes are cleared\n 558→\n 559→---\n 560→\n 561→## 9. Monitoring & Observability\n 562→\n 563→### 9.1 Metrics to Track\n 564→- AI CLI execution duration (histogram)\n 565→- AI CLI success/failure rate\n 566→- Heartbeat delivery rate\n 567→- Process interrupt frequency\n 568→- Output size distribution\n 569→\n 570→### 9.2 Logging\n 571→- Log process start with PID, sessionId, prompt length\n 572→- Log process end with exit code, duration, output size\n 573→- Log interrupts with reason\n 574→- Log heartbeat events at debug level\n 575→\n 576→---\n 577→\n 578→## 10. Documentation Updates\n 579→\n 580→### 10.1 Files to Update\n 581→- `.prizm-docs/runtime.prizm`: Add F-011 entries to KEY_FILES, TRAPS, DECISIONS\n 582→- `README.md`: Document new config options\n 583→- `.env.example`: Add new environment variables\n 584→\n 585→### 10.2 New Documentation\n 586→- `docs/ai-cli-proxy.md`: Feature documentation for users\n 587→\n 588→---\n 589→\n 590→## 11. User Story Mapping\n 591→\n 592→| User Story | Tasks |\n 593→|------------|-------|\n 594→| US-1: Natural Language Execution | T-010, T-011, T-012, T-030, T-031 |\n 595→| US-2: Multi-turn Context | T-013 (uses existing session-store) |\n 596→| US-3: Task Interrupt | T-014, T-015, T-032, T-033 |\n 597→| US-4: Heartbeat Progress | T-004, T-016, T-034 |\n 598→| US-5: Error Handling | T-017, T-035 |\n 599→| US-6: Markdown Formatting | T-006, T-007, T-008, T-036 |\n 600→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:56:31.773Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"00ede6af-41d4-41e0-9f5b-2dac8d20f0ab","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce39f3dc582434144cbbced0fa560","content":[{"type":"text","text":"   1→/**\n   2→ * Stop Command Handler\n   3→ * Handles /stop command to stop running pipelines and AI CLI tasks.\n   4→ * F-006: Integrated with security guard\n   5→ * F-011: Extended to handle AI CLI task interruption\n   6→ */\n   7→\n   8→import { stopPipeline } from '../../../services/pipeline-controller.js';\n   9→import { interruptAiCli, isAiCliRunning } from '../../../services/ai-cli-service.js';\n  10→import { logAuditEntry } from '../../../services/audit-log-service.js';\n  11→import {\n  12→  createConfirmation,\n  13→  checkConfirmation as _checkConfirmation,\n  14→  confirmAction,\n  15→  cancelConfirmation\n  16→} from '../../../security/confirmation-manager.js';\n  17→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n  18→import { isAdmin } from '../../../security/permission-guard.js';\n  19→\n  20→// Store pending confirmations for text-based flow\n  21→const pendingConfirmations = new Map();\n  22→\n  23→/**\n  24→ * Stop command metadata.\n  25→ * T-102: minRole added\n  26→ * F-011: Extended for AI CLI tasks\n  27→ */\n  28→export const stopMeta = {\n  29→  name: 'stop',\n  30→  aliases: [],\n  31→  description: '停止运行中的管道或 AI CLI 任务',\n  32→  usage: '/stop [target]',\n  33→  examples: ['/stop', '/stop my-feature'],\n  34→  params: [\n  35→    {\n  36→      name: 'target',\n  37→      type: 'string',\n  38→      required: false,\n  39→      description: '目标标识符'\n  40→    }\n  41→  ],\n  42→  requiresAuth: true,\n  43→  minRole: 'admin',\n  44→  helpText: '/stop [target] - 停止运行中的管道或 AI CLI 任务'\n  45→};\n  46→\n  47→/**\n  48→ * Handle stop command.\n  49→ * T-104, T-106: Added confirmation flow\n  50→ * F-011: Check for AI CLI tasks first\n  51→ * @param {Object} handlerCtx - Handler context\n  52→ */\n  53→export async function handleStop(handlerCtx) {\n  54→  const { params, reply, userId, userRole: _userRole, requiresConfirmation, parsed, sessionId } = handlerCtx;\n  55→\n  56→  // F-011: Check for AI CLI task first\n  57→  if (sessionId && isAiCliRunning(sessionId)) {\n  58→    const result = interruptAiCli(sessionId);\n  59→\n  60→    if (result.ok) {\n  61→      await logAuditEntry({\n  62→        userId,\n  63→        action: 'stop-ai-cli',\n  64→        params: { pid: result.pid },\n  65→        result: 'success',\n  66→        sessionId\n  67→      });\n  68→\n  69→      await reply(`✅ AI CLI 任务已中断 (PID: ${result.pid})。`);\n  70→      return;\n  71→    } else {\n  72→      await logAuditEntry({\n  73→        userId,\n  74→        action: 'stop-ai-cli',\n  75→        params: {},\n  76→        result: 'failed',\n  77→        reason: result.error,\n  78→        sessionId\n  79→      });\n  80→      await reply(`❌ 中断失败: ${result.error}`);\n  81→      return;\n  82→    }\n  83→  }\n  84→\n  85→  // Sanitize target parameter\n  86→  const rawTarget = params._args?.[0] || params.target;\n  87→  const typeResult = sanitizeParam(params.type || 'feature', { maxLength: 50, isTargetId: false });\n  88→  if (!typeResult.ok) {\n  89→    await reply(`❌ 参数无效: ${typeResult.error}`);\n  90→    return;\n  91→  }\n  92→  const pipelineType = typeResult.value;\n  93→\n  94→  // Check if force flag is set (AC-4.4: --force skips confirmation for admin)\n  95→  const forceFlag = params.force === true || parsed?.flags?.force === true;\n  96→  const canSkipConfirmation = isAdmin(userId) && forceFlag;\n  97→\n  98→  // Handle confirmation flow (AC-4.1)\n  99→  if (requiresConfirmation && !canSkipConfirmation) {\n 100→    // Check if this is a CONFIRM response\n 101→    if (rawTarget === 'CONFIRM') {\n 102→      const pendingKey = `stop:${userId}`;\n 103→      const confirmId = pendingConfirmations.get(pendingKey);\n 104→\n 105→      if (confirmId) {\n 106→        const result = confirmAction(confirmId, userId);\n 107→        if (result.ok) {\n 108→          pendingConfirmations.delete(pendingKey);\n 109→          await executeStop(handlerCtx, result.params.type, userId, reply);\n 110→        } else {\n 111→          await reply(`❌ 确认失败: ${result.error}`);\n 112→        }\n 113→        return;\n 114→      } else {\n 115→        await reply('❌ 没有待确认的 stop 操作，或操作已过期。');\n 116→        return;\n 117→      }\n 118→    }\n 119→\n 120→    // Check if this is a CANCEL response\n 121→    if (rawTarget === 'CANCEL') {\n 122→      const pendingKey = `stop:${userId}`;\n 123→      const confirmId = pendingConfirmations.get(pendingKey);\n 124→      if (confirmId) {\n 125→        cancelConfirmation(confirmId, userId);\n 126→        pendingConfirmations.delete(pendingKey);\n 127→        await reply('✅ 已取消 stop 操作。');\n 128→      } else {\n 129→        await reply('没有待确认的 stop 操作。');\n 130→      }\n 131→      return;\n 132→    }\n 133→\n 134→    // Create new confirmation\n 135→    const { confirmId, message } = createConfirmation(userId, 'stop', { type: pipelineType });\n 136→    pendingConfirmations.set(`stop:${userId}`, confirmId);\n 137→\n 138→    await reply(`⚠️ 高风险操作确认\\n\\n${message}\\n\\n请回复 /stop CONFIRM 确认，或 /stop CANCEL 取消。`);\n 139→    return;\n 140→  }\n 141→\n 142→  // Execute directly (admin with --force or no confirmation required)\n 143→  await executeStop(handlerCtx, pipelineType, userId, reply);\n 144→}\n 145→\n 146→/**\n 147→ * Execute stop operation\n 148→ */\n 149→async function executeStop(handlerCtx, pipelineType, userId, reply) {\n 150→  try {\n 151→    const result = await stopPipeline({ type: pipelineType });\n 152→\n 153→    if (result.ok) {\n 154→      await logAuditEntry({\n 155→        userId,\n 156→        action: 'stop',\n 157→        params: { type: pipelineType },\n 158→        result: 'success'\n 159→      });\n 160→\n 161→      if (result.errorCode === 'ALREADY_STOPPED') {\n 162→        await reply('⚠️ 没有运行中的管道。');\n 163→      } else {\n 164→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n 165→        await reply(`✅ 已停止管道${pidInfo}。`);\n 166→      }\n 167→    } else {\n 168→      await logAuditEntry({\n 169→        userId,\n 170→        action: 'stop',\n 171→        params: { type: pipelineType },\n 172→        result: 'failed',\n 173→        reason: result.message\n 174→      });\n 175→      await reply(`❌ 停止失败: ${result.message || '未知错误'}`);\n 176→    }\n 177→  } catch (error) {\n 178→    await logAuditEntry({\n 179→      userId,\n 180→      action: 'stop',\n 181→      params: { type: pipelineType },\n 182→      result: 'failed',\n 183→      reason: error.message\n 184→    });\n 185→    await reply(`❌ 停止失败: ${error.message}`);\n 186→  }\n 187→}\n 188→\n 189→export default handleStop;\n 190→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:56:31.774Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"da8ca26b-764a-40eb-9d35-72f91c1904c8","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce39f3f909c5586cf9b9a9e3a4773","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: AI CLI Service\n   3→ *\n   4→ * Encapsulates AI CLI execution logic with process tracking,\n   5→ * heartbeat, and interrupt support.\n   6→ */\n   7→\n   8→import { spawn } from 'node:child_process';\n   9→import { config } from '../config.js';\n  10→import { logger } from '../utils/logger.js';\n  11→import { sessionStore } from './session-store.js';\n  12→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n  13→\n  14→/**\n  15→ * @typedef {Object} AiCliExecutionOptions\n  16→ * @property {string} sessionId - Session identifier\n  17→ * @property {string} prompt - User prompt/input\n  18→ * @property {Object} [hooks] - Callback hooks\n  19→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n  20→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n  21→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n  22→ * @property {AbortSignal} [signal] - Optional abort signal\n  23→ * @property {number} [timeoutMs] - Optional timeout override\n  24→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n  25→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n  26→ * @property {string} [bin] - Optional binary override (for testing)\n  27→ */\n  28→\n  29→/**\n  30→ * @typedef {Object} AiCliExecutionResult\n  31→ * @property {string} output - Final output text\n  32→ * @property {boolean} timedOut - Whether execution timed out\n  33→ * @property {boolean} interrupted - Whether execution was interrupted\n  34→ * @property {number} elapsedMs - Execution time in milliseconds\n  35→ * @property {number|null} exitCode - Process exit code (if completed)\n  36→ * @property {string} stderr - Error output if any\n  37→ */\n  38→\n  39→/**\n  40→ * @typedef {Object} HeartbeatInfo\n  41→ * @property {number} elapsedMs - Elapsed time in milliseconds\n  42→ * @property {number} stdoutBytes - Bytes received so far\n  43→ * @property {string} status - Current status ('running', 'streaming')\n  44→ */\n  45→\n  46→/**\n  47→ * Write text to echo output for debugging.\n  48→ * @param {string} tag - Tag for the output\n  49→ * @param {string} text - Text to write\n  50→ */\n  51→function writeEcho(tag, text) {\n  52→  const normalized = String(text ?? '');\n  53→  if (!normalized) {\n  54→    return;\n  55→  }\n  56→\n  57→  const lines = normalized.split(/\\r?\\n/);\n  58→  for (const line of lines) {\n  59→    if (!line) {\n  60→      continue;\n  61→    }\n  62→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  63→  }\n  64→}\n  65→\n  66→/**\n  67→ * Execute AI CLI with session context and process tracking.\n  68→ * @param {AiCliExecutionOptions} options\n  69→ * @returns {Promise<AiCliExecutionResult>}\n  70→ */\n  71→export async function executeAiCli(options) {\n  72→  const {\n  73→    sessionId,\n  74→    prompt,\n  75→    hooks = {},\n  76→    signal,\n  77→    timeoutMs,\n  78→    heartbeatThresholdMs,\n  79→    heartbeatIntervalMs,\n  80→    bin\n  81→  } = options;\n  82→\n  83→  const effectiveBin = bin || config.codebuddyBin;\n  84→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n  85→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n  86→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n  87→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n  88→\n  89→  const args = ['-p', prompt];\n  90→  if (config.codebuddyPermissionFlag) {\n  91→    args.push(config.codebuddyPermissionFlag);\n  92→  }\n  93→\n  94→  return new Promise((resolve) => {\n  95→    let stdout = '';\n  96→    let stderr = '';\n  97→    let stdoutBytes = 0;\n  98→    let interrupted = false;\n  99→    let timedOut = false;\n 100→    const startedAt = Date.now();\n 101→    const sessionKey = sessionId;\n 102→\n 103→    // Heartbeat manager\n 104→    const heartbeatManager = createHeartbeatManager();\n 105→\n 106→    // Spawn process\n 107→    let child;\n 108→    try {\n 109→      child = spawn(effectiveBin, args, {\n 110→        stdio: ['ignore', 'pipe', 'pipe']\n 111→      });\n 112→    } catch (err) {\n 113→      resolve({\n 114→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 115→        timedOut: false,\n 116→        interrupted: false,\n 117→        elapsedMs: Date.now() - startedAt,\n 118→        exitCode: null,\n 119→        stderr: ''\n 120→      });\n 121→      return;\n 122→    }\n 123→\n 124→    // Track process in session store\n 125→    sessionStore.setActiveProcess(sessionKey, {\n 126→      pid: child.pid,\n 127→      startedAt,\n 128→      childProcess: child,\n 129→      interrupted: false,\n 130→      timedOut: false\n 131→    });\n 132→\n 133→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n 134→\n 135→    // Handle process error\n 136→    child.on('error', (err) => {\n 137→      cleanup();\n 138→      resolve({\n 139→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 140→        timedOut: false,\n 141→        interrupted: false,\n 142→        elapsedMs: Date.now() - startedAt,\n 143→        exitCode: null,\n 144→        stderr\n 145→      });\n 146→    });\n 147→\n 148→    // Handle stdout\n 149→    child.stdout.on('data', (chunk) => {\n 150→      const text = chunk.toString();\n 151→      stdout += text;\n 152→      stdoutBytes += Buffer.byteLength(text);\n 153→\n 154→      // Update session store byte count\n 155→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n 156→\n 157→      // Echo to console if enabled\n 158→      if (config.codebuddyEchoStdio) {\n 159→        writeEcho('stdout', text);\n 160→      }\n 161→\n 162→      // Call onChunk hook\n 163→      if (typeof hooks.onChunk === 'function') {\n 164→        hooks.onChunk(text);\n 165→      }\n 166→    });\n 167→\n 168→    // Handle stderr\n 169→    child.stderr.on('data', (chunk) => {\n 170→      const text = chunk.toString();\n 171→      stderr += text;\n 172→\n 173→      if (config.codebuddyEchoStdio) {\n 174→        writeEcho('stderr', text);\n 175→      }\n 176→    });\n 177→\n 178→    // Timeout handler\n 179→    const timeout = effectiveTimeoutMs > 0\n 180→      ? setTimeout(() => {\n 181→          timedOut = true;\n 182→          const info = sessionStore.getActiveProcess(sessionKey);\n 183→          if (info) {\n 184→            info.timedOut = true;\n 185→          }\n 186→          child.kill('SIGTERM');\n 187→\n 188→          // Schedule SIGKILL if process doesn't exit\n 189→          setTimeout(() => {\n 190→            if (sessionStore.getActiveProcess(sessionKey)) {\n 191→              child.kill('SIGKILL');\n 192→            }\n 193→          }, 5000);\n 194→        }, effectiveTimeoutMs)\n 195→      : null;\n 196→\n 197→    // Abort signal handler\n 198→    const onAbort = () => {\n 199→      interrupted = true;\n 200→      const info = sessionStore.getActiveProcess(sessionKey);\n 201→      if (info) {\n 202→        info.interrupted = true;\n 203→      }\n 204→      child.kill('SIGTERM');\n 205→\n 206→      // Schedule SIGKILL if process doesn't exit\n 207→      setTimeout(() => {\n 208→        if (sessionStore.getActiveProcess(sessionKey)) {\n 209→          child.kill('SIGKILL');\n 210→        }\n 211→      }, 5000);\n 212→    };\n 213→\n 214→    if (signal) {\n 215→      signal.addEventListener('abort', onAbort);\n 216→    }\n 217→\n 218→    // Heartbeat setup\n 219→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n 220→      heartbeatManager.start({\n 221→        callback: () => {\n 222→          const elapsedMs = Date.now() - startedAt;\n 223→          hooks.onHeartbeat({\n 224→            elapsedMs,\n 225→            stdoutBytes,\n 226→            status: 'running'\n 227→          });\n 228→        },\n 229→        intervalMs: effectiveHeartbeatIntervalMs,\n 230→        thresholdMs: effectiveHeartbeatThresholdMs\n 231→      });\n 232→    }\n 233→\n 234→    // Cleanup function\n 235→    function cleanup() {\n 236→      if (timeout) {\n 237→        clearTimeout(timeout);\n 238→      }\n 239→      heartbeatManager.stop();\n 240→      sessionStore.clearActiveProcess(sessionKey);\n 241→      if (signal) {\n 242→        signal.removeEventListener('abort', onAbort);\n 243→      }\n 244→    }\n 245→\n 246→    // Handle process close\n 247→    child.on('close', (code) => {\n 248→      const elapsedMs = Date.now() - startedAt;\n 249→\n 250→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n 251→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n 252→      if (storedInfo) {\n 253→        if (storedInfo.interrupted) {\n 254→          interrupted = true;\n 255→        }\n 256→        if (storedInfo.timedOut) {\n 257→          timedOut = true;\n 258→        }\n 259→      }\n 260→\n 261→      cleanup();\n 262→\n 263→      logger.info(\n 264→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n 265→        'AI CLI process closed'\n 266→      );\n 267→\n 268→      // Build output\n 269→      let output = stdout.trim();\n 270→\n 271→      if (interrupted) {\n 272→        output = output || '任务已被用户中断。';\n 273→      } else if (timedOut) {\n 274→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n 275→      } else if (code !== 0) {\n 276→        output = output || `AI CLI 退出码 ${code}。`;\n 277→        if (stderr.trim()) {\n 278→          output += `\\n错误信息:\\n${stderr.trim()}`;\n 279→        }\n 280→      }\n 281→\n 282→      resolve({\n 283→        output: output || 'AI CLI 未返回文本结果。',\n 284→        timedOut,\n 285→        interrupted,\n 286→        elapsedMs,\n 287→        exitCode: code,\n 288→        stderr: stderr.trim()\n 289→      });\n 290→    });\n 291→  });\n 292→}\n 293→\n 294→/**\n 295→ * Interrupt running AI CLI task for a session.\n 296→ * @param {string} sessionId - Session identifier\n 297→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 298→ */\n 299→export function interruptAiCli(sessionId) {\n 300→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 301→\n 302→  if (!processInfo) {\n 303→    return { ok: false, error: '没有正在执行的任务。' };\n 304→  }\n 305→\n 306→  const { pid, childProcess } = processInfo;\n 307→\n 308→  try {\n 309→    // Mark as interrupted so close handler knows\n 310→    processInfo.interrupted = true;\n 311→\n 312→    // Send SIGTERM first\n 313→    childProcess.kill('SIGTERM');\n 314→\n 315→    // Schedule SIGKILL as backup\n 316→    setTimeout(() => {\n 317→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n 318→      if (stillRunning) {\n 319→        try {\n 320→          childProcess.kill('SIGKILL');\n 321→        } catch {\n 322→          // Process already dead\n 323→        }\n 324→      }\n 325→    }, 5000);\n 326→\n 327→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n 328→\n 329→    return { ok: true, pid };\n 330→  } catch (err) {\n 331→    return { ok: false, error: `中断失败: ${err.message}` };\n 332→  }\n 333→}\n 334→\n 335→/**\n 336→ * Check if AI CLI is running for a session.\n 337→ * @param {string} sessionId\n 338→ * @returns {boolean}\n 339→ */\n 340→export function isAiCliRunning(sessionId) {\n 341→  return sessionStore.getActiveProcess(sessionId) !== null;\n 342→}\n 343→\n 344→/**\n 345→ * Get active process info for a session.\n 346→ * @param {string} sessionId\n 347→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number } | null}\n 348→ */\n 349→export function getActiveProcessInfo(sessionId) {\n 350→  const info = sessionStore.getActiveProcess(sessionId);\n 351→  if (!info) {\n 352→    return null;\n 353→  }\n 354→\n 355→  // Don't expose childProcess to external callers\n 356→  return {\n 357→    pid: info.pid,\n 358→    startedAt: info.startedAt,\n 359→    stdoutBytes: info.stdoutBytes ?? 0\n 360→  };\n 361→}\n 362→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:56:31.774Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
