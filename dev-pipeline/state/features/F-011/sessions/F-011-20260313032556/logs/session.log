{"type":"user","uuid":"276e83df-3fbd-403a-869e-a6ffb53414af","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce38c111af1d0ed56e6c510d7522d","content":[{"type":"text","text":"   1→# Channel switches\n   2→ENABLE_TELEGRAM=true\n   3→\n   4→# Telegram\n   5→# 填你的 Bot Token。不要把真实 token 提交到仓库。\n   6→TELEGRAM_BOT_TOKEN=\n   7→# ALLOWED_USER_IDS 留空 = 不限制用户ID（任何能访问你 Bot 的用户都可用）\n   8→# 建议生产环境填写，例如: ALLOWED_USER_IDS=12345678,99887766\n   9→ALLOWED_USER_IDS=\n  10→\n  11→# CodeBuddy CLI\n  12→CODEBUDDY_BIN=codebuddy\n  13→CODEBUDDY_PERMISSION_FLAG=-y\n  14→CODEBUDDY_ECHO_STDIO=true\n  15→CODEBUDDY_HEARTBEAT_MS=15000\n  16→# 可选：覆盖文件发送安全根目录（逗号分隔绝对路径）。留空则用默认值。\n  17→TELEGRAM_FILE_ALLOWED_ROOTS=\n  18→# 可选：覆盖文件候选搜索目录（逗号分隔绝对路径）。留空则用默认值。\n  19→TELEGRAM_FILE_CANDIDATE_DIRS=\n  20→REQUEST_TIMEOUT_MS=120000\n  21→MAX_PROMPT_CHARS=8000\n  22→MAX_HISTORY_TURNS=10\n  23→\n  24→# Web management panel\n  25→WEB_HOST=127.0.0.1\n  26→WEB_PORT=8787\n  27→\n  28→# System operation permissions (DANGEROUS, use whitelist)\n  29→ENABLE_SYSTEM_EXEC=false\n  30→ALLOWED_COMMAND_PREFIXES=ls,pwd,open,codebuddy,node,npm,python3\n  31→SYSTEM_EXEC_TIMEOUT_MS=60000\n  32→# F-009: Command blacklist - comma-separated command prefixes to block (e.g., rm -rf,mkfs,dd if=)\n  33→COMMAND_BLACKLIST=rm -rf,mkfs,dd if=\n  34→# F-009: High-risk keywords - comma-separated keywords that require confirmation before execution\n  35→HIGH_RISK_KEYWORDS=rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt\n  36→# F-009: Direct exec mode - when true, plain text messages are treated as shell commands\n  37→DIRECT_EXEC_MODE=false\n  38→\n  39→# Pipeline infra\n  40→PIPELINE_PROJECT_ROOT=\n  41→PIPELINE_DIR=\n  42→FEATURE_LIST_PATH=feature-list.json\n  43→BUG_FIX_LIST_PATH=bug-fix-list.json\n  44→MAX_RETRIES=3\n  45→SESSION_TIMEOUT=0\n  46→HEARTBEAT_INTERVAL=30\n  47→AI_CLI=cbc\n  48→PRIZMKIT_PLATFORM=codebuddy\n  49→\n  50→# Logging\n  51→LOG_LEVEL=info\n  52→\n  53→# F-006: Safety and Permission Guard\n  54→# USER_PERMISSIONS format: userId:role,userId:role (roles: admin, operator, viewer)\n  55→# Example: USER_PERMISSIONS=123456789:admin,987654321:operator\n  56→USER_PERMISSIONS=\n  57→# Allow admin users to skip confirmation for high-risk commands\n  58→ALLOW_ADMIN_SKIP_CONFIRM=true\n  59→# Audit log configuration\n  60→AUDIT_LOG_DIR=logs\n  61→AUDIT_LOG_MAX_SIZE_MB=10\n  62→AUDIT_LOG_MAX_FILES=5\n  63→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce38bdd117b44f51df57146b62d27","__timestamp":"2026-03-12T19:35:33.837Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
