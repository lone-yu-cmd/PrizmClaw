{"type":"user","uuid":"a2185599-523d-4151-ae9a-4ffffc9b40fa","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce38c49569548859362e85702d2e3","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20)\n  43→});\n  44→\n  45→const parsed = schema.parse(process.env);\n  46→\n  47→function parseAllowedUserIds(input) {\n  48→  return new Set(\n  49→    input\n  50→      .split(',')\n  51→      .map((id) => id.trim())\n  52→      .filter(Boolean)\n  53→  );\n  54→}\n  55→\n  56→function parseCsvList(input) {\n  57→  return input\n  58→    .split(',')\n  59→    .map((item) => item.trim())\n  60→    .filter(Boolean);\n  61→}\n  62→\n  63→function parseBoolean(input) {\n  64→  const normalized = (input ?? '').trim().toLowerCase();\n  65→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  66→}\n  67→\n  68→/**\n  69→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  70→ * Format: \"123456789:admin,987654321:operator\"\n  71→ * @param {string} input\n  72→ * @returns {Map<string, string>}\n  73→ */\n  74→function parseUserPermissions(input) {\n  75→  const permissions = new Map();\n  76→  if (!input || !input.trim()) {\n  77→    return permissions;\n  78→  }\n  79→\n  80→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  81→  for (const entry of entries) {\n  82→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  83→    if (userId && role) {\n  84→      const normalizedRole = role.toLowerCase();\n  85→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  86→        permissions.set(userId, normalizedRole);\n  87→      }\n  88→    }\n  89→  }\n  90→  return permissions;\n  91→}\n  92→\n  93→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n  94→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n  95→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n  96→}\n  97→\n  98→const pipelineInfra = loadPipelineInfraConfig({\n  99→  env: process.env,\n 100→  argv: process.argv.slice(2),\n 101→  cwd: process.cwd()\n 102→});\n 103→\n 104→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 105→\n 106→export const config = Object.freeze({\n 107→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 108→  enableTelegram,\n 109→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 110→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 111→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 112→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 113→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 114→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 115→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 116→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 117→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 118→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 119→  webHost: parsed.WEB_HOST,\n 120→  webPort: parsed.WEB_PORT,\n 121→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 122→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 123→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 124→  logLevel: parsed.LOG_LEVEL,\n 125→  // F-006: Safety and Permission Guard\n 126→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 127→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 128→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 129→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 130→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 131→  // F-009: General Command Executor\n 132→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 133→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 134→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 135→  // F-010: File Manager\n 136→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 137→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 138→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 139→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 140→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 141→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 142→  pipelineInfra: Object.freeze({\n 143→    ...pipelineInfra,\n 144→    daemonLogPaths\n 145→  })\n 146→});\n 147→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce38bdd117b44f51df57146b62d27","__timestamp":"2026-03-12T19:35:48.208Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
