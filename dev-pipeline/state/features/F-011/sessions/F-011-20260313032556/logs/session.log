{"type":"user","uuid":"05f91895-8231-4ebc-933e-0de59419235c","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3b65113abaf2e54216b340bb30e","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for F-011 AI CLI Service\n   3→ * T-010, T-011, T-012, T-013, T-014, T-015, T-016, T-017\n   4→ */\n   5→\n   6→import { describe, test, beforeEach, afterEach, mock } from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→\n   9→describe('F-011 AI CLI Service', () => {\n  10→  const testSessionId = 'test-session-f011';\n  11→\n  12→  beforeEach(async () => {\n  13→    // Reset modules to get fresh instances\n  14→    const { sessionStore } = await import('../../src/services/session-store.js');\n  15→    sessionStore.clear(testSessionId);\n  16→  });\n  17→\n  18→  afterEach(async () => {\n  19→    const { sessionStore } = await import('../../src/services/session-store.js');\n  20→    sessionStore.clear(testSessionId);\n  21→  });\n  22→\n  23→  describe('executeAiCli', () => {\n  24→    test('should export executeAiCli function', async () => {\n  25→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  26→      assert.ok(typeof executeAiCli === 'function');\n  27→    });\n  28→\n  29→    test('should return result object with required properties', async () => {\n  30→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  31→\n  32→      const result = await executeAiCli({\n  33→        sessionId: testSessionId,\n  34→        prompt: 'echo hello'\n  35→      });\n  36→\n  37→      assert.ok(result);\n  38→      assert.ok('output' in result);\n  39→      assert.ok('elapsedMs' in result);\n  40→      assert.ok('timedOut' in result);\n  41→      assert.ok('interrupted' in result);\n  42→    });\n  43→\n  44→    test('should track active process in session store', async () => {\n  45→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  46→      const { sessionStore } = await import('../../src/services/session-store.js');\n  47→\n  48→      // Start execution (it should track the process)\n  49→      const resultPromise = executeAiCli({\n  50→        sessionId: testSessionId,\n  51→        prompt: 'echo test'\n  52→      });\n  53→\n  54→      // Wait for completion\n  55→      await resultPromise;\n  56→\n  57→      // After completion, process should be cleared\n  58→      const processInfo = sessionStore.getActiveProcess(testSessionId);\n  59→      assert.equal(processInfo, null);\n  60→    });\n  61→\n  62→    test('should call onChunk callback for streaming output', async () => {\n  63→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  64→\n  65→      const chunks = [];\n  66→      const result = await executeAiCli({\n  67→        sessionId: testSessionId,\n  68→        prompt: 'echo hello world',\n  69→        hooks: {\n  70→          onChunk: (text) => { chunks.push(text); }\n  71→        }\n  72→      });\n  73→\n  74→      // Chunks should have been captured\n  75→      assert.ok(Array.isArray(chunks));\n  76→    });\n  77→\n  78→    test('should handle timeout correctly', async () => {\n  79→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  80→\n  81→      // Use a very short timeout\n  82→      const result = await executeAiCli({\n  83→        sessionId: testSessionId,\n  84→        prompt: 'sleep 5 && echo done',\n  85→        timeoutMs: 100  // Very short timeout\n  86→      });\n  87→\n  88→      assert.equal(result.timedOut, true);\n  89→    });\n  90→\n  91→    test('should handle abort signal', async () => {\n  92→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n  93→\n  94→      const controller = new AbortController();\n  95→\n  96→      // Start execution\n  97→      const resultPromise = executeAiCli({\n  98→        sessionId: testSessionId,\n  99→        prompt: 'sleep 10 && echo done',\n 100→        signal: controller.signal\n 101→      });\n 102→\n 103→      // Abort after a short delay\n 104→      setTimeout(() => controller.abort(), 100);\n 105→\n 106→      const result = await resultPromise;\n 107→      assert.equal(result.interrupted, true);\n 108→    });\n 109→\n 110→    test('should clean up process on completion', async () => {\n 111→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 112→      const { sessionStore } = await import('../../src/services/session-store.js');\n 113→\n 114→      await executeAiCli({\n 115→        sessionId: testSessionId,\n 116→        prompt: 'echo test'\n 117→      });\n 118→\n 119→      const processInfo = sessionStore.getActiveProcess(testSessionId);\n 120→      assert.equal(processInfo, null);\n 121→    });\n 122→\n 123→    test('should call onHeartbeat callback during long execution', async () => {\n 124→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 125→\n 126→      const heartbeats = [];\n 127→      const result = await executeAiCli({\n 128→        sessionId: testSessionId,\n 129→        prompt: 'sleep 1 && echo done',\n 130→        hooks: {\n 131→          onHeartbeat: (info) => { heartbeats.push(info); }\n 132→        },\n 133→        heartbeatThresholdMs: 10,\n 134→        heartbeatIntervalMs: 100\n 135→      });\n 136→\n 137→      // Heartbeats should have been captured\n 138→      assert.ok(Array.isArray(heartbeats));\n 139→    });\n 140→  });\n 141→\n 142→  describe('interruptAiCli', () => {\n 143→    test('should export interruptAiCli function', async () => {\n 144→      const { interruptAiCli } = await import('../../src/services/ai-cli-service.js');\n 145→      assert.ok(typeof interruptAiCli === 'function');\n 146→    });\n 147→\n 148→    test('should return error if no process running', async () => {\n 149→      const { interruptAiCli } = await import('../../src/services/ai-cli-service.js');\n 150→\n 151→      const result = interruptAiCli('non-existent-session');\n 152→\n 153→      assert.equal(result.ok, false);\n 154→      assert.ok(result.error);\n 155→    });\n 156→\n 157→    test('should clear session store after interrupt', async () => {\n 158→      const { executeAiCli, interruptAiCli } = await import('../../src/services/ai-cli-service.js');\n 159→      const { sessionStore } = await import('../../src/services/session-store.js');\n 160→\n 161→      // Start a long-running execution\n 162→      const execPromise = executeAiCli({\n 163→        sessionId: testSessionId,\n 164→        prompt: 'sleep 10 && echo done',\n 165→        timeoutMs: 20000  // Long timeout\n 166→      });\n 167→\n 168→      // Wait a bit for the process to start\n 169→      await new Promise(resolve => setTimeout(resolve, 200));\n 170→\n 171→      // Verify process is tracked\n 172→      const processInfo = sessionStore.getActiveProcess(testSessionId);\n 173→      assert.ok(processInfo, 'Process should be tracked');\n 174→\n 175→      // Interrupt\n 176→      const result = interruptAiCli(testSessionId);\n 177→      assert.equal(result.ok, true);\n 178→\n 179→      // Wait for execution to complete\n 180→      const execResult = await execPromise;\n 181→      assert.equal(execResult.interrupted, true);\n 182→    });\n 183→  });\n 184→\n 185→  describe('isAiCliRunning', () => {\n 186→    test('should export isAiCliRunning function', async () => {\n 187→      const { isAiCliRunning } = await import('../../src/services/ai-cli-service.js');\n 188→      assert.ok(typeof isAiCliRunning === 'function');\n 189→    });\n 190→\n 191→    test('should return false when no process running', async () => {\n 192→      const { isAiCliRunning } = await import('../../src/services/ai-cli-service.js');\n 193→\n 194→      const running = isAiCliRunning('non-existent-session');\n 195→      assert.equal(running, false);\n 196→    });\n 197→  });\n 198→\n 199→  describe('getActiveProcessInfo', () => {\n 200→    test('should export getActiveProcessInfo function', async () => {\n 201→      const { getActiveProcessInfo } = await import('../../src/services/ai-cli-service.js');\n 202→      assert.ok(typeof getActiveProcessInfo === 'function');\n 203→    });\n 204→\n 205→    test('should return null when no process running', async () => {\n 206→      const { getActiveProcessInfo } = await import('../../src/services/ai-cli-service.js');\n 207→\n 208→      const info = getActiveProcessInfo('non-existent-session');\n 209→      assert.equal(info, null);\n 210→    });\n 211→  });\n 212→\n 213→  describe('Error Handling', () => {\n 214→    test('should return helpful error for process spawn failure', async () => {\n 215→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 216→\n 217→      const result = await executeAiCli({\n 218→        sessionId: testSessionId,\n 219→        prompt: 'test prompt',\n 220→        bin: 'non-existent-command-that-should-fail'\n 221→      });\n 222→\n 223→      assert.ok(result.output);\n 224→      assert.ok(result.output.includes('无法启动') || result.output.includes('error') || result.output.includes('失败'));\n 225→    });\n 226→\n 227→    test('should include suggestion on timeout', async () => {\n 228→      const { executeAiCli } = await import('../../src/services/ai-cli-service.js');\n 229→\n 230→      const result = await executeAiCli({\n 231→        sessionId: testSessionId,\n 232→        prompt: 'sleep 5',\n 233→        timeoutMs: 100\n 234→      });\n 235→\n 236→      assert.equal(result.timedOut, true);\n 237→      assert.ok(result.output);\n 238→    });\n 239→  });\n 240→});\n 241→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3b4f54dcd7b31cdb68e43e953ad","__timestamp":"2026-03-12T20:21:43.218Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"b59ccbca-e908-4db2-85b4-eef0d50bdd9c","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3b652bda33bebf376a58743cdbd","content":[{"type":"text","text":"   1→/**\n   2→ * Integration Tests for AI CLI Telegram Flow\n   3→ * F-011, T-039, T-040: Test full Telegram → AI CLI → output flow\n   4→ *\n   5→ * Tests cover:\n   6→ * - Normal execution flow with process tracking\n   7→ * - Multi-turn conversation with session context\n   8→ * - /stop interrupt functionality\n   9→ * - Error handling with recovery suggestions\n  10→ * - MarkdownV2 output formatting\n  11→ */\n  12→\n  13→import { describe, test, beforeEach, afterEach } from 'node:test';\n  14→import assert from 'node:assert/strict';\n  15→import { writeFile, mkdir, rm } from 'node:fs/promises';\n  16→import { join } from 'node:path';\n  17→import { tmpdir } from 'node:os';\n  18→\n  19→import { sessionStore } from '../../src/services/session-store.js';\n  20→import {\n  21→  executeAiCli,\n  22→  interruptAiCli,\n  23→  isAiCliRunning,\n  24→  getActiveProcessInfo,\n  25→  canInterruptAiCli,\n  26→  resetMetrics,\n  27→  getMetrics\n  28→} from '../../src/services/ai-cli-service.js';\n  29→import { convertToMarkdownV2, escapeMarkdownV2, formatCodeBlock } from '../../src/utils/markdown-v2-formatter.js';\n  30→\n  31→describe('F-011 AI CLI Telegram Flow Integration', () => {\n  32→  const testSessionId = 'test-telegram-session-001';\n  33→  const testUserId = '123456789';\n  34→  const adminUserId = '987654321';\n  35→\n  36→  beforeEach(() => {\n  37→    sessionStore.clear(testSessionId);\n  38→    resetMetrics();\n  39→  });\n  40→\n  41→  afterEach(() => {\n  42→    sessionStore.clear(testSessionId);\n  43→  });\n  44→\n  45→  describe('Normal Execution Flow (T-039)', () => {\n  46→    test('should execute AI CLI and return output', async () => {\n  47→      const chunks = [];\n  48→      const result = await executeAiCli({\n  49→        sessionId: testSessionId,\n  50→        prompt: 'hello',\n  51→        userId: testUserId,\n  52→        bin: 'echo',\n  53→        args: ['hello world'], // Custom args for echo\n  54→        timeoutMs: 5000,\n  55→        hooks: {\n  56→          onChunk: (text) => chunks.push(text)\n  57→        }\n  58→      });\n  59→\n  60→      assert.ok(result.output);\n  61→      assert.equal(result.timedOut, false);\n  62→      assert.equal(result.interrupted, false);\n  63→      assert.ok(result.elapsedMs >= 0);\n  64→      assert.equal(result.exitCode, 0);\n  65→\n  66→      // Check that chunks were received or output contains expected content\n  67→      assert.ok(chunks.length > 0 || result.output.includes('hello'));\n  68→    });\n  69→\n  70→    test('should track process during execution', async () => {\n  71→      // Start a long-running process\n  72→      const executionPromise = executeAiCli({\n  73→        sessionId: testSessionId,\n  74→        prompt: 'sleep',\n  75→        userId: testUserId,\n  76→        bin: 'sleep',\n  77→        args: ['0.5'], // Custom args for sleep\n  78→        timeoutMs: 10000\n  79→      });\n  80→\n  81→      // Give it a moment to start\n  82→      await new Promise((resolve) => setTimeout(resolve, 100));\n  83→\n  84→      // Check process is tracked\n  85→      const isRunning = isAiCliRunning(testSessionId);\n  86→      assert.equal(isRunning, true);\n  87→\n  88→      const processInfo = getActiveProcessInfo(testSessionId);\n  89→      assert.ok(processInfo);\n  90→      assert.ok(processInfo.pid);\n  91→      assert.ok(processInfo.startedAt);\n  92→      assert.equal(processInfo.userId, testUserId);\n  93→\n  94→      // Wait for completion\n  95→      await executionPromise;\n  96→\n  97→      // Check process is cleared\n  98→      assert.equal(isAiCliRunning(testSessionId), false);\n  99→    });\n 100→\n 101→    test('should handle concurrent execution attempts gracefully', async () => {\n 102→      // Start first execution\n 103→      const firstPromise = executeAiCli({\n 104→        sessionId: testSessionId,\n 105→        prompt: 'first',\n 106→        userId: testUserId,\n 107→        bin: 'sleep',\n 108→        args: ['0.3'],\n 109→        timeoutMs: 10000\n 110→      });\n 111→\n 112→      // Give it time to start\n 113→      await new Promise((resolve) => setTimeout(resolve, 50));\n 114→\n 115→      // Verify process is running\n 116→      assert.equal(isAiCliRunning(testSessionId), true);\n 117→\n 118→      // Wait for completion\n 119→      await firstPromise;\n 120→\n 121→      // Now start second\n 122→      const secondResult = await executeAiCli({\n 123→        sessionId: testSessionId,\n 124→        prompt: 'second',\n 125→        userId: testUserId,\n 126→        bin: 'echo',\n 127→        args: ['done'],\n 128→        timeoutMs: 5000\n 129→      });\n 130→\n 131→      assert.ok(secondResult.output);\n 132→      assert.equal(secondResult.interrupted, false);\n 133→    });\n 134→  });\n 135→\n 136→  describe('Multi-turn Conversation (T-039)', () => {\n 137→    test('should clear session after reset', async () => {\n 138→      // First message\n 139→      await executeAiCli({\n 140→        sessionId: testSessionId,\n 141→        prompt: 'first message',\n 142→        userId: testUserId,\n 143→        bin: 'echo',\n 144→        args: ['first response'],\n 145→        timeoutMs: 5000\n 146→      });\n 147→\n 148→      // Session should be trackable\n 149→      const processInfo = getActiveProcessInfo(testSessionId);\n 150→      assert.equal(processInfo, null); // Process should be cleared after execution\n 151→\n 152→      // Clear session manually\n 153→      sessionStore.clear(testSessionId);\n 154→\n 155→      // Verify cleared\n 156→      const messages = sessionStore.get(testSessionId);\n 157→      assert.equal(messages.length, 0);\n 158→    });\n 159→\n 160→    test('should handle sequential executions', async () => {\n 161→      // Execute first\n 162→      const result1 = await executeAiCli({\n 163→        sessionId: testSessionId,\n 164→        prompt: 'first',\n 165→        userId: testUserId,\n 166→        bin: 'echo',\n 167→        args: ['response1'],\n 168→        timeoutMs: 5000\n 169→      });\n 170→      assert.ok(result1.output);\n 171→\n 172→      // Execute second\n 173→      const result2 = await executeAiCli({\n 174→        sessionId: testSessionId,\n 175→        prompt: 'second',\n 176→        userId: testUserId,\n 177→        bin: 'echo',\n 178→        args: ['response2'],\n 179→        timeoutMs: 5000\n 180→      });\n 181→      assert.ok(result2.output);\n 182→\n 183→      // Execute third\n 184→      const result3 = await executeAiCli({\n 185→        sessionId: testSessionId,\n 186→        prompt: 'third',\n 187→        userId: testUserId,\n 188→        bin: 'echo',\n 189→        args: ['response3'],\n 190→        timeoutMs: 5000\n 191→      });\n 192→      assert.ok(result3.output);\n 193→    });\n 194→  });\n 195→\n 196→  describe('Stop Interrupt (T-039)', () => {\n 197→    test('should interrupt running process via /stop', async () => {\n 198→      // Start a long-running process\n 199→      const executionPromise = executeAiCli({\n 200→        sessionId: testSessionId,\n 201→        prompt: 'long-task',\n 202→        userId: testUserId,\n 203→        bin: 'sleep',\n 204→        args: ['10'], // Sleep for 10 seconds\n 205→        timeoutMs: 30000\n 206→      });\n 207→\n 208→      // Give it a moment to start\n 209→      await new Promise((resolve) => setTimeout(resolve, 100));\n 210→\n 211→      // Verify process is running\n 212→      assert.equal(isAiCliRunning(testSessionId), true);\n 213→\n 214→      // Interrupt\n 215→      const interruptResult = interruptAiCli(testSessionId);\n 216→      assert.equal(interruptResult.ok, true);\n 217→      assert.ok(interruptResult.pid);\n 218→\n 219→      // Wait for execution to complete\n 220→      const result = await executionPromise;\n 221→\n 222→      // Should be marked as interrupted\n 223→      assert.equal(result.interrupted, true);\n 224→    });\n 225→\n 226→    test('should return error when no process to interrupt', () => {\n 227→      const result = interruptAiCli('non-existent-session');\n 228→      assert.equal(result.ok, false);\n 229→      assert.ok(result.error);\n 230→    });\n 231→  });\n 232→\n 233→  describe('Error Handling (T-039)', () => {\n 234→    test('should handle process spawn failure gracefully', async () => {\n 235→      const result = await executeAiCli({\n 236→        sessionId: testSessionId,\n 237→        prompt: 'test',\n 238→        userId: testUserId,\n 239→        bin: '/nonexistent/binary/that/does/not/exist',\n 240→        args: [],\n 241→        timeoutMs: 5000\n 242→      });\n 243→\n 244→      assert.ok(result.output.includes('无法启动') || result.output.includes('error') || result.output.includes('失败'));\n 245→      assert.equal(result.timedOut, false);\n 246→      assert.equal(result.interrupted, false);\n 247→    });\n 248→\n 249→    test('should handle non-zero exit code', async () => {\n 250→      const result = await executeAiCli({\n 251→        sessionId: testSessionId,\n 252→        prompt: 'fail',\n 253→        userId: testUserId,\n 254→        bin: 'sh',\n 255→        args: ['-c', 'exit 1'], // Run a command that exits with code 1\n 256→        timeoutMs: 5000\n 257→      });\n 258→\n 259→      assert.equal(result.exitCode, 1);\n 260→      assert.ok(result.output);\n 261→    });\n 262→\n 263→    test('should handle timeout with suggestion', async () => {\n 264→      const result = await executeAiCli({\n 265→        sessionId: testSessionId,\n 266→        prompt: 'slow',\n 267→        userId: testUserId,\n 268→        bin: 'sleep',\n 269→        args: ['5'],\n 270→        timeoutMs: 100 // Very short timeout\n 271→      });\n 272→\n 273→      assert.equal(result.timedOut, true);\n 274→      assert.ok(result.output);\n 275→      // Should include suggestion about /stop or timeout config\n 276→      assert.ok(\n 277→        result.output.includes('超时') ||\n 278→        result.output.includes('timeout') ||\n 279→        result.output.includes('/stop') ||\n 280→        result.output.includes('TIMEOUT')\n 281→      );\n 282→    });\n 283→  });\n 284→\n 285→  describe('Permission Checks (T-033)', () => {\n 286→    test('should allow task owner to interrupt', () => {\n 287→      // Simulate a running task\n 288→      sessionStore.setActiveProcess(testSessionId, {\n 289→        pid: 12345,\n 290→        startedAt: Date.now(),\n 291→        childProcess: { kill: () => {} },\n 292→        userId: testUserId\n 293→      });\n 294→\n 295→      const check = canInterruptAiCli(testSessionId, testUserId, () => false);\n 296→      assert.equal(check.canInterrupt, true);\n 297→    });\n 298→\n 299→    test('should allow admin to interrupt', () => {\n 300→      // Simulate a running task owned by another user\n 301→      sessionStore.setActiveProcess(testSessionId, {\n 302→        pid: 12345,\n 303→        startedAt: Date.now(),\n 304→        childProcess: { kill: () => {} },\n 305→        userId: 'other-user-id'\n 306→      });\n 307→\n 308→      const check = canInterruptAiCli(testSessionId, adminUserId, (id) => String(id) === adminUserId);\n 309→      assert.equal(check.canInterrupt, true);\n 310→    });\n 311→\n 312→    test('should deny non-owner non-admin interrupt', () => {\n 313→      // Simulate a running task owned by another user\n 314→      sessionStore.setActiveProcess(testSessionId, {\n 315→        pid: 12345,\n 316→        startedAt: Date.now(),\n 317→        childProcess: { kill: () => {} },\n 318→        userId: testUserId\n 319→      });\n 320→\n 321→      const check = canInterruptAiCli(testSessionId, 'another-user-id', () => false);\n 322→      assert.equal(check.canInterrupt, false);\n 323→      assert.ok(check.reason.includes('权限不足'));\n 324→    });\n 325→\n 326→    test('should deny interrupt when no process running', () => {\n 327→      const check = canInterruptAiCli(testSessionId, testUserId, () => false);\n 328→      assert.equal(check.canInterrupt, false);\n 329→      assert.ok(check.reason);\n 330→    });\n 331→  });\n 332→\n 333→  describe('MarkdownV2 Output Formatting (T-040)', () => {\n 334→    test('should escape special characters in MarkdownV2', () => {\n 335→      const input = 'Hello *world* with _underscores_ and `code`!';\n 336→      const escaped = escapeMarkdownV2(input);\n 337→\n 338→      // All MarkdownV2 special chars should be escaped\n 339→      assert.ok(!escaped.includes('*') || escaped.includes('\\\\*'));\n 340→      assert.ok(!escaped.includes('_') || escaped.includes('\\\\_'));\n 341→      assert.ok(!escaped.includes('`') || escaped.includes('\\\\`'));\n 342→    });\n 343→\n 344→    test('should format code blocks correctly', () => {\n 345→      const code = 'const x = 1;';\n 346→      const formatted = formatCodeBlock(code, 'javascript');\n 347→\n 348→      assert.ok(formatted.startsWith('```'));\n 349→      assert.ok(formatted.endsWith('```'));\n 350→      assert.ok(formatted.includes('javascript'));\n 351→    });\n 352→\n 353→    test('should convert common markdown to MarkdownV2', () => {\n 354→      // Test with bold text - MarkdownV2 uses single * for bold\n 355→      const boldInput = 'This is **bold** text';\n 356→      const boldOutput = convertToMarkdownV2(boldInput);\n 357→      // The formatter converts **text** to *escaped_text* (single * for MarkdownV2 bold)\n 358→      assert.ok(boldOutput.includes('*'));\n 359→      assert.ok(boldOutput.includes('bold'));\n 360→\n 361→      // Test with code block\n 362→      const codeInput = '```\\ncode here\\n```';\n 363→      const codeOutput = convertToMarkdownV2(codeInput);\n 364→      assert.ok(codeOutput.includes('```'));\n 365→    });\n 366→\n 367→    test('should handle mixed formatting', () => {\n 368→      const mixed = 'Here is **bold**, _italic_, and `inline code`.';\n 369→      const formatted = convertToMarkdownV2(mixed);\n 370→\n 371→      // Should not throw and should produce valid output\n 372→      assert.ok(formatted);\n 373→      assert.ok(formatted.length > 0);\n 374→    });\n 375→\n 376→    test('should handle special Telegram characters', () => {\n 377→      const special = 'Price: $100 [link](http://example.com) {braces}';\n 378→      const formatted = convertToMarkdownV2(special);\n 379→\n 380→      // Should escape special chars\n 381→      assert.ok(formatted);\n 382→    });\n 383→  });\n 384→\n 385→  describe('Metrics (T-051)', () => {\n 386→    test('should track execution metrics', async () => {\n 387→      // Execute a simple command\n 388→      await executeAiCli({\n 389→        sessionId: testSessionId,\n 390→        prompt: 'hello',\n 391→        userId: testUserId,\n 392→        bin: 'echo',\n 393→        args: ['hello'],\n 394→        timeoutMs: 5000\n 395→      });\n 396→\n 397→      const metrics = getMetrics();\n 398→      assert.equal(metrics.totalExecutions, 1);\n 399→      assert.equal(metrics.successCount, 1);\n 400→      assert.ok(metrics.averageDurationMs >= 0);\n 401→    });\n 402→\n 403→    test('should track interrupt metrics', async () => {\n 404→      // Start and interrupt a process\n 405→      const execPromise = executeAiCli({\n 406→        sessionId: testSessionId,\n 407→        prompt: 'slow',\n 408→        userId: testUserId,\n 409→        bin: 'sleep',\n 410→        args: ['5'],\n 411→        timeoutMs: 30000\n 412→      });\n 413→\n 414→      await new Promise((resolve) => setTimeout(resolve, 50));\n 415→      interruptAiCli(testSessionId);\n 416→      await execPromise;\n 417→\n 418→      const metrics = getMetrics();\n 419→      assert.equal(metrics.totalExecutions, 1);\n 420→      assert.equal(metrics.interruptCount, 1);\n 421→    });\n 422→\n 423→    test('should track timeout metrics', async () => {\n 424→      // Run a command that times out\n 425→      await executeAiCli({\n 426→        sessionId: testSessionId,\n 427→        prompt: 'slow',\n 428→        userId: testUserId,\n 429→        bin: 'sleep',\n 430→        args: ['10'],\n 431→        timeoutMs: 50\n 432→      });\n 433→\n 434→      const metrics = getMetrics();\n 435→      assert.equal(metrics.totalExecutions, 1);\n 436→      assert.equal(metrics.timeoutCount, 1);\n 437→    });\n 438→  });\n 439→});\n 440→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3b4f54dcd7b31cdb68e43e953ad","__timestamp":"2026-03-12T20:21:43.229Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
