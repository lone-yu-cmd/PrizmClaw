{"type":"assistant","uuid":"20260313035808a612f7bc7db640a6","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"id":"20260313035808a612f7bc7db640a6","content":[{"type":"tool_use","id":"019ce3a0c84aa3ca5064b2cab65fabdb","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/ai-cli-service.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":71117,"output_tokens":41,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:58:11.476Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
{"type":"user","uuid":"418dbd29-75b2-40e2-8eae-a33c950e215e","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3a0c84aa3ca5064b2cab65fabdb","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: AI CLI Service\n   3→ *\n   4→ * Encapsulates AI CLI execution logic with process tracking,\n   5→ * heartbeat, and interrupt support.\n   6→ */\n   7→\n   8→import { spawn } from 'node:child_process';\n   9→import { config } from '../config.js';\n  10→import { logger } from '../utils/logger.js';\n  11→import { sessionStore } from './session-store.js';\n  12→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n  13→\n  14→/**\n  15→ * @typedef {Object} AiCliExecutionOptions\n  16→ * @property {string} sessionId - Session identifier\n  17→ * @property {string} prompt - User prompt/input\n  18→ * @property {Object} [hooks] - Callback hooks\n  19→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n  20→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n  21→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n  22→ * @property {AbortSignal} [signal] - Optional abort signal\n  23→ * @property {number} [timeoutMs] - Optional timeout override\n  24→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n  25→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n  26→ * @property {string} [bin] - Optional binary override (for testing)\n  27→ */\n  28→\n  29→/**\n  30→ * @typedef {Object} AiCliExecutionResult\n  31→ * @property {string} output - Final output text\n  32→ * @property {boolean} timedOut - Whether execution timed out\n  33→ * @property {boolean} interrupted - Whether execution was interrupted\n  34→ * @property {number} elapsedMs - Execution time in milliseconds\n  35→ * @property {number|null} exitCode - Process exit code (if completed)\n  36→ * @property {string} stderr - Error output if any\n  37→ */\n  38→\n  39→/**\n  40→ * @typedef {Object} HeartbeatInfo\n  41→ * @property {number} elapsedMs - Elapsed time in milliseconds\n  42→ * @property {number} stdoutBytes - Bytes received so far\n  43→ * @property {string} status - Current status ('running', 'streaming')\n  44→ */\n  45→\n  46→/**\n  47→ * Write text to echo output for debugging.\n  48→ * @param {string} tag - Tag for the output\n  49→ * @param {string} text - Text to write\n  50→ */\n  51→function writeEcho(tag, text) {\n  52→  const normalized = String(text ?? '');\n  53→  if (!normalized) {\n  54→    return;\n  55→  }\n  56→\n  57→  const lines = normalized.split(/\\r?\\n/);\n  58→  for (const line of lines) {\n  59→    if (!line) {\n  60→      continue;\n  61→    }\n  62→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  63→  }\n  64→}\n  65→\n  66→/**\n  67→ * Execute AI CLI with session context and process tracking.\n  68→ * @param {AiCliExecutionOptions} options\n  69→ * @returns {Promise<AiCliExecutionResult>}\n  70→ */\n  71→export async function executeAiCli(options) {\n  72→  const {\n  73→    sessionId,\n  74→    prompt,\n  75→    hooks = {},\n  76→    signal,\n  77→    timeoutMs,\n  78→    heartbeatThresholdMs,\n  79→    heartbeatIntervalMs,\n  80→    bin\n  81→  } = options;\n  82→\n  83→  const effectiveBin = bin || config.codebuddyBin;\n  84→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n  85→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n  86→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n  87→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n  88→\n  89→  const args = ['-p', prompt];\n  90→  if (config.codebuddyPermissionFlag) {\n  91→    args.push(config.codebuddyPermissionFlag);\n  92→  }\n  93→\n  94→  return new Promise((resolve) => {\n  95→    let stdout = '';\n  96→    let stderr = '';\n  97→    let stdoutBytes = 0;\n  98→    let interrupted = false;\n  99→    let timedOut = false;\n 100→    const startedAt = Date.now();\n 101→    const sessionKey = sessionId;\n 102→\n 103→    // Heartbeat manager\n 104→    const heartbeatManager = createHeartbeatManager();\n 105→\n 106→    // Spawn process\n 107→    let child;\n 108→    try {\n 109→      child = spawn(effectiveBin, args, {\n 110→        stdio: ['ignore', 'pipe', 'pipe']\n 111→      });\n 112→    } catch (err) {\n 113→      resolve({\n 114→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 115→        timedOut: false,\n 116→        interrupted: false,\n 117→        elapsedMs: Date.now() - startedAt,\n 118→        exitCode: null,\n 119→        stderr: ''\n 120→      });\n 121→      return;\n 122→    }\n 123→\n 124→    // Track process in session store\n 125→    sessionStore.setActiveProcess(sessionKey, {\n 126→      pid: child.pid,\n 127→      startedAt,\n 128→      childProcess: child,\n 129→      interrupted: false,\n 130→      timedOut: false\n 131→    });\n 132→\n 133→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n 134→\n 135→    // Handle process error\n 136→    child.on('error', (err) => {\n 137→      cleanup();\n 138→      resolve({\n 139→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n 140→        timedOut: false,\n 141→        interrupted: false,\n 142→        elapsedMs: Date.now() - startedAt,\n 143→        exitCode: null,\n 144→        stderr\n 145→      });\n 146→    });\n 147→\n 148→    // Handle stdout\n 149→    child.stdout.on('data', (chunk) => {\n 150→      const text = chunk.toString();\n 151→      stdout += text;\n 152→      stdoutBytes += Buffer.byteLength(text);\n 153→\n 154→      // Update session store byte count\n 155→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n 156→\n 157→      // Echo to console if enabled\n 158→      if (config.codebuddyEchoStdio) {\n 159→        writeEcho('stdout', text);\n 160→      }\n 161→\n 162→      // Call onChunk hook\n 163→      if (typeof hooks.onChunk === 'function') {\n 164→        hooks.onChunk(text);\n 165→      }\n 166→    });\n 167→\n 168→    // Handle stderr\n 169→    child.stderr.on('data', (chunk) => {\n 170→      const text = chunk.toString();\n 171→      stderr += text;\n 172→\n 173→      if (config.codebuddyEchoStdio) {\n 174→        writeEcho('stderr', text);\n 175→      }\n 176→    });\n 177→\n 178→    // Timeout handler\n 179→    const timeout = effectiveTimeoutMs > 0\n 180→      ? setTimeout(() => {\n 181→          timedOut = true;\n 182→          const info = sessionStore.getActiveProcess(sessionKey);\n 183→          if (info) {\n 184→            info.timedOut = true;\n 185→          }\n 186→          child.kill('SIGTERM');\n 187→\n 188→          // Schedule SIGKILL if process doesn't exit\n 189→          setTimeout(() => {\n 190→            if (sessionStore.getActiveProcess(sessionKey)) {\n 191→              child.kill('SIGKILL');\n 192→            }\n 193→          }, 5000);\n 194→        }, effectiveTimeoutMs)\n 195→      : null;\n 196→\n 197→    // Abort signal handler\n 198→    const onAbort = () => {\n 199→      interrupted = true;\n 200→      const info = sessionStore.getActiveProcess(sessionKey);\n 201→      if (info) {\n 202→        info.interrupted = true;\n 203→      }\n 204→      child.kill('SIGTERM');\n 205→\n 206→      // Schedule SIGKILL if process doesn't exit\n 207→      setTimeout(() => {\n 208→        if (sessionStore.getActiveProcess(sessionKey)) {\n 209→          child.kill('SIGKILL');\n 210→        }\n 211→      }, 5000);\n 212→    };\n 213→\n 214→    if (signal) {\n 215→      signal.addEventListener('abort', onAbort);\n 216→    }\n 217→\n 218→    // Heartbeat setup\n 219→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n 220→      heartbeatManager.start({\n 221→        callback: () => {\n 222→          const elapsedMs = Date.now() - startedAt;\n 223→          hooks.onHeartbeat({\n 224→            elapsedMs,\n 225→            stdoutBytes,\n 226→            status: 'running'\n 227→          });\n 228→        },\n 229→        intervalMs: effectiveHeartbeatIntervalMs,\n 230→        thresholdMs: effectiveHeartbeatThresholdMs\n 231→      });\n 232→    }\n 233→\n 234→    // Cleanup function\n 235→    function cleanup() {\n 236→      if (timeout) {\n 237→        clearTimeout(timeout);\n 238→      }\n 239→      heartbeatManager.stop();\n 240→      sessionStore.clearActiveProcess(sessionKey);\n 241→      if (signal) {\n 242→        signal.removeEventListener('abort', onAbort);\n 243→      }\n 244→    }\n 245→\n 246→    // Handle process close\n 247→    child.on('close', (code) => {\n 248→      const elapsedMs = Date.now() - startedAt;\n 249→\n 250→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n 251→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n 252→      if (storedInfo) {\n 253→        if (storedInfo.interrupted) {\n 254→          interrupted = true;\n 255→        }\n 256→        if (storedInfo.timedOut) {\n 257→          timedOut = true;\n 258→        }\n 259→      }\n 260→\n 261→      cleanup();\n 262→\n 263→      logger.info(\n 264→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n 265→        'AI CLI process closed'\n 266→      );\n 267→\n 268→      // Build output\n 269→      let output = stdout.trim();\n 270→\n 271→      if (interrupted) {\n 272→        output = output || '任务已被用户中断。';\n 273→      } else if (timedOut) {\n 274→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n 275→      } else if (code !== 0) {\n 276→        output = output || `AI CLI 退出码 ${code}。`;\n 277→        if (stderr.trim()) {\n 278→          output += `\\n错误信息:\\n${stderr.trim()}`;\n 279→        }\n 280→      }\n 281→\n 282→      resolve({\n 283→        output: output || 'AI CLI 未返回文本结果。',\n 284→        timedOut,\n 285→        interrupted,\n 286→        elapsedMs,\n 287→        exitCode: code,\n 288→        stderr: stderr.trim()\n 289→      });\n 290→    });\n 291→  });\n 292→}\n 293→\n 294→/**\n 295→ * Interrupt running AI CLI task for a session.\n 296→ * @param {string} sessionId - Session identifier\n 297→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n 298→ */\n 299→export function interruptAiCli(sessionId) {\n 300→  const processInfo = sessionStore.getActiveProcess(sessionId);\n 301→\n 302→  if (!processInfo) {\n 303→    return { ok: false, error: '没有正在执行的任务。' };\n 304→  }\n 305→\n 306→  const { pid, childProcess } = processInfo;\n 307→\n 308→  try {\n 309→    // Mark as interrupted so close handler knows\n 310→    processInfo.interrupted = true;\n 311→\n 312→    // Send SIGTERM first\n 313→    childProcess.kill('SIGTERM');\n 314→\n 315→    // Schedule SIGKILL as backup\n 316→    setTimeout(() => {\n 317→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n 318→      if (stillRunning) {\n 319→        try {\n 320→          childProcess.kill('SIGKILL');\n 321→        } catch {\n 322→          // Process already dead\n 323→        }\n 324→      }\n 325→    }, 5000);\n 326→\n 327→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n 328→\n 329→    return { ok: true, pid };\n 330→  } catch (err) {\n 331→    return { ok: false, error: `中断失败: ${err.message}` };\n 332→  }\n 333→}\n 334→\n 335→/**\n 336→ * Check if AI CLI is running for a session.\n 337→ * @param {string} sessionId\n 338→ * @returns {boolean}\n 339→ */\n 340→export function isAiCliRunning(sessionId) {\n 341→  return sessionStore.getActiveProcess(sessionId) !== null;\n 342→}\n 343→\n 344→/**\n 345→ * Get active process info for a session.\n 346→ * @param {string} sessionId\n 347→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number } | null}\n 348→ */\n 349→export function getActiveProcessInfo(sessionId) {\n 350→  const info = sessionStore.getActiveProcess(sessionId);\n 351→  if (!info) {\n 352→    return null;\n 353→  }\n 354→\n 355→  // Don't expose childProcess to external callers\n 356→  return {\n 357→    pid: info.pid,\n 358→    startedAt: info.startedAt,\n 359→    stdoutBytes: info.stdoutBytes ?? 0\n 360→  };\n 361→}\n 362→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce39f0778d4066459442ce7c1f5eb","__timestamp":"2026-03-12T19:58:11.484Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
