{"type":"user","uuid":"33af2eb3-e2fe-494d-9d8a-65cbad66b7f4","session_id":"6b971ac8-f58b-4539-b600-b41cd157b86c","message":{"content":[{"type":"tool_result","tool_use_id":"019ce38f8b16dd0173c1bfeb30a6ce6d","content":[{"type":"text","text":"   1→/**\n   2→ * F-011: MarkdownV2 Formatter for Telegram\n   3→ *\n   4→ * Telegram MarkdownV2 requires escaping specific characters.\n   5→ * This module provides utilities for converting common Markdown\n   6→ * to Telegram's MarkdownV2 format.\n   7→ *\n   8→ * Reference: https://core.telegram.org/bots/api#markdownv2-style\n   9→ */\n  10→\n  11→/**\n  12→ * Characters that need escaping in MarkdownV2.\n  13→ * All these characters must be escaped with a backslash.\n  14→ */\n  15→const ESCAPE_CHARS = ['_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!'];\n  16→\n  17→/**\n  18→ * Escape text for Telegram MarkdownV2 format.\n  19→ * In MarkdownV2, all special characters must be escaped.\n  20→ * @param {string} text - Text to escape\n  21→ * @returns {string} Escaped text\n  22→ */\n  23→export function escapeMarkdownV2(text) {\n  24→  if (!text) return '';\n  25→\n  26→  let result = text;\n  27→  for (const char of ESCAPE_CHARS) {\n  28→    result = result.split(char).join('\\\\' + char);\n  29→  }\n  30→  return result;\n  31→}\n  32→\n  33→/**\n  34→ * Escape text inside code blocks.\n  35→ * Inside code blocks, only ` and \\ need escaping.\n  36→ * @param {string} code - Code content\n  37→ * @returns {string} Escaped code\n  38→ */\n  39→function escapeCodeContent(code) {\n  40→  if (!code) return '';\n  41→  return code\n  42→    .split('\\\\').join('\\\\\\\\')\n  43→    .split('`').join('\\\\`');\n  44→}\n  45→\n  46→/**\n  47→ * Format code block for Telegram MarkdownV2.\n  48→ * @param {string} code - Code content\n  49→ * @param {string} [language=''] - Optional language identifier\n  50→ * @returns {string} Formatted code block\n  51→ */\n  52→export function formatCodeBlock(code, language = '') {\n  53→  const escapedCode = escapeCodeContent(code ?? '');\n  54→  return '```' + language + '\\n' + escapedCode + '\\n```';\n  55→}\n  56→\n  57→/**\n  58→ * Format inline code for Telegram MarkdownV2.\n  59→ * @param {string} code - Code content\n  60→ * @returns {string} Formatted inline code\n  61→ */\n  62→export function formatInlineCode(code) {\n  63→  const escapedCode = escapeCodeContent(code ?? '');\n  64→  return '`' + escapedCode + '`';\n  65→}\n  66→\n  67→/**\n  68→ * Convert common Markdown to Telegram MarkdownV2.\n  69→ * Handles: code blocks, inline code, bold, italic, links.\n  70→ * @param {string} markdown - Input markdown\n  71→ * @returns {string} MarkdownV2 formatted text\n  72→ */\n  73→export function convertToMarkdownV2(markdown) {\n  74→  if (!markdown) return '';\n  75→\n  76→  let result = markdown;\n  77→\n  78→  // Process code blocks first (to protect their content)\n  79→  const codeBlocks = [];\n  80→  result = result.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, (match, lang, code) => {\n  81→    const placeholder = `\\x00CODE_BLOCK_${codeBlocks.length}\\x00`;\n  82→    codeBlocks.push(formatCodeBlock(code, lang));\n  83→    return placeholder;\n  84→  });\n  85→\n  86→  // Process inline code\n  87→  const inlineCodes = [];\n  88→  result = result.replace(/`([^`]+)`/g, (match, code) => {\n  89→    const placeholder = `\\x00INLINE_CODE_${inlineCodes.length}\\x00`;\n  90→    inlineCodes.push(formatInlineCode(code));\n  91→    return placeholder;\n  92→  });\n  93→\n  94→  // Process links [text](url)\n  95→  const links = [];\n  96→  result = result.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/g, (match, text, url) => {\n  97→    const placeholder = `\\x00LINK_${links.length}\\x00`;\n  98→    // In MarkdownV2, escape the URL but keep the link format\n  99→    links.push(`[${escapeMarkdownV2(text)}](${escapeMarkdownV2(url)})`);\n 100→    return placeholder;\n 101→  });\n 102→\n 103→  // Process bold **text**\n 104→  result = result.replace(/\\*\\*([^*]+)\\*\\*/g, (match, text) => {\n 105→    return '*' + escapeMarkdownV2(text) + '*';\n 106→  });\n 107→\n 108→  // Process italic _text_\n 109→  result = result.replace(/_([^_]+)_/g, (match, text) => {\n 110→    return '_' + escapeMarkdownV2(text) + '_';\n 111→  });\n 112→\n 113→  // Escape remaining special characters\n 114→  result = escapeMarkdownV2(result);\n 115→\n 116→  // Restore protected content\n 117→  for (let i = 0; i < codeBlocks.length; i++) {\n 118→    result = result.split(`\\x00CODE_BLOCK_${i}\\x00`).join(codeBlocks[i]);\n 119→  }\n 120→  for (let i = 0; i < inlineCodes.length; i++) {\n 121→    result = result.split(`\\x00INLINE_CODE_${i}\\x00`).join(inlineCodes[i]);\n 122→  }\n 123→  for (let i = 0; i < links.length; i++) {\n 124→    result = result.split(`\\x00LINK_${i}\\x00`).join(links[i]);\n 125→  }\n 126→\n 127→  // Remove any remaining null placeholders (for safety)\n 128→  result = result.replace(/\\x00[^\\x00]+\\x00/g, '');\n 129→\n 130→  return result;\n 131→}\n 132→\n 133→/**\n 134→ * Split text into segments respecting code block boundaries.\n 135→ * Useful for splitting long messages without breaking code blocks.\n 136→ * @param {string} text - Text to split\n 137→ * @param {number} maxLength - Maximum length per segment (default 4000)\n 138→ * @returns {string[]} Array of segments\n 139→ */\n 140→export function splitRespectingCodeBlocks(text, maxLength = 4000) {\n 141→  if (!text) return [''];\n 142→  if (text.length <= maxLength) return [text];\n 143→\n 144→  const segments = [];\n 145→  let currentSegment = '';\n 146→\n 147→  // Split text into chunks: code blocks and non-code parts\n 148→  const parts = text.split(/(```[\\s\\S]*?```)/g);\n 149→\n 150→  for (const part of parts) {\n 151→    // If adding this part would exceed maxLength\n 152→    if (currentSegment.length + part.length > maxLength) {\n 153→      // If it's a code block, we need to keep it whole\n 154→      if (part.startsWith('```') && part.endsWith('```')) {\n 155→        // If current segment has content, push it\n 156→        if (currentSegment.trim()) {\n 157→          segments.push(currentSegment);\n 158→          currentSegment = '';\n 159→        }\n 160→        // Check if code block itself exceeds maxLength\n 161→        if (part.length > maxLength) {\n 162→          // We have to split it - but try at a reasonable point\n 163→          // For now, just push it as a single segment (Telegram will truncate)\n 164→          segments.push(part);\n 165→        } else {\n 166→          currentSegment = part;\n 167→        }\n 168→      } else {\n 169→        // Regular text - try to split at paragraph or newline\n 170→        const remaining = maxLength - currentSegment.length;\n 171→        if (remaining > 0) {\n 172→          // Take what we can from this part\n 173→          const chunk = part.slice(0, remaining);\n 174→          const breakPoint = Math.max(\n 175→            chunk.lastIndexOf('\\n\\n'),\n 176→            chunk.lastIndexOf('\\n'),\n 177→            chunk.lastIndexOf(' ')\n 178→          );\n 179→\n 180→          if (breakPoint > 0) {\n 181→            currentSegment += chunk.slice(0, breakPoint + 1);\n 182→            segments.push(currentSegment);\n 183→            currentSegment = part.slice(breakPoint + 1);\n 184→          } else {\n 185→            currentSegment += chunk;\n 186→            segments.push(currentSegment);\n 187→            currentSegment = part.slice(remaining);\n 188→          }\n 189→        } else {\n 190→          if (currentSegment.trim()) {\n 191→            segments.push(currentSegment);\n 192→          }\n 193→          currentSegment = part;\n 194→        }\n 195→\n 196→        // If current segment still exceeds, we need to keep splitting\n 197→        while (currentSegment.length > maxLength) {\n 198→          const chunk = currentSegment.slice(0, maxLength);\n 199→          const breakPoint = Math.max(\n 200→            chunk.lastIndexOf('\\n\\n'),\n 201→            chunk.lastIndexOf('\\n'),\n 202→            chunk.lastIndexOf(' ')\n 203→          );\n 204→\n 205→          if (breakPoint > 0) {\n 206→            segments.push(chunk.slice(0, breakPoint + 1));\n 207→            currentSegment = currentSegment.slice(breakPoint + 1);\n 208→          } else {\n 209→            segments.push(chunk);\n 210→            currentSegment = currentSegment.slice(maxLength);\n 211→          }\n 212→        }\n 213→      }\n 214→    } else {\n 215→      currentSegment += part;\n 216→    }\n 217→  }\n 218→\n 219→  if (currentSegment.trim()) {\n 220→    segments.push(currentSegment);\n 221→  }\n 222→\n 223→  return segments.length > 0 ? segments : [''];\n 224→}\n 225→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce38bdd117b44f51df57146b62d27","__timestamp":"2026-03-12T19:39:21.706Z","_requestId":"39750009e8f3457a8b44aaadfd2ecc82"}
