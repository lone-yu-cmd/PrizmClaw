t.ok(replies[0].includes('无效') || replies[0].includes('格式') || replies[0].includes('invalid'), 'Should indicate invalid format');\n 100→    });\n 101→\n 102→    test('should handle \"remove\" subcommand', async () => {\n 103→      // First add a rule\n 104→      const setCtx = {\n 105→        reply: (msg) => { replies.push(msg); },\n 106→        userId: 'test-user',\n 107→        sessionId: 'test-session',\n 108→        args: ['set', 'cpu>80']\n 109→      };\n 110→      await monitorHandler.handleMonitor(setCtx);\n 111→      replies = [];\n 112→\n 113→      // Then list to get the ID (or we test with non-existent)\n 114→      const handlerCtx = {\n 115→        reply: (msg) => { replies.push(msg); },\n 116→        userId: 'test-user',\n 117→        sessionId: 'test-session',\n 118→        args: ['remove', 'non-existent-id']\n 119→      };\n 120→\n 121→      await monitorHandler.handleMonitor(handlerCtx);\n 122→\n 123→      assert.ok(replies.length > 0, 'Should send a reply');\n 124→    });\n 125→\n 126→    test('should handle \"enable\" subcommand', async () => {\n 127→      const handlerCtx = {\n 128→        reply: (msg) => { replies.push(msg); },\n 129→        userId: 'test-user',\n 130→        sessionId: 'test-session',\n 131→        args: ['enable', 'non-existent-id']\n 132→      };\n 133→\n 134→      await monitorHandler.handleMonitor(handlerCtx);\n 135→\n 136→      assert.ok(replies.length > 0, 'Should send a reply');\n 137→    });\n 138→\n 139→    test('should handle \"disable\" subcommand', async () => {\n 140→      const handlerCtx = {\n 141→        reply: (msg) => { replies.push(msg); },\n 142→        userId: 'test-user',\n 143→        sessionId: 'test-session',\n 144→        args: ['disable', 'non-existent-id']\n 145→      };\n 146→\n 147→      await monitorHandler.handleMonitor(handlerCtx);\n 148→\n 149→      assert.ok(replies.length > 0, 'Should send a reply');\n 150→    });\n 151→  });\n 152→\n 153→  describe('parseSubcommand', () => {\n 154→    test('s