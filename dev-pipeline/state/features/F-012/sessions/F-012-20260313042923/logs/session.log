{"type":"user","uuid":"c5f5e381-60bc-4ac5-919a-a686e596afff","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc1bb7230aaac8a2c395031406","content":[{"type":"text","text":"   1→/**\n   2→ * System Monitor Service\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Provides system information, process management, and monitoring capabilities.\n   6→ */\n   7→\n   8→import os from 'node:os';\n   9→import { spawn } from 'node:child_process';\n  10→import { promisify } from 'node:util';\n  11→import { exec } from 'node:child_process';\n  12→\n  13→const execAsync = promisify(exec);\n  14→\n  15→/**\n  16→ * @typedef {Object} SystemInfo\n  17→ * @property {Object} cpu - CPU information\n  18→ * @property {number} cpu.usage - CPU usage percentage (0-100)\n  19→ * @property {number} cpu.cores - Number of CPU cores\n  20→ * @property {string} cpu.model - CPU model name\n  21→ * @property {Object} memory - Memory information\n  22→ * @property {number} memory.total - Total memory in bytes\n  23→ * @property {number} memory.free - Free memory in bytes\n  24→ * @property {number} memory.used - Used memory in bytes\n  25→ * @property {number} memory.usagePercent - Memory usage percentage\n  26→ * @property {Object} disk - Disk information\n  27→ * @property {number} disk.total - Total disk space in bytes\n  28→ * @property {number} disk.free - Free disk space in bytes\n  29→ * @property {number} disk.used - Used disk space in bytes\n  30→ * @property {number} disk.usagePercent - Disk usage percentage\n  31→ * @property {Object} network - Network information\n  32→ * @property {string[]} network.interfaces - Network interface names\n  33→ * @property {number} network.bytesReceived - Total bytes received\n  34→ * @property {number} network.bytesSent - Total bytes sent\n  35→ * @property {number} uptime - System uptime in seconds\n  36→ * @property {string} hostname - System hostname\n  37→ * @property {string} platform - Operating system platform\n  38→ */\n  39→\n  40→/**\n  41→ * @typedef {Object} ProcessInfo\n  42→ * @property {number} pid - Process ID\n  43→ * @property {string} name - Process name\n  44→ * @property {number} cpu - CPU usage percentage\n  45→ * @property {number} memory - Memory usage percentage\n  46→ * @property {number} memoryBytes - Memory usage in bytes\n  47→ * @property {string} user - User running the process\n  48→ * @property {string} command - Full command line\n  49→ */\n  50→\n  51→export class SystemMonitorService {\n  52→  constructor() {\n  53→    this.platform = process.platform;\n  54→    this._lastCpuInfo = null;\n  55→  }\n  56→\n  57→  /**\n  58→   * Get comprehensive system information\n  59→   * @returns {Promise<SystemInfo>}\n  60→   */\n  61→  async getSystemInfo() {\n  62→    const [cpuInfo, diskInfo] = await Promise.all([\n  63→      this._getCpuInfo(),\n  64→      this._getDiskInfo()\n  65→    ]);\n  66→\n  67→    const totalMem = os.totalmem();\n  68→    const freeMem = os.freemem();\n  69→    const usedMem = totalMem - freeMem;\n  70→\n  71→    return {\n  72→      cpu: cpuInfo,\n  73→      memory: {\n  74→        total: totalMem,\n  75→        free: freeMem,\n  76→        used: usedMem,\n  77→        usagePercent: totalMem > 0 ? (usedMem / totalMem) * 100 : 0\n  78→      },\n  79→      disk: diskInfo,\n  80→      network: this._getNetworkInfo(),\n  81→      uptime: os.uptime(),\n  82→      hostname: os.hostname(),\n  83→      platform: this.platform\n  84→    };\n  85→  }\n  86→\n  87→  /**\n  88→   * Get list of running processes\n  89→   * @param {Object} options - Query options\n  90→   * @param {string} [options.sortBy='cpu'] - Sort by 'cpu' or 'memory'\n  91→   * @param {string} [options.filter] - Filter by keyword\n  92→   * @param {number} [options.limit=20] - Maximum number of processes to return\n  93→   * @returns {Promise<ProcessInfo[]>}\n  94→   */\n  95→  async getProcessList(options = {}) {\n  96→    const { sortBy = 'cpu', filter, limit = 20 } = options;\n  97→\n  98→    let processes;\n  99→    try {\n 100→      processes = await this._getProcessListFromSystem();\n 101→    } catch (error) {\n 102→      // Return empty array if command fails\n 103→      return [];\n 104→    }\n 105→\n 106→    // Apply filter\n 107→    if (filter) {\n 108→      const keyword = filter.toLowerCase();\n 109→      processes = processes.filter(proc =>\n 110→        proc.name.toLowerCase().includes(keyword) ||\n 111→        proc.command.toLowerCase().includes(keyword) ||\n 112→        String(proc.pid).includes(keyword)\n 113→      );\n 114→    }\n 115→\n 116→    // Sort\n 117→    processes.sort((a, b) => {\n 118→      if (sortBy === 'memory') {\n 119→        return b.memory - a.memory;\n 120→      }\n 121→      return b.cpu - a.cpu;\n 122→    });\n 123→\n 124→    // Limit\n 125→    return processes.slice(0, limit);\n 126→  }\n 127→\n 128→  /**\n 129→   * Kill a process by PID\n 130→   * @param {number|string} pid - Process ID\n 131→   * @param {string} [signal='SIGTERM'] - Signal to send\n 132→   * @returns {Promise<{success: boolean, error?: string}>}\n 133→   */\n 134→  async killProcess(pid, signal = 'SIGTERM') {\n 135→    // Validate PID\n 136→    const numericPid = typeof pid === 'string' ? parseInt(pid, 10) : pid;\n 137→\n 138→    if (isNaN(numericPid) || numericPid <= 0) {\n 139→      return { success: false, error: 'Invalid PID: must be a positive number' };\n 140→    }\n 141→\n 142→    try {\n 143→      // Check if process exists first\n 144→      process.kill(numericPid, 0);\n 145→\n 146→      // Send the kill signal\n 147→      process.kill(numericPid, signal);\n 148→\n 149→      return { success: true };\n 150→    } catch (error) {\n 151→      const code = error.code;\n 152→      if (code === 'ESRCH') {\n 153→        return { success: false, error: `Process ${numericPid} not found` };\n 154→      }\n 155→      if (code === 'EPERM') {\n 156→        return { success: false, error: `Permission denied to kill process ${numericPid}` };\n 157→      }\n 158→      return { success: false, error: error.message || 'Unknown error' };\n 159→    }\n 160→  }\n 161→\n 162→  /**\n 163→   * Format bytes to human readable string\n 164→   * @param {number} bytes - Bytes\n 165→   * @returns {string}\n 166→   */\n 167→  formatBytes(bytes) {\n 168→    if (bytes === 0) return '0 B';\n 169→\n 170→    const units = ['B', 'KB', 'MB', 'GB', 'TB'];\n 171→    const k = 1024;\n 172→    const i = Math.floor(Math.log(bytes) / Math.log(k));\n 173→    const unit = units[Math.min(i, units.length - 1)];\n 174→\n 175→    return `${(bytes / Math.pow(k, i)).toFixed(1)} ${unit}`;\n 176→  }\n 177→\n 178→  /**\n 179→   * Format uptime to human readable string\n 180→   * @param {number} seconds - Uptime in seconds\n 181→   * @returns {string}\n 182→   */\n 183→  formatUptime(seconds) {\n 184→    const days = Math.floor(seconds / 86400);\n 185→    const hours = Math.floor((seconds % 86400) / 3600);\n 186→    const minutes = Math.floor((seconds % 3600) / 60);\n 187→    const secs = Math.floor(seconds % 60);\n 188→\n 189→    const parts = [];\n 190→    if (days > 0) parts.push(`${days}d`);\n 191→    if (hours > 0) parts.push(`${hours}h`);\n 192→    if (minutes > 0) parts.push(`${minutes}m`);\n 193→    if (secs > 0 || parts.length === 0) parts.push(`${secs}s`);\n 194→\n 195→    return parts.join(' ');\n 196→  }\n 197→\n 198→  /**\n 199→   * Get CPU information\n 200→   * @private\n 201→   * @returns {Promise<{usage: number, cores: number, model: string}>}\n 202→   */\n 203→  async _getCpuInfo() {\n 204→    const cpus = os.cpus();\n 205→    const cores = cpus.length;\n 206→    const model = cpus[0]?.model || 'Unknown';\n 207→\n 208→    // Calculate CPU usage\n 209→    let totalIdle = 0;\n 210→    let totalTick = 0;\n 211→\n 212→    for (const cpu of cpus) {\n 213→      for (const type in cpu.times) {\n 214→        totalTick += cpu.times[type];\n 215→      }\n 216→      totalIdle += cpu.times.idle;\n 217→    }\n 218→\n 219→    const usage = totalTick > 0 ? ((totalTick - totalIdle) / totalTick) * 100 : 0;\n 220→\n 221→    return {\n 222→      usage: Math.round(usage * 10) / 10,\n 223→      cores,\n 224→      model\n 225→    };\n 226→  }\n 227→\n 228→  /**\n 229→   * Get disk information\n 230→   * @private\n 231→   * @returns {Promise<{total: number, free: number, used: number, usagePercent: number}>}\n 232→   */\n 233→  async _getDiskInfo() {\n 234→    try {\n 235→      let stdout;\n 236→\n 237→      if (this.platform === 'win32') {\n 238→        // Windows: use wmic\n 239→        const result = await execAsync('wmic logicaldisk get size,freespace,caption /format:csv', {\n 240→          timeout: 5000\n 241→        });\n 242→        stdout = result.stdout;\n 243→        return this._parseWindowsDiskInfo(stdout);\n 244→      } else {\n 245→        // macOS/Linux: use df\n 246→        const result = await execAsync('df -k /', { timeout: 5000 });\n 247→        stdout = result.stdout;\n 248→        return this._parseUnixDiskInfo(stdout);\n 249→      }\n 250→    } catch (error) {\n 251→      // Return zeros if command fails\n 252→      return {\n 253→        total: 0,\n 254→        free: 0,\n 255→        used: 0,\n 256→        usagePercent: 0\n 257→      };\n 258→    }\n 259→  }\n 260→\n 261→  /**\n 262→   * Parse Unix df command output\n 263→   * @private\n 264→   */\n 265→  _parseUnixDiskInfo(output) {\n 266→    const lines = output.trim().split('\\n');\n 267→    if (lines.length < 2) {\n 268→      return { total: 0, free: 0, used: 0, usagePercent: 0 };\n 269→    }\n 270→\n 271→    const parts = lines[1].split(/\\s+/);\n 272→    if (parts.length < 4) {\n 273→      return { total: 0, free: 0, used: 0, usagePercent: 0 };\n 274→    }\n 275→\n 276→    const total = parseInt(parts[1], 10) * 1024; // Convert from KB to bytes\n 277→    const used = parseInt(parts[2], 10) * 1024;\n 278→    const free = parseInt(parts[3], 10) * 1024;\n 279→    const usagePercent = total > 0 ? (used / total) * 100 : 0;\n 280→\n 281→    return {\n 282→      total,\n 283→      free,\n 284→      used,\n 285→      usagePercent: Math.round(usagePercent * 10) / 10\n 286→    };\n 287→  }\n 288→\n 289→  /**\n 290→   * Parse Windows wmic output\n 291→   * @private\n 292→   */\n 293→  _parseWindowsDiskInfo(output) {\n 294→    // Default to system drive\n 295→    const lines = output.trim().split('\\n').filter(l => l.trim());\n 296→    let total = 0;\n 297→    let free = 0;\n 298→\n 299→    for (const line of lines) {\n 300→      const parts = line.split(',');\n 301→      if (parts.length >= 3 && parts[1]) {\n 302→        // Get the first drive (usually C:)\n 303→        free = parseInt(parts[1], 10) || 0;\n 304→        total = parseInt(parts[2], 10) || 0;\n 305→        break;\n 306→      }\n 307→    }\n 308→\n 309→    const used = total - free;\n 310→    const usagePercent = total > 0 ? (used / total) * 100 : 0;\n 311→\n 312→    return {\n 313→      total,\n 314→      free,\n 315→      used,\n 316→      usagePercent: Math.round(usagePercent * 10) / 10\n 317→    };\n 318→  }\n 319→\n 320→  /**\n 321→   * Get network information\n 322→   * @private\n 323→   */\n 324→  _getNetworkInfo() {\n 325→    const interfaces = os.networkInterfaces();\n 326→    const interfaceNames = Object.keys(interfaces).filter(name => name !== 'lo0' && name !== 'lo');\n 327→\n 328→    return {\n 329→      interfaces: interfaceNames,\n 330→      bytesReceived: 0, // Requires platform-specific commands\n 331→      bytesSent: 0\n 332→    };\n 333→  }\n 334→\n 335→  /**\n 336→   * Get process list from system\n 337→   * @private\n 338→   * @returns {Promise<ProcessInfo[]>}\n 339→   */\n 340→  async _getProcessListFromSystem() {\n 341→    try {\n 342→      let stdout;\n 343→\n 344→      if (this.platform === 'win32') {\n 345→        // Windows: use tasklist\n 346→        const result = await execAsync('tasklist /fo csv /nh', { timeout: 10000 });\n 347→        stdout = result.stdout;\n 348→        return this._parseWindowsProcessList(stdout);\n 349→      } else {\n 350→        // macOS/Linux: use ps\n 351→        const result = await execAsync('ps aux', { timeout: 10000 });\n 352→        stdout = result.stdout;\n 353→        return this._parseUnixProcessList(stdout);\n 354→      }\n 355→    } catch (error) {\n 356→      return [];\n 357→    }\n 358→  }\n 359→\n 360→  /**\n 361→   * Parse Unix ps aux output\n 362→   * @private\n 363→   */\n 364→  _parseUnixProcessList(output) {\n 365→    const lines = output.trim().split('\\n');\n 366→    const processes = [];\n 367→\n 368→    for (let i = 1; i < lines.length; i++) {\n 369→      const line = lines[i].trim();\n 370→      if (!line) continue;\n 371→\n 372→      // ps aux format: USER PID %CPU %MEM VSZ RSS TTY STAT START TIME COMMAND\n 373→      const parts = line.split(/\\s+/);\n 374→      if (parts.length < 11) continue;\n 375→\n 376→      const user = parts[0];\n 377→      const pid = parseInt(parts[1], 10);\n 378→      const cpu = parseFloat(parts[2]) || 0;\n 379→      const memory = parseFloat(parts[3]) || 0;\n 380→      const command = parts.slice(10).join(' ');\n 381→\n 382→      // Extract process name from command\n 383→      const name = parts[10].split('/')[0].split(' ')[0];\n 384→\n 385→      if (!isNaN(pid)) {\n 386→        processes.push({\n 387→          pid,\n 388→          name,\n 389→          cpu: Math.round(cpu * 10) / 10,\n 390→          memory: Math.round(memory * 10) / 10,\n 391→          memoryBytes: 0, // Would need RSS * 1024\n 392→          user,\n 393→          command\n 394→        });\n 395→      }\n 396→    }\n 397→\n 398→    return processes;\n 399→  }\n 400→\n 401→  /**\n 402→   * Parse Windows tasklist output\n 403→   * @private\n 404→   */\n 405→  _parseWindowsProcessList(output) {\n 406→    const lines = output.trim().split('\\n');\n 407→    const processes = [];\n 408→\n 409→    for (const line of lines) {\n 410→      if (!line.trim()) continue;\n 411→\n 412→      // CSV format: \"Image Name\",\"PID\",\"Session Name\",\"Session#\",\"Mem Usage\"\n 413→      const match = line.match(/\"([^\"]+)\",\"(\\d+)\",\"([^\"]+)\",\"(\\d+)\",\"([^\"]+)\"/);\n 414→      if (!match) continue;\n 415→\n 416→      const name = match[1];\n 417→      const pid = parseInt(match[2], 10);\n 418→      const memUsageStr = match[5].replace(/[^\\d]/g, '');\n 419→      const memoryBytes = parseInt(memUsageStr, 10) * 1024; // Convert KB to bytes\n 420→\n 421→      if (!isNaN(pid)) {\n 422→        processes.push({\n 423→          pid,\n 424→          name,\n 425→          cpu: 0, // Windows tasklist doesn't show CPU\n 426→          memory: 0, // Would need calculation\n 427→          memoryBytes,\n 428→          user: 'N/A',\n 429→          command: name\n 430→        });\n 431→      }\n 432→    }\n 433→\n 434→    return processes;\n 435→  }\n 436→}\n 437→\n 438→// Export singleton instance for convenience\n 439→export const systemMonitorService = new SystemMonitorService();\n 440→\n 441→export default SystemMonitorService;\n 442→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:33.330Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"39a598f2-a216-4ecb-a9d6-55167ecff623","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc1d7b1742d25a4f5f09a202f5","content":[{"type":"text","text":"   1→/**\n   2→ * Alert Manager Service\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Manages alert rules, threshold monitoring, and notifications.\n   6→ */\n   7→\n   8→import { randomUUID } from 'node:crypto';\n   9→import { mkdir, readFile, writeFile } from 'node:fs/promises';\n  10→import { join } from 'node:path';\n  11→import { config } from '../config.js';\n  12→\n  13→/**\n  14→ * @typedef {Object} AlertRule\n  15→ * @property {string} id - Unique rule identifier\n  16→ * @property {'cpu'|'memory'|'disk'} metric - Metric to monitor\n  17→ * @property {'>'|'<'|'>='|'<='} operator - Comparison operator\n  18→ * @property {number} threshold - Threshold value (0-100)\n  19→ * @property {boolean} enabled - Whether rule is active\n  20→ * @property {number} createdAt - Creation timestamp\n  21→ * @property {number} [lastTriggered] - Last triggered timestamp\n  22→ */\n  23→\n  24→/**\n  25→ * @typedef {Object} AlertStatus\n  26→ * @property {string} ruleId - Rule that triggered\n  27→ * @property {string} metric - Metric name\n  28→ * @property {number} currentValue - Current metric value\n  29→ * @property {number} threshold - Configured threshold\n  30→ * @property {number} triggeredAt - Trigger timestamp\n  31→ */\n  32→\n  33→const VALID_METRICS = ['cpu', 'memory', 'disk'];\n  34→const VALID_OPERATORS = ['>', '<', '>=', '<='];\n  35→const DEFAULT_COOLDOWN_MS = 5 * 60 * 1000; // 5 minutes\n  36→\n  37→export class AlertManagerService {\n  38→  /**\n  39→   * @param {Object} options\n  40→   * @param {string} [options.dataDir] - Directory for persistence\n  41→   * @param {string} [options.rulesFile] - Rules file name\n  42→   * @param {number} [options.cooldownMs] - Cooldown period in ms\n  43→   */\n  44→  constructor(options = {}) {\n  45→    this.dataDir = options.dataDir || config.systemMonitorDataDir;\n  46→    this.rulesFile = options.rulesFile || 'alert-rules.json';\n  47→    this.cooldownMs = options.cooldownMs || DEFAULT_COOLDOWN_MS;\n  48→\n  49→    /** @type {Map<string, AlertRule>} */\n  50→    this.rules = new Map();\n  51→\n  52→    /** @type {Map<string, number>} - Last triggered time by rule ID */\n  53→    this.lastTriggered = new Map();\n  54→\n  55→    /** @type {NodeJS.Timeout|null} */\n  56→    this.monitorInterval = null;\n  57→\n  58→    /** @type {Function|null} */\n  59→    this.pushCallback = null;\n  60→  }\n  61→\n  62→  /**\n  63→   * Add a new alert rule\n  64→   * @param {Omit<AlertRule, 'id' | 'createdAt'>} ruleData\n  65→   * @returns {AlertRule}\n  66→   */\n  67→  addRule(ruleData) {\n  68→    this._validateRule(ruleData);\n  69→\n  70→    const id = randomUUID();\n  71→    const rule = {\n  72→      id,\n  73→      metric: ruleData.metric,\n  74→      operator: ruleData.operator,\n  75→      threshold: ruleData.threshold,\n  76→      enabled: ruleData.enabled ?? true,\n  77→      createdAt: Date.now()\n  78→    };\n  79→\n  80→    this.rules.set(id, rule);\n  81→    return { ...rule };\n  82→  }\n  83→\n  84→  /**\n  85→   * Remove a rule by ID\n  86→   * @param {string} ruleId\n  87→   * @returns {boolean}\n  88→   */\n  89→  removeRule(ruleId) {\n  90→    if (!this.rules.has(ruleId)) {\n  91→      return false;\n  92→    }\n  93→\n  94→    this.rules.delete(ruleId);\n  95→    this.lastTriggered.delete(ruleId);\n  96→    return true;\n  97→  }\n  98→\n  99→  /**\n 100→   * List all rules\n 101→   * @returns {AlertRule[]}\n 102→   */\n 103→  listRules() {\n 104→    return Array.from(this.rules.values()).map(rule => ({ ...rule }));\n 105→  }\n 106→\n 107→  /**\n 108→   * Enable a rule\n 109→   * @param {string} ruleId\n 110→   * @returns {boolean}\n 111→   */\n 112→  enableRule(ruleId) {\n 113→    const rule = this.rules.get(ruleId);\n 114→    if (!rule) {\n 115→      return false;\n 116→    }\n 117→\n 118→    rule.enabled = true;\n 119→    return true;\n 120→  }\n 121→\n 122→  /**\n 123→   * Disable a rule\n 124→   * @param {string} ruleId\n 125→   * @returns {boolean}\n 126→   */\n 127→  disableRule(ruleId) {\n 128→    const rule = this.rules.get(ruleId);\n 129→    if (!rule) {\n 130→      return false;\n 131→    }\n 132→\n 133→    rule.enabled = false;\n 134→    return true;\n 135→  }\n 136→\n 137→  /**\n 138→   * Check thresholds against current metrics\n 139→   * @param {Object} currentMetrics - System metrics\n 140→   * @returns {AlertStatus[]}\n 141→   */\n 142→  checkThresholds(currentMetrics) {\n 143→    const alerts = [];\n 144→    const now = Date.now();\n 145→\n 146→    for (const rule of this.rules.values()) {\n 147→      if (!rule.enabled) {\n 148→        continue;\n 149→      }\n 150→\n 151→      // Check cooldown\n 152→      const lastTrigger = this.lastTriggered.get(rule.id);\n 153→      if (lastTrigger && (now - lastTrigger) < this.cooldownMs) {\n 154→        continue;\n 155→      }\n 156→\n 157→      const currentValue = this._getMetricValue(currentMetrics, rule.metric);\n 158→      if (currentValue === undefined) {\n 159→        continue;\n 160→      }\n 161→\n 162→      if (this._evaluateThreshold(currentValue, rule.operator, rule.threshold)) {\n 163→        this.lastTriggered.set(rule.id, now);\n 164→\n 165→        // Update lastTriggered on rule\n 166→        rule.lastTriggered = now;\n 167→\n 168→        alerts.push({\n 169→          ruleId: rule.id,\n 170→          metric: rule.metric,\n 171→          currentValue,\n 172→          threshold: rule.threshold,\n 173→          triggeredAt: now\n 174→        });\n 175→      }\n 176→    }\n 177→\n 178→    return alerts;\n 179→  }\n 180→\n 181→  /**\n 182→   * Start monitoring loop\n 183→   * @param {Function} pushCallback - Callback for alert notifications\n 184→   * @param {number} [intervalMs] - Check interval (default from config)\n 185→   */\n 186→  startMonitoring(pushCallback, intervalMs) {\n 187→    if (this.monitorInterval) {\n 188→      throw new Error('Monitoring is already running');\n 189→    }\n 190→\n 191→    this.pushCallback = pushCallback;\n 192→    const interval = intervalMs || config.systemMonitorIntervalMs;\n 193→\n 194→    this.monitorInterval = setInterval(async () => {\n 195→      try {\n 196→        // Import here to avoid circular dependency\n 197→        const { systemMonitorService } = await import('./system-monitor-service.js');\n 198→        const metrics = await systemMonitorService.getSystemInfo();\n 199→        const alerts = this.checkThresholds(metrics);\n 200→\n 201→        for (const alert of alerts) {\n 202→          if (this.pushCallback) {\n 203→            this.pushCallback(alert);\n 204→          }\n 205→        }\n 206→      } catch (error) {\n 207→        // Log error but don't stop monitoring\n 208→        console.error('Alert monitoring error:', error);\n 209→      }\n 210→    }, interval);\n 211→  }\n 212→\n 213→  /**\n 214→   * Stop monitoring loop\n 215→   */\n 216→  stopMonitoring() {\n 217→    if (this.monitorInterval) {\n 218→      clearInterval(this.monitorInterval);\n 219→      this.monitorInterval = null;\n 220→    }\n 221→    this.pushCallback = null;\n 222→  }\n 223→\n 224→  /**\n 225→   * Load rules from persistent storage\n 226→   */\n 227→  async loadRules() {\n 228→    try {\n 229→      const filePath = join(this.dataDir, this.rulesFile);\n 230→      const content = await readFile(filePath, 'utf-8');\n 231→      const rules = JSON.parse(content);\n 232→\n 233→      this.rules.clear();\n 234→      for (const rule of rules) {\n 235→        if (rule.id && rule.metric) {\n 236→          this.rules.set(rule.id, rule);\n 237→        }\n 238→      }\n 239→    } catch (error) {\n 240→      // File doesn't exist or is corrupted - start fresh\n 241→      this.rules.clear();\n 242→    }\n 243→  }\n 244→\n 245→  /**\n 246→   * Save rules to persistent storage\n 247→   */\n 248→  async saveRules() {\n 249→    try {\n 250→      // Ensure directory exists\n 251→      await mkdir(this.dataDir, { recursive: true });\n 252→\n 253→      const filePath = join(this.dataDir, this.rulesFile);\n 254→      const rules = Array.from(this.rules.values());\n 255→      await writeFile(filePath, JSON.stringify(rules, null, 2), 'utf-8');\n 256→    } catch (error) {\n 257→      throw new Error(`Failed to save alert rules: ${error.message}`);\n 258→    }\n 259→  }\n 260→\n 261→  /**\n 262→   * Parse rule string like \"cpu>80\"\n 263→   * @param {string} ruleString\n 264→   * @returns {{metric: string, operator: string, threshold: number}}\n 265→   */\n 266→  parseRuleString(ruleString) {\n 267→    // Match patterns like \"cpu>80\", \"memory>=90\", \"disk<10\"\n 268→    const match = ruleString.match(/^(cpu|memory|disk)(>|<|>=|<=)(\\d+)$/i);\n 269→\n 270→    if (!match) {\n 271→      throw new Error(`Invalid rule format: ${ruleString}. Expected format: cpu>80, memory>=90, disk<10`);\n 272→    }\n 273→\n 274→    const metric = match[1].toLowerCase();\n 275→    const operator = match[2];\n 276→    const threshold = parseInt(match[3], 10);\n 277→\n 278→    if (threshold < 0 || threshold > 100) {\n 279→      throw new Error('Threshold must be between 0 and 100');\n 280→    }\n 281→\n 282→    return { metric, operator, threshold };\n 283→  }\n 284→\n 285→  /**\n 286→   * Validate rule data\n 287→   * @private\n 288→   */\n 289→  _validateRule(ruleData) {\n 290→    if (!VALID_METRICS.includes(ruleData.metric)) {\n 291→      throw new Error(`Invalid metric: ${ruleData.metric}. Must be one of: ${VALID_METRICS.join(', ')}`);\n 292→    }\n 293→\n 294→    if (!VALID_OPERATORS.includes(ruleData.operator)) {\n 295→      throw new Error(`Invalid operator: ${ruleData.operator}. Must be one of: ${VALID_OPERATORS.join(', ')}`);\n 296→    }\n 297→\n 298→    const threshold = Number(ruleData.threshold);\n 299→    if (isNaN(threshold) || threshold < 0 || threshold > 100) {\n 300→      throw new Error('Threshold must be a number between 0 and 100');\n 301→    }\n 302→  }\n 303→\n 304→  /**\n 305→   * Get metric value from system info\n 306→   * @private\n 307→   */\n 308→  _getMetricValue(metrics, metricName) {\n 309→    switch (metricName) {\n 310→      case 'cpu':\n 311→        return metrics.cpu?.usage;\n 312→      case 'memory':\n 313→        return metrics.memory?.usagePercent;\n 314→      case 'disk':\n 315→        return metrics.disk?.usagePercent;\n 316→      default:\n 317→        return undefined;\n 318→    }\n 319→  }\n 320→\n 321→  /**\n 322→   * Evaluate threshold condition\n 323→   * @private\n 324→   */\n 325→  _evaluateThreshold(currentValue, operator, threshold) {\n 326→    switch (operator) {\n 327→      case '>':\n 328→        return currentValue > threshold;\n 329→      case '<':\n 330→        return currentValue < threshold;\n 331→      case '>=':\n 332→        return currentValue >= threshold;\n 333→      case '<=':\n 334→        return currentValue <= threshold;\n 335→      default:\n 336→        return false;\n 337→    }\n 338→  }\n 339→}\n 340→\n 341→// Export singleton instance for convenience\n 342→export const alertManagerService = new AlertManagerService();\n 343→\n 344→export default AlertManagerService;\n 345→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:33.330Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"647a8817-856e-45df-99d6-46d95921ff28","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc1f235e6e7b7cbf2560547e2d","content":[{"type":"text","text":"   1→/**\n   2→ * /sysinfo Command Handler\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Returns system overview including CPU, memory, disk, and network status.\n   6→ */\n   7→\n   8→import { systemMonitorService } from '../../../services/system-monitor-service.js';\n   9→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  10→\n  11→export const sysinfoMeta = {\n  12→  name: 'sysinfo',\n  13→  aliases: ['si'],\n  14→  description: '查看系统状态概览（CPU、内存、磁盘、网络）',\n  15→  usage: '/sysinfo',\n  16→  examples: ['/sysinfo'],\n  17→  params: [],\n  18→  requiresAuth: true,\n  19→  minRole: 'viewer',\n  20→  helpText: '/sysinfo - 查看系统状态概览（CPU、内存、磁盘、网络）'\n  21→};\n  22→\n  23→/**\n  24→ * Handle /sysinfo command\n  25→ * @param {Object} handlerCtx - Handler context\n  26→ */\n  27→export async function handleSysinfo(handlerCtx) {\n  28→  const { reply } = handlerCtx;\n  29→\n  30→  try {\n  31→    const info = await systemMonitorService.getSystemInfo();\n  32→\n  33→    // Format as table\n  34→    const lines = [\n  35→      '📊 *系统状态概览*',\n  36→      '',\n  37→      `🖥️ *主机*: ${escapeMarkdownV2(info.hostname)}`,\n  38→      `⏱️ *运行时间*: ${systemMonitorService.formatUptime(info.uptime)}`,\n  39→      `💻 *平台*: ${escapeMarkdownV2(info.platform)}`,\n  40→      '',\n  41→      '*CPU*',\n  42→      `├ 型号: ${escapeMarkdownV2(info.cpu.model)}`,\n  43→      `├ 核心数: ${info.cpu.cores}`,\n  44→      `└ 使用率: ${info.cpu.usage.toFixed(1)}%`,\n  45→      '',\n  46→      '*内存*',\n  47→      `├ 总量: ${systemMonitorService.formatBytes(info.memory.total)}`,\n  48→      `├ 已用: ${systemMonitorService.formatBytes(info.memory.used)}`,\n  49→      `├ 空闲: ${systemMonitorService.formatBytes(info.memory.free)}`,\n  50→      `└ 使用率: ${info.memory.usagePercent.toFixed(1)}%`,\n  51→      '',\n  52→      '*磁盘*',\n  53→      `├ 总量: ${systemMonitorService.formatBytes(info.disk.total)}`,\n  54→      `├ 已用: ${systemMonitorService.formatBytes(info.disk.used)}`,\n  55→      `├ 空闲: ${systemMonitorService.formatBytes(info.disk.free)}`,\n  56→      `└ 使用率: ${info.disk.usagePercent.toFixed(1)}%`,\n  57→      '',\n  58→      '*网络*',\n  59→      `└ 接口: ${info.network.interfaces.join(', ') || 'N/A'}`\n  60→    ];\n  61→\n  62→    await reply(lines.join('\\n'));\n  63→  } catch (error) {\n  64→    const message = error instanceof Error ? error.message : String(error);\n  65→    await reply(`❌ 获取系统信息失败: ${escapeMarkdownV2(message)}`);\n  66→  }\n  67→}\n  68→\n  69→export default {\n  70→  sysinfoMeta,\n  71→  handleSysinfo\n  72→};\n  73→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:33.331Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"3c386f9b-0dc7-414e-b50b-b483cf43422e","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc211f732f0f05866374672f43","content":[{"type":"text","text":"   1→/**\n   2→ * /ps Command Handler\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Returns process list with sorting and filtering options.\n   6→ */\n   7→\n   8→import { systemMonitorService } from '../../../services/system-monitor-service.js';\n   9→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  10→\n  11→export const psMeta = {\n  12→  name: 'ps',\n  13→  aliases: [],\n  14→  description: '查看进程列表（支持排序和过滤）',\n  15→  usage: '/ps [--sort=cpu|memory] [--limit=N] [filter]',\n  16→  examples: ['/ps', '/ps --sort=memory', '/ps node', '/ps --sort=cpu --limit=10'],\n  17→  params: [],\n  18→  requiresAuth: true,\n  19→  minRole: 'viewer',\n  20→  helpText: '/ps [选项] [关键词] - 查看进程列表\\n选项:\\n  --sort=cpu|memory  按CPU或内存排序\\n  --limit=N          限制显示数量'\n  21→};\n  22→\n  23→const DEFAULT_LIMIT = 20;\n  24→\n  25→/**\n  26→ * Parse command arguments into options\n  27→ * @param {string[]} args\n  28→ * @returns {{sortBy: string, limit: number, filter: string}}\n  29→ */\n  30→export function parseOptions(args) {\n  31→  let sortBy = 'cpu';\n  32→  let limit = DEFAULT_LIMIT;\n  33→  const filterParts = [];\n  34→\n  35→  for (const arg of args) {\n  36→    if (arg.startsWith('--sort=')) {\n  37→      const value = arg.slice(7).toLowerCase();\n  38→      if (['cpu', 'memory'].includes(value)) {\n  39→        sortBy = value;\n  40→      }\n  41→    } else if (arg.startsWith('--limit=')) {\n  42→      const value = parseInt(arg.slice(8), 10);\n  43→      if (!isNaN(value) && value > 0 && value <= 100) {\n  44→        limit = value;\n  45→      }\n  46→    } else {\n  47→      filterParts.push(arg);\n  48→    }\n  49→  }\n  50→\n  51→  return {\n  52→    sortBy,\n  53→    limit,\n  54→    filter: filterParts.join(' ')\n  55→  };\n  56→}\n  57→\n  58→/**\n  59→ * Handle /ps command\n  60→ * @param {Object} handlerCtx - Handler context\n  61→ */\n  62→export async function handlePs(handlerCtx) {\n  63→  const { reply, args = [] } = handlerCtx;\n  64→\n  65→  try {\n  66→    const options = parseOptions(args);\n  67→    const processes = await systemMonitorService.getProcessList(options);\n  68→\n  69→    if (processes.length === 0) {\n  70→      if (options.filter) {\n  71→        await reply(`🔍 未找到匹配 \"${escapeMarkdownV2(options.filter)}\" 的进程。`);\n  72→      } else {\n  73→        await reply('📋 未找到任何进程。');\n  74→      }\n  75→      return;\n  76→    }\n  77→\n  78→    // Format as table\n  79→    const lines = [\n  80→      `📋 *进程列表* ${options.filter ? `\\(过滤: \"${escapeMarkdownV2(options.filter)}\")` : ''}`,\n  81→      `排序: ${options.sortBy === 'cpu' ? 'CPU' : '内存'} | 显示: ${processes.length}`,\n  82→      '',\n  83→      '```\\nPID      CPU%   MEM%   NAME',\n  84→      '-'.repeat(40)\n  85→    ];\n  86→\n  87→    for (const proc of processes) {\n  88→      const pid = String(proc.pid).padEnd(8);\n  89→      const cpu = `${proc.cpu.toFixed(1)}%`.padEnd(6);\n  90→      const mem = `${proc.memory.toFixed(1)}%`.padEnd(6);\n  91→      const name = proc.name.substring(0, 20);\n  92→      lines.push(`${pid}${cpu}${mem}${name}`);\n  93→    }\n  94→\n  95→    lines.push('```');\n  96→\n  97→    await reply(lines.join('\\n'));\n  98→  } catch (error) {\n  99→    const message = error instanceof Error ? error.message : String(error);\n 100→    await reply(`❌ 获取进程列表失败: ${escapeMarkdownV2(message)}`);\n 101→  }\n 102→}\n 103→\n 104→export default {\n 105→  psMeta,\n 106→  handlePs,\n 107→  parseOptions\n 108→};\n 109→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:33.332Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"ed873b65-3c06-464e-abaa-3c9ce02e2635","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc2303b8503c59750286b88766","content":[{"type":"text","text":"   1→/**\n   2→ * /kill Command Handler\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Terminates a process by PID. Requires admin permission and confirmation.\n   6→ */\n   7→\n   8→import { systemMonitorService } from '../../../services/system-monitor-service.js';\n   9→import { createConfirmation } from '../../../security/confirmation-manager.js';\n  10→import { logAuditEntry } from '../../../services/audit-log-service.js';\n  11→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  12→\n  13→export const killMeta = {\n  14→  name: 'kill',\n  15→  aliases: [],\n  16→  description: '终止指定进程（需要管理员权限和确认）',\n  17→  usage: '/kill <PID>',\n  18→  examples: ['/kill 12345'],\n  19→  params: [],\n  20→  requiresAuth: true,\n  21→  minRole: 'admin',\n  22→  helpText: '/kill <PID> - 终止指定进程（需要管理员权限）'\n  23→};\n  24→\n  25→/**\n  26→ * Parse PID from argument\n  27→ * @param {string} arg\n  28→ * @returns {number|null}\n  29→ */\n  30→export function parsePid(arg) {\n  31→  if (!arg) return null;\n  32→\n  33→  const pid = parseInt(arg, 10);\n  34→\n  35→  if (isNaN(pid) || pid <= 0) {\n  36→    return null;\n  37→  }\n  38→\n  39→  return pid;\n  40→}\n  41→\n  42→/**\n  43→ * Handle /kill command\n  44→ * @param {Object} handlerCtx - Handler context\n  45→ */\n  46→export async function handleKill(handlerCtx) {\n  47→  const { reply, args = [], userId, sessionId, confirmationId, skipConfirmation } = handlerCtx;\n  48→\n  49→  // Parse PID from arguments\n  50→  const pidArg = args[0];\n  51→  const pid = parsePid(pidArg);\n  52→\n  53→  if (!pid) {\n  54→    await reply('❌ 请提供有效的 PID。用法: /kill <PID>');\n  55→    return;\n  56→  }\n  57→\n  58→  // If confirmation ID provided, this is a confirmation callback\n  59→  if (confirmationId && skipConfirmation) {\n  60→    await executeKill(pid, userId, reply);\n  61→    return;\n  62→  }\n  63→\n  64→  // Request confirmation\n  65→  const { confirmId, message } = createConfirmation(\n  66→    userId,\n  67→    'kill',\n  68→    { pid },\n  69→    60000 // 60 second timeout\n  70→  );\n  71→\n  72→  await reply([\n  73→    `⚠️ *确认终止进程*`,\n  74→    '',\n  75→    `PID: ${pid}`,\n  76→    '',\n  77→    message,\n  78→    '',\n  79→    `确认 ID: \\`${confirmId}\\``\n  80→  ].join('\\n'));\n  81→}\n  82→\n  83→/**\n  84→ * Execute the kill operation\n  85→ * @param {number} pid\n  86→ * @param {string|number} userId\n  87→ * @param {Function} reply\n  88→ */\n  89→async function executeKill(pid, userId, reply) {\n  90→  try {\n  91→    const result = await systemMonitorService.killProcess(pid);\n  92→\n  93→    if (result.success) {\n  94→      // Log audit entry\n  95→      await logAuditEntry({\n  96→        timestamp: new Date().toISOString(),\n  97→        action: 'kill',\n  98→        userId: String(userId),\n  99→        params: { pid },\n 100→        result: 'success'\n 101→      });\n 102→\n 103→      await reply(`✅ 进程 ${pid} 已终止。`);\n 104→    } else {\n 105→      await reply(`❌ 终止进程 ${pid} 失败: ${escapeMarkdownV2(result.error)}`);\n 106→    }\n 107→  } catch (error) {\n 108→    const message = error instanceof Error ? error.message : String(error);\n 109→    await reply(`❌ 终止进程 ${pid} 失败: ${escapeMarkdownV2(message)}`);\n 110→  }\n 111→}\n 112→\n 113→export default {\n 114→  killMeta,\n 115→  handleKill,\n 116→  parsePid\n 117→};\n 118→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:33.332Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"d0fce9eb-f0d6-41de-a820-c990e8f75333","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc24e69d6cdb960bd5a947c6ae","content":[{"type":"text","text":"   1→/**\n   2→ * /monitor Command Handler\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Manages alert rules for system monitoring.\n   6→ */\n   7→\n   8→import { alertManagerService } from '../../../services/alert-manager-service.js';\n   9→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  10→\n  11→export const monitorMeta = {\n  12→  name: 'monitor',\n  13→  aliases: [],\n  14→  description: '管理系统监控告警规则',\n  15→  usage: '/monitor <set|list|remove|enable|disable> [参数]',\n  16→  examples: [\n  17→    '/monitor set cpu>80',\n  18→    '/monitor set memory>=90',\n  19→    '/monitor list',\n  20→    '/monitor remove <规则ID>',\n  21→    '/monitor enable <规则ID>',\n  22→    '/monitor disable <规则ID>'\n  23→  ],\n  24→  params: [],\n  25→  requiresAuth: true,\n  26→  minRole: 'operator',\n  27→  helpText: '/monitor <子命令> [参数]\\n' +\n  28→    '子命令:\\n' +\n  29→    '  set <规则>      添加告警规则 (如 cpu>80, memory>=90)\\n' +\n  30→    '  list           列出所有告警规则\\n' +\n  31→    '  remove <ID>    删除规则\\n' +\n  32→    '  enable <ID>    启用规则\\n' +\n  33→    '  disable <ID>   禁用规则'\n  34→};\n  35→\n  36→/**\n  37→ * Parse subcommand from arguments\n  38→ * @param {string[]} args\n  39→ * @returns {{subcommand: string, arg?: string}}\n  40→ */\n  41→export function parseSubcommand(args) {\n  42→  if (!args || args.length === 0) {\n  43→    return { subcommand: '' };\n  44→  }\n  45→\n  46→  const subcommand = args[0].toLowerCase();\n  47→  const arg = args.slice(1).join(' ');\n  48→\n  49→  return { subcommand, arg };\n  50→}\n  51→\n  52→/**\n  53→ * Handle /monitor command\n  54→ * @param {Object} handlerCtx - Handler context\n  55→ */\n  56→export async function handleMonitor(handlerCtx) {\n  57→  const { reply, args = [] } = handlerCtx;\n  58→\n  59→  const { subcommand, arg } = parseSubcommand(args);\n  60→\n  61→  switch (subcommand) {\n  62→    case 'set':\n  63→      await handleSet(arg, reply);\n  64→      break;\n  65→    case 'list':\n  66→      await handleList(reply);\n  67→      break;\n  68→    case 'remove':\n  69→      await handleRemove(arg, reply);\n  70→      break;\n  71→    case 'enable':\n  72→      await handleToggle(arg, true, reply);\n  73→      break;\n  74→    case 'disable':\n  75→      await handleToggle(arg, false, reply);\n  76→      break;\n  77→    default:\n  78→      await reply([\n  79→        '📋 *监控告警命令用法*',\n  80→        '',\n  81→        '```',\n  82→        '/monitor set <规则>    添加告警规则',\n  83→        '/monitor list          列出所有规则',\n  84→        '/monitor remove <ID>   删除规则',\n  85→        '/monitor enable <ID>   启用规则',\n  86→        '/monitor disable <ID>  禁用规则',\n  87→        '```',\n  88→        '',\n  89→        '规则格式: <指标><操作符><阈值>',\n  90→        '指标: cpu, memory, disk',\n  91→        '操作符: >, <, >=, <=',\n  92→        '示例: cpu>80, memory>=90, disk<10'\n  93→      ].join('\\n'));\n  94→  }\n  95→}\n  96→\n  97→/**\n  98→ * Handle set subcommand\n  99→ * @param {string} ruleString\n 100→ * @param {Function} reply\n 101→ */\n 102→async function handleSet(ruleString, reply) {\n 103→  if (!ruleString) {\n 104→    await reply('❌ 请提供规则。用法: /monitor set cpu>80');\n 105→    return;\n 106→  }\n 107→\n 108→  try {\n 109→    const ruleData = alertManagerService.parseRuleString(ruleString);\n 110→    const rule = alertManagerService.addRule({\n 111→      ...ruleData,\n 112→      enabled: true\n 113→    });\n 114→\n 115→    // Save rules\n 116→    await alertManagerService.saveRules();\n 117→\n 118→    await reply([\n 119→      '✅ *告警规则已添加*',\n 120→      '',\n 121→      `ID: \\`${rule.id}\\``,\n 122→      `规则: ${rule.metric}${rule.operator}${rule.threshold}`,\n 123→      `状态: 启用`\n 124→    ].join('\\n'));\n 125→  } catch (error) {\n 126→    const message = error instanceof Error ? error.message : String(error);\n 127→    await reply(`❌ 添加规则失败: ${escapeMarkdownV2(message)}`);\n 128→  }\n 129→}\n 130→\n 131→/**\n 132→ * Handle list subcommand\n 133→ * @param {Function} reply\n 134→ */\n 135→async function handleList(reply) {\n 136→  const rules = alertManagerService.listRules();\n 137→\n 138→  if (rules.length === 0) {\n 139→    await reply('📋 当前没有配置任何告警规则。');\n 140→    return;\n 141→  }\n 142→\n 143→  const lines = [\n 144→    `📋 *告警规则列表* (${rules.length})`,\n 145→    ''\n 146→  ];\n 147→\n 148→  for (const rule of rules) {\n 149→    const status = rule.enabled ? '✅' : '⏸️';\n 150→    const lastTriggered = rule.lastTriggered\n 151→      ? new Date(rule.lastTriggered).toLocaleString()\n 152→      : '从未';\n 153→    lines.push(`${status} \\`${rule.id}\\``);\n 154→    lines.push(`   规则: ${rule.metric}${rule.operator}${rule.threshold}`);\n 155→    lines.push(`   最近触发: ${lastTriggered}`);\n 156→  }\n 157→\n 158→  await reply(lines.join('\\n'));\n 159→}\n 160→\n 161→/**\n 162→ * Handle remove subcommand\n 163→ * @param {string} ruleId\n 164→ * @param {Function} reply\n 165→ */\n 166→async function handleRemove(ruleId, reply) {\n 167→  if (!ruleId) {\n 168→    await reply('❌ 请提供规则 ID。用法: /monitor remove <规则ID>');\n 169→    return;\n 170→  }\n 171→\n 172→  const removed = alertManagerService.removeRule(ruleId.trim());\n 173→\n 174→  if (removed) {\n 175→    await alertManagerService.saveRules();\n 176→    await reply(`✅ 规则 \\`${ruleId}\\` 已删除。`);\n 177→  } else {\n 178→    await reply(`❌ 规则 \\`${ruleId}\\` 不存在。`);\n 179→  }\n 180→}\n 181→\n 182→/**\n 183→ * Handle enable/disable subcommand\n 184→ * @param {string} ruleId\n 185→ * @param {boolean} enable\n 186→ * @param {Function} reply\n 187→ */\n 188→async function handleToggle(ruleId, enable, reply) {\n 189→  if (!ruleId) {\n 190→    await reply(`❌ 请提供规则 ID。用法: /monitor ${enable ? 'enable' : 'disable'} <规则ID>`);\n 191→    return;\n 192→  }\n 193→\n 194→  const success = enable\n 195→    ? alertManagerService.enableRule(ruleId.trim())\n 196→    : alertManagerService.disableRule(ruleId.trim());\n 197→\n 198→  if (success) {\n 199→    await alertManagerService.saveRules();\n 200→    await reply(`✅ 规则 \\`${ruleId}\\` 已${enable ? '启用' : '禁用'}。`);\n 201→  } else {\n 202→    await reply(`❌ 规则 \\`${ruleId}\\` 不存在。`);\n 203→  }\n 204→}\n 205→\n 206→export default {\n 207→  monitorMeta,\n 208→  handleMonitor,\n 209→  parseSubcommand\n 210→};\n 211→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:33.332Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
