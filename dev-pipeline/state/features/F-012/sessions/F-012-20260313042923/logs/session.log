ion CPU');\n  47→      assert.ok(reply.includes('内存') || reply.includes('Memory') || reply.includes('memory'), 'Should mention memory');\n  48→    });\n  49→\n  50→    test('should format output with structured sections', async () => {\n  51→      const handlerCtx = {\n  52→        reply: (msg) => { replies.push(msg); },\n  53→        userId: 'test-user',\n  54→        sessionId: 'test-session',\n  55→        args: []\n  56→      };\n  57→\n  58→      await sysinfoHandler.handleSysinfo(handlerCtx);\n  59→\n  60→      const reply = replies[0];\n  61→      // Should have structured output with tree-like indicators (├ └)\n  62→      assert.ok(reply.includes('├') || reply.includes('└'), 'Should have tree-style formatting');\n  63→    });\n  64→\n  65→    test('should include hostname', async () => {\n  66→      const handlerCtx = {\n  67→        reply: (msg) => { replies.push(msg); },\n  68→        userId: 'test-user',\n  69→        sessionId: 'test-session',\n  70→        args: []\n  71→      };\n  72→\n  73→      await sysinfoHandler.handleSysinfo(handlerCtx);\n  74→\n  75→      const reply = replies[0];\n  76→      assert.ok(reply.includes('主机') || reply.includes('Hostname') || reply.includes('hostname'), 'Should include hostname');\n  77→    });\n  78→\n  79→    test('should include uptime', async () => {\n  80→      const handlerCtx = {\n  81→        reply: (msg) => { replies.push(msg); },\n  82→        userId: 'test-user',\n  83→        sessionId: 'test-session',\n  84→        args: []\n  85→      };\n  86→\n  87→      await sysinfoHandler.handleSysinfo(handlerCtx);\n  88→\n  89→      const reply = replies[0];\n  90→      assert.ok(reply.includes('运行时间') || reply.includes('Uptime') || reply.includes('uptime'), 'Should include uptime');\n  91→    });\n  92→  });\n  93→});\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:54.469Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
