{"type":"user","uuid":"dc635681-113c-4e1e-8178-02ad871490ff","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc2e65d075f0e2d3b1ce0535c3","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20),\n  43→  // F-011: AI CLI Proxy\n  44→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n  45→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n  46→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true'),\n  47→  // F-012: System Monitor\n  48→  SYSTEM_MONITOR_INTERVAL_MS: z.coerce.number().int().positive().default(60000),\n  49→  SYSTEM_MONITOR_DATA_DIR: z.string().optional().default('data')\n  50→});\n  51→\n  52→const parsed = schema.parse(process.env);\n  53→\n  54→function parseAllowedUserIds(input) {\n  55→  return new Set(\n  56→    input\n  57→      .split(',')\n  58→      .map((id) => id.trim())\n  59→      .filter(Boolean)\n  60→  );\n  61→}\n  62→\n  63→function parseCsvList(input) {\n  64→  return input\n  65→    .split(',')\n  66→    .map((item) => item.trim())\n  67→    .filter(Boolean);\n  68→}\n  69→\n  70→function parseBoolean(input) {\n  71→  const normalized = (input ?? '').trim().toLowerCase();\n  72→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  73→}\n  74→\n  75→/**\n  76→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  77→ * Format: \"123456789:admin,987654321:operator\"\n  78→ * @param {string} input\n  79→ * @returns {Map<string, string>}\n  80→ */\n  81→function parseUserPermissions(input) {\n  82→  const permissions = new Map();\n  83→  if (!input || !input.trim()) {\n  84→    return permissions;\n  85→  }\n  86→\n  87→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  88→  for (const entry of entries) {\n  89→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  90→    if (userId && role) {\n  91→      const normalizedRole = role.toLowerCase();\n  92→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  93→        permissions.set(userId, normalizedRole);\n  94→      }\n  95→    }\n  96→  }\n  97→  return permissions;\n  98→}\n  99→\n 100→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n 101→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n 102→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 103→}\n 104→\n 105→const pipelineInfra = loadPipelineInfraConfig({\n 106→  env: process.env,\n 107→  argv: process.argv.slice(2),\n 108→  cwd: process.cwd()\n 109→});\n 110→\n 111→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 112→\n 113→export const config = Object.freeze({\n 114→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 115→  enableTelegram,\n 116→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 117→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 118→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 119→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 120→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 121→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 122→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 123→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 124→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 125→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 126→  webHost: parsed.WEB_HOST,\n 127→  webPort: parsed.WEB_PORT,\n 128→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 129→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 130→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 131→  logLevel: parsed.LOG_LEVEL,\n 132→  // F-006: Safety and Permission Guard\n 133→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 134→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 135→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 136→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 137→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 138→  // F-009: General Command Executor\n 139→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 140→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 141→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 142→  // F-010: File Manager\n 143→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 144→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 145→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 146→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 147→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 148→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 149→  // F-011: AI CLI Proxy\n 150→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 151→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 152→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 153→  // F-012: System Monitor\n 154→  systemMonitorIntervalMs: parsed.SYSTEM_MONITOR_INTERVAL_MS,\n 155→  systemMonitorDataDir: parsed.SYSTEM_MONITOR_DATA_DIR,\n 156→  pipelineInfra: Object.freeze({\n 157→    ...pipelineInfra,\n 158→    daemonLogPaths\n 159→  })\n 160→});\n 161→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:36.302Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"aab011c4-2090-4ca8-9a55-dd98170a02fa","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc2fabb4bc226966f14553361b","content":[{"type":"text","text":"   1→/**\n   2→ * Permission Guard Module\n   3→ * F-006: Safety and Permission Guard\n   4→ *\n   5→ * Provides user permission tiers and command authorization checking.\n   6→ */\n   7→\n   8→import { config } from '../config.js';\n   9→\n  10→/**\n  11→ * Role hierarchy levels (higher = more permissions)\n  12→ */\n  13→export const ROLE_HIERARCHY = {\n  14→  viewer: 0,\n  15→  operator: 1,\n  16→  admin: 2\n  17→};\n  18→\n  19→/**\n  20→ * Minimum required role for each command\n  21→ */\n  22→const COMMAND_MIN_ROLE = {\n  23→  status: 'viewer',\n  24→  logs: 'viewer',\n  25→  commits: 'viewer',\n  26→  // F-009: cd and more commands\n  27→  cd: 'operator',\n  28→  more: 'viewer',\n  29→  // F-010: File Manager commands\n  30→  ls: 'viewer',\n  31→  tree: 'viewer',\n  32→  cat: 'viewer',\n  33→  head: 'viewer',\n  34→  tail: 'viewer',\n  35→  find: 'viewer',\n  36→  upload: 'operator',\n  37→  download: 'operator',\n  38→  // F-012: System Monitor commands\n  39→  sysinfo: 'viewer',\n  40→  ps: 'viewer',\n  41→  monitor: 'operator',\n  42→  kill: 'admin',\n  43→  pipeline: 'operator',\n  44→  bugfix: 'operator',\n  45→  planner: 'operator',\n  46→  retry: 'operator',\n  47→  commit: 'operator',\n  48→  stop: 'admin',\n  49→  reset: 'admin',\n  50→  'force-unlock': 'admin',\n  51→  exec: 'admin',\n  52→  'commit-amend': 'admin',\n  53→  'commit-force': 'admin'\n  54→};\n  55→\n  56→/**\n  57→ * High-risk commands that require confirmation\n  58→ */\n  59→const HIGH_RISK_COMMANDS = new Set(['stop', 'reset', 'force-unlock', 'commit-amend', 'commit-force', 'kill']);\n  60→\n  61→/**\n  62→ * Internal config reference - can be overridden for testing\n  63→ * @type {Object}\n  64→ */\n  65→let _config = config;\n  66→\n  67→/**\n  68→ * Set config for testing purposes\n  69→ * @param {Object} testConfig\n  70→ */\n  71→export function setConfigForTesting(testConfig) {\n  72→  _config = testConfig;\n  73→}\n  74→\n  75→/**\n  76→ * Reset config to original (for testing cleanup)\n  77→ */\n  78→export function resetConfig() {\n  79→  _config = config;\n  80→}\n  81→\n  82→/**\n  83→ * Get user permission level\n  84→ * @param {string|number} userId - Telegram user ID\n  85→ * @returns {'admin'|'operator'|'viewer'}\n  86→ */\n  87→export function getUserRole(userId) {\n  88→  const userIdStr = String(userId);\n  89→  const configuredRole = _config.userPermissions.get(userIdStr);\n  90→\n  91→  if (configuredRole) {\n  92→    return configuredRole;\n  93→  }\n  94→\n  95→  // Default to operator for unknown users (AC-1.3)\n  96→  return 'operator';\n  97→}\n  98→\n  99→/**\n 100→ * Check if user is admin\n 101→ * @param {string|number} userId\n 102→ * @returns {boolean}\n 103→ */\n 104→export function isAdmin(userId) {\n 105→  return getUserRole(userId) === 'admin';\n 106→}\n 107→\n 108→/**\n 109→ * Check if user can execute command\n 110→ * @param {string|number} userId\n 111→ * @param {string} command - Command name\n 112→ * @returns {{ allowed: boolean, requiresConfirmation: boolean, reason?: string }}\n 113→ */\n 114→export function checkCommandPermission(userId, command) {\n 115→  const userRole = getUserRole(userId);\n 116→  const minRole = COMMAND_MIN_ROLE[command] || 'viewer';\n 117→\n 118→  // Special handling for exec command (AC-2.4, F-002)\n 119→  if (command === 'exec' && !_config.enableSystemExec) {\n 120→    return {\n 121→      allowed: false,\n 122→      requiresConfirmation: false,\n 123→      reason: '系统命令执行未启用。请在 .env 中设置 ENABLE_SYSTEM_EXEC=true。'\n 124→    };\n 125→  }\n 126→\n 127→  // Check role hierarchy\n 128→  const userLevel = ROLE_HIERARCHY[userRole];\n 129→  const requiredLevel = ROLE_HIERARCHY[minRole];\n 130→\n 131→  if (userLevel < requiredLevel) {\n 132→    return {\n 133→      allowed: false,\n 134→      requiresConfirmation: false,\n 135→      reason: `权限不足。此命令需要 ${minRole} 权限，当前权限: ${userRole}。`\n 136→    };\n 137→  }\n 138→\n 139→  // Check if this is a high-risk command requiring confirmation\n 140→  const requiresConfirmation = HIGH_RISK_COMMANDS.has(command);\n 141→\n 142→  return {\n 143→    allowed: true,\n 144→    requiresConfirmation\n 145→  };\n 146→}\n 147→\n 148→export default {\n 149→  getUserRole,\n 150→  checkCommandPermission,\n 151→  isAdmin,\n 152→  ROLE_HIERARCHY,\n 153→  setConfigForTesting,\n 154→  resetConfig\n 155→};\n 156→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:36.322Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"2420c704-b2af-4894-9ac2-275342164b14","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc310aa11b948c9144b31d0867","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { executeAiCli, interruptAiCli, isAiCliRunning } from '../services/ai-cli-service.js';\n  11→import { captureScreenshot } from '../services/screenshot-service.js';\n  12→import { executeCommand, confirmHighRiskCommand } from '../services/command-executor-service.js';\n  13→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  14→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  15→import { registerCommand } from './commands/index.js';\n  16→import { routeCommand } from './commands/index.js';\n  17→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  18→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  19→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  20→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  21→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  22→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  23→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  24→import { auditMeta, handleAudit } from './commands/handlers/audit.js';\n  25→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n  26→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n  27→// F-009: New command handlers\n  28→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n  29→import { moreMeta, handleMore } from './commands/handlers/more.js';\n  30→// F-010: File Manager command handlers\n  31→import { lsMeta, handleLs } from './commands/handlers/ls.js';\n  32→import { treeMeta, handleTree } from './commands/handlers/tree.js';\n  33→import { catMeta, handleCat } from './commands/handlers/cat.js';\n  34→import { headMeta, handleHead } from './commands/handlers/head.js';\n  35→import { tailMeta, handleTail } from './commands/handlers/tail.js';\n  36→import { findMeta, handleFind } from './commands/handlers/find.js';\n  37→import { uploadMeta, handleUpload } from './commands/handlers/upload.js';\n  38→import { downloadMeta, handleDownload } from './commands/handlers/download.js';\n  39→// F-012: System Monitor command handlers\n  40→import { sysinfoMeta, handleSysinfo } from './commands/handlers/sysinfo.js';\n  41→import { psMeta, handlePs } from './commands/handlers/ps.js';\n  42→import { killMeta, handleKill } from './commands/handlers/kill.js';\n  43→import { monitorMeta, handleMonitor } from './commands/handlers/monitor.js';\n  44→import { generateHelp } from './commands/help.js';\n  45→import { sessionStore } from '../services/session-store.js';\n  46→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n  47→\n  48→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  49→const STREAM_MIN_CHARS = 220;\n  50→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  51→const TYPING_INTERVAL_MS = 3500;\n  52→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  53→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  54→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  55→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  56→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  57→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  58→const TMP_DIR = path.resolve(os.tmpdir());\n  59→const HOME_DIR = path.resolve(os.homedir());\n  60→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  61→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  62→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  63→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  64→\n  65→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  66→  const normalized = configuredDirs\n  67→    .map((dir) => String(dir ?? '').trim())\n  68→    .filter(Boolean)\n  69→    .map((dir) => path.resolve(dir));\n  70→\n  71→  if (normalized.length > 0) {\n  72→    return [...new Set(normalized)];\n  73→  }\n  74→\n  75→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  76→}\n  77→\n  78→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  79→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  80→\n  81→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  82→  const chunks = [];\n  83→  for (let i = 0; i < text.length; i += chunkSize) {\n  84→    chunks.push(text.slice(i, i + chunkSize));\n  85→  }\n  86→  return chunks;\n  87→}\n  88→\n  89→function sanitizeMarkerPath(raw) {\n  90→  return String(raw ?? '')\n  91→    .trim()\n  92→    .replace(/^['\"`]+/, '')\n  93→    .replace(/['\"`]+$/, '');\n  94→}\n  95→\n  96→function extractFileMarkers(text = '') {\n  97→  const fileRefs = [];\n  98→\n  99→  const withSendFileRemoved = text.replace(\n 100→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n 101→    (_full, rawRef) => {\n 102→      const ref = sanitizeMarkerPath(rawRef);\n 103→      if (ref) {\n 104→        fileRefs.push(ref);\n 105→      }\n 106→      return '\\n';\n 107→    }\n 108→  );\n 109→\n 110→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n 111→    const ref = sanitizeMarkerPath(rawRef);\n 112→    if (ref) {\n 113→      fileRefs.push(ref);\n 114→    }\n 115→    return '';\n 116→  });\n 117→\n 118→  const withBacktickPathRemoved = withImageRemoved.replace(\n 119→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 120→    (_full, rawRef) => {\n 121→      const ref = sanitizeMarkerPath(rawRef);\n 122→      if (ref) {\n 123→        fileRefs.push(ref);\n 124→      }\n 125→      return '';\n 126→    }\n 127→  );\n 128→\n 129→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 130→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 131→    (_full, rawRef) => {\n 132→      const ref = sanitizeMarkerPath(rawRef);\n 133→      if (ref) {\n 134→        fileRefs.push(ref);\n 135→      }\n 136→      return '';\n 137→    }\n 138→  );\n 139→\n 140→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 141→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 142→    (_full, rawRef) => {\n 143→      const ref = sanitizeMarkerPath(rawRef);\n 144→      if (ref) {\n 145→        fileRefs.push(ref);\n 146→      }\n 147→      return '\\n';\n 148→    }\n 149→  );\n 150→\n 151→  return {\n 152→    fileRefs: [...new Set(fileRefs)],\n 153→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 154→  };\n 155→}\n 156→\n 157→function isPathWithinRoot(targetPath, rootPath) {\n 158→  const relative = path.relative(rootPath, targetPath);\n 159→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 160→}\n 161→\n 162→function isAllowedFilePath(filePath) {\n 163→  const resolved = path.resolve(filePath);\n 164→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 165→}\n 166→\n 167→function buildFileCandidates(normalizedPath) {\n 168→  if (path.isAbsolute(normalizedPath)) {\n 169→    return [normalizedPath];\n 170→  }\n 171→\n 172→  const baseName = path.basename(normalizedPath);\n 173→  const candidates = [\n 174→    path.resolve(process.cwd(), normalizedPath),\n 175→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 176→  ];\n 177→\n 178→  return [...new Set(candidates)];\n 179→}\n 180→\n 181→async function resolveLocalFilePath(fileRef) {\n 182→  const normalized = sanitizeMarkerPath(fileRef);\n 183→  if (!normalized) {\n 184→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 185→  }\n 186→\n 187→  if (!path.isAbsolute(normalized)) {\n 188→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 189→  }\n 190→\n 191→  const candidates = buildFileCandidates(normalized);\n 192→\n 193→  for (const candidate of candidates) {\n 194→    try {\n 195→      await access(candidate);\n 196→      return { filePath: candidate, triedPaths: candidates };\n 197→    } catch {\n 198→      // ignore\n 199→    }\n 200→  }\n 201→\n 202→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 203→}\n 204→\n 205→async function validateFileForTelegram(filePath) {\n 206→  const resolvedPath = path.resolve(filePath);\n 207→  if (!isAllowedFilePath(resolvedPath)) {\n 208→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 209→  }\n 210→\n 211→  const ext = path.extname(resolvedPath).toLowerCase();\n 212→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 213→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 214→  }\n 215→\n 216→  const fileStat = await stat(resolvedPath);\n 217→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 218→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 219→\n 220→  if (fileStat.size > maxSize) {\n 221→    return {\n 222→      ok: false,\n 223→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 224→    };\n 225→  }\n 226→\n 227→  return { ok: true, isPhoto, resolvedPath };\n 228→}\n 229→\n 230→function isTimeoutLikeError(message = '') {\n 231→  const normalized = String(message).toLowerCase();\n 232→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 233→}\n 234→\n 235→function sleep(ms) {\n 236→  return new Promise((resolve) => setTimeout(resolve, ms));\n 237→}\n 238→\n 239→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 240→  if (isPhoto) {\n 241→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 242→    return;\n 243→  }\n 244→\n 245→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 246→}\n 247→\n 248→async function replyFiles(ctx, fileRefs = []) {\n 249→  const results = [];\n 250→\n 251→  for (const fileRef of fileRefs) {\n 252→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 253→    if (!filePath) {\n 254→      const reason = rejectReason || 'not_found';\n 255→      results.push({ fileRef, sent: false, reason, triedPaths });\n 256→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 257→      continue;\n 258→    }\n 259→\n 260→    try {\n 261→      const validation = await validateFileForTelegram(filePath);\n 262→      if (!validation.ok) {\n 263→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 264→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 265→        continue;\n 266→      }\n 267→\n 268→      const actualPath = validation.resolvedPath;\n 269→      let sent = false;\n 270→      let lastReason = '';\n 271→\n 272→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 273→        try {\n 274→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 275→          sent = true;\n 276→          logger.info(\n 277→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 278→            'Telegram file sent'\n 279→          );\n 280→          break;\n 281→        } catch (error) {\n 282→          lastReason = error instanceof Error ? error.message : String(error);\n 283→          logger.warn(\n 284→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 285→            'Telegram file send attempt failed'\n 286→          );\n 287→\n 288→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 289→            await sleep(600);\n 290→            continue;\n 291→          }\n 292→\n 293→          break;\n 294→        }\n 295→      }\n 296→\n 297→      if (!sent) {\n 298→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 299→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 300→        continue;\n 301→      }\n 302→\n 303→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 304→    } catch (error) {\n 305→      const reason = error instanceof Error ? error.message : String(error);\n 306→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 307→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 308→    }\n 309→  }\n 310→\n 311→  return results;\n 312→}\n 313→\n 314→async function safeReply(ctx, text) {\n 315→  try {\n 316→    await ctx.reply(text);\n 317→    return true;\n 318→  } catch (error) {\n 319→    const reason = error instanceof Error ? error.message : String(error);\n 320→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 321→    return false;\n 322→  }\n 323→}\n 324→\n 325→async function replyLargeText(ctx, text) {\n 326→  const chunks = splitMessage(text);\n 327→  for (const chunk of chunks) {\n 328→    const ok = await safeReply(ctx, chunk);\n 329→    if (!ok) {\n 330→      break;\n 331→    }\n 332→  }\n 333→}\n 334→\n 335→async function safeEditMessageText(ctx, messageId, text) {\n 336→  const nextText = text && text.trim() ? text : ' ';\n 337→\n 338→  try {\n 339→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 340→  } catch (error) {\n 341→    const message = error instanceof Error ? error.message : String(error);\n 342→    if (message.includes('message is not modified')) {\n 343→      return;\n 344→    }\n 345→    throw error;\n 346→  }\n 347→}\n 348→\n 349→function createEditableStreamPublisher(ctx) {\n 350→  let fullText = '';\n 351→  let renderedText = '';\n 352→  let pendingChars = 0;\n 353→  let lastFlushAt = 0;\n 354→  let flushChain = Promise.resolve();\n 355→  let activeMessage = null;\n 356→  let activeSegmentIndex = 0;\n 357→  let publishedMessageCount = 0;\n 358→\n 359→  async function ensureActiveMessage() {\n 360→    if (activeMessage) {\n 361→      return;\n 362→    }\n 363→    activeMessage = await ctx.reply('处理中...');\n 364→    activeSegmentIndex = 0;\n 365→    publishedMessageCount += 1;\n 366→  }\n 367→\n 368→  async function render(force = false) {\n 369→    const now = Date.now();\n 370→\n 371→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 372→      return;\n 373→    }\n 374→\n 375→    if (fullText === renderedText) {\n 376→      pendingChars = 0;\n 377→      return;\n 378→    }\n 379→\n 380→    await ensureActiveMessage();\n 381→\n 382→    const segments = splitMessage(fullText);\n 383→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 384→\n 385→    while (activeSegmentIndex < targetLastIndex) {\n 386→      const text = segments[activeSegmentIndex] ?? ' ';\n 387→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 388→\n 389→      activeMessage = await ctx.reply('继续输出中...');\n 390→      activeSegmentIndex += 1;\n 391→      publishedMessageCount += 1;\n 392→    }\n 393→\n 394→    const activeText = segments[targetLastIndex] ?? ' ';\n 395→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 396→\n 397→    renderedText = fullText;\n 398→    pendingChars = 0;\n 399→    lastFlushAt = now;\n 400→  }\n 401→\n 402→  function enqueueRender(force = false) {\n 403→    flushChain = flushChain.then(() => render(force));\n 404→  }\n 405→\n 406→  return {\n 407→    push(text) {\n 408→      const appendText = text ?? '';\n 409→      if (!appendText) {\n 410→        return;\n 411→      }\n 412→      fullText += appendText;\n 413→      pendingChars += appendText.length;\n 414→      enqueueRender(false);\n 415→    },\n 416→    setFinalText(text) {\n 417→      fullText = text ?? '';\n 418→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 419→      enqueueRender(true);\n 420→    },\n 421→    async finish() {\n 422→      enqueueRender(true);\n 423→      await flushChain;\n 424→      return {\n 425→        outputLength: renderedText.length,\n 426→        messageCount: publishedMessageCount\n 427→      };\n 428→    }\n 429→  };\n 430→}\n 431→\n 432→function buildSessionId(ctx) {\n 433→  return String(ctx.chat.id);\n 434→}\n 435→\n 436→function ensureAllowed(ctx) {\n 437→  const userId = ctx.from?.id;\n 438→  if (!isAllowedUser(userId)) {\n 439→    throw new Error('当前账号未被授权使用该机器人。');\n 440→  }\n 441→}\n 442→\n 443→/**\n 444→ * Register all pipeline-related commands.\n 445→ */\n 446→function registerPipelineCommands() {\n 447→  registerCommand(pipelineMeta, handlePipeline);\n 448→  registerCommand(bugfixMeta, handleBugfix);\n 449→  registerCommand(plannerMeta, handlePlanner);\n 450→  registerCommand(statusMeta, handleStatus);\n 451→  registerCommand(logsMeta, handleLogs);\n 452→  registerCommand(stopMeta, handleStop);\n 453→  registerCommand(planMeta, handlePlan);\n 454→  registerCommand(auditMeta, handleAudit);\n 455→  registerCommand(commitMeta, handleCommit);\n 456→  registerCommand(commitsMeta, handleCommits);\n 457→  // F-009: New commands\n 458→  registerCommand(cdMeta, handleCd);\n 459→  registerCommand(moreMeta, handleMore);\n 460→  // F-010: File Manager commands\n 461→  registerCommand(lsMeta, handleLs);\n 462→  registerCommand(treeMeta, handleTree);\n 463→  registerCommand(catMeta, handleCat);\n 464→  registerCommand(headMeta, handleHead);\n 465→  registerCommand(tailMeta, handleTail);\n 466→  registerCommand(findMeta, handleFind);\n 467→  registerCommand(uploadMeta, handleUpload);\n 468→  registerCommand(downloadMeta, handleDownload);\n 469→  // F-012: System Monitor commands\n 470→  registerCommand(sysinfoMeta, handleSysinfo);\n 471→  registerCommand(psMeta, handlePs);\n 472→  registerCommand(killMeta, handleKill);\n 473→  registerCommand(monitorMeta, handleMonitor);\n 474→}\n 475→\n 476→export function createTelegramBot() {\n 477→  const bot = new Telegraf(config.telegramBotToken, {\n 478→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 479→  });\n 480→\n 481→  // Register pipeline commands\n 482→  registerPipelineCommands();\n 483→\n 484→  bot.catch((error, ctx) => {\n 485→    const message = error instanceof Error ? error.message : String(error);\n 486→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 487→  });\n 488→\n 489→  bot.start(async (ctx) => {\n 490→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 491→  });\n 492→\n 493→  bot.help(async (ctx) => {\n 494→    const helpText = generateHelp();\n 495→    await ctx.reply(helpText);\n 496→  });\n 497→\n 498→  bot.command('reset', async (ctx) => {\n 499→    try {\n 500→      ensureAllowed(ctx);\n 501→      const sessionId = buildSessionId(ctx);\n 502→\n 503→      // F-011: Interrupt any running AI CLI task\n 504→      if (isAiCliRunning(sessionId)) {\n 505→        interruptAiCli(sessionId);\n 506→      }\n 507→\n 508→      resetSession({ channel: 'telegram', sessionId });\n 509→      await ctx.reply('已清空当前会话上下文。');\n 510→    } catch (error) {\n 511→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 512→    }\n 513→  });\n 514→\n 515→  bot.command('screenshot', async (ctx) => {\n 516→    try {\n 517→      ensureAllowed(ctx);\n 518→      await ctx.reply('正在获取截图。');\n 519→      const { buffer } = await captureScreenshot();\n 520→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 521→    } catch (error) {\n 522→      const message = error instanceof Error ? error.message : String(error);\n 523→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 524→      await ctx.reply(`截图失败：${message}`);\n 525→    }\n 526→  });\n 527→\n 528→  bot.command('exec', async (ctx) => {\n 529→    try {\n 530→      ensureAllowed(ctx);\n 531→      const payload = ctx.message.text.replace('/exec', '').trim();\n 532→      if (!payload) {\n 533→        await ctx.reply('请提供命令，例如 /exec pwd');\n 534→        return;\n 535→      }\n 536→\n 537→      const sessionId = buildSessionId(ctx);\n 538→      const userId = ctx.from?.id;\n 539→\n 540→      await ctx.reply('正在执行命令...');\n 541→      const result = await executeCommand({\n 542→        command: payload,\n 543→        sessionId,\n 544→        userId\n 545→      });\n 546→\n 547→      // Handle confirmation required\n 548→      if (result.needsConfirmation) {\n 549→        await ctx.reply(result.confirmationMessage);\n 550→        return;\n 551→      }\n 552→\n 553→      // Send output\n 554→      await replyLargeText(ctx, result.output);\n 555→\n 556→      // Indicate if more pages available\n 557→      if (result.hasMorePages) {\n 558→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 559→      }\n 560→    } catch (error) {\n 561→      const message = error instanceof Error ? error.message : String(error);\n 562→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 563→      await ctx.reply(`执行失败：${message}`);\n 564→    }\n 565→  });\n 566→\n 567→  // F-009: /cd command handler\n 568→  bot.command('cd', async (ctx) => {\n 569→    try {\n 570→      ensureAllowed(ctx);\n 571→      const payload = ctx.message.text.replace('/cd', '').trim();\n 572→      const sessionId = buildSessionId(ctx);\n 573→\n 574→      await handleCd({\n 575→        ctx,\n 576→        reply: (msg) => ctx.reply(msg),\n 577→        params: {},\n 578→        userId: ctx.from?.id,\n 579→        sessionId,\n 580→        args: payload ? [payload] : []\n 581→      });\n 582→    } catch (error) {\n 583→      const message = error instanceof Error ? error.message : String(error);\n 584→      logger.error({ err: message }, 'Failed to cd in telegram');\n 585→      await ctx.reply(`切换目录失败：${message}`);\n 586→    }\n 587→  });\n 588→\n 589→  // F-009: /more command handler\n 590→  bot.command('more', async (ctx) => {\n 591→    try {\n 592→      ensureAllowed(ctx);\n 593→      const sessionId = buildSessionId(ctx);\n 594→\n 595→      await handleMore({\n 596→        ctx,\n 597→        reply: (msg) => ctx.reply(msg),\n 598→        params: {},\n 599→        userId: ctx.from?.id,\n 600→        sessionId\n 601→      });\n 602→    } catch (error) {\n 603→      const message = error instanceof Error ? error.message : String(error);\n 604→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 605→      await ctx.reply(`获取更多输出失败：${message}`);\n 606→    }\n 607→  });\n 608→\n 609→  // T-100: Document upload handler for plan files\n 610→  bot.on('document', async (ctx) => {\n 611→    try {\n 612→      ensureAllowed(ctx);\n 613→\n 614→      const document = ctx.message?.document;\n 615→      if (!document) {\n 616→        return;\n 617→      }\n 618→\n 619→      // Check file extension\n 620→      const fileName = document.file_name || '';\n 621→      const ext = path.extname(fileName).toLowerCase();\n 622→\n 623→      if (ext !== '.json') {\n 624→        // Not a JSON file, ignore silently (other handlers may process it)\n 625→        return;\n 626→      }\n 627→\n 628→      // Check file size\n 629→      const fileSize = document.file_size || 0;\n 630→      if (fileSize > 1024 * 1024) { // 1MB limit\n 631→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 632→        return;\n 633→      }\n 634→\n 635→      await ctx.reply('正在处理上传的计划文件...');\n 636→\n 637→      // Download file content\n 638→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 639→      const fileUrl = fileLink.href || fileLink.toString();\n 640→\n 641→      const response = await fetch(fileUrl);\n 642→      if (!response.ok) {\n 643→        throw new Error(`下载文件失败: ${response.status}`);\n 644→      }\n 645→\n 646→      const content = await response.text();\n 647→\n 648→      // Validate and save using plan-ingestion-service\n 649→      const infraConfig = loadPipelineInfraConfig();\n 650→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 651→\n 652→      const validationResult = planService.validate(content);\n 653→\n 654→      if (!validationResult.valid) {\n 655→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 656→        await ctx.reply(errorMsg);\n 657→        return;\n 658→      }\n 659→\n 660→      // Save the plan\n 661→      const saveResult = await planService.save(\n 662→        validationResult.type,\n 663→        content,\n 664→        { uploadedBy: ctx.from?.id }\n 665→      );\n 666→\n 667→      if (!saveResult.success) {\n 668→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 669→        return;\n 670→      }\n 671→\n 672→      // Set as current version\n 673→      await planService.setCurrent(validationResult.type, saveResult.version);\n 674→\n 675→      // Format success message\n 676→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 677→      const summary = validationResult.summary;\n 678→\n 679→      await ctx.reply([\n 680→        `✅ ${typeDisplay}已保存并激活`,\n 681→        `版本: ${saveResult.version}`,\n 682→        `名称: ${summary?.name || '未知'}`,\n 683→        `项目数: ${summary?.itemCount || 0}`,\n 684→        '',\n 685→        summary?.statusBreakdown ? '状态分布:' : '',\n 686→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 687→      ].filter(Boolean).join('\\n'));\n 688→\n 689→    } catch (error) {\n 690→      const message = error instanceof Error ? error.message : String(error);\n 691→      logger.error({ err: message }, 'Failed to process document upload');\n 692→      await ctx.reply(`❌ 处理失败：${message}`);\n 693→    }\n 694→  });\n 695→\n 696→  bot.on('text', async (ctx) => {\n 697→    // Check for pipeline commands first\n 698→    const handled = await routeCommand(ctx);\n 699→    if (handled) {\n 700→      return;\n 701→    }\n 702→\n 703→    const sessionId = buildSessionId(ctx);\n 704→    const userId = ctx.from?.id;\n 705→\n 706→    // F-009: Direct exec mode - treat plain text as command when enabled\n 707→    if (config.directExecMode && config.enableSystemExec) {\n 708→      try {\n 709→        ensureAllowed(ctx);\n 710→        const command = ctx.message.text;\n 711→\n 712→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 713→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 714→\n 715→        if (!isLikelyChat) {\n 716→          await ctx.reply('正在执行命令...');\n 717→          const result = await executeCommand({\n 718→            command,\n 719→            sessionId,\n 720→            userId\n 721→          });\n 722→\n 723→          if (result.needsConfirmation) {\n 724→            await ctx.reply(result.confirmationMessage);\n 725→            return;\n 726→          }\n 727→\n 728→          await replyLargeText(ctx, result.output);\n 729→\n 730→          if (result.hasMorePages) {\n 731→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 732→          }\n 733→          return;\n 734→        }\n 735→      } catch (error) {\n 736→        const message = error instanceof Error ? error.message : String(error);\n 737→        // If exec fails, fall through to chat mode\n 738→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n 739→      }\n 740→    }\n 741→\n 742→    // F-011: Check if AI CLI is already running\n 743→    if (isAiCliRunning(sessionId)) {\n 744→      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n 745→      return;\n 746→    }\n 747→\n 748→    let typingTimer = null;\n 749→\n 750→    try {\n 751→      ensureAllowed(ctx);\n 752→      await ctx.sendChatAction('typing');\n 753→\n 754→      const streamPublisher = createEditableStreamPublisher(ctx);\n 755→      typingTimer = setInterval(() => {\n 756→        ctx.sendChatAction('typing').catch(() => undefined);\n 757→      }, TYPING_INTERVAL_MS);\n 758→\n 759→      // F-011: Use ai-cli-service for execution with process tracking\n 760→      const sessionKey = `telegram:${sessionId}`;\n 761→\n 762→      // Append user message to session history\n 763→      sessionStore.append(sessionKey, 'user', ctx.message.text);\n 764→\n 765→      // Build prompt with context\n 766→      const prompt = sessionStore.toPrompt(sessionKey, 'telegram');\n 767→\n 768→      // Track last heartbeat message for updates\n 769→      /** @type {{ message_id: number } | null} */\n 770→      let lastHeartbeatMsg = null;\n 771→\n 772→      const result = await executeAiCli({\n 773→        sessionId,\n 774→        prompt,\n 775→        hooks: {\n 776→          onChunk: (text) => {\n 777→            streamPublisher.push(text);\n 778→          },\n 779→          onHeartbeat: config.aiCliEnableHeartbeat ? (info) => {\n 780→            // Send/update heartbeat progress message\n 781→            const elapsedSec = Math.floor(info.elapsedMs / 1000);\n 782→            const progressText = `⏳ 任务执行中... (${elapsedSec}s, ${Math.floor(info.stdoutBytes / 1024)}KB)`;\n 783→\n 784→            // Don't await - fire and forget\n 785→            if (lastHeartbeatMsg) {\n 786→              ctx.telegram.editMessageText(ctx.chat.id, lastHeartbeatMsg.message_id, undefined, progressText)\n 787→                .catch(() => {});\n 788→            } else {\n 789→              ctx.reply(progressText)\n 790→                .then((msg) => { lastHeartbeatMsg = msg; })\n 791→                .catch(() => {});\n 792→            }\n 793→          } : undefined,\n 794→          onStatus: (status) => {\n 795→            if (status === 'running') {\n 796→              ctx.sendChatAction('typing').catch(() => undefined);\n 797→            }\n 798→          }\n 799→        }\n 800→      });\n 801→\n 802→      // Delete heartbeat message if exists\n 803→      if (lastHeartbeatMsg) {\n 804→        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n 805→      }\n 806→\n 807→      // Append assistant reply to session history\n 808→      sessionStore.append(sessionKey, 'assistant', result.output);\n 809→\n 810→      // F-011: Format output with MarkdownV2\n 811→      const formattedOutput = convertToMarkdownV2(result.output);\n 812→\n 813→      // Handle result states\n 814→      if (result.interrupted) {\n 815→        await ctx.reply('⏹️ 任务已被中断。');\n 816→      } else if (result.timedOut) {\n 817→        await ctx.reply(`⏰ 任务执行超时。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n 818→      }\n 819→\n 820→      // Extract file markers and send\n 821→      const { fileRefs, cleanedText } = extractFileMarkers(result.output);\n 822→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 823→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 824→\n 825→      streamPublisher.setFinalText(finalText);\n 826→      const streamed = await streamPublisher.finish();\n 827→      if (streamed.outputLength === 0) {\n 828→        await replyLargeText(ctx, finalText);\n 829→      }\n 830→\n 831→      if (fileRefs.length > 0) {\n 832→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 833→        const failed = fileSendResults.filter((item) => !item.sent);\n 834→\n 835→        if (failed.length === 0) {\n 836→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 837→        } else {\n 838→          const failedList = failed\n 839→            .map((item) => {\n 840→              const reason =\n 841→                item.reason === 'relative_path_not_allowed'\n 842→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 843→                  : item.reason === 'not_found'\n 844→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 845→                    : item.reason;\n 846→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 847→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 848→            })\n 849→            .join('\\n');\n 850→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 851→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 852→        }\n 853→      }\n 854→    } catch (error) {\n 855→      const message = error instanceof Error ? error.message : String(error);\n 856→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 857→      await safeReply(ctx, `处理失败：${message}`);\n 858→    } finally {\n 859→      if (typingTimer) {\n 860→        clearInterval(typingTimer);\n 861→      }\n 862→    }\n 863→  });\n 864→\n 865→  return bot;\n 866→}\n 867→"}],"is_error":false}],"role":"