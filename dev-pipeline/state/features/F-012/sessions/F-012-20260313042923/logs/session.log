.networkInterfaces = () => mockNetworkInterfaces;\n  46→\n  47→    // Import fresh module\n  48→    const module = await import('../../src/services/system-monitor-service.js');\n  49→    SystemMonitorService = module.SystemMonitorService;\n  50→  });\n  51→\n  52→  afterEach(() => {\n  53→    // Restore original values\n  54→    Object.defineProperty(process, 'platform', { value: originalPlatform });\n  55→    os.homedir = originalHomedir;\n  56→    os.cpus = originalCpus;\n  57→    os.totalmem = originalTotalmem;\n  58→    os.freemem = originalFreemem;\n  59→    os.uptime = originalUptime;\n  60→    os.hostname = originalHostname;\n  61→    os.networkInterfaces = originalNetworkInterfaces;\n  62→  });\n  63→\n  64→  describe('getSystemInfo', () => {\n  65→    test('should return valid system info structure', async () => {\n  66→      const service = new SystemMonitorService();\n  67→      const info = await service.getSystemInfo();\n  68→\n  69→      assert.ok(info, 'Should return system info object');\n  70→      assert.ok(info.cpu, 'Should have cpu info');\n  71→      assert.ok(info.memory, 'Should have memory info');\n  72→      assert.ok(info.disk, 'Should have disk info');\n  73→      assert.ok(info.network, 'Should have network info');\n  74→      assert.ok(typeof info.uptime === 'number', 'Should have uptime');\n  75→      assert.ok(typeof info.hostname === 'string', 'Should have hostname');\n  76→      assert.ok(typeof info.platform === 'string', 'Should have platform');\n  77→    });\n  78→\n  79→    test('should return CPU info with correct structure', async () => {\n  80→      const service = new SystemMonitorService();\n  81→      const info = await service.getSystemInfo();\n  82→\n  83→      assert.ok(info.cpu.cores, 'Should have cpu cores');\n  84→      assert.ok(info.cpu.model, 'Should have cpu model');\n  85→      assert.ok(typeof info.cpu.usage === 'number', 'Should have cpu usage');\n  86→      assert.ok(info.cpu.usage >= 0 && info.cpu.usage <= 100, 'CPU usage should be 0-100');\n  87→    });\n  88→\n  89→    test('should return memory info with correct structure', async () => {\n  90→      const service = new SystemMonitorService();\n  91→      const info = await service.getSystemInfo();\n  92→\n  93→      assert.ok(typeof info.memory.total === 'number', 'Should have total memory');\n  94→      assert.ok(typeof info.memory.free === 'number', 'Should have free memory');\n  95→      assert.ok(typeof info.memory.used === 'number', 'Should have used memory');\n  96→      assert.ok(typeof info.memory.usagePercent === 'number', 'Should have usage percent');\n  97→      assert.ok(info.memory.usagePercent >= 0 && info.memory.usagePercent <= 100, 'Memory usage should be 0-100');\n  98→    });\n  99→\n 100→    test('should calculate memory usage correctly', async () => {\n 101→      const service = new SystemMonitorService();\n 102→      const info = await service.getSystemInfo();\n 103→\n 104→      // Total 16GB, Free 6GB, Used 10GB -> 62.5% usage\n 105→      assert.equal(info.memory.total, 16 * 1024 * 1024 * 1024);\n 106→      assert.equal(info.memory.free, 6 * 1024 * 1024 * 1024);\n 107→      assert.equal(info.memory.used, 10 * 1024 * 1024 * 1024);\n 108→      assert.ok(Math.abs(info.memory.usagePercent - 62.5) < 1, 'Memory usage should be ~62.5%');\n 109→    });\n 110→\n 111→    test('should return uptime in seconds', async () => {\n 112→      const service = new SystemMonitorService();\n 113→      const info = await service.getSystemInfo();\n 114→\n 115→      assert.equal(info.uptime, 86400, 'Uptime should be 86400 seconds');\n 116→    });\n 117→\n 118→    test('should return hostname', async () => {\n 119→      const service = new SystemMonitorService();\n 120→      const info = await service.getSystemInfo();\n 121→\n 122→      assert.equal(info.hostname, 'test-host', 'Hostname should match');\n 123→    });\n 124→\n 125→    test('should return platform', async () => {\n 126→      const service = new SystemMonitorService();\n 127→      const info = await service.getSystemInfo();\n 128→\n 129→      assert.ok(['darwin', 'linux', 'win32'].includes(info.platform) || typeof info.platform === 'string', 'Platform should be valid');\n 130→    });\n 131→  });\n 132→\n 133→  describe('getProcessList', () => {\n 134→    test('should return array of processes', async () => {\n 135→      const service = new SystemMonitorService();\n 136→      const processes = await service.getProcessList();\n 137→\n 138→      assert.ok(Array.isArray(processes), 'Should return an array');\n 139→      if (processes.length > 0) {\n 140→        const proc = processes[0];\n 141→        assert.ok(typeof proc.pid === 'number', 'Should have pid');\n 142→        assert.ok(typeof proc.name === 'string', 'Should have name');\n 143→        assert.ok(typeof proc.cpu === 'number', 'Should have cpu');\n 144→        assert.ok(typeof proc.memory === 'number', 'Should have memory');\n 145→      }\n 146→    });\n 147→\n 148→    test('should sort by CPU when sortBy=cpu', async () => {\n 149→      const service = new SystemMonitorService();\n 150→      const processes = await service.getProcessList({ sortBy: 'cpu' });\n 151→\n 152→      if (processes.length > 1) {\n 153→        for (let i = 1; i < processes.length; i++) {\n 154→          assert.ok(processes[i - 1].cpu >= processes[i].cpu, 'Should be sorted by CPU descending');\n 155→        }\n 156→      }\n 157→    });\n 158→\n 159→    test('should sort by memory when sortBy=memory', async () => {\n 160→      const service = new SystemMonitorService();\n 161→      const processes = await service.getProcessList({ sortBy: 'memory' });\n 162→\n 163→      if (processes.length > 1) {\n 164→        for (let i = 1; i < processes.length; i++) {\n 165→          assert.ok(processes[i - 1].memory >= processes[i].memory, 'Should be sorted by memory descending');\n 166→        }\n 167→      }\n 168→    });\n 169→\n 170→    test('should filter processes by keyword', async () => {\n 171→      const service = new SystemMonitorService();\n 172→      const processes = await service.getProcessList({ filter: 'node' });\n 173→\n 174→      if (processes.length > 0) {\n 175→        for (const proc of processes) {\n 176→          const matchesKeyword = proc.name.toLowerCase().includes('node') ||\n 177→            proc.command.toLowerCase().includes('node');\n 178→          assert.ok(matchesKeyword, 'All processes should match filter keyword');\n 179→        }\n 180→      }\n 181→    });\n 182→\n 183→    test('should limit process count', async () => {\n 184→      const service = new SystemMonitorService();\n 185→      const processes = await service.getProcessList({ limit: 10 });\n 186→\n 187→      assert.ok(processes.length <= 10, 'Should not exceed limit');\n 188→    });\n 189→  });\n 190→\n 191→  describe('killProcess', () => {\n 192→    test('should return error for invalid PID', async () => {\n 193→      const service = new SystemMonitorService();\n 194→      const result = await service.killProcess('invalid');\n 195→\n 196→      assert.equal(result.success, false);\n 197→      assert.ok(result.error, 'Should have error message');\n 198→    });\n 199→\n 200→    test('should return error for negative PID', async () => {\n 201→      const service = new SystemMonitorService();\n 202→      const result = await service.killProcess(-1);\n 203→\n 204→      assert.equal(result.success, false);\n 205→      assert.ok(result.error, 'Should have error message');\n 206→    });\n 207→\n 208→    test('should return error for non-existent PID', async () => {\n 209→      const service = new SystemMonitorService();\n 210→      // PID 999999 is unlikely to exist\n 211→      const result = await service.killProcess(999999);\n 212→\n 213→      assert.equal(result.success, false);\n 214→      assert.ok(result.error, 'Should have error message for non-existent process');\n 215→    });\n 216→  });\n 217→\n 218→  describe('formatUptime', () => {\n 219→    test('should format seconds correctly', async () => {\n 220→      const service = new SystemMonitorService();\n 221→      const formatted = service.formatUptime(45);\n 222→\n 223→      assert.ok(formatted.includes('45'), 'Should include seconds');\n 224→    });\n 225→\n 226→    test('should format minutes correctly', async () => {\n 227→      const service = new SystemMonitorService();\n 228→      const formatted = service.formatUptime(125); // 2m 5s\n 229→\n 230→      assert.ok(formatted.includes('2'), 'Should include minutes');\n 231→    });\n 232→\n 233→    test('should format hours correctly', async () => {\n 234→      const service = new SystemMonitorService();\n 235→      const formatted = service.formatUptime(3665); // 1h 1m 5s\n 236→\n 237→      assert.ok(formatted.includes('1'), 'Should include hours');\n 238→    });\n 239→\n 240→    test('should format days correctly', async () => {\n 241→      const service = new SystemMonitorService();\n 242→      const formatted = service.formatUptime(90065); // 1d 1h 1m 5s\n 243→\n 244→      assert.ok(formatted.includes('1'), 'Should include days');\n 245→    });\n 246→  });\n 247→\n 248→  describe('formatBytes', () => {\n 249→    test('should format bytes', async () => {\n 250→      const service = new SystemMonitorService();\n 251→      assert.ok(service.formatBytes(500).includes('B'));\n 252→      assert.ok(service.formatBytes(500).includes('500'));\n 253→    });\n 254→\n 255→    test('should format kilobytes', async () => {\n 256→      const service = new SystemMonitorService();\n 257→      assert.ok(service.formatBytes(1024).includes('KB'));\n 258→    });\n 259→\n 260→    test('should format megabytes', async () => {\n 261→      const service = new SystemMonitorService();\n 262→      const result = service.formatBytes(1024 * 1024);\n 263→      assert.ok(result.includes('MB'));\n 264→    });\n 265→\n 266→    test('should format gigabytes', async () => {\n 267→      const service = new SystemMonitorService();\n 268→      const result = service.formatBytes(16 * 1024 * 1024 * 1024);\n 269→      assert.ok(result.includes('GB'));\n 270→    });\n 271→  });\n 272→});\n 273→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:40.257Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"771cee8b-2dfa-4715-8bc8-c8738079b407","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc3ebeded0a889d450637f8eb3","content":[{"type":"text","text":"   1→import { describe, test, beforeEach, afterEach } from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import { mkdtemp, rm, writeFile, readFile } from 'node:fs/promises';\n   4→import { tmpdir } from 'node:os';\n   5→import { join } from 'node:path';\n   6→\n   7→describe('F-012 AlertManagerService', () => {\n   8→  let AlertManagerService;\n   9→  let tempDir;\n  10→  let alertManager;\n  11→  let rulesFile;\n  12→\n  13→  beforeEach(async () => {\n  14→    // Create temp directory\n  15→    tempDir = await mkdtemp(join(tmpdir(), 'alert-manager-test-'));\n  16→    rulesFile = join(tempDir, 'alert-rules.json');\n  17→\n  18→    // Import fresh module\n  19→    const module = await import('../../src/services/alert-manager-service.js');\n  20→    AlertManagerService = module.AlertManagerService;\n  21→\n  22→    // Create instance with temp directory\n  23→    alertManager = new AlertManagerService({\n  24→      dataDir: tempDir,\n  25→      rulesFile: 'alert-rules.json'\n  26→    });\n  27→  });\n  28→\n  29→  afterEach(async () => {\n  30→    // Stop any running monitoring\n  31→    if (alertManager) {\n  32→      alertManager.stopMonitoring();\n  33→    }\n  34→    // Cleanup temp directory\n  35→    try {\n  36→      await rm(tempDir, { recursive: true, force: true });\n  37→    } catch {\n  38→      // ignore\n  39→    }\n  40→  });\n  41→\n  42→  describe('addRule', () => {\n  43→    test('should add a new alert rule', () => {\n  44→      const rule = alertManager.addRule({\n  45→        metric: 'cpu',\n  46→        operator: '>',\n  47→        threshold: 80,\n  48→        enabled: true\n  49→      });\n  50→\n  51→      assert.ok(rule.id, 'Should have generated ID');\n  52→      assert.equal(rule.metric, 'cpu');\n  53→      assert.equal(rule.operator, '>');\n  54→      assert.equal(rule.threshold, 80);\n  55→      assert.equal(rule.enabled, true);\n  56→      assert.ok(rule.createdAt, 'Should have createdAt timestamp');\n  57→    });\n  58→\n  59→    test('should generate unique IDs for different rules', () => {\n  60→      const rule1 = alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n  61→      const rule2 = alertManager.addRule({ metric: 'memory', operator: '>', threshold: 90, enabled: true });\n  62→\n  63→      assert.notEqual(rule1.id, rule2.id, 'IDs should be unique');\n  64→    });\n  65→\n  66→    test('should validate metric type', () => {\n  67→      assert.throws(() => {\n  68→        alertManager.addRule({ metric: 'invalid', operator: '>', threshold: 50, enabled: true });\n  69→      }, /invalid metric/i);\n  70→    });\n  71→\n  72→    test('should validate operator', () => {\n  73→      assert.throws(() => {\n  74→        alertManager.addRule({ metric: 'cpu', operator: '==', threshold: 50, enabled: true });\n  75→      }, /invalid operator/i);\n  76→    });\n  77→\n  78→    test('should validate threshold is a number', () => {\n  79→      assert.throws(() => {\n  80→        alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 'not-a-number', enabled: true });\n  81→      }, /threshold/i);\n  82→    });\n  83→\n  84→    test('should validate threshold range (0-100)', () => {\n  85→      assert.throws(() => {\n  86→        alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 150, enabled: true });\n  87→      }, /threshold/i);\n  88→\n  89→      assert.throws(() => {\n  90→        alertManager.addRule({ metric: 'cpu', operator: '>', threshold: -10, enabled: true });\n  91→      }, /threshold/i);\n  92→    });\n  93→  });\n  94→\n  95→  describe('removeRule', () => {\n  96→    test('should remove an existing rule', () => {\n  97→      const rule = alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n  98→      const result = alertManager.removeRule(rule.id);\n  99→\n 100→      assert.equal(result, true, 'Should return true for successful removal');\n 101→\n 102→      const rules = alertManager.listRules();\n 103→      assert.equal(rules.length, 0, 'Rule should be removed');\n 104→    });\n 105→\n 106→    test('should return false for non-existent rule', () => {\n 107→      const result = alertManager.removeRule('non-existent-id');\n 108→      assert.equal(result, false, 'Should return false for non-existent rule');\n 109→    });\n 110→  });\n 111→\n 112→  describe('listRules', () => {\n 113→    test('should return empty array when no rules', () => {\n 114→      const rules = alertManager.listRules();\n 115→      assert.deepEqual(rules, []);\n 116→    });\n 117→\n 118→    test('should return all rules', () => {\n 119→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 120→      alertManager.addRule({ metric: 'memory', operator: '>', threshold: 90, enabled: true });\n 121→\n 122→      const rules = alertManager.listRules();\n 123→      assert.equal(rules.length, 2);\n 124→    });\n 125→  });\n 126→\n 127→  describe('enableRule / disableRule', () => {\n 128→    test('should disable a rule', () => {\n 129→      const rule = alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 130→      const result = alertManager.disableRule(rule.id);\n 131→\n 132→      assert.equal(result, true);\n 133→\n 134→      const rules = alertManager.listRules();\n 135→      assert.equal(rules[0].enabled, false);\n 136→    });\n 137→\n 138→    test('should enable a disabled rule', () => {\n 139→      const rule = alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: false });\n 140→      const result = alertManager.enableRule(rule.id);\n 141→\n 142→      assert.equal(result, true);\n 143→\n 144→      const rules = alertManager.listRules();\n 145→      assert.equal(rules[0].enabled, true);\n 146→    });\n 147→\n 148→    test('should return false for non-existent rule', () => {\n 149→      assert.equal(alertManager.enableRule('non-existent'), false);\n 150→      assert.equal(alertManager.disableRule('non-existent'), false);\n 151→    });\n 152→  });\n 153→\n 154→  describe('checkThresholds', () => {\n 155→    test('should detect threshold breach', () => {\n 156→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 157→\n 158→      const metrics = {\n 159→        cpu: { usage: 85 },\n 160→        memory: { usagePercent: 50 },\n 161→        disk: { usagePercent: 60 }\n 162→      };\n 163→\n 164→      const alerts = alertManager.checkThresholds(metrics);\n 165→\n 166→      assert.equal(alerts.length, 1);\n 167→      assert.equal(alerts[0].metric, 'cpu');\n 168→      assert.equal(alerts[0].currentValue, 85);\n 169→      assert.equal(alerts[0].threshold, 80);\n 170→    });\n 171→\n 172→    test('should not alert for disabled rules', () => {\n 173→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: false });\n 174→\n 175→      const metrics = {\n 176→        cpu: { usage: 85 },\n 177→        memory: { usagePercent: 50 },\n 178→        disk: { usagePercent: 60 }\n 179→      };\n 180→\n 181→      const alerts = alertManager.checkThresholds(metrics);\n 182→      assert.equal(alerts.length, 0);\n 183→    });\n 184→\n 185→    test('should support different operators', () => {\n 186→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 187→      alertManager.addRule({ metric: 'memory', operator: '>=', threshold: 90, enabled: true });\n 188→      alertManager.addRule({ metric: 'disk', operator: '<', threshold: 10, enabled: true });\n 189→\n 190→      const metrics = {\n 191→        cpu: { usage: 85 },    // 85 > 80 -> alert\n 192→        memory: { usagePercent: 90 }, // 90 >= 90 -> alert\n 193→        disk: { usagePercent: 5 }     // 5 < 10 -> alert\n 194→      };\n 195→\n 196→      const alerts = alertManager.checkThresholds(metrics);\n 197→      assert.equal(alerts.length, 3);\n 198→    });\n 199→\n 200→    test('should not alert when threshold not breached', () => {\n 201→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 202→\n 203→      const metrics = {\n 204→        cpu: { usage: 75 },\n 205→        memory: { usagePercent: 50 },\n 206→        disk: { usagePercent: 60 }\n 207→      };\n 208→\n 209→      const alerts = alertManager.checkThresholds(metrics);\n 210→      assert.equal(alerts.length, 0);\n 211→    });\n 212→  });\n 213→\n 214→  describe('persistence', () => {\n 215→    test('should save rules to file', async () => {\n 216→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 217→\n 218→      await alertManager.saveRules();\n 219→\n 220→      const content = await readFile(rulesFile, 'utf-8');\n 221→      const savedRules = JSON.parse(content);\n 222→\n 223→      assert.equal(savedRules.length, 1);\n 224→      assert.equal(savedRules[0].metric, 'cpu');\n 225→    });\n 226→\n 227→    test('should load rules from file', async () => {\n 228→      // Write rules directly to file\n 229→      const testRules = [{\n 230→        id: 'test-id-123',\n 231→        metric: 'memory',\n 232→        operator: '>=',\n 233→        threshold: 90,\n 234→        enabled: true,\n 235→        createdAt: Date.now()\n 236→      }];\n 237→\n 238→      await writeFile(rulesFile, JSON.stringify(testRules));\n 239→\n 240→      await alertManager.loadRules();\n 241→\n 242→      const rules = alertManager.listRules();\n 243→      assert.equal(rules.length, 1);\n 244→      assert.equal(rules[0].id, 'test-id-123');\n 245→    });\n 246→\n 247→    test('should handle missing file gracefully', async () => {\n 248→      // Don't create the file\n 249→      await alertManager.loadRules();\n 250→\n 251→      const rules = alertManager.listRules();\n 252→      assert.deepEqual(rules, []);\n 253→    });\n 254→\n 255→    test('should handle corrupted file gracefully', async () => {\n 256→      await writeFile(rulesFile, 'not valid json');\n 257→\n 258→      await alertManager.loadRules();\n 259→\n 260→      const rules = alertManager.listRules();\n 261→      assert.deepEqual(rules, []);\n 262→    });\n 263→  });\n 264→\n 265→  describe('monitoring', () => {\n 266→    test('should start monitoring', () => {\n 267→      const alerts = [];\n 268→      alertManager.startMonitoring(() => {}, 1000);\n 269→\n 270→      // Should not throw\n 271→      alertManager.stopMonitoring();\n 272→    });\n 273→\n 274→    test('should stop monitoring', () => {\n 275→      alertManager.startMonitoring(() => {}, 1000);\n 276→      alertManager.stopMonitoring();\n 277→\n 278→      // Should not throw when called again\n 279→      alertManager.stopMonitoring();\n 280→    });\n 281→\n 282→    test('should not start duplicate monitoring', () => {\n 283→      alertManager.startMonitoring(() => {}, 1000);\n 284→\n 285→      assert.throws(() => {\n 286→        alertManager.startMonitoring(() => {}, 1000);\n 287→      }, /already running/i);\n 288→\n 289→      alertManager.stopMonitoring();\n 290→    });\n 291→  });\n 292→\n 293→  describe('cooldown', () => {\n 294→    test('should apply cooldown to prevent spam', () => {\n 295→      alertManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 296→\n 297→      const metrics = {\n 298→        cpu: { usage: 85 },\n 299→        memory: { usagePercent: 50 },\n 300→        disk: { usagePercent: 60 }\n 301→      };\n 302→\n 303→      // First check should trigger\n 304→      const alerts1 = alertManager.checkThresholds(metrics);\n 305→      assert.equal(alerts1.length, 1);\n 306→\n 307→      // Immediate second check should not trigger (cooldown)\n 308→      const alerts2 = alertManager.checkThresholds(metrics);\n 309→      assert.equal(alerts2.length, 0);\n 310→    });\n 311→\n 312→    test('should allow alert after cooldown expires', () => {\n 313→      // Create instance with very short cooldown for testing\n 314→      const shortCooldownManager = new AlertManagerService({\n 315→        dataDir: tempDir,\n 316→        rulesFile: 'alert-rules-2.json',\n 317→        cooldownMs: 10 // 10ms cooldown\n 318→      });\n 319→\n 320→      shortCooldownManager.addRule({ metric: 'cpu', operator: '>', threshold: 80, enabled: true });\n 321→\n 322→      const metrics = {\n 323→        cpu: { usage: 85 },\n 324→        memory: { usagePercent: 50 },\n 325→        disk: { usagePercent: 60 }\n 326→      };\n 327→\n 328→      // First check\n 329→      const alerts1 = shortCooldownManager.checkThresholds(metrics);\n 330→      assert.equal(alerts1.length, 1);\n 331→\n 332→      // Wait for cooldown\n 333→      return new Promise((resolve) => {\n 334→        setTimeout(() => {\n 335→          const alerts2 = shortCooldownManager.checkThresholds(metrics);\n 336→          assert.equal(alerts2.length, 1);\n 337→          resolve();\n 338→        }, 50);\n 339→      });\n 340→    });\n 341→  });\n 342→\n 343→  describe('parseRuleString', () => {\n 344→    test('should parse \"cpu>80\" format', () => {\n 345→      const result = alertManager.parseRuleString('cpu>80');\n 346→\n 347→      assert.deepEqual(result, {\n 348→        metric: 'cpu',\n 349→        operator: '>',\n 350→        threshold: 80\n 351→      });\n 352→    });\n 353→\n 354→    test('should parse \"memory>=90\" format', () => {\n 355→      const result = alertManager.parseRuleString('memory>=90');\n 356→\n 357→      assert.deepEqual(result, {\n 358→        metric: 'memory',\n 359→        operator: '>=',\n 360→        threshold: 90\n 361→      });\n 362→    });\n 363→\n 364→    test('should parse \"disk<10\" format', () => {\n 365→      const result = alertManager.parseRuleString('disk<10');\n 366→\n 367→      assert.deepEqual(result, {\n 368→        metric: 'disk',\n 369→        operator: '<',\n 370→        threshold: 10\n 371→      });\n 372→    });\n 373→\n 374→    test('should throw for invalid format', () => {\n 375→      assert.throws(() => {\n 376→        alertManager.parseRuleString('invalid');\n 377→      }, /invalid/i);\n 378→    });\n 379→  });\n 380→});\n 381→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:40.258Z","_requestId":"d34d194674fe4df2b045b65a2435281c"}
{"type":"user","uuid":"0922e86d-bbfa-45c8-9c0a-20aef6c7f6e7","session_id":"301af3e8-7399-4356-b525-ec1e2117384a","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3cc403d1bbf25b3e7d88b1db5f1","content":[{"type":"text","text":"   1→import { describe, test, beforeEach, afterEach } from 'node:test';\n   2→import assert from 'node:assert/strict';\n   3→import { mkdtemp, rm } from 'node:fs/promises';\n   4→import { tmpdir } from 'node:os';\n   5→import { join } from 'node:path';\n   6→\n   7→describe('F-012 System Monitor Integration', () => {\n   8→  let tempDir;\n   9→  let SystemMonitorService;\n  10→  let AlertManagerService;\n  11→\n  12→  beforeEach(async () => {\n  13→    tempDir = await mkdtemp(join(tmpdir(), 'f012-integration-test-'));\n  14→\n  15→    const monitorModule = await import('../../src/services/system-monitor-service.js');\n  16→    const alertModule = await import('../../src/services/alert-manager-service.js');\n  17→\n  18→    SystemMonitorService = monitorModule.SystemMonitorService;\n  19→    AlertManagerService = alertModule.AlertManagerService;\n  20→  });\n  21→\n  22→  afterEach(async () => {\n  23→    try {\n  24→      await rm(tempDir, { recursive: true, force: true });\n  25→    } catch {\n  26→      // ignore\n  27→    }\n  28→  });\n  29→\n  30→  describe('Full workflow', () => {\n  31→    test('should get system info and check against alert rules', async () => {\n  32→      const monitor = new SystemMonitorService();\n  33→      const alertManager = new AlertManagerService({ dataDir: tempDir });\n  34→\n  35→      // Get system info\n  36→      const info = await monitor.getSystemInfo();\n  37→      assert.ok(info.cpu, 'Should have CPU info');\n  38→      assert.ok(info.memory, 'Should have memory info');\n  39→      assert.ok(info.disk, 'Should have disk info');\n  40→\n  41→      // Add an alert rule\n  42→      const rule = alertManager.addRule({\n  43→        metric: 'cpu',\n  44→        operator: '>',\n  45→        threshold: 0, // Low threshold to ensure trigger\n  46→        enabled: true\n  47→      });\n  48→\n  49→      assert.ok(rule.id, 'Should have rule ID');\n  50→\n  51→      // Check thresholds\n  52→      const alerts = alertManager.checkThresholds(info);\n  53→\n  54→      // CPU usage > 0 should trigger\n  55→      assert.ok(alerts.length >= 1, 'Should have at least one alert');\n  56→\n  57→      // Save and reload rules\n  58→      await alertManager.saveRules();\n  59→      await alertManager.loadRules();\n  60→\n  61→      const rules = alertManager.listRules();\n  62→      assert.equal(rules.length, 1, 'Should have one rule after reload');\n  63→    });\n  64→\n  65→    test('should persist rules across service instances', async () => {\n  66→      // Create first instance and add a rule\n  67→      const alertManager1 = new AlertManagerService({\n  68→        dataDir: tempDir,\n  69→        rulesFile: 'test-rules.json'\n  70→      });\n  71→\n  72→      const rule = alertManager1.addRule({\n  73→        metric: 'memory',\n  74→        operator: '>=',\n  75→        threshold: 50,\n  76→        enabled: true\n  77→      });\n  78→\n  79→      await alertManager1.saveRules();\n  80→\n  81→      // Create second instance and load rules\n  82→      const alertManager2 = new AlertManagerService({\n  83→        dataDir: tempDir,\n  84→        rulesFile: 'test-rules.json'\n  85→      });\n  86→\n  87→      await alertManager2.loadRules();\n  88→\n  89→      const rules = alertManager2.listRules();\n  90→      assert.equal(rules.length, 1, 'Should have one rule');\n  91→      assert.equal(rules[0].id, rule.id, 'Rule ID should match');\n  92→      assert.equal(rules[0].metric, 'memory', 'Metric should match');\n  93→    });\n  94→\n  95→    test('should get process list and filter', async () => {\n  96→      const monitor = new SystemMonitorService();\n  97→\n  98→      const allProcesses = await monitor.getProcessList({ limit: 100 });\n  99→      assert.ok(Array.isArray(allProcesses), 'Should return array');\n 100→\n 101→      if (allProcesses.length > 0) {\n 102→        // Filter for common processes\n 103→        const filteredProcesses = await monitor.getProcessList({\n 104→          filter: 'node',\n 105→          limit: 10\n 106→        });\n 107→\n 108→        // On a development machine, there should be at least one node process\n 109→        // (the test runner)\n 110→        assert.ok(Array.isArray(filteredProcesses), 'Should return filtered array');\n 111→      }\n 112→    });\n 113→  });\n 114→\n 115→  describe('Permission integration', () => {\n 116→    test('should check command permissions', async () => {\n 117→      const { checkCommandPermission, setConfigForTesting, resetConfig } =\n 118→        await import('../../src/security/permission-guard.js');\n 119→\n 120→      // Test sysinfo permission (viewer)\n 121→      const sysinfoResult = checkCommandPermission('test-user', 'sysinfo');\n 122→      assert.ok(sysinfoResult.allowed, 'sysinfo should be allowed for viewer');\n 123→\n 124→      // Test ps permission (viewer)\n 125→      const psResult = checkCommandPermission('test-user', 'ps');\n 126→      assert.ok(psResult.allowed, 'ps should be allowed for viewer');\n 127→\n 128→      // Test monitor permission (operator)\n 129→      const monitorResult = checkCommandPermission('test-user', 'monitor');\n 130→      assert.ok(monitorResult.allowed, 'monitor should be allowed for operator');\n 131→\n 132→      // Test kill permission (admin) - requires high role\n 133→      const killResult = checkCommandPermission('test-user', 'kill');\n 134→      // Default unknown user is operator, not admin\n 135→      // So kill should require confirmation but might not be allowed\n 136→      // Let's check the actual behavior\n 137→      assert.ok(killResult.requiresConfirmation || !killResult.allowed,\n 138→        'kill should require confirmation or be denied');\n 139→\n 140→      resetConfig();\n 141→    });\n 142→  });\n 143→\n 144→  describe('Command handler integration', () => {\n 145→    test('should execute sysinfo handler end-to-end', async () => {\n 146→      const { handleSysinfo } = await import('../../src/bot/commands/handlers/sysinfo.js');\n 147→\n 148→      const replies = [];\n 149→      const handlerCtx = {\n 150→        reply: (msg) => { replies.push(msg); },\n 151→        userId: 'test-user',\n 152→        sessionId: 'test-session',\n 153→        args: []\n 154→      };\n 155→\n 156→      await handleSysinfo(handlerCtx);\n 157→\n 158→      assert.equal(replies.length, 1, 'Should send one reply');\n 159→      assert.ok(replies[0].length > 50, 'Reply should have substantial content');\n 160→    });\n 161→\n 162→    test('should execute ps handler end-to-end', async () => {\n 163→      const { handlePs } = await import('../../src/bot/commands/handlers/ps.js');\n 164→\n 165→      const replies = [];\n 166→      const handlerCtx = {\n 167→        reply: (msg) => { replies.push(msg); },\n 168→        userId: 'test-user',\n 169→        sessionId: 'test-session',\n 170→        args: []\n 171→      };\n 172→\n 173→      await handlePs(handlerCtx);\n 174→\n 175→      assert.equal(replies.length, 1, 'Should send one reply');\n 176→    });\n 177→\n 178→    test('should execute monitor handler end-to-end', async () => {\n 179→      const { handleMonitor } = await import('../../src/bot/commands/handlers/monitor.js');\n 180→\n 181→      const replies = [];\n 182→      const handlerCtx = {\n 183→        reply: (msg) => { replies.push(msg); },\n 184→        userId: 'test-user',\n 185→        sessionId: 'test-session',\n 186→        args: ['list']\n 187→      };\n 188→\n 189→      await handleMonitor(handlerCtx);\n 190→\n 191→      assert.equal(replies.length, 1, 'Should send one reply');\n 192→    });\n 193→  });\n 194→});\n 195→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"019ce3cbfdc7f65a81b731c993e2893f","__timestamp":"2026-03-12T20:45:40.258Z","_requestId":"d34d194674f