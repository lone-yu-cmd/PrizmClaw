{"type":"user","uuid":"2810e512-2222-4429-9a62-64e68d3789ce","session_id":"34f919b8-df8c-46e5-a3ef-c48e25e357c2","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3f03debc55d3e3edb12cbe9b329","content":[{"type":"text","text":"   1→/**\n   2→ * History Command Handler\n   3→ * F-013: Session and Context Manager\n   4→ *\n   5→ * Handles the /history command for viewing command execution history.\n   6→ */\n   7→\n   8→import { sessionStore } from '../../../services/session-store.js';\n   9→\n  10→/**\n  11→ * History command metadata.\n  12→ */\n  13→export const historyMeta = {\n  14→  name: 'history',\n  15→  aliases: ['h'],\n  16→  description: '查看命令执行历史',\n  17→  usage: '/history [N]',\n  18→  examples: ['/history', '/history 20'],\n  19→  params: [\n  20→    {\n  21→      name: 'count',\n  22→      required: false,\n  23→      description: '显示最近 N 条命令（默认 10 条）'\n  24→    }\n  25→  ],\n  26→  requiresAuth: true,\n  27→  minRole: 'viewer',\n  28→  helpText: '/history [N] - 查看最近执行的命令历史'\n  29→};\n  30→\n  31→/**\n  32→ * Format a timestamp for display.\n  33→ * @param {number} timestamp - Unix timestamp in ms\n  34→ * @returns {string} Formatted string\n  35→ */\n  36→function formatTimestamp(timestamp) {\n  37→  const date = new Date(timestamp);\n  38→  const year = date.getFullYear();\n  39→  const month = String(date.getMonth() + 1).padStart(2, '0');\n  40→  const day = String(date.getDate()).padStart(2, '0');\n  41→  const hours = String(date.getHours()).padStart(2, '0');\n  42→  const minutes = String(date.getMinutes()).padStart(2, '0');\n  43→  const seconds = String(date.getSeconds()).padStart(2, '0');\n  44→  return `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;\n  45→}\n  46→\n  47→/**\n  48→ * Handle /history command.\n  49→ * @param {Object} handlerCtx - Handler context\n  50→ */\n  51→export async function handleHistory(handlerCtx) {\n  52→  const { reply, sessionId, args = [] } = handlerCtx;\n  53→\n  54→  // Parse count argument\n  55→  let count = 10;\n  56→  if (args.length > 0) {\n  57→    const parsed = parseInt(args[0], 10);\n  58→    if (Number.isNaN(parsed) || parsed <= 0) {\n  59→      await reply('❌ 参数必须是正整数。用法: /history [N]');\n  60→      return;\n  61→    }\n  62→    count = Math.min(parsed, 100); // Cap at 100\n  63→  }\n  64→\n  65→  // Get command history\n  66→  const history = sessionStore.getCommandHistory(sessionId, count);\n  67→\n  68→  if (history.length === 0) {\n  69→    await reply('📋 暂无命令历史记录。');\n  70→    return;\n  71→  }\n  72→\n  73→  // Format output\n  74→  const lines = [`📋 最近 ${history.length} 条命令历史：`];\n  75→\n  76→  // Show in reverse chronological order (most recent first)\n  77→  const reversedHistory = [...history].reverse();\n  78→\n  79→  for (let i = 0; i < reversedHistory.length; i++) {\n  80→    const entry = reversedHistory[i];\n  81→    const index = history.length - i; // Original index (1-based)\n  82→    const exitCodeStr = entry.exitCode === 0 ? '✓' : `✗(${entry.exitCode})`;\n  83→    const timeStr = formatTimestamp(entry.timestamp);\n  84→    lines.push(`[${index}] ${timeStr} ${exitCodeStr} ${entry.command}`);\n  85→  }\n  86→\n  87→  await reply(lines.join('\\n'));\n  88→}\n  89→\n  90→export default {\n  91→  historyMeta,\n  92→  handleHistory\n  93→};\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_3d7e31db14ef42178fba10ad","__timestamp":"2026-03-12T21:25:00.792Z","_requestId":"30cce9077aca4cd7aed923be6e80b09a"}
{"type":"user","uuid":"540c3c2e-02dd-4581-a245-d0b4565c1e99","session_id":"34f919b8-df8c-46e5-a3ef-c48e25e357c2","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3f03fc130200f0e15fd80481bdc","content":[{"type":"text","text":"   1→/**\n   2→ * Alias Command Handler\n   3→ * F-013: Session and Context Manager\n   4→ *\n   5→ * Handles the /alias command for managing command aliases.\n   6→ */\n   7→\n   8→import { aliasStore } from '../../../services/alias-store.js';\n   9→\n  10→/**\n  11→ * Alias command metadata.\n  12→ */\n  13→export const aliasMeta = {\n  14→  name: 'alias',\n  15→  aliases: [],\n  16→  description: '管理命令别名',\n  17→  usage: '/alias [name=command] 或 /alias del <name>',\n  18→  examples: ['/alias', '/alias ll=ls -la', '/alias del ll'],\n  19→  params: [],\n  20→  requiresAuth: true,\n  21→  minRole: 'operator',\n  22→  helpText: '/alias - 查看别名列表；/alias name=command - 定义别名；/alias del name - 删除别名'\n  23→};\n  24→\n  25→/**\n  26→ * Parse alias definition from string.\n  27→ * @param {string} input - Input string like \"name=command\"\n  28→ * @returns {{ name: string, command: string } | null} Parsed result or null\n  29→ */\n  30→function parseAliasDefinition(input) {\n  31→  const eqIndex = input.indexOf('=');\n  32→  if (eqIndex === -1) {\n  33→    return null;\n  34→  }\n  35→  const name = input.slice(0, eqIndex).trim();\n  36→  const command = input.slice(eqIndex + 1).trim();\n  37→  if (!name || !command) {\n  38→    return null;\n  39→  }\n  40→  return { name, command };\n  41→}\n  42→\n  43→/**\n  44→ * Handle /alias command.\n  45→ * @param {Object} handlerCtx - Handler context\n  46→ */\n  47→export async function handleAlias(handlerCtx) {\n  48→  const { reply, userId, args = [] } = handlerCtx;\n  49→  const userIdStr = String(userId);\n  50→\n  51→  // No args: list all aliases\n  52→  if (args.length === 0) {\n  53→    const aliases = aliasStore.getAllAliases(userIdStr);\n  54→    const aliasNames = Object.keys(aliases);\n  55→\n  56→    if (aliasNames.length === 0) {\n  57→      await reply('📋 您还没有定义任何别名。');\n  58→      return;\n  59→    }\n  60→\n  61→    const lines = ['📋 您的命令别名：'];\n  62→    for (const name of aliasNames.sort()) {\n  63→      lines.push(`  ${name} = ${aliases[name]}`);\n  64→    }\n  65→    lines.push('', '用法: /alias name=command 定义别名，/alias del name 删除别名');\n  66→    await reply(lines.join('\\n'));\n  67→    return;\n  68→  }\n  69→\n  70→  // Check for delete subcommand\n  71→  if (args[0].toLowerCase() === 'del' || args[0].toLowerCase() === 'delete') {\n  72→    if (args.length < 2) {\n  73→      await reply('❌ 用法: /alias del <name>');\n  74→      return;\n  75→    }\n  76→\n  77→    const name = args[1];\n  78→    const deleted = await aliasStore.deleteAlias(userIdStr, name);\n  79→\n  80→    if (deleted) {\n  81→      await reply(`✅ 已删除别名: ${name}`);\n  82→    } else {\n  83→      await reply(`❌ 别名 \"${name}\" 不存在。`);\n  84→    }\n  85→    return;\n  86→  }\n  87→\n  88→  // Parse alias definition\n  89→  const definition = parseAliasDefinition(args.join(' '));\n  90→  if (!definition) {\n  91→    await reply('❌ 用法: /alias name=command 或 /alias del <name>');\n  92→    return;\n  93→  }\n  94→\n  95→  try {\n  96→    await aliasStore.setAlias(userIdStr, definition.name, definition.command);\n  97→    await reply(`✅ 已定义别名: ${definition.name} = ${definition.command}`);\n  98→  } catch (error) {\n  99→    await reply(`❌ ${error.message}`);\n 100→  }\n 101→}\n 102→\n 103→export default {\n 104→  aliasMeta,\n 105→  handleAlias\n 106→};\n 107→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_3d7e31db14ef42178fba10ad","__timestamp":"2026-03-12T21:25:00.792Z","_requestId":"30cce9077aca4cd7aed923be6e80b09a"}
{"type":"user","uuid":"553ac716-347d-461a-9612-7f9e5b629ec4","session_id":"34f919b8-df8c-46e5-a3ef-c48e25e357c2","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3f041b434df099c91892d8d5076","content":[{"type":"text","text":"   1→/**\n   2→ * Sessions Command Handler\n   3→ * F-013: Session and Context Manager\n   4→ *\n   5→ * Handles the /sessions command for viewing all active sessions.\n   6→ * Admin-only command.\n   7→ */\n   8→\n   9→import { sessionStore } from '../../../services/session-store.js';\n  10→\n  11→/**\n  12→ * Sessions command metadata.\n  13→ */\n  14→export const sessionsMeta = {\n  15→  name: 'sessions',\n  16→  aliases: [],\n  17→  description: '查看所有活跃会话（仅管理员）',\n  18→  usage: '/sessions',\n  19→  examples: ['/sessions'],\n  20→  params: [],\n  21→  requiresAuth: true,\n  22→  minRole: 'admin',\n  23→  helpText: '/sessions - 查看所有活跃会话的概要信息（仅管理员）'\n  24→};\n  25→\n  26→/**\n  27→ * Format duration in human-readable form.\n  28→ * @param {number} ms - Duration in milliseconds\n  29→ * @returns {string} Formatted string\n  30→ */\n  31→function formatDuration(ms) {\n  32→  if (ms < 1000) {\n  33→    return `${ms}ms`;\n  34→  }\n  35→  if (ms < 60000) {\n  36→    return `${Math.floor(ms / 1000)}s`;\n  37→  }\n  38→  if (ms < 3600000) {\n  39→    const minutes = Math.floor(ms / 60000);\n  40→    const seconds = Math.floor((ms % 60000) / 1000);\n  41→    return `${minutes}m ${seconds}s`;\n  42→  }\n  43→  const hours = Math.floor(ms / 3600000);\n  44→  const minutes = Math.floor((ms % 3600000) / 60000);\n  45→  return `${hours}h ${minutes}m`;\n  46→}\n  47→\n  48→/**\n  49→ * Truncate string to max length.\n  50→ * @param {string} str - String to truncate\n  51→ * @param {number} maxLen - Maximum length\n  52→ * @returns {string} Truncated string\n  53→ */\n  54→function truncate(str, maxLen) {\n  55→  if (!str) return '(none)';\n  56→  if (str.length <= maxLen) return str;\n  57→  return str.slice(0, maxLen - 3) + '...';\n  58→}\n  59→\n  60→/**\n  61→ * Handle /sessions command.\n  62→ * @param {Object} handlerCtx - Handler context\n  63→ */\n  64→export async function handleSessions(handlerCtx) {\n  65→  const { reply } = handlerCtx;\n  66→\n  67→  // Get all session keys\n  68→  const sessionKeys = sessionStore.getAllSessionKeys();\n  69→\n  70→  if (sessionKeys.length === 0) {\n  71→    await reply('📋 当前没有活跃会话。');\n  72→    return;\n  73→  }\n  74→\n  75→  // Build session list\n  76→  const lines = [`📋 活跃会话 (${sessionKeys.length})：`];\n  77→\n  78→  for (const sessionKey of sessionKeys) {\n  79→    const info = sessionStore.getSessionInfo(sessionKey);\n  80→    if (!info) continue;\n  81→\n  82→    const age = sessionStore.getSessionAge(sessionKey);\n  83→    const idle = sessionStore.getIdleTime(sessionKey);\n  84→\n  85→    lines.push('');\n  86→    lines.push(`📌 ${sessionKey}`);\n  87→    lines.push(`   用户: ${info.userId || '未知'}`);\n  88→    lines.push(`   年龄: ${formatDuration(age)}`);\n  89→    lines.push(`   空闲: ${formatDuration(idle)}`);\n  90→    lines.push(`   目录: ${truncate(info.cwd, 40)}`);\n  91→    lines.push(`   命令数: ${info.commandCount}`);\n  92→  }\n  93→\n  94→  // Add footer\n  95→  lines.push('');\n  96→  lines.push('💡 使用 /reset 清理会话');\n  97→\n  98→  await reply(lines.join('\\n'));\n  99→}\n 100→\n 101→export default {\n 102→  sessionsMeta,\n 103→  handleSessions\n 104→};\n 105→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_3d7e31db14ef42178fba10ad","__timestamp":"2026-03-12T21:25:00.792Z","_requestId":"30cce9077aca4cd7aed923be6e80b09a"}
{"type":"user","uuid":"1d9779bc-58a4-4653-9bdf-863df0b6ce92","session_id":"34f919b8-df8c-46e5-a3ef-c48e25e357c2","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3f043a6fc0a01db7325333f7e83","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20),\n  43→  // F-011: AI CLI Proxy\n  44→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n  45→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n  46→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true'),\n  47→  // F-012: System Monitor\n  48→  SYSTEM_MONITOR_INTERVAL_MS: z.coerce.number().int().positive().default(60000),\n  49→  SYSTEM_MONITOR_DATA_DIR: z.string().optional().default('data'),\n  50→  // F-013: Session and Context Manager\n  51→  SESSION_TIMEOUT_MS: z.coerce.number().int().positive().default(1800000), // 30 min\n  52→  SESSION_HISTORY_MAX: z.coerce.number().int().positive().default(100),\n  53→  SESSION_PERSISTENCE_DIR: z.string().optional().default('data/sessions'),\n  54→  ALIAS_PERSISTENCE_PATH: z.string().optional().default('data/aliases.json')\n  55→});\n  56→\n  57→const parsed = schema.parse(process.env);\n  58→\n  59→function parseAllowedUserIds(input) {\n  60→  return new Set(\n  61→    input\n  62→      .split(',')\n  63→      .map((id) => id.trim())\n  64→      .filter(Boolean)\n  65→  );\n  66→}\n  67→\n  68→function parseCsvList(input) {\n  69→  return input\n  70→    .split(',')\n  71→    .map((item) => item.trim())\n  72→    .filter(Boolean);\n  73→}\n  74→\n  75→function parseBoolean(input) {\n  76→  const normalized = (input ?? '').trim().toLowerCase();\n  77→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  78→}\n  79→\n  80→/**\n  81→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  82→ * Format: \"123456789:admin,987654321:operator\"\n  83→ * @param {string} input\n  84→ * @returns {Map<string, string>}\n  85→ */\n  86→function parseUserPermissions(input) {\n  87→  const permissions = new Map();\n  88→  if (!input || !input.trim()) {\n  89→    return permissions;\n  90→  }\n  91→\n  92→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  93→  for (const entry of entries) {\n  94→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  95→    if (userId && role) {\n  96→      const normalizedRole = role.toLowerCase();\n  97→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  98→        permissions.set(userId, normalizedRole);\n  99→      }\n 100→    }\n 101→  }\n 102→  return permissions;\n 103→}\n 104→\n 105→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n 106→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n 107→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 108→}\n 109→\n 110→const pipelineInfra = loadPipelineInfraConfig({\n 111→  env: process.env,\n 112→  argv: process.argv.slice(2),\n 113→  cwd: process.cwd()\n 114→});\n 115→\n 116→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 117→\n 118→export const config = Object.freeze({\n 119→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 120→  enableTelegram,\n 121→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 122→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 123→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 124→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 125→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 126→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 127→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 128→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 129→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 130→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 131→  webHost: parsed.WEB_HOST,\n 132→  webPort: parsed.WEB_PORT,\n 133→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 134→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 135→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 136→  logLevel: parsed.LOG_LEVEL,\n 137→  // F-006: Safety and Permission Guard\n 138→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 139→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 140→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 141→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 142→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 143→  // F-009: General Command Executor\n 144→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 145→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 146→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 147→  // F-010: File Manager\n 148→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 149→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 150→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 151→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 152→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 153→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 154→  // F-011: AI CLI Proxy\n 155→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\