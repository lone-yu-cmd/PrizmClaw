z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20),\n  43→  // F-011: AI CLI Proxy\n  44→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n  45→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n  46→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true'),\n  47→  // F-012: System Monitor\n  48→  SYSTEM_MONITOR_INTERVAL_MS: z.coerce.number().int().positive().default(60000),\n  49→  SYSTEM_MONITOR_DATA_DIR: z.string().optional().default('data'),\n  50→  // F-013: Session and Context Manager\n  51→  SESSION_TIMEOUT_MS: z.coerce.number().int().positive().default(1800000), // 30 min\n  52→  SESSION_HISTORY_MAX: z.coerce.number().int().positive().default(100),\n  53→  SESSION_PERSISTENCE_DIR: z.string().optional().default('data/sessions'),\n  54→  ALIAS_PERSISTENCE_PATH: z.string().optional().default('data/aliases.json')\n  55→});\n  56→\n  57→const parsed = schema.parse(process.env);\n  58→\n  59→function parseAllowedUserIds(input) {\n  60→  return new Set(\n  61→    input\n  62→      .split(',')\n  63→      .map((id) => id.trim())\n  64→      .filter(Boolean)\n  65→  );\n  66→}\n  67→\n  68→function parseCsvList(input) {\n  69→  return input\n  70→    .split(',')\n  71→    .map((item) => item.trim())\n  72→    .filter(Boolean);\n  73→}\n  74→\n  75→function parseBoolean(input) {\n  76→  const normalized = (input ?? '').trim().toLowerCase();\n  77→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  78→}\n  79→\n  80→/**\n  81→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  82→ * Format: \"123456789:admin,987654321:operator\"\n  83→ * @param {string} input\n  84→ * @returns {Map<string, string>}\n  85→ */\n  86→function parseUserPermissions(input) {\n  87→  const permissions = new Map();\n  88→  if (!input || !input.trim()) {\n  89→    return permissions;\n  90→  }\n  91→\n  92→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  93→  for (const entry of entries) {\n  94→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  95→    if (userId && role) {\n  96→      const normalizedRole = role.toLowerCase();\n  97→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  98→        permissions.set(userId, normalizedRole);\n  99→      }\n 100→    }\n 101→  }\n 102→  return permissions;\n 103→}\n 104→\n 105→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n 106→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n 107→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 108→}\n 109→\n 110→const pipelineInfra = loadPipelineInfraConfig({\n 111→  env: process.env,\n 112→  argv: process.argv.slice(2),\n 113→  cwd: process.cwd()\n 114→});\n 115→\n 116→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 117→\n 118→export const config = Object.freeze({\n 119→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 120→  enableTelegram,\n 121→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 122→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 123→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 124→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 125→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 126→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 127→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 128→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 129→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 130→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 131→  webHost: parsed.WEB_HOST,\n 132→  webPort: parsed.WEB_PORT,\n 133→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 134→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 135→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 136→  logLevel: parsed.LOG_LEVEL,\n 137→  // F-006: Safety and Permission Guard\n 138→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 139→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 140→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 141→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 142→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 143→  // F-009: General Command Executor\n 144→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 145→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 146→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 147→  // F-010: File Manager\n 148→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 149→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 150→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 151→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 152→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 153→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 154→  // F-011: AI CLI Proxy\n 155→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 156→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 157→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 158→  // F-012: System Monitor\n 159→  systemMonitorIntervalMs: parsed.SYSTEM_MONITOR_INTERVAL_MS,\n 160→  systemMonitorDataDir: parsed.SYSTEM_MONITOR_DATA_DIR,\n 161→  // F-013: Session and Context Manager\n 162→  sessionTimeoutMs: parsed.SESSION_TIMEOUT_MS,\n 163→  sessionHistoryMax: parsed.SESSION_HISTORY_MAX,\n 164→  sessionPersistenceDir: parsed.SESSION_PERSISTENCE_DIR,\n 165→  aliasPersistencePath: parsed.ALIAS_PERSISTENCE_PATH,\n 166→  pipelineInfra: Object.freeze({\n 167→    ...pipelineInfra,\n 168→    daemonLogPaths\n 169→  })\n 170→});\n 171→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_1270175d963e43709105fcf4","__timestamp":"2026-03-12T21:19:22.226Z","_requestId":"47d23dc854de4b359e56f15c300d9539"}
{"type":"user","uuid":"5b32580a-168d-4d8b-82ec-19d6a712c302","session_id":"34f919b8-df8c-46e5-a3ef-c48e25e357c2","message":{"content":[{"type":"tool_result","tool_use_id":"call_c7d60b4fa03744b283e9b05b","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  /** @type {Record<string, string>} */\n 215→  const map = {};\n 216→  for (const [alias, command] of aliasToCommand) {\n 217→    map[alias] = command;\n 218→  }\n 219→  return map;\n 220→}\n 221→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_c7d60b4fa03744b283e9b05b","__timestamp":"2026-03-12T21:19:22.228Z","_requestId":"47d23dc854de4b359e56f15c300d9539"}
{"type":"user","uuid":"182a4431-8bb7-401e-ba9b-227753994ef6","session_id":"34f919b8-df8c-46e5-a3ef-c48e25e357c2","message":{"content":[{"type":"tool_result","tool_use_id":"call_58e87c110fc04e759b294212","content":[{"type":"text","text":"   1→import { Telegraf } from 'telegraf';\n   2→import { createReadStream } from 'node:fs';\n   3→import { access, stat } from 'node:fs/promises';\n   4→import os from 'node:os';\n   5→import path from 'node:path';\n   6→import { config } from '../config.js';\n   7→import { logger } from '../utils/logger.js';\n   8→import { isAllowedUser } from '../security/guard.js';\n   9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n  10→import { executeAiCli, interruptAiCli, isAiCliRunning } from '../services/ai-cli-service.js';\n  11→import { captureScreenshot } from '../services/screenshot-service.js';\n  12→import { executeCommand, confirmHighRiskCommand } from '../services/command-executor-service.js';\n  13→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n  14→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n  15→import { registerCommand } from './commands/index.js';\n  16→import { routeCommand } from './commands/index.js';\n  17→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n  18→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n  19→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n  20→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n  21→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n  22→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n  23→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n  24→import { auditMeta, handleAudit } from './commands/handlers/audit.js';\n  25→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n  26→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n  27→// F-009: New command handlers\n  28→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n  29→import { moreMeta, handleMore } from './commands/handlers/more.js';\n  30→// F-010: File Manager command handlers\n  31→import { lsMeta, handleLs } from './commands/handlers/ls.js';\n  32→import { treeMeta, handleTree } from './commands/handlers/tree.js';\n  33→import { catMeta, handleCat } from './commands/handlers/cat.js';\n  34→import { headMeta, handleHead } from './commands/handlers/head.js';\n  35→import { tailMeta, handleTail } from './commands/handlers/tail.js';\n  36→import { findMeta, handleFind } from './commands/handlers/find.js';\n  37→import { uploadMeta, handleUpload } from './commands/handlers/upload.js';\n  38→import { downloadMeta, handleDownload } from './commands/handlers/download.js';\n  39→// F-012: System Monitor command handlers\n  40→import { sysinfoMeta, handleSysinfo } from './commands/handlers/sysinfo.js';\n  41→import { psMeta, handlePs } from './commands/handlers/ps.js';\n  42→import { killMeta, handleKill } from './commands/handlers/kill.js';\n  43→import { monitorMeta, handleMonitor } from './commands/handlers/monitor.js';\n  44→// F-013: Session and Context Manager command handlers\n  45→import { historyMeta, handleHistory } from './commands/handlers/history.js';\n  46→import { aliasMeta, handleAlias } from './commands/handlers/alias.js';\n  47→import { sessionsMeta, handleSessions } from './commands/handlers/sessions.js';\n  48→import { generateHelp } from './commands/help.js';\n  49→import { sessionStore } from '../services/session-store.js';\n  50→import { sessionContextService } from '../services/session-context-service.js';\n  51→import { aliasStore } from '../services/alias-store.js';\n  52→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n  53→\n  54→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  55→const STREAM_MIN_CHARS = 220;\n  56→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  57→const TYPING_INTERVAL_MS = 3500;\n  58→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  59→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  60→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  61→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  62→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  63→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  64→const TMP_DIR = path.resolve(os.tmpdir());\n  65→const HOME_DIR = path.resolve(os.homedir());\n  66→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  67→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  68→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  69→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  70→\n  71→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  72→  const normalized = configuredDirs\n  73→    .map((dir) => String(dir ?? '').trim())\n  74→    .filter(Boolean)\n  75→    .map((dir) => path.resolve(dir));\n  76→\n  77→  if (normalized.length > 0) {\n  78→    return [...new Set(normalized)];\n  79→  }\n  80→\n  81→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  82→}\n  83→\n  84→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  85→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  86→\n  87→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  88→  const chunks = [];\n  89→  for (let i = 0; i < text.length; i += chunkSize) {\n  90→    chunks.push(text.slice(i, i + chunkSize));\n  91→  }\n  92→  return chunks;\n  93→}\n  94→\n  95→function sanitizeMarkerPath(raw) {\n  96→  return String(raw ?? '')\n  97→    .trim()\n  98→    .replace(/^['\"`]+/, '')\n  99→    .replace(/['\"`]+$/, '');\n 100→}\n 101→\n 102→function extractFileMarkers(text = '') {\n 103→  const fileRefs = [];\n 104→\n 105→  const withSendFileRemoved = text.replace(\n 106→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n 107→    (_full, rawRef) => {\n 108→      const ref = sanitizeMarkerPath(rawRef);\n 109→      if (ref) {\n 110→        fileRefs.push(ref);\n 111→      }\n 112→      return '\\n';\n 113→    }\n 114→  );\n 115→\n 116→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n 117→    const ref = sanitizeMarkerPath(rawRef);\n 118→    if (ref) {\n 119→      fileRefs.push(ref);\n 120→    }\n 121→    return '';\n 122→  });\n 123→\n 124→  const withBacktickPathRemoved = withImageRemoved.replace(\n 125→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 126→    (_full, rawRef) => {\n 127→      const ref = sanitizeMarkerPath(rawRef);\n 128→      if (ref) {\n 129→        fileRefs.push(ref);\n 130→      }\n 131→      return '';\n 132→    }\n 133→  );\n 134→\n 135→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 136→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 137→    (_full, rawRef) => {\n 138→      const ref = sanitizeMarkerPath(rawRef);\n 139→      if (ref) {\n 140→        fileRefs.push(ref);\n 141→      }\n 142→      return '';\n 143→    }\n 144→  );\n 145→\n 146→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 147→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 148→    (_full, rawRef) => {\n 149→      const ref = sanitizeMarkerPath(rawRef);\n 150→      if (ref) {\n 151→        fileRefs.push(ref);\n 152→      }\n 153→      return '\\n';\n 154→    }\n 155→  );\n 156→\n 157→  return {\n 158→    fileRefs: [...new Set(fileRefs)],\n 159→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 160→  };\n 161→}\n 162→\n 163→function isPathWithinRoot(targetPath, rootPath) {\n 164→  const relative = path.relative(rootPath, targetPath);\n 165→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 166→}\n 167→\n 168→function isAllowedFilePath(filePath) {\n 169→  const resolved = path.resolve(filePath);\n 170→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 171→}\n 172→\n 173→function buildFileCandidates(normalizedPath) {\n 174→  if (path.isAbsolute(normalizedPath)) {\n 175→    return [normalizedPath];\n 176→  }\n 177→\n 178→  const baseName = path.basename(normalizedPath);\n 179→  const candidates = [\n 180→    path.resolve(process.cwd(), normalizedPath),\n 181→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 182→  ];\n 183→\n 184→  return [...new Set(candidates)];\n 185→}\n 186→\n 187→async function resolveLocalFilePath(fileRef) {\n 188→  const normalized = sanitizeMarkerPath(fileRef);\n 189→  if (!normalized) {\n 190→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 191→  }\n 192→\n 193→  if (!path.isAbsolute(normalized)) {\n 194→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 195→  }\n 196→\n 197→  const candidates = buildFileCandidates(normalized);\n 198→\n 199→  for (const candidate of candidates) {\n 200→    try {\n 201→      await access(candidate);\n 202→      return { filePath: candidate, triedPaths: candidates };\n 203→    } catch {\n 204→      // ignore\n 205→    }\n 206→  }\n 207→\n 208→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 209→}\n 210→\n 211→async function validateFileForTelegram(filePath) {\n 212→  const resolvedPath = path.resolve(filePath);\n 213→  if (!isAllowedFilePath(resolvedPath)) {\n 214→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 215→  }\n 216→\n 217→  const ext = path.extname(resolvedPath).toLowerCase();\n 218→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 219→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 220→  }\n 221→\n 222→  const fileStat = await stat(resolvedPath);\n 223→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 224→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 225→\n 226→  if (fileStat.size > maxSize) {\n 227→    return {\n 228→      ok: false,\n 229→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 230→    };\n 231→  }\n 232→\n 233→  return { ok: true, isPhoto, resolvedPath };\n 234→}\n 235→\n 236→function isTimeoutLikeError(message = '') {\n 237→  const normalized = String(message).toLowerCase();\n 238→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 239→}\n 240→\n 241→function sleep(ms) {\n 242→  return new Promise((resolve) => setTimeout(resolve, ms));\n 243→}\n 244→\n 245→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 246→  if (isPhoto) {\n 247→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 248→    return;\n 249→  }\n 250→\n 251→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 252→}\n 253→\n 254→async function replyFiles(ctx, fileRefs = []) {\n 255→  const results = [];\n 256→\n 257→  for (const fileRef of fileRefs) {\n 258→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 259→    if (!filePath) {\n 260→      const reason = rejectReason || 'not_found';\n 261→      results.push({ fileRef, sent: false, reason, triedPaths });\n 262→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 263→      continue;\n 264→    }\n 265→\n 266→    try {\n 267→      const validation = await validateFileForTelegram(filePath);\n 268→      if (!validation.ok) {\n 269→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 270→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 271→        continue;\n 272→      }\n 273→\n 274→      const actualPath = validation.resolvedPath;\n 275→      let sent = false;\n 276→      let lastReason = '';\n 277→\n 278→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 279→        try {\n 280→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 281→          sent = true;\n 282→          logger.info(\n 283→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 284→            'Telegram file sent'\n 285→          );\n 286→          break;\n 287→        } catch (error) {\n 288→          lastReason = error instanceof Error ? error.message : String(error);\n 289→          logger.warn(\n 290→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 291→            'Telegram file send attempt failed'\n 292→          );\n 293→\n 294→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 295→            await sleep(600);\n 296→            continue;\n 297→          }\n 298→\n 299→          break;\n 300→        }\n 301→      }\n 302→\n 303→      if (!sent) {\n 304→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 305→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 306→        continue;\n 307→      }\n 308→\n 309→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 310→    } catch (error) {\n 311→      const reason = error instanceof Error ? error.message : String(error);\n 312→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 313→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 314→    }\n 315→  }\n 316→\n 317→  return results;\n 318→}\n 319→\n 320→async function safeReply(ctx, text) {\n 321→  try {\n 322→    await ctx.reply(text);\n 323→    return true;\n 324→  } catch (error) {\n 325→    const reason = error instanceof Error ? error.message : String(error);\n 326→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 327→    return false;\n 328→  }\n 329→}\n 330→\n 331→async function replyLargeText(ctx, text) {\n 332→  const chunks = splitMessage(text);\n 333→  for (const chunk of chunks) {\n 334→    const ok = await safeReply(ctx, chunk);\n 335→    if (!ok) {\n 336→      break;\n 337→    }\n 338→  }\n 339→}\n 340→\n 341→async function safeEditMessageText(ctx, messageId, text) {\n 342→  const nextText = text && text.trim() ? text : ' ';\n 343→\n 344→  try {\n 345→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 346→  } catch (error) {\n 347→    const message = error instanceof Error ? error.message : String(error);\n 348→    if (message.includes('message is not modified')) {\n 349→      return;\n 350→    }\n 351→    throw error;\n 352→  }\n 353→}\n 354→\n 355→function createEditableStreamPublisher(ctx) {\n 356→  let fullText = '';\n 357→  let renderedText = '';\n 358→  let pendingChars = 0;\n 359→  let lastFlushAt = 0;\n 360→  let flushChain = Promise.resolve();\n 361→  let activeMessage = null;\n 362→  let activeSegmentIndex = 0;\n 363→  let publishedMessageCount = 0;\n 364→\n 365→  async function ensureActiveMessage() {\n 366→    if (activeMessage) {\n 367→      return;\n 368→    }\n 369→    activeMessage = await ctx.reply('处理中...');\n 370→    activeSegmentIndex = 0;\n 371→    publishedMessageCount += 1;\n 372→  }\n 373→\n 374→  async function render(force = false) {\n 375→    const now = Date.now();\n 376→\n 377→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 378→      return;\n 379→    }\n 380→\n 381→    if (fullText === renderedText) {\n 382→      pendingChars = 0;\n 383→      return;\n 384→    }\n 385→\n 386→    await ensureActiveMessage();\n 387→\n 388→    const segments = splitMessage(fullText);\n 389→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 390→\n 391→    while (activeSegmentIndex < targetLastIndex) {\n 392→      const text = segments[activeSegmentIndex] ?? ' ';\n 393→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 394→\n 395→      activeMessage = await ctx.reply('继续输出中...');\n 396→      activeSegmentIndex += 1;\n 397→      publishedMessageCount += 1;\n 398→    }\n 399→\n 400→    const activeText = segments[targetLastIndex] ?? ' ';\n 401→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 402→\n 403→    renderedText = fullText;\n 404→    pendingChars = 0;\n 405→    lastFlushAt = now;\n 406→  }\n 407→\n 408→  function enqueueRender(force = false) {\n 409→    flushChain = flushChain.then(() => render(force));\n 410→  }\n 411→\n 412→  return {\n 413→    push(text) {\n 414→      const appendText = text ?? '';\n 415→      if (!appendText) {\n 416→        return;\n 417→      }\n 418→      fullText += appendText;\n 419→      pendingChars += appendText.length;\n 420→      enqueueRender(false);\n 421→    },\n 422→    setFinalText(text) {\n 423→      fullText = text ?? '';\n 424→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 425→      enqueueRender(true);\n 426→    },\n 427→    async finish() {\n 428→      enqueueRender(true);\n 429→      await flushChain;\n 430→      return {\n 431→        outputLength: renderedText.length,\n 432→        messageCount: publishedMessageCount\n 433→      };\n 434→    }\n 435→  };\n 436→}\n 437→\n 438→function buildSessionId(ctx) {\n 439→  return String(ctx.chat.id);\n 440→}\n 441→\n 442→function ensureAllowed(ctx) {\n 443→  const userId = ctx.from?.id;\n 444→  if (!isAllowedUser(userId)) {\n 445→    throw new Error('当前账号未被授权使用该机器人。');\n 446→  }\n 447→}\n 448→\n 449→/**\n 450→ * Register all pipeline-related commands.\n 451→ */\n 452→function registerPipelineCommands() {\n 453→  registerCommand(pipelineMeta, handlePipeline);\n 454→  registerCommand(bugfixMeta, handleBugfix);\n 455→  registerCommand(plannerMeta, handlePlanner);\n 456→  registerCommand(statusMeta, handleStatus);\n 457→  registerCommand(logsMeta, handleLogs);\n 458→  registerCommand(stopMeta, handleStop);\n 459→  registerCommand(planMeta, handlePlan);\n 460→  registerCommand(auditMeta, handleAudit);\n 461→  registerCommand(commitMeta, handleCommit);\n 462→  registerCommand(commitsMeta, handleCommits);\n 463→  // F-009: New commands\n 464→  registerCommand(cdMeta, handleCd);\n 465→  registerCommand(moreMeta, handleMore);\n 466→  // F-010: File Manager commands\n 467→  registerCommand(lsMeta, handleLs);\n 468→  registerCommand(treeMeta, handleTree);\n 469→  registerCommand(catMeta, handleCat);\n 470→  registerCommand(headMeta, handleHead);\n 471→  registerCommand(tailMeta, handleTail);\n 472→  registerCommand(findMeta, handleFind);\n 473→  registerCommand(uploadMeta, handleUpload);\n 474→  registerCommand(downloadMeta, handleDownload);\n 475→  // F-012: System Monitor commands\n 476→  registerCommand(sysinfoMeta, handleSysinfo);\n 477→  registerCommand(psMeta, handlePs);\n 478→  registerCommand(killMeta, handleKill);\n 479→  registerCommand(monitorMeta, handleMonitor);\n 480→  // F-013: Session and Context Manager commands\n 481→  registerCommand(historyMeta, handleHistory);\n 482→  registerCommand(aliasMeta, handleAlias);\n 483→  registerCommand(sessionsMeta, handleSessions);\n 484→}\n 485→\n 486→export async function createTelegramBot() {\n 487→  const bot = new Telegraf(config.telegramBotToken, {\n 488→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 489→  });\n 490→\n 491→  // F-013: Initialize session context service\n 492→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n 493→  await aliasStore.initAliasStore({ filePath: config.aliasPersistencePath });\n 494→\n 495→  // F-013: Restore sessions from disk\n 496→  await sessionContextService.restoreSessions();\n 497→\n 498→  // F-013: Set up notification callback for session timeout\n 499→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n 500→    try {\n 501→      // Extract chat ID from session key (format: telegram:123456789)\n 502→      const chatId = sessionKey.replace('telegram:', '');\n 503→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n 504→    } catch (error) {\n 505→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n 506→    }\n 507→  });\n 508→\n 509→  // F-013: Start timeout watcher\n 510→  sessionContextService.startTimeoutWatcher();\n 511→\n 512→  // Register pipeline commands\n 513→  registerPipelineCommands();\n 514→\n 515→  bot.catch((error, ctx) => {\n 516→    const message = error instanceof Error ? error.message : String(error);\n 517→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 518→  });\n 519→\n 520→  bot.start(async (ctx) => {\n 521→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 522→  });\n 523→\n 524→  bot.help(async (ctx) => {\n 525→    const helpText = generateHelp();\n 526→    await ctx.reply(helpText);\n 527→  });\n 528→\n 529→  bot.command('reset', async (ctx) => {\n 530→    try {\n 531→      ensureAllowed(ctx);\n 532→      const sessionId = buildSessionId(ctx);\n 533→\n 534→      // F-011: Interrupt any running AI CLI task\n 535→      if (isAiCliRunning(sessionId)) {\n 536→        interruptAiCli(sessionId);\n 537→      }\n 538→\n 539→      resetSession({ channel: 'telegram', sessionId });\n 540→      await ctx.reply('已清空当前会话上下文。');\n 541→    } catch (error) {\n 542→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 543→    }\n 544→  });\n 545→\n 546→  bot.command('screenshot', async (ctx) => {\n 547→    try {\n 548→      ensureAllowed(ctx);\n 549→      await ctx.reply('正在获取截图。');\n 550→      const { buffer } = await captureScreenshot();\n 551→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 552→    } catch (error) {\n 553→      const message = error instanceof Error ? error.message : String(error);\n 554→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 555→      await ctx.reply(`截图失败：${message}`);\n 556→    }\n 557→  });\n 558→\n 559→  bot.command('exec', async (ctx) => {\n 560→    try {\n 561→      ensureAllowed(ctx);\n 562→      const payload = ctx.message.text.replace('/exec', '').trim();\n 563→      if (!payload) {\n 564→        await ctx.reply('请提供命令，例如 /exec pwd');\n 565→        return;\n 566→      }\n 567→\n 568→      const sessionId = buildSessionId(ctx);\n 569→      const userId = ctx.from?.id;\n 570→\n 571→      await ctx.reply('正在执行命令...');\n 572→      const result = await executeCommand({\n 573→        command: payload,\n 574→        sessionId,\n 575→        userId\n 576→      });\n 577→\n 578→      // Handle confirmation required\n 579→      if (result.needsConfirmation) {\n 580→        await ctx.reply(result.confirmationMessage);\n 581→        return;\n 582→      }\n 583→\n 584→      // Send output\n 585→      await replyLargeText(ctx, result.output);\n 586→\n 587→      // Indicate if more pages available\n 588→      if (result.hasMorePages) {\n 589→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 590→      }\n 591→    } catch (error) {\n 592→      const message = error instanceof Error ? error.message : String(error);\n 593→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 594→      await ctx.reply(`执行失败：${message}`);\n 595→    }\n 596→  });\n 597→\n 598→  // F-009: /cd command handler\n 599→  bot.command('cd', async (ctx) => {\n 600→    try {\n 601→      ensureAllowed(ctx);\n 602→      const payload = ctx.message.text.replace('/cd', '').trim();\n 603→      const sessionId = buildSessionId(ctx);\n 604→\n 605→      await handleCd({\n 606→        ctx,\n 607→        reply: (msg) => ctx.reply(msg),\n 608→        params: {},\n 609→        userId: ctx.from?.id,\n 610→        sessionId,\n 611→        args: payload ? [payload] : []\n 612→      });\n 613→    } catch (error) {\n 614→      const message = error instanceof Error ? error.message : String(error);\n 615→      logger.error({ err: message }, 'Failed to cd in telegram');\n 616→      await ctx.reply(`切换目录失败：${message}`);\n 617→    }\n 618→  });\n 619→\n 620→  // F-009: /more command handler\n 621→  bot.command('more', async (ctx) => {\n 622→    try {\n 623→      ensureAllowed(ctx);\n 624→      const sessionId = buildSessionId(ctx);\n 625→\n 626→      await handleMore({\n 627→        ctx,\n 628→        reply: (msg) => ctx.reply(msg),\n 629→        params: {},\n 630→        userId: ctx.from?.id,\n 631→        sessionId\n 632→      });\n 633→    } catch (error) {\n 634→      const message = error instanceof Error ? error.message : String(error);\n 635→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 636→      await ctx.reply(`获取更多输出失败：${message}`);\n 637→    }\n 638→  });\n 639→\n 640→  // T-100: Document upload handler for plan files\n 641→  bot.on('document', async (ctx) => {\n 642→    try {\n 643→      ensureAllowed(ctx);\n 644→\n 645→      const document = ctx.message?.document;\n 646→      if (!document) {\n 647→        return;\n 648→      }\n 649→\n 650→      // Check file extension\n 651→      const fileName = document.file_name || '';\n 652→      const ext = path.extname(fileName).toLowerCase();\n 653→\n 654→      if (ext !== '.json') {\n 655→        // Not a JSON file, ignore silently (other handlers may process it)\n 656→        return;\n 657→      }\n 658→\n 659→      // Check file size\n 660→      const fileSize = document.file_size || 0;\n 661→      if (fileSize > 1024 * 1024) { // 1MB limit\n 662→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 663→        return;\n 664→      }\n 665→\n 666→      await ctx.reply('正在处理上传的计划文件...');\n 667→\n 668→      // Download file content\n 669→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 670→      const fileUrl = fileLink.href || fileLink.toString();\n 671→\n 672→      const response = await fetch(fileUrl);\n 673→      if (!response.ok) {\n 674→        throw new Error(`下载文件失败: ${response.status}`);\n 675→      }\n 676→\n 677→      const content = await response.text();\n 678→\n 679→      // Validate and save using plan-ingestion-service\n 680→      const infraConfig = loadPipelineInfraConfig();\n 681→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 682→\n 683→      const validationResult = planService.validate(content);\n 684→\n 685→      if (!validationResult.valid) {\n 686→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 687→        await ctx.reply(errorMsg);\n 688→        return;\n 689→      }\n 690→\n 691→      // Save the plan\n 692→      const saveResult = await planService.save(\n 693→        validationResult.type,\n 694→        content,\n 695→        { uploadedBy: ctx.from?.id }\n 696→      );\n 697→\n 698→      if (!saveResult.success) {\n 699→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 700→        return;\n 701→      }\n 702→\n 703→      // Set as current version\n 704→      await planService.setCurrent(validationResult.type, saveResult.version);\n 705→\n 706→      // Format success message\n 707→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 708→      const summary = validationResult.summary;\n 709→\n 710→      await ctx.reply([\n 711→        `✅ ${typeDisplay}已保存并激活`,\n 712→        `版本: ${saveResult.version}`,\n 713→        `名称: ${summary?.name || '未知'}`,\n 714→        `项目数: ${summary?.itemCount || 0}`,\n 715→        '',\n 716→        summary?.statusBreakdown ? '状态分布:' : '',\n 717→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 718→      ].filter(Boolean).join('\\n'));\n 719→\n 720→    } catch (error) {\n 721→      const message = error instanceof Error ? error.message : String(error);\n 722→      logger.error({ err: message }, 'Failed to process document upload');\n 723→      await ctx.reply(`❌ 处理失败：${message}`);\n 724→    }\n 725→  });\n 726→\n 727→  bot.on('text', async (ctx) => {\n 728→    // Check for pipeline commands first\n 729→    const handled = await routeCommand(ctx);\n 730→    if (handled) {\n 731→      return;\n 732→    }\n 733→\n 734→    const sessionId = buildSessionId(ctx);\n 735→    const userId = ctx.from?.id;\n 736→\n 737→    // F-009: Direct exec mode - treat plain text as command when enabled\n 738→    if (config.directExecMode && config.enableSystemExec) {\n 739→      try {\n 740→        ensureAllowed(ctx);\n 741→        const command = ctx.message.text;\n 742→\n 743→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 744→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 745→\n 746→        if (!isLikelyChat) {\n 747→          await ctx.reply('正在执行命令...');\n 748→          const result = await executeCommand({\n 749→            command,\n 750→            sessionId,\n 751→            userId\n 752→          });\n 753→\n 754→          if (result.needsConfirmation) {\n 755→            await ctx.reply(result.confirmationMessage);\n 756→            return;\n 757→          }\n 758→\n 759→          await replyLargeText(ctx, result.output);\n 760→\n 761→          if (result.hasMorePages) {\n 762→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 763→          }\n 764→          return;\n 765→        }\n 766→      } catch (error) {\n 767→        const message = error instanceof Error ? error.message : String(error);\n 768→        // If exec fails, fall through to chat mode\n 769→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n 770→      }\n 771→    }\n 772→\n 773→    // F-011: Check if AI CLI is already running\n 774→    if (isAiCliRunning(sessionId)) {\n 775→      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n 776→      return;\n 777→    }\n 778→\n 779→    let typingTimer = null;\n 780→\n 781→    try {\n 782→      ensureAllowed(ctx);\n 783→      await ctx.sendChatAction('typing');\n 784→\n 785→      const streamPublisher = createEditableStreamPublisher(ctx);\n 786→      typingTimer = setInterval(() => {\n 787→        ctx.sendChatAction('typing').catch(() => undefined);\n 788→      }, TYPING_INTERVAL_MS);\n 789→\n 790→      // F-011: Use ai-cli-service for execution with process tracking\n 791→      const sessionKey = `telegram:${sessionId}`;\n 792→\n 793→      // Append user message to session history\n 794→      sessionStore.append(sessionKey, 'user', ctx.message.text);\n 795→\n 796→      // Build prompt with context\n 797→      const prompt = sessionStore.toPrompt(sessionKey, 'telegram');\n 798→\n 799→      // Track last heartbeat message for updates\n 800→      /** @type {{ message_id: number } | null} */\n 801→      let lastHeartbeatMsg = null;\n 802→\n 803→      const result = await executeAiCli({\n 804→        sessionId,\n 805→        prompt,\n 806→        hooks: {\n 807→          onChunk: (text) => {\n 808→            streamPublisher.push(text);\n 809→          },\n 810→          onHeartbeat: config.aiCliEnableHeartbeat ? (info) => {\n 811→            // Send/update heartbeat progress message\n 812→            const elapsedSec = Math.floor(info.elapsedMs / 1000);\n 813→            const progressText = `⏳ 任务执行中... (${elapsedSec}s, ${Math.floor(info.stdoutBytes / 1024)}KB)`;\n 814→\n 815→            // Don't await - fire and forget\n 816→            if (lastHeartbeatMsg) {\n 817→              ctx.telegram.editMessageText(ctx.chat.id, lastHeartbeatMsg.message_id, undefined, progressText)\n 818→                .catch(() => {});\n 819→            } else {\n 820→              ctx.reply(progressText)\n 821→                .then((msg) => { lastHeartbeatMsg = msg; })\n 822→                .catch(() => {});\n 823→            }\n 824→          } : undefined,\n 825→          onStatus: (status) => {\n 826→            if (status === 'running') {\n 827→              ctx.sendChatAction('typing').catch(() => undefined);\n 828→            }\n 829→          }\n 830→        }\n 831→      });\n 832→\n 833→      // Delete heartbeat message if exists\n 834→      if (lastHeartbeatMsg) {\n 835→        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n 836→      }\n 837→\n 838→      // Append assistant reply to session history\n 839→      sessionStore.append(sessionKey, 'assistant', result.output);\n 840→\n 841→      // F-011: Format output with MarkdownV2\n 842→      const formattedOutput = convertToMarkdownV2(result.output);\n 843→\n 844→      // Handle result states\n 845→      if (result.interrupted) {\n 846→        await ctx.reply('⏹️ 任务已被中断。');\n 847→      } else if (result.timedOut) {\n 848→        await ctx.reply(`⏰ 任务执行超时。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n 849→      }\n 850→\n 851→      // Extract file markers and send\n 852→      const { fileRefs, cleanedText } = extractFileMarkers(result.output);\n 853→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 854→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 855→\n 856→      streamPublisher.setFinalText(finalText);\n 857→      const streamed = await streamPublisher.finish();\n 858→      if (streamed.outputLength === 0) {\n 859→        await replyLargeText(ctx, finalText);\n 860→      }\n 861→\n 862→      if (fileRefs.length > 0) {\n 863→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 864→        const failed = fileSendResults.filter((item) => !item.sent);\n 865→\n 866→        if (failed.length === 0) {\n 867→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 868→        } else {\n 869→          const failedList = failed\n 870→            .map((item) => {\n 871→              const reason =\n 872→                item.reason === 'relative_path_not_allowed'\n 873→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 874→                  : item.reason === 'not_found'\n 875→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 876→                    : item.reason;\n 877→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 878→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 879→            })\n 880→            .join('\\n');\n 881→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 882→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 883→        }\n 884→      }\n 885→    } catch (error) {\n 886→      const message = error instanceof Error ? error.message : String(error);\n 887→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 888→      await safeReply(ctx, `处理失败：${message}`);\n 889→    } finally {\n 890→      if (typingTimer) {\n 891→        clearInterval(typingTimer);\n 892→      }\n 893→    }\n 894→  });\n 895→\n 896→  return bot;\n 897→}\n 898→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_58e87c110fc04e759b294212","__timestamp":"2026-03-12T21:19:22.229Z","_requestId":"47d23dc854de4b359e56f15c300d9539"}
