w/tests/integration/f010-file-manager.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/upload.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/config/f011-config.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/session-store-f011.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/utils/heartbeat-manager.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/utils/markdown-v2-formatter.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/ai-cli-service.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/ai-cli-markdownv2.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/ai-cli-telegram.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/ai-cli-heartbeat.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/ai-cli-error-handling.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f011-comprehensive.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/system-monitor-service.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/alert-manager-service.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/sysinfo.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/ps.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/kill.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/monitor.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f012-system-monitor.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/config-f013.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/session-store-f013.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/session-context-service.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/history.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/bot/commands/handlers/alias.test.js\",\"/Users/loneyu/SelfProjects/PrizmClaw/tests/