{"type":"user","uuid":"4b15f6d1-48d1-41c3-9f15-b2c5fcaf0151","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"call_88b4dc43fe424034b85f5518","content":[{"type":"text","text":"   1→/**\n   2→ * Tests for F-014 Scheduled Task Service\n   3→ * Phase 2: ScheduledTaskService implementation\n   4→ */\n   5→\n   6→import { describe, test, beforeEach, afterEach } from 'node:test';\n   7→import assert from 'node:assert/strict';\n   8→import { mkdir, rm, readFile, writeFile } from 'node:fs/promises';\n   9→import path from 'node:path';\n  10→import { tmpdir } from 'node:os';\n  11→import { Cron } from 'croner';\n  12→\n  13→describe('F-014 ScheduledTaskService', () => {\n  14→  let scheduledTaskService;\n  15→  let tempDir;\n  16→  let tasksFile;\n  17→\n  18→  beforeEach(async () => {\n  19→    // Create temp directory\n  20→    tempDir = await mkdir(path.join(tmpdir(), 'scheduled-task-test-'), { recursive: true });\n  21→    tasksFile = path.join(tempDir, 'scheduled-tasks.json');\n  22→\n  23→    // Import fresh module\n  24→    const module = await import('../../src/services/scheduled-task-service.js');\n  25→    scheduledTaskService = module.scheduledTaskService;\n  26→    scheduledTaskService.reset();\n  27→  });\n  28→\n  29→  afterEach(async () => {\n  30→    // Stop any running scheduler\n  31→    if (scheduledTaskService) {\n  32→      scheduledTaskService.stopScheduler();\n  33→      scheduledTaskService.reset();\n  34→    }\n  35→    // Cleanup temp directory\n  36→    try {\n  37→      await rm(tempDir, { recursive: true, force: true });\n  38→    } catch {\n  39→      // ignore\n  40→    }\n  41→  });\n  42→\n  43→  describe('initScheduledTaskService', () => {\n  44→    test('should initialize with configuration', () => {\n  45→      scheduledTaskService.initScheduledTaskService({\n  46→        dataDir: tempDir,\n  47→        maxTasks: 100\n  48→      });\n  49→      assert.ok(scheduledTaskService.isInitialized());\n  50→    });\n  51→  });\n  52→\n  53→  describe('addCronTask', () => {\n  54→    test('should add a cron task with valid cron expression', () => {\n  55→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n  56→\n  57→      const task = scheduledTaskService.addCronTask({\n  58→        schedule: '*/5 * * * *',\n  59→        command: 'echo \"hello\"',\n  60→        chatId: '123456789',\n  61→        userId: '987654321'\n  62→      });\n  63→\n  64→      assert.ok(task.id, 'Should have generated ID');\n  65→      assert.equal(task.type, 'cron');\n  66→      assert.equal(task.schedule, '*/5 * * * *');\n  67→      assert.equal(task.command, 'echo \"hello\"');\n  68→      assert.equal(task.chatId, '123456789');\n  69→      assert.equal(task.enabled, true);\n  70→      assert.ok(task.createdAt);\n  71→    });\n  72→\n  73→    test('should reject invalid cron expression', () => {\n  74→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n  75→\n  76→      assert.throws(() => {\n  77→        scheduledTaskService.addCronTask({\n  78→          schedule: 'invalid-cron',\n  79→          command: 'echo test',\n  80→          chatId: '123',\n  81→          userId: '456'\n  82→        });\n  83→      }, /invalid cron/i);\n  84→    });\n  85→\n  86→    test('should enforce max tasks limit', () => {\n  87→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir, maxTasks: 2 });\n  88→\n  89→      scheduledTaskService.addCronTask({\n  90→        schedule: '* * * * *',\n  91→        command: 'cmd1',\n  92→        chatId: '123',\n  93→        userId: '456'\n  94→      });\n  95→\n  96→      scheduledTaskService.addCronTask({\n  97→        schedule: '*/2 * * * *',\n  98→        command: 'cmd2',\n  99→        chatId: '123',\n 100→        userId: '456'\n 101→      });\n 102→\n 103→      assert.throws(() => {\n 104→        scheduledTaskService.addCronTask({\n 105→          schedule: '*/3 * * * *',\n 106→          command: 'cmd3',\n 107→          chatId: '123',\n 108→          userId: '456'\n 109→        });\n 110→      }, /maximum.*tasks/i);\n 111→    });\n 112→  });\n 113→\n 114→  describe('addOneTimeTask', () => {\n 115→    test('should add a one-time task with ISO timestamp', () => {\n 116→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 117→\n 118→      const futureTime = new Date(Date.now() + 3600000).toISOString();\n 119→      const task = scheduledTaskService.addOneTimeTask({\n 120→        schedule: futureTime,\n 121→        command: 'echo \"once\"',\n 122→        chatId: '123456789',\n 123→        userId: '987654321'\n 124→      });\n 125→\n 126→      assert.ok(task.id);\n 127→      assert.equal(task.type, 'once');\n 128→      assert.equal(task.schedule, futureTime);\n 129→      assert.equal(task.command, 'echo \"once\"');\n 130→    });\n 131→\n 132→    test('should reject past timestamps', () => {\n 133→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 134→\n 135→      const pastTime = new Date(Date.now() - 3600000).toISOString();\n 136→      assert.throws(() => {\n 137→        scheduledTaskService.addOneTimeTask({\n 138→          schedule: pastTime,\n 139→          command: 'echo test',\n 140→          chatId: '123',\n 141→          userId: '456'\n 142→        });\n 143→      }, /past/i);\n 144→    });\n 145→\n 146→    test('should accept datetime string format', () => {\n 147→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 148→\n 149→      const futureDate = new Date(Date.now() + 86400000);\n 150→      const datetimeStr = `${futureDate.getFullYear()}-${String(futureDate.getMonth() + 1).padStart(2, '0')}-${String(futureDate.getDate()).padStart(2, '0')} ${String(futureDate.getHours()).padStart(2, '0')}:${String(futureDate.getMinutes()).padStart(2, '0')}`;\n 151→\n 152→      const task = scheduledTaskService.addOneTimeTask({\n 153→        schedule: datetimeStr,\n 154→        command: 'echo test',\n 155→        chatId: '123',\n 156→        userId: '456'\n 157→      });\n 158→\n 159→      assert.ok(task.id);\n 160→      assert.equal(task.type, 'once');\n 161→    });\n 162→  });\n 163→\n 164→  describe('listTasks', () => {\n 165→    test('should return empty array when no tasks', () => {\n 166→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 167→\n 168→      const tasks = scheduledTaskService.listTasks();\n 169→      assert.deepEqual(tasks, []);\n 170→    });\n 171→\n 172→    test('should filter by chatId', () => {\n 173→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 174→\n 175→      scheduledTaskService.addCronTask({\n 176→        schedule: '* * * * *',\n 177→        command: 'cmd1',\n 178→        chatId: 'chat1',\n 179→        userId: 'user1'\n 180→      });\n 181→\n 182→      scheduledTaskService.addCronTask({\n 183→        schedule: '*/2 * * * *',\n 184→        command: 'cmd2',\n 185→        chatId: 'chat2',\n 186→        userId: 'user2'\n 187→      });\n 188→\n 189→      const tasks = scheduledTaskService.listTasks({ chatId: 'chat1' });\n 190→      assert.equal(tasks.length, 1);\n 191→      assert.equal(tasks[0].chatId, 'chat1');\n 192→    });\n 193→\n 194→    test('should return all tasks without filter', () => {\n 195→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 196→\n 197→      scheduledTaskService.addCronTask({\n 198→        schedule: '* * * * *',\n 199→        command: 'cmd1',\n 200→        chatId: 'chat1',\n 201→        userId: 'user1'\n 202→      });\n 203→\n 204→      scheduledTaskService.addCronTask({\n 205→        schedule: '*/2 * * * *',\n 206→        command: 'cmd2',\n 207→        chatId: 'chat2',\n 208→        userId: 'user2'\n 209→      });\n 210→\n 211→      const tasks = scheduledTaskService.listTasks();\n 212→      assert.equal(tasks.length, 2);\n 213→    });\n 214→  });\n 215→\n 216→  describe('pauseTask and resumeTask', () => {\n 217→    test('should pause a task', () => {\n 218→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 219→\n 220→      const task = scheduledTaskService.addCronTask({\n 221→        schedule: '* * * * *',\n 222→        command: 'cmd',\n 223→        chatId: '123',\n 224→        userId: '456'\n 225→      });\n 226→\n 227→      const result = scheduledTaskService.pauseTask(task.id);\n 228→      assert.equal(result, true);\n 229→\n 230→      const tasks = scheduledTaskService.listTasks();\n 231→      assert.equal(tasks[0].enabled, false);\n 232→    });\n 233→\n 234→    test('should resume a paused task', () => {\n 235→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 236→\n 237→      const task = scheduledTaskService.addCronTask({\n 238→        schedule: '* * * * *',\n 239→        command: 'cmd',\n 240→        chatId: '123',\n 241→        userId: '456'\n 242→      });\n 243→\n 244→      scheduledTaskService.pauseTask(task.id);\n 245→      const result = scheduledTaskService.resumeTask(task.id);\n 246→      assert.equal(result, true);\n 247→\n 248→      const tasks = scheduledTaskService.listTasks();\n 249→      assert.equal(tasks[0].enabled, true);\n 250→    });\n 251→\n 252→    test('should return false for non-existent task', () => {\n 253→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 254→\n 255→      assert.equal(scheduledTaskService.pauseTask('non-existent'), false);\n 256→      assert.equal(scheduledTaskService.resumeTask('non-existent'), false);\n 257→    });\n 258→  });\n 259→\n 260→  describe('deleteTask', () => {\n 261→    test('should delete an existing task', () => {\n 262→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 263→\n 264→      const task = scheduledTaskService.addCronTask({\n 265→        schedule: '* * * * *',\n 266→        command: 'cmd',\n 267→        chatId: '123',\n 268→        userId: '456'\n 269→      });\n 270→\n 271→      const result = scheduledTaskService.deleteTask(task.id);\n 272→      assert.equal(result, true);\n 273→\n 274→      const tasks = scheduledTaskService.listTasks();\n 275→      assert.equal(tasks.length, 0);\n 276→    });\n 277→\n 278→    test('should return false for non-existent task', () => {\n 279→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 280→\n 281→      const result = scheduledTaskService.deleteTask('non-existent');\n 282→      assert.equal(result, false);\n 283→    });\n 284→  });\n 285→\n 286→  describe('getTask', () => {\n 287→    test('should return task by ID', () => {\n 288→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 289→\n 290→      const task = scheduledTaskService.addCronTask({\n 291→        schedule: '* * * * *',\n 292→        command: 'cmd',\n 293→        chatId: '123',\n 294→        userId: '456'\n 295→      });\n 296→\n 297→      const found = scheduledTaskService.getTask(task.id);\n 298→      assert.ok(found);\n 299→      assert.equal(found.id, task.id);\n 300→    });\n 301→\n 302→    test('should return null for non-existent task', () => {\n 303→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 304→\n 305→      const found = scheduledTaskService.getTask('non-existent');\n 306→      assert.equal(found, null);\n 307→    });\n 308→  });\n 309→\n 310→  describe('persistence', () => {\n 311→    test('should save tasks to file', async () => {\n 312→      scheduledTaskService.initScheduledTaskService({\n 313→        dataDir: tempDir,\n 314→        tasksFile: 'scheduled-tasks.json'\n 315→      });\n 316→\n 317→      scheduledTaskService.addCronTask({\n 318→        schedule: '* * * * *',\n 319→        command: 'echo test',\n 320→        chatId: '123',\n 321→        userId: '456'\n 322→      });\n 323→\n 324→      await scheduledTaskService.saveTasks();\n 325→\n 326→      const content = await readFile(tasksFile, 'utf-8');\n 327→      const savedTasks = JSON.parse(content);\n 328→\n 329→      assert.equal(savedTasks.length, 1);\n 330→      assert.equal(savedTasks[0].command, 'echo test');\n 331→    });\n 332→\n 333→    test('should load tasks from file', async () => {\n 334→      // Write tasks directly to file\n 335→      const testTasks = [{\n 336→        id: 'test-id-123',\n 337→        type: 'cron',\n 338→        schedule: '*/5 * * * *',\n 339→        command: 'echo loaded',\n 340→        chatId: '123',\n 341→        userId: '456',\n 342→        enabled: true,\n 343→        createdAt: Date.now()\n 344→      }];\n 345→\n 346→      await writeFile(tasksFile, JSON.stringify(testTasks));\n 347→\n 348→      scheduledTaskService.initScheduledTaskService({\n 349→        dataDir: tempDir,\n 350→        tasksFile: 'scheduled-tasks.json'\n 351→      });\n 352→\n 353→      await scheduledTaskService.loadTasks();\n 354→\n 355→      const tasks = scheduledTaskService.listTasks();\n 356→      assert.equal(tasks.length, 1);\n 357→      assert.equal(tasks[0].id, 'test-id-123');\n 358→    });\n 359→\n 360→    test('should handle missing file gracefully', async () => {\n 361→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 362→\n 363→      await scheduledTaskService.loadTasks();\n 364→\n 365→      const tasks = scheduledTaskService.listTasks();\n 366→      assert.deepEqual(tasks, []);\n 367→    });\n 368→\n 369→    test('should handle corrupted file gracefully', async () => {\n 370→      await writeFile(tasksFile, 'not valid json');\n 371→\n 372→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 373→\n 374→      await scheduledTaskService.loadTasks();\n 375→\n 376→      const tasks = scheduledTaskService.listTasks();\n 377→      assert.deepEqual(tasks, []);\n 378→    });\n 379→  });\n 380→\n 381→  describe('setNotificationCallback', () => {\n 382→    test('should set notification callback', () => {\n 383→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 384→\n 385→      let called = false;\n 386→      scheduledTaskService.setNotificationCallback(() => {\n 387→        called = true;\n 388→      });\n 389→\n 390→      // Callback is set, scheduler can use it\n 391→      assert.ok(true);\n 392→    });\n 393→  });\n 394→\n 395→  describe('startScheduler and stopScheduler', () => {\n 396→    test('should start and stop scheduler', () => {\n 397→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 398→\n 399→      scheduledTaskService.startScheduler();\n 400→      assert.ok(scheduledTaskService.isSchedulerRunning());\n 401→\n 402→      scheduledTaskService.stopScheduler();\n 403→      assert.ok(!scheduledTaskService.isSchedulerRunning());\n 404→    });\n 405→\n 406→    test('should not start duplicate scheduler', () => {\n 407→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n 408→\n 409→      scheduledTaskService.startScheduler();\n 410→\n 411→      assert.throws(() => {\n 412→        scheduledTaskService.startScheduler();\n 413→      }, /already running/i);\n 414→\n 415→      scheduledTaskService.stopScheduler();\n 416→    });\n 417→  });\n 418→\n 419→  describe('cron expression validation', () => {\n 420→    test('should accept standard 5-field cron expressions', () => {\n 421→      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir, maxTasks: 100 });\n 422→\n 423→      const validExpressions = [\n 424→        '* * * * *',\n 425→        '*/5 * * * *',\n 426→        '0 * * * *',\n 427→        '0 0 * * *',\n 428→        '0 0 1 * *',\n 429→        '0 0 1 1 *',\n 430→        '0 0 * * 0'\n 431→      ];\n 432→\n 433→      for (const expr of validExpressions) {\n 434→        const task = scheduledTaskService.addCronTask({\n 435→          schedule: expr,\n 436→          command: 'test',\n 437→          chatId: '123',\n 438→          userId: '456'\n 439→        });\n 440→        assert.ok(task.id, `Should accept: ${expr}`);\n 441→      }\n 442→    });\n 443→  });\n 444→});\n 445→"}],"i