    fileWatcherService.initFileWatcherService({\n  55→        dataDir: tempDir,\n  56→        allowedRoots: ['/tmp', '/home'],\n  57→        maxWatchers: 50,\n  58→        debounceMs: 500\n  59→      });\n  60→      assert.ok(fileWatcherService.isInitialized());\n  61→    });\n  62→  });\n  63→\n  64→  describe('addWatch', () => {\n  65→    test('should add a file watcher', () => {\n  66→      fileWatcherService.initFileWatcherService({\n  67→        dataDir: tempDir,\n  68→        allowedRoots: [tempDir]\n  69→      });\n  70→\n  71→      const watcher = fileWatcherService.addWatch({\n  72→        path: tempDir,\n  73→        chatId: '123456789',\n  74→        userId: '987654321'\n  75→      });\n  76→\n  77→      assert.ok(watcher.id, 'Should have generated ID');\n  78→      assert.equal(watcher.path, tempDir);\n  79→      assert.equal(watcher.chatId, '123456789');\n  80→      assert.equal(watcher.enabled, true);\n  81→      assert.ok(watcher.createdAt);\n  82→    });\n  83→\n  84→    test('should reject path outside allowed roots', () => {\n  85→      fileWatcherService.initFileWatcherService({\n  86→        dataDir: tempDir,\n  87→        allowedRoots: ['/tmp/allowed']\n  88→      });\n  89→\n  90→      assert.throws(() => {\n  91→        fileWatcherService.addWatch({\n  92→          path: '/etc/passwd',\n  93→          chatId: '123',\n  94→          userId: '456'\n  95→        });\n  96→      }, /not allowed|permission/i);\n  97→    });\n  98→\n  99→    test('should allow path inside allowed roots', () => {\n 100→      const allowedDir = path.join(tempDir, 'allowed');\n 101→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_8164acc216aa40eaa825218d","__timestamp":"2026-03-12T21:38:20.836Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
