{"type":"assistant","uuid":"2026031305440748bff8cbcffd47f7","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"id":"2026031305440748bff8cbcffd47f7","content":[{"type":"text","text":"Now let me create Phase 7 integration tests:"}],"model":"glm-5.0","role":"assistant","stop_reason":null,"stop_sequence":null,"type":"message","usage":{"input_tokens":0,"output_tokens":0,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_8164acc216aa40eaa825218d","__timestamp":"2026-03-12T21:44:38.633Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
{"type":"assistant","uuid":"2026031305440748bff8cbcffd47f7","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"id":"2026031305440748bff8cbcffd47f7","content":[{"type":"tool_use","id":"019ce401cd429018b708b7c850128fd2","name":"Write","input":{"content":"/**\n * Integration Tests for F-014 Scheduled Tasks\n * Phase 7: Integration Tests\n */\n\nimport { describe, test, beforeEach, afterEach } from 'node:test';\nimport assert from 'node:assert/strict';\nimport { mkdir, rm, readFile, writeFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport { tmpdir } from 'node:os';\n\ndescribe('F-014 Scheduled Tasks Integration', () => {\n  let scheduledTaskService;\n  let tempDir;\n  let tasksFile;\n  let executionLog;\n\n  beforeEach(async () => {\n    tempDir = await mkdir(path.join(tmpdir(), 'scheduled-tasks-integration-'), { recursive: true });\n    tasksFile = path.join(tempDir, 'scheduled-tasks.json');\n    executionLog = [];\n\n    const projectRoot = process.cwd();\n    const servicePath = new URL(`file://${projectRoot}/src/services/scheduled-task-service.js`);\n    const serviceModule = await import(servicePath.href);\n    scheduledTaskService = serviceModule.scheduledTaskService;\n    scheduledTaskService.reset();\n  });\n\n  afterEach(async () => {\n    scheduledTaskService.stopScheduler();\n    scheduledTaskService.reset();\n    try {\n      await rm(tempDir, { recursive: true, force: true });\n    } catch {\n      // ignore\n    }\n  });\n\n  describe('end-to-end task lifecycle', () => {\n    test('should create, execute, and delete task', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      // Create task\n      const task = scheduledTaskService.addCronTask({\n        schedule: '* * * * *',\n        command: 'echo \"integration test\"',\n        chatId: 'test-chat',\n        userId: 'test-user'\n      });\n\n      assert.ok(task.id);\n      assert.equal(task.enabled, true);\n\n      // List tasks\n      const tasks = scheduledTaskService.listTasks({ chatId: 'test-chat' });\n      assert.equal(tasks.length, 1);\n\n      // Pause task\n      const paused = scheduledTaskService.pauseTask(task.id);\n      assert.equal(paused, true);\n\n      const pausedTask = scheduledTaskService.getTask(task.id);\n      assert.equal(pausedTask.enabled, false);\n\n      // Resume task\n      const resumed = scheduledTaskService.resumeTask(task.id);\n      assert.equal(resumed, true);\n\n      const resumedTask = scheduledTaskService.getTask(task.id);\n      assert.equal(resumedTask.enabled, true);\n\n      // Delete task\n      const deleted = scheduledTaskService.deleteTask(task.id);\n      assert.equal(deleted, true);\n\n      const remainingTasks = scheduledTaskService.listTasks();\n      assert.equal(remainingTasks.length, 0);\n    });\n\n    test('should persist tasks across service restart', async () => {\n      // First instance\n      scheduledTaskService.initScheduledTaskService({\n        dataDir: tempDir,\n        tasksFile: 'scheduled-tasks.json'\n      });\n\n      const task = scheduledTaskService.addCronTask({\n        schedule: '*/10 * * * *',\n        command: 'persistent task',\n        chatId: 'chat-1',\n        userId: 'user-1'\n      });\n\n      await scheduledTaskService.saveTasks();\n\n      // Verify file exists\n      const content = await readFile(tasksFile, 'utf-8');\n      const savedTasks = JSON.parse(content);\n      assert.equal(savedTasks.length, 1);\n      assert.equal(savedTasks[0].command, 'persistent task');\n\n      // Simulate restart\n      scheduledTaskService.stopScheduler();\n      scheduledTaskService.reset();\n\n      // Second instance\n      const servicePath = new URL(`file://${process.cwd()}/src/services/scheduled-task-service.js`);\n      const serviceModule = await import(servicePath.href);\n      const newService = serviceModule.scheduledTaskService;\n\n      newService.initScheduledTaskService({\n        dataDir: tempDir,\n        tasksFile: 'scheduled-tasks.json'\n      });\n\n      await newService.loadTasks();\n\n      const restoredTasks = newService.listTasks();\n      assert.equal(restoredTasks.length, 1);\n      assert.equal(restoredTasks[0].command, 'persistent task');\n      assert.equal(restoredTasks[0].chatId, 'chat-1');\n\n      newService.stopScheduler();\n      newService.reset();\n    });\n  });\n\n  describe('task execution with callback', () => {\n    test('should execute task with provided callback', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      const executionResults = [];\n      scheduledTaskService.setExecuteCallback(async ({ command, userId }) => {\n        executionResults.push({ command, userId });\n        return {\n          stdout: `executed: ${command}`,\n          stderr: '',\n          exitCode: 0,\n          timedOut: false\n        };\n      });\n\n      const task = scheduledTaskService.addCronTask({\n        schedule: '* * * * *',\n        command: 'test command',\n        chatId: 'chat-1',\n        userId: 'user-1'\n      });\n\n      const result = await scheduledTaskService.executeTask(task.id);\n\n      assert.equal(result.exitCode, 0);\n      assert.ok(result.stdout.includes('test command'));\n      assert.equal(executionResults.length, 1);\n      assert.equal(executionResults[0].command, 'test command');\n    });\n\n    test('should handle execution errors gracefully', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      scheduledTaskService.setExecuteCallback(async () => {\n        throw new Error('Execution failed');\n      });\n\n      const task = scheduledTaskService.addCronTask({\n        schedule: '* * * * *',\n        command: 'failing command',\n        chatId: 'chat-1',\n        userId: 'user-1'\n      });\n\n      const result = await scheduledTaskService.executeTask(task.id);\n\n      assert.equal(result.exitCode, 1);\n      assert.ok(result.stderr.includes('Execution failed'));\n    });\n  });\n\n  describe('notification callback', () => {\n    test('should call notification callback after task execution', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      const notifications = [];\n      scheduledTaskService.setExecuteCallback(async () => ({\n        stdout: 'test output',\n        stderr: '',\n        exitCode: 0,\n        timedOut: false\n      }));\n\n      scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n        notifications.push({ chatId, taskId: task.id, result: task.lastResult });\n      });\n\n      const task = scheduledTaskService.addCronTask({\n        schedule: '* * * * *',\n        command: 'notify test',\n        chatId: 'notify-chat',\n        userId: 'user-1'\n      });\n\n      await scheduledTaskService.executeTask(task.id);\n\n      assert.equal(notifications.length, 1);\n      assert.equal(notifications[0].chatId, 'notify-chat');\n      assert.ok(notifications[0].result);\n      assert.equal(notifications[0].result.exitCode, 0);\n    });\n  });\n\n  describe('one-time tasks', () => {\n    test('should create and schedule one-time task', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      const futureTime = new Date(Date.now() + 3600000).toISOString();\n      const task = scheduledTaskService.addOneTimeTask({\n        schedule: futureTime,\n        command: 'one-time command',\n        chatId: 'chat-1',\n        userId: 'user-1'\n      });\n\n      assert.equal(task.type, 'once');\n      assert.ok(task.nextRunAt > Date.now());\n    });\n\n    test('should reject past timestamps', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      const pastTime = new Date(Date.now() - 3600000).toISOString();\n\n      assert.throws(() => {\n        scheduledTaskService.addOneTimeTask({\n          schedule: pastTime,\n          command: 'past task',\n          chatId: 'chat-1',\n          userId: 'user-1'\n        });\n      }, /past/i);\n    });\n  });\n\n  describe('scheduler lifecycle', () => {\n    test('should start and stop scheduler', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      assert.equal(scheduledTaskService.isSchedulerRunning(), false);\n\n      scheduledTaskService.startScheduler();\n      assert.equal(scheduledTaskService.isSchedulerRunning(), true);\n\n      scheduledTaskService.stopScheduler();\n      assert.equal(scheduledTaskService.isSchedulerRunning(), false);\n    });\n\n    test('should prevent duplicate scheduler start', async () => {\n      scheduledTaskService.initScheduledTaskService({ dataDir: tempDir });\n\n      scheduledTaskService.startScheduler();\n\n      assert.throws(() => {\n        scheduledTaskService.startScheduler();\n      }, /already running/i);\n\n      scheduledTaskService.stopScheduler();\n    });\n  });\n});\n","file_path":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f014-scheduled-tasks.test.js"}}],"model":"glm-5.0","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":108864,"output_tokens":1898,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_8164acc216aa40eaa825218d","__timestamp":"2026-03-12T21:44:38.638Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
