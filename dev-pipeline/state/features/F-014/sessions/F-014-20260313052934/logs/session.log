> {\n 600→    try {\n 601→      ensureAllowed(ctx);\n 602→      const payload = ctx.message.text.replace('/cd', '').trim();\n 603→      const sessionId = buildSessionId(ctx);\n 604→\n 605→      await handleCd({\n 606→        ctx,\n 607→        reply: (msg) => ctx.reply(msg),\n 608→        params: {},\n 609→        userId: ctx.from?.id,\n 610→        sessionId,\n 611→        args: payload ? [payload] : []\n 612→      });\n 613→    } catch (error) {\n 614→      const message = error instanceof Error ? error.message : String(error);\n 615→      logger.error({ err: message }, 'Failed to cd in telegram');\n 616→      await ctx.reply(`切换目录失败：${message}`);\n 617→    }\n 618→  });\n 619→\n 620→  // F-009: /more command handler\n 621→  bot.command('more', async (ctx) => {\n 622→    try {\n 623→      ensureAllowed(ctx);\n 624→      const sessionId = buildSessionId(ctx);\n 625→\n 626→      await handleMore({\n 627→        ctx,\n 628→        reply: (msg) => ctx.reply(msg),\n 629→        params: {},\n 630→        userId: ctx.from?.id,\n 631→        sessionId\n 632→      });\n 633→    } catch (error) {\n 634→      const message = error instanceof Error ? error.message : String(error);\n 635→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 636→      await ctx.reply(`获取更多输出失败：${message}`);\n 637→    }\n 638→  });\n 639→\n 640→  // T-100: Document upload handler for plan files\n 641→  bot.on('document', async (ctx) => {\n 642→    try {\n 643→      ensureAllowed(ctx);\n 644→\n 645→      const document = ctx.message?.document;\n 646→      if (!document) {\n 647→        return;\n 648→      }\n 649→\n 650→      // Check file extension\n 651→      const fileName = document.file_name || '';\n 652→      const ext = path.extname(fileName).toLowerCase();\n 653→\n 654→      if (ext !== '.json') {\n 655→        // Not a JSON file, ignore silently (other handlers may process it)\n 656→        return;\n 657→      }\n 658→\n 659→      // Check file size\n 660→      const fileSize = document.file_size || 0;\n 661→      if (fileSize > 1024 * 1024) { // 1MB limit\n 662→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 663→        return;\n 664→      }\n 665→\n 666→      await ctx.reply('正在处理上传的计划文件...');\n 667→\n 668→      // Download file content\n 669→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 670→      const fileUrl = fileLink.href || fileLink.toString();\n 671→\n 672→      const response = await fetch(fileUrl);\n 673→      if (!response.ok) {\n 674→        throw new Error(`下载文件失败: ${response.status}`);\n 675→      }\n 676→\n 677→      const content = await response.text();\n 678→\n 679→      // Validate and save using plan-ingestion-service\n 680→      const infraConfig = loadPipelineInfraConfig();\n 681→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 682→\n 683→      const validationResult = planService.validate(content);\n 684→\n 685→      if (!validationResult.valid) {\n 686→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 687→        await ctx.reply(errorMsg);\n 688→        return;\n 689→      }\n 690→\n 691→      // Save the plan\n 692→      const saveResult = await planService.save(\n 693→        validationResult.type,\n 694→        content,\n 695→        { uploadedBy: ctx.from?.id }\n 696→      );\n 697→\n 698→      if (!saveResult.success) {\n 699→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 700→        return;\n 701→      }\n 702→\n 703→      // Set as current version\n 704→      await planService.setCurrent(validationResult.type, saveResult.version);\n 705→\n 706→      // Format success message\n 707→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 708→      const summary = validationResult.summary;\n 709→\n 710→      await ctx.reply([\n 711→        `✅ ${typeDisplay}已保存并激活`,\n 712→        `版本: ${saveResult.version}`,\n 713→        `名称: ${summary?.name || '未知'}`,\n 714→        `项目数: ${summary?.itemCount || 0}`,\n 715→        '',\n 716→        summary?.statusBreakdown ? '状态分布:' : '',\n 717→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 718→      ].filter(Boolean).join('\\n'));\n 719→\n 720→    } catch (error) {\n 721→      const message = error instanceof Error ? error.message : String(error);\n 722→      logger.error({ err: message }, 'Failed to process document upload');\n 723→      await ctx.reply(`❌ 处理失败：${message}`);\n 724→    }\n 725→  });\n 726→\n 727→  bot.on('text', async (ctx) => {\n 728→    // Check for pipeline commands first\n 729→    const handled = await routeCommand(ctx);\n 730→    if (handled) {\n 731→      return;\n 732→    }\n 733→\n 734→    const sessionId = buildSessionId(ctx);\n 735→    const userId = ctx.from?.id;\n 736→\n 737→    // F-009: Direct exec mode - treat plain text as command when enabled\n 738→    if (config.directExecMode && config.enableSystemExec) {\n 739→      try {\n 740→        ensureAllowed(ctx);\n 741→        const command = ctx.message.text;\n 742→\n 743→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 744→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 745→\n 746→        if (!isLikelyChat) {\n 747→          await ctx.reply('正在执行命令...');\n 748→          const result = await executeCommand({\n 749→            command,\n 750→            sessionId,\n 751→            userId\n 752→          });\n 753→\n 754→          if (result.needsConfirmation) {\n 755→            await ctx.reply(result.confirmationMessage);\n 756→            return;\n 757→          }\n 758→\n 759→          await replyLargeText(ctx, result.output);\n 760→\n 761→          if (result.hasMorePages) {\n 762→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 763→          }\n 764→          return;\n 765→        }\n 766→      } catch (error) {\n 767→        const 