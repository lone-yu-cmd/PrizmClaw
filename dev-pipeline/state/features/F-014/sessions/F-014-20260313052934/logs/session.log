{"type":"user","uuid":"6b5a143c-654f-4fc0-b5b1-df0ef5dd44a8","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce4091b130dc95509754ea7fd7517","content":[{"type":"text","text":"   1→/**\n   2→ * Scheduled Task Service\n   3→ * F-014: Notification and Scheduled Tasks\n   4→ *\n   5→ * Manages scheduled tasks with cron expressions and one-time execution.\n   6→ * Integrates with executeCommand for task execution and Telegram for notifications.\n   7→ */\n   8→\n   9→import { randomUUID } from 'node:crypto';\n  10→import { mkdir, readFile, writeFile } from 'node:fs/promises';\n  11→import { join } from 'node:path';\n  12→import { Cron } from 'croner';\n  13→\n  14→class ScheduledTaskServiceClass {\n  15→  #dataDir = null;\n  16→  #tasksFile = 'scheduled-tasks.json';\n  17→  #maxTasks = 100;\n  18→  #tasks = new Map();\n  19→  #cronJobs = new Map();\n  20→  #notificationCallback = null;\n  21→  #executeCallback = null;\n  22→  #isInitialized = false;\n  23→  #schedulerRunning = false;\n  24→\n  25→  reset() {\n  26→    this.#dataDir = null;\n  27→    this.#tasks.clear();\n  28→    this.#cronJobs.clear();\n  29→    this.#notificationCallback = null;\n  30→    this.#executeCallback = null;\n  31→    this.#isInitialized = false;\n  32→    this.#schedulerRunning = false;\n  33→  }\n  34→\n  35→  isInitialized() {\n  36→    return this.#isInitialized;\n  37→  }\n  38→\n  39→  initScheduledTaskService({ dataDir, tasksFile, maxTasks }) {\n  40→    this.#dataDir = dataDir;\n  41→    if (tasksFile) this.#tasksFile = tasksFile;\n  42→    if (maxTasks !== undefined) this.#maxTasks = maxTasks;\n  43→    this.#isInitialized = true;\n  44→  }\n  45→\n  46→  #checkInitialized() {\n  47→    if (!this.#isInitialized) {\n  48→      throw new Error('ScheduledTaskService not initialized. Call initScheduledTaskService first.');\n  49→    }\n  50→  }\n  51→\n  52→  async #ensureDataDir() {\n  53→    if (this.#dataDir) {\n  54→      await mkdir(this.#dataDir, { recursive: true });\n  55→    }\n  56→  }\n  57→\n  58→  setNotificationCallback(callback) {\n  59→    this.#notificationCallback = callback;\n  60→  }\n  61→\n  62→  setExecuteCallback(callback) {\n  63→    this.#executeCallback = callback;\n  64→  }\n  65→\n  66→  /**\n  67→   * Validate cron expression using croner\n  68→   * @param {string} expression - Cron expression\n  69→   * @returns {boolean} - True if valid\n  70→   */\n  71→  #validateCronExpression(expression) {\n  72→    try {\n  73→      const cron = new Cron(expression);\n  74→      cron.stop();\n  75→      return true;\n  76→    } catch {\n  77→      return false;\n  78→    }\n  79→  }\n  80→\n  81→  /**\n  82→   * Parse datetime string to Date object\n  83→   * @param {string} datetime - ISO timestamp or 'YYYY-MM-DD HH:mm' format\n  84→   * @returns {Date|null} - Parsed date or null if invalid\n  85→   */\n  86→  #parseDatetime(datetime) {\n  87→    // Try ISO format first\n  88→    const isoDate = new Date(datetime);\n  89→    if (!isNaN(isoDate.getTime())) {\n  90→      return isoDate;\n  91→    }\n  92→\n  93→    // Try 'YYYY-MM-DD HH:mm' format\n  94→    const match = datetime.match(/^(\\d{4})-(\\d{2})-(\\d{2})\\s+(\\d{2}):(\\d{2})$/);\n  95→    if (match) {\n  96→      const [, year, month, day, hour, minute] = match;\n  97→      return new Date(parseInt(year), parseInt(month) - 1, parseInt(day), parseInt(hour), parseInt(minute));\n  98→    }\n  99→\n 100→    return null;\n 101→  }\n 102→\n 103→  /**\n 104→   * Add a cron-based recurring task\n 105→   */\n 106→  addCronTask({ schedule, command, chatId, userId, cwd }) {\n 107→    this.#checkInitialized();\n 108→\n 109→    // Validate cron expression\n 110→    if (!this.#validateCronExpression(schedule)) {\n 111→      throw new Error(`Invalid cron expression: ${schedule}`);\n 112→    }\n 113→\n 114→    // Check max tasks limit\n 115→    if (this.#tasks.size >= this.#maxTasks) {\n 116→      throw new Error(`Maximum number of tasks (${this.#maxTasks}) reached`);\n 117→    }\n 118→\n 119→    const id = randomUUID();\n 120→    const task = {\n 121→      id,\n 122→      type: 'cron',\n 123→      schedule,\n 124→      command,\n 125→      chatId,\n 126→      userId,\n 127→      cwd: cwd || null,\n 128→      enabled: true,\n 129→      createdAt: Date.now(),\n 130→      lastRunAt: null,\n 131→      lastResult: null,\n 132→      nextRunAt: this.#getNextRunTime(schedule)\n 133→    };\n 134→\n 135→    this.#tasks.set(id, task);\n 136→\n 137→    // If scheduler is running, schedule this task\n 138→    if (this.#schedulerRunning) {\n 139→      this.#scheduleCronTask(task);\n 140→    }\n 141→\n 142→    return { ...task };\n 143→  }\n 144→\n 145→  /**\n 146→   * Add a one-time task\n 147→   */\n 148→  addOneTimeTask({ schedule, command, chatId, userId, cwd }) {\n 149→    this.#checkInitialized();\n 150→\n 151→    // Parse datetime\n 152→    const scheduledDate = this.#parseDatetime(schedule);\n 153→    if (!scheduledDate) {\n 154→      throw new Error(`Invalid datetime format: ${schedule}`);\n 155→    }\n 156→\n 157→    // Check if in the past\n 158→    if (scheduledDate.getTime() <= Date.now()) {\n 159→      throw new Error('Cannot schedule task in the past');\n 160→    }\n 161→\n 162→    // Check max tasks limit\n 163→    if (this.#tasks.size >= this.#maxTasks) {\n 164→      throw new Error(`Maximum number of tasks (${this.#maxTasks}) reached`);\n 165→    }\n 166→\n 167→    const id = randomUUID();\n 168→    const task = {\n 169→      id,\n 170→      type: 'once',\n 171→      schedule: scheduledDate.toISOString(),\n 172→      command,\n 173→      chatId,\n 174→      userId,\n 175→      cwd: cwd || null,\n 176→      enabled: true,\n 177→      createdAt: Date.now(),\n 178→      lastRunAt: null,\n 179→      lastResult: null,\n 180→      nextRunAt: scheduledDate.getTime()\n 181→    };\n 182→\n 183→    this.#tasks.set(id, task);\n 184→\n 185→    // If scheduler is running, schedule this task\n 186→    if (this.#schedulerRunning) {\n 187→      this.#scheduleOneTimeTask(task);\n 188→    }\n 189→\n 190→    return { ...task };\n 191→  }\n 192→\n 193→  /**\n 194→   * Get next run time for cron expression\n 195→   */\n 196→  #getNextRunTime(schedule) {\n 197→    try {\n 198→      const cron = new Cron(schedule);\n 199→      const next = cron.nextRun();\n 200→      cron.stop();\n 201→      return next ? next.getTime() : null;\n 202→    } catch {\n 203→      return null;\n 204→    }\n 205→  }\n 206→\n 207→  /**\n 208→   * List tasks, optionally filtered by chatId\n 209→   */\n 210→  listTasks({ chatId } = {}) {\n 211→    const tasks = Array.from(this.#tasks.values());\n 212→    if (chatId) {\n 213→      return tasks.filter(t => t.chatId === chatId).map(t => ({ ...t }));\n 214→    }\n 215→    return tasks.map(t => ({ ...t }));\n 216→  }\n 217→\n 218→  /**\n 219→   * Get a single task by ID\n 220→   */\n 221→  getTask(taskId) {\n 222→    const task = this.#tasks.get(taskId);\n 223→    return task ? { ...task } : null;\n 224→  }\n 225→\n 226→  /**\n 227→   * Pause a task\n 228→   */\n 229→  pauseTask(taskId) {\n 230→    const task = this.#tasks.get(taskId);\n 231→    if (!task) return false;\n 232→\n 233→    task.enabled = false;\n 234→\n 235→    // Stop any running cron job\n 236→    const cronJob = this.#cronJobs.get(taskId);\n 237→    if (cronJob) {\n 238→      cronJob.stop();\n 239→      this.#cronJobs.delete(taskId);\n 240→    }\n 241→\n 242→    return true;\n 243→  }\n 244→\n 245→  /**\n 246→   * Resume a paused task\n 247→   */\n 248→  resumeTask(taskId) {\n 249→    const task = this.#tasks.get(taskId);\n 250→    if (!task) return false;\n 251→\n 252→    task.enabled = true;\n 253→\n 254→    // Re-schedule if scheduler is running\n 255→    if (this.#schedulerRunning) {\n 256→      if (task.type === 'cron') {\n 257→        this.#scheduleCronTask(task);\n 258→      } else {\n 259→        this.#scheduleOneTimeTask(task);\n 260→      }\n 261→    }\n 262→\n 263→    return true;\n 264→  }\n 265→\n 266→  /**\n 267→   * Delete a task\n 268→   */\n 269→  deleteTask(taskId) {\n 270→    const task = this.#tasks.get(taskId);\n 271→    if (!task) return false;\n 272→\n 273→    // Stop any running cron job\n 274→    const cronJob = this.#cronJobs.get(taskId);\n 275→    if (cronJob) {\n 276→      cronJob.stop();\n 277→      this.#cronJobs.delete(taskId);\n 278→    }\n 279→\n 280→    this.#tasks.delete(taskId);\n 281→    return true;\n 282→  }\n 283→\n 284→  /**\n 285→   * Execute a task\n 286→   */\n 287→  async executeTask(taskId) {\n 288→    const task = this.#tasks.get(taskId);\n 289→    if (!task) {\n 290→      throw new Error(`Task not found: ${taskId}`);\n 291→    }\n 292→\n 293→    const executedAt = Date.now();\n 294→    let result;\n 295→\n 296→    try {\n 297→      if (this.#executeCallback) {\n 298→        result = await this.#executeCallback({\n 299→          command: task.command,\n 300→          cwd: task.cwd,\n 301→          sessionId: `scheduled:${taskId}`,\n 302→          userId: task.userId\n 303→        });\n 304→      } else {\n 305→        // Fallback: just record execution without actual command\n 306→        result = {\n 307→          stdout: '',\n 308→          stderr: 'No execute callback configured',\n 309→          exitCode: 1,\n 310→          timedOut: false\n 311→        };\n 312→      }\n 313→    } catch (error) {\n 314→      result = {\n 315→        stdout: '',\n 316→        stderr: error.message,\n 317→        exitCode: 1,\n 318→        timedOut: false\n 319→      };\n 320→    }\n 321→\n 322→    // Update task\n 323→    task.lastRunAt = executedAt;\n 324→    task.lastResult = {\n 325→      stdout: result.stdout || '',\n 326→      stderr: result.stderr || '',\n 327→      exitCode: result.exitCode,\n 328→      timedOut: result.timedOut || false,\n 329→      executedAt\n 330→    };\n 331→\n 332→    // Update next run time for cron tasks\n 333→    if (task.type === 'cron') {\n 334→      task.nextRunAt = this.#getNextRunTime(task.schedule);\n 335→    }\n 336→\n 337→    // Notify via callback\n 338→    if (this.#notificationCallback) {\n 339→      await this.#notificationCallback(task.chatId, task);\n 340→    }\n 341→\n 342→    return task.lastResult;\n 343→  }\n 344→\n 345→  /**\n 346→   * Schedule a cron task\n 347→   */\n 348→  #scheduleCronTask(task) {\n 349→    if (!task.enabled) return;\n 350→\n 351→    try {\n 352→      const cronJob = new Cron(task.schedule, async () => {\n 353→        await this.executeTask(task.id);\n 354→      });\n 355→\n 356→      this.#cronJobs.set(task.id, cronJob);\n 357→    } catch (error) {\n 358→      console.error(`Failed to schedule cron task ${task.id}:`, error.message);\n 359→    }\n 360→  }\n 361→\n 362→  /**\n 363→   * Schedule a one-time task\n 364→   */\n 365→  #scheduleOneTimeTask(task) {\n 366→    if (!task.enabled) return;\n 367→\n 368→    const delay = new Date(task.schedule).getTime() - Date.now();\n 369→    if (delay <= 0) return;\n 370→\n 371→    const timeoutId = setTimeout(async () => {\n 372→      await this.executeTask(task.id);\n 373→      // One-time tasks delete themselves after execution\n 374→      this.deleteTask(task.id);\n 375→    }, delay);\n 376→\n 377→    // Store as a pseudo-cron job for tracking\n 378→    this.#cronJobs.set(task.id, { stop: () => clearTimeout(timeoutId) });\n 379→  }\n 380→\n 381→  /**\n 382→   * Start the scheduler\n 383→   */\n 384→  startScheduler() {\n 385→    if (this.#schedulerRunning) {\n 386→      throw new Error('Scheduler is already running');\n 387→    }\n 388→\n 389→    this.#checkInitialized();\n 390→    this.#schedulerRunning = true;\n 391→\n 392→    // Schedule all enabled tasks\n 393→    for (const task of this.#tasks.values()) {\n 394→      if (task.enabled) {\n 395→        if (task.type === 'cron') {\n 396→          this.#scheduleCronTask(task);\n 397→        } else {\n 398→          this.#scheduleOneTimeTask(task);\n 399→        }\n 400→      }\n 401→    }\n 402→  }\n 403→\n 404→  /**\n 405→   * Stop the scheduler\n 406→   */\n 407→  stopScheduler() {\n 408→    for (const cronJob of this.#cronJobs.values()) {\n 409→      cronJob.stop();\n 410→    }\n 411→    this.#cronJobs.clear();\n 412→    this.#schedulerRunning = false;\n 413→  }\n 414→\n 415→  isSchedulerRunning() {\n 416→    return this.#schedulerRunning;\n 417→  }\n 418→\n 419→  /**\n 420→   * Save tasks to disk\n 421→   */\n 422→  async saveTasks() {\n 423→    this.#checkInitialized();\n 424→    await this.#ensureDataDir();\n 425→\n 426→    const filePath = join(this.#dataDir, this.#tasksFile);\n 427→    const tasks = Array.from(this.#tasks.values());\n 428→    await writeFile(filePath, JSON.stringify(tasks, null, 2), 'utf-8');\n 429→  }\n 430→\n 431→  /**\n 432→   * Load tasks from disk\n 433→   */\n 434→  async loadTasks() {\n 435→    this.#checkInitialized();\n 436→\n 437→    try {\n 438→      const filePath = join(this.#dataDir, this.#tasksFile);\n 439→      const content = await readFile(filePath, 'utf-8');\n 440→      const tasks = JSON.parse(content);\n 441→\n 442→      this.#tasks.clear();\n 443→      for (const task of tasks) {\n 444→        if (task.id && task.type && task.command) {\n 445→          // Skip one-time tasks that are in the past\n 446→          if (task.type === 'once') {\n 447→            const scheduledDate = new Date(task.schedule);\n 448→            if (scheduledDate.getTime() <= Date.now()) {\n 449→              continue;\n 450→            }\n 451→          }\n 452→          this.#tasks.set(task.id, task);\n 453→        }\n 454→      }\n 455→    } catch (error) {\n 456→      if (error.code !== 'ENOENT') {\n 457→        console.error('Failed to load tasks:', error.message);\n 458→      }\n 459→      this.#tasks.clear();\n 460→    }\n 461→  }\n 462→}\n 463→\n 464→export const scheduledTaskService = new ScheduledTaskServiceClass();\n 465→export default ScheduledTaskServiceClass;\n 466→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__timestamp":"2026-03-12T21:52:10.740Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
{"type":"user","uuid":"f04c0897-f820-4872-b015-6c4d0cef30b6","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce4091cc4570b310f6c77791f239d","content":[{"type":"text","text":"   1→/**\n   2→ * File Watcher Service\n   3→ * F-014: Notification and Scheduled Tasks\n   4→ *\n   5→ * Manages file system monitoring with fs.watch and debouncing.\n   6→ * Sends Telegram notifications on file changes.\n   7→ */\n   8→\n   9→import { randomUUID } from 'node:crypto';\n  10→import { mkdir, readFile, writeFile, access, stat } from 'node:fs/promises';\n  11→import { join, resolve, normalize } from 'node:path';\n  12→import { watch } from 'node:fs';\n  13→\n  14→class FileWatcherServiceClass {\n  15→  #dataDir = null;\n  16→  #watchersFile = 'file-watchers.json';\n  17→  #maxWatchers = 50;\n  18→  #debounceMs = 500;\n  19→  #allowedRoots = [];\n  20→  #watchers = new Map();\n  21→  #fsWatchers = new Map();\n  22→  #debounceTimers = new Map();\n  23→  #notificationCallback = null;\n  24→  #isInitialized = false;\n  25→\n  26→  reset() {\n  27→    this.#dataDir = null;\n  28→    this.#watchers.clear();\n  29→    this.stopAllWatchers();\n  30→    this.#notificationCallback = null;\n  31→    this.#isInitialized = false;\n  32→  }\n  33→\n  34→  isInitialized() {\n  35→    return this.#isInitialized;\n  36→  }\n  37→\n  38→  initFileWatcherService({ dataDir, watchersFile, maxWatchers, debounceMs, allowedRoots }) {\n  39→    this.#dataDir = dataDir;\n  40→    if (watchersFile) this.#watchersFile = watchersFile;\n  41→    if (maxWatchers !== undefined) this.#maxWatchers = maxWatchers;\n  42→    if (debounceMs !== undefined) this.#debounceMs = debounceMs;\n  43→    if (allowedRoots) this.#allowedRoots = allowedRoots.map(p => normalize(p));\n  44→    this.#isInitialized = true;\n  45→  }\n  46→\n  47→  #checkInitialized() {\n  48→    if (!this.#isInitialized) {\n  49→      throw new Error('FileWatcherService not initialized. Call initFileWatcherService first.');\n  50→    }\n  51→  }\n  52→\n  53→  async #ensureDataDir() {\n  54→    if (this.#dataDir) {\n  55→      await mkdir(this.#dataDir, { recursive: true });\n  56→    }\n  57→  }\n  58→\n  59→  setNotificationCallback(callback) {\n  60→    this.#notificationCallback = callback;\n  61→  }\n  62→\n  63→  /**\n  64→   * Validate path is within allowed roots\n  65→   */\n  66→  #isPathAllowed(targetPath) {\n  67→    if (this.#allowedRoots.length === 0) {\n  68→      return true; // No restrictions if no roots defined\n  69→    }\n  70→\n  71→    const normalizedPath = normalize(targetPath);\n  72→    return this.#allowedRoots.some(root => {\n  73→      const normalizedRoot = normalize(root);\n  74→      return normalizedPath.startsWith(normalizedRoot);\n  75→    });\n  76→  }\n  77→\n  78→  /**\n  79→   * Add a file watcher\n  80→   */\n  81→  async addWatch({ path: watchPath, chatId, userId, recursive = true }) {\n  82→    this.#checkInitialized();\n  83→\n  84→    // Normalize and resolve path (removes trailing slashes)\n  85→    const normalizedPath = resolve(watchPath);\n  86→\n  87→    // Check path is allowed\n  88→    if (!this.#isPathAllowed(normalizedPath)) {\n  89→      throw new Error(`Path not allowed: ${normalizedPath}. Must be within allowed roots.`);\n  90→    }\n  91→\n  92→    // Check path exists\n  93→    try {\n  94→      await access(normalizedPath);\n  95→    } catch {\n  96→      throw new Error(`Path does not exist: ${normalizedPath}`);\n  97→    }\n  98→\n  99→    // Check max watchers limit\n 100→    if (this.#watchers.size >= this.#maxWatchers) {\n 101→      throw new Error(`Maximum number of watchers (${this.#maxWatchers}) reached`);\n 102→    }\n 103→\n 104→    const id = randomUUID();\n 105→    const watcher = {\n 106→      id,\n 107→      path: normalizedPath,\n 108→      chatId,\n 109→      userId,\n 110→      recursive,\n 111→      enabled: true,\n 112→      createdAt: Date.now(),\n 113→      lastEventAt: null,\n 114→      lastEventType: null\n 115→    };\n 116→\n 117→    this.#watchers.set(id, watcher);\n 118→\n 119→    return { ...watcher };\n 120→  }\n 121→\n 122→  /**\n 123→   * Remove a watcher\n 124→   */\n 125→  removeWatch(watcherId) {\n 126→    const watcher = this.#watchers.get(watcherId);\n 127→    if (!watcher) return false;\n 128→\n 129→    // Stop any active fs watcher\n 130→    this.stopWatching(watcherId);\n 131→\n 132→    this.#watchers.delete(watcherId);\n 133→    return true;\n 134→  }\n 135→\n 136→  /**\n 137→   * List watchers, optionally filtered by chatId\n 138→   */\n 139→  listWatches({ chatId } = {}) {\n 140→    const watchers = Array.from(this.#watchers.values());\n 141→    if (chatId) {\n 142→      return watchers.filter(w => w.chatId === chatId).map(w => ({ ...w }));\n 143→    }\n 144→    return watchers.map(w => ({ ...w }));\n 145→  }\n 146→\n 147→  /**\n 148→   * Get a single watcher by ID\n 149→   */\n 150→  getWatch(watcherId) {\n 151→    const watcher = this.#watchers.get(watcherId);\n 152→    return watcher ? { ...watcher } : null;\n 153→  }\n 154→\n 155→  /**\n 156→   * Start watching a path\n 157→   */\n 158→  startWatching(watcherId) {\n 159→    const watcher = this.#watchers.get(watcherId);\n 160→    if (!watcher || !watcher.enabled) return false;\n 161→\n 162→    // Already watching?\n 163→    if (this.#fsWatchers.has(watcherId)) {\n 164→      return true;\n 165→    }\n 166→\n 167→    try {\n 168→      const fsWatcher = watch(\n 169→        watcher.path,\n 170→        { recursive: watcher.recursive },\n 171→        (eventType, filename) => {\n 172→          this.#handleFileEvent(watcherId, eventType, filename);\n 173→        }\n 174→      );\n 175→\n 176→      fsWatcher.on('error', (error) => {\n 177→        console.error(`File watcher error for ${watcher.path}:`, error.message);\n 178→      });\n 179→\n 180→      this.#fsWatchers.set(watcherId, fsWatcher);\n 181→      return true;\n 182→    } catch (error) {\n 183→      console.error(`Failed to start watching ${watcher.path}:`, error.message);\n 184→      return false;\n 185→    }\n 186→  }\n 187→\n 188→  /**\n 189→   * Handle file change event with debouncing\n 190→   */\n 191→  #handleFileEvent(watcherId, eventType, filename) {\n 192→    const watcher = this.#watchers.get(watcherId);\n 193→    if (!watcher) return;\n 194→\n 195→    // Clear existing debounce timer\n 196→    const existingTimer = this.#debounceTimers.get(watcherId);\n 197→    if (existingTimer) {\n 198→      clearTimeout(existingTimer);\n 199→    }\n 200→\n 201→    // Set new debounce timer\n 202→    const timer = setTimeout(async () => {\n 203→      // Update watcher state\n 204→      watcher.lastEventAt = Date.now();\n 205→      watcher.lastEventType = eventType;\n 206→\n 207→      // Notify via callback\n 208→      if (this.#notificationCallback) {\n 209→        await this.#notificationCallback(watcher.chatId, {\n 210→          ...watcher,\n 211→          eventType,\n 212→          filename\n 213→        });\n 214→      }\n 215→\n 216→      this.#debounceTimers.delete(watcherId);\n 217→    }, this.#debounceMs);\n 218→\n 219→    this.#debounceTimers.set(watcherId, timer);\n 220→  }\n 221→\n 222→  /**\n 223→   * Stop watching a path\n 224→   */\n 225→  stopWatching(watcherId) {\n 226→    const fsWatcher = this.#fsWatchers.get(watcherId);\n 227→    if (fsWatcher) {\n 228→      fsWatcher.close();\n 229→      this.#fsWatchers.delete(watcherId);\n 230→    }\n 231→\n 232→    // Clear any pending debounce timer\n 233→    const timer = this.#debounceTimers.get(watcherId);\n 234→    if (timer) {\n 235→      clearTimeout(timer);\n 236→      this.#debounceTimers.delete(watcherId);\n 237→    }\n 238→\n 239→    return true;\n 240→  }\n 241→\n 242→  /**\n 243→   * Stop all watchers\n 244→   */\n 245→  stopAllWatchers() {\n 246→    for (const [watcherId] of this.#fsWatchers) {\n 247→      this.stopWatching(watcherId);\n 248→    }\n 249→  }\n 250→\n 251→  /**\n 252→   * Check if a watcher is active\n 253→   */\n 254→  isWatcherActive(watcherId) {\n 255→    return this.#fsWatchers.has(watcherId);\n 256→  }\n 257→\n 258→  /**\n 259→   * Save watchers to disk\n 260→   */\n 261→  async saveWatches() {\n 262→    this.#checkInitialized();\n 263→    await this.#ensureDataDir();\n 264→\n 265→    const filePath = join(this.#dataDir, this.#watchersFile);\n 266→    const watchers = Array.from(this.#watchers.values());\n 267→    await writeFile(filePath, JSON.stringify(watchers, null, 2), 'utf-8');\n 268→  }\n 269→\n 270→  /**\n 271→   * Load watchers from disk\n 272→   */\n 273→  async loadWatches() {\n 274→    this.#checkInitialized();\n 275→\n 276→    try {\n 277→      const filePath = join(this.#dataDir, this.#watchersFile);\n 278→      const content = await readFile(filePath, 'utf-8');\n 279→      const watchers = JSON.parse(content);\n 280→\n 281→      this.#watchers.clear();\n 282→      for (const watcher of watchers) {\n 283→        if (watcher.id && watcher.path && watcher.chatId) {\n 284→          this.#watchers.set(watcher.id, watcher);\n 285→        }\n 286→      }\n 287→    } catch (error) {\n 288→      if (error.code !== 'ENOENT') {\n 289→        console.error('Failed to load watchers:', error.message);\n 290→      }\n 291→      this.#watchers.clear();\n 292→    }\n 293→  }\n 294→\n 295→  /**\n 296→   * Restore watchers - load from disk and start watching\n 297→   */\n 298→  async restoreWatches() {\n 299→    await this.loadWatches();\n 300→\n 301→    // Start watching all enabled watchers\n 302→    for (const watcher of this.#watchers.values()) {\n 303→      if (watcher.enabled) {\n 304→        this.startWatching(watcher.id);\n 305→      }\n 306→    }\n 307→  }\n 308→}\n 309→\n 310→export const fileWatcherService = new FileWatcherServiceClass();\n 311→export default FileWatcherServiceClass;\n 312→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__timestamp":"2026-03-12T21:52:10.741Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
{"type":"user","uuid":"5001ad4e-8d5b-4270-a38d-eec13b743097","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce4091e76e01a93102ce4520260d1","content":[{"type":"text","text":"   1→/**\n   2→ * /cron Command Handler\n   3→ * F-014: Notification and Scheduled Tasks\n   4→ *\n   5→ * Handles scheduled task creation with cron expressions and one-time execution.\n   6→ */\n   7→\n   8→import { scheduledTaskService } from '../../../services/scheduled-task-service.js';\n   9→import { sessionStore } from '../../../services/session-store.js';\n  10→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  11→\n  12→export const cronMeta = {\n  13→  name: 'cron',\n  14→  aliases: [],\n  15→  description: '创建定时任务',\n  16→  usage: '/cron add <cron表达式> <命令> | /cron add --once <时间> <命令>',\n  17→  examples: [\n  18→    '/cron add \"*/5 * * * *\" echo hello',\n  19→    '/cron add --once \"2026-03-15 10:00\" echo hello',\n  20→    '/cron add --once \"2026-03-15 10:00\" npm test'\n  21→  ],\n  22→  params: [],\n  23→  requiresAuth: true,\n  24→  minRole: 'operator',\n  25→  helpText: '/cron add <cron表达式> <命令>\\n' +\n  26→    '/cron add --once <时间> <命令>\\n' +\n  27→    '\\n' +\n  28→    'Cron 表达式格式: 分 时 日 月 周\\n' +\n  29→    '示例:\\n' +\n  30→    '  */5 * * * *    每5分钟\\n' +\n  31→    '  0 * * * *      每小时\\n' +\n  32→    '  0 0 * * *      每天0点\\n' +\n  33→    '  0 9 * * 1-5    工作日上午9点\\n' +\n  34→    '\\n' +\n  35→    '一次性任务时间格式:\\n' +\n  36→    '  \"2026-03-15 10:00\" 或 ISO 格式'\n  37→};\n  38→\n  39→/**\n  40→ * Parse cron add command\n  41→ * @param {string[]} args\n  42→ * @returns {{type: 'cron'|'once', schedule: string, command: string}|null}\n  43→ */\n  44→export function parseCronAddCommand(args) {\n  45→  if (!args || args.length < 3) {\n  46→    return null;\n  47→  }\n  48→\n  49→  // Check for --once flag\n  50→  if (args[0].toLowerCase() === 'add' && args[1] === '--once') {\n  51→    // Format: add --once \"datetime\" <command>\n  52→    const schedule = args[2];\n  53→    const command = args.slice(3).join(' ');\n  54→    return { type: 'once', schedule, command };\n  55→  }\n  56→\n  57→  // Format: add \"cron\" <command>\n  58→  if (args[0].toLowerCase() === 'add') {\n  59→    const schedule = args[1];\n  60→    const command = args.slice(2).join(' ');\n  61→    return { type: 'cron', schedule, command };\n  62→  }\n  63→\n  64→  return null;\n  65→}\n  66→\n  67→/**\n  68→ * Handle /cron command\n  69→ * @param {Object} handlerCtx - Handler context\n  70→ */\n  71→export async function handleCron(handlerCtx) {\n  72→  const { reply, args = [], from, chat, sessionId } = handlerCtx;\n  73→\n  74→  if (args.length === 0) {\n  75→    await reply([\n  76→      '⏰ *定时任务命令用法*',\n  77→      '',\n  78→      '```',\n  79→      '/cron add <cron表达式> <命令>',\n  80→      '/cron add --once <时间> <命令>',\n  81→      '```',\n  82→      '',\n  83→      'Cron 表达式格式: 分 时 日 月 周',\n  84→      '示例:',\n  85→      '  `*/5 * * * *` 每5分钟',\n  86→      '  `0 * * * *` 每小时',\n  87→      '  `0 0 * * *` 每天0点',\n  88→      '',\n  89→      '一次性任务时间格式:',\n  90→      '  `\"2026-03-15 10:00\"`',\n  91→      '',\n  92→      '使用 /jobs 查看和管理已创建的任务'\n  93→    ].join('\\n'));\n  94→    return;\n  95→  }\n  96→\n  97→  const parsed = parseCronAddCommand(args);\n  98→\n  99→  if (!parsed) {\n 100→    await reply('❌ 命令格式错误。用法: /cron add <cron表达式> <命令>');\n 101→    return;\n 102→  }\n 103→\n 104→  if (!parsed.command) {\n 105→    await reply('❌ 请提供要执行的命令。');\n 106→    return;\n 107→  }\n 108→\n 109→  try {\n 110→    const chatId = String(chat.id);\n 111→    const userId = String(from.id);\n 112→    const cwd = sessionStore.getCwd(sessionId) || process.cwd();\n 113→\n 114→    let task;\n 115→    if (parsed.type === 'once') {\n 116→      task = scheduledTaskService.addOneTimeTask({\n 117→        schedule: parsed.schedule,\n 118→        command: parsed.command,\n 119→        chatId,\n 120→        userId,\n 121→        cwd\n 122→      });\n 123→    } else {\n 124→      task = scheduledTaskService.addCronTask({\n 125→        schedule: parsed.schedule,\n 126→        command: parsed.command,\n 127→        chatId,\n 128→        userId,\n 129→        cwd\n 130→      });\n 131→    }\n 132→\n 133→    // Save tasks\n 134→    await scheduledTaskService.saveTasks();\n 135→\n 136→    const nextRun = task.nextRunAt\n 137→      ? new Date(task.nextRunAt).toLocaleString()\n 138→      : '计算中...';\n 139→\n 140→    await reply([\n 141→      '✅ *定时任务已创建*',\n 142→      '',\n 143→      `ID: \\`${task.id}\\``,\n 144→      `类型: ${task.type === 'cron' ? '周期任务' : '一次性任务'}`,\n 145→      `调度: \\`${task.schedule}\\``,\n 146→      `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n 147→      `下次执行: ${nextRun}`\n 148→    ].join('\\n'));\n 149→  } catch (error) {\n 150→    const message = error instanceof Error ? error.message : String(error);\n 151→    await reply(`❌ 创建任务失败: ${escapeMarkdownV2(message)}`);\n 152→  }\n 153→}\n 154→\n 155→export default {\n 156→  cronMeta,\n 157→  handleCron,\n 158→  parseCronAddCommand\n 159→};\n 160→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__timestamp":"2026-03-12T21:52:10.742Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
{"type":"user","uuid":"a9e0d94a-f5fe-40a2-a35a-1829f676e18a","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce40920627036cfebedcb55c91f27","content":[{"type":"text","text":"   1→/**\n   2→ * /jobs Command Handler\n   3→ * F-014: Notification and Scheduled Tasks\n   4→ *\n   5→ * Manages scheduled tasks - list, pause, resume, delete.\n   6→ */\n   7→\n   8→import { scheduledTaskService } from '../../../services/scheduled-task-service.js';\n   9→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  10→\n  11→export const jobsMeta = {\n  12→  name: 'jobs',\n  13→  aliases: [],\n  14→  description: '管理定时任务',\n  15→  usage: '/jobs <list|pause|resume|delete> [ID]',\n  16→  examples: [\n  17→    '/jobs list',\n  18→    '/jobs pause abc123',\n  19→    '/jobs resume abc123',\n  20→    '/jobs delete abc123'\n  21→  ],\n  22→  params: [],\n  23→  requiresAuth: true,\n  24→  minRole: 'operator',\n  25→  helpText: '/jobs <子命令> [参数]\\n' +\n  26→    '子命令:\\n' +\n  27→    '  list           列出所有任务\\n' +\n  28→    '  pause <ID>     暂停任务\\n' +\n  29→    '  resume <ID>    恢复任务\\n' +\n  30→    '  delete <ID>    删除任务'\n  31→};\n  32→\n  33→/**\n  34→ * Parse subcommand from arguments\n  35→ * @param {string[]} args\n  36→ * @returns {{subcommand: string, arg?: string}}\n  37→ */\n  38→export function parseJobsSubcommand(args) {\n  39→  if (!args || args.length === 0) {\n  40→    return { subcommand: 'list' };\n  41→  }\n  42→\n  43→  const subcommand = args[0].toLowerCase();\n  44→  const arg = args.slice(1).join(' ');\n  45→\n  46→  return { subcommand, arg };\n  47→}\n  48→\n  49→/**\n  50→ * Handle /jobs command\n  51→ * @param {Object} handlerCtx - Handler context\n  52→ */\n  53→export async function handleJobs(handlerCtx) {\n  54→  const { reply, args = [], chat } = handlerCtx;\n  55→\n  56→  const { subcommand, arg } = parseJobsSubcommand(args);\n  57→\n  58→  switch (subcommand) {\n  59→    case 'list':\n  60→      await handleList(reply, String(chat.id));\n  61→      break;\n  62→    case 'pause':\n  63→      await handlePause(arg, reply);\n  64→      break;\n  65→    case 'resume':\n  66→      await handleResume(arg, reply);\n  67→      break;\n  68→    case 'delete':\n  69→    case 'remove':\n  70→      await handleDelete(arg, reply);\n  71→      break;\n  72→    default:\n  73→      await reply([\n  74→        '📋 *定时任务命令用法*',\n  75→        '',\n  76→        '```',\n  77→        '/jobs list           列出所有任务',\n  78→        '/jobs pause <ID>     暂停任务',\n  79→        '/jobs resume <ID>    恢复任务',\n  80→        '/jobs delete <ID>    删除任务',\n  81→        '```'\n  82→      ].join('\\n'));\n  83→  }\n  84→}\n  85→\n  86→/**\n  87→ * Handle list subcommand\n  88→ * @param {Function} reply\n  89→ * @param {string} chatId\n  90→ */\n  91→async function handleList(reply, chatId) {\n  92→  const tasks = scheduledTaskService.listTasks({ chatId });\n  93→\n  94→  if (tasks.length === 0) {\n  95→    await reply('📋 当前没有配置任何定时任务。');\n  96→    return;\n  97→  }\n  98→\n  99→  const lines = [\n 100→    `📋 *定时任务列表* (${tasks.length})`,\n 101→    ''\n 102→  ];\n 103→\n 104→  for (const task of tasks) {\n 105→    const status = task.enabled ? '✅' : '⏸️';\n 106→    const type = task.type === 'cron' ? '周期' : '一次';\n 107→    const lastRun = task.lastRunAt\n 108→      ? new Date(task.lastRunAt).toLocaleString()\n 109→      : '从未';\n 110→    const nextRun = task.nextRunAt\n 111→      ? new Date(task.nextRunAt).toLocaleString()\n 112→      : '-';\n 113→\n 114→    lines.push(`${status} \\`${task.id.substring(0, 8)}...\\``);\n 115→    lines.push(`   类型: ${type} | 调度: \\`${task.schedule}\\``);\n 116→    lines.push(`   命令: \\`${truncate(task.command, 30)}\\``);\n 117→    lines.push(`   上次: ${lastRun} | 下次: ${nextRun}`);\n 118→    lines.push('');\n 119→  }\n 120→\n 121→  lines.push('使用 /jobs pause|resume|delete <ID> 管理任务');\n 122→\n 123→  await reply(lines.join('\\n'));\n 124→}\n 125→\n 126→/**\n 127→ * Handle pause subcommand\n 128→ * @param {string} taskId\n 129→ * @param {Function} reply\n 130→ */\n 131→async function handlePause(taskId, reply) {\n 132→  if (!taskId) {\n 133→    await reply('❌ 请提供任务 ID。用法: /jobs pause <任务ID>');\n 134→    return;\n 135→  }\n 136→\n 137→  const trimmedId = taskId.trim();\n 138→  const task = findTaskById(trimmedId);\n 139→\n 140→  if (!task) {\n 141→    await reply(`❌ 任务 \\`${trimmedId}\\` 不存在。`);\n 142→    return;\n 143→  }\n 144→\n 145→  const success = scheduledTaskService.pauseTask(task.id);\n 146→\n 147→  if (success) {\n 148→    await scheduledTaskService.saveTasks();\n 149→    await reply(`✅ 任务 \\`${trimmedId}\\` 已暂停。`);\n 150→  } else {\n 151→    await reply(`❌ 暂停任务失败。`);\n 152→  }\n 153→}\n 154→\n 155→/**\n 156→ * Handle resume subcommand\n 157→ * @param {string} taskId\n 158→ * @param {Function} reply\n 159→ */\n 160→async function handleResume(taskId, reply) {\n 161→  if (!taskId) {\n 162→    await reply('❌ 请提供任务 ID。用法: /jobs resume <任务ID>');\n 163→    return;\n 164→  }\n 165→\n 166→  const trimmedId = taskId.trim();\n 167→  const task = findTaskById(trimmedId);\n 168→\n 169→  if (!task) {\n 170→    await reply(`❌ 任务 \\`${trimmedId}\\` 不存在。`);\n 171→    return;\n 172→  }\n 173→\n 174→  const success = scheduledTaskService.resumeTask(task.id);\n 175→\n 176→  if (success) {\n 177→    await scheduledTaskService.saveTasks();\n 178→    await reply(`✅ 任务 \\`${trimmedId}\\` 已恢复。`);\n 179→  } else {\n 180→    await reply(`❌ 恢复任务失败。`);\n 181→  }\n 182→}\n 183→\n 184→/**\n 185→ * Handle delete subcommand\n 186→ * @param {string} taskId\n 187→ * @param {Function} reply\n 188→ */\n 189→async function handleDelete(taskId, reply) {\n 190→  if (!taskId) {\n 191→    await reply('❌ 请提供任务 ID。用法: /jobs delete <任务ID>');\n 192→    return;\n 193→  }\n 194→\n 195→  const trimmedId = taskId.trim();\n 196→  const task = findTaskById(trimmedId);\n 197→\n 198→  if (!task) {\n 199→    await reply(`❌ 任务 \\`${trimmedId}\\` 不存在。`);\n 200→    return;\n 201→  }\n 202→\n 203→  const removed = scheduledTaskService.deleteTask(task.id);\n 204→\n 205→  if (removed) {\n 206→    await scheduledTaskService.saveTasks();\n 207→    await reply(`✅ 任务 \\`${trimmedId}\\` 已删除。`);\n 208→  } else {\n 209→    await reply(`❌ 删除任务失败。`);\n 210→  }\n 211→}\n 212→\n 213→/**\n 214→ * Find task by partial ID\n 215→ * @param {string} partialId\n 216→ * @returns {Object|null}\n 217→ */\n 218→function findTaskById(partialId) {\n 219→  const tasks = scheduledTaskService.listTasks();\n 220→  // First try exact match\n 221→  const exact = tasks.find(t => t.id === partialId);\n 222→  if (exact) return exact;\n 223→  // Then try prefix match\n 224→  return tasks.find(t => t.id.startsWith(partialId));\n 225→}\n 226→\n 227→/**\n 228→ * Truncate string to max length\n 229→ * @param {string} str\n 230→ * @param {number} maxLen\n 231→ * @returns {string}\n 232→ */\n 233→function truncate(str, maxLen) {\n 234→  if (!str) return '';\n 235→  if (str.length <= maxLen) return str;\n 236→  return str.substring(0, maxLen) + '...';\n 237→}\n 238→\n 239→export default {\n 240→  jobsMeta,\n 241→  handleJobs,\n 242→  parseJobsSubcommand\n 243→};\n 244→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__timestamp":"2026-03-12T21:52:10.742Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
{"type":"user","uuid":"0ee64f62-f166-4ae7-937f-051e0d5aeb23","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce409226276ebcd0113f25a865f46","content":[{"type":"text","text":"   1→/**\n   2→ * /watch Command Handler\n   3→ * F-014: Notification and Scheduled Tasks\n   4→ *\n   5→ * Handles file system monitoring with /watch and /unwatch commands.\n   6→ */\n   7→\n   8→import { fileWatcherService } from '../../../services/file-watcher-service.js';\n   9→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n  10→import { config } from '../../../config.js';\n  11→import { resolve, relative } from 'node:path';\n  12→\n  13→export const watchMeta = {\n  14→  name: 'watch',\n  15→  aliases: [],\n  16→  description: '监听文件或目录变更',\n  17→  usage: '/watch <路径> | /unwatch <路径|ID>',\n  18→  examples: [\n  19→    '/watch /path/to/file.txt',\n  20→    '/watch /path/to/directory',\n  21→    '/unwatch /path/to/file.txt',\n  22→    '/unwatch abc123'\n  23→  ],\n  24→  params: [],\n  25→  requiresAuth: true,\n  26→  minRole: 'operator',\n  27→  helpText: '/watch <路径>  监听文件或目录变更\\n' +\n  28→    '/unwatch <路径|ID>  取消监听\\n' +\n  29→    '\\n' +\n  30→    '监听的路径必须在允许的根目录范围内。'\n  31→};\n  32→\n  33→/**\n  34→ * Handle /watch command\n  35→ * @param {Object} handlerCtx - Handler context\n  36→ */\n  37→export async function handleWatch(handlerCtx) {\n  38→  const { reply, args = [], from, chat } = handlerCtx;\n  39→\n  40→  if (args.length === 0) {\n  41→    await reply([\n  42→      '📁 *文件监听命令用法*',\n  43→      '',\n  44→      '```',\n  45→      '/watch <路径>    监听文件或目录',\n  46→      '/unwatch <路径>  取消监听',\n  47→      '```',\n  48→      '',\n  49→      '监听的路径必须在允许的根目录范围内。',\n  50→      '',\n  51→      '使用 /watch list 查看当前所有监听'\n  52→    ].join('\\n'));\n  53→    return;\n  54→  }\n  55→\n  56→  // Handle list subcommand\n  57→  if (args[0].toLowerCase() === 'list') {\n  58→    await handleList(reply, String(chat.id));\n  59→    return;\n  60→  }\n  61→\n  62→  // Handle unwatch\n  63→  if (args[0].toLowerCase() === 'unwatch' || args[0].toLowerCase() === 'remove') {\n  64→    await handleUnwatch(args.slice(1).join(' '), reply, String(chat.id));\n  65→    return;\n  66→  }\n  67→\n  68→  // Handle watch add\n  69→  const watchPath = args.join(' ');\n  70→\n  71→  try {\n  72→    const chatId = String(chat.id);\n  73→    const userId = String(from.id);\n  74→\n  75→    // Resolve relative path if needed\n  76→    const resolvedPath = resolve(watchPath);\n  77→\n  78→    // Use config allowed roots if available, otherwise allow all\n  79→    const allowedRoots = config.telegramFileAllowedRoots.length > 0\n  80→      ? config.telegramFileAllowedRoots\n  81→      : null;\n  82→\n  83→    // Initialize service if needed\n  84→    if (!fileWatcherService.isInitialized()) {\n  85→      fileWatcherService.initFileWatcherService({\n  86→        dataDir: config.systemMonitorDataDir,\n  87→        watchersFile: config.fileWatchersPath,\n  88→        maxWatchers: config.maxFileWatchers,\n  89→        debounceMs: config.taskDebounceMs,\n  90→        allowedRoots: allowedRoots || [process.cwd()]\n  91→      });\n  92→    }\n  93→\n  94→    const watcher = await fileWatcherService.addWatch({\n  95→      path: resolvedPath,\n  96→      chatId,\n  97→      userId,\n  98→      recursive: true\n  99→    });\n 100→\n 101→    // Save watchers\n 102→    await fileWatcherService.saveWatches();\n 103→\n 104→    // Start watching\n 105→    fileWatcherService.startWatching(watcher.id);\n 106→\n 107→    await reply([\n 108→      '✅ *文件监听已添加*',\n 109→      '',\n 110→      `ID: \\`${watcher.id.substring(0, 8)}...\\``,\n 111→      `路径: \\`${escapeMarkdownV2(resolvedPath)}\\``,\n 112→      `状态: 活跃`,\n 113→      '',\n 114→      '当文件或目录发生变更时，你将收到通知。'\n 115→    ].join('\\n'));\n 116→  } catch (error) {\n 117→    const message = error instanceof Error ? error.message : String(error);\n 118→    await reply(`❌ 添加监听失败: ${escapeMarkdownV2(message)}`);\n 119→  }\n 120→}\n 121→\n 122→/**\n 123→ * Handle list subcommand\n 124→ * @param {Function} reply\n 125→ * @param {string} chatId\n 126→ */\n 127→async function handleList(reply, chatId) {\n 128→  if (!fileWatcherService.isInitialized()) {\n 129→    await reply('📋 当前没有任何文件监听。');\n 130→    return;\n 131→  }\n 132→\n 133→  const watchers = fileWatcherService.listWatches({ chatId });\n 134→\n 135→  if (watchers.length === 0) {\n 136→    await reply('📋 当前没有配置任何文件监听。');\n 137→    return;\n 138→  }\n 139→\n 140→  const lines = [\n 141→    `📋 *文件监听列表* (${watchers.length})`,\n 142→    ''\n 143→  ];\n 144→\n 145→  for (const watcher of watchers) {\n 146→    const status = watcher.enabled ? (fileWatcherService.isWatcherActive(watcher.id) ? '✅' : '⏸️') : '⏸️';\n 147→    const lastEvent = watcher.lastEventAt\n 148→      ? `${watcher.lastEventType} at ${new Date(watcher.lastEventAt).toLocaleString()}`\n 149→      : '无事件';\n 150→\n 151→    lines.push(`${status} \\`${watcher.id.substring(0, 8)}...\\``);\n 152→    lines.push(`   路径: \\`${truncate(watcher.path, 40)}\\``);\n 153→    lines.push(`   最近事件: ${lastEvent}`);\n 154→    lines.push('');\n 155→  }\n 156→\n 157→  lines.push('使用 /unwatch <路径|ID> 取消监听');\n 158→\n 159→  await reply(lines.join('\\n'));\n 160→}\n 161→\n 162→/**\n 163→ * Handle unwatch command\n 164→ * @param {string} pathOrId\n 165→ * @param {Function} reply\n 166→ * @param {string} chatId\n 167→ */\n 168→async function handleUnwatch(pathOrId, reply, chatId) {\n 169→  if (!pathOrId) {\n 170→    await reply('❌ 请提供路径或 ID。用法: /unwatch <路径|ID>');\n 171→    return;\n 172→  }\n 173→\n 174→  if (!fileWatcherService.isInitialized()) {\n 175→    await reply('❌ 当前没有任何文件监听。');\n 176→    return;\n 177→  }\n 178→\n 179→  const trimmedInput = pathOrId.trim();\n 180→\n 181→  // Try to find by ID first\n 182→  const watchers = fileWatcherService.listWatches({ chatId });\n 183→  let watcher = watchers.find(w => w.id === trimmedInput || w.id.startsWith(trimmedInput));\n 184→\n 185→  // If not found by ID, try by path\n 186→  if (!watcher) {\n 187→    const resolvedPath = resolve(trimmedInput);\n 188→    watcher = watchers.find(w => w.path === resolvedPath);\n 189→  }\n 190→\n 191→  if (!watcher) {\n 192→    await reply(`❌ 未找到监听: \\`${trimmedInput}\\``);\n 193→    return;\n 194→  }\n 195→\n 196→  const removed = fileWatcherService.removeWatch(watcher.id);\n 197→\n 198→  if (removed) {\n 199→    await fileWatcherService.saveWatches();\n 200→    await reply([\n 201→      '✅ *文件监听已取消*',\n 202→      '',\n 203→      `路径: \\`${escapeMarkdownV2(watcher.path)}\\``\n 204→    ].join('\\n'));\n 205→  } else {\n 206→    await reply('❌ 取消监听失败。');\n 207→  }\n 208→}\n 209→\n 210→/**\n 211→ * Truncate string to max length\n 212→ * @param {string} str\n 213→ * @param {number} maxLen\n 214→ * @returns {string}\n 215→ */\n 216→function truncate(str, maxLen) {\n 217→  if (!str) return '';\n 218→  if (str.length <= maxLen) return str;\n 219→  return str.substring(0, maxLen) + '...';\n 220→}\n 221→\n 222→export default {\n 223→  watchMeta,\n 224→  handleWatch\n 225→};\n 226→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__timestamp":"2026-03-12T21:52:10.743Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
{"type":"user","uuid":"0fa7c6fe-a781-409b-acc2-4c6c4b4017ef","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce40924480307ab74fe6f67c71c4b","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20),\n  43→  // F-011: AI CLI Proxy\n  44→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n  45→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n  46→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true'),\n  47→  // F-012: System Monitor\n  48→  SYSTEM_MONITOR_INTERVAL_MS: z.coerce.number().int().positive().default(60000),\n  49→  SYSTEM_MONITOR_DATA_DIR: z.string().optional().default('data'),\n  50→  // F-013: Session and Context Manager\n  51→  SESSION_TIMEOUT_MS: z.coerce.number().int().positive().default(1800000), // 30 min\n  52→  SESSION_HISTORY_MAX: z.coerce.number().int().positive().default(100),\n  53→  SESSION_PERSISTENCE_DIR: z.string().optional().default('data/sessions'),\n  54→  ALIAS_PERSISTENCE_PATH: z.string().optional().default('data/aliases.json'),\n  55→  // F-014: Notification and Scheduled Tasks\n  56→  SCHEDULED_TASKS_PATH: z.string().optional().default('data/scheduled-tasks.json'),\n  57→  FILE_WATCHERS_PATH: z.string().optional().default('data/file-watchers.json'),\n  58→  MAX_SCHEDULED_TASKS: z.coerce.number().int().positive().default(100),\n  59→  MAX_FILE_WATCHERS: z.coerce.number().int().positive().default(50),\n  60→  TASK_DEBOUNCE_MS: z.coerce.number().int().positive().default(500)\n  61→});\n  62→\n  63→const parsed = schema.parse(process.env);\n  64→\n  65→function parseAllowedUserIds(input) {\n  66→  return new Set(\n  67→    input\n  68→      .split(',')\n  69→      .map((id) => id.trim())\n  70→      .filter(Boolean)\n  71→  );\n  72→}\n  73→\n  74→function parseCsvList(input) {\n  75→  return input\n  76→    .split(',')\n  77→    .map((item) => item.trim())\n  78→    .filter(Boolean);\n  79→}\n  80→\n  81→function parseBoolean(input) {\n  82→  const normalized = (input ?? '').trim().toLowerCase();\n  83→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  84→}\n  85→\n  86→/**\n  87→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  88→ * Format: \"123456789:admin,987654321:operator\"\n  89→ * @param {string} input\n  90→ * @returns {Map<string, string>}\n  91→ */\n  92→function parseUserPermissions(input) {\n  93→  const permissions = new Map();\n  94→  if (!input || !input.trim()) {\n  95→    return permissions;\n  96→  }\n  97→\n  98→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  99→  for (const entry of entries) {\n 100→    const [userId, role] = entry.split(':').map((s) => s.trim());\n 101→    if (userId && role) {\n 102→      const normalizedRole = role.toLowerCase();\n 103→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n 104→        permissions.set(userId, normalizedRole);\n 105→      }\n 106→    }\n 107→  }\n 108→  return permissions;\n 109→}\n 110→\n 111→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n 112→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n 113→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 114→}\n 115→\n 116→const pipelineInfra = loadPipelineInfraConfig({\n 117→  env: process.env,\n 118→  argv: process.argv.slice(2),\n 119→  cwd: process.cwd()\n 120→});\n 121→\n 122→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 123→\n 124→export const config = Object.freeze({\n 125→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 126→  enableTelegram,\n 127→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 128→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 129→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 130→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 131→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 132→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 133→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 134→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 135→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 136→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 137→  webHost: parsed.WEB_HOST,\n 138→  webPort: parsed.WEB_PORT,\n 139→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 140→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 141→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 142→  logLevel: parsed.LOG_LEVEL,\n 143→  // F-006: Safety and Permission Guard\n 144→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 145→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 146→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 147→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 148→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 149→  // F-009: General Command Executor\n 150→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 151→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 152→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 153→  // F-010: File Manager\n 154→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 155→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 156→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 157→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 158→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 159→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 160→  // F-011: AI CLI Proxy\n 161→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 162→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 163→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 164→  // F-012: System Monitor\n 165→  systemMonitorIntervalMs: parsed.SYSTEM_MONITOR_INTERVAL_MS,\n 166→  systemMonitorDataDir: parsed.SYSTEM_MONITOR_DATA_DIR,\n 167→  // F-013: Session and Context Manager\n 168→  sessionTimeoutMs: parsed.SESSION_TIMEOUT_MS,\n 169→  sessionHistoryMax: parsed.SESSION_HISTORY_MAX,\n 170→  sessionPersistenceDir: parsed.SESSION_PERSISTENCE_DIR,\n 171→  aliasPersistencePath: parsed.ALIAS_PERSISTENCE_PATH,\n 172→  // F-014: Notification and Scheduled Tasks\n 173→  scheduledTasksPath: parsed.SCHEDULED_TASKS_PATH,\n 174→  fileWatchersPath: parsed.FILE_WATCHERS_PATH,\n 175→  maxScheduledTasks: parsed.MAX_SCHEDULED_TASKS,\n 176→  maxFileWatchers: parsed.MAX_FILE_WATCHERS,\n 177→  taskDebounceMs: parsed.TASK_DEBOUNCE_MS,\n 178→  pipelineInfra: Object.freeze({\n 179→    ...pipelineInfra,\n 180→    daemonLogPaths\n 181→  })\n 182→});\n 183→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__timestamp":"2026-03-12T21:52:10.743Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
