} from '../services/session-context-service.js';\n  55→import { aliasStore } from '../services/alias-store.js';\n  56→import { scheduledTaskService } from '../services/scheduled-task-service.js';\n  57→import { fileWatcherService } from '../services/file-watcher-service.js';\n  58→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n  59→import { escapeMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n  60→\n  61→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  62→const STREAM_MIN_CHARS = 220;\n  63→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  64→const TYPING_INTERVAL_MS = 3500;\n  65→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  66→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  67→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  68→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  69→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  70→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  71→const TMP_DIR = path.resolve(os.tmpdir());\n  72→const HOME_DIR = path.resolve(os.homedir());\n  73→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  74→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  75→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  76→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  77→\n  78→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  79→  const normalized = configuredDirs\n  80→    .map((dir) => String(dir ?? '').trim())\n  81→    .filter(Boolean)\n  82→    .map((dir) => path.resolve(dir));\n  83→\n  84→  if (normalized.length > 0) {\n  85→    return [...new Set(normalized)];\n  86→  }\n  87→\n  88→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  89→}\n  90→\n  91→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  92→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  93→\n  94→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  95→  const chunks = [];\n  96→  for (let i = 0; i < text.length; i += chunkSize) {\n  97→    chunks.push(text.slice(i, i + chunkSize));\n  98→  }\n  99→  return chunks;\n 100→}\n 101→\n 102→function truncate(text, maxLen) {\n 103→  if (!text) return '';\n 104→  if (text.length <= maxLen) return text;\n 105→  return text.substring(0, maxLen) + '...';\n 106→}\n 107→\n 108→function sanitizeMarkerPath(raw) {\n 109→  return String(raw ?? '')\n 110→    .trim()\n 111→    .replace(/^['\"`]+/, '')\n 112→    .replace(/['\"`]+$/, '');\n 113→}\n 114→\n 115→function extractFileMarkers(text = '') {\n 116→  const fileRefs = [];\n 117→\n 118→  const withSendFileRemoved = text.replace(\n 119→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n 120→    (_full, rawRef) => {\n 121→      const ref = sanitizeMarkerPath(rawRef);\n 122→      if (ref) {\n 123→        fileRefs.push(ref);\n 124→      }\n 125→      return '\\n';\n 126→    }\n 127→  );\n 128→\n 129→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n 130→    const ref = sanitizeMarkerPath(rawRef);\n 131→    if (ref) {\n 132→      fileRefs.push(ref);\n 133→    }\n 134→    return '';\n 135→  });\n 136→\n 137→  const withBacktickPathRemoved = withImageRemoved.replace(\n 138→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 139→    (_full, rawRef) => {\n 140→      const ref = sanitizeMarkerPath(rawRef);\n 141→      if (ref) {\n 142→        fileRefs.push(ref);\n 143→      }\n 144→      return '';\n 145→    }\n 146→  );\n 147→\n 148→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 149→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 150→    (_full, rawRef) => {\n 151→      const ref = sanitizeMarkerPath(rawRef);\n 152→      if (ref) {\n 153→        fileRefs.push(ref);\n 154→      }\n 155→      return '';\n 156→    }\n 157→  );\n 158→\n 159→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 160→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 161→    (_full, rawRef) => {\n 162→      const ref = sanitizeMarkerPath(rawRef);\n 163→      if (ref) {\n 164→        fileRefs.push(ref);\n 165→      }\n 166→      return '\\n';\n 167→    }\n 168→  );\n 169→\n 170→  return {\n 171→    fileRefs: [...new Set(fileRefs)],\n 172→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 173→  };\n 174→}\n 175→\n 176→function isPathWithinRoot(targetPath, rootPath) {\n 177→  const relative = path.relative(rootPath, targetPath);\n 178→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 179→}\n 180→\n 181→function isAllowedFilePath(filePath) {\n 182→  const resolved = path.resolve(filePath);\n 183→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 184→}\n 185→\n 186→function buildFileCandidates(normalizedPath) {\n 187→  if (path.isAbsolute(normalizedPath)) {\n 188→    return [normalizedPath];\n 189→  }\n 190→\n 191→  const baseName = path.basename(normalizedPath);\n 192→  const candidates = [\n 193→    path.resolve(process.cwd(), normalizedPath),\n 194→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 195→  ];\n 196→\n 197→  return [...new Set(candidates)];\n 198→}\n 199→\n 200→async function resolveLocalFilePath(fileRef) {\n 201→  const normalized = sanitizeMarkerPath(fileRef);\n 202→  if (!normalized) {\n 203→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 204→  }\n 205→\n 206→  if (!path.isAbsolute(normalized)) {\n 207→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 208→  }\n 209→\n 210→  const candidates = buildFileCandidates(normalized);\n 211→\n 212→  for (const candidate of candidates) {\n 213→    try {\n 214→      await access(candidate);\n 215→      return { filePath: candidate, triedPaths: candidates };\n 216→    } catch {\n 217→      // ignore\n 218→    }\n 219→  }\n 220→\n 221→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 222→}\n 223→\n 224→async function validateFileForTelegram(filePath) {\n 225→  const resolvedPath = path.resolve(filePath);\n 226→  if (!isAllowedFilePath(resolvedPath)) {\n 227→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 228→  }\n 229→\n 230→  const ext = path.extname(resolvedPath).toLowerCase();\n 231→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 232→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 233→  }\n 234→\n 235→  const fileStat = await stat(resolvedPath);\n 236→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 237→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 238→\n 239→  if (fileStat.size > maxSize) {\n 240→    return {\n 241→      ok: false,\n 242→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 243→    };\n 244→  }\n 245→\n 246→  return { ok: true, isPhoto, resolvedPath };\n 247→}\n 248→\n 249→function isTimeoutLikeError(message = '') {\n 250→  const normalized = String(message).toLowerCase();\n 251→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 252→}\n 253→\n 254→function sleep(ms) {\n 255→  return new Promise((resolve) => setTimeout(resolve, ms));\n 256→}\n 257→\n 258→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 259→  if (isPhoto) {\n 260→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 261→    return;\n 262→  }\n 263→\n 264→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 265→}\n 266→\n 267→async function replyFiles(ctx, fileRefs = []) {\n 268→  const results = [];\n 269→\n 270→  for (const fileRef of fileRefs) {\n 271→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 272→    if (!filePath) {\n 273→      const reason = rejectReason || 'not_found';\n 274→      results.push({ fileRef, sent: false, reason, triedPaths });\n 275→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 276→      continue;\n 277→    }\n 278→\n 279→    try {\n 280→      const validation = await validateFileForTelegram(filePath);\n 281→      if (!validation.ok) {\n 282→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 283→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 284→        continue;\n 285→      }\n 286→\n 287→      const actualPath = validation.resolvedPath;\n 288→      let sent = false;\n 289→      let lastReason = '';\n 290→\n 291→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 292→        try {\n 293→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 294→          sent = true;\n 295→          logger.info(\n 296→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 297→            'Telegram file sent'\n 298→          );\n 299→          break;\n 300→        } catch (error) {\n 301→          lastReason = error instanceof Error ? error.message : String(error);\n 302→          logger.warn(\n 303→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 304→            'Telegram file send attempt failed'\n 305→          );\n 306→\n 307→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 308→            await sleep(600);\n 309→            continue;\n 310→          }\n 311→\n 312→          break;\n 313→        }\n 314→      }\n 315→\n 316→      if (!sent) {\n 317→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 318→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 319→        continue;\n 320→      }\n 321→\n 322→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 323→    } catch (error) {\n 324→      const reason = error instanceof Error ? error.message : String(error);\n 325→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 326→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 327→    }\n 328→  }\n 329→\n 330→  return results;\n 331→}\n 332→\n 333→async function safeReply(ctx, text) {\n 334→  try {\n 335→    await ctx.reply(text);\n 336→    return true;\n 337→  } catch (error) {\n 338→    const reason = error instanceof Error ? error.message : String(error);\n 339→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 340→    return false;\n 341→  }\n 342→}\n 343→\n 344→async function replyLargeText(ctx, text) {\n 345→  const chunks = splitMessage(text);\n 346→  for (const chunk of chunks) {\n 347→    const ok = await safeReply(ctx, chunk);\n 348→    if (!ok) {\n 349→      break;\n 350→    }\n 351→  }\n 352→}\n 353→\n 354→async function safeEditMessageText(ctx, messageId, text) {\n 355→  const nextText = text && text.trim() ? text : ' ';\n 356→\n 357→  try {\n 358→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 359→  } catch (error) {\n 360→    const message = error instanceof Error ? error.message : String(error);\n 361→    if (message.includes('message is not modified')) {\n 362→      return;\n 363→    }\n 364→    throw error;\n 365→  }\n 366→}\n 367→\n 368→function createEditableStreamPublisher(ctx) {\n 369→  let fullText = '';\n 370→  let renderedText = '';\n 371→  let pendingChars = 0;\n 372→  let lastFlushAt = 0;\n 373→  let flushChain = Promise.resolve();\n 374→  let activeMessage = null;\n 375→  let activeSegmentIndex = 0;\n 376→  let publishedMessageCount = 0;\n 377→\n 378→  async function ensureActiveMessage() {\n 379→    if (activeMessage) {\n 380→      return;\n 381→    }\n 382→    activeMessage = await ctx.reply('处理中...');\n 383→    activeSegmentIndex = 0;\n 384→    publishedMessageCount += 1;\n 385→  }\n 386→\n 387→  async function render(force = false) {\n 388→    const now = Date.now();\n 389→\n 390→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 391→      return;\n 392→    }\n 393→\n 394→    if (fullText === renderedText) {\n 395→      pendingChars = 0;\n 396→      return;\n 397→    }\n 398→\n 399→    await ensureActiveMessage();\n 400→\n 401→    const segments = splitMessage(fullText);\n 402→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 403→\n 404→    while (activeSegmentIndex < targetLastIndex) {\n 405→      const text = segments[activeSegmentIndex] ?? ' ';\n 406→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 407→\n 408→      activeMessage = await ctx.reply('继续输出中...');\n 409→      activeSegmentIndex += 1;\n 410→      publishedMessageCount += 1;\n 411→    }\n 412→\n 413→    const activeText = segments[targetLastIndex] ?? ' ';\n 414→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 415→\n 416→    renderedText = fullText;\n 417→    pendingChars = 0;\n 418→    lastFlushAt = now;\n 419→  }\n 420→\n 421→  function enqueueRender(force = false) {\n 422→    flushChain = flushChain.then(() => render(force));\n 423→  }\n 424→\n 425→  return {\n 426→    push(text) {\n 427→      const appendText = text ?? '';\n 428→      if (!appendText) {\n 429→        return;\n 430→      }\n 431→      fullText += appendText;\n 432→      pendingChars += appendText.length;\n 433→      enqueueRender(false);\n 434→    },\n 435→    setFinalText(text) {\n 436→      fullText = text ?? '';\n 437→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 438→      enqueueRender(true);\n 439→    },\n 440→    async finish() {\n 441→      enqueueRender(true);\n 442→      await flushChain;\n 443→      return {\n 444→        outputLength: renderedText.length,\n 445→        messageCount: publishedMessageCount\n 446→      };\n 447→    }\n 448→  };\n 449→}\n 450→\n 451→function buildSessionId(ctx) {\n 452→  return String(ctx.chat.id);\n 453→}\n 454→\n 455→function ensureAllowed(ctx) {\n 456→  const userId = ctx.from?.id;\n 457→  if (!isAllowedUser(userId)) {\n 458→    throw new Error('当前账号未被授权使用该机器人。');\n 459→  }\n 460→}\n 461→\n 462→/**\n 463→ * Register all pipeline-related commands.\n 464→ */\n 465→function registerPipelineCommands() {\n 466→  registerCommand(pipelineMeta, handlePipeline);\n 467→  registerCommand(bugfixMeta, handleBugfix);\n 468→  registerCommand(plannerMeta, handlePlanner);\n 469→  registerCommand(statusMeta, handleStatus);\n 470→  registerCommand(logsMeta, handleLogs);\n 471→  registerCommand(stopMeta, handleStop);\n 472→  registerCommand(planMeta, handlePlan);\n 473→  registerCommand(auditMeta, handleAudit);\n 474→  registerCommand(commitMeta, handleCommit);\n 475→  registerCommand(commitsMeta, handleCommits);\n 476→  // F-009: New commands\n 477→  registerCommand(cdMeta, handleCd);\n 478→  registerCommand(moreMeta, handleMore);\n 479→  // F-010: File Manager commands\n 480→  registerCommand(lsMeta, handleLs);\n 481→  registerCommand(treeMeta, handleTree);\n 482→  registerCommand(catMeta, handleCat);\n 483→  registerCommand(headMeta, handleHead);\n 484→  registerCommand(tailMeta, handleTail);\n 485→  registerCommand(findMeta, handleFind);\n 486→  registerCommand(uploadMeta, handleUpload);\n 487→  registerCommand(downloadMeta, handleDownload);\n 488→  // F-012: System Monitor commands\n 489→  registerCommand(sysinfoMeta, handleSysinfo);\n 490→  registerCommand(psMeta, handlePs);\n 491→  registerCommand(killMeta, handleKill);\n 492→  registerCommand(monitorMeta, handleMonitor);\n 493→  // F-013: Session and Context Manager commands\n 494→  registerCommand(historyMeta, handleHistory);\n 495→  registerCommand(aliasMeta, handleAlias);\n 496→  registerCommand(sessionsMeta, handleSessions);\n 497→  // F-014: Notification and Scheduled Tasks commands\n 498→  registerCommand(cronMeta, handleCron);\n 499→  registerCommand(jobsMeta, handleJobs);\n 500→  registerCommand(watchMeta, handleWatch);\n 501→}\n 502→\n 503→export async function createTelegramBot() {\n 504→  const bot = new Telegraf(config.telegramBotToken, {\n 505→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 506→  });\n 507→\n 508→  // F-013: Initialize session context service\n 509→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n 510→  await aliasStore.initAliasStore({ filePath: config.aliasPersistencePath });\n 511→\n 512→  // F-013: Restore sessions from disk\n 513→  await sessionContextService.restoreSessions();\n 514→\n 515→  // F-013: Set up notification callback for session timeout\n 516→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n 517→    try {\n 518→      // Extract chat ID from session key (format: telegram:123456789)\n 519→      const chatId = sessionKey.replace('telegram:', '');\n 520→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n 521→    } catch (error) {\n 522→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n 523→    }\n 524→  });\n 525→\n 526→  // F-013: Start timeout watcher\n 527→  sessionContextService.startTimeoutWatcher();\n 528→\n 529→  // F-014: Initialize scheduled task service\n 530→  scheduledTaskService.initScheduledTaskService({\n 531→    dataDir: config.systemMonitorDataDir,\n 532→    tasksFile: config.scheduledTasksPath,\n 533→    maxTasks: config.maxScheduledTasks\n 534→  });\n 535→\n 536→  // F-014: Set up task execution callback\n 537→  scheduledTaskService.setExecuteCallback(async ({ command, cwd, sessionId, userId }) => {\n 538→    try {\n 539→      return await executeCommand({\n 540→        command,\n 541→        cwd,\n 542→        sessionId,\n 543→        userId,\n 544→        skipConfirmation: true // Skip confirmation for scheduled tasks\n 545→      });\n 546→    } catch (error) {\n 547→      return {\n 548→        stdout: '',\n 549→        stderr: error.message,\n 550→        exitCode: 1,\n 551→        timedOut: false\n 552→      };\n 553→    }\n 554→  });\n 555→\n 556→  // F-014: Set up task notification callback\n 557→  scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n 558→    try {\n 559→      const result = task.lastResult || {};\n 560→      const lines = [\n 561→        '⏰ *定时任务完成*',\n 562→        '',\n 563→        `任务ID: \\`${task.id.substring(0, 8)}...\\``,\n 564→        `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n 565→        `执行时间: ${new Date(result.executedAt || Date.now()).toLocaleString()}`,\n 566→        '',\n 567→        `exitCode: ${result.exitCode}`,\n 568→        result.stdout ? `stdout:\\n${truncate(result.stdout, 500)}` : 'stdout: (empty)',\n 569→        result.stderr ? `stderr:\\n${escapeMarkdownV2(truncate(result.stderr, 500))}` : 'stderr: (empty)'\n 570→      ];\n 571→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n 572→    } catch (error) {\n 573→      logger.warn({ taskId: task.id, error: error.message }, 'Failed to send task notification');\n 574→    }\n 575→  });\n 576→\n 577→  // F-014: Load and start scheduled tasks\n 578→  await scheduledTaskService.loadTasks();\n 579→  scheduledTaskService.startScheduler();\n 580→\n 581→  // F-014: Initialize file watcher service\n 582→  fileWatcherService.initFileWatcherService({\n 583→    dataDir: config.systemMonitorDataDir,\n 584→    watchersFile: config.fileWatchersPath,\n 585→    maxWatchers: config.maxFileWatchers,\n 586→    debounceMs: config.taskDebounceMs,\n 587→    allowedRoots: config.telegramFileAllowedRoots.length > 0\n 588→      ? config.telegramFileAllowedRoots\n 589→      : [process.cwd()]\n 590→  });\n 591→\n 592→  // F-014: Set up file watcher notification callback\n 593→  fileWatcherService.setNotificationCallback(async (chatId, watcher) => {\n 594→    try {\n 595→      const lines = [\n 596→        '📁 *文件变更检测*',\n 597→        '',\n 598→        `路径: \\`${escapeMarkdownV2(watcher.path)}\\``,\n 599→        `事件: ${watcher.eventType}`,\n 600→        `文件: ${watcher.filename || '(未知)'}`,\n 601→        `时间: ${new Date().toLocaleString()}`\n 602→      ];\n 603→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n 604→    } catch (error) {\n 605→      logger.warn({ watcherId: watcher.id, error: error.message }, 'Failed to send file watcher notification');\n 606→    }\n 607→  });\n 608→\n 609→  // F-014: Restore file watchers\n 610→  await fileWatcherService.restoreWatches();\n 611→\n 612→  // Register pipeline commands\n 613→  registerPipelineCommands();\n 614→\n 615→  bot.catch((error, ctx) => {\n 616→    const message = error instanceof Error ? error.message : String(error);\n 617→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 618→  });\n 619→\n 620→  bot.start(async (ctx) => {\n 621→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 622→  });\n 623→\n 624→  bot.help(async (ctx) => {\n 625→    const helpText = generateHelp();\n 626→    await ctx.reply(helpText);\n 627→  });\n 628→\n 629→  bot.command('reset', async (ctx) => {\n 630→    try {\n 631→      ensureAllowed(ctx);\n 632→      const sessionId = buildSessionId(ctx);\n 633→\n 634→      // F-011: Interrupt any running AI CLI task\n 635→      if (isAiCliRunning(sessionId)) {\n 636→        interruptAiCli(sessionId);\n 637→      }\n 638→\n 639→      resetSession({ channel: 'telegram', sessionId });\n 640→      await ctx.reply('已清空当前会话上下文。');\n 641→    } catch (error) {\n 642→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 643→    }\n 644→  });\n 645→\n 646→  bot.command('screenshot', async (ctx) => {\n 647→    try {\n 648→      ensureAllowed(ctx);\n 649→      await ctx.reply('正在获取截图。');\n 650→      const { buffer } = await captureScreenshot();\n 651→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 652→    } catch (error) {\n 653→      const message = error instanceof Error ? error.message : String(error);\n 654→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 655→      await ctx.reply(`截图失败：${message}`);\n 656→    }\n 657→  });\n 658→\n 659→  bot.command('exec', async (ctx) => {\n 660→    try {\n 661→      ensureAllowed(ctx);\n 662→      const payload = ctx.message.text.replace('/exec', '').trim();\n 663→      if (!payload) {\n 664→        await ctx.reply('请提供命令，例如 /exec pwd');\n 665→        return;\n 666→      }\n 667→\n 668→      const sessionId = buildSessionId(ctx);\n 669→      const userId = ctx.from?.id;\n 670→\n 671→      await ctx.reply('正在执行命令...');\n 672→      const result = await executeCommand({\n 673→        command: payload,\n 674→        sessionId,\n 675→        userId\n 676→      });\n 677→\n 678→      // Handle confirmation required\n 679→      if (result.needsConfirmation) {\n 680→        await ctx.reply(result.confirmationMessage);\n 681→        return;\n 682→      }\n 683→\n 684→      // Send output\n 685→      await replyLargeText(ctx, result.output);\n 686→\n 687→      // Indicate if more pages available\n 688→      if (result.hasMorePages) {\n 689→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 690→      }\n 691→    } catch (error) {\n 692→      const message = error instanceof Error ? error.message : String(error);\n 693→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 694→      await ctx.reply(`执行失败：${message}`);\n 695→    }\n 696→  });\n 697→\n 698→  // F-009: /cd command handler\n 699→  bot.command('cd', async (ctx) => {\n 700→    try {\n 701→      ensureAllowed(ctx);\n 702→      const payload = ctx.message.text.replace('/cd', '').trim();\n 703→      const sessionId = buildSessionId(ctx);\n 704→\n 705→      await handleCd({\n 706→        ctx,\n 707→        reply: (msg) => ctx.reply(msg),\n 708→        params: {},\n 709→        userId: ctx.from?.id,\n 710→        sessionId,\n 711→        args: payload ? [payload] : []\n 712→      });\n 713→    } catch (error) {\n 714→      const message = error instanceof Error ? error.message : String(error);\n 715→      logger.error({ err: message }, 'Failed to cd in telegram');\n 716→      await ctx.reply(`切换目录失败：${message}`);\n 717→    }\n 718→  });\n 719→\n 720→  // F-009: /more command handler\n 721→  bot.command('more', async (ctx) => {\n 722→    try {\n 723→      ensureAllowed(ctx);\n 724→      const sessionId = buildSessionId(ctx);\n 725→\n 726→      await handleMore({\n 727→        ctx,\n 728→        reply: (msg) => ctx.reply(msg),\n 729→        params: {},\n 730→        userId: ctx.from?.id,\n 731→        sessionId\n 732→      });\n 733→    } catch (error) {\n 734→      const message = error instanceof Error ? error.message : String(error);\n 735→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 736→      await ctx.reply(`获取更多输出失败：${message}`);\n 737→    }\n 738→  });\n 739→\n 740→  // T-100: Document upload handler for plan files\n 741→  bot.on('document', async (ctx) => {\n 742→    try {\n 743→      ensureAllowed(ctx);\n 744→\n 745→      const document = ctx.message?.document;\n 746→      if (!document) {\n 747→        return;\n 748→      }\n 749→\n 750→      // Check file extension\n 751→      const fileName = document.file_name || '';\n 752→      const ext = path.extname(fileName).toLowerCase();\n 753→\n 754→      if (ext !== '.json') {\n 755→        // Not a JSON file, ignore silently (other handlers may process it)\n 756→        return;\n 757→      }\n 758→\n 759→      // Check file size\n 760→      const fileSize = document.file_size || 0;\n 761→      if (fileSize > 1024 * 1024) { // 1MB limit\n 762→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 763→        return;\n 764→      }\n 765→\n 766→      await ctx.reply('正在处理上传的计划文件...');\n 767→\n 768→      // Download file content\n 769→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 770→      const fileUrl = fileLink.href || fileLink.toString();\n 771→\n 772→      const response = await fetch(fileUrl);\n 773→      if (!response.ok) {\n 774→        throw new Error(`下载文件失败: ${response.status}`);\n 775→      }\n 776→\n 777→      const content = await response.text();\n 778→\n 779→      // Validate and save using plan-ingestion-service\n 780→      const infraConfig = loadPipelineInfraConfig();\n 781→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 782→\n 783→      const validationResult = planService.validate(content);\n 784→\n 785→      if (!validationResult.valid) {\n 786→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 787→        await ctx.reply(errorMsg);\n 788→        return;\n 789→      }\n 790→\n 791→      // Save the plan\n 792→      const saveResult = await planService.save(\n 793→        validationResult.type,\n 794→        content,\n 795→        { uploadedBy: ctx.from?.id }\n 796→      );\n 797→\n 798→      if (!saveResult.success) {\n 799→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 800→        return;\n 801→      }\n 802→\n 803→      // Set as current version\n 804→      await planService.setCurrent(validationResult.type, saveResult.version);\n 805→\n 806→      // Format success message\n 807→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 808→      const summary = validationResult.summary;\n 809→\n 810→      await ctx.reply([\n 811→        `✅ ${typeDisplay}已保存并激活`,\n 812→        `版本: ${saveResult.version}`,\n 813→        `名称: ${summary?.name || '未知'}`,\n 814→        `项目数: ${summary?.itemCount || 0}`,\n 815→        '',\n 816→        summary?.statusBreakdown ? '状态分布:' : '',\n 817→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 818→      ].filter(Boolean).join('\\n'));\n 819→\n 820→    } catch (error) {\n 821→      const message = error instanceof Error ? error.message : String(error);\n 822→      logger.error({ err: message }, 'Failed to process document upload');\n 823→      await ctx.reply(`❌ 处理失败：${message}`);\n 824→    }\n 825→  });\n 826→\n 827→  bot.on('text', async (ctx) => {\n 828→    // Check for pipeline commands first\n 829→    const handled = await routeCommand(ctx);\n 830→    if (handled) {\n 831→      return;\n 832→    }\n 833→\n 834→    const sessionId = buildSessionId(ctx);\n 835→    const userId = ctx.from?.id;\n 836→\n 837→    // F-009: Direct exec mode - treat plain text as command when enabled\n 838→    if (config.directExecMode && config.enableSystemExec) {\n 839→      try {\n 840→        ensureAllowed(ctx);\n 841→        const command = ctx.message.text;\n 842→\n 843→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 844→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 845→\n 846→        if (!isLikelyChat) {\n 847→          await ctx.reply('正在执行命令...');\n 848→          const result = await executeCommand({\n 849→            command,\n 850→            sessionId,\n 851→            userId\n 852→          });\n 853→\n 854→          if (result.needsConfirmation) {\n 855→            await ctx.reply(result.confirmationMessage);\n 856→            return;\n 857→          }\n 858→\n 859→          await replyLargeText(ctx, result.output);\n 860→\n 861→          if (result.hasMorePages) {\n 862→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 863→          }\n 864→          return;\n 865→        }\n 866→      } catch (error) {\n 867→        const message = error instanceof Error ? error.message : String(error);\n 868→        // If exec fails, fall through to chat mode\n 869→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n 870→      }\n 871→    }\n 872→\n 873→    // F-011: Check if AI CLI is already running\n 874→    if (isAiCliRunning(sessionId)) {\n 875→      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n 876→      return;\n 877→    }\n 878→\n 879→    let typingTimer = null;\n 880→\n 881→    try {\n 882→      ensureAllowed(ctx);\n 883→      await ctx.sendChatAction('typing');\n 884→\n 885→      const streamPublisher = createEditableStreamPublisher(ctx);\n 886→      typingTimer = setInterval(() => {\n 887→        ctx.sendChatAction('typing').catch(() => undefined);\n 888→      }, TYPING_INTERVAL_MS);\n 889→\n 890→      // F-011: Use ai-cli-service for execution with process tracking\n 891→      const sessionKey = `telegram:${sessionId}`;\n 892→\n 893→      // Append user message to session history\n 894→      sessionStore.append(sessionKey, 'user', ctx.message.text);\n 895→\n 896→      // Build prompt with context\n 897→      const prompt = sessionStore.toPrompt(sessionKey, 'telegram');\n 898→\n 899→      // Track last heartbeat message for updates\n 900→      /** @type {{ message_id: number } | null} */\n 901→      let lastHeartbeatMsg = null;\n 902→\n 903→      const result = await executeAiCli({\n 904→        sessionId,\n 905→        prompt,\n 906→        hooks: {\n 907→          onChunk: (text) => {\n 908→            streamPublisher.push(text);\n 909→          },\n 910→          onHeartbeat: config.aiCliEnableHeartbeat ? (info) => {\n 911→            // Send/update heartbeat progress message\n 912→            const elapsedSec = Math.floor(info.elapsedMs / 1000);\n 913→            const progressText = `⏳ 任务执行中... (${elapsedSec}s, ${Math.floor(info.stdoutBytes / 1024)}KB)`;\n 914→\n 915→            // Don't await - fire and forget\n 916→            if (lastHeartbeatMsg) {\n 917→              ctx.telegram.editMessageText(ctx.chat.id, lastHeartbeatMsg.message_id, undefined, progressText)\n 918→                .catch(() => {});\n 919→            } else {\n 920→              ctx.reply(progressText)\n 921→                .then((msg) => { lastHeartbeatMsg = msg; })\n 922→                .catch(() => {});\n 923→            }\n 924→          } : undefined,\n 925→          onStatus: (status) => {\n 926→            if (status === 'running') {\n 927→              ctx.sendChatAction('typing').catch(() => undefined);\n 928→            }\n 929→          }\n 930→        }\n 931→      });\n 932→\n 933→      // Delete heartbeat message if exists\n 934→      if (lastHeartbeatMsg) {\n 935→        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n 936→      }\n 937→\n 938→      // Append assistant reply to session history\n 939→      sessionStore.append(sessionKey, 'assistant', result.output);\n 940→\n 941→      // F-011: Format output with MarkdownV2\n 942→      const formattedOutput = convertToMarkdownV2(result.output);\n 943→\n 944→      // Handle result states\n 945→      if (result.interrupted) {\n 946→        await ctx.reply('⏹️ 任务已被中断。');\n 947→      } else if (result.timedOut) {\n 948→        await ctx.reply(`⏰ 任务执行超时。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n 949→      }\n 950→\n 951→      // Extract file markers and send\n 952→      const { fileRefs, cleanedText } = extractFileMarkers(result.output);\n 953→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 954→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 955→\n 956→      streamPublisher.setFinalText(finalText);\n 957→      const streamed = await streamPublisher.finish();\n 958→      if (streamed.outputLength === 0) {\n 959→        await replyLargeText(ctx, finalText);\n 960→      }\n 961→\n 962→      if (fileRefs.length > 0) {\n 963→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 964→        const failed = fileSendResults.filter((item) => !item.sent);\n 965→\n 966→        if (failed.length === 0) {\n 967→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 968→        } else {\n 969→          const failedList = failed\n 970→            .map((item) => {\n 971→              const reason =\n 972→                item.reason === 'relative_path_not_allowed'\n 973→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 974→                  : item.reason === 'not_found'\n 975→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 976→                    : item.reason;\n 977→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 978→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 979→            })\n 980→            .join('\\n');\n 981→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 982→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 983→        }\n 984→      }\n 985→    } catch (error) {\n 986→      const message = error instanceof Error ? error.message : String(error);\n 987→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 988→      await safeReply(ctx, `处理失败：${message}`);\n 989→    } finally {\n 990→      if (typingTimer) {\n 991→        clearInterval(typingTimer);\n 992→      }\n 993→    }\n 994→  });\n 995→\n 996→  return bot;\n 997→}\n 998→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_856b2e0610214177b9bb07b6","__time