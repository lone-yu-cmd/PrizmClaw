ndleCron\n  37→- [ ] Implement /cron add <cron-expr> <command> parsing\n  38→- [ ] Implement /cron add --once <datetime> <command> parsing\n  39→- [ ] Add validation for cron expressions and datetime formats\n  40→- [ ] Create src/bot/commands/handlers/jobs.js with jobsMeta and handleJobs\n  41→- [ ] Implement /jobs list subcommand\n  42→- [ ] Implement /jobs pause <id> subcommand\n  43→- [ ] Implement /jobs resume <id> subcommand\n  44→- [ ] Implement /jobs delete <id> subcommand\n  45→- [ ] Create src/bot/commands/handlers/watch.js with watchMeta and handleWatch\n  46→- [ ] Implement /watch <path> command\n  47→- [ ] Implement /unwatch <path> command\n  48→\n  49→## Phase 5: Bot Integration\n  50→\n  51→- [ ] Import new services in src/bot/telegram.js\n  52→- [ ] Import new command handlers in src/bot/telegram.js\n  53→- [ ] Initialize scheduledTaskService in createTelegramBot()\n  54→- [ ] Initialize fileWatcherService in createTelegramBot()\n  55→- [ ] Set up notification callbacks with bot.telegram reference\n  56→- [ ] Restore tasks and watchers from disk on startup\n  57→- [ ] Register /cron, /jobs, /watch commands\n  58→- [ ] Add services to src/services/index.js exports\n  59→\n  60→## Phase 6: Unit Tests\n  61→\n  62→- [ ] Create tests/config/f014-config.test.js for config validation\n  63→- [ ] Create tests/services/scheduled-task-service.test.js\n  64→- [ ] Test cron task creation and scheduling\n  65→- [ ] Test one-time task creation\n  66→- [ ] Test task CRUD operations\n  67→- [ ] Test persistence save/load\n  68→- [ ] Create tests/services/file-watcher-service.test.js\n  69→- [ ] Test watcher CRUD operations\n  70→- [ ] Test path validation\n  71→- [ ] Test persistence save/load\n  72→- [ ] Create tests/bot/commands/handlers/cron.test.js\n  73→- [ ] Create tests/bot/commands/handlers/jobs.test.js\n  74→- [ ] Create tests/bot/commands/handlers/watch.test.js\n  75→\n  76→## Phase 7: Integration Tests\n  77→\n  78→- [ ] Create tests/integration/f014-scheduled-tasks.test.js\n  79→- [ ] Test end-to-end task lifecycle\n  80→- [ ] Test bot notification on task execution\n  81→- [ ] Create tests/integration/f014-file-watchers.test.js\n  82→- [ ] Test file change detection and notification\n  83→- [ ] Test persistence across simulated restart\n  84→\n  85→## Phase 8: Prizm Docs Update\n  86→\n  87→- [ ] Update .prizm-docs/runtime.prizm with F-014 interfaces\n  88→- [ ] Update .prizm-docs/runtime/services.prizm with new services\n  89→- [ ] Update .prizm-docs/runtime/bot.prizm with new commands\n  90→\n  91→## Dependencies\n  92→\n  93→- [x] Install croner package: npm install croner\n  94→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_8164acc216aa40eaa825218d","__timestamp":"2026-03-12T21:37:40.162Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
