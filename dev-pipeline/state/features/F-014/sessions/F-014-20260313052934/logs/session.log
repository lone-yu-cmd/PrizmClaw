w Set(\n  61→    input\n  62→      .split(',')\n  63→      .map((id) => id.trim())\n  64→      .filter(Boolean)\n  65→  );\n  66→}\n  67→\n  68→function parseCsvList(input) {\n  69→  return input\n  70→    .split(',')\n  71→    .map((item) => item.trim())\n  72→    .filter(Boolean);\n  73→}\n  74→\n  75→function parseBoolean(input) {\n  76→  const normalized = (input ?? '').trim().toLowerCase();\n  77→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  78→}\n  79→\n  80→/**\n  81→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  82→ * Format: \"123456789:admin,987654321:operator\"\n  83→ * @param {string} input\n  84→ * @returns {Map<string, string>}\n  85→ */\n  86→function parseUserPermissions(input) {\n  87→  const permissions = new Map();\n  88→  if (!input || !input.trim()) {\n  89→    return permissions;\n  90→  }\n  91→\n  92→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  93→  for (const entry of entries) {\n  94→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  95→    if (userId && role) {\n  96→      const normalizedRole = role.toLowerCase();\n  97→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  98→        permissions.set(userId, normalizedRole);\n  99→      }\n 100→    }\n 101→  }\n 102→  return permissions;\n 103→}\n 104→\n 105→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n 106→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n 107→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 108→}\n 109→\n 110→const pipelineInfra = loadPipelineInfraConfig({\n 111→  env: process.env,\n 112→  argv: process.argv.slice(2),\n 113→  cwd: process.cwd()\n 114→});\n 115→\n 116→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 117→\n 118→export const config = Object.freeze({\n 119→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 120→  enableTelegram,\n 121→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 122→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 123→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 124→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 125→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 126→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 127→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 128→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 129→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 130→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 131→  webHost: parsed.WEB_HOST,\n 132→  webPort: parsed.WEB_PORT,\n 133→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 134→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 135→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 136→  logLevel: parsed.LOG_LEVEL,\n 137→  // F-006: Safety and Permission Guard\n 138→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 139→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 140→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 141→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 142→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 143→  // F-009: General Command Executor\n 144→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 145→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 146→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 147→  // F-010: File Manager\n 148→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 149→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 150→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 151→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 152→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 153→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 154→  // F-011: AI CLI Proxy\n 155→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 156→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 157→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 158→  // F-012: System Monitor\n 159→  systemMonitorIntervalMs: parsed.SYSTEM_MONITOR_INTERVAL_MS,\n 160→  systemMonitorDataDir: parsed.SYSTEM_MONITOR_DATA_DIR,\n 161→  // F-013: Session and Context Manager\n 162→  sessionTimeoutMs: parsed.SESSION_TIMEOUT_MS,\n 163→  sessionHistoryMax: parsed.SESSION_HISTORY_MAX,\n 164→  sessionPersistenceDir: parsed.SESSION_PERSISTENCE_DIR,\n 165→  aliasPersistencePath: parsed.ALIAS_PERSISTENCE_PATH,\n 166→  pipelineInfra: Object.freeze({\n 167→    ...pipelineInfra,\n 168→    daemonLogPaths\n 169→  })\n 170→});\n 171→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_32ef8cc4efe8472d9fa4f436","__timestamp":"2026-03-12T21:29:53.645Z","_requestId":"197c31d70a614d2a931d269ab7ee2117"}
{"type":"user","uuid":"02fc6455-bed2-4898-8fca-df6028c918fd","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"call_7afcb2cc5abe45e5b40c1854","content":[{"type":"text","text":"   1→/**\n   2→ * Command Executor Service\n   3→ * F-009: General Command Executor\n   4→ *\n   5→ * Main service for executing shell commands with:\n   6→ * - Blacklist checking\n   7→ * - High-risk keyword detection\n   8→ * - Confirmation flow for dangerous commands\n   9→ * - Session working directory support\n  10→ * - Output pagination\n  11→ * - Audit logging\n  12→ */\n  13→\n  14→import { config } from '../config.js';\n  15→import { sessionStore } from './session-store.js';\n  16→import { executeSystemCommand } from './system-exec-service.js';\n  17→import { checkCommandBlacklist, detectHighRiskKeywords } from '../security/system-guard.js';\n  18→import { createConfirmation, confirmAction } from '../security/confirmation-manager.js';\n  19→import { logAuditEntry } from './audit-log-service.js';\n  20→import { paginateOutput, storeOutputPages, hasMorePages } from './output-pager-service.js';\n  21→import { getUserRole } from '../security/permission-guard.js';\n  22→\n  23→/**\n  24→ * Execute a command with full security checks and pagination.\n  25→ * @param {Object} options - Execution options\n  26→ * @param {string} options.command - Command to execute\n  27→ * @param {string} options.sessionId - Session identifier\n  28→ * @param {string|number} options.userId - User ID for audit and permissions\n  29→ * @param {boolean} [options.skipConfirmation=false] - Skip confirmation (for confirmed commands)\n  30→ * @param {string} [options.confirmationId] - Confirmation ID if this is a confirmed execution\n  31→ * @returns {Promise<Object>} Execution result\n  32→ */\n  33→export async function executeCommand(options) {\n  34→  const { command, sessionId, userId, skipConfirmation = false, confirmationId } = options;\n  35→\n  36→  // Check blacklist first\n  37→  const blacklistResult = checkCommandBlacklist(command, config.commandBlacklist);\n  38→  if (blacklistResult.blocked) {\n  39→    await logAuditEntry({\n  40→      userId,\n  41→      role: getUserRole(userId),\n  42→      action: 'exec',\n  43→      params: { command },\n  44→      result: 'denied',\n  45→      reason: `Blacklisted command: ${blacklistResult.matchedCommand}`,\n  46→      sessionId\n  47→    });\n  48→\n  49→    throw new Error(`命令被拒绝：${blacklistResult.reason}`);\n  50→  }\n  51→\n  52→  // Detect high-risk keywords\n  53→  const riskResult = detectHighRiskKeywords(command, config.highRiskKeywords);\n  54→\n  55→  // If high-risk and not confirmed, require confirmation\n  56→  if (riskResult.isHighRisk && !skipConfirmation && !confirmationId) {\n  57→    const params = { command, sessionId };\n  58→    const { confirmId, message } = createConfirmation(userId, 'exec', params);\n  59→\n  60→    await logAuditEntry({\n  61→      userId,\n  62→      role: getUserRole(userId),\n  63→      action: 'exec',\n  64→      params: { command },\n  65→      result: 'pending_confirmation',\n  66→      reason: `High-risk keywords: ${riskResult.detectedKeywords.join(', ')}`,\n  67→      sessionId\n  68→    });\n  69→\n  70→    return {\n  71→      needsConfirmation: true,\n  72→      confirmationId: confirmId,\n  73→      confirmationMessage: message,\n  74→      detectedKeywords: riskResult.detectedKeywords\n  75→    };\n  76→  }\n  77→\n  78→  // If confirmation ID provided, verify it\n  79→  if (confirmationId) {\n  80→    const confirmResult = confirmAction(confirmationId, userId);\n  81→    if (!confirmResult.ok) {\n  82→      throw new Error(`确认失败：${confirmResult.error}`);\n  83→    }\n  84→  }\n  85→\n  86→  // Get session cwd\n  87→  const cwd = sessionStore.getCwd(sessionId) || process.cwd();\n  88→\n  89→  // Execute the command\n  90→  let result;\n  91→  try {\n  92→    result = await executeSystemCommand(command, { cwd });\n  93→  } catch (error) {\n  94→    await logAuditEntry({\n  95→      userId,\n  96→      role: getUserRole(userId),\n  97→      action: 'exec',\n  98→      params: { command, cwd },\n  99→      result: 'failed',\n 100→      reason: error.message,\n 101→      sessionId\n 102→    });\n 103→    throw error;\n 104→  }\n 105→\n 106→  // Format output\n 107→  const output = formatOutput(result);\n 108→\n 109→  // Paginate if needed\n 110→  const pages = paginateOutput(output);\n 111→  const displayOutput = pages[0];\n 112→\n 113→  // Store remaining pages for /more\n 114→  if (pages.length > 1) {\n 115→    storeOutputPages(sessionId, pages.slice(1));\n 116→  }\n 117→\n 118→  // Log successful execution\n 119→  await logAuditEntry({\n 120→    userId,\n 121→    role: getUserRole(userId),\n 122→    action: 'exec',\n 123→    params: { command, cwd },\n 124→    result: 'success',\n 125→    sessionId\n 126→  });\n 127→\n 128→  // F-013: Record command in history\n 129→  sessionStore.recordCommand(sessionId, command, result.exitCode);\n 130→\n 131→  return {\n 132→    stdout: result.stdout,\n 133→    stderr: result.stderr,\n 134→    exitCode: result.exitCode,\n 135→    timedOut: result.timedOut,\n 136→    output: displayOutput,\n 137→    hasMorePages: hasMorePages(sessionId),\n 138→    needsConfirmation: false\n 139→  };\n 140→}\n 141→\n 142→/**\n 143→ * Confirm and execute a high-risk command.\n 144→ * @param {string} confirmationId - Confirmation ID from previous executeCommand call\n 145→ * @param {string|number} userId - User ID\n 146→ * @param {string} sessionId - Session identifier\n 147→ * @returns {Promise<Object>} Execution result\n 148→ */\n 149→export async function confirmHighRiskCommand(confirmationId, userId, sessionId) {\n 150→  const confirmResult = confirmAction(confirmationId, userId);\n 151→\n 152→  if (!confirmResult.ok) {\n 153→    throw new Error(`确认失败：${confirmResult.error}`);\n 154→  }\n 155→\n 156→  const { params } = confirmResult;\n 157→  return executeCommand({\n 158→    command: params.command,\n 159→    sessionId: params.sessionId || sessionId,\n 160→    userId,\n 161→    skipConfirmation: true\n 162→  });\n 163→}\n 164→\n 165→/**\n 166→ * Format command output for display.\n 167→ * @param {Object} result - Execution result\n 168→ * @returns {string} Formatted output\n 169→ */\n 170→function formatOutput(result) {\n 171→  const parts = [];\n 172→\n 173→  if (result.timedOut) {\n 174→    parts.push(`⚠️ 命令执行超时，已终止进程。`);\n 175→  }\n 176→\n 177→  parts.push(`exitCode: ${result.exitCode}`);\n 178→\n 179→  if (result.stdout) {\n 180→    parts.push(`stdout:\\n${result.stdout}`);\n 181→  } else {\n 182→    parts.push(`stdout: (empty)`);\n 183→  }\n 184→\n 185→  if (result.stderr) {\n 186→    parts.push(`stderr:\\n${result.stderr}`);\n 187→  } else {\n 188→    parts.push(`stderr: (empty)`);\n 189→  }\n 190→\n 191→  return parts.join('\\n\\n');\n 192→}\n 193→\n 194→export default {\n 195→  executeCommand,\n 196→  confirmHighRiskCommand\n 197→};\n 198→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_7afcb2cc5abe45e5b40c1854","__timestamp":"2026-03-12T21:29:53.646Z","_requestId":"197c31d70a614d2a931d269ab7ee2117"}
{"type":"user","uuid":"3711ec2e-3b63-4d88-8f6b-4398479bf842","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"call_2c631cf487d84c45a47c48ed","content":[{"type":"text","text":"   1→/**\n   2→ * Session Context Service\n   3→ * F-013: Session and Context Manager\n   4→ *\n   5→ * Manages session lifecycle, persistence, and timeout handling.\n   6→ * Coordinates with sessionStore for in-memory session state.\n   7→ */\n   8→\n   9→import { mkdir, readFile, writeFile, unlink, readdir } from 'node:fs/promises';\n  10→import { join } from 'node:path';\n  11→import { config } from '../config.js';\n  12→import { sessionStore } from './session-store.js';\n  13→\n  14→/**\n  15→ * @typedef {Object} SessionContextService\n  16→ * @property {Function} initSessionContext - Initialize with data directory\n  17→ * @property {Function} createSession - Create new session\n  18→ * @property {Function} getOrCreateSession - Get existing or create new\n  19→ * @property {Function} touchSession - Update activity timestamp\n  20→ * @property {Function} cleanupSession - Clear session data\n  21→ * @property {Function} persistSession - Save to disk\n  22→ * @property {Function} restoreSessions - Load from disk on startup\n  23→ * @property {Function} startTimeoutWatcher - Start interval to check timeouts\n  24→ * @property {Function} stopTimeoutWatcher - Stop interval on shutdown\n  25→ * @property {Function} setNotificationCallback - Set callback for timeout notifications\n  26→ * @property {Function} isWatcherRunning - Check if watcher is active\n  27→ */\n  28→\n  29→class SessionContextServiceClass {\n  30→  #dataDir = null;\n  31→  #notificationCallback = null;\n  32→  #timeoutWatcherId = null;\n  33→  #isInitialized = false;\n  34→  #timeoutMs = null;\n  35→  #checkIntervalMs = null;\n  36→\n  37→  /**\n  38→   * Reset the service state (for testing).\n  39→   */\n  40→  reset() {\n  41→    this.#dataDir = null;\n  42→    this.#notificationCallback = null;\n  43→    if (this.#timeoutWatcherId) {\n  44→      clearInterval(this.#timeoutWatcherId);\n  45→      this.#timeoutWatcherId = null;\n  46→    }\n  47→    this.#isInitialized = false;\n  48→    this.#timeoutMs = null;\n  49→    this.#checkIntervalMs = null;\n  50→  }\n  51→\n  52→  /**\n  53→   * Check if service is initialized.\n  54→   * @returns {boolean}\n  55→   */\n  56→  isInitialized() {\n  57→    return this.#isInitialized;\n  58→  }\n  59→\n  60→  /**\n  61→   * Initialize the session context service.\n  62→   * @param {Object} options - Initialization options\n  63→   * @param {string} options.dataDir - Directory for session persistence\n  64→   * @param {number} [options.timeoutMs] - Session timeout in ms (default: from config)\n  65→   * @param {number} [options.checkIntervalMs] - Timeout check interval in ms (default: 60000)\n  66→   */\n  67→  initSessionContext({ dataDir, timeoutMs, checkIntervalMs }) {\n  68→    this.#dataDir = dataDir;\n  69→    this.#timeoutMs = timeoutMs || config.sessionTimeoutMs;\n  70→    this.#checkIntervalMs = checkIntervalMs || 60000;\n  71→    this.#isInitialized = true;\n  72→  }\n  73→\n  74→  /**\n  75→   * Check if service is initialized.\n  76→   * @throws {Error} If not initialized\n  77→   */\n  78→  #checkInitialized() {\n  79→    if (!this.#isInitialized) {\n  80→      throw new Error('SessionContextService not initialized. Call initSessionContext first.');\n  81→    }\n  82→  }\n  83→\n  84→  /**\n  85→   * Ensure data directory exists.\n  86→   */\n  87→  async #ensureDataDir() {\n  88→    if (this.#dataDir) {\n  89→      await mkdir(this.#dataDir, { recursive: true });\n  90→    }\n  91→  }\n  92→\n  93→  /**\n  94→   * Create a new session.\n  95→   * @param {string} sessionKey - Session identifier\n  96→   * @param {string} userId - Telegram user ID\n  97→   * @returns {Object} Created session info\n  98→   */\n  99→  createSession(sessionKey, userId) {\n 100→    this.#checkInitialized();\n 101→\n 102→    // Create in sessionStore - touchSession will set createdAt if new\n 103→    sessionStore.touchSession(sessionKey, userId);\n 104→    sessionStore.setUserId(sessionKey, userId);\n 105→\n 106→    return sessionStore.getSessionInfo(sessionKey);\n 107→  }\n 108→\n 109→  /**\n 110→   * Get existing session or create new one.\n 111→   * @param {string} sessionKey - Session identifier\n 112→   * @param {string} userId - Telegram user ID\n 113→   * @returns {Object} Session info\n 114→   */\n 115→  getOrCreateSession(sessionKey, userId) {\n 116→    this.#checkInitialized();\n 117→\n 118→    const existing = sessionStore.getSessionInfo(sessionKey);\n 119→    if (existing) {\n 120→      // Update userId if different\n 121→      if (existing.userId !== userId) {\n 122→        sessionStore.setUserId(sessionKey, userId);\n 123→      }\n 124→      // Return fresh info from sessionStore\n 125→      return sessionStore.getSessionInfo(sessionKey);\n 126→    }\n 127→\n 128→    return this.createSession(sessionKey, userId);\n 129→  }\n 130→\n 131→  /**\n 132→   * Update session activity timestamp.\n 133→   * @param {string} sessionKey - Session identifier\n 134→   */\n 135→  touchSession(sessionKey) {\n 136→    this.#checkInitialized();\n 137→\n 138→    // sessionStore.touchSession will set createdAt if new\n 139→    const userId = sessionStore.getUserId(sessionKey) || undefined;\n 140→    sessionStore.touchSession(sessionKey, userId);\n 141→  }\n 142→\n 143→  /**\n 144→   * Cleanup a session - clear from memory and delete persisted file.\n 145→   * @param {string} sessionKey - Session identifier\n 146→   */\n 147→  cleanupSession(sessionKey) {\n 148→    this.#checkInitialized();\n 149→\n 150→    // Get userId before clearing for notification\n 151→    const userId = sessionStore.getUserId(sessionKey);\n 152→\n 153→    // Clear from sessionStore\n 154→    sessionStore.clear(sessionKey);\n 155→\n 156→    // Delete persisted file (async, fire-and-forget)\n 157→    this.#deleteSessionFile(sessionKey);\n 158→\n 159→    // Notify if callback set\n 160→    if (this.#notificationCallback && userId) {\n 161→      this.#notificationCallback(sessionKey, userId);\n 162→    }\n 163→  }\n 164→\n 165→  /**\n 166→   * Delete session file from disk.\n 167→   * @param {string} sessionKey - Session identifier\n 168→   */\n 169→  async #deleteSessionFile(sessionKey) {\n 170→    const filePath = this.#getSessionFilePath(sessionKey);\n 171→    try {\n 172→      await unlink(filePath);\n 173→    } catch {\n 174→      // Ignore if file doesn't exist\n 175→    }\n 176→  }\n 177→\n 178→  /**\n 179→   * Set notification callback for session cleanup.\n 180→   * @param {Function} callback - Function(sessionKey, userId)\n 181→   */\n 182→  setNotificationCallback(callback) {\n 183→    this.#notificationCallback = callback;\n 184→  }\n 185→\n 186→  /**\n 187→   * Get file path for a session file.\n 188→   * @param {string} sessionKey - Session identifier\n 189→   * @returns {string} File path\n 190→   */\n 191→  #getSessionFilePath(sessionKey) {\n 192→    // Replace colons with underscores for filesystem compatibility\n 193→    const safeFileName = sessionKey.replace(/:/g, '_');\n 194→    return join(this.#dataDir, `${safeFileName}.json`);\n 195→  }\n 196→\n 197→  /**\n 198→   * Persist a session to disk.\n 199→   * @param {string} sessionKey - Session identifier\n 200→   */\n 201→  async persistSession(sessionKey) {\n 202→    this.#checkInitialized();\n 203→    await this.#ensureDataDir();\n 204→\n 205→    const info = sessionStore.getSessionInfo(sessionKey);\n 206→    if (!info) {\n 207→      throw new Error(`Session ${sessionKey} not found`);\n 208→    }\n 209→\n 210→    const data = {\n 211→      sessionKey: info.sessionKey,\n 212→      userId: info.userId,\n 213→      cwd: sessionStore.getCwd(sessionKey),\n 214→      envOverrides: sessionStore.getEnvOverrides(sessionKey),\n 215→      commandHistory: sessionStore.getCommandHistory(sessionKey),\n 216→      createdAt: info.createdAt,\n 217→      lastActivityAt: info.lastActivityAt\n 218→    };\n 219→\n 220→    const filePath = this.#getSessionFilePath(sessionKey);\n 221→    await writeFile(filePath, JSON.stringify(data, null, 2));\n 222→  }\n 223→\n 224→  /**\n 225→   * Restore sessions from disk.\n 226→   */\n 227→  async restoreSessions() {\n 228→    this.#checkInitialized();\n 229→\n 230→    try {\n 231→      const files = await readdir(this.#dataDir);\n 232→      const sessionFiles = files.filter((f) => f.endsWith('.json'));\n 233→\n 234→      for (const file of sessionFiles) {\n 235→        try {\n 236→          const filePath = join(this.#dataDir, file);\n 237→          const content = await readFile(filePath, 'utf-8');\n 238→          const data = JSON.parse(content);\n 239→\n 240→          // Check if session has expired\n 241→          const idleTime = Date.now() - (data.lastActivityAt || 0);\n 242→          const timeoutMs = this.#timeoutMs;\n 243→\n 244→          if (idleTime > timeoutMs) {\n 245→            // Session expired, delete file\n 246→            await unlink(filePath);\n 247→            continue;\n 248→          }\n 249→\n 250→          // Restore to sessionStore\n 251→          const { sessionKey, userId, cwd, envOverrides } = data;\n 252→\n 253→          // Set userId and timestamps\n 254→          sessionStore.touchSession(sessionKey, userId);\n 255→\n 256→          // Restore cwd\n 257→          if (cwd) {\n 258→            sessionStore.setCwd(sessionKey, cwd);\n 259→          }\n 260→\n 261→          // Restore env overrides\n 262→          for (const [key, value] of Object.entries(envOverrides || {})) {\n 263→            sessionStore.setEnvOverride(sessionKey, key, value);\n 264→          }\n 265→\n 266→          // Note: commandHistory is stored in the file but we don't restore it\n 267→          // to sessionStore because it's mainly for historical reference.\n 268→\n 269→        } catch (error) {\n 270→          // Log error but continue with other files\n 271→          console.error(`Failed to restore session from ${file}:`, error.message);\n 272→        }\n 273→      }\n 274→    } catch (error) {\n 275→      // Directory might not exist yet\n 276→      if (error.code !== 'ENOENT') {\n 277→        throw error;\n 278→      }\n 279→    }\n 280→  }\n 281→\n 282→  /**\n 283→   * Start the timeout watcher.\n 284→   */\n 285→  startTimeoutWatcher() {\n 286→    if (this.#timeoutWatcherId) {\n 287→      // Already running\n 288→      return;\n 289→    }\n 290→\n 291→    this.#timeoutWatcherId = setInterval(() => {\n 292→      this.#checkTimeouts();\n 293→    }, this.#checkIntervalMs);\n 294→\n 295→    // Prevent the interval from keeping the process alive\n 296→    this.#timeoutWatcherId.unref?.();\n 297→  }\n 298→\n 299→  /**\n 300→   * Check all sessions for timeout.\n 301→   */\n 302→  #checkTimeouts() {\n 303→    const sessionKeys = sessionStore.getAllSessionKeys();\n 304→\n 305→    for (const sessionKey of sessionKeys) {\n 306→      const idleTime = sessionStore.getIdleTime(sessionKey);\n 307→\n 308→      if (idleTime !== null && idleTime > this.#timeoutMs) {\n 309→        // Session expired\n 310→        this.cleanupSession(sessionKey);\n 311→      }\n 312→    }\n 313→  }\n 314→\n 315→  /**\n 316→   * Stop the timeout watcher.\n 317→   */\n 318→  stopTimeoutWatcher() {\n 319→    if (this.#timeoutWatcherId) {\n 320→      clearInterval(this.#timeoutWatcherId);\n 321→      this.#timeoutWatcherId = null;\n 322→    }\n 323→  }\n 324→\n 325→  /**\n 326→   * Check if the timeout watcher is running.\n 327→   * @returns {boolean}\n 328→   */\n 329→  isWatcherRunning() {\n 330→    return this.#timeoutWatcherId !== null;\n 331→  }\n 332→}\n 333→\n 334→export const sessionContextService = new SessionContextServiceClass();\n 335→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_2c631cf487d84c45a47c48ed","__timestamp":"2026-03-12T21:29:53.647Z","_requestId":"197c31d70a614d2a931d269ab7ee2117"}
{"type":"user","uuid":"52fbe253-2419-4623-bc62-d3a146da6cc7","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"call_731dc1b01ddc41d0bd2ad98b","content":[{"type":"text","text":"   1→/**\n   2→ * Alert Manager Service\n   3→ * F-012: System Monitor\n   4→ *\n   5→ * Manages alert rules, threshold monitoring, and notifications.\n   6→ */\n   7→\n   8→import { randomUUID } from 'node:crypto';\n   9→import { mkdir, readFile, writeFile } from 'node:fs/promises';\n  10→import { join } from 'node:path';\n  11→import { config } from '../config.js';\n  12→\n  13→/**\n  14→ * @typedef {Object} AlertRule\n  15→ * @property {string} id - Unique rule identifier\n  16→ * @property {'cpu'|'memory'|'disk'} metric - Metric to monitor\n  17→ * @property {'>'|'<'|'>='|'<='} operator - Comparison operator\n  18→ * @property {number} threshold - Threshold value (0-100)\n  19→ * @property {boolean} enabled - Whether rule is active\n  20→ * @property {number} createdAt - Creation timestamp\n  21→ * @property {number} [lastTriggered] - Last triggered timestamp\n  22→ */\n  23→\n  24→/**\n  25→ * @typedef {Object} AlertStatus\n  26→ * @property {string} ruleId - Rule that triggered\n  27→ * @property {string} metric - Metric name\n  28→ * @property {number} currentValue - Current metric value\n  29→ * @property {number} threshold - Configured threshold\n  30→ * @property {number} triggeredAt - Trigger timestamp\n  31→ */\n  32→\n  33→const VALID_METRICS = ['cpu', 'memory', 'disk'];\n  34→const VALID_OPERATORS = ['>', '<', '>=', '<='];\n  35→const DEFAULT_COOLDOWN_MS = 5 * 60 * 1000; // 5 minutes\n  36→\n  37→export class AlertManagerService {\n  38→  /**\n  39→   * @param {Object} options\n  40→   * @param {string} [options.dataDir] - Directory for persistence\n  41→   * @param {string} [options.rulesFile] - Rules file name\n  42→   * @param {number} [options.cooldownMs] - Cooldown period in ms\n  43→   */\n  44→  constructor(options = {}) {\n  45→    this.dataDir = options.dataDir || config.systemMonitorDataDir;\n  46→    this.rulesFile = options.rulesFile || 'alert-rules.json';\n  47→    this.cooldownMs = options.cooldownMs || DEFAULT_COOLDOWN_MS;\n  48→\n  49→    /** @type {Map<string, AlertRule>} */\n  50→    this.rules = new Map();\n  51→\n  52→    /** @type {Map<string, number>} - Last triggered time by rule ID */\n  53→    this.lastTriggered = new Map();\n  54→\n  55→    /** @type {NodeJS.Timeout|null} */\n  56→    this.monitorInterval = null;\n  57→\n  58→    /** @type {Function|null} */\n  59→    this.pushCallback = null;\n  60→  }\n  61→\n  62→  /**\n  63→   * Add a new alert rule\n  64→   * @param {Omit<AlertRule, 'id' | 'createdAt'>} ruleData\n  65→   * @returns {AlertRule}\n  66→   */\n  67→  addRule(ruleData) {\n  68→    this._validateRule(ruleData);\n  69→\n  70→    const id = randomUUID();\n  71→    const rule = {\n  72→      id,\n  73→      metric: ruleData.metric,\n  74→      operator: ruleData.operator,\n  75→      threshold: ruleData.threshold,\n  76→      enabled: ruleData.enabled ?? true,\n  77→      createdAt: Date.now()\n  78→    };\n  79→\n  80→    this.rules.set(id, rule);\n  81→    return { ...rule };\n  82→  }\n  83→\n  84→  /**\n  85→   * Remove a rule by ID\n  86→   * @param {string} ruleId\n  87→   * @returns {boolean}\n  88→   */\n  89→  removeRule(ruleId) {\n  90→    if (!this.rules.has(ruleId)) {\n  91→      return false;\n  92→    }\n  93→\n  94→    this.rules.delete(ruleId);\n  95→    this.lastTriggered.delete(ruleId);\n  96→    return true;\n  97→  }\n  98→\n  99→  /**\n 100→   * List all rules\n 101→   * @returns {AlertRule[]}\n 102→   */\n 103→  listRules() {\n 104→    return Array.from(this.rules.values()).map(rule => ({ ...rule }));\n 105→  }\n 106→\n 107→  /**\n 108→   * Enable a rule\n 109→   * @param {string} ruleId\n 110→   * @returns {boolean}\n 111→   */\n 112→  enableRule(ruleId) {\n 113→    const rule = this.rules.get(ruleId);\n 114→    if (!rule) {\n 115→      return false;\n 116→    }\n 117→\n 118→    rule.enabled = true;\n 119→    return true;\n 120→  }\n 121→\n 122→  /**\n 123→   * Disable a rule\n 124→   * @param {string} ruleId\n 125→   * @returns {boolean}\n 126→   */\n 127→  disableRule(ruleId) {\n 128→    const rule = this.rules.get(ruleId);\n 129→    if (!rule) {\n 130→      return false;\n 131→    }\n 132→\n 133→    rule.enabled = false;\n 134→    return true;\n 135→  }\n 136→\n 137→  /**\n 138→   * Check thresholds against current metrics\n 139→   * @param {Object} currentMetrics - System metrics\n 140→   * @returns {AlertStatus[]}\n 141→   */\n 142→  checkThresholds(currentMetrics) {\n 143→    const alerts = [];\n 144→    const now = Date.now();\n 145→\n 146→    for (const rule of this.rules.values()) {\n 147→      if (!rule.enabled) {\n 148→        continue;\n 149→      }\n 150→\n 151→      // Check cooldown\n 152→      const lastTrigger = this.lastTriggered.get(rule.id);\n 153→      if (lastTrigger && (now - lastTrigger) < this.cooldownMs) {\n 154→        continue;\n 155→      }\n 156→\n 157→      const currentValue = this._getMetricValue(currentMetrics, rule.metric);\n 158→      if (currentValue === undefined) {\n 159→        continue;\n 160→      }\n 161→\n 162→      if (this._evaluateThreshold(currentValue, rule.operator, rule.threshold)) {\n 163→        this.lastTriggered.set(rule.id, now);\n 164→\n 165→        // Update lastTriggered on rule\n 166→        rule.lastTriggered = now;\n 167→\n 168→        alerts.push({\n 169→          ruleId: rule.id,\n 170→          metric: rule.metric,\n 171→          currentValue,\n 172→          threshold: rule.threshold,\n 173→          triggeredAt: now\n 174→        });\n 175→      }\n 176→    }\n 177→\n 178→    return alerts;\n 179→  }\n 180→\n 181→  /**\n 182→   * Start monitoring loop\n 183→   * @param {Function} pushCallback - Callback for alert notifications\n 184→   * @param {number} [intervalMs] - Check interval (default from config)\n 185→   */\n 186→  startMonitoring(pushCallback, intervalMs) {\n 187→    if (this.monitorInterval) {\n 188→      throw new Error('Monitoring is already running');\n 189→    }\n 190→\n 191→    this.pushCallback = pushCallback;\n 192→    const interval = intervalMs || config.systemMonitorIntervalMs;\n 193→\n 194→    this.monitorInterval = setInterval(async () => {\n 195→      try {\n 196→        // Import here to avoid circular dependency\n 197→        const { systemMonitorService } = await import('./system-monitor-service.js');\n 198→        const metrics = await systemMonitorService.getSystemInfo();\n 199→        const alerts = this.checkThresholds(metrics);\n 200→\n 201→        for (const alert of alerts) {\n 202→          if (this.pushCallback) {\n 203→            this.pushCallback(alert);\n 204→          }\n 205→        }\n 206→      } catch (error) {\n 207→        // Log error but don't stop monitoring\n 208→        console.error('Alert monitoring error:', error);\n 209→      }\n 210→    }, interval);\n 211→  }\n 212→\n 213→  /**\n 214→   * Stop monitoring loop\n 215→   */\n 216→  stopMonitoring() {\n 217→    if (this.monitorInterval) {\n 218→      clearInterval(this.monitorInterval);\n 219→      this.monitorInterval = null;\n 220→    }\n 221→    this.pushCallback = null;\n 222→  }\n 223→\n 224→  /**\n 225→   * Load rules from persistent storage\n 226→   */\n 227→  async loadRules() {\n 228→    try {\n 229→      const filePath = join(this.dataDir, this.rulesFile);\n 230→      const content = await readFile(filePath, 'utf-8');\n 231→      const rules = JSON.parse(content);\n 232→\n 233→      this.rules.clear();\n 234→      for (const rule of rules) {\n 235→        if (rule.id && rule.metric) {\n 236→          this.rules.set(rule.id, rule);\n 237→        }\n 238→      }\n 239→    } catch (error) {\n 240→      // File doesn't exist or is corrupted - start fresh\n 241→      this.rules.clear();\n 242→    }\n 243→  }\n 244→\n 245→  /**\n 246→   * Save rules to persistent storage\n 247→   */\n 248→  async saveRules() {\n 249→    try {\n 250→      // Ensure directory exists\n 251→      await mkdir(this.dataDir, { recursive: true });\n 252→\n 253→      const filePath = join(this.dataDir, this.rulesFile);\n 254→      const rules = Array.from(this.rules.values());\n 255→      await writeFile(filePath, JSON.stringify(rules, null, 2), 'utf-8');\n 256→    } catch (error) {\n 257→      throw new Error(`Failed to save alert rules: ${error.message}`);\n 258→    }\n 259→  }\n 260→\n 261→  /**\n 262→   * Parse rule string like \"cpu>80\"\n 263→   * @param {string} ruleString\n 264→   * @returns {{metric: string, operator: string, threshold: number}}\n 265→   */\n 266→  parseRuleString(ruleString) {\n 267→    // Match patterns like \"cpu>80\", \"memory>=90\", \"disk<10\"\n 268→    const match = ruleString.match(/^(cpu|memory|disk)(>|<|>=|<=)(\\d+)$/i);\n 269→\n 270→    if (!match) {\n 271→      throw new Error(`Invalid rule format: ${ruleString}. Expected format: cpu>80, memory>=90, disk<10`);\n 272→    }\n 273→\n 274→    const metric = match[1].toLowerCase();\n 275→    const operator = match[2];\n 276→    const threshold = parseInt(match[3], 10);\n 277→\n 278→    if (threshold < 0 || threshold > 100) {\n 279→      throw new Error('Threshold must be between 0 and 100');\n 280→    }\n 281→\n 282→    return { metric, operator, threshold };\n 283→  }\n 284→\n 285→  /**\n 286→   * Validate rule data\n 287→   * @private\n 288→   */\n 289→  _validateRule(ruleData) {\n 290→    if (!VALID_METRICS.includes(ruleData.metric)) {\n 291→      throw new Error(`Invalid metric: ${ruleData.metric}. Must be one of: ${VALID_METRICS.join(', ')}`);\n 292→    }\n 293→\n 294→    if (!VALID_OPERATORS.includes(ruleData.operator)) {\n 295→      throw new Error(`Invalid operator: ${ruleData.operator}. Must be one of: ${VALID_OPERATORS.join(', ')}`);\n 296→    }\n 297→\n 298→    const threshold = Number(ruleData.threshold);\n 299→    if (isNaN(threshold) || threshold < 0 || threshold > 100) {\n 300→      throw new Error('Threshold must be a number between 0 and 100');\n 301→    }\n 302→  }\n 303→\n 304→  /**\n 305→   * Get metric value from system info\n 306→   * @private\n 307→   */\n 308→  _getMetricValue(metrics, metricName) {\n 309→    switch (metricName) {\n 310→      case 'cpu':\n 311→        return metrics.cpu?.usage;\n 312→      case 'memory':\n 313→        return metrics.memory?.usagePercent;\n 314→      case 'disk':\n 315→        return metrics.disk?.usagePercent;\n 316→      default:\n 317→        return undefined;\n 318→    }\n 319→  }\n 320→\n 321→  /**\n 322→   * Evaluate threshold condition\n 323→   * @private\n 324→   */\n 325→  _evaluateThreshold(currentValue, operator, threshold) {\n 326→    switch (operator) {\n 327→      case '>':\n 328→        return currentValue > threshold;\n 329→      case '<':\n 330→        return currentValue < threshold;\n 331→      case '>=':\n 332→        return currentValue >= threshold;\n 333→      case '<=':\n 334→        return currentValue <= threshold;\n 335→      default:\n 336→        return false;\n 337→    }\n 338→  }\n 339→}\n 340→\n 341→// Export singleton instance for convenience\n 342→export const alertManagerService = new AlertManagerService();\n 343→\n 344→export default AlertManagerService;\n 345→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_731dc1b01ddc41d0bd2ad98b","__timestamp":"2026-03-12T21:29:53.648Z","_requestId":"197c31d70a614d2a931d269ab7ee2117"}
