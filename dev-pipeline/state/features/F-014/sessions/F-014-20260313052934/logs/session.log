{"type":"user","uuid":"82beba08-fa70-4dbc-a897-150aa9fefea1","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"019ce3f831f7034e724ec307742e66dc","content":[{"type":"text","text":"   1→import 'dotenv/config';\n   2→import { z } from 'zod';\n   3→\n   4→import { loadPipelineInfraConfig } from './pipeline-infra/config-loader.js';\n   5→import { resolveDaemonLogPaths } from './pipeline-infra/path-policy.js';\n   6→\n   7→const schema = z.object({\n   8→  TELEGRAM_BOT_TOKEN: z.string().optional().default(''),\n   9→  ENABLE_TELEGRAM: z.string().optional().default('true'),\n  10→  ALLOWED_USER_IDS: z.string().optional().default(''),\n  11→  CODEBUDDY_BIN: z.string().min(1).default('codebuddy'),\n  12→  CODEBUDDY_PERMISSION_FLAG: z.string().default('-y'),\n  13→  CODEBUDDY_ECHO_STDIO: z.string().optional().default('true'),\n  14→  CODEBUDDY_HEARTBEAT_MS: z.coerce.number().int().nonnegative().default(15000),\n  15→  TELEGRAM_FILE_ALLOWED_ROOTS: z.string().optional().default(''),\n  16→  TELEGRAM_FILE_CANDIDATE_DIRS: z.string().optional().default(''),\n  17→  REQUEST_TIMEOUT_MS: z.coerce.number().int().nonnegative().default(120000),\n  18→  MAX_PROMPT_CHARS: z.coerce.number().int().positive().default(8000),\n  19→  MAX_HISTORY_TURNS: z.coerce.number().int().positive().default(10),\n  20→  WEB_HOST: z.string().default('127.0.0.1'),\n  21→  WEB_PORT: z.coerce.number().int().positive().default(8787),\n  22→  ENABLE_SYSTEM_EXEC: z.string().optional().default('false'),\n  23→  ALLOWED_COMMAND_PREFIXES: z.string().optional().default(''),\n  24→  SYSTEM_EXEC_TIMEOUT_MS: z.coerce.number().int().positive().default(60000),\n  25→  LOG_LEVEL: z.enum(['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent']).default('info'),\n  26→  // F-006: Safety and Permission Guard\n  27→  USER_PERMISSIONS: z.string().optional().default(''),\n  28→  ALLOW_ADMIN_SKIP_CONFIRM: z.string().optional().default('true'),\n  29→  AUDIT_LOG_DIR: z.string().optional().default('logs'),\n  30→  AUDIT_LOG_MAX_SIZE_MB: z.coerce.number().int().positive().default(10),\n  31→  AUDIT_LOG_MAX_FILES: z.coerce.number().int().positive().default(5),\n  32→  // F-009: General Command Executor\n  33→  COMMAND_BLACKLIST: z.string().optional().default(''),\n  34→  HIGH_RISK_KEYWORDS: z.string().optional().default('rm -rf,sudo,kill,chmod -R,chown,dd,mkfs,shutdown,reboot,halt'),\n  35→  DIRECT_EXEC_MODE: z.string().optional().default('false'),\n  36→  // F-010: File Manager\n  37→  FILE_MAX_READ_SIZE: z.coerce.number().int().positive().default(1048576), // 1MB\n  38→  FILE_MAX_TREE_DEPTH: z.coerce.number().int().positive().default(3),\n  39→  FILE_MAX_TREE_ITEMS: z.coerce.number().int().positive().default(100),\n  40→  FILE_MAX_SEARCH_DEPTH: z.coerce.number().int().positive().default(10),\n  41→  FILE_MAX_SEARCH_RESULTS: z.coerce.number().int().positive().default(100),\n  42→  FILE_SEARCH_RESULTS_PER_PAGE: z.coerce.number().int().positive().default(20),\n  43→  // F-011: AI CLI Proxy\n  44→  AI_CLI_HEARTBEAT_THRESHOLD_MS: z.coerce.number().int().nonnegative().default(10000),\n  45→  AI_CLI_HEARTBEAT_INTERVAL_MS: z.coerce.number().int().nonnegative().default(30000),\n  46→  AI_CLI_ENABLE_HEARTBEAT: z.string().optional().default('true'),\n  47→  // F-012: System Monitor\n  48→  SYSTEM_MONITOR_INTERVAL_MS: z.coerce.number().int().positive().default(60000),\n  49→  SYSTEM_MONITOR_DATA_DIR: z.string().optional().default('data'),\n  50→  // F-013: Session and Context Manager\n  51→  SESSION_TIMEOUT_MS: z.coerce.number().int().positive().default(1800000), // 30 min\n  52→  SESSION_HISTORY_MAX: z.coerce.number().int().positive().default(100),\n  53→  SESSION_PERSISTENCE_DIR: z.string().optional().default('data/sessions'),\n  54→  ALIAS_PERSISTENCE_PATH: z.string().optional().default('data/aliases.json')\n  55→});\n  56→\n  57→const parsed = schema.parse(process.env);\n  58→\n  59→function parseAllowedUserIds(input) {\n  60→  return new Set(\n  61→    input\n  62→      .split(',')\n  63→      .map((id) => id.trim())\n  64→      .filter(Boolean)\n  65→  );\n  66→}\n  67→\n  68→function parseCsvList(input) {\n  69→  return input\n  70→    .split(',')\n  71→    .map((item) => item.trim())\n  72→    .filter(Boolean);\n  73→}\n  74→\n  75→function parseBoolean(input) {\n  76→  const normalized = (input ?? '').trim().toLowerCase();\n  77→  return normalized === '1' || normalized === 'true' || normalized === 'yes' || normalized === 'on';\n  78→}\n  79→\n  80→/**\n  81→ * Parse USER_PERMISSIONS env var into a Map of userId -> role\n  82→ * Format: \"123456789:admin,987654321:operator\"\n  83→ * @param {string} input\n  84→ * @returns {Map<string, string>}\n  85→ */\n  86→function parseUserPermissions(input) {\n  87→  const permissions = new Map();\n  88→  if (!input || !input.trim()) {\n  89→    return permissions;\n  90→  }\n  91→\n  92→  const entries = input.split(',').map((s) => s.trim()).filter(Boolean);\n  93→  for (const entry of entries) {\n  94→    const [userId, role] = entry.split(':').map((s) => s.trim());\n  95→    if (userId && role) {\n  96→      const normalizedRole = role.toLowerCase();\n  97→      if (['admin', 'operator', 'viewer'].includes(normalizedRole)) {\n  98→        permissions.set(userId, normalizedRole);\n  99→      }\n 100→    }\n 101→  }\n 102→  return permissions;\n 103→}\n 104→\n 105→const enableTelegram = parseBoolean(parsed.ENABLE_TELEGRAM);\n 106→if (enableTelegram && !parsed.TELEGRAM_BOT_TOKEN) {\n 107→  throw new Error('ENABLE_TELEGRAM=true 时必须提供 TELEGRAM_BOT_TOKEN');\n 108→}\n 109→\n 110→const pipelineInfra = loadPipelineInfraConfig({\n 111→  env: process.env,\n 112→  argv: process.argv.slice(2),\n 113→  cwd: process.cwd()\n 114→});\n 115→\n 116→const daemonLogPaths = resolveDaemonLogPaths(pipelineInfra.projectRoot);\n 117→\n 118→export const config = Object.freeze({\n 119→  telegramBotToken: parsed.TELEGRAM_BOT_TOKEN,\n 120→  enableTelegram,\n 121→  allowedUserIds: parseAllowedUserIds(parsed.ALLOWED_USER_IDS),\n 122→  codebuddyBin: parsed.CODEBUDDY_BIN,\n 123→  codebuddyPermissionFlag: parsed.CODEBUDDY_PERMISSION_FLAG,\n 124→  codebuddyEchoStdio: parseBoolean(parsed.CODEBUDDY_ECHO_STDIO),\n 125→  codebuddyHeartbeatMs: parsed.CODEBUDDY_HEARTBEAT_MS,\n 126→  telegramFileAllowedRoots: parseCsvList(parsed.TELEGRAM_FILE_ALLOWED_ROOTS),\n 127→  telegramFileCandidateDirs: parseCsvList(parsed.TELEGRAM_FILE_CANDIDATE_DIRS),\n 128→  requestTimeoutMs: parsed.REQUEST_TIMEOUT_MS,\n 129→  maxPromptChars: parsed.MAX_PROMPT_CHARS,\n 130→  maxHistoryTurns: parsed.MAX_HISTORY_TURNS,\n 131→  webHost: parsed.WEB_HOST,\n 132→  webPort: parsed.WEB_PORT,\n 133→  enableSystemExec: parseBoolean(parsed.ENABLE_SYSTEM_EXEC),\n 134→  allowedCommandPrefixes: parseCsvList(parsed.ALLOWED_COMMAND_PREFIXES),\n 135→  systemExecTimeoutMs: parsed.SYSTEM_EXEC_TIMEOUT_MS,\n 136→  logLevel: parsed.LOG_LEVEL,\n 137→  // F-006: Safety and Permission Guard\n 138→  userPermissions: parseUserPermissions(parsed.USER_PERMISSIONS),\n 139→  allowAdminSkipConfirm: parseBoolean(parsed.ALLOW_ADMIN_SKIP_CONFIRM),\n 140→  auditLogDir: parsed.AUDIT_LOG_DIR,\n 141→  auditLogMaxSizeMb: parsed.AUDIT_LOG_MAX_SIZE_MB,\n 142→  auditLogMaxFiles: parsed.AUDIT_LOG_MAX_FILES,\n 143→  // F-009: General Command Executor\n 144→  commandBlacklist: parseCsvList(parsed.COMMAND_BLACKLIST),\n 145→  highRiskKeywords: parseCsvList(parsed.HIGH_RISK_KEYWORDS),\n 146→  directExecMode: parseBoolean(parsed.DIRECT_EXEC_MODE),\n 147→  // F-010: File Manager\n 148→  fileMaxReadSize: parsed.FILE_MAX_READ_SIZE,\n 149→  fileMaxTreeDepth: parsed.FILE_MAX_TREE_DEPTH,\n 150→  fileMaxTreeItems: parsed.FILE_MAX_TREE_ITEMS,\n 151→  fileMaxSearchDepth: parsed.FILE_MAX_SEARCH_DEPTH,\n 152→  fileMaxSearchResults: parsed.FILE_MAX_SEARCH_RESULTS,\n 153→  fileSearchResultsPerPage: parsed.FILE_SEARCH_RESULTS_PER_PAGE,\n 154→  // F-011: AI CLI Proxy\n 155→  aiCliHeartbeatThresholdMs: parsed.AI_CLI_HEARTBEAT_THRESHOLD_MS,\n 156→  aiCliHeartbeatIntervalMs: parsed.AI_CLI_HEARTBEAT_INTERVAL_MS,\n 157→  aiCliEnableHeartbeat: parseBoolean(parsed.AI_CLI_ENABLE_HEARTBEAT),\n 158→  // F-012: System Monitor\n 159→  systemMonitorIntervalMs: parsed.SYSTEM_MONITOR_INTERVAL_MS,\n 160→  systemMonitorDataDir: parsed.SYSTEM_MONITOR_DATA_DIR,\n 161→  // F-013: Session and Context Manager\n 162→  sessionTimeoutMs: parsed.SESSION_TIMEOUT_MS,\n 163→  sessionHistoryMax: parsed.SESSION_HISTORY_MAX,\n 164→  sessionPersistenceDir: parsed.SESSION_PERSISTENCE_DIR,\n 165→  aliasPersistencePath: parsed.ALIAS_PERSISTENCE_PATH,\n 166→  pipelineInfra: Object.freeze({\n 167→    ...pipelineInfra,\n 168→    daemonLogPaths\n 169→  })\n 170→});\n 171→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_fc1b22860b7f4ad68e98b8a4","__timestamp":"2026-03-12T21:33:40.419Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
