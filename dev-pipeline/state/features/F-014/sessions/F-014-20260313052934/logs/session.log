ta, handleCommits } from './commands/handlers/commits.js';\n  27→// F-009: New command handlers\n  28→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n  29→import { moreMeta, handleMore } from './commands/handlers/more.js';\n  30→// F-010: File Manager command handlers\n  31→import { lsMeta, handleLs } from './commands/handlers/ls.js';\n  32→import { treeMeta, handleTree } from './commands/handlers/tree.js';\n  33→import { catMeta, handleCat } from './commands/handlers/cat.js';\n  34→import { headMeta, handleHead } from './commands/handlers/head.js';\n  35→import { tailMeta, handleTail } from './commands/handlers/tail.js';\n  36→import { findMeta, handleFind } from './commands/handlers/find.js';\n  37→import { uploadMeta, handleUpload } from './commands/handlers/upload.js';\n  38→import { downloadMeta, handleDownload } from './commands/handlers/download.js';\n  39→// F-012: System Monitor command handlers\n  40→import { sysinfoMeta, handleSysinfo } from './commands/handlers/sysinfo.js';\n  41→import { psMeta, handlePs } from './commands/handlers/ps.js';\n  42→import { killMeta, handleKill } from './commands/handlers/kill.js';\n  43→import { monitorMeta, handleMonitor } from './commands/handlers/monitor.js';\n  44→// F-013: Session and Context Manager command handlers\n  45→import { historyMeta, handleHistory } from './commands/handlers/history.js';\n  46→import { aliasMeta, handleAlias } from './commands/handlers/alias.js';\n  47→import { sessionsMeta, handleSessions } from './commands/handlers/sessions.js';\n  48→import { generateHelp } from './commands/help.js';\n  49→import { sessionStore } from '../services/session-store.js';\n  50→import { sessionContextService } from '../services/session-context-service.js';\n  51→import { aliasStore } from '../services/alias-store.js';\n  52→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n  53→\n  54→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n  55→const STREAM_MIN_CHARS = 220;\n  56→const STREAM_FLUSH_INTERVAL_MS = 1200;\n  57→const TYPING_INTERVAL_MS = 3500;\n  58→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n  59→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n  60→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n  61→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n  62→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n  63→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n  64→const TMP_DIR = path.resolve(os.tmpdir());\n  65→const HOME_DIR = path.resolve(os.homedir());\n  66→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n  67→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n  68→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  69→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n  70→\n  71→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  72→  const normalized = configuredDirs\n  73→    .map((dir) => String(dir ?? '').trim())\n  74→    .filter(Boolean)\n  75→    .map((dir) => path.resolve(dir));\n  76→\n  77→  if (normalized.length > 0) {\n  78→    return [...new Set(normalized)];\n  79→  }\n  80→\n  81→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n  82→}\n  83→\n  84→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  85→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  86→\n  87→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  88→  const chunks = [];\n  89→  for (let i = 0; i < text.length; i += chunkSize) {\n  90→    chunks.push(text.slice(i, i + chunkSize));\n  91→  }\n  92→  return chunks;\n  93→}\n  94→\n  95→function sanitizeMarkerPath(raw) {\n  96→  return String(raw ?? '')\n  97→    .trim()\n  98→    .replace(/^['\"`]+/, '')\n  99→    .replace(/['\"`]+$/, '');\n 100→}\n 101→\n 102→function extractFileMarkers(text = '') {\n 103→  const fileRefs = [];\n 104→\n 105→  const withSendFileRemoved = text.replace(\n 106→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n 107→    (_full, rawRef) => {\n 108→      const ref = sanitizeMarkerPath(rawRef);\n 109→      if (ref) {\n 110→        fileRefs.push(ref);\n 111→      }\n 112→      return '\\n';\n 113→    }\n 114→  );\n 115→\n 116→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n 117→    const ref = sanitizeMarkerPath(rawRef);\n 118→    if (ref) {\n 119→      fileRefs.push(ref);\n 120→    }\n 121→    return '';\n 122→  });\n 123→\n 124→  const withBacktickPathRemoved = withImageRemoved.replace(\n 125→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 126→    (_full, rawRef) => {\n 127→      const ref = sanitizeMarkerPath(rawRef);\n 128→      if (ref) {\n 129→        fileRefs.push(ref);\n 130→      }\n 131→      return '';\n 132→    }\n 133→  );\n 134→\n 135→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 136→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 137→    (_full, rawRef) => {\n 138→      const ref = sanitizeMarkerPath(rawRef);\n 139→      if (ref) {\n 140→        fileRefs.push(ref);\n 141→      }\n 142→      return '';\n 143→    }\n 144→  );\n 145→\n 146→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 147→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 148→    (_full, rawRef) => {\n 149→      const ref = sanitizeMarkerPath(rawRef);\n 150→      if (ref) {\n 151→        fileRefs.push(ref);\n 152→      }\n 153→      return '\\n';\n 154→    }\n 155→  );\n 156→\n 157→  return {\n 158→    fileRefs: [...new Set(fileRefs)],\n 159→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 160→  };\n 161→}\n 162→\n 163→function isPathWithinRoot(targetPath, rootPath) {\n 164→  const relative = path.relative(rootPath, targetPath);\n 165→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 166→}\n 167→\n 168→function isAllowedFilePath(filePath) {\n 169→  const resolved = path.resolve(filePath);\n 170→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 171→}\n 172→\n 173→function buildFileCandidates(normalizedPath) {\n 174→  if (path.isAbsolute(normalizedPath)) {\n 175→    return [normalizedPath];\n 176→  }\n 177→\n 178→  const baseName = path.basename(normalizedPath);\n 179→  const candidates = [\n 180→    path.resolve(process.cwd(), normalizedPath),\n 181→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 182→  ];\n 183→\n 184→  return [...new Set(candidates)];\n 185→}\n 186→\n 187→async function resolveLocalFilePath(fileRef) {\n 188→  const normalized = sanitizeMarkerPath(fileRef);\n 189→  if (!normalized) {\n 190→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 191→  }\n 192→\n 193→  if (!path.isAbsolute(normalized)) {\n 194→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 195→  }\n 196→\n 197→  const candidates = buildFileCandidates(normalized);\n 198→\n 199→  for (const candidate of candidates) {\n 200→    try {\n 201→      await access(candidate);\n 202→      return { filePath: candidate, triedPaths: candidates };\n 203→    } catch {\n 204→      // ignore\n 205→    }\n 206→  }\n 207→\n 208→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 209→}\n 210→\n 211→async function validateFileForTelegram(filePath) {\n 212→  const resolvedPath = path.resolve(filePath);\n 213→  if (!isAllowedFilePath(resolvedPath)) {\n 214→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 215→  }\n 216→\n 217→  const ext = path.extname(resolvedPath).toLowerCase();\n 218→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 219→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 220→  }\n 221→\n 222→  const fileStat = await stat(resolvedPath);\n 223→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 224→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 225→\n 226→  if (fileStat.size > maxSize) {\n 227→    return {\n 228→      ok: false,\n 229→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 230→    };\n 231→  }\n 232→\n 233→  return { ok: true, isPhoto, resolvedPath };\n 234→}\n 235→\n 236→function isTimeoutLikeError(message = '') {\n 237→  const normalized = String(message).toLowerCase();\n 238→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 239→}\n 240→\n 241→function sleep(ms) {\n 242→  return new Promise((resolve) => setTimeout(resolve, ms));\n 243→}\n 244→\n 245→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 246→  if (isPhoto) {\n 247→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 248→    return;\n 249→  }\n 250→\n 251→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 252→}\n 253→\n 254→async function replyFiles(ctx, fileRefs = []) {\n 255→  const results = [];\n 256→\n 257→  for (const fileRef of fileRefs) {\n 258→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 259→    if (!filePath) {\n 260→      const reason = rejectReason || 'not_found';\n 261→      results.push({ fileRef, sent: false, reason, triedPaths });\n 262→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 263→      continue;\n 264→    }\n 265→\n 266→    try {\n 267→      const validation = await validateFileForTelegram(filePath);\n 268→      if (!validation.ok) {\n 269→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 270→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 271→        continue;\n 272→      }\n 273→\n 274→      const actualPath = validation.resolvedPath;\n 275→      let sent = false;\n 276→      let lastReason = '';\n 277→\n 278→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 279→        try {\n 280→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 281→          sent = true;\n 282→          logger.info(\n 283→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 284→            'Telegram file sent'\n 285→          );\n 286→          break;\n 287→        } catch (error) {\n 288→          lastReason = error instanceof Error ? error.message : String(error);\n 289→          logger.warn(\n 290→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 291→            'Telegram file send attempt failed'\n 292→          );\n 293→\n 294→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 295→            await sleep(600);\n 296→            continue;\n 297→          }\n 298→\n 299→          break;\n 300→        }\n 301→      }\n 302→\n 303→      if (!sent) {\n 304→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 305→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 306→        continue;\n 307→      }\n 308→\n 309→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 310→    } catch (error) {\n 311→      const reason = error instanceof Error ? error.message : String(error);\n 312→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 313→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 314→    }\n 315→  }\n 316→\n 317→  return results;\n 318→}\n 319→\n 320→async function safeReply(ctx, text) {\n 321→  try {\n 322→    await ctx.reply(text);\n 323→    return true;\n 324→  } catch (error) {\n 325→    const reason = error instanceof Error ? error.message : String(error);\n 326→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 327→    return false;\n 328→  }\n 329→}\n 330→\n 331→async function replyLargeText(ctx, text) {\n 332→  const chunks = splitMessage(text);\n 333→  for (const chunk of chunks) {\n 334→    const ok = await safeReply(ctx, chunk);\n 335→    if (!ok) {\n 336→      break;\n 337→    }\n 338→  }\n 339→}\n 340→\n 341→async function safeEditMessageText(ctx, messageId, text) {\n 342→  const nextText = text && text.trim() ? text : ' ';\n 343→\n 344→  try {\n 345→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 346→  } catch (error) {\n 347→    const message = error instanceof Error ? error.message : String(error);\n 348→    if (message.includes('message is not modified')) {\n 349→      return;\n 350→    }\n 351→    throw error;\n 352→  }\n 353→}\n 354→\n 355→function createEditableStreamPublisher(ctx) {\n 356→  let fullText = '';\n 357→  let renderedText = '';\n 358→  let pendingChars = 0;\n 359→  let lastFlushAt = 0;\n 360→  let flushChain = Promise.resolve();\n 361→  let activeMessage = null;\n 362→  let activeSegmentIndex = 0;\n 363→  let publishedMessageCount = 0;\n 364→\n 365→  async function ensureActiveMessage() {\n 366→    if (activeMessage) {\n 367→      return;\n 368→    }\n 369→    activeMessage = await ctx.reply('处理中...');\n 370→    activeSegmentIndex = 0;\n 371→    publishedMessageCount += 1;\n 372→  }\n 373→\n 374→  async function render(force = false) {\n 375→    const now = Date.now();\n 376→\n 377→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 378→      return;\n 379→    }\n 380→\n 381→    if (fullText === renderedText) {\n 382→      pendingChars = 0;\n 383→      return;\n 384→    }\n 385→\n 386→    await ensureActiveMessage();\n 387→\n 388→    const segments = splitMessage(fullText);\n 389→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 390→\n 391→    while (activeSegmentIndex < targetLastIndex) {\n 392→      const text = segments[activeSegmentIndex] ?? ' ';\n 393→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 394→\n 395→      activeMessage = await ctx.reply('继续输出中...');\n 396→      activeSegmentIndex += 1;\n 397→      publishedMessageCount += 1;\n 398→    }\n 399→\n 400→    const activeText = segments[targetLastIndex] ?? ' ';\n 401→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 402→\n 403→    renderedText = fullText;\n 404→    pendingChars = 0;\n 405→    lastFlushAt = now;\n 406→  }\n 407→\n 408→  function enqueueRender(force = false) {\n 409→    flushChain = flushChain.then(() => render(force));\n 410→  }\n 411→\n 412→  return {\n 413→    push(text) {\n 414→      const appendText = text ?? '';\n 415→      if (!appendText) {\n 416→        return;\n 417→      }\n 418→      fullText += appendText;\n 419→      pendingChars += appendText.length;\n 420→      enqueueRender(false);\n 421→    },\n 422→    setFinalText(text) {\n 423→      fullText = text ?? '';\n 424→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 425→      enqueueRender(true);\n 426→    },\n 427→    async finish() {\n 428→      enqueueRender(true);\n 429→      await flushChain;\n 430→      return {\n 431→        outputLength: renderedText.length,\n 432→        messageCount: publishedMessageCount\n 433→      };\n 434→    }\n 435→  };\n 436→}\n 437→\n 438→function buildSessionId(ctx) {\n 439→  return String(ctx.chat.id);\n 440→}\n 441→\n 442→function ensureAllowed(ctx) {\n 443→  const userId = ctx.from?.id;\n 444→  if (!isAllowedUser(userId)) {\n 445→    throw new Error('当前账号未被授权使用该机器人。');\n 446→  }\n 447→}\n 448→\n 449→/**\n 450→ * Register all pipeline-related commands.\n 451→ */\n 452→function registerPipelineCommands() {\n 453→  registerCommand(pipelineMeta, handlePipeline);\n 454→  registerCommand(bugfixMeta, handleBugfix);\n 455→  registerCommand(plannerMeta, handlePlanner);\n 456→  registerCommand(statusMeta, handleStatus);\n 457→  registerCommand(logsMeta, handleLogs);\n 458→  registerCommand(stopMeta, handleStop);\n 459→  registerCommand(planMeta, handlePlan);\n 460→  registerCommand(auditMeta, handleAudit);\n 461→  registerCommand(commitMeta, handleCommit);\n 462→  registerCommand(commitsMeta, handleCommits);\n 463→  // F-009: New commands\n 464→  registerCommand(cdMeta, handleCd);\n 465→  registerCommand(moreMeta, handleMore);\n 466→  // F-010: File Manager commands\n 467→  registerCommand(lsMeta, handleLs);\n 468→  registerCommand(treeMeta, handleTree);\n 469→  registerCommand(catMeta, handleCat);\n 470→  registerCommand(headMeta, handleHead);\n 471→  registerCommand(tailMeta, handleTail);\n 472→  registerCommand(findMeta, handleFind);\n 473→  registerCommand(uploadMeta, handleUpload);\n 474→  registerCommand(downloadMeta, handleDownload);\n 475→  // F-012: System Monitor commands\n 476→  registerCommand(sysinfoMeta, handleSysinfo);\n 477→  registerCommand(psMeta, handlePs);\n 478→  registerCommand(killMeta, handleKill);\n 479→  registerCommand(monitorMeta, handleMonitor);\n 480→  // F-013: Session and Context Manager commands\n 481→  registerCommand(historyMeta, handleHistory);\n 482→  registerCommand(aliasMeta, handleAlias);\n 483→  registerCommand(sessionsMeta, handleSessions);\n 484→}\n 485→\n 486→export async function createTelegramBot() {\n 487→  const bot = new Telegraf(config.telegramBotToken, {\n 488→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 489→  });\n 490→\n 491→  // F-013: Initialize session context service\n 492→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n 493→  await aliasStore.initAliasStore({ filePath: config.aliasPersistencePath });\n 494→\n 495→  // F-013: Restore sessions from disk\n 496→  await sessionContextService.restoreSessions();\n 497→\n 498→  // F-013: Set up notification callback for session timeout\n 499→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n 500→    try {\n 501→      // Extract chat ID from session key (format: telegram:123456789)\n 502→      const chatId = sessionKey.replace('telegram:', '');\n 503→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n 504→    } catch (error) {\n 505→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n 506→    }\n 507→  });\n 508→\n 509→  // F-013: Start timeout watcher\n 510→  sessionContextService.startTimeoutWatcher();\n 511→\n 512→  // Register pipeline commands\n 513→  registerPipelineCommands();\n 514→\n 515→  bot.catch((error, ctx) => {\n 516→    const message = error instanceof Error ? error.message : String(error);\n 517→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 518→  });\n 519→\n 520→  bot.start(async (ctx) => {\n 521→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 522→  });\n 523→\n 524→  bot.help(async (ctx) => {\n 525→    const helpText = generateHelp();\n 526→    await ctx.reply(helpText);\n 527→  });\n 528→\n 529→  bot.command('reset', async (ctx) => {\n 530→    try {\n 531→      ensureAllowed(ctx);\n 532→      const sessionId = buildSessionId(ctx);\n 533→\n 534→      // F-011: Interrupt any running AI CLI task\n 535→      if (isAiCliRunning(sessionId)) {\n 536→        interruptAiCli(sessionId);\n 537→      }\n 538→\n 539→      resetSession({ channel: 'telegram', sessionId });\n 540→      await ctx.reply('已清空当前会话上下文。');\n 541→    } catch (error) {\n 542→      await ctx.reply(error instanceof E