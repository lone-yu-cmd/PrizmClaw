{"type":"user","uuid":"1765d939-2417-4393-886f-545a9e65d49e","session_id":"1a582f91-d102-4cef-bad5-528739f0d8b3","message":{"content":[{"type":"tool_result","tool_use_id":"call_59b0aefa181741bca29c6523","content":[{"type":"text","text":"   1→import { config } from '../config.js';\n   2→\n   3→class SessionStore {\n   4→  #messagesBySessionKey = new Map();\n   5→  #commitsBySessionKey = new Map();\n   6→  // F-009: Command executor extensions\n   7→  #cwdBySessionKey = new Map();\n   8→  #outputPagesBySessionKey = new Map();\n   9→  // F-010: File search results state for pagination\n  10→  #searchResultsBySessionKey = new Map();\n  11→  // F-011: AI CLI process tracking\n  12→  #activeProcessBySessionKey = new Map();\n  13→  // F-013: Session and Context Manager\n  14→  #commandHistoryBySessionKey = new Map();\n  15→  #envOverridesBySessionKey = new Map();\n  16→  #lastActivityBySessionKey = new Map();\n  17→  #userIdBySessionKey = new Map();\n  18→  #sessionCreatedAtBySessionKey = new Map();\n  19→\n  20→  get(sessionKey) {\n  21→    if (!this.#messagesBySessionKey.has(sessionKey)) {\n  22→      this.#messagesBySessionKey.set(sessionKey, []);\n  23→    }\n  24→    return this.#messagesBySessionKey.get(sessionKey);\n  25→  }\n  26→\n  27→  append(sessionKey, role, content) {\n  28→    const messages = this.get(sessionKey);\n  29→    messages.push({ role, content });\n  30→\n  31→    const maxMessages = config.maxHistoryTurns * 2;\n  32→    if (messages.length > maxMessages) {\n  33→      messages.splice(0, messages.length - maxMessages);\n  34→    }\n  35→  }\n  36→\n  37→  clear(sessionKey) {\n  38→    this.#messagesBySessionKey.delete(sessionKey);\n  39→    this.#commitsBySessionKey.delete(sessionKey);\n  40→    // F-009: Clear cwd and output pages\n  41→    this.#cwdBySessionKey.delete(sessionKey);\n  42→    this.#outputPagesBySessionKey.delete(sessionKey);\n  43→    // F-010: Clear search results\n  44→    this.#searchResultsBySessionKey.delete(sessionKey);\n  45→    // F-011: Clear active process\n  46→    this.#activeProcessBySessionKey.delete(sessionKey);\n  47→    // F-013: Clear session context data\n  48→    this.#commandHistoryBySessionKey.delete(sessionKey);\n  49→    this.#envOverridesBySessionKey.delete(sessionKey);\n  50→    this.#lastActivityBySessionKey.delete(sessionKey);\n  51→    this.#userIdBySessionKey.delete(sessionKey);\n  52→    this.#sessionCreatedAtBySessionKey.delete(sessionKey);\n  53→  }\n  54→\n  55→  toPrompt(sessionKey, channel = 'unknown') {\n  56→    const messages = this.get(sessionKey);\n  57→\n  58→    return [\n  59→      `你正在通过 ${channel} 渠道提供电脑助手服务。`,\n  60→      '请使用自然、简洁、可执行的表达。',\n  61→      '如果用户请求系统操作或截图，明确说明步骤与结果。',\n  62→      '当你产出本地文件（截图/文档）时，必须额外输出独立行：SEND_FILE:<绝对路径>。',\n  63→      '禁止仅输出 @image:xxx 或相对路径；路径必须是绝对路径（例如 /var/folders/... 或 /home/...）。',\n  64→      '以下是最近对话上下文：',\n  65→      ...messages.map((msg) => `${msg.role === 'user' ? '用户' : '助手'}: ${msg.content}`),\n  66→      '请继续回答最后一条用户消息。'\n  67→    ].join('\\n');\n  68→  }\n  69→\n  70→  /**\n  71→   * Add a commit record to a session.\n  72→   * @param {string} sessionKey - Session identifier\n  73→   * @param {Object} commitInfo - Commit information\n  74→   */\n  75→  addCommit(sessionKey, commitInfo) {\n  76→    if (!this.#commitsBySessionKey.has(sessionKey)) {\n  77→      this.#commitsBySessionKey.set(sessionKey, []);\n  78→    }\n  79→    const commits = this.#commitsBySessionKey.get(sessionKey);\n  80→    commits.push({\n  81→      ...commitInfo,\n  82→      timestamp: commitInfo.timestamp || Date.now()\n  83→    });\n  84→  }\n  85→\n  86→  /**\n  87→   * Get commits for a session.\n  88→   * @param {string} sessionKey - Session identifier\n  89→   * @returns {Object[]} Array of commit records\n  90→   */\n  91→  getCommits(sessionKey) {\n  92→    return this.#commitsBySessionKey.get(sessionKey) || [];\n  93→  }\n  94→\n  95→  /**\n  96→   * Get the last commit for a session.\n  97→   * @param {string} sessionKey - Session identifier\n  98→   * @returns {Object|null} Last commit record or null\n  99→   */\n 100→  getLastCommit(sessionKey) {\n 101→    const commits = this.getCommits(sessionKey);\n 102→    return commits.length > 0 ? commits[commits.length - 1] : null;\n 103→  }\n 104→\n 105→  // F-009: Command executor methods\n 106→\n 107→  /**\n 108→   * Get current working directory for a session.\n 109→   * @param {string} sessionKey - Session identifier\n 110→   * @returns {string|null} Current working directory or null\n 111→   */\n 112→  getCwd(sessionKey) {\n 113→    return this.#cwdBySessionKey.get(sessionKey) || null;\n 114→  }\n 115→\n 116→  /**\n 117→   * Set current working directory for a session.\n 118→   * @param {string} sessionKey - Session identifier\n 119→   * @param {string} cwd - Working directory path\n 120→   */\n 121→  setCwd(sessionKey, cwd) {\n 122→    this.#cwdBySessionKey.set(sessionKey, cwd);\n 123→  }\n 124→\n 125→  /**\n 126→   * Get output pages for a session (for /more pagination).\n 127→   * @param {string} sessionKey - Session identifier\n 128→   * @returns {string[]|null} Array of output pages or null\n 129→   */\n 130→  getOutputPages(sessionKey) {\n 131→    return this.#outputPagesBySessionKey.get(sessionKey) || null;\n 132→  }\n 133→\n 134→  /**\n 135→   * Set output pages for a session.\n 136→   * @param {string} sessionKey - Session identifier\n 137→   * @param {string[]} pages - Array of output page strings\n 138→   */\n 139→  setOutputPages(sessionKey, pages) {\n 140→    this.#outputPagesBySessionKey.set(sessionKey, pages);\n 141→  }\n 142→\n 143→  /**\n 144→   * Clear output pages for a session.\n 145→   * @param {string} sessionKey - Session identifier\n 146→   */\n 147→  clearOutputPages(sessionKey) {\n 148→    this.#outputPagesBySessionKey.delete(sessionKey);\n 149→  }\n 150→\n 151→  // F-010: File search results methods\n 152→\n 153→  /**\n 154→   * Get search results for a session.\n 155→   * @param {string} sessionKey - Session identifier\n 156→   * @returns {Object[]|null} Array of search results or null\n 157→   */\n 158→  getSearchResults(sessionKey) {\n 159→    return this.#searchResultsBySessionKey.get(sessionKey) || null;\n 160→  }\n 161→\n 162→  /**\n 163→   * Set search results for a session.\n 164→   * @param {string} sessionKey - Session identifier\n 165→   * @param {Object[]} results - Array of search result objects\n 166→   */\n 167→  setSearchResults(sessionKey, results) {\n 168→    this.#searchResultsBySessionKey.set(sessionKey, results);\n 169→  }\n 170→\n 171→  /**\n 172→   * Clear search results for a session.\n 173→   * @param {string} sessionKey - Session identifier\n 174→   */\n 175→  clearSearchResults(sessionKey) {\n 176→    this.#searchResultsBySessionKey.delete(sessionKey);\n 177→  }\n 178→\n 179→  // F-011: AI CLI process tracking methods\n 180→\n 181→  /**\n 182→   * Get active AI CLI process info.\n 183→   * @param {string} sessionKey - Session identifier\n 184→   * @returns {{ pid: number, startedAt: number, stdoutBytes?: number, childProcess: Object, interrupted?: boolean, timedOut?: boolean, userId?: string } | null}\n 185→   */\n 186→  getActiveProcess(sessionKey) {\n 187→    return this.#activeProcessBySessionKey.get(sessionKey) || null;\n 188→  }\n 189→\n 190→  /**\n 191→   * Set active AI CLI process.\n 192→   * @param {string} sessionKey - Session identifier\n 193→   * @param {{ pid: number, startedAt: number, childProcess: Object, stdoutBytes?: number, userId?: string, interrupted?: boolean, timedOut?: boolean }} info\n 194→   */\n 195→  setActiveProcess(sessionKey, info) {\n 196→    this.#activeProcessBySessionKey.set(sessionKey, {\n 197→      ...info,\n 198→      stdoutBytes: info.stdoutBytes ?? 0\n 199→    });\n 200→  }\n 201→\n 202→  /**\n 203→   * Update stdout bytes for active process.\n 204→   * @param {string} sessionKey - Session identifier\n 205→   * @param {number} bytes - Additional bytes received\n 206→   */\n 207→  updateProcessBytes(sessionKey, bytes) {\n 208→    const info = this.#activeProcessBySessionKey.get(sessionKey);\n 209→    if (info) {\n 210→      info.stdoutBytes = (info.stdoutBytes ?? 0) + bytes;\n 211→    }\n 212→  }\n 213→\n 214→  /**\n 215→   * Clear active process.\n 216→   * @param {string} sessionKey - Session identifier\n 217→   */\n 218→  clearActiveProcess(sessionKey) {\n 219→    this.#activeProcessBySessionKey.delete(sessionKey);\n 220→  }\n 221→\n 222→  // F-013: Session and Context Manager methods\n 223→\n 224→  /**\n 225→   * Record a command execution in history.\n 226→   * @param {string} sessionKey - Session identifier\n 227→   * @param {string} command - Command that was executed\n 228→   * @param {number} exitCode - Exit code of the command\n 229→   */\n 230→  recordCommand(sessionKey, command, exitCode) {\n 231→    if (!this.#commandHistoryBySessionKey.has(sessionKey)) {\n 232→      this.#commandHistoryBySessionKey.set(sessionKey, []);\n 233→    }\n 234→    const history = this.#commandHistoryBySessionKey.get(sessionKey);\n 235→    history.push({\n 236→      command,\n 237→      exitCode,\n 238→      timestamp: Date.now()\n 239→    });\n 240→\n 241→    // Trim to max history size\n 242→    const maxHistory = config.sessionHistoryMax;\n 243→    if (history.length > maxHistory) {\n 244→      history.splice(0, history.length - maxHistory);\n 245→    }\n 246→  }\n 247→\n 248→  /**\n 249→   * Get command history for a session.\n 250→   * @param {string} sessionKey - Session identifier\n 251→   * @param {number} [limit] - Maximum number of entries to return\n 252→   * @returns {Object[]} Array of { command, exitCode, timestamp }\n 253→   */\n 254→  getCommandHistory(sessionKey, limit) {\n 255→    const history = this.#commandHistoryBySessionKey.get(sessionKey) || [];\n 256→    if (limit !== undefined && limit > 0) {\n 257→      const start = Math.max(0, history.length - limit);\n 258→      return history.slice(start);\n 259→    }\n 260→    return [...history];\n 261→  }\n 262→\n 263→  /**\n 264→   * Set an environment variable override for a session.\n 265→   * @param {string} sessionKey - Session identifier\n 266→   * @param {string} key - Environment variable name\n 267→   * @param {string} value - Environment variable value\n 268→   */\n 269→  setEnvOverride(sessionKey, key, value) {\n 270→    if (!this.#envOverridesBySessionKey.has(sessionKey)) {\n 271→      this.#envOverridesBySessionKey.set(sessionKey, {});\n 272→    }\n 273→    this.#envOverridesBySessionKey.get(sessionKey)[key] = value;\n 274→  }\n 275→\n 276→  /**\n 277→   * Get all environment variable overrides for a session.\n 278→   * @param {string} sessionKey - Session identifier\n 279→   * @returns {Object} Environment variable key-value pairs\n 280→   */\n 281→  getEnvOverrides(sessionKey) {\n 282→    return { ...this.#envOverridesBySessionKey.get(sessionKey) } || {};\n 283→  }\n 284→\n 285→  /**\n 286→   * Update session activity timestamp and user ID.\n 287→   * @param {string} sessionKey - Session identifier\n 288→   * @param {string} userId - Telegram user ID\n 289→   */\n 290→  touchSession(sessionKey, userId) {\n 291→    const now = Date.now();\n 292→    this.#lastActivityBySessionKey.set(sessionKey, now);\n 293→    if (userId !== undefined) {\n 294→      this.#userIdBySessionKey.set(sessionKey, userId);\n 295→    }\n 296→    // Set creation time if this is a new session\n 297→    if (!this.#sessionCreatedAtBySessionKey.has(sessionKey)) {\n 298→      this.#sessionCreatedAtBySessionKey.set(sessionKey, now);\n 299→    }\n 300→  }\n 301→\n 302→  /**\n 303→   * Get last activity timestamp for a session.\n 304→   * @param {string} sessionKey - Session identifier\n 305→   * @returns {number|null} Timestamp or null if not set\n 306→   */\n 307→  getLastActivity(sessionKey) {\n 308→    return this.#lastActivityBySessionKey.get(sessionKey) || null;\n 309→  }\n 310→\n 311→  /**\n 312→   * Get comprehensive session information.\n 313→   * @param {string} sessionKey - Session identifier\n 314→   * @returns {Object|null} Session info object or null if not found\n 315→   */\n 316→  getSessionInfo(sessionKey) {\n 317→    const userId = this.#userIdBySessionKey.get(sessionKey);\n 318→    const createdAt = this.#sessionCreatedAtBySessionKey.get(sessionKey);\n 319→    const lastActivityAt = this.#lastActivityBySessionKey.get(sessionKey);\n 320→\n 321→    // Return null if session has no tracking data\n 322→    if (!createdAt && !lastActivityAt) {\n 323→      return null;\n 324→    }\n 325→\n 326→    return {\n 327→      sessionKey,\n 328→      userId: userId || null,\n 329→      cwd: this.#cwdBySessionKey.get(sessionKey) || null,\n 330→      envOverrides: { ...this.#envOverridesBySessionKey.get(sessionKey) } || {},\n 331→      commandCount: (this.#commandHistoryBySessionKey.get(sessionKey) || []).length,\n 332→      createdAt: createdAt || null,\n 333→      lastActivityAt: lastActivityAt || null\n 334→    };\n 335→  }\n 336→\n 337→  /**\n 338→   * Get all active session keys.\n 339→   * @returns {string[]} Array of session keys\n 340→   */\n 341→  getAllSessionKeys() {\n 342→    // Return keys from sessions that have activity tracking\n 343→    return Array.from(this.#lastActivityBySessionKey.keys());\n 344→  }\n 345→\n 346→  /**\n 347→   * Get the age of a session in milliseconds.\n 348→   * @param {string} sessionKey - Session identifier\n 349→   * @returns {number|null} Age in ms or null if not found\n 350→   */\n 351→  getSessionAge(sessionKey) {\n 352→    const createdAt = this.#sessionCreatedAtBySessionKey.get(sessionKey);\n 353→    if (!createdAt) {\n 354→      return null;\n 355→    }\n 356→    return Date.now() - createdAt;\n 357→  }\n 358→\n 359→  /**\n 360→   * Get idle time for a session in milliseconds.\n 361→   * @param {string} sessionKey - Session identifier\n 362→   * @returns {number|null} Idle time in ms or null if not found\n 363→   */\n 364→  getIdleTime(sessionKey) {\n 365→    const lastActivity = this.#lastActivityBySessionKey.get(sessionKey);\n 366→    if (!lastActivity) {\n 367→      return null;\n 368→    }\n 369→    return Date.now() - lastActivity;\n 370→  }\n 371→\n 372→  /**\n 373→   * Set user ID for a session.\n 374→   * @param {string} sessionKey - Session identifier\n 375→   * @param {string} userId - Telegram user ID\n 376→   */\n 377→  setUserId(sessionKey, userId) {\n 378→    this.#userIdBySessionKey.set(sessionKey, userId);\n 379→  }\n 380→\n 381→  /**\n 382→   * Get user ID for a session.\n 383→   * @param {string} sessionKey - Session identifier\n 384→   * @returns {string|null} User ID or null if not set\n 385→   */\n 386→  getUserId(sessionKey) {\n 387→    return this.#userIdBySessionKey.get(sessionKey) || null;\n 388→  }\n 389→}\n 390→\n 391→export const sessionStore = new SessionStore();\n 392→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_59b0aefa181741bca29c6523","__timestamp":"2026-03-12T21:30:00.026Z","_requestId":"197c31d70a614d2a931d269ab7ee2117"}
