st savedWatchers = JSON.parse(content);\n 260→\n 261→      assert.equal(savedWatchers.length, 1);\n 262→      assert.equal(savedWatchers[0].path, tempDir);\n 263→    });\n 264→\n 265→    test('should load watchers from file', async () => {\n 266→      // Write watchers directly to file\n 267→      const testWatchers = [{\n 268→        id: 'test-id-123',\n 269→        path: tempDir,\n 270→        chatId: '123',\n 271→        userId: '456',\n 272→        recursive: true,\n 273→        enabled: true,\n 274→        createdAt: Date.now()\n 275→      }];\n 276→\n 277→      await writeFile(watchersFile, JSON.stringify(testWatchers));\n 278→\n 279→      fileWatcherService.initFileWatcherService({\n 280→        dataDir: tempDir,\n 281→        allowedRoots: [tempDir],\n 282→        watchersFile: 'file-watchers.json'\n 283→      });\n 284→\n 285→      await fileWatcherService.loadWatches();\n 286→\n 287→      const watchers = fileWatcherService.listWatches();\n 288→      assert.equal(watchers.length, 1);\n 289→      assert.equal(watchers[0].id, 'test-id-123');\n 290→    });\n 291→\n 292→    test('should handle missing file gracefully', async () => {\n 293→      fileWatcherService.initFileWatcherService({ dataDir: tempDir });\n 294→\n 295→      await fileWatcherService.loadWatches();\n 296→\n 297→      const watchers = fileWatcherService.listWatches();\n 298→      assert.deepEqual(watchers, []);\n 299→    });\n 300→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_8164acc216aa40eaa825218d","__timestamp":"2026-03-12T21:38:33.106Z","_requestId":"0897e02cbc65495fa1b66af82a5de7ab"}
