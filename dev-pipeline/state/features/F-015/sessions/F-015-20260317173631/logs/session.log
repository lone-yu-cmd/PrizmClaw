{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_7955c7c5308146478fa28390","type":"tool_result","content":"     1→/**\n     2→ * Tests for test helpers\n     3→ * F-007: Test and Validation Suite\n     4→ *\n     5→ * Verifies that all test helper modules work correctly.\n     6→ */\n     7→\n     8→import test from 'node:test';\n     9→import assert from 'node:assert/strict';\n    10→import { join } from 'node:path';\n    11→\n    12→// Import all helpers at module level\n    13→import {\n    14→  getFixturePath,\n    15→  loadFixture,\n    16→  loadJsonFixture,\n    17→  fixtureExists\n    18→} from './fixture-loader.js';\n    19→\n    20→import {\n    21→  createMockRunner,\n    22→  createStatefulMockRunner\n    23→} from './mock-runner.js';\n    24→\n    25→import {\n    26→  createMockContext,\n    27→  createAdminContext,\n    28→  createOperatorContext,\n    29→  createViewerContext,\n    30→  createDocumentContext,\n    31→  createCommandContext\n    32→} from './mock-telegram.js';\n    33→\n    34→import {\n    35→  createTestStateDir,\n    36→  createTestPipelineDirs,\n    37→  writeTestState,\n    38→  readTestState,\n    39→  createTestPlan\n    40→} from './test-state.js';\n    41→\n    42→// ============================================================\n    43→// Fixture Loader Tests\n    44→// ============================================================\n    45→\n    46→test('fixture-loader: getFixturePath returns correct path', () => {\n    47→  const path = getFixturePath('plans/valid-feature-list.json');\n    48→  assert.ok(path.includes('fixtures'));\n    49→  assert.ok(path.includes('plans'));\n    50→  assert.ok(path.includes('valid-feature-list.json'));\n    51→});\n    52→\n    53→test('fixture-loader: loadFixture loads file content', () => {\n    54→  const content = loadFixture('plans/valid-feature-list.json');\n    55→  assert.ok(content.includes('$schema'));\n    56→  assert.ok(content.includes('TestApp'));\n    57→});\n    58→\n    59→test('fixture-loader: loadFixture throws for non-existent file', () => {\n    60→  assert.throws(\n    61→    () => loadFixture('non-existent-file.json'),\n    62→    /Fixture not found/\n    63→  );\n    64→});\n    65→\n    66→test('fixture-loader: loadJsonFixture parses JSON correctly', () => {\n    67→  const data = loadJsonFixture('plans/valid-feature-list.json');\n    68→  assert.equal(data.$schema, 'dev-pipeline-feature-list-v1');\n    69→  assert.equal(data.app_name, 'TestApp');\n    70→  assert.ok(Array.isArray(data.features));\n    71→});\n    72→\n    73→test('fixture-loader: loadJsonFixture throws for invalid JSON', () => {\n    74→  assert.throws(\n    75→    () => loadJsonFixture('plans/invalid-bad-json.json'),\n    76→    /Invalid JSON/\n    77→  );\n    78→});\n    79→\n    80→test('fixture-loader: fixtureExists returns true for existing fixture', () => {\n    81→  assert.equal(fixtureExists('plans/valid-feature-list.json'), true);\n    82→});\n    83→\n    84→test('fixture-loader: fixtureExists returns false for non-existing fixture', () => {\n    85→  assert.equal(fixtureExists('non-existent.json'), false);\n    86→});\n    87→\n    88→// ============================================================\n    89→// Mock Runner Tests\n    90→// ============================================================\n    91→\n    92→test('mock-runner: createMockRunner returns function', () => {\n    93→  const runner = createMockRunner();\n    94→  assert.equal(typeof runner, 'function');\n    95→});\n    96→\n    97→test('mock-runner: returns default response for unmocked action', async () => {\n    98→  const runner = createMockRunner();\n    99→  const result = await runner({ action: 'unknown' });\n   100→\n   101→  assert.equal(result.ok, true);\n   102→  assert.equal(result.normalizedStatus, 'success');\n   103→});\n   104→\n   105→test('mock-runner: returns configured response', async () => {\n   106→  const runner = createMockRunner({\n   107→    run: { ok: true, pid: 12345, runId: 'run-001' }\n   108→  });\n   109→\n   110→  const result = await runner({ action: 'run' });\n   111→  assert.equal(result.ok, true);\n   112→  assert.equal(result.pid, 12345);\n   113→  assert.equal(result.runId, 'run-001');\n   114→});\n   115→\n   116→test('mock-runner: supports response sequencing', async () => {\n   117→  const runner = createMockRunner({\n   118→    status: [\n   119→      { ok: true, isRunning: true },\n   120→      { ok: true, isRunning: false }\n   121→    ]\n   122→  });\n   123→\n   124→  const result1 = await runner({ action: 'status' });\n   125→  assert.equal(result1.isRunning, true);\n   126→\n   127→  const result2 = await runner({ action: 'status' });\n   128→  assert.equal(result2.isRunning, false);\n   129→});\n   130→\n   131→test('mock-runner: callLog tracks calls', async () => {\n   132→  const runner = createMockRunner();\n   133→  await runner({ action: 'run', targetId: 'F-001' });\n   134→  await runner({ action: 'status' });\n   135→\n   136→  const log = runner.getCallLog();\n   137→  assert.equal(log.length, 2);\n   138→  assert.equal(log[0].action, 'run');\n   139→  assert.equal(log[0].params.targetId, 'F-001');\n   140→});\n   141→\n   142→test('mock-runner: getCalls filters by action', async () => {\n   143→  const runner = createMockRunner();\n   144→  await runner({ action: 'run' });\n   145→  await runner({ action: 'status' });\n   146→  await runner({ action: 'run' });\n   147→\n   148→  const runCalls = runner.getCalls('run');\n   149→  assert.equal(runCalls.length, 2);\n   150→});\n   151→\n   152→test('mock-runner: addResponse adds new response', async () => {\n   153→  const runner = createMockRunner();\n   154→  runner.addResponse('run', { ok: true, pid: 999 });\n   155→\n   156→  const result = await runner({ action: 'run' });\n   157→  assert.equal(result.pid, 999);\n   158→});\n   159→\n   160→test('mock-runner: createStatefulMockRunner tracks state', async () => {\n   161→  const runner = createStatefulMockRunner();\n   162→  let state = runner.getState();\n   163→  assert.equal(state.isRunning, false);\n   164→\n   165→  await runner({ action: 'run' });\n   166→  state = runner.getState();\n   167→  assert.equal(state.isRunning, true);\n   168→\n   169→  await runner({ action: 'stop' });\n   170→  state = runner.getState();\n   171→  assert.equal(state.isRunning, false);\n   172→});\n   173→\n   174→test('mock-runner: createStatefulMockRunner prevents duplicate start', async () => {\n   175→  const runner = createStatefulMockRunner({ startRunning: true });\n   176→  const result = await runner({ action: 'run' });\n   177→\n   178→  assert.equal(result.ok, false);\n   179→  assert.equal(result.errorCode, 'ALREADY_RUNNING');\n   180→});\n   181→\n   182→// ============================================================\n   183→// Mock Telegram Tests\n   184→// ============================================================\n   185→\n   186→test('mock-telegram: createMockContext creates context', () => {\n   187→  const ctx = createMockContext();\n   188→  assert.ok(ctx.message);\n   189→  assert.ok(ctx.chat);\n   190→  assert.ok(ctx.from);\n   191→  assert.equal(typeof ctx.reply, 'function');\n   192→});\n   193→\n   194→test('mock-telegram: createMockContext applies overrides', () => {\n   195→  const ctx = createMockContext({\n   196→    message: { text: '/start' }\n   197→  });\n   198→\n   199→  assert.equal(ctx.message.text, '/start');\n   200→});\n   201→\n   202→test('mock-telegram: reply captures messages', async () => {\n   203→  const ctx = createMockContext();\n   204→  await ctx.reply('Hello');\n   205→  await ctx.reply('World');\n   206→\n   207→  const replies = ctx._getReplies();\n   208→  assert.equal(replies.length, 2);\n   209→  assert.equal(replies[0].text, 'Hello');\n   210→  assert.equal(replies[1].text, 'World');\n   211→});\n   212→\n   213→test('mock-telegram: _getLastReply returns last reply', async () => {\n   214→  const ctx = createMockContext();\n   215→  await ctx.reply('First');\n   216→  await ctx.reply('Last');\n   217→\n   218→  const last = ctx._getLastReply();\n   219→  assert.equal(last.text, 'Last');\n   220→});\n   221→\n   222→test('mock-telegram: createAdminContext sets admin permission', () => {\n   223→  const ctx = createAdminContext();\n   224→  assert.equal(ctx.state.permission, 'admin');\n   225→});\n   226→\n   227→test('mock-telegram: createOperatorContext sets operator permission', () => {\n   228→  const ctx = createOperatorContext();\n   229→  assert.equal(ctx.state.permission, 'operator');\n   230→});\n   231→\n   232→test('mock-telegram: createViewerContext sets viewer permission', () => {\n   233→  const ctx = createViewerContext();\n   234→  assert.equal(ctx.state.permission, 'viewer');\n   235→});\n   236→\n   237→test('mock-telegram: createDocumentContext creates document message', () => {\n   238→  const ctx = createDocumentContext({\n   239→    file_name: 'test-plan.json',\n   240→    file_size: 2048\n   241→  });\n   242→\n   243→  assert.ok(ctx.message.document);\n   244→  assert.equal(ctx.message.document.file_name, 'test-plan.json');\n   245→  assert.equal(ctx.message.document.file_size, 2048);\n   246→});\n   247→\n   248→test('mock-telegram: createCommandContext creates command message', () => {\n   249→  const ctx = createCommandContext('/pipeline run --type=feature');\n   250→  assert.equal(ctx.message.text, '/pipeline run --type=feature');\n   251→});\n   252→\n   253→// ============================================================\n   254→// Test State Tests\n   255→// ============================================================\n   256→\n   257→test('test-state: createTestStateDir creates directory', async () => {\n   258→  const { path, cleanup } = await createTestStateDir();\n   259→  assert.ok(path);\n   260→\n   261→  await cleanup();\n   262→});\n   263→\n   264→test('test-state: createTestPipelineDirs creates full structure', async () => {\n   265→  const { tempDir, stateDir, bugfixStateDir, plansDir, cleanup } = await createTestPipelineDirs();\n   266→\n   267→  assert.ok(tempDir);\n   268→  assert.ok(stateDir);\n   269→  assert.ok(bugfixStateDir);\n   270→  assert.ok(plansDir);\n   271→\n   272→  await cleanup();\n   273→});\n   274→\n   275→test('test-state: writeTestState and readTestState work together', async () => {\n   276→  const { path, cleanup } = await createTestStateDir();\n   277→\n   278→  const testData = { foo: 'bar', nested: { value: 42 } };\n   279→  const filePath = join(path, 'test.json');\n   280→\n   281→  await writeTestState(filePath, testData);\n   282→  const loaded = await readTestState(filePath);\n   283→\n   284→  assert.deepEqual(loaded, testData);\n   285→\n   286→  await cleanup();\n   287→});\n   288→\n   289→test('test-state: readTestState returns null for non-existent file', async () => {\n   290→  const result = await readTestState('/non/existent/path.json');\n   291→  assert.equal(result, null);\n   292→});\n   293→\n   294→test('test-state: createTestPlan creates plan file', async () => {\n   295→  const { plansDir, cleanup } = await createTestPipelineDirs();\n   296→\n   297→  const planContent = {\n   298→    $schema: 'dev-pipeline-feature-list-v1',\n   299→    app_name: 'TestApp',\n   300→    features: []\n   301→  };\n   302→\n   303→  const planPath = await createTestPlan(plansDir, 'feature-list', planContent);\n   304→  const loaded = await readTestState(planPath);\n   305→\n   306→  assert.equal(loaded.app_name, 'TestApp');\n   307→\n   308→  await cleanup();\n   309→});\n   310→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6c8ebc62-648e-4d09-8200-69d30faee4f6","uuid":"040f6053-2ad7-4e95-a0c6-f5cf5f6b2c66","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/tests/helpers/helpers.test.js","content":"/**\n * Tests for test helpers\n * F-007: Test and Validation Suite\n *\n * Verifies that all test helper modules work correctly.\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport { join } from 'node:path';\n\n// Import all helpers at module level\nimport {\n  getFixturePath,\n  loadFixture,\n  loadJsonFixture,\n  fixtureExists\n} from './fixture-loader.js';\n\nimport {\n  createMockRunner,\n  createStatefulMockRunner\n} from './mock-runner.js';\n\nimport {\n  createMockContext,\n  createAdminContext,\n  createOperatorContext,\n  createViewerContext,\n  createDocumentContext,\n  createCommandContext\n} from './mock-telegram.js';\n\nimport {\n  createTestStateDir,\n  createTestPipelineDirs,\n  writeTestState,\n  readTestState,\n  createTestPlan\n} from './test-state.js';\n\n// ============================================================\n// Fixture Loader Tests\n// ============================================================\n\ntest('fixture-loader: getFixturePath returns correct path', () => {\n  const path = getFixturePath('plans/valid-feature-list.json');\n  assert.ok(path.includes('fixtures'));\n  assert.ok(path.includes('plans'));\n  assert.ok(path.includes('valid-feature-list.json'));\n});\n\ntest('fixture-loader: loadFixture loads file content', () => {\n  const content = loadFixture('plans/valid-feature-list.json');\n  assert.ok(content.includes('$schema'));\n  assert.ok(content.includes('TestApp'));\n});\n\ntest('fixture-loader: loadFixture throws for non-existent file', () => {\n  assert.throws(\n    () => loadFixture('non-existent-file.json'),\n    /Fixture not found/\n  );\n});\n\ntest('fixture-loader: loadJsonFixture parses JSON correctly', () => {\n  const data = loadJsonFixture('plans/valid-feature-list.json');\n  assert.equal(data.$schema, 'dev-pipeline-feature-list-v1');\n  assert.equal(data.app_name, 'TestApp');\n  assert.ok(Array.isArray(data.features));\n});\n\ntest('fixture-loader: loadJsonFixture throws for invalid JSON', () => {\n  assert.throws(\n    () => loadJsonFixture('plans/invalid-bad-json.json'),\n    /Invalid JSON/\n  );\n});\n\ntest('fixture-loader: fixtureExists returns true for existing fixture', () => {\n  assert.equal(fixtureExists('plans/valid-feature-list.json'), true);\n});\n\ntest('fixture-loader: fixtureExists returns false for non-existing fixture', () => {\n  assert.equal(fixtureExists('non-existent.json'), false);\n});\n\n// ============================================================\n// Mock Runner Tests\n// ============================================================\n\ntest('mock-runner: createMockRunner returns function', () => {\n  const runner = createMockRunner();\n  assert.equal(typeof runner, 'function');\n});\n\ntest('mock-runner: returns default response for unmocked action', async () => {\n  const runner = createMockRunner();\n  const result = await runner({ action: 'unknown' });\n\n  assert.equal(result.ok, true);\n  assert.equal(result.normalizedStatus, 'success');\n});\n\ntest('mock-runner: returns configured response', async () => {\n  const runner = createMockRunner({\n    run: { ok: true, pid: 12345, runId: 'run-001' }\n  });\n\n  const result = await runner({ action: 'run' });\n  assert.equal(result.ok, true);\n  assert.equal(result.pid, 12345);\n  assert.equal(result.runId, 'run-001');\n});\n\ntest('mock-runner: supports response sequencing', async () => {\n  const runner = createMockRunner({\n    status: [\n      { ok: true, isRunning: true },\n      { ok: true, isRunning: false }\n    ]\n  });\n\n  const result1 = await runner({ action: 'status' });\n  assert.equal(result1.isRunning, true);\n\n  const result2 = await runner({ action: 'status' });\n  assert.equal(result2.isRunning, false);\n});\n\ntest('mock-runner: callLog tracks calls', async () => {\n  const runner = createMockRunner();\n  await runner({ action: 'run', targetId: 'F-001' });\n  await runner({ action: 'status' });\n\n  const log = runner.getCallLog();\n  assert.equal(log.length, 2);\n  assert.equal(log[0].action, 'run');\n  assert.equal(log[0].params.targetId, 'F-001');\n});\n\ntest('mock-runner: getCalls filters by action', async () => {\n  const runner = createMockRunner();\n  await runner({ action: 'run' });\n  await runner({ action: 'status' });\n  await runner({ action: 'run' });\n\n  const runCalls = runner.getCalls('run');\n  assert.equal(runCalls.length, 2);\n});\n\ntest('mock-runner: addResponse adds new response', async () => {\n  const runner = createMockRunner();\n  runner.addResponse('run', { ok: true, pid: 999 });\n\n  const result = await runner({ action: 'run' });\n  assert.equal(result.pid, 999);\n});\n\ntest('mock-runner: createStatefulMockRunner tracks state', async () => {\n  const runner = createStatefulMockRunner();\n  let state = runner.getState();\n  assert.equal(state.isRunning, false);\n\n  await runner({ action: 'run' });\n  state = runner.getState();\n  assert.equal(state.isRunning, true);\n\n  await runner({ action: 'stop' });\n  state = runner.getState();\n  assert.equal(state.isRunning, false);\n});\n\ntest('mock-runner: createStatefulMockRunner prevents duplicate start', async () => {\n  const runner = createStatefulMockRunner({ startRunning: true });\n  const result = await runner({ action: 'run' });\n\n  assert.equal(result.ok, false);\n  assert.equal(result.errorCode, 'ALREADY_RUNNING');\n});\n\n// ============================================================\n// Mock Telegram Tests\n// ============================================================\n\ntest('mock-telegram: createMockContext creates context', () => {\n  const ctx = createMockContext();\n  assert.ok(ctx.message);\n  assert.ok(ctx.chat);\n  assert.ok(ctx.from);\n  assert.equal(typeof ctx.reply, 'function');\n});\n\ntest('mock-telegram: createMockContext applies overrides', () => {\n  const ctx = createMockContext({\n    message: { text: '/start' }\n  });\n\n  assert.equal(ctx.message.text, '/start');\n});\n\ntest('mock-telegram: reply captures messages', async () => {\n  const ctx = createMockContext();\n  await ctx.reply('Hello');\n  await ctx.reply('World');\n\n  const replies = ctx._getReplies();\n  assert.equal(replies.length, 2);\n  assert.equal(replies[0].text, 'Hello');\n  assert.equal(replies[1].text, 'World');\n});\n\ntest('mock-telegram: _getLastReply returns last reply', async () => {\n  const ctx = createMockContext();\n  await ctx.reply('First');\n  await ctx.reply('Last');\n\n  const last = ctx._getLastReply();\n  assert.equal(last.text, 'Last');\n});\n\ntest('mock-telegram: createAdminContext sets admin permission', () => {\n  const ctx = createAdminContext();\n  assert.equal(ctx.state.permission, 'admin');\n});\n\ntest('mock-telegram: createOperatorContext sets operator permission', () => {\n  const ctx = createOperatorContext();\n  assert.equal(ctx.state.permission, 'operator');\n});\n\ntest('mock-telegram: createViewerContext sets viewer permission', () => {\n  const ctx = createViewerContext();\n  assert.equal(ctx.state.permission, 'viewer');\n});\n\ntest('mock-telegram: createDocumentContext creates document message', () => {\n  const ctx = createDocumentContext({\n    file_name: 'test-plan.json',\n    file_size: 2048\n  });\n\n  assert.ok(ctx.message.document);\n  assert.equal(ctx.message.document.file_name, 'test-plan.json');\n  assert.equal(ctx.message.document.file_size, 2048);\n});\n\ntest('mock-telegram: createCommandContext creates command message', () => {\n  const ctx = createCommandContext('/pipeline run --type=feature');\n  assert.equal(ctx.message.text, '/pipeline run --type=feature');\n});\n\n// ============================================================\n// Test State Tests\n// ============================================================\n\ntest('test-state: createTestStateDir creates directory', async () => {\n  const { path, cleanup } = await createTestStateDir();\n  assert.ok(path);\n\n  await cleanup();\n});\n\ntest('test-state: createTestPipelineDirs creates full structure', async () => {\n  const { tempDir, stateDir, bugfixStateDir, plansDir, cleanup } = await createTestPipelineDirs();\n\n  assert.ok(tempDir);\n  assert.ok(stateDir);\n  assert.ok(bugfixStateDir);\n  assert.ok(plansDir);\n\n  await cleanup();\n});\n\ntest('test-state: writeTestState and readTestState work together', async () => {\n  const { path, cleanup } = await createTestStateDir();\n\n  const testData = { foo: 'bar', nested: { value: 42 } };\n  const filePath = join(path, 'test.json');\n\n  await writeTestState(filePath, testData);\n  const loaded = await readTestState(filePath);\n\n  assert.deepEqual(loaded, testData);\n\n  await cleanup();\n});\n\ntest('test-state: readTestState returns null for non-existent file', async () => {\n  const result = await readTestState('/non/existent/path.json');\n  assert.equal(result, null);\n});\n\ntest('test-state: createTestPlan creates plan file', async () => {\n  const { plansDir, cleanup } = await createTestPipelineDirs();\n\n  const planContent = {\n    $schema: 'dev-pipeline-feature-list-v1',\n    app_name: 'TestApp',\n    features: []\n  };\n\n  const planPath = await createTestPlan(plansDir, 'feature-list', planContent);\n  const loaded = await readTestState(planPath);\n\n  assert.equal(loaded.app_name, 'TestApp');\n\n  await cleanup();\n});\n","numLines":310,"startLine":1,"totalLines":310}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_4c2f2b1250e440bdb412c42f","type":"tool_result","content":"     1→import { Telegraf } from 'telegraf';\n     2→import { createReadStream } from 'node:fs';\n     3→import { access, stat } from 'node:fs/promises';\n     4→import os from 'node:os';\n     5→import path from 'node:path';\n     6→import { config } from '../config.js';\n     7→import { logger } from '../utils/logger.js';\n     8→import { isAllowedUser } from '../security/guard.js';\n     9→import { chatWithSession, resetSession } from '../services/chat-service.js';\n    10→import { executeAiCli, interruptAiCli, isAiCliRunning } from '../services/ai-cli-service.js';\n    11→import { captureScreenshot } from '../services/screenshot-service.js';\n    12→import { executeCommand, confirmHighRiskCommand } from '../services/command-executor-service.js';\n    13→import { createPlanIngestionService } from '../services/plan-ingestion-service.js';\n    14→import { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n    15→import { registerCommand } from './commands/index.js';\n    16→import { routeCommand } from './commands/index.js';\n    17→import { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\n    18→import { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\n    19→import { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\n    20→import { statusMeta, handleStatus } from './commands/handlers/status.js';\n    21→import { logsMeta, handleLogs } from './commands/handlers/logs.js';\n    22→import { stopMeta, handleStop } from './commands/handlers/stop.js';\n    23→import { planMeta, handlePlan } from './commands/handlers/plan.js';\n    24→import { auditMeta, handleAudit } from './commands/handlers/audit.js';\n    25→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n    26→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n    27→// F-009: New command handlers\n    28→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n    29→import { moreMeta, handleMore } from './commands/handlers/more.js';\n    30→// F-010: File Manager command handlers\n    31→import { lsMeta, handleLs } from './commands/handlers/ls.js';\n    32→import { treeMeta, handleTree } from './commands/handlers/tree.js';\n    33→import { catMeta, handleCat } from './commands/handlers/cat.js';\n    34→import { headMeta, handleHead } from './commands/handlers/head.js';\n    35→import { tailMeta, handleTail } from './commands/handlers/tail.js';\n    36→import { findMeta, handleFind } from './commands/handlers/find.js';\n    37→import { uploadMeta, handleUpload } from './commands/handlers/upload.js';\n    38→import { downloadMeta, handleDownload } from './commands/handlers/download.js';\n    39→// F-012: System Monitor command handlers\n    40→import { sysinfoMeta, handleSysinfo } from './commands/handlers/sysinfo.js';\n    41→import { psMeta, handlePs } from './commands/handlers/ps.js';\n    42→import { killMeta, handleKill } from './commands/handlers/kill.js';\n    43→import { monitorMeta, handleMonitor } from './commands/handlers/monitor.js';\n    44→// F-013: Session and Context Manager command handlers\n    45→import { historyMeta, handleHistory } from './commands/handlers/history.js';\n    46→import { aliasMeta, handleAlias } from './commands/handlers/alias.js';\n    47→import { sessionsMeta, handleSessions } from './commands/handlers/sessions.js';\n    48→// F-014: Notification and Scheduled Tasks command handlers\n    49→import { cronMeta, handleCron } from './commands/handlers/cron.js';\n    50→import { jobsMeta, handleJobs } from './commands/handlers/jobs.js';\n    51→import { watchMeta, handleWatch } from './commands/handlers/watch.js';\n    52→import { generateHelp } from './commands/help.js';\n    53→import { sessionStore } from '../services/session-store.js';\n    54→import { sessionContextService } from '../services/session-context-service.js';\n    55→import { aliasStore } from '../services/alias-store.js';\n    56→import { scheduledTaskService } from '../services/scheduled-task-service.js';\n    57→import { fileWatcherService } from '../services/file-watcher-service.js';\n    58→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n    59→import { escapeMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n    60→\n    61→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n    62→const STREAM_MIN_CHARS = 220;\n    63→const STREAM_FLUSH_INTERVAL_MS = 1200;\n    64→const TYPING_INTERVAL_MS = 3500;\n    65→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n    66→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n    67→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n    68→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n    69→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n    70→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n    71→const TMP_DIR = path.resolve(os.tmpdir());\n    72→const HOME_DIR = path.resolve(os.homedir());\n    73→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n    74→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n    75→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n    76→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n    77→\n    78→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n    79→  const normalized = configuredDirs\n    80→    .map((dir) => String(dir ?? '').trim())\n    81→    .filter(Boolean)\n    82→    .map((dir) => path.resolve(dir));\n    83→\n    84→  if (normalized.length > 0) {\n    85→    return [...new Set(normalized)];\n    86→  }\n    87→\n    88→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n    89→}\n    90→\n    91→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n    92→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n    93→\n    94→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n    95→  const chunks = [];\n    96→  for (let i = 0; i < text.length; i += chunkSize) {\n    97→    chunks.push(text.slice(i, i + chunkSize));\n    98→  }\n    99→  return chunks;\n   100→}\n   101→\n   102→function truncate(text, maxLen) {\n   103→  if (!text) return '';\n   104→  if (text.length <= maxLen) return text;\n   105→  return text.substring(0, maxLen) + '...';\n   106→}\n   107→\n   108→function sanitizeMarkerPath(raw) {\n   109→  return String(raw ?? '')\n   110→    .trim()\n   111→    .replace(/^['\"`]+/, '')\n   112→    .replace(/['\"`]+$/, '');\n   113→}\n   114→\n   115→function extractFileMarkers(text = '') {\n   116→  const fileRefs = [];\n   117→\n   118→  const withSendFileRemoved = text.replace(\n   119→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n   120→    (_full, rawRef) => {\n   121→      const ref = sanitizeMarkerPath(rawRef);\n   122→      if (ref) {\n   123→        fileRefs.push(ref);\n   124→      }\n   125→      return '\\n';\n   126→    }\n   127→  );\n   128→\n   129→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n   130→    const ref = sanitizeMarkerPath(rawRef);\n   131→    if (ref) {\n   132→      fileRefs.push(ref);\n   133→    }\n   134→    return '';\n   135→  });\n   136→\n   137→  const withBacktickPathRemoved = withImageRemoved.replace(\n   138→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n   139→    (_full, rawRef) => {\n   140→      const ref = sanitizeMarkerPath(rawRef);\n   141→      if (ref) {\n   142→        fileRefs.push(ref);\n   143→      }\n   144→      return '';\n   145→    }\n   146→  );\n   147→\n   148→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n   149→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n   150→    (_full, rawRef) => {\n   151→      const ref = sanitizeMarkerPath(rawRef);\n   152→      if (ref) {\n   153→        fileRefs.push(ref);\n   154→      }\n   155→      return '';\n   156→    }\n   157→  );\n   158→\n   159→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n   160→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n   161→    (_full, rawRef) => {\n   162→      const ref = sanitizeMarkerPath(rawRef);\n   163→      if (ref) {\n   164→        fileRefs.push(ref);\n   165→      }\n   166→      return '\\n';\n   167→    }\n   168→  );\n   169→\n   170→  return {\n   171→    fileRefs: [...new Set(fileRefs)],\n   172→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n   173→  };\n   174→}\n   175→\n   176→function isPathWithinRoot(targetPath, rootPath) {\n   177→  const relative = path.relative(rootPath, targetPath);\n   178→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n   179→}\n   180→\n   181→function isAllowedFilePath(filePath) {\n   182→  const resolved = path.resolve(filePath);\n   183→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n   184→}\n   185→\n   186→function buildFileCandidates(normalizedPath) {\n   187→  if (path.isAbsolute(normalizedPath)) {\n   188→    return [normalizedPath];\n   189→  }\n   190→\n   191→  const baseName = path.basename(normalizedPath);\n   192→  const candidates = [\n   193→    path.resolve(process.cwd(), normalizedPath),\n   194→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n   195→  ];\n   196→\n   197→  return [...new Set(candidates)];\n   198→}\n   199→\n   200→async function resolveLocalFilePath(fileRef) {\n   201→  const normalized = sanitizeMarkerPath(fileRef);\n   202→  if (!normalized) {\n   203→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n   204→  }\n   205→\n   206→  if (!path.isAbsolute(normalized)) {\n   207→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n   208→  }\n   209→\n   210→  const candidates = buildFileCandidates(normalized);\n   211→\n   212→  for (const candidate of candidates) {\n   213→    try {\n   214→      await access(candidate);\n   215→      return { filePath: candidate, triedPaths: candidates };\n   216→    } catch {\n   217→      // ignore\n   218→    }\n   219→  }\n   220→\n   221→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n   222→}\n   223→\n   224→async function validateFileForTelegram(filePath) {\n   225→  const resolvedPath = path.resolve(filePath);\n   226→  if (!isAllowedFilePath(resolvedPath)) {\n   227→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n   228→  }\n   229→\n   230→  const ext = path.extname(resolvedPath).toLowerCase();\n   231→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n   232→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n   233→  }\n   234→\n   235→  const fileStat = await stat(resolvedPath);\n   236→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n   237→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n   238→\n   239→  if (fileStat.size > maxSize) {\n   240→    return {\n   241→      ok: false,\n   242→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n   243→    };\n   244→  }\n   245→\n   246→  return { ok: true, isPhoto, resolvedPath };\n   247→}\n   248→\n   249→function isTimeoutLikeError(message = '') {\n   250→  const normalized = String(message).toLowerCase();\n   251→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n   252→}\n   253→\n   254→function sleep(ms) {\n   255→  return new Promise((resolve) => setTimeout(resolve, ms));\n   256→}\n   257→\n   258→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n   259→  if (isPhoto) {\n   260→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n   261→    return;\n   262→  }\n   263→\n   264→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n   265→}\n   266→\n   267→async function replyFiles(ctx, fileRefs = []) {\n   268→  const results = [];\n   269→\n   270→  for (const fileRef of fileRefs) {\n   271→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n   272→    if (!filePath) {\n   273→      const reason = rejectReason || 'not_found';\n   274→      results.push({ fileRef, sent: false, reason, triedPaths });\n   275→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n   276→      continue;\n   277→    }\n   278→\n   279→    try {\n   280→      const validation = await validateFileForTelegram(filePath);\n   281→      if (!validation.ok) {\n   282→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n   283→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n   284→        continue;\n   285→      }\n   286→\n   287→      const actualPath = validation.resolvedPath;\n   288→      let sent = false;\n   289→      let lastReason = '';\n   290→\n   291→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n   292→        try {\n   293→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n   294→          sent = true;\n   295→          logger.info(\n   296→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n   297→            'Telegram file sent'\n   298→          );\n   299→          break;\n   300→        } catch (error) {\n   301→          lastReason = error instanceof Error ? error.message : String(error);\n   302→          logger.warn(\n   303→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n   304→            'Telegram file send attempt failed'\n   305→          );\n   306→\n   307→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n   308→            await sleep(600);\n   309→            continue;\n   310→          }\n   311→\n   312→          break;\n   313→        }\n   314→      }\n   315→\n   316→      if (!sent) {\n   317→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n   318→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n   319→        continue;\n   320→      }\n   321→\n   322→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n   323→    } catch (error) {\n   324→      const reason = error instanceof Error ? error.message : String(error);\n   325→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n   326→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n   327→    }\n   328→  }\n   329→\n   330→  return results;\n   331→}\n   332→\n   333→async function safeReply(ctx, text) {\n   334→  try {\n   335→    await ctx.reply(text);\n   336→    return true;\n   337→  } catch (error) {\n   338→    const reason = error instanceof Error ? error.message : String(error);\n   339→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n   340→    return false;\n   341→  }\n   342→}\n   343→\n   344→async function replyLargeText(ctx, text) {\n   345→  const chunks = splitMessage(text);\n   346→  for (const chunk of chunks) {\n   347→    const ok = await safeReply(ctx, chunk);\n   348→    if (!ok) {\n   349→      break;\n   350→    }\n   351→  }\n   352→}\n   353→\n   354→async function safeEditMessageText(ctx, messageId, text) {\n   355→  const nextText = text && text.trim() ? text : ' ';\n   356→\n   357→  try {\n   358→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n   359→  } catch (error) {\n   360→    const message = error instanceof Error ? error.message : String(error);\n   361→    if (message.includes('message is not modified')) {\n   362→      return;\n   363→    }\n   364→    throw error;\n   365→  }\n   366→}\n   367→\n   368→function createEditableStreamPublisher(ctx) {\n   369→  let fullText = '';\n   370→  let renderedText = '';\n   371→  let pendingChars = 0;\n   372→  let lastFlushAt = 0;\n   373→  let flushChain = Promise.resolve();\n   374→  let activeMessage = null;\n   375→  let activeSegmentIndex = 0;\n   376→  let publishedMessageCount = 0;\n   377→\n   378→  async function ensureActiveMessage() {\n   379→    if (activeMessage) {\n   380→      return;\n   381→    }\n   382→    activeMessage = await ctx.reply('处理中...');\n   383→    activeSegmentIndex = 0;\n   384→    publishedMessageCount += 1;\n   385→  }\n   386→\n   387→  async function render(force = false) {\n   388→    const now = Date.now();\n   389→\n   390→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n   391→      return;\n   392→    }\n   393→\n   394→    if (fullText === renderedText) {\n   395→      pendingChars = 0;\n   396→      return;\n   397→    }\n   398→\n   399→    await ensureActiveMessage();\n   400→\n   401→    const segments = splitMessage(fullText);\n   402→    const targetLastIndex = Math.max(segments.length - 1, 0);\n   403→\n   404→    while (activeSegmentIndex < targetLastIndex) {\n   405→      const text = segments[activeSegmentIndex] ?? ' ';\n   406→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n   407→\n   408→      activeMessage = await ctx.reply('继续输出中...');\n   409→      activeSegmentIndex += 1;\n   410→      publishedMessageCount += 1;\n   411→    }\n   412→\n   413→    const activeText = segments[targetLastIndex] ?? ' ';\n   414→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n   415→\n   416→    renderedText = fullText;\n   417→    pendingChars = 0;\n   418→    lastFlushAt = now;\n   419→  }\n   420→\n   421→  function enqueueRender(force = false) {\n   422→    flushChain = flushChain.then(() => render(force));\n   423→  }\n   424→\n   425→  return {\n   426→    push(text) {\n   427→      const appendText = text ?? '';\n   428→      if (!appendText) {\n   429→        return;\n   430→      }\n   431→      fullText += appendText;\n   432→      pendingChars += appendText.length;\n   433→      enqueueRender(false);\n   434→    },\n   435→    setFinalText(text) {\n   436→      fullText = text ?? '';\n   437→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n   438→      enqueueRender(true);\n   439→    },\n   440→    async finish() {\n   441→      enqueueRender(true);\n   442→      await flushChain;\n   443→      return {\n   444→        outputLength: renderedText.length,\n   445→        messageCount: publishedMessageCount\n   446→      };\n   447→    }\n   448→  };\n   449→}\n   450→\n   451→function buildSessionId(ctx) {\n   452→  return String(ctx.chat.id);\n   453→}\n   454→\n   455→function ensureAllowed(ctx) {\n   456→  const userId = ctx.from?.id;\n   457→  if (!isAllowedUser(userId)) {\n   458→    throw new Error('当前账号未被授权使用该机器人。');\n   459→  }\n   460→}\n   461→\n   462→/**\n   463→ * Register all pipeline-related commands.\n   464→ */\n   465→function registerPipelineCommands() {\n   466→  registerCommand(pipelineMeta, handlePipeline);\n   467→  registerCommand(bugfixMeta, handleBugfix);\n   468→  registerCommand(plannerMeta, handlePlanner);\n   469→  registerCommand(statusMeta, handleStatus);\n   470→  registerCommand(logsMeta, handleLogs);\n   471→  registerCommand(stopMeta, handleStop);\n   472→  registerCommand(planMeta, handlePlan);\n   473→  registerCommand(auditMeta, handleAudit);\n   474→  registerCommand(commitMeta, handleCommit);\n   475→  registerCommand(commitsMeta, handleCommits);\n   476→  // F-009: New commands\n   477→  registerCommand(cdMeta, handleCd);\n   478→  registerCommand(moreMeta, handleMore);\n   479→  // F-010: File Manager commands\n   480→  registerCommand(lsMeta, handleLs);\n   481→  registerCommand(treeMeta, handleTree);\n   482→  registerCommand(catMeta, handleCat);\n   483→  registerCommand(headMeta, handleHead);\n   484→  registerCommand(tailMeta, handleTail);\n   485→  registerCommand(findMeta, handleFind);\n   486→  registerCommand(uploadMeta, handleUpload);\n   487→  registerCommand(downloadMeta, handleDownload);\n   488→  // F-012: System Monitor commands\n   489→  registerCommand(sysinfoMeta, handleSysinfo);\n   490→  registerCommand(psMeta, handlePs);\n   491→  registerCommand(killMeta, handleKill);\n   492→  registerCommand(monitorMeta, handleMonitor);\n   493→  // F-013: Session and Context Manager commands\n   494→  registerCommand(historyMeta, handleHistory);\n   495→  registerCommand(aliasMeta, handleAlias);\n   496→  registerCommand(sessionsMeta, handleSessions);\n   497→  // F-014: Notification and Scheduled Tasks commands\n   498→  registerCommand(cronMeta, handleCron);\n   499→  registerCommand(jobsMeta, handleJobs);\n   500→  registerCommand(watchMeta, handleWatch);\n   501→}\n   502→\n   503→export async function createTelegramBot() {\n   504→  const bot = new Telegraf(config.telegramBotToken, {\n   505→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n   506→  });\n   507→\n   508→  // F-013: Initialize session context service\n   509→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n   510→  await aliasStore.initAliasStore({ persistencePath: config.aliasPersistencePath });\n   511→\n   512→  // F-013: Restore sessions from disk\n   513→  await sessionContextService.restoreSessions();\n   514→\n   515→  // F-013: Set up notification callback for session timeout\n   516→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n   517→    try {\n   518→      // Extract chat ID from session key (format: telegram:123456789)\n   519→      const chatId = sessionKey.replace('telegram:', '');\n   520→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n   521→    } catch (error) {\n   522→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n   523→    }\n   524→  });\n   525→\n   526→  // F-013: Start timeout watcher\n   527→  sessionContextService.startTimeoutWatcher();\n   528→\n   529→  // F-014: Initialize scheduled task service\n   530→  scheduledTaskService.initScheduledTaskService({\n   531→    dataDir: config.systemMonitorDataDir,\n   532→    tasksFile: config.scheduledTasksPath,\n   533→    maxTasks: config.maxScheduledTasks\n   534→  });\n   535→\n   536→  // F-014: Set up task execution callback\n   537→  scheduledTaskService.setExecuteCallback(async ({ command, cwd, sessionId, userId }) => {\n   538→    try {\n   539→      return await executeCommand({\n   540→        command,\n   541→        cwd,\n   542→        sessionId,\n   543→        userId,\n   544→        skipConfirmation: true // Skip confirmation for scheduled tasks\n   545→      });\n   546→    } catch (error) {\n   547→      return {\n   548→        stdout: '',\n   549→        stderr: error.message,\n   550→        exitCode: 1,\n   551→        timedOut: false\n   552→      };\n   553→    }\n   554→  });\n   555→\n   556→  // F-014: Set up task notification callback\n   557→  scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n   558→    try {\n   559→      const result = task.lastResult || {};\n   560→      const lines = [\n   561→        '⏰ *定时任务完成*',\n   562→        '',\n   563→        `任务ID: \\`${task.id.substring(0, 8)}...\\``,\n   564→        `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n   565→        `执行时间: ${new Date(result.executedAt || Date.now()).toLocaleString()}`,\n   566→        '',\n   567→        `exitCode: ${result.exitCode}`,\n   568→        result.stdout ? `stdout:\\n${truncate(result.stdout, 500)}` : 'stdout: (empty)',\n   569→        result.stderr ? `stderr:\\n${escapeMarkdownV2(truncate(result.stderr, 500))}` : 'stderr: (empty)'\n   570→      ];\n   571→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n   572→    } catch (error) {\n   573→      logger.warn({ taskId: task.id, error: error.message }, 'Failed to send task notification');\n   574→    }\n   575→  });\n   576→\n   577→  // F-014: Load and start scheduled tasks\n   578→  await scheduledTaskService.loadTasks();\n   579→  scheduledTaskService.startScheduler();\n   580→\n   581→  // F-014: Initialize file watcher service\n   582→  fileWatcherService.initFileWatcherService({\n   583→    dataDir: config.systemMonitorDataDir,\n   584→    watchersFile: config.fileWatchersPath,\n   585→    maxWatchers: config.maxFileWatchers,\n   586→    debounceMs: config.taskDebounceMs,\n   587→    allowedRoots: config.telegramFileAllowedRoots.length > 0\n   588→      ? config.telegramFileAllowedRoots\n   589→      : [process.cwd()]\n   590→  });\n   591→\n   592→  // F-014: Set up file watcher notification callback\n   593→  fileWatcherService.setNotificationCallback(async (chatId, watcher) => {\n   594→    try {\n   595→      const lines = [\n   596→        '📁 *文件变更检测*',\n   597→        '',\n   598→        `路径: \\`${escapeMarkdownV2(watcher.path)}\\``,\n   599→        `事件: ${watcher.eventType}`,\n   600→        `文件: ${watcher.filename || '(未知)'}`,\n   601→        `时间: ${new Date().toLocaleString()}`\n   602→      ];\n   603→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n   604→    } catch (error) {\n   605→      logger.warn({ watcherId: watcher.id, error: error.message }, 'Failed to send file watcher notification');\n   606→    }\n   607→  });\n   608→\n   609→  // F-014: Restore file watchers\n   610→  await fileWatcherService.restoreWatches();\n   611→\n   612→  // Register pipeline commands\n   613→  registerPipelineCommands();\n   614→\n   615→  bot.catch((error, ctx) => {\n   616→    const message = error instanceof Error ? error.message : String(error);\n   617→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n   618→  });\n   619→\n   620→  bot.start(async (ctx) => {\n   621→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n   622→  });\n   623→\n   624→  bot.help(async (ctx) => {\n   625→    const helpText = generateHelp();\n   626→    await ctx.reply(helpText);\n   627→  });\n   628→\n   629→  bot.command('reset', async (ctx) => {\n   630→    try {\n   631→      ensureAllowed(ctx);\n   632→      const sessionId = buildSessionId(ctx);\n   633→\n   634→      // F-011: Interrupt any running AI CLI task\n   635→      if (isAiCliRunning(sessionId)) {\n   636→        interruptAiCli(sessionId);\n   637→      }\n   638→\n   639→      resetSession({ channel: 'telegram', sessionId });\n   640→      await ctx.reply('已清空当前会话上下文。');\n   641→    } catch (error) {\n   642→      await ctx.reply(error instanceof Error ? error.message : String(error));\n   643→    }\n   644→  });\n   645→\n   646→  bot.command('screenshot', async (ctx) => {\n   647→    try {\n   648→      ensureAllowed(ctx);\n   649→      await ctx.reply('正在获取截图。');\n   650→      const { buffer } = await captureScreenshot();\n   651→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n   652→    } catch (error) {\n   653→      const message = error instanceof Error ? error.message : String(error);\n   654→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n   655→      await ctx.reply(`截图失败：${message}`);\n   656→    }\n   657→  });\n   658→\n   659→  bot.command('exec', async (ctx) => {\n   660→    try {\n   661→      ensureAllowed(ctx);\n   662→      const payload = ctx.message.text.replace('/exec', '').trim();\n   663→      if (!payload) {\n   664→        await ctx.reply('请提供命令，例如 /exec pwd');\n   665→        return;\n   666→      }\n   667→\n   668→      const sessionId = buildSessionId(ctx);\n   669→      const userId = ctx.from?.id;\n   670→\n   671→      await ctx.reply('正在执行命令...');\n   672→      const result = await executeCommand({\n   673→        command: payload,\n   674→        sessionId,\n   675→        userId\n   676→      });\n   677→\n   678→      // Handle confirmation required\n   679→      if (result.needsConfirmation) {\n   680→        await ctx.reply(result.confirmationMessage);\n   681→        return;\n   682→      }\n   683→\n   684→      // Send output\n   685→      await replyLargeText(ctx, result.output);\n   686→\n   687→      // Indicate if more pages available\n   688→      if (result.hasMorePages) {\n   689→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n   690→      }\n   691→    } catch (error) {\n   692→      const message = error instanceof Error ? error.message : String(error);\n   693→      logger.error({ err: message }, 'Failed to exec command in telegram');\n   694→      await ctx.reply(`执行失败：${message}`);\n   695→    }\n   696→  });\n   697→\n   698→  // F-009: /cd command handler\n   699→  bot.command('cd', async (ctx) => {\n   700→    try {\n   701→      ensureAllowed(ctx);\n   702→      const payload = ctx.message.text.replace('/cd', '').trim();\n   703→      const sessionId = buildSessionId(ctx);\n   704→\n   705→      await handleCd({\n   706→        ctx,\n   707→        reply: (msg) => ctx.reply(msg),\n   708→        params: {},\n   709→        userId: ctx.from?.id,\n   710→        sessionId,\n   711→        args: payload ? [payload] : []\n   712→      });\n   713→    } catch (error) {\n   714→      const message = error instanceof Error ? error.message : String(error);\n   715→      logger.error({ err: message }, 'Failed to cd in telegram');\n   716→      await ctx.reply(`切换目录失败：${message}`);\n   717→    }\n   718→  });\n   719→\n   720→  // F-009: /more command handler\n   721→  bot.command('more', async (ctx) => {\n   722→    try {\n   723→      ensureAllowed(ctx);\n   724→      const sessionId = buildSessionId(ctx);\n   725→\n   726→      await handleMore({\n   727→        ctx,\n   728→        reply: (msg) => ctx.reply(msg),\n   729→        params: {},\n   730→        userId: ctx.from?.id,\n   731→        sessionId\n   732→      });\n   733→    } catch (error) {\n   734→      const message = error instanceof Error ? error.message : String(error);\n   735→      logger.error({ err: message }, 'Failed to get more output in telegram');\n   736→      await ctx.reply(`获取更多输出失败：${message}`);\n   737→    }\n   738→  });\n   739→\n   740→  // T-100: Document upload handler for plan files\n   741→  bot.on('document', async (ctx) => {\n   742→    try {\n   743→      ensureAllowed(ctx);\n   744→\n   745→      const document = ctx.message?.document;\n   746→      if (!document) {\n   747→        return;\n   748→      }\n   749→\n   750→      // Check file extension\n   751→      const fileName = document.file_name || '';\n   752→      const ext = path.extname(fileName).toLowerCase();\n   753→\n   754→      if (ext !== '.json') {\n   755→        // Not a JSON file, ignore silently (other handlers may process it)\n   756→        return;\n   757→      }\n   758→\n   759→      // Check file size\n   760→      const fileSize = document.file_size || 0;\n   761→      if (fileSize > 1024 * 1024) { // 1MB limit\n   762→        await ctx.reply('❌ 文件过大，限制 1MB。');\n   763→        return;\n   764→      }\n   765→\n   766→      await ctx.reply('正在处理上传的计划文件...');\n   767→\n   768→      // Download file content\n   769→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n   770→      const fileUrl = fileLink.href || fileLink.toString();\n   771→\n   772→      const response = await fetch(fileUrl);\n   773→      if (!response.ok) {\n   774→        throw new Error(`下载文件失败: ${response.status}`);\n   775→      }\n   776→\n   777→      const content = await response.text();\n   778→\n   779→      // Validate and save using plan-ingestion-service\n   780→      const infraConfig = loadPipelineInfraConfig();\n   781→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n   782→\n   783→      const validationResult = planService.validate(content);\n   784→\n   785→      if (!validationResult.valid) {\n   786→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n   787→        await ctx.reply(errorMsg);\n   788→        return;\n   789→      }\n   790→\n   791→      // Save the plan\n   792→      const saveResult = await planService.save(\n   793→        validationResult.type,\n   794→        content,\n   795→        { uploadedBy: ctx.from?.id }\n   796→      );\n   797→\n   798→      if (!saveResult.success) {\n   799→        await ctx.reply('❌ 保存失败，请稍后重试。');\n   800→        return;\n   801→      }\n   802→\n   803→      // Set as current version\n   804→      await planService.setCurrent(validationResult.type, saveResult.version);\n   805→\n   806→      // Format success message\n   807→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n   808→      const summary = validationResult.summary;\n   809→\n   810→      await ctx.reply([\n   811→        `✅ ${typeDisplay}已保存并激活`,\n   812→        `版本: ${saveResult.version}`,\n   813→        `名称: ${summary?.name || '未知'}`,\n   814→        `项目数: ${summary?.itemCount || 0}`,\n   815→        '',\n   816→        summary?.statusBreakdown ? '状态分布:' : '',\n   817→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n   818→      ].filter(Boolean).join('\\n'));\n   819→\n   820→    } catch (error) {\n   821→      const message = error instanceof Error ? error.message : String(error);\n   822→      logger.error({ err: message }, 'Failed to process document upload');\n   823→      await ctx.reply(`❌ 处理失败：${message}`);\n   824→    }\n   825→  });\n   826→\n   827→  bot.on('text', async (ctx) => {\n   828→    // Check for pipeline commands first\n   829→    const handled = await routeCommand(ctx);\n   830→    if (handled) {\n   831→      return;\n   832→    }\n   833→\n   834→    const sessionId = buildSessionId(ctx);\n   835→    const userId = ctx.from?.id;\n   836→\n   837→    // F-009: Direct exec mode - treat plain text as command when enabled\n   838→    if (config.directExecMode && config.enableSystemExec) {\n   839→      try {\n   840→        ensureAllowed(ctx);\n   841→        const command = ctx.message.text;\n   842→\n   843→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n   844→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n   845→\n   846→        if (!isLikelyChat) {\n   847→          await ctx.reply('正在执行命令...');\n   848→          const result = await executeCommand({\n   849→            command,\n   850→            sessionId,\n   851→            userId\n   852→          });\n   853→\n   854→          if (result.needsConfirmation) {\n   855→            await ctx.reply(result.confirmationMessage);\n   856→            return;\n   857→          }\n   858→\n   859→          await replyLargeText(ctx, result.output);\n   860→\n   861→          if (result.hasMorePages) {\n   862→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n   863→          }\n   864→          return;\n   865→        }\n   866→      } catch (error) {\n   867→        const message = error instanceof Error ? error.message : String(error);\n   868→        // If exec fails, fall through to chat mode\n   869→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n   870→      }\n   871→    }\n   872→\n   873→    // F-011: Check if AI CLI is already running\n   874→    if (isAiCliRunning(sessionId)) {\n   875→      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n   876→      return;\n   877→    }\n   878→\n   879→    let typingTimer = null;\n   880→\n   881→    try {\n   882→      ensureAllowed(ctx);\n   883→      await ctx.sendChatAction('typing');\n   884→\n   885→      const streamPublisher = createEditableStreamPublisher(ctx);\n   886→      typingTimer = setInterval(() => {\n   887→        ctx.sendChatAction('typing').catch(() => undefined);\n   888→      }, TYPING_INTERVAL_MS);\n   889→\n   890→      // F-011: Use ai-cli-service for execution with process tracking\n   891→      const sessionKey = `telegram:${sessionId}`;\n   892→\n   893→      // Append user message to session history\n   894→      sessionStore.append(sessionKey, 'user', ctx.message.text);\n   895→\n   896→      // Build prompt with context\n   897→      const prompt = sessionStore.toPrompt(sessionKey, 'telegram');\n   898→\n   899→      // Track last heartbeat message for updates\n   900→      /** @type {{ message_id: number } | null} */\n   901→      let lastHeartbeatMsg = null;\n   902→\n   903→      const result = await executeAiCli({\n   904→        sessionId,\n   905→        prompt,\n   906→        hooks: {\n   907→          onChunk: (text) => {\n   908→            streamPublisher.push(text);\n   909→          },\n   910→          onHeartbeat: config.aiCliEnableHeartbeat ? (info) => {\n   911→            // Send/update heartbeat progress message\n   912→            const elapsedSec = Math.floor(info.elapsedMs / 1000);\n   913→            const progressText = `⏳ 任务执行中... (${elapsedSec}s, ${Math.floor(info.stdoutBytes / 1024)}KB)`;\n   914→\n   915→            // Don't await - fire and forget\n   916→            if (lastHeartbeatMsg) {\n   917→              ctx.telegram.editMessageText(ctx.chat.id, lastHeartbeatMsg.message_id, undefined, progressText)\n   918→                .catch(() => {});\n   919→            } else {\n   920→              ctx.reply(progressText)\n   921→                .then((msg) => { lastHeartbeatMsg = msg; })\n   922→                .catch(() => {});\n   923→            }\n   924→          } : undefined,\n   925→          onStatus: (status) => {\n   926→            if (status === 'running') {\n   927→              ctx.sendChatAction('typing').catch(() => undefined);\n   928→            }\n   929→          }\n   930→        }\n   931→      });\n   932→\n   933→      // Delete heartbeat message if exists\n   934→      if (lastHeartbeatMsg) {\n   935→        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n   936→      }\n   937→\n   938→      // Append assistant reply to session history\n   939→      sessionStore.append(sessionKey, 'assistant', result.output);\n   940→\n   941→      // F-011: Format output with MarkdownV2\n   942→      const formattedOutput = convertToMarkdownV2(result.output);\n   943→\n   944→      // Handle result states\n   945→      if (result.interrupted) {\n   946→        await ctx.reply('⏹️ 任务已被中断。');\n   947→      } else if (result.timedOut) {\n   948→        await ctx.reply(`⏰ 任务执行超时。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n   949→      }\n   950→\n   951→      // Extract file markers and send\n   952→      const { fileRefs, cleanedText } = extractFileMarkers(result.output);\n   953→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n   954→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n   955→\n   956→      streamPublisher.setFinalText(finalText);\n   957→      const streamed = await streamPublisher.finish();\n   958→      if (streamed.outputLength === 0) {\n   959→        await replyLargeText(ctx, finalText);\n   960→      }\n   961→\n   962→      if (fileRefs.length > 0) {\n   963→        const fileSendResults = await replyFiles(ctx, fileRefs);\n   964→        const failed = fileSendResults.filter((item) => !item.sent);\n   965→\n   966→        if (failed.length === 0) {\n   967→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n   968→        } else {\n   969→          const failedList = failed\n   970→            .map((item) => {\n   971→              const reason =\n   972→                item.reason === 'relative_path_not_allowed'\n   973→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n   974→                  : item.reason === 'not_found'\n   975→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n   976→                    : item.reason;\n   977→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n   978→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n   979→            })\n   980→            .join('\\n');\n   981→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n   982→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n   983→        }\n   984→      }\n   985→    } catch (error) {\n   986→      const message = error instanceof Error ? error.message : String(error);\n   987→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n   988→      await safeReply(ctx, `处理失败：${message}`);\n   989→    } finally {\n   990→      if (typingTimer) {\n   991→        clearInterval(typingTimer);\n   992→      }\n   993→    }\n   994→  });\n   995→\n   996→  return bot;\n   997→}\n   998→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6c8ebc62-648e-4d09-8200-69d30faee4f6","uuid":"982b9c71-1068-41bf-a3f4-5440ab1aef00","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/src/bot/telegram.js","content":"import { Telegraf } from 'telegraf';\nimport { createReadStream } from 'node:fs';\nimport { access, stat } from 'node:fs/promises';\nimport os from 'node:os';\nimport path from 'node:path';\nimport { config } from '../config.js';\nimport { logger } from '../utils/logger.js';\nimport { isAllowedUser } from '../security/guard.js';\nimport { chatWithSession, resetSession } from '../services/chat-service.js';\nimport { executeAiCli, interruptAiCli, isAiCliRunning } from '../services/ai-cli-service.js';\nimport { captureScreenshot } from '../services/screenshot-service.js';\nimport { executeCommand, confirmHighRiskCommand } from '../services/command-executor-service.js';\nimport { createPlanIngestionService } from '../services/plan-ingestion-service.js';\nimport { loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\nimport { registerCommand } from './commands/index.js';\nimport { routeCommand } from './commands/index.js';\nimport { pipelineMeta, handlePipeline } from './commands/handlers/pipeline.js';\nimport { bugfixMeta, handleBugfix } from './commands/handlers/bugfix.js';\nimport { plannerMeta, handlePlanner } from './commands/handlers/planner.js';\nimport { statusMeta, handleStatus } from './commands/handlers/status.js';\nimport { logsMeta, handleLogs } from './commands/handlers/logs.js';\nimport { stopMeta, handleStop } from './commands/handlers/stop.js';\nimport { planMeta, handlePlan } from './commands/handlers/plan.js';\nimport { auditMeta, handleAudit } from './commands/handlers/audit.js';\nimport { commitMeta, handleCommit } from './commands/handlers/commit.js';\nimport { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n// F-009: New command handlers\nimport { cdMeta, handleCd } from './commands/handlers/cd.js';\nimport { moreMeta, handleMore } from './commands/handlers/more.js';\n// F-010: File Manager command handlers\nimport { lsMeta, handleLs } from './commands/handlers/ls.js';\nimport { treeMeta, handleTree } from './commands/handlers/tree.js';\nimport { catMeta, handleCat } from './commands/handlers/cat.js';\nimport { headMeta, handleHead } from './commands/handlers/head.js';\nimport { tailMeta, handleTail } from './commands/handlers/tail.js';\nimport { findMeta, handleFind } from './commands/handlers/find.js';\nimport { uploadMeta, handleUpload } from './commands/handlers/upload.js';\nimport { downloadMeta, handleDownload } from './commands/handlers/download.js';\n// F-012: System Monitor command handlers\nimport { sysinfoMeta, handleSysinfo } from './commands/handlers/sysinfo.js';\nimport { psMeta, handlePs } from './commands/handlers/ps.js';\nimport { killMeta, handleKill } from './commands/handlers/kill.js';\nimport { monitorMeta, handleMonitor } from './commands/handlers/monitor.js';\n// F-013: Session and Context Manager command handlers\nimport { historyMeta, handleHistory } from './commands/handlers/history.js';\nimport { aliasMeta, handleAlias } from './commands/handlers/alias.js';\nimport { sessionsMeta, handleSessions } from './commands/handlers/sessions.js';\n// F-014: Notification and Scheduled Tasks command handlers\nimport { cronMeta, handleCron } from './commands/handlers/cron.js';\nimport { jobsMeta, handleJobs } from './commands/handlers/jobs.js';\nimport { watchMeta, handleWatch } from './commands/handlers/watch.js';\nimport { generateHelp } from './commands/help.js';\nimport { sessionStore } from '../services/session-store.js';\nimport { sessionContextService } from '../services/session-context-service.js';\nimport { aliasStore } from '../services/alias-store.js';\nimport { scheduledTaskService } from '../services/scheduled-task-service.js';\nimport { fileWatcherService } from '../services/file-watcher-service.js';\nimport { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\nimport { escapeMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n\nconst TELEGRAM_MSG_CHUNK_SIZE = 3800;\nconst STREAM_MIN_CHARS = 220;\nconst STREAM_FLUSH_INTERVAL_MS = 1200;\nconst TYPING_INTERVAL_MS = 3500;\nconst PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\nconst DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\nconst ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\nconst TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\nconst TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\nconst TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\nconst TMP_DIR = path.resolve(os.tmpdir());\nconst HOME_DIR = path.resolve(os.homedir());\nconst DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\nconst DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\nconst DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\nconst DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n\nfunction resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n  const normalized = configuredDirs\n    .map((dir) => String(dir ?? '').trim())\n    .filter(Boolean)\n    .map((dir) => path.resolve(dir));\n\n  if (normalized.length > 0) {\n    return [...new Set(normalized)];\n  }\n\n  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n}\n\nconst ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\nconst FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n\nfunction splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  const chunks = [];\n  for (let i = 0; i < text.length; i += chunkSize) {\n    chunks.push(text.slice(i, i + chunkSize));\n  }\n  return chunks;\n}\n\nfunction truncate(text, maxLen) {\n  if (!text) return '';\n  if (text.length <= maxLen) return text;\n  return text.substring(0, maxLen) + '...';\n}\n\nfunction sanitizeMarkerPath(raw) {\n  return String(raw ?? '')\n    .trim()\n    .replace(/^['\"`]+/, '')\n    .replace(/['\"`]+$/, '');\n}\n\nfunction extractFileMarkers(text = '') {\n  const fileRefs = [];\n\n  const withSendFileRemoved = text.replace(\n    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n    (_full, rawRef) => {\n      const ref = sanitizeMarkerPath(rawRef);\n      if (ref) {\n        fileRefs.push(ref);\n      }\n      return '\\n';\n    }\n  );\n\n  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n    const ref = sanitizeMarkerPath(rawRef);\n    if (ref) {\n      fileRefs.push(ref);\n    }\n    return '';\n  });\n\n  const withBacktickPathRemoved = withImageRemoved.replace(\n    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n    (_full, rawRef) => {\n      const ref = sanitizeMarkerPath(rawRef);\n      if (ref) {\n        fileRefs.push(ref);\n      }\n      return '';\n    }\n  );\n\n  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n    (_full, rawRef) => {\n      const ref = sanitizeMarkerPath(rawRef);\n      if (ref) {\n        fileRefs.push(ref);\n      }\n      return '';\n    }\n  );\n\n  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n    (_full, rawRef) => {\n      const ref = sanitizeMarkerPath(rawRef);\n      if (ref) {\n        fileRefs.push(ref);\n      }\n      return '\\n';\n    }\n  );\n\n  return {\n    fileRefs: [...new Set(fileRefs)],\n    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n  };\n}\n\nfunction isPathWithinRoot(targetPath, rootPath) {\n  const relative = path.relative(rootPath, targetPath);\n  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n}\n\nfunction isAllowedFilePath(filePath) {\n  const resolved = path.resolve(filePath);\n  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n}\n\nfunction buildFileCandidates(normalizedPath) {\n  if (path.isAbsolute(normalizedPath)) {\n    return [normalizedPath];\n  }\n\n  const baseName = path.basename(normalizedPath);\n  const candidates = [\n    path.resolve(process.cwd(), normalizedPath),\n    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n  ];\n\n  return [...new Set(candidates)];\n}\n\nasync function resolveLocalFilePath(fileRef) {\n  const normalized = sanitizeMarkerPath(fileRef);\n  if (!normalized) {\n    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n  }\n\n  if (!path.isAbsolute(normalized)) {\n    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n  }\n\n  const candidates = buildFileCandidates(normalized);\n\n  for (const candidate of candidates) {\n    try {\n      await access(candidate);\n      return { filePath: candidate, triedPaths: candidates };\n    } catch {\n      // ignore\n    }\n  }\n\n  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n}\n\nasync function validateFileForTelegram(filePath) {\n  const resolvedPath = path.resolve(filePath);\n  if (!isAllowedFilePath(resolvedPath)) {\n    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n  }\n\n  const ext = path.extname(resolvedPath).toLowerCase();\n  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n  }\n\n  const fileStat = await stat(resolvedPath);\n  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n\n  if (fileStat.size > maxSize) {\n    return {\n      ok: false,\n      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n    };\n  }\n\n  return { ok: true, isPhoto, resolvedPath };\n}\n\nfunction isTimeoutLikeError(message = '') {\n  const normalized = String(message).toLowerCase();\n  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n}\n\nfunction sleep(ms) {\n  return new Promise((resolve) => setTimeout(resolve, ms));\n}\n\nasync function sendTelegramFileByType(ctx, filePath, isPhoto) {\n  if (isPhoto) {\n    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n    return;\n  }\n\n  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n}\n\nasync function replyFiles(ctx, fileRefs = []) {\n  const results = [];\n\n  for (const fileRef of fileRefs) {\n    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n    if (!filePath) {\n      const reason = rejectReason || 'not_found';\n      results.push({ fileRef, sent: false, reason, triedPaths });\n      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n      continue;\n    }\n\n    try {\n      const validation = await validateFileForTelegram(filePath);\n      if (!validation.ok) {\n        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n        continue;\n      }\n\n      const actualPath = validation.resolvedPath;\n      let sent = false;\n      let lastReason = '';\n\n      for (let attempt = 1; attempt <= 2; attempt += 1) {\n        try {\n          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n          sent = true;\n          logger.info(\n            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n            'Telegram file sent'\n          );\n          break;\n        } catch (error) {\n          lastReason = error instanceof Error ? error.message : String(error);\n          logger.warn(\n            { fileRef, filePath: actualPath, err: lastReason, attempt },\n            'Telegram file send attempt failed'\n          );\n\n          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n            await sleep(600);\n            continue;\n          }\n\n          break;\n        }\n      }\n\n      if (!sent) {\n        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n        continue;\n      }\n\n      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n    } catch (error) {\n      const reason = error instanceof Error ? error.message : String(error);\n      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n    }\n  }\n\n  return results;\n}\n\nasync function safeReply(ctx, text) {\n  try {\n    await ctx.reply(text);\n    return true;\n  } catch (error) {\n    const reason = error instanceof Error ? error.message : String(error);\n    logger.error({ err: reason }, 'Failed to send telegram text reply');\n    return false;\n  }\n}\n\nasync function replyLargeText(ctx, text) {\n  const chunks = splitMessage(text);\n  for (const chunk of chunks) {\n    const ok = await safeReply(ctx, chunk);\n    if (!ok) {\n      break;\n    }\n  }\n}\n\nasync function safeEditMessageText(ctx, messageId, text) {\n  const nextText = text && text.trim() ? text : ' ';\n\n  try {\n    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    if (message.includes('message is not modified')) {\n      return;\n    }\n    throw error;\n  }\n}\n\nfunction createEditableStreamPublisher(ctx) {\n  let fullText = '';\n  let renderedText = '';\n  let pendingChars = 0;\n  let lastFlushAt = 0;\n  let flushChain = Promise.resolve();\n  let activeMessage = null;\n  let activeSegmentIndex = 0;\n  let publishedMessageCount = 0;\n\n  async function ensureActiveMessage() {\n    if (activeMessage) {\n      return;\n    }\n    activeMessage = await ctx.reply('处理中...');\n    activeSegmentIndex = 0;\n    publishedMessageCount += 1;\n  }\n\n  async function render(force = false) {\n    const now = Date.now();\n\n    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n      return;\n    }\n\n    if (fullText === renderedText) {\n      pendingChars = 0;\n      return;\n    }\n\n    await ensureActiveMessage();\n\n    const segments = splitMessage(fullText);\n    const targetLastIndex = Math.max(segments.length - 1, 0);\n\n    while (activeSegmentIndex < targetLastIndex) {\n      const text = segments[activeSegmentIndex] ?? ' ';\n      await safeEditMessageText(ctx, activeMessage.message_id, text);\n\n      activeMessage = await ctx.reply('继续输出中...');\n      activeSegmentIndex += 1;\n      publishedMessageCount += 1;\n    }\n\n    const activeText = segments[targetLastIndex] ?? ' ';\n    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n\n    renderedText = fullText;\n    pendingChars = 0;\n    lastFlushAt = now;\n  }\n\n  function enqueueRender(force = false) {\n    flushChain = flushChain.then(() => render(force));\n  }\n\n  return {\n    push(text) {\n      const appendText = text ?? '';\n      if (!appendText) {\n        return;\n      }\n      fullText += appendText;\n      pendingChars += appendText.length;\n      enqueueRender(false);\n    },\n    setFinalText(text) {\n      fullText = text ?? '';\n      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n      enqueueRender(true);\n    },\n    async finish() {\n      enqueueRender(true);\n      await flushChain;\n      return {\n        outputLength: renderedText.length,\n        messageCount: publishedMessageCount\n      };\n    }\n  };\n}\n\nfunction buildSessionId(ctx) {\n  return String(ctx.chat.id);\n}\n\nfunction ensureAllowed(ctx) {\n  const userId = ctx.from?.id;\n  if (!isAllowedUser(userId)) {\n    throw new Error('当前账号未被授权使用该机器人。');\n  }\n}\n\n/**\n * Register all pipeline-related commands.\n */\nfunction registerPipelineCommands() {\n  registerCommand(pipelineMeta, handlePipeline);\n  registerCommand(bugfixMeta, handleBugfix);\n  registerCommand(plannerMeta, handlePlanner);\n  registerCommand(statusMeta, handleStatus);\n  registerCommand(logsMeta, handleLogs);\n  registerCommand(stopMeta, handleStop);\n  registerCommand(planMeta, handlePlan);\n  registerCommand(auditMeta, handleAudit);\n  registerCommand(commitMeta, handleCommit);\n  registerCommand(commitsMeta, handleCommits);\n  // F-009: New commands\n  registerCommand(cdMeta, handleCd);\n  registerCommand(moreMeta, handleMore);\n  // F-010: File Manager commands\n  registerCommand(lsMeta, handleLs);\n  registerCommand(treeMeta, handleTree);\n  registerCommand(catMeta, handleCat);\n  registerCommand(headMeta, handleHead);\n  registerCommand(tailMeta, handleTail);\n  registerCommand(findMeta, handleFind);\n  registerCommand(uploadMeta, handleUpload);\n  registerCommand(downloadMeta, handleDownload);\n  // F-012: System Monitor commands\n  registerCommand(sysinfoMeta, handleSysinfo);\n  registerCommand(psMeta, handlePs);\n  registerCommand(killMeta, handleKill);\n  registerCommand(monitorMeta, handleMonitor);\n  // F-013: Session and Context Manager commands\n  registerCommand(historyMeta, handleHistory);\n  registerCommand(aliasMeta, handleAlias);\n  registerCommand(sessionsMeta, handleSessions);\n  // F-014: Notification and Scheduled Tasks commands\n  registerCommand(cronMeta, handleCron);\n  registerCommand(jobsMeta, handleJobs);\n  registerCommand(watchMeta, handleWatch);\n}\n\nexport async function createTelegramBot() {\n  const bot = new Telegraf(config.telegramBotToken, {\n    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n  });\n\n  // F-013: Initialize session context service\n  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n  await aliasStore.initAliasStore({ persistencePath: config.aliasPersistencePath });\n\n  // F-013: Restore sessions from disk\n  await sessionContextService.restoreSessions();\n\n  // F-013: Set up notification callback for session timeout\n  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n    try {\n      // Extract chat ID from session key (format: telegram:123456789)\n      const chatId = sessionKey.replace('telegram:', '');\n      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n    } catch (error) {\n      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n    }\n  });\n\n  // F-013: Start timeout watcher\n  sessionContextService.startTimeoutWatcher();\n\n  // F-014: Initialize scheduled task service\n  scheduledTaskService.initScheduledTaskService({\n    dataDir: config.systemMonitorDataDir,\n    tasksFile: config.scheduledTasksPath,\n    maxTasks: config.maxScheduledTasks\n  });\n\n  // F-014: Set up task execution callback\n  scheduledTaskService.setExecuteCallback(async ({ command, cwd, sessionId, userId }) => {\n    try {\n      return await executeCommand({\n        command,\n        cwd,\n        sessionId,\n        userId,\n        skipConfirmation: true // Skip confirmation for scheduled tasks\n      });\n    } catch (error) {\n      return {\n        stdout: '',\n        stderr: error.message,\n        exitCode: 1,\n        timedOut: false\n      };\n    }\n  });\n\n  // F-014: Set up task notification callback\n  scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n    try {\n      const result = task.lastResult || {};\n      const lines = [\n        '⏰ *定时任务完成*',\n        '',\n        `任务ID: \\`${task.id.substring(0, 8)}...\\``,\n        `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n        `执行时间: ${new Date(result.executedAt || Date.now()).toLocaleString()}`,\n        '',\n        `exitCode: ${result.exitCode}`,\n        result.stdout ? `stdout:\\n${truncate(result.stdout, 500)}` : 'stdout: (empty)',\n        result.stderr ? `stderr:\\n${escapeMarkdownV2(truncate(result.stderr, 500))}` : 'stderr: (empty)'\n      ];\n      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n    } catch (error) {\n      logger.warn({ taskId: task.id, error: error.message }, 'Failed to send task notification');\n    }\n  });\n\n  // F-014: Load and start scheduled tasks\n  await scheduledTaskService.loadTasks();\n  scheduledTaskService.startScheduler();\n\n  // F-014: Initialize file watcher service\n  fileWatcherService.initFileWatcherService({\n    dataDir: config.systemMonitorDataDir,\n    watchersFile: config.fileWatchersPath,\n    maxWatchers: config.maxFileWatchers,\n    debounceMs: config.taskDebounceMs,\n    allowedRoots: config.telegramFileAllowedRoots.length > 0\n      ? config.telegramFileAllowedRoots\n      : [process.cwd()]\n  });\n\n  // F-014: Set up file watcher notification callback\n  fileWatcherService.setNotificationCallback(async (chatId, watcher) => {\n    try {\n      const lines = [\n        '📁 *文件变更检测*',\n        '',\n        `路径: \\`${escapeMarkdownV2(watcher.path)}\\``,\n        `事件: ${watcher.eventType}`,\n        `文件: ${watcher.filename || '(未知)'}`,\n        `时间: ${new Date().toLocaleString()}`\n      ];\n      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n    } catch (error) {\n      logger.warn({ watcherId: watcher.id, error: error.message }, 'Failed to send file watcher notification');\n    }\n  });\n\n  // F-014: Restore file watchers\n  await fileWatcherService.restoreWatches();\n\n  // Register pipeline commands\n  registerPipelineCommands();\n\n  bot.catch((error, ctx) => {\n    const message = error instanceof Error ? error.message : String(error);\n    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n  });\n\n  bot.start(async (ctx) => {\n    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n  });\n\n  bot.help(async (ctx) => {\n    const helpText = generateHelp();\n    await ctx.reply(helpText);\n  });\n\n  bot.command('reset', async (ctx) => {\n    try {\n      ensureAllowed(ctx);\n      const sessionId = buildSessionId(ctx);\n\n      // F-011: Interrupt any running AI CLI task\n      if (isAiCliRunning(sessionId)) {\n        interruptAiCli(sessionId);\n      }\n\n      resetSession({ channel: 'telegram', sessionId });\n      await ctx.reply('已清空当前会话上下文。');\n    } catch (error) {\n      await ctx.reply(error instanceof Error ? error.message : String(error));\n    }\n  });\n\n  bot.command('screenshot', async (ctx) => {\n    try {\n      ensureAllowed(ctx);\n      await ctx.reply('正在获取截图。');\n      const { buffer } = await captureScreenshot();\n      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n    } catch (error) {\n      const message = error instanceof Error ? error.message : String(error);\n      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n      await ctx.reply(`截图失败：${message}`);\n    }\n  });\n\n  bot.command('exec', async (ctx) => {\n    try {\n      ensureAllowed(ctx);\n      const payload = ctx.message.text.replace('/exec', '').trim();\n      if (!payload) {\n        await ctx.reply('请提供命令，例如 /exec pwd');\n        return;\n      }\n\n      const sessionId = buildSessionId(ctx);\n      const userId = ctx.from?.id;\n\n      await ctx.reply('正在执行命令...');\n      const result = await executeCommand({\n        command: payload,\n        sessionId,\n        userId\n      });\n\n      // Handle confirmation required\n      if (result.needsConfirmation) {\n        await ctx.reply(result.confirmationMessage);\n        return;\n      }\n\n      // Send output\n      await replyLargeText(ctx, result.output);\n\n      // Indicate if more pages available\n      if (result.hasMorePages) {\n        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n      }\n    } catch (error) {\n      const message = error instanceof Error ? error.message : String(error);\n      logger.error({ err: message }, 'Failed to exec command in telegram');\n      await ctx.reply(`执行失败：${message}`);\n    }\n  });\n\n  // F-009: /cd command handler\n  bot.command('cd', async (ctx) => {\n    try {\n      ensureAllowed(ctx);\n      const payload = ctx.message.text.replace('/cd', '').trim();\n      const sessionId = buildSessionId(ctx);\n\n      await handleCd({\n        ctx,\n        reply: (msg) => ctx.reply(msg),\n        params: {},\n        userId: ctx.from?.id,\n        sessionId,\n        args: payload ? [payload] : []\n      });\n    } catch (error) {\n      const message = error instanceof Error ? error.message : String(error);\n      logger.error({ err: message }, 'Failed to cd in telegram');\n      await ctx.reply(`切换目录失败：${message}`);\n    }\n  });\n\n  // F-009: /more command handler\n  bot.command('more', async (ctx) => {\n    try {\n      ensureAllowed(ctx);\n      const sessionId = buildSessionId(ctx);\n\n      await handleMore({\n        ctx,\n        reply: (msg) => ctx.reply(msg),\n        params: {},\n        userId: ctx.from?.id,\n        sessionId\n      });\n    } catch (error) {\n      const message = error instanceof Error ? error.message : String(error);\n      logger.error({ err: message }, 'Failed to get more output in telegram');\n      await ctx.reply(`获取更多输出失败：${message}`);\n    }\n  });\n\n  // T-100: Document upload handler for plan files\n  bot.on('document', async (ctx) => {\n    try {\n      ensureAllowed(ctx);\n\n      const document = ctx.message?.document;\n      if (!document) {\n        return;\n      }\n\n      // Check file extension\n      const fileName = document.file_name || '';\n      const ext = path.extname(fileName).toLowerCase();\n\n      if (ext !== '.json') {\n        // Not a JSON file, ignore silently (other handlers may process it)\n        return;\n      }\n\n      // Check file size\n      const fileSize = document.file_size || 0;\n      if (fileSize > 1024 * 1024) { // 1MB limit\n        await ctx.reply('❌ 文件过大，限制 1MB。');\n        return;\n      }\n\n      await ctx.reply('正在处理上传的计划文件...');\n\n      // Download file content\n      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n      const fileUrl = fileLink.href || fileLink.toString();\n\n      const response = await fetch(fileUrl);\n      if (!response.ok) {\n        throw new Error(`下载文件失败: ${response.status}`);\n      }\n\n      const content = await response.text();\n\n      // Validate and save using plan-ingestion-service\n      const infraConfig = loadPipelineInfraConfig();\n      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n\n      const validationResult = planService.validate(content);\n\n      if (!validationResult.valid) {\n        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n        await ctx.reply(errorMsg);\n        return;\n      }\n\n      // Save the plan\n      const saveResult = await planService.save(\n        validationResult.type,\n        content,\n        { uploadedBy: ctx.from?.id }\n      );\n\n      if (!saveResult.success) {\n        await ctx.reply('❌ 保存失败，请稍后重试。');\n        return;\n      }\n\n      // Set as current version\n      await planService.setCurrent(validationResult.type, saveResult.version);\n\n      // Format success message\n      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n      const summary = validationResult.summary;\n\n      await ctx.reply([\n        `✅ ${typeDisplay}已保存并激活`,\n        `版本: ${saveResult.version}`,\n        `名称: ${summary?.name || '未知'}`,\n        `项目数: ${summary?.itemCount || 0}`,\n        '',\n        summary?.statusBreakdown ? '状态分布:' : '',\n        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n      ].filter(Boolean).join('\\n'));\n\n    } catch (error) {\n      const message = error instanceof Error ? error.message : String(error);\n      logger.error({ err: message }, 'Failed to process document upload');\n      await ctx.reply(`❌ 处理失败：${message}`);\n    }\n  });\n\n  bot.on('text', async (ctx) => {\n    // Check for pipeline commands first\n    const handled = await routeCommand(ctx);\n    if (handled) {\n      return;\n    }\n\n    const sessionId = buildSessionId(ctx);\n    const userId = ctx.from?.id;\n\n    // F-009: Direct exec mode - treat plain text as command when enabled\n    if (config.directExecMode && config.enableSystemExec) {\n      try {\n        ensureAllowed(ctx);\n        const command = ctx.message.text;\n\n        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n\n        if (!isLikelyChat) {\n          await ctx.reply('正在执行命令...');\n          const result = await executeCommand({\n            command,\n            sessionId,\n            userId\n          });\n\n          if (result.needsConfirmation) {\n            await ctx.reply(result.confirmationMessage);\n            return;\n          }\n\n          await replyLargeText(ctx, result.output);\n\n          if (result.hasMorePages) {\n            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n          }\n          return;\n        }\n      } catch (error) {\n        const message = error instanceof Error ? error.message : String(error);\n        // If exec fails, fall through to chat mode\n        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n      }\n    }\n\n    // F-011: Check if AI CLI is already running\n    if (isAiCliRunning(sessionId)) {\n      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n      return;\n    }\n\n    let typingTimer = null;\n\n    try {\n      ensureAllowed(ctx);\n      await ctx.sendChatAction('typing');\n\n      const streamPublisher = createEditableStreamPublisher(ctx);\n      typingTimer = setInterval(() => {\n        ctx.sendChatAction('typing').catch(() => undefined);\n      }, TYPING_INTERVAL_MS);\n\n      // F-011: Use ai-cli-service for execution with process tracking\n      const sessionKey = `telegram:${sessionId}`;\n\n      // Append user message to session history\n      sessionStore.append(sessionKey, 'user', ctx.message.text);\n\n      // Build prompt with context\n      const prompt = sessionStore.toPrompt(sessionKey, 'telegram');\n\n      // Track last heartbeat message for updates\n      /** @type {{ message_id: number } | null} */\n      let lastHeartbeatMsg = null;\n\n      const result = await executeAiCli({\n        sessionId,\n        prompt,\n        hooks: {\n          onChunk: (text) => {\n            streamPublisher.push(text);\n          },\n          onHeartbeat: config.aiCliEnableHeartbeat ? (info) => {\n            // Send/update heartbeat progress message\n            const elapsedSec = Math.floor(info.elapsedMs / 1000);\n            const progressText = `⏳ 任务执行中... (${elapsedSec}s, ${Math.floor(info.stdoutBytes / 1024)}KB)`;\n\n            // Don't await - fire and forget\n            if (lastHeartbeatMsg) {\n              ctx.telegram.editMessageText(ctx.chat.id, lastHeartbeatMsg.message_id, undefined, progressText)\n                .catch(() => {});\n            } else {\n              ctx.reply(progressText)\n                .then((msg) => { lastHeartbeatMsg = msg; })\n                .catch(() => {});\n            }\n          } : undefined,\n          onStatus: (status) => {\n            if (status === 'running') {\n              ctx.sendChatAction('typing').catch(() => undefined);\n            }\n          }\n        }\n      });\n\n      // Delete heartbeat message if exists\n      if (lastHeartbeatMsg) {\n        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n      }\n\n      // Append assistant reply to session history\n      sessionStore.append(sessionKey, 'assistant', result.output);\n\n      // F-011: Format output with MarkdownV2\n      const formattedOutput = convertToMarkdownV2(result.output);\n\n      // Handle result states\n      if (result.interrupted) {\n        await ctx.reply('⏹️ 任务已被中断。');\n      } else if (result.timedOut) {\n        await ctx.reply(`⏰ 任务执行超时。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n      }\n\n      // Extract file markers and send\n      const { fileRefs, cleanedText } = extractFileMarkers(result.output);\n      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n\n      streamPublisher.setFinalText(finalText);\n      const streamed = await streamPublisher.finish();\n      if (streamed.outputLength === 0) {\n        await replyLargeText(ctx, finalText);\n      }\n\n      if (fileRefs.length > 0) {\n        const fileSendResults = await replyFiles(ctx, fileRefs);\n        const failed = fileSendResults.filter((item) => !item.sent);\n\n        if (failed.length === 0) {\n          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n        } else {\n          const failedList = failed\n            .map((item) => {\n              const reason =\n                item.reason === 'relative_path_not_allowed'\n                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n                  : item.reason === 'not_found'\n                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n                    : item.reason;\n              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n            })\n            .join('\\n');\n          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n        }\n      }\n    } catch (error) {\n      const message = error instanceof Error ? error.message : String(error);\n      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n      await safeReply(ctx, `处理失败：${message}`);\n    } finally {\n      if (typingTimer) {\n        clearInterval(typingTimer);\n      }\n    }\n  });\n\n  return bot;\n}\n","numLines":998,"startLine":1,"totalLines":998}}}
