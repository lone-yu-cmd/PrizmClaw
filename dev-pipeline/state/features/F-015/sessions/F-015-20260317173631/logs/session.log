{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_621a3f1edb5d4c55aec88445","type":"tool_result","content":"     1→/**\n     2→ * F-011: AI CLI Service\n     3→ *\n     4→ * Encapsulates AI CLI execution logic with process tracking,\n     5→ * heartbeat, and interrupt support.\n     6→ *\n     7→ * T-051: Metrics tracking for monitoring\n     8→ */\n     9→\n    10→import { spawn } from 'node:child_process';\n    11→import { config } from '../config.js';\n    12→import { logger } from '../utils/logger.js';\n    13→import { sessionStore } from './session-store.js';\n    14→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n    15→\n    16→/**\n    17→ * Metrics for AI CLI execution monitoring.\n    18→ * T-051: Track execution statistics\n    19→ */\n    20→const metrics = {\n    21→  // Execution counts\n    22→  totalExecutions: 0,\n    23→  successCount: 0,\n    24→  failureCount: 0,\n    25→  timeoutCount: 0,\n    26→  interruptCount: 0,\n    27→\n    28→  // Duration tracking (for histogram)\n    29→  durations: [],\n    30→  maxDurations: 100, // Keep last 100 durations\n    31→\n    32→  // Output size tracking\n    33→  outputSizes: [],\n    34→  maxOutputSizes: 100\n    35→};\n    36→\n    37→/**\n    38→ * Get current metrics snapshot.\n    39→ * @returns {Object} Metrics snapshot\n    40→ */\n    41→export function getMetrics() {\n    42→  const durations = [...metrics.durations];\n    43→  const outputSizes = [...metrics.outputSizes];\n    44→\n    45→  return {\n    46→    totalExecutions: metrics.totalExecutions,\n    47→    successCount: metrics.successCount,\n    48→    failureCount: metrics.failureCount,\n    49→    timeoutCount: metrics.timeoutCount,\n    50→    interruptCount: metrics.interruptCount,\n    51→    averageDurationMs: durations.length > 0\n    52→      ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length)\n    53→      : 0,\n    54→    minDurationMs: durations.length > 0 ? Math.min(...durations) : 0,\n    55→    maxDurationMs: durations.length > 0 ? Math.max(...durations) : 0,\n    56→    averageOutputBytes: outputSizes.length > 0\n    57→      ? Math.round(outputSizes.reduce((a, b) => a + b, 0) / outputSizes.length)\n    58→      : 0\n    59→  };\n    60→}\n    61→\n    62→/**\n    63→ * Record execution metrics.\n    64→ * @param {Object} result - Execution result\n    65→ * @param {number} result.elapsedMs - Execution duration\n    66→ * @param {number} result.stdoutBytes - Output size\n    67→ * @param {boolean} result.success - Whether execution succeeded\n    68→ * @param {boolean} result.timedOut - Whether execution timed out\n    69→ * @param {boolean} result.interrupted - Whether execution was interrupted\n    70→ */\n    71→function recordMetrics(result) {\n    72→  metrics.totalExecutions++;\n    73→\n    74→  // Track duration\n    75→  metrics.durations.push(result.elapsedMs);\n    76→  if (metrics.durations.length > metrics.maxDurations) {\n    77→    metrics.durations.shift();\n    78→  }\n    79→\n    80→  // Track output size\n    81→  metrics.outputSizes.push(result.stdoutBytes || 0);\n    82→  if (metrics.outputSizes.length > metrics.maxOutputSizes) {\n    83→    metrics.outputSizes.shift();\n    84→  }\n    85→\n    86→  // Track outcome\n    87→  if (result.interrupted) {\n    88→    metrics.interruptCount++;\n    89→  } else if (result.timedOut) {\n    90→    metrics.timeoutCount++;\n    91→  } else if (result.success) {\n    92→    metrics.successCount++;\n    93→  } else {\n    94→    metrics.failureCount++;\n    95→  }\n    96→\n    97→  // Log metrics at debug level\n    98→  logger.debug(\n    99→    {\n   100→      totalExecutions: metrics.totalExecutions,\n   101→      successRate: `${Math.round((metrics.successCount / metrics.totalExecutions) * 100)}%`,\n   102→      interruptRate: `${Math.round((metrics.interruptCount / metrics.totalExecutions) * 100)}%`,\n   103→      timeoutRate: `${Math.round((metrics.timeoutCount / metrics.totalExecutions) * 100)}%`\n   104→    },\n   105→    'AI CLI metrics updated'\n   106→  );\n   107→}\n   108→\n   109→/**\n   110→ * Reset metrics (useful for testing).\n   111→ */\n   112→export function resetMetrics() {\n   113→  metrics.totalExecutions = 0;\n   114→  metrics.successCount = 0;\n   115→  metrics.failureCount = 0;\n   116→  metrics.timeoutCount = 0;\n   117→  metrics.interruptCount = 0;\n   118→  metrics.durations = [];\n   119→  metrics.outputSizes = [];\n   120→}\n   121→\n   122→/**\n   123→ * @typedef {Object} AiCliExecutionOptions\n   124→ * @property {string} sessionId - Session identifier\n   125→ * @property {string} prompt - User prompt/input\n   126→ * @property {string} [userId] - User ID who initiated the task (for permission checks)\n   127→ * @property {Object} [hooks] - Callback hooks\n   128→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n   129→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n   130→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n   131→ * @property {AbortSignal} [signal] - Optional abort signal\n   132→ * @property {number} [timeoutMs] - Optional timeout override\n   133→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n   134→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n   135→ * @property {string} [bin] - Optional binary override (for testing)\n   136→ * @property {string[]} [args] - Optional args override (for testing, replaces default args)\n   137→ */\n   138→\n   139→/**\n   140→ * @typedef {Object} AiCliExecutionResult\n   141→ * @property {string} output - Final output text\n   142→ * @property {boolean} timedOut - Whether execution timed out\n   143→ * @property {boolean} interrupted - Whether execution was interrupted\n   144→ * @property {number} elapsedMs - Execution time in milliseconds\n   145→ * @property {number|null} exitCode - Process exit code (if completed)\n   146→ * @property {string} stderr - Error output if any\n   147→ */\n   148→\n   149→/**\n   150→ * @typedef {Object} HeartbeatInfo\n   151→ * @property {number} elapsedMs - Elapsed time in milliseconds\n   152→ * @property {number} stdoutBytes - Bytes received so far\n   153→ * @property {string} status - Current status ('running', 'streaming')\n   154→ */\n   155→\n   156→/**\n   157→ * Write text to echo output for debugging.\n   158→ * @param {string} tag - Tag for the output\n   159→ * @param {string} text - Text to write\n   160→ */\n   161→function writeEcho(tag, text) {\n   162→  const normalized = String(text ?? '');\n   163→  if (!normalized) {\n   164→    return;\n   165→  }\n   166→\n   167→  const lines = normalized.split(/\\r?\\n/);\n   168→  for (const line of lines) {\n   169→    if (!line) {\n   170→      continue;\n   171→    }\n   172→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n   173→  }\n   174→}\n   175→\n   176→/**\n   177→ * Execute AI CLI with session context and process tracking.\n   178→ * @param {AiCliExecutionOptions} options\n   179→ * @returns {Promise<AiCliExecutionResult>}\n   180→ */\n   181→export async function executeAiCli(options) {\n   182→  const {\n   183→    sessionId,\n   184→    prompt,\n   185→    userId,\n   186→    hooks = {},\n   187→    signal,\n   188→    timeoutMs,\n   189→    heartbeatThresholdMs,\n   190→    heartbeatIntervalMs,\n   191→    bin,\n   192→    args: customArgs\n   193→  } = options;\n   194→\n   195→  const effectiveBin = bin || config.codebuddyBin;\n   196→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n   197→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n   198→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n   199→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n   200→\n   201→  // Use custom args if provided (for testing), otherwise build default args\n   202→  const args = customArgs ?? (() => {\n   203→    const defaultArgs = ['-p', prompt];\n   204→    if (config.codebuddyPermissionFlag) {\n   205→      defaultArgs.push(config.codebuddyPermissionFlag);\n   206→    }\n   207→    return defaultArgs;\n   208→  })();\n   209→\n   210→  return new Promise((resolve) => {\n   211→    let stdout = '';\n   212→    let stderr = '';\n   213→    let stdoutBytes = 0;\n   214→    let interrupted = false;\n   215→    let timedOut = false;\n   216→    const startedAt = Date.now();\n   217→    const sessionKey = sessionId;\n   218→\n   219→    // Heartbeat manager\n   220→    const heartbeatManager = createHeartbeatManager();\n   221→\n   222→    // Spawn process\n   223→    let child;\n   224→    try {\n   225→      child = spawn(effectiveBin, args, {\n   226→        stdio: ['ignore', 'pipe', 'pipe']\n   227→      });\n   228→    } catch (err) {\n   229→      resolve({\n   230→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n   231→        timedOut: false,\n   232→        interrupted: false,\n   233→        elapsedMs: Date.now() - startedAt,\n   234→        exitCode: null,\n   235→        stderr: ''\n   236→      });\n   237→      return;\n   238→    }\n   239→\n   240→    // Track process in session store\n   241→    sessionStore.setActiveProcess(sessionKey, {\n   242→      pid: child.pid,\n   243→      startedAt,\n   244→      childProcess: child,\n   245→      interrupted: false,\n   246→      timedOut: false,\n   247→      userId\n   248→    });\n   249→\n   250→    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n   251→\n   252→    // Handle process error\n   253→    child.on('error', (err) => {\n   254→      cleanup();\n   255→      resolve({\n   256→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n   257→        timedOut: false,\n   258→        interrupted: false,\n   259→        elapsedMs: Date.now() - startedAt,\n   260→        exitCode: null,\n   261→        stderr\n   262→      });\n   263→    });\n   264→\n   265→    // Handle stdout\n   266→    child.stdout.on('data', (chunk) => {\n   267→      const text = chunk.toString();\n   268→      stdout += text;\n   269→      stdoutBytes += Buffer.byteLength(text);\n   270→\n   271→      // Update session store byte count\n   272→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n   273→\n   274→      // Echo to console if enabled\n   275→      if (config.codebuddyEchoStdio) {\n   276→        writeEcho('stdout', text);\n   277→      }\n   278→\n   279→      // Call onChunk hook\n   280→      if (typeof hooks.onChunk === 'function') {\n   281→        hooks.onChunk(text);\n   282→      }\n   283→    });\n   284→\n   285→    // Handle stderr\n   286→    child.stderr.on('data', (chunk) => {\n   287→      const text = chunk.toString();\n   288→      stderr += text;\n   289→\n   290→      if (config.codebuddyEchoStdio) {\n   291→        writeEcho('stderr', text);\n   292→      }\n   293→    });\n   294→\n   295→    // Timeout handler\n   296→    const timeout = effectiveTimeoutMs > 0\n   297→      ? setTimeout(() => {\n   298→          timedOut = true;\n   299→          const info = sessionStore.getActiveProcess(sessionKey);\n   300→          if (info) {\n   301→            info.timedOut = true;\n   302→          }\n   303→          child.kill('SIGTERM');\n   304→\n   305→          // Schedule SIGKILL if process doesn't exit\n   306→          setTimeout(() => {\n   307→            if (sessionStore.getActiveProcess(sessionKey)) {\n   308→              child.kill('SIGKILL');\n   309→            }\n   310→          }, 5000);\n   311→        }, effectiveTimeoutMs)\n   312→      : null;\n   313→\n   314→    // Abort signal handler\n   315→    const onAbort = () => {\n   316→      interrupted = true;\n   317→      const info = sessionStore.getActiveProcess(sessionKey);\n   318→      if (info) {\n   319→        info.interrupted = true;\n   320→      }\n   321→      child.kill('SIGTERM');\n   322→\n   323→      // Schedule SIGKILL if process doesn't exit\n   324→      setTimeout(() => {\n   325→        if (sessionStore.getActiveProcess(sessionKey)) {\n   326→          child.kill('SIGKILL');\n   327→        }\n   328→      }, 5000);\n   329→    };\n   330→\n   331→    if (signal) {\n   332→      signal.addEventListener('abort', onAbort);\n   333→    }\n   334→\n   335→    // Heartbeat setup\n   336→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n   337→      heartbeatManager.start({\n   338→        callback: () => {\n   339→          const elapsedMs = Date.now() - startedAt;\n   340→          hooks.onHeartbeat({\n   341→            elapsedMs,\n   342→            stdoutBytes,\n   343→            status: 'running'\n   344→          });\n   345→        },\n   346→        intervalMs: effectiveHeartbeatIntervalMs,\n   347→        thresholdMs: effectiveHeartbeatThresholdMs\n   348→      });\n   349→    }\n   350→\n   351→    // Cleanup function\n   352→    function cleanup() {\n   353→      if (timeout) {\n   354→        clearTimeout(timeout);\n   355→      }\n   356→      heartbeatManager.stop();\n   357→      sessionStore.clearActiveProcess(sessionKey);\n   358→      if (signal) {\n   359→        signal.removeEventListener('abort', onAbort);\n   360→      }\n   361→    }\n   362→\n   363→    // Handle process close\n   364→    child.on('close', (code) => {\n   365→      const elapsedMs = Date.now() - startedAt;\n   366→\n   367→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n   368→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n   369→      if (storedInfo) {\n   370→        if (storedInfo.interrupted) {\n   371→          interrupted = true;\n   372→        }\n   373→        if (storedInfo.timedOut) {\n   374→          timedOut = true;\n   375→        }\n   376→      }\n   377→\n   378→      cleanup();\n   379→\n   380→      logger.info(\n   381→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n   382→        'AI CLI process closed'\n   383→      );\n   384→\n   385→      // Build output\n   386→      let output = stdout.trim();\n   387→\n   388→      if (interrupted) {\n   389→        output = output || '任务已被用户中断。';\n   390→      } else if (timedOut) {\n   391→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n   392→      } else if (code !== 0) {\n   393→        output = output || `AI CLI 退出码 ${code}。`;\n   394→        if (stderr.trim()) {\n   395→          output += `\\n错误信息:\\n${stderr.trim()}`;\n   396→        }\n   397→      }\n   398→\n   399→      // Record metrics (T-051)\n   400→      recordMetrics({\n   401→        elapsedMs,\n   402→        stdoutBytes,\n   403→        success: code === 0 && !interrupted && !timedOut,\n   404→        timedOut,\n   405→        interrupted\n   406→      });\n   407→\n   408→      resolve({\n   409→        output: output || 'AI CLI 未返回文本结果。',\n   410→        timedOut,\n   411→        interrupted,\n   412→        elapsedMs,\n   413→        exitCode: code,\n   414→        stderr: stderr.trim()\n   415→      });\n   416→    });\n   417→  });\n   418→}\n   419→\n   420→/**\n   421→ * Interrupt running AI CLI task for a session.\n   422→ * @param {string} sessionId - Session identifier\n   423→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n   424→ */\n   425→export function interruptAiCli(sessionId) {\n   426→  const processInfo = sessionStore.getActiveProcess(sessionId);\n   427→\n   428→  if (!processInfo) {\n   429→    return { ok: false, error: '没有正在执行的任务。' };\n   430→  }\n   431→\n   432→  const { pid, childProcess } = processInfo;\n   433→\n   434→  try {\n   435→    // Mark as interrupted so close handler knows\n   436→    processInfo.interrupted = true;\n   437→\n   438→    // Send SIGTERM first\n   439→    childProcess.kill('SIGTERM');\n   440→\n   441→    // Schedule SIGKILL as backup\n   442→    setTimeout(() => {\n   443→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n   444→      if (stillRunning) {\n   445→        try {\n   446→          childProcess.kill('SIGKILL');\n   447→        } catch {\n   448→          // Process already dead\n   449→        }\n   450→      }\n   451→    }, 5000);\n   452→\n   453→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n   454→\n   455→    return { ok: true, pid };\n   456→  } catch (err) {\n   457→    return { ok: false, error: `中断失败: ${err.message}` };\n   458→  }\n   459→}\n   460→\n   461→/**\n   462→ * Check if AI CLI is running for a session.\n   463→ * @param {string} sessionId\n   464→ * @returns {boolean}\n   465→ */\n   466→export function isAiCliRunning(sessionId) {\n   467→  return sessionStore.getActiveProcess(sessionId) !== null;\n   468→}\n   469→\n   470→/**\n   471→ * Get active process info for a session.\n   472→ * @param {string} sessionId\n   473→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n   474→ */\n   475→export function getActiveProcessInfo(sessionId) {\n   476→  const info = sessionStore.getActiveProcess(sessionId);\n   477→  if (!info) {\n   478→    return null;\n   479→  }\n   480→\n   481→  // Don't expose childProcess to external callers\n   482→  return {\n   483→    pid: info.pid,\n   484→    startedAt: info.startedAt,\n   485→    stdoutBytes: info.stdoutBytes ?? 0,\n   486→    userId: info.userId\n   487→  };\n   488→}\n   489→\n   490→/**\n   491→ * Check if user can interrupt AI CLI task.\n   492→ * @param {string} sessionId - Session identifier\n   493→ * @param {string|number} requestUserId - User requesting interrupt\n   494→ * @param {Function} isAdminFn - Function to check if user is admin\n   495→ * @returns {{ canInterrupt: boolean, reason?: string }}\n   496→ */\n   497→export function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n   498→  const processInfo = sessionStore.getActiveProcess(sessionId);\n   499→\n   500→  if (!processInfo) {\n   501→    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n   502→  }\n   503→\n   504→  // Admin can always interrupt\n   505→  if (isAdminFn && isAdminFn(requestUserId)) {\n   506→    return { canInterrupt: true };\n   507→  }\n   508→\n   509→  // Task owner can interrupt\n   510→  const taskUserId = processInfo.userId;\n   511→  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n   512→    return { canInterrupt: true };\n   513→  }\n   514→\n   515→  // Otherwise, permission denied\n   516→  return {\n   517→    canInterrupt: false,\n   518→    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n   519→  };\n   520→}\n   521→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6c8ebc62-648e-4d09-8200-69d30faee4f6","uuid":"2b68eb2d-323e-4e23-9582-9bdb9c8488ae","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/src/services/ai-cli-service.js","content":"/**\n * F-011: AI CLI Service\n *\n * Encapsulates AI CLI execution logic with process tracking,\n * heartbeat, and interrupt support.\n *\n * T-051: Metrics tracking for monitoring\n */\n\nimport { spawn } from 'node:child_process';\nimport { config } from '../config.js';\nimport { logger } from '../utils/logger.js';\nimport { sessionStore } from './session-store.js';\nimport { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n\n/**\n * Metrics for AI CLI execution monitoring.\n * T-051: Track execution statistics\n */\nconst metrics = {\n  // Execution counts\n  totalExecutions: 0,\n  successCount: 0,\n  failureCount: 0,\n  timeoutCount: 0,\n  interruptCount: 0,\n\n  // Duration tracking (for histogram)\n  durations: [],\n  maxDurations: 100, // Keep last 100 durations\n\n  // Output size tracking\n  outputSizes: [],\n  maxOutputSizes: 100\n};\n\n/**\n * Get current metrics snapshot.\n * @returns {Object} Metrics snapshot\n */\nexport function getMetrics() {\n  const durations = [...metrics.durations];\n  const outputSizes = [...metrics.outputSizes];\n\n  return {\n    totalExecutions: metrics.totalExecutions,\n    successCount: metrics.successCount,\n    failureCount: metrics.failureCount,\n    timeoutCount: metrics.timeoutCount,\n    interruptCount: metrics.interruptCount,\n    averageDurationMs: durations.length > 0\n      ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length)\n      : 0,\n    minDurationMs: durations.length > 0 ? Math.min(...durations) : 0,\n    maxDurationMs: durations.length > 0 ? Math.max(...durations) : 0,\n    averageOutputBytes: outputSizes.length > 0\n      ? Math.round(outputSizes.reduce((a, b) => a + b, 0) / outputSizes.length)\n      : 0\n  };\n}\n\n/**\n * Record execution metrics.\n * @param {Object} result - Execution result\n * @param {number} result.elapsedMs - Execution duration\n * @param {number} result.stdoutBytes - Output size\n * @param {boolean} result.success - Whether execution succeeded\n * @param {boolean} result.timedOut - Whether execution timed out\n * @param {boolean} result.interrupted - Whether execution was interrupted\n */\nfunction recordMetrics(result) {\n  metrics.totalExecutions++;\n\n  // Track duration\n  metrics.durations.push(result.elapsedMs);\n  if (metrics.durations.length > metrics.maxDurations) {\n    metrics.durations.shift();\n  }\n\n  // Track output size\n  metrics.outputSizes.push(result.stdoutBytes || 0);\n  if (metrics.outputSizes.length > metrics.maxOutputSizes) {\n    metrics.outputSizes.shift();\n  }\n\n  // Track outcome\n  if (result.interrupted) {\n    metrics.interruptCount++;\n  } else if (result.timedOut) {\n    metrics.timeoutCount++;\n  } else if (result.success) {\n    metrics.successCount++;\n  } else {\n    metrics.failureCount++;\n  }\n\n  // Log metrics at debug level\n  logger.debug(\n    {\n      totalExecutions: metrics.totalExecutions,\n      successRate: `${Math.round((metrics.successCount / metrics.totalExecutions) * 100)}%`,\n      interruptRate: `${Math.round((metrics.interruptCount / metrics.totalExecutions) * 100)}%`,\n      timeoutRate: `${Math.round((metrics.timeoutCount / metrics.totalExecutions) * 100)}%`\n    },\n    'AI CLI metrics updated'\n  );\n}\n\n/**\n * Reset metrics (useful for testing).\n */\nexport function resetMetrics() {\n  metrics.totalExecutions = 0;\n  metrics.successCount = 0;\n  metrics.failureCount = 0;\n  metrics.timeoutCount = 0;\n  metrics.interruptCount = 0;\n  metrics.durations = [];\n  metrics.outputSizes = [];\n}\n\n/**\n * @typedef {Object} AiCliExecutionOptions\n * @property {string} sessionId - Session identifier\n * @property {string} prompt - User prompt/input\n * @property {string} [userId] - User ID who initiated the task (for permission checks)\n * @property {Object} [hooks] - Callback hooks\n * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n * @property {AbortSignal} [signal] - Optional abort signal\n * @property {number} [timeoutMs] - Optional timeout override\n * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n * @property {string} [bin] - Optional binary override (for testing)\n * @property {string[]} [args] - Optional args override (for testing, replaces default args)\n */\n\n/**\n * @typedef {Object} AiCliExecutionResult\n * @property {string} output - Final output text\n * @property {boolean} timedOut - Whether execution timed out\n * @property {boolean} interrupted - Whether execution was interrupted\n * @property {number} elapsedMs - Execution time in milliseconds\n * @property {number|null} exitCode - Process exit code (if completed)\n * @property {string} stderr - Error output if any\n */\n\n/**\n * @typedef {Object} HeartbeatInfo\n * @property {number} elapsedMs - Elapsed time in milliseconds\n * @property {number} stdoutBytes - Bytes received so far\n * @property {string} status - Current status ('running', 'streaming')\n */\n\n/**\n * Write text to echo output for debugging.\n * @param {string} tag - Tag for the output\n * @param {string} text - Text to write\n */\nfunction writeEcho(tag, text) {\n  const normalized = String(text ?? '');\n  if (!normalized) {\n    return;\n  }\n\n  const lines = normalized.split(/\\r?\\n/);\n  for (const line of lines) {\n    if (!line) {\n      continue;\n    }\n    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  }\n}\n\n/**\n * Execute AI CLI with session context and process tracking.\n * @param {AiCliExecutionOptions} options\n * @returns {Promise<AiCliExecutionResult>}\n */\nexport async function executeAiCli(options) {\n  const {\n    sessionId,\n    prompt,\n    userId,\n    hooks = {},\n    signal,\n    timeoutMs,\n    heartbeatThresholdMs,\n    heartbeatIntervalMs,\n    bin,\n    args: customArgs\n  } = options;\n\n  const effectiveBin = bin || config.codebuddyBin;\n  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n  const enableHeartbeat = config.aiCliEnableHeartbeat;\n\n  // Use custom args if provided (for testing), otherwise build default args\n  const args = customArgs ?? (() => {\n    const defaultArgs = ['-p', prompt];\n    if (config.codebuddyPermissionFlag) {\n      defaultArgs.push(config.codebuddyPermissionFlag);\n    }\n    return defaultArgs;\n  })();\n\n  return new Promise((resolve) => {\n    let stdout = '';\n    let stderr = '';\n    let stdoutBytes = 0;\n    let interrupted = false;\n    let timedOut = false;\n    const startedAt = Date.now();\n    const sessionKey = sessionId;\n\n    // Heartbeat manager\n    const heartbeatManager = createHeartbeatManager();\n\n    // Spawn process\n    let child;\n    try {\n      child = spawn(effectiveBin, args, {\n        stdio: ['ignore', 'pipe', 'pipe']\n      });\n    } catch (err) {\n      resolve({\n        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n        timedOut: false,\n        interrupted: false,\n        elapsedMs: Date.now() - startedAt,\n        exitCode: null,\n        stderr: ''\n      });\n      return;\n    }\n\n    // Track process in session store\n    sessionStore.setActiveProcess(sessionKey, {\n      pid: child.pid,\n      startedAt,\n      childProcess: child,\n      interrupted: false,\n      timedOut: false,\n      userId\n    });\n\n    logger.info({ pid: child.pid, bin: effectiveBin, args, sessionId }, 'AI CLI process started');\n\n    // Handle process error\n    child.on('error', (err) => {\n      cleanup();\n      resolve({\n        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n        timedOut: false,\n        interrupted: false,\n        elapsedMs: Date.now() - startedAt,\n        exitCode: null,\n        stderr\n      });\n    });\n\n    // Handle stdout\n    child.stdout.on('data', (chunk) => {\n      const text = chunk.toString();\n      stdout += text;\n      stdoutBytes += Buffer.byteLength(text);\n\n      // Update session store byte count\n      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n\n      // Echo to console if enabled\n      if (config.codebuddyEchoStdio) {\n        writeEcho('stdout', text);\n      }\n\n      // Call onChunk hook\n      if (typeof hooks.onChunk === 'function') {\n        hooks.onChunk(text);\n      }\n    });\n\n    // Handle stderr\n    child.stderr.on('data', (chunk) => {\n      const text = chunk.toString();\n      stderr += text;\n\n      if (config.codebuddyEchoStdio) {\n        writeEcho('stderr', text);\n      }\n    });\n\n    // Timeout handler\n    const timeout = effectiveTimeoutMs > 0\n      ? setTimeout(() => {\n          timedOut = true;\n          const info = sessionStore.getActiveProcess(sessionKey);\n          if (info) {\n            info.timedOut = true;\n          }\n          child.kill('SIGTERM');\n\n          // Schedule SIGKILL if process doesn't exit\n          setTimeout(() => {\n            if (sessionStore.getActiveProcess(sessionKey)) {\n              child.kill('SIGKILL');\n            }\n          }, 5000);\n        }, effectiveTimeoutMs)\n      : null;\n\n    // Abort signal handler\n    const onAbort = () => {\n      interrupted = true;\n      const info = sessionStore.getActiveProcess(sessionKey);\n      if (info) {\n        info.interrupted = true;\n      }\n      child.kill('SIGTERM');\n\n      // Schedule SIGKILL if process doesn't exit\n      setTimeout(() => {\n        if (sessionStore.getActiveProcess(sessionKey)) {\n          child.kill('SIGKILL');\n        }\n      }, 5000);\n    };\n\n    if (signal) {\n      signal.addEventListener('abort', onAbort);\n    }\n\n    // Heartbeat setup\n    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n      heartbeatManager.start({\n        callback: () => {\n          const elapsedMs = Date.now() - startedAt;\n          hooks.onHeartbeat({\n            elapsedMs,\n            stdoutBytes,\n            status: 'running'\n          });\n        },\n        intervalMs: effectiveHeartbeatIntervalMs,\n        thresholdMs: effectiveHeartbeatThresholdMs\n      });\n    }\n\n    // Cleanup function\n    function cleanup() {\n      if (timeout) {\n        clearTimeout(timeout);\n      }\n      heartbeatManager.stop();\n      sessionStore.clearActiveProcess(sessionKey);\n      if (signal) {\n        signal.removeEventListener('abort', onAbort);\n      }\n    }\n\n    // Handle process close\n    child.on('close', (code) => {\n      const elapsedMs = Date.now() - startedAt;\n\n      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n      if (storedInfo) {\n        if (storedInfo.interrupted) {\n          interrupted = true;\n        }\n        if (storedInfo.timedOut) {\n          timedOut = true;\n        }\n      }\n\n      cleanup();\n\n      logger.info(\n        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n        'AI CLI process closed'\n      );\n\n      // Build output\n      let output = stdout.trim();\n\n      if (interrupted) {\n        output = output || '任务已被用户中断。';\n      } else if (timedOut) {\n        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n      } else if (code !== 0) {\n        output = output || `AI CLI 退出码 ${code}。`;\n        if (stderr.trim()) {\n          output += `\\n错误信息:\\n${stderr.trim()}`;\n        }\n      }\n\n      // Record metrics (T-051)\n      recordMetrics({\n        elapsedMs,\n        stdoutBytes,\n        success: code === 0 && !interrupted && !timedOut,\n        timedOut,\n        interrupted\n      });\n\n      resolve({\n        output: output || 'AI CLI 未返回文本结果。',\n        timedOut,\n        interrupted,\n        elapsedMs,\n        exitCode: code,\n        stderr: stderr.trim()\n      });\n    });\n  });\n}\n\n/**\n * Interrupt running AI CLI task for a session.\n * @param {string} sessionId - Session identifier\n * @returns {{ ok: boolean, pid?: number, error?: string }}\n */\nexport function interruptAiCli(sessionId) {\n  const processInfo = sessionStore.getActiveProcess(sessionId);\n\n  if (!processInfo) {\n    return { ok: false, error: '没有正在执行的任务。' };\n  }\n\n  const { pid, childProcess } = processInfo;\n\n  try {\n    // Mark as interrupted so close handler knows\n    processInfo.interrupted = true;\n\n    // Send SIGTERM first\n    childProcess.kill('SIGTERM');\n\n    // Schedule SIGKILL as backup\n    setTimeout(() => {\n      const stillRunning = sessionStore.getActiveProcess(sessionId);\n      if (stillRunning) {\n        try {\n          childProcess.kill('SIGKILL');\n        } catch {\n          // Process already dead\n        }\n      }\n    }, 5000);\n\n    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n\n    return { ok: true, pid };\n  } catch (err) {\n    return { ok: false, error: `中断失败: ${err.message}` };\n  }\n}\n\n/**\n * Check if AI CLI is running for a session.\n * @param {string} sessionId\n * @returns {boolean}\n */\nexport function isAiCliRunning(sessionId) {\n  return sessionStore.getActiveProcess(sessionId) !== null;\n}\n\n/**\n * Get active process info for a session.\n * @param {string} sessionId\n * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n */\nexport function getActiveProcessInfo(sessionId) {\n  const info = sessionStore.getActiveProcess(sessionId);\n  if (!info) {\n    return null;\n  }\n\n  // Don't expose childProcess to external callers\n  return {\n    pid: info.pid,\n    startedAt: info.startedAt,\n    stdoutBytes: info.stdoutBytes ?? 0,\n    userId: info.userId\n  };\n}\n\n/**\n * Check if user can interrupt AI CLI task.\n * @param {string} sessionId - Session identifier\n * @param {string|number} requestUserId - User requesting interrupt\n * @param {Function} isAdminFn - Function to check if user is admin\n * @returns {{ canInterrupt: boolean, reason?: string }}\n */\nexport function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n  const processInfo = sessionStore.getActiveProcess(sessionId);\n\n  if (!processInfo) {\n    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n  }\n\n  // Admin can always interrupt\n  if (isAdminFn && isAdminFn(requestUserId)) {\n    return { canInterrupt: true };\n  }\n\n  // Task owner can interrupt\n  const taskUserId = processInfo.userId;\n  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n    return { canInterrupt: true };\n  }\n\n  // Otherwise, permission denied\n  return {\n    canInterrupt: false,\n    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n  };\n}\n","numLines":521,"startLine":1,"totalLines":521}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_027a2bbcd2984061a67d7c46","type":"tool_result","content":"     1→/**\n     2→ * Session Context Service\n     3→ * F-013: Session and Context Manager\n     4→ *\n     5→ * Manages session lifecycle, persistence, and timeout handling.\n     6→ * Coordinates with sessionStore for in-memory session state.\n     7→ */\n     8→\n     9→import { mkdir, readFile, writeFile, unlink, readdir } from 'node:fs/promises';\n    10→import { join } from 'node:path';\n    11→import { config } from '../config.js';\n    12→import { sessionStore } from './session-store.js';\n    13→\n    14→/**\n    15→ * @typedef {Object} SessionContextService\n    16→ * @property {Function} initSessionContext - Initialize with data directory\n    17→ * @property {Function} createSession - Create new session\n    18→ * @property {Function} getOrCreateSession - Get existing or create new\n    19→ * @property {Function} touchSession - Update activity timestamp\n    20→ * @property {Function} cleanupSession - Clear session data\n    21→ * @property {Function} persistSession - Save to disk\n    22→ * @property {Function} restoreSessions - Load from disk on startup\n    23→ * @property {Function} startTimeoutWatcher - Start interval to check timeouts\n    24→ * @property {Function} stopTimeoutWatcher - Stop interval on shutdown\n    25→ * @property {Function} setNotificationCallback - Set callback for timeout notifications\n    26→ * @property {Function} isWatcherRunning - Check if watcher is active\n    27→ */\n    28→\n    29→class SessionContextServiceClass {\n    30→  #dataDir = null;\n    31→  #notificationCallback = null;\n    32→  #timeoutWatcherId = null;\n    33→  #isInitialized = false;\n    34→  #timeoutMs = null;\n    35→  #checkIntervalMs = null;\n    36→\n    37→  /**\n    38→   * Reset the service state (for testing).\n    39→   */\n    40→  reset() {\n    41→    this.#dataDir = null;\n    42→    this.#notificationCallback = null;\n    43→    if (this.#timeoutWatcherId) {\n    44→      clearInterval(this.#timeoutWatcherId);\n    45→      this.#timeoutWatcherId = null;\n    46→    }\n    47→    this.#isInitialized = false;\n    48→    this.#timeoutMs = null;\n    49→    this.#checkIntervalMs = null;\n    50→  }\n    51→\n    52→  /**\n    53→   * Check if service is initialized.\n    54→   * @returns {boolean}\n    55→   */\n    56→  isInitialized() {\n    57→    return this.#isInitialized;\n    58→  }\n    59→\n    60→  /**\n    61→   * Initialize the session context service.\n    62→   * @param {Object} options - Initialization options\n    63→   * @param {string} options.dataDir - Directory for session persistence\n    64→   * @param {number} [options.timeoutMs] - Session timeout in ms (default: from config)\n    65→   * @param {number} [options.checkIntervalMs] - Timeout check interval in ms (default: 60000)\n    66→   */\n    67→  initSessionContext({ dataDir, timeoutMs, checkIntervalMs }) {\n    68→    this.#dataDir = dataDir;\n    69→    this.#timeoutMs = timeoutMs || config.sessionTimeoutMs;\n    70→    this.#checkIntervalMs = checkIntervalMs || 60000;\n    71→    this.#isInitialized = true;\n    72→  }\n    73→\n    74→  /**\n    75→   * Check if service is initialized.\n    76→   * @throws {Error} If not initialized\n    77→   */\n    78→  #checkInitialized() {\n    79→    if (!this.#isInitialized) {\n    80→      throw new Error('SessionContextService not initialized. Call initSessionContext first.');\n    81→    }\n    82→  }\n    83→\n    84→  /**\n    85→   * Ensure data directory exists.\n    86→   */\n    87→  async #ensureDataDir() {\n    88→    if (this.#dataDir) {\n    89→      await mkdir(this.#dataDir, { recursive: true });\n    90→    }\n    91→  }\n    92→\n    93→  /**\n    94→   * Create a new session.\n    95→   * @param {string} sessionKey - Session identifier\n    96→   * @param {string} userId - Telegram user ID\n    97→   * @returns {Object} Created session info\n    98→   */\n    99→  createSession(sessionKey, userId) {\n   100→    this.#checkInitialized();\n   101→\n   102→    // Create in sessionStore - touchSession will set createdAt if new\n   103→    sessionStore.touchSession(sessionKey, userId);\n   104→    sessionStore.setUserId(sessionKey, userId);\n   105→\n   106→    return sessionStore.getSessionInfo(sessionKey);\n   107→  }\n   108→\n   109→  /**\n   110→   * Get existing session or create new one.\n   111→   * @param {string} sessionKey - Session identifier\n   112→   * @param {string} userId - Telegram user ID\n   113→   * @returns {Object} Session info\n   114→   */\n   115→  getOrCreateSession(sessionKey, userId) {\n   116→    this.#checkInitialized();\n   117→\n   118→    const existing = sessionStore.getSessionInfo(sessionKey);\n   119→    if (existing) {\n   120→      // Update userId if different\n   121→      if (existing.userId !== userId) {\n   122→        sessionStore.setUserId(sessionKey, userId);\n   123→      }\n   124→      // Return fresh info from sessionStore\n   125→      return sessionStore.getSessionInfo(sessionKey);\n   126→    }\n   127→\n   128→    return this.createSession(sessionKey, userId);\n   129→  }\n   130→\n   131→  /**\n   132→   * Update session activity timestamp.\n   133→   * @param {string} sessionKey - Session identifier\n   134→   */\n   135→  touchSession(sessionKey) {\n   136→    this.#checkInitialized();\n   137→\n   138→    // sessionStore.touchSession will set createdAt if new\n   139→    const userId = sessionStore.getUserId(sessionKey) || undefined;\n   140→    sessionStore.touchSession(sessionKey, userId);\n   141→  }\n   142→\n   143→  /**\n   144→   * Cleanup a session - clear from memory and delete persisted file.\n   145→   * @param {string} sessionKey - Session identifier\n   146→   */\n   147→  cleanupSession(sessionKey) {\n   148→    this.#checkInitialized();\n   149→\n   150→    // Get userId before clearing for notification\n   151→    const userId = sessionStore.getUserId(sessionKey);\n   152→\n   153→    // Clear from sessionStore\n   154→    sessionStore.clear(sessionKey);\n   155→\n   156→    // Delete persisted file (async, fire-and-forget)\n   157→    this.#deleteSessionFile(sessionKey);\n   158→\n   159→    // Notify if callback set\n   160→    if (this.#notificationCallback && userId) {\n   161→      this.#notificationCallback(sessionKey, userId);\n   162→    }\n   163→  }\n   164→\n   165→  /**\n   166→   * Delete session file from disk.\n   167→   * @param {string} sessionKey - Session identifier\n   168→   */\n   169→  async #deleteSessionFile(sessionKey) {\n   170→    const filePath = this.#getSessionFilePath(sessionKey);\n   171→    try {\n   172→      await unlink(filePath);\n   173→    } catch {\n   174→      // Ignore if file doesn't exist\n   175→    }\n   176→  }\n   177→\n   178→  /**\n   179→   * Set notification callback for session cleanup.\n   180→   * @param {Function} callback - Function(sessionKey, userId)\n   181→   */\n   182→  setNotificationCallback(callback) {\n   183→    this.#notificationCallback = callback;\n   184→  }\n   185→\n   186→  /**\n   187→   * Get file path for a session file.\n   188→   * @param {string} sessionKey - Session identifier\n   189→   * @returns {string} File path\n   190→   */\n   191→  #getSessionFilePath(sessionKey) {\n   192→    // Replace colons with underscores for filesystem compatibility\n   193→    const safeFileName = sessionKey.replace(/:/g, '_');\n   194→    return join(this.#dataDir, `${safeFileName}.json`);\n   195→  }\n   196→\n   197→  /**\n   198→   * Persist a session to disk.\n   199→   * @param {string} sessionKey - Session identifier\n   200→   */\n   201→  async persistSession(sessionKey) {\n   202→    this.#checkInitialized();\n   203→    await this.#ensureDataDir();\n   204→\n   205→    const info = sessionStore.getSessionInfo(sessionKey);\n   206→    if (!info) {\n   207→      throw new Error(`Session ${sessionKey} not found`);\n   208→    }\n   209→\n   210→    const data = {\n   211→      sessionKey: info.sessionKey,\n   212→      userId: info.userId,\n   213→      cwd: sessionStore.getCwd(sessionKey),\n   214→      envOverrides: sessionStore.getEnvOverrides(sessionKey),\n   215→      commandHistory: sessionStore.getCommandHistory(sessionKey),\n   216→      createdAt: info.createdAt,\n   217→      lastActivityAt: info.lastActivityAt\n   218→    };\n   219→\n   220→    const filePath = this.#getSessionFilePath(sessionKey);\n   221→    await writeFile(filePath, JSON.stringify(data, null, 2));\n   222→  }\n   223→\n   224→  /**\n   225→   * Restore sessions from disk.\n   226→   */\n   227→  async restoreSessions() {\n   228→    this.#checkInitialized();\n   229→\n   230→    try {\n   231→      const files = await readdir(this.#dataDir);\n   232→      const sessionFiles = files.filter((f) => f.endsWith('.json'));\n   233→\n   234→      for (const file of sessionFiles) {\n   235→        try {\n   236→          const filePath = join(this.#dataDir, file);\n   237→          const content = await readFile(filePath, 'utf-8');\n   238→          const data = JSON.parse(content);\n   239→\n   240→          // Check if session has expired\n   241→          const idleTime = Date.now() - (data.lastActivityAt || 0);\n   242→          const timeoutMs = this.#timeoutMs;\n   243→\n   244→          if (idleTime > timeoutMs) {\n   245→            // Session expired, delete file\n   246→            await unlink(filePath);\n   247→            continue;\n   248→          }\n   249→\n   250→          // Restore to sessionStore\n   251→          const { sessionKey, userId, cwd, envOverrides } = data;\n   252→\n   253→          // Set userId and timestamps\n   254→          sessionStore.touchSession(sessionKey, userId);\n   255→\n   256→          // Restore cwd\n   257→          if (cwd) {\n   258→            sessionStore.setCwd(sessionKey, cwd);\n   259→          }\n   260→\n   261→          // Restore env overrides\n   262→          for (const [key, value] of Object.entries(envOverrides || {})) {\n   263→            sessionStore.setEnvOverride(sessionKey, key, value);\n   264→          }\n   265→\n   266→          // Note: commandHistory is stored in the file but we don't restore it\n   267→          // to sessionStore because it's mainly for historical reference.\n   268→\n   269→        } catch (error) {\n   270→          // Log error but continue with other files\n   271→          console.error(`Failed to restore session from ${file}:`, error.message);\n   272→        }\n   273→      }\n   274→    } catch (error) {\n   275→      // Directory might not exist yet\n   276→      if (error.code !== 'ENOENT') {\n   277→        throw error;\n   278→      }\n   279→    }\n   280→  }\n   281→\n   282→  /**\n   283→   * Start the timeout watcher.\n   284→   */\n   285→  startTimeoutWatcher() {\n   286→    if (this.#timeoutWatcherId) {\n   287→      // Already running\n   288→      return;\n   289→    }\n   290→\n   291→    this.#timeoutWatcherId = setInterval(() => {\n   292→      this.#checkTimeouts();\n   293→    }, this.#checkIntervalMs);\n   294→\n   295→    // Prevent the interval from keeping the process alive\n   296→    this.#timeoutWatcherId.unref?.();\n   297→  }\n   298→\n   299→  /**\n   300→   * Check all sessions for timeout.\n   301→   */\n   302→  #checkTimeouts() {\n   303→    const sessionKeys = sessionStore.getAllSessionKeys();\n   304→\n   305→    for (const sessionKey of sessionKeys) {\n   306→      const idleTime = sessionStore.getIdleTime(sessionKey);\n   307→\n   308→      if (idleTime !== null && idleTime > this.#timeoutMs) {\n   309→        // Session expired\n   310→        this.cleanupSession(sessionKey);\n   311→      }\n   312→    }\n   313→  }\n   314→\n   315→  /**\n   316→   * Stop the timeout watcher.\n   317→   */\n   318→  stopTimeoutWatcher() {\n   319→    if (this.#timeoutWatcherId) {\n   320→      clearInterval(this.#timeoutWatcherId);\n   321→      this.#timeoutWatcherId = null;\n   322→    }\n   323→  }\n   324→\n   325→  /**\n   326→   * Check if the timeout watcher is running.\n   327→   * @returns {boolean}\n   328→   */\n   329→  isWatcherRunning() {\n   330→    return this.#timeoutWatcherId !== null;\n   331→  }\n   332→}\n   333→\n   334→export const sessionContextService = new SessionContextServiceClass();\n   335→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6c8ebc62-648e-4d09-8200-69d30faee4f6","uuid":"8f7a49e2-e4f6-4a8f-b15a-b27b55096092","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/src/services/session-context-service.js","content":"/**\n * Session Context Service\n * F-013: Session and Context Manager\n *\n * Manages session lifecycle, persistence, and timeout handling.\n * Coordinates with sessionStore for in-memory session state.\n */\n\nimport { mkdir, readFile, writeFile, unlink, readdir } from 'node:fs/promises';\nimport { join } from 'node:path';\nimport { config } from '../config.js';\nimport { sessionStore } from './session-store.js';\n\n/**\n * @typedef {Object} SessionContextService\n * @property {Function} initSessionContext - Initialize with data directory\n * @property {Function} createSession - Create new session\n * @property {Function} getOrCreateSession - Get existing or create new\n * @property {Function} touchSession - Update activity timestamp\n * @property {Function} cleanupSession - Clear session data\n * @property {Function} persistSession - Save to disk\n * @property {Function} restoreSessions - Load from disk on startup\n * @property {Function} startTimeoutWatcher - Start interval to check timeouts\n * @property {Function} stopTimeoutWatcher - Stop interval on shutdown\n * @property {Function} setNotificationCallback - Set callback for timeout notifications\n * @property {Function} isWatcherRunning - Check if watcher is active\n */\n\nclass SessionContextServiceClass {\n  #dataDir = null;\n  #notificationCallback = null;\n  #timeoutWatcherId = null;\n  #isInitialized = false;\n  #timeoutMs = null;\n  #checkIntervalMs = null;\n\n  /**\n   * Reset the service state (for testing).\n   */\n  reset() {\n    this.#dataDir = null;\n    this.#notificationCallback = null;\n    if (this.#timeoutWatcherId) {\n      clearInterval(this.#timeoutWatcherId);\n      this.#timeoutWatcherId = null;\n    }\n    this.#isInitialized = false;\n    this.#timeoutMs = null;\n    this.#checkIntervalMs = null;\n  }\n\n  /**\n   * Check if service is initialized.\n   * @returns {boolean}\n   */\n  isInitialized() {\n    return this.#isInitialized;\n  }\n\n  /**\n   * Initialize the session context service.\n   * @param {Object} options - Initialization options\n   * @param {string} options.dataDir - Directory for session persistence\n   * @param {number} [options.timeoutMs] - Session timeout in ms (default: from config)\n   * @param {number} [options.checkIntervalMs] - Timeout check interval in ms (default: 60000)\n   */\n  initSessionContext({ dataDir, timeoutMs, checkIntervalMs }) {\n    this.#dataDir = dataDir;\n    this.#timeoutMs = timeoutMs || config.sessionTimeoutMs;\n    this.#checkIntervalMs = checkIntervalMs || 60000;\n    this.#isInitialized = true;\n  }\n\n  /**\n   * Check if service is initialized.\n   * @throws {Error} If not initialized\n   */\n  #checkInitialized() {\n    if (!this.#isInitialized) {\n      throw new Error('SessionContextService not initialized. Call initSessionContext first.');\n    }\n  }\n\n  /**\n   * Ensure data directory exists.\n   */\n  async #ensureDataDir() {\n    if (this.#dataDir) {\n      await mkdir(this.#dataDir, { recursive: true });\n    }\n  }\n\n  /**\n   * Create a new session.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} userId - Telegram user ID\n   * @returns {Object} Created session info\n   */\n  createSession(sessionKey, userId) {\n    this.#checkInitialized();\n\n    // Create in sessionStore - touchSession will set createdAt if new\n    sessionStore.touchSession(sessionKey, userId);\n    sessionStore.setUserId(sessionKey, userId);\n\n    return sessionStore.getSessionInfo(sessionKey);\n  }\n\n  /**\n   * Get existing session or create new one.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} userId - Telegram user ID\n   * @returns {Object} Session info\n   */\n  getOrCreateSession(sessionKey, userId) {\n    this.#checkInitialized();\n\n    const existing = sessionStore.getSessionInfo(sessionKey);\n    if (existing) {\n      // Update userId if different\n      if (existing.userId !== userId) {\n        sessionStore.setUserId(sessionKey, userId);\n      }\n      // Return fresh info from sessionStore\n      return sessionStore.getSessionInfo(sessionKey);\n    }\n\n    return this.createSession(sessionKey, userId);\n  }\n\n  /**\n   * Update session activity timestamp.\n   * @param {string} sessionKey - Session identifier\n   */\n  touchSession(sessionKey) {\n    this.#checkInitialized();\n\n    // sessionStore.touchSession will set createdAt if new\n    const userId = sessionStore.getUserId(sessionKey) || undefined;\n    sessionStore.touchSession(sessionKey, userId);\n  }\n\n  /**\n   * Cleanup a session - clear from memory and delete persisted file.\n   * @param {string} sessionKey - Session identifier\n   */\n  cleanupSession(sessionKey) {\n    this.#checkInitialized();\n\n    // Get userId before clearing for notification\n    const userId = sessionStore.getUserId(sessionKey);\n\n    // Clear from sessionStore\n    sessionStore.clear(sessionKey);\n\n    // Delete persisted file (async, fire-and-forget)\n    this.#deleteSessionFile(sessionKey);\n\n    // Notify if callback set\n    if (this.#notificationCallback && userId) {\n      this.#notificationCallback(sessionKey, userId);\n    }\n  }\n\n  /**\n   * Delete session file from disk.\n   * @param {string} sessionKey - Session identifier\n   */\n  async #deleteSessionFile(sessionKey) {\n    const filePath = this.#getSessionFilePath(sessionKey);\n    try {\n      await unlink(filePath);\n    } catch {\n      // Ignore if file doesn't exist\n    }\n  }\n\n  /**\n   * Set notification callback for session cleanup.\n   * @param {Function} callback - Function(sessionKey, userId)\n   */\n  setNotificationCallback(callback) {\n    this.#notificationCallback = callback;\n  }\n\n  /**\n   * Get file path for a session file.\n   * @param {string} sessionKey - Session identifier\n   * @returns {string} File path\n   */\n  #getSessionFilePath(sessionKey) {\n    // Replace colons with underscores for filesystem compatibility\n    const safeFileName = sessionKey.replace(/:/g, '_');\n    return join(this.#dataDir, `${safeFileName}.json`);\n  }\n\n  /**\n   * Persist a session to disk.\n   * @param {string} sessionKey - Session identifier\n   */\n  async persistSession(sessionKey) {\n    this.#checkInitialized();\n    await this.#ensureDataDir();\n\n    const info = sessionStore.getSessionInfo(sessionKey);\n    if (!info) {\n      throw new Error(`Session ${sessionKey} not found`);\n    }\n\n    const data = {\n      sessionKey: info.sessionKey,\n      userId: info.userId,\n      cwd: sessionStore.getCwd(sessionKey),\n      envOverrides: sessionStore.getEnvOverrides(sessionKey),\n      commandHistory: sessionStore.getCommandHistory(sessionKey),\n      createdAt: info.createdAt,\n      lastActivityAt: info.lastActivityAt\n    };\n\n    const filePath = this.#getSessionFilePath(sessionKey);\n    await writeFile(filePath, JSON.stringify(data, null, 2));\n  }\n\n  /**\n   * Restore sessions from disk.\n   */\n  async restoreSessions() {\n    this.#checkInitialized();\n\n    try {\n      const files = await readdir(this.#dataDir);\n      const sessionFiles = files.filter((f) => f.endsWith('.json'));\n\n      for (const file of sessionFiles) {\n        try {\n          const filePath = join(this.#dataDir, file);\n          const content = await readFile(filePath, 'utf-8');\n          const data = JSON.parse(content);\n\n          // Check if session has expired\n          const idleTime = Date.now() - (data.lastActivityAt || 0);\n          const timeoutMs = this.#timeoutMs;\n\n          if (idleTime > timeoutMs) {\n            // Session expired, delete file\n            await unlink(filePath);\n            continue;\n          }\n\n          // Restore to sessionStore\n          const { sessionKey, userId, cwd, envOverrides } = data;\n\n          // Set userId and timestamps\n          sessionStore.touchSession(sessionKey, userId);\n\n          // Restore cwd\n          if (cwd) {\n            sessionStore.setCwd(sessionKey, cwd);\n          }\n\n          // Restore env overrides\n          for (const [key, value] of Object.entries(envOverrides || {})) {\n            sessionStore.setEnvOverride(sessionKey, key, value);\n          }\n\n          // Note: commandHistory is stored in the file but we don't restore it\n          // to sessionStore because it's mainly for historical reference.\n\n        } catch (error) {\n          // Log error but continue with other files\n          console.error(`Failed to restore session from ${file}:`, error.message);\n        }\n      }\n    } catch (error) {\n      // Directory might not exist yet\n      if (error.code !== 'ENOENT') {\n        throw error;\n      }\n    }\n  }\n\n  /**\n   * Start the timeout watcher.\n   */\n  startTimeoutWatcher() {\n    if (this.#timeoutWatcherId) {\n      // Already running\n      return;\n    }\n\n    this.#timeoutWatcherId = setInterval(() => {\n      this.#checkTimeouts();\n    }, this.#checkIntervalMs);\n\n    // Prevent the interval from keeping the process alive\n    this.#timeoutWatcherId.unref?.();\n  }\n\n  /**\n   * Check all sessions for timeout.\n   */\n  #checkTimeouts() {\n    const sessionKeys = sessionStore.getAllSessionKeys();\n\n    for (const sessionKey of sessionKeys) {\n      const idleTime = sessionStore.getIdleTime(sessionKey);\n\n      if (idleTime !== null && idleTime > this.#timeoutMs) {\n        // Session expired\n        this.cleanupSession(sessionKey);\n      }\n    }\n  }\n\n  /**\n   * Stop the timeout watcher.\n   */\n  stopTimeoutWatcher() {\n    if (this.#timeoutWatcherId) {\n      clearInterval(this.#timeoutWatcherId);\n      this.#timeoutWatcherId = null;\n    }\n  }\n\n  /**\n   * Check if the timeout watcher is running.\n   * @returns {boolean}\n   */\n  isWatcherRunning() {\n    return this.#timeoutWatcherId !== null;\n  }\n}\n\nexport const sessionContextService = new SessionContextServiceClass();\n","numLines":335,"startLine":1,"totalLines":335}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_40c27474f4074ba88a4c2275","type":"tool_result","content":"     1→import { config } from '../config.js';\n     2→\n     3→class SessionStore {\n     4→  #messagesBySessionKey = new Map();\n     5→  #commitsBySessionKey = new Map();\n     6→  // F-009: Command executor extensions\n     7→  #cwdBySessionKey = new Map();\n     8→  #outputPagesBySessionKey = new Map();\n     9→  // F-010: File search results state for pagination\n    10→  #searchResultsBySessionKey = new Map();\n    11→  // F-011: AI CLI process tracking\n    12→  #activeProcessBySessionKey = new Map();\n    13→  // F-013: Session and Context Manager\n    14→  #commandHistoryBySessionKey = new Map();\n    15→  #envOverridesBySessionKey = new Map();\n    16→  #lastActivityBySessionKey = new Map();\n    17→  #userIdBySessionKey = new Map();\n    18→  #sessionCreatedAtBySessionKey = new Map();\n    19→\n    20→  get(sessionKey) {\n    21→    if (!this.#messagesBySessionKey.has(sessionKey)) {\n    22→      this.#messagesBySessionKey.set(sessionKey, []);\n    23→    }\n    24→    return this.#messagesBySessionKey.get(sessionKey);\n    25→  }\n    26→\n    27→  append(sessionKey, role, content) {\n    28→    const messages = this.get(sessionKey);\n    29→    messages.push({ role, content });\n    30→\n    31→    const maxMessages = config.maxHistoryTurns * 2;\n    32→    if (messages.length > maxMessages) {\n    33→      messages.splice(0, messages.length - maxMessages);\n    34→    }\n    35→  }\n    36→\n    37→  clear(sessionKey) {\n    38→    this.#messagesBySessionKey.delete(sessionKey);\n    39→    this.#commitsBySessionKey.delete(sessionKey);\n    40→    // F-009: Clear cwd and output pages\n    41→    this.#cwdBySessionKey.delete(sessionKey);\n    42→    this.#outputPagesBySessionKey.delete(sessionKey);\n    43→    // F-010: Clear search results\n    44→    this.#searchResultsBySessionKey.delete(sessionKey);\n    45→    // F-011: Clear active process\n    46→    this.#activeProcessBySessionKey.delete(sessionKey);\n    47→    // F-013: Clear session context data\n    48→    this.#commandHistoryBySessionKey.delete(sessionKey);\n    49→    this.#envOverridesBySessionKey.delete(sessionKey);\n    50→    this.#lastActivityBySessionKey.delete(sessionKey);\n    51→    this.#userIdBySessionKey.delete(sessionKey);\n    52→    this.#sessionCreatedAtBySessionKey.delete(sessionKey);\n    53→  }\n    54→\n    55→  toPrompt(sessionKey, channel = 'unknown') {\n    56→    const messages = this.get(sessionKey);\n    57→\n    58→    return [\n    59→      `你正在通过 ${channel} 渠道提供电脑助手服务。`,\n    60→      '请使用自然、简洁、可执行的表达。',\n    61→      '如果用户请求系统操作或截图，明确说明步骤与结果。',\n    62→      '当你产出本地文件（截图/文档）时，必须额外输出独立行：SEND_FILE:<绝对路径>。',\n    63→      '禁止仅输出 @image:xxx 或相对路径；路径必须是绝对路径（例如 /var/folders/... 或 /home/...）。',\n    64→      '以下是最近对话上下文：',\n    65→      ...messages.map((msg) => `${msg.role === 'user' ? '用户' : '助手'}: ${msg.content}`),\n    66→      '请继续回答最后一条用户消息。'\n    67→    ].join('\\n');\n    68→  }\n    69→\n    70→  /**\n    71→   * Add a commit record to a session.\n    72→   * @param {string} sessionKey - Session identifier\n    73→   * @param {Object} commitInfo - Commit information\n    74→   */\n    75→  addCommit(sessionKey, commitInfo) {\n    76→    if (!this.#commitsBySessionKey.has(sessionKey)) {\n    77→      this.#commitsBySessionKey.set(sessionKey, []);\n    78→    }\n    79→    const commits = this.#commitsBySessionKey.get(sessionKey);\n    80→    commits.push({\n    81→      ...commitInfo,\n    82→      timestamp: commitInfo.timestamp || Date.now()\n    83→    });\n    84→  }\n    85→\n    86→  /**\n    87→   * Get commits for a session.\n    88→   * @param {string} sessionKey - Session identifier\n    89→   * @returns {Object[]} Array of commit records\n    90→   */\n    91→  getCommits(sessionKey) {\n    92→    return this.#commitsBySessionKey.get(sessionKey) || [];\n    93→  }\n    94→\n    95→  /**\n    96→   * Get the last commit for a session.\n    97→   * @param {string} sessionKey - Session identifier\n    98→   * @returns {Object|null} Last commit record or null\n    99→   */\n   100→  getLastCommit(sessionKey) {\n   101→    const commits = this.getCommits(sessionKey);\n   102→    return commits.length > 0 ? commits[commits.length - 1] : null;\n   103→  }\n   104→\n   105→  // F-009: Command executor methods\n   106→\n   107→  /**\n   108→   * Get current working directory for a session.\n   109→   * @param {string} sessionKey - Session identifier\n   110→   * @returns {string|null} Current working directory or null\n   111→   */\n   112→  getCwd(sessionKey) {\n   113→    return this.#cwdBySessionKey.get(sessionKey) || null;\n   114→  }\n   115→\n   116→  /**\n   117→   * Set current working directory for a session.\n   118→   * @param {string} sessionKey - Session identifier\n   119→   * @param {string} cwd - Working directory path\n   120→   */\n   121→  setCwd(sessionKey, cwd) {\n   122→    this.#cwdBySessionKey.set(sessionKey, cwd);\n   123→  }\n   124→\n   125→  /**\n   126→   * Get output pages for a session (for /more pagination).\n   127→   * @param {string} sessionKey - Session identifier\n   128→   * @returns {string[]|null} Array of output pages or null\n   129→   */\n   130→  getOutputPages(sessionKey) {\n   131→    return this.#outputPagesBySessionKey.get(sessionKey) || null;\n   132→  }\n   133→\n   134→  /**\n   135→   * Set output pages for a session.\n   136→   * @param {string} sessionKey - Session identifier\n   137→   * @param {string[]} pages - Array of output page strings\n   138→   */\n   139→  setOutputPages(sessionKey, pages) {\n   140→    this.#outputPagesBySessionKey.set(sessionKey, pages);\n   141→  }\n   142→\n   143→  /**\n   144→   * Clear output pages for a session.\n   145→   * @param {string} sessionKey - Session identifier\n   146→   */\n   147→  clearOutputPages(sessionKey) {\n   148→    this.#outputPagesBySessionKey.delete(sessionKey);\n   149→  }\n   150→\n   151→  // F-010: File search results methods\n   152→\n   153→  /**\n   154→   * Get search results for a session.\n   155→   * @param {string} sessionKey - Session identifier\n   156→   * @returns {Object[]|null} Array of search results or null\n   157→   */\n   158→  getSearchResults(sessionKey) {\n   159→    return this.#searchResultsBySessionKey.get(sessionKey) || null;\n   160→  }\n   161→\n   162→  /**\n   163→   * Set search results for a session.\n   164→   * @param {string} sessionKey - Session identifier\n   165→   * @param {Object[]} results - Array of search result objects\n   166→   */\n   167→  setSearchResults(sessionKey, results) {\n   168→    this.#searchResultsBySessionKey.set(sessionKey, results);\n   169→  }\n   170→\n   171→  /**\n   172→   * Clear search results for a session.\n   173→   * @param {string} sessionKey - Session identifier\n   174→   */\n   175→  clearSearchResults(sessionKey) {\n   176→    this.#searchResultsBySessionKey.delete(sessionKey);\n   177→  }\n   178→\n   179→  // F-011: AI CLI process tracking methods\n   180→\n   181→  /**\n   182→   * Get active AI CLI process info.\n   183→   * @param {string} sessionKey - Session identifier\n   184→   * @returns {{ pid: number, startedAt: number, stdoutBytes?: number, childProcess: Object, interrupted?: boolean, timedOut?: boolean, userId?: string } | null}\n   185→   */\n   186→  getActiveProcess(sessionKey) {\n   187→    return this.#activeProcessBySessionKey.get(sessionKey) || null;\n   188→  }\n   189→\n   190→  /**\n   191→   * Set active AI CLI process.\n   192→   * @param {string} sessionKey - Session identifier\n   193→   * @param {{ pid: number, startedAt: number, childProcess: Object, stdoutBytes?: number, userId?: string, interrupted?: boolean, timedOut?: boolean }} info\n   194→   */\n   195→  setActiveProcess(sessionKey, info) {\n   196→    this.#activeProcessBySessionKey.set(sessionKey, {\n   197→      ...info,\n   198→      stdoutBytes: info.stdoutBytes ?? 0\n   199→    });\n   200→  }\n   201→\n   202→  /**\n   203→   * Update stdout bytes for active process.\n   204→   * @param {string} sessionKey - Session identifier\n   205→   * @param {number} bytes - Additional bytes received\n   206→   */\n   207→  updateProcessBytes(sessionKey, bytes) {\n   208→    const info = this.#activeProcessBySessionKey.get(sessionKey);\n   209→    if (info) {\n   210→      info.stdoutBytes = (info.stdoutBytes ?? 0) + bytes;\n   211→    }\n   212→  }\n   213→\n   214→  /**\n   215→   * Clear active process.\n   216→   * @param {string} sessionKey - Session identifier\n   217→   */\n   218→  clearActiveProcess(sessionKey) {\n   219→    this.#activeProcessBySessionKey.delete(sessionKey);\n   220→  }\n   221→\n   222→  // F-013: Session and Context Manager methods\n   223→\n   224→  /**\n   225→   * Record a command execution in history.\n   226→   * @param {string} sessionKey - Session identifier\n   227→   * @param {string} command - Command that was executed\n   228→   * @param {number} exitCode - Exit code of the command\n   229→   */\n   230→  recordCommand(sessionKey, command, exitCode) {\n   231→    if (!this.#commandHistoryBySessionKey.has(sessionKey)) {\n   232→      this.#commandHistoryBySessionKey.set(sessionKey, []);\n   233→    }\n   234→    const history = this.#commandHistoryBySessionKey.get(sessionKey);\n   235→    history.push({\n   236→      command,\n   237→      exitCode,\n   238→      timestamp: Date.now()\n   239→    });\n   240→\n   241→    // Trim to max history size\n   242→    const maxHistory = config.sessionHistoryMax;\n   243→    if (history.length > maxHistory) {\n   244→      history.splice(0, history.length - maxHistory);\n   245→    }\n   246→  }\n   247→\n   248→  /**\n   249→   * Get command history for a session.\n   250→   * @param {string} sessionKey - Session identifier\n   251→   * @param {number} [limit] - Maximum number of entries to return\n   252→   * @returns {Object[]} Array of { command, exitCode, timestamp }\n   253→   */\n   254→  getCommandHistory(sessionKey, limit) {\n   255→    const history = this.#commandHistoryBySessionKey.get(sessionKey) || [];\n   256→    if (limit !== undefined && limit > 0) {\n   257→      const start = Math.max(0, history.length - limit);\n   258→      return history.slice(start);\n   259→    }\n   260→    return [...history];\n   261→  }\n   262→\n   263→  /**\n   264→   * Set an environment variable override for a session.\n   265→   * @param {string} sessionKey - Session identifier\n   266→   * @param {string} key - Environment variable name\n   267→   * @param {string} value - Environment variable value\n   268→   */\n   269→  setEnvOverride(sessionKey, key, value) {\n   270→    if (!this.#envOverridesBySessionKey.has(sessionKey)) {\n   271→      this.#envOverridesBySessionKey.set(sessionKey, {});\n   272→    }\n   273→    this.#envOverridesBySessionKey.get(sessionKey)[key] = value;\n   274→  }\n   275→\n   276→  /**\n   277→   * Get all environment variable overrides for a session.\n   278→   * @param {string} sessionKey - Session identifier\n   279→   * @returns {Object} Environment variable key-value pairs\n   280→   */\n   281→  getEnvOverrides(sessionKey) {\n   282→    return { ...this.#envOverridesBySessionKey.get(sessionKey) } || {};\n   283→  }\n   284→\n   285→  /**\n   286→   * Update session activity timestamp and user ID.\n   287→   * @param {string} sessionKey - Session identifier\n   288→   * @param {string} userId - Telegram user ID\n   289→   */\n   290→  touchSession(sessionKey, userId) {\n   291→    const now = Date.now();\n   292→    this.#lastActivityBySessionKey.set(sessionKey, now);\n   293→    if (userId !== undefined) {\n   294→      this.#userIdBySessionKey.set(sessionKey, userId);\n   295→    }\n   296→    // Set creation time if this is a new session\n   297→    if (!this.#sessionCreatedAtBySessionKey.has(sessionKey)) {\n   298→      this.#sessionCreatedAtBySessionKey.set(sessionKey, now);\n   299→    }\n   300→  }\n   301→\n   302→  /**\n   303→   * Get last activity timestamp for a session.\n   304→   * @param {string} sessionKey - Session identifier\n   305→   * @returns {number|null} Timestamp or null if not set\n   306→   */\n   307→  getLastActivity(sessionKey) {\n   308→    return this.#lastActivityBySessionKey.get(sessionKey) || null;\n   309→  }\n   310→\n   311→  /**\n   312→   * Get comprehensive session information.\n   313→   * @param {string} sessionKey - Session identifier\n   314→   * @returns {Object|null} Session info object or null if not found\n   315→   */\n   316→  getSessionInfo(sessionKey) {\n   317→    const userId = this.#userIdBySessionKey.get(sessionKey);\n   318→    const createdAt = this.#sessionCreatedAtBySessionKey.get(sessionKey);\n   319→    const lastActivityAt = this.#lastActivityBySessionKey.get(sessionKey);\n   320→\n   321→    // Return null if session has no tracking data\n   322→    if (!createdAt && !lastActivityAt) {\n   323→      return null;\n   324→    }\n   325→\n   326→    return {\n   327→      sessionKey,\n   328→      userId: userId || null,\n   329→      cwd: this.#cwdBySessionKey.get(sessionKey) || null,\n   330→      envOverrides: { ...this.#envOverridesBySessionKey.get(sessionKey) } || {},\n   331→      commandCount: (this.#commandHistoryBySessionKey.get(sessionKey) || []).length,\n   332→      createdAt: createdAt || null,\n   333→      lastActivityAt: lastActivityAt || null\n   334→    };\n   335→  }\n   336→\n   337→  /**\n   338→   * Get all active session keys.\n   339→   * @returns {string[]} Array of session keys\n   340→   */\n   341→  getAllSessionKeys() {\n   342→    // Return keys from sessions that have activity tracking\n   343→    return Array.from(this.#lastActivityBySessionKey.keys());\n   344→  }\n   345→\n   346→  /**\n   347→   * Get the age of a session in milliseconds.\n   348→   * @param {string} sessionKey - Session identifier\n   349→   * @returns {number|null} Age in ms or null if not found\n   350→   */\n   351→  getSessionAge(sessionKey) {\n   352→    const createdAt = this.#sessionCreatedAtBySessionKey.get(sessionKey);\n   353→    if (!createdAt) {\n   354→      return null;\n   355→    }\n   356→    return Date.now() - createdAt;\n   357→  }\n   358→\n   359→  /**\n   360→   * Get idle time for a session in milliseconds.\n   361→   * @param {string} sessionKey - Session identifier\n   362→   * @returns {number|null} Idle time in ms or null if not found\n   363→   */\n   364→  getIdleTime(sessionKey) {\n   365→    const lastActivity = this.#lastActivityBySessionKey.get(sessionKey);\n   366→    if (!lastActivity) {\n   367→      return null;\n   368→    }\n   369→    return Date.now() - lastActivity;\n   370→  }\n   371→\n   372→  /**\n   373→   * Set user ID for a session.\n   374→   * @param {string} sessionKey - Session identifier\n   375→   * @param {string} userId - Telegram user ID\n   376→   */\n   377→  setUserId(sessionKey, userId) {\n   378→    this.#userIdBySessionKey.set(sessionKey, userId);\n   379→  }\n   380→\n   381→  /**\n   382→   * Get user ID for a session.\n   383→   * @param {string} sessionKey - Session identifier\n   384→   * @returns {string|null} User ID or null if not set\n   385→   */\n   386→  getUserId(sessionKey) {\n   387→    return this.#userIdBySessionKey.get(sessionKey) || null;\n   388→  }\n   389→}\n   390→\n   391→export const sessionStore = new SessionStore();\n   392→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6c8ebc62-648e-4d09-8200-69d30faee4f6","uuid":"ac821692-02ca-47a5-af63-5a798274f59a","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/src/services/session-store.js","content":"import { config } from '../config.js';\n\nclass SessionStore {\n  #messagesBySessionKey = new Map();\n  #commitsBySessionKey = new Map();\n  // F-009: Command executor extensions\n  #cwdBySessionKey = new Map();\n  #outputPagesBySessionKey = new Map();\n  // F-010: File search results state for pagination\n  #searchResultsBySessionKey = new Map();\n  // F-011: AI CLI process tracking\n  #activeProcessBySessionKey = new Map();\n  // F-013: Session and Context Manager\n  #commandHistoryBySessionKey = new Map();\n  #envOverridesBySessionKey = new Map();\n  #lastActivityBySessionKey = new Map();\n  #userIdBySessionKey = new Map();\n  #sessionCreatedAtBySessionKey = new Map();\n\n  get(sessionKey) {\n    if (!this.#messagesBySessionKey.has(sessionKey)) {\n      this.#messagesBySessionKey.set(sessionKey, []);\n    }\n    return this.#messagesBySessionKey.get(sessionKey);\n  }\n\n  append(sessionKey, role, content) {\n    const messages = this.get(sessionKey);\n    messages.push({ role, content });\n\n    const maxMessages = config.maxHistoryTurns * 2;\n    if (messages.length > maxMessages) {\n      messages.splice(0, messages.length - maxMessages);\n    }\n  }\n\n  clear(sessionKey) {\n    this.#messagesBySessionKey.delete(sessionKey);\n    this.#commitsBySessionKey.delete(sessionKey);\n    // F-009: Clear cwd and output pages\n    this.#cwdBySessionKey.delete(sessionKey);\n    this.#outputPagesBySessionKey.delete(sessionKey);\n    // F-010: Clear search results\n    this.#searchResultsBySessionKey.delete(sessionKey);\n    // F-011: Clear active process\n    this.#activeProcessBySessionKey.delete(sessionKey);\n    // F-013: Clear session context data\n    this.#commandHistoryBySessionKey.delete(sessionKey);\n    this.#envOverridesBySessionKey.delete(sessionKey);\n    this.#lastActivityBySessionKey.delete(sessionKey);\n    this.#userIdBySessionKey.delete(sessionKey);\n    this.#sessionCreatedAtBySessionKey.delete(sessionKey);\n  }\n\n  toPrompt(sessionKey, channel = 'unknown') {\n    const messages = this.get(sessionKey);\n\n    return [\n      `你正在通过 ${channel} 渠道提供电脑助手服务。`,\n      '请使用自然、简洁、可执行的表达。',\n      '如果用户请求系统操作或截图，明确说明步骤与结果。',\n      '当你产出本地文件（截图/文档）时，必须额外输出独立行：SEND_FILE:<绝对路径>。',\n      '禁止仅输出 @image:xxx 或相对路径；路径必须是绝对路径（例如 /var/folders/... 或 /home/...）。',\n      '以下是最近对话上下文：',\n      ...messages.map((msg) => `${msg.role === 'user' ? '用户' : '助手'}: ${msg.content}`),\n      '请继续回答最后一条用户消息。'\n    ].join('\\n');\n  }\n\n  /**\n   * Add a commit record to a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {Object} commitInfo - Commit information\n   */\n  addCommit(sessionKey, commitInfo) {\n    if (!this.#commitsBySessionKey.has(sessionKey)) {\n      this.#commitsBySessionKey.set(sessionKey, []);\n    }\n    const commits = this.#commitsBySessionKey.get(sessionKey);\n    commits.push({\n      ...commitInfo,\n      timestamp: commitInfo.timestamp || Date.now()\n    });\n  }\n\n  /**\n   * Get commits for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {Object[]} Array of commit records\n   */\n  getCommits(sessionKey) {\n    return this.#commitsBySessionKey.get(sessionKey) || [];\n  }\n\n  /**\n   * Get the last commit for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {Object|null} Last commit record or null\n   */\n  getLastCommit(sessionKey) {\n    const commits = this.getCommits(sessionKey);\n    return commits.length > 0 ? commits[commits.length - 1] : null;\n  }\n\n  // F-009: Command executor methods\n\n  /**\n   * Get current working directory for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {string|null} Current working directory or null\n   */\n  getCwd(sessionKey) {\n    return this.#cwdBySessionKey.get(sessionKey) || null;\n  }\n\n  /**\n   * Set current working directory for a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} cwd - Working directory path\n   */\n  setCwd(sessionKey, cwd) {\n    this.#cwdBySessionKey.set(sessionKey, cwd);\n  }\n\n  /**\n   * Get output pages for a session (for /more pagination).\n   * @param {string} sessionKey - Session identifier\n   * @returns {string[]|null} Array of output pages or null\n   */\n  getOutputPages(sessionKey) {\n    return this.#outputPagesBySessionKey.get(sessionKey) || null;\n  }\n\n  /**\n   * Set output pages for a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {string[]} pages - Array of output page strings\n   */\n  setOutputPages(sessionKey, pages) {\n    this.#outputPagesBySessionKey.set(sessionKey, pages);\n  }\n\n  /**\n   * Clear output pages for a session.\n   * @param {string} sessionKey - Session identifier\n   */\n  clearOutputPages(sessionKey) {\n    this.#outputPagesBySessionKey.delete(sessionKey);\n  }\n\n  // F-010: File search results methods\n\n  /**\n   * Get search results for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {Object[]|null} Array of search results or null\n   */\n  getSearchResults(sessionKey) {\n    return this.#searchResultsBySessionKey.get(sessionKey) || null;\n  }\n\n  /**\n   * Set search results for a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {Object[]} results - Array of search result objects\n   */\n  setSearchResults(sessionKey, results) {\n    this.#searchResultsBySessionKey.set(sessionKey, results);\n  }\n\n  /**\n   * Clear search results for a session.\n   * @param {string} sessionKey - Session identifier\n   */\n  clearSearchResults(sessionKey) {\n    this.#searchResultsBySessionKey.delete(sessionKey);\n  }\n\n  // F-011: AI CLI process tracking methods\n\n  /**\n   * Get active AI CLI process info.\n   * @param {string} sessionKey - Session identifier\n   * @returns {{ pid: number, startedAt: number, stdoutBytes?: number, childProcess: Object, interrupted?: boolean, timedOut?: boolean, userId?: string } | null}\n   */\n  getActiveProcess(sessionKey) {\n    return this.#activeProcessBySessionKey.get(sessionKey) || null;\n  }\n\n  /**\n   * Set active AI CLI process.\n   * @param {string} sessionKey - Session identifier\n   * @param {{ pid: number, startedAt: number, childProcess: Object, stdoutBytes?: number, userId?: string, interrupted?: boolean, timedOut?: boolean }} info\n   */\n  setActiveProcess(sessionKey, info) {\n    this.#activeProcessBySessionKey.set(sessionKey, {\n      ...info,\n      stdoutBytes: info.stdoutBytes ?? 0\n    });\n  }\n\n  /**\n   * Update stdout bytes for active process.\n   * @param {string} sessionKey - Session identifier\n   * @param {number} bytes - Additional bytes received\n   */\n  updateProcessBytes(sessionKey, bytes) {\n    const info = this.#activeProcessBySessionKey.get(sessionKey);\n    if (info) {\n      info.stdoutBytes = (info.stdoutBytes ?? 0) + bytes;\n    }\n  }\n\n  /**\n   * Clear active process.\n   * @param {string} sessionKey - Session identifier\n   */\n  clearActiveProcess(sessionKey) {\n    this.#activeProcessBySessionKey.delete(sessionKey);\n  }\n\n  // F-013: Session and Context Manager methods\n\n  /**\n   * Record a command execution in history.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} command - Command that was executed\n   * @param {number} exitCode - Exit code of the command\n   */\n  recordCommand(sessionKey, command, exitCode) {\n    if (!this.#commandHistoryBySessionKey.has(sessionKey)) {\n      this.#commandHistoryBySessionKey.set(sessionKey, []);\n    }\n    const history = this.#commandHistoryBySessionKey.get(sessionKey);\n    history.push({\n      command,\n      exitCode,\n      timestamp: Date.now()\n    });\n\n    // Trim to max history size\n    const maxHistory = config.sessionHistoryMax;\n    if (history.length > maxHistory) {\n      history.splice(0, history.length - maxHistory);\n    }\n  }\n\n  /**\n   * Get command history for a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {number} [limit] - Maximum number of entries to return\n   * @returns {Object[]} Array of { command, exitCode, timestamp }\n   */\n  getCommandHistory(sessionKey, limit) {\n    const history = this.#commandHistoryBySessionKey.get(sessionKey) || [];\n    if (limit !== undefined && limit > 0) {\n      const start = Math.max(0, history.length - limit);\n      return history.slice(start);\n    }\n    return [...history];\n  }\n\n  /**\n   * Set an environment variable override for a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} key - Environment variable name\n   * @param {string} value - Environment variable value\n   */\n  setEnvOverride(sessionKey, key, value) {\n    if (!this.#envOverridesBySessionKey.has(sessionKey)) {\n      this.#envOverridesBySessionKey.set(sessionKey, {});\n    }\n    this.#envOverridesBySessionKey.get(sessionKey)[key] = value;\n  }\n\n  /**\n   * Get all environment variable overrides for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {Object} Environment variable key-value pairs\n   */\n  getEnvOverrides(sessionKey) {\n    return { ...this.#envOverridesBySessionKey.get(sessionKey) } || {};\n  }\n\n  /**\n   * Update session activity timestamp and user ID.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} userId - Telegram user ID\n   */\n  touchSession(sessionKey, userId) {\n    const now = Date.now();\n    this.#lastActivityBySessionKey.set(sessionKey, now);\n    if (userId !== undefined) {\n      this.#userIdBySessionKey.set(sessionKey, userId);\n    }\n    // Set creation time if this is a new session\n    if (!this.#sessionCreatedAtBySessionKey.has(sessionKey)) {\n      this.#sessionCreatedAtBySessionKey.set(sessionKey, now);\n    }\n  }\n\n  /**\n   * Get last activity timestamp for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {number|null} Timestamp or null if not set\n   */\n  getLastActivity(sessionKey) {\n    return this.#lastActivityBySessionKey.get(sessionKey) || null;\n  }\n\n  /**\n   * Get comprehensive session information.\n   * @param {string} sessionKey - Session identifier\n   * @returns {Object|null} Session info object or null if not found\n   */\n  getSessionInfo(sessionKey) {\n    const userId = this.#userIdBySessionKey.get(sessionKey);\n    const createdAt = this.#sessionCreatedAtBySessionKey.get(sessionKey);\n    const lastActivityAt = this.#lastActivityBySessionKey.get(sessionKey);\n\n    // Return null if session has no tracking data\n    if (!createdAt && !lastActivityAt) {\n      return null;\n    }\n\n    return {\n      sessionKey,\n      userId: userId || null,\n      cwd: this.#cwdBySessionKey.get(sessionKey) || null,\n      envOverrides: { ...this.#envOverridesBySessionKey.get(sessionKey) } || {},\n      commandCount: (this.#commandHistoryBySessionKey.get(sessionKey) || []).length,\n      createdAt: createdAt || null,\n      lastActivityAt: lastActivityAt || null\n    };\n  }\n\n  /**\n   * Get all active session keys.\n   * @returns {string[]} Array of session keys\n   */\n  getAllSessionKeys() {\n    // Return keys from sessions that have activity tracking\n    return Array.from(this.#lastActivityBySessionKey.keys());\n  }\n\n  /**\n   * Get the age of a session in milliseconds.\n   * @param {string} sessionKey - Session identifier\n   * @returns {number|null} Age in ms or null if not found\n   */\n  getSessionAge(sessionKey) {\n    const createdAt = this.#sessionCreatedAtBySessionKey.get(sessionKey);\n    if (!createdAt) {\n      return null;\n    }\n    return Date.now() - createdAt;\n  }\n\n  /**\n   * Get idle time for a session in milliseconds.\n   * @param {string} sessionKey - Session identifier\n   * @returns {number|null} Idle time in ms or null if not found\n   */\n  getIdleTime(sessionKey) {\n    const lastActivity = this.#lastActivityBySessionKey.get(sessionKey);\n    if (!lastActivity) {\n      return null;\n    }\n    return Date.now() - lastActivity;\n  }\n\n  /**\n   * Set user ID for a session.\n   * @param {string} sessionKey - Session identifier\n   * @param {string} userId - Telegram user ID\n   */\n  setUserId(sessionKey, userId) {\n    this.#userIdBySessionKey.set(sessionKey, userId);\n  }\n\n  /**\n   * Get user ID for a session.\n   * @param {string} sessionKey - Session identifier\n   * @returns {string|null} User ID or null if not set\n   */\n  getUserId(sessionKey) {\n    return this.#userIdBySessionKey.get(sessionKey) || null;\n  }\n}\n\nexport const sessionStore = new SessionStore();\n","numLines":392,"startLine":1,"totalLines":392}}}
