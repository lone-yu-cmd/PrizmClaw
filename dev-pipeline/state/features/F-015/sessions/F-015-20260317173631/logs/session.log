{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_ebf24bbf95654a358549083a","type":"tool_result","content":"     1→/**\n     2→ * Status Command Handler\n     3→ * Handles /status command to show aggregated pipeline status.\n     4→ *\n     5→ * F-005: Pipeline Status Aggregation and Log Streaming - US-1: Aggregated Status Query\n     6→ * F-008: T-120 - Added last commit display\n     7→ */\n     8→\n     9→import { createStatusAggregator } from '../../../services/status-aggregator.js';\n    10→import { createGitService } from '../../../services/git-service.js';\n    11→import { sessionStore } from '../../../services/session-store.js';\n    12→\n    13→/**\n    14→ * Status command metadata.\n    15→ */\n    16→export const statusMeta = {\n    17→  name: 'status',\n    18→  aliases: ['s'],\n    19→  description: '查看管道状态',\n    20→  usage: '/status [--type=feature|bugfix]',\n    21→  examples: ['/status', '/status --type=bugfix', '/status -t feature'],\n    22→  params: [\n    23→    {\n    24→      name: 'type',\n    25→      type: 'string',\n    26→      required: false,\n    27→      description: 'Pipeline 类型 (feature 或 bugfix)',\n    28→      default: 'feature',\n    29→      aliases: ['t']\n    30→    }\n    31→  ],\n    32→  requiresAuth: true,\n    33→  minRole: 'viewer',\n    34→  helpText: '/status [--type=feature|bugfix] - 查看管道状态'\n    35→};\n    36→\n    37→/**\n    38→ * Handle status command.\n    39→ * @param {Object} handlerCtx - Handler context\n    40→ */\n    41→export async function handleStatus(handlerCtx) {\n    42→  const { reply, params, ctx, userId } = handlerCtx;\n    43→  const pipelineType = params.type || params.t || 'feature';\n    44→\n    45→  // Validate pipeline type\n    46→  if (pipelineType !== 'feature' && pipelineType !== 'bugfix') {\n    47→    await reply(`❌ 无效的 pipeline 类型: ${pipelineType}。请使用 'feature' 或 'bugfix'。`);\n    48→    return;\n    49→  }\n    50→\n    51→  try {\n    52→    const aggregator = createStatusAggregator();\n    53→    const status = await aggregator.aggregateStatus(pipelineType);\n    54→    let formatted = aggregator.formatStatusForTelegram(status);\n    55→\n    56→    // T-120: Add last commit info\n    57→    const gitService = createGitService();\n    58→    const lastCommit = await gitService.getLastCommit();\n    59→\n    60→    if (lastCommit) {\n    61→      formatted += '\\n\\n📦 **最近提交**';\n    62→      formatted += `\\n\\`${lastCommit.shortHash}\\` ${lastCommit.message.split('\\n')[0]}`;\n    63→      formatted += `\\n👤 ${lastCommit.author} | 📅 ${formatDate(lastCommit.date)}`;\n    64→    }\n    65→\n    66→    // Also show session last commit if available\n    67→    const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n    68→    const sessionLastCommit = sessionStore.getLastCommit(sessionId);\n    69→\n    70→    if (sessionLastCommit) {\n    71→      formatted += '\\n\\n📝 **会话最近提交**';\n    72→      formatted += `\\n\\`${sessionLastCommit.shortHash}\\` ${sessionLastCommit.message?.split('\\n')[0] || '(无消息)'}`;\n    73→      if (sessionLastCommit.featureId) {\n    74→        formatted += `\\n🏷️ Feature: ${sessionLastCommit.featureId}`;\n    75→      }\n    76→    }\n    77→\n    78→    await reply(formatted);\n    79→  } catch (error) {\n    80→    await reply(`❌ 查询失败: ${error.message}`);\n    81→  }\n    82→}\n    83→\n    84→/**\n    85→ * Format date for display.\n    86→ * @param {string} dateStr - ISO date string\n    87→ * @returns {string} Formatted date\n    88→ */\n    89→function formatDate(dateStr) {\n    90→  if (!dateStr) return '未知';\n    91→  const date = new Date(dateStr);\n    92→  return date.toLocaleDateString('zh-CN', {\n    93→    month: 'short',\n    94→    day: 'numeric',\n    95→    hour: '2-digit',\n    96→    minute: '2-digit'\n    97→  });\n    98→}\n    99→\n   100→export default handleStatus;\n   101→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6c8ebc62-648e-4d09-8200-69d30faee4f6","uuid":"fa406de0-2190-4b5d-b466-f40c03773b12","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/src/bot/commands/handlers/status.js","content":"/**\n * Status Command Handler\n * Handles /status command to show aggregated pipeline status.\n *\n * F-005: Pipeline Status Aggregation and Log Streaming - US-1: Aggregated Status Query\n * F-008: T-120 - Added last commit display\n */\n\nimport { createStatusAggregator } from '../../../services/status-aggregator.js';\nimport { createGitService } from '../../../services/git-service.js';\nimport { sessionStore } from '../../../services/session-store.js';\n\n/**\n * Status command metadata.\n */\nexport const statusMeta = {\n  name: 'status',\n  aliases: ['s'],\n  description: '查看管道状态',\n  usage: '/status [--type=feature|bugfix]',\n  examples: ['/status', '/status --type=bugfix', '/status -t feature'],\n  params: [\n    {\n      name: 'type',\n      type: 'string',\n      required: false,\n      description: 'Pipeline 类型 (feature 或 bugfix)',\n      default: 'feature',\n      aliases: ['t']\n    }\n  ],\n  requiresAuth: true,\n  minRole: 'viewer',\n  helpText: '/status [--type=feature|bugfix] - 查看管道状态'\n};\n\n/**\n * Handle status command.\n * @param {Object} handlerCtx - Handler context\n */\nexport async function handleStatus(handlerCtx) {\n  const { reply, params, ctx, userId } = handlerCtx;\n  const pipelineType = params.type || params.t || 'feature';\n\n  // Validate pipeline type\n  if (pipelineType !== 'feature' && pipelineType !== 'bugfix') {\n    await reply(`❌ 无效的 pipeline 类型: ${pipelineType}。请使用 'feature' 或 'bugfix'。`);\n    return;\n  }\n\n  try {\n    const aggregator = createStatusAggregator();\n    const status = await aggregator.aggregateStatus(pipelineType);\n    let formatted = aggregator.formatStatusForTelegram(status);\n\n    // T-120: Add last commit info\n    const gitService = createGitService();\n    const lastCommit = await gitService.getLastCommit();\n\n    if (lastCommit) {\n      formatted += '\\n\\n📦 **最近提交**';\n      formatted += `\\n\\`${lastCommit.shortHash}\\` ${lastCommit.message.split('\\n')[0]}`;\n      formatted += `\\n👤 ${lastCommit.author} | 📅 ${formatDate(lastCommit.date)}`;\n    }\n\n    // Also show session last commit if available\n    const sessionId = ctx?.chat?.id?.toString() || `session-${userId}`;\n    const sessionLastCommit = sessionStore.getLastCommit(sessionId);\n\n    if (sessionLastCommit) {\n      formatted += '\\n\\n📝 **会话最近提交**';\n      formatted += `\\n\\`${sessionLastCommit.shortHash}\\` ${sessionLastCommit.message?.split('\\n')[0] || '(无消息)'}`;\n      if (sessionLastCommit.featureId) {\n        formatted += `\\n🏷️ Feature: ${sessionLastCommit.featureId}`;\n      }\n    }\n\n    await reply(formatted);\n  } catch (error) {\n    await reply(`❌ 查询失败: ${error.message}`);\n  }\n}\n\n/**\n * Format date for display.\n * @param {string} dateStr - ISO date string\n * @returns {string} Formatted date\n */\nfunction formatDate(dateStr) {\n  if (!dateStr) return '未知';\n  const date = new Date(dateStr);\n  return date.toLocaleDateString('zh-CN', {\n    month: 'short',\n    day: 'numeric',\n    hour: '2-digit',\n    minute: '2-digit'\n  });\n}\n\nexport default handleStatus;\n","numLines":101,"startLine":1,"totalLines":101}}}
