{"type":"user","uuid":"18067a9b-163e-431a-9cb1-027e23286dc8","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_013gEFy1ytFxbgPZvjbrga6L","content":[{"type":"text","text":"   1→/**\n   2→ * Pipeline Command Handler\n   3→ * Handles /pipeline command with run/status/logs/stop subcommands.\n   4→ * F-006: Integrated with security guard\n   5→ */\n   6→\n   7→import {\n   8→  startPipeline,\n   9→  stopPipeline,\n  10→  getStatus,\n  11→  getLogs,\n  12→  forceUnlock\n  13→} from '../../../services/pipeline-controller.js';\n  14→import { formatValidationErrors as _formatValidationErrors, formatError as _formatError, ErrorCodes as _ErrorCodes } from '../formatter.js';\n  15→import { logAuditEntry } from '../../../services/audit-log-service.js';\n  16→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n  17→import { isAdmin } from '../../../security/permission-guard.js';\n  18→import {\n  19→  createConfirmation,\n  20→  checkConfirmation as _checkConfirmation,\n  21→  confirmAction,\n  22→  cancelConfirmation\n  23→} from '../../../security/confirmation-manager.js';\n  24→\n  25→// Store pending confirmations for text-based flow\n  26→const pendingConfirmations = new Map();\n  27→\n  28→/**\n  29→ * Pipeline command metadata.\n  30→ * T-102: minRole added\n  31→ */\n  32→export const pipelineMeta = {\n  33→  name: 'pipeline',\n  34→  aliases: ['p'],\n  35→  description: '管理管道任务',\n  36→  usage: '/pipeline <action> [target] [--type=<type>]',\n  37→  examples: [\n  38→    '/pipeline run my-feature',\n  39→    '/pipeline run my-feature --type=bugfix',\n  40→    '/pipeline status',\n  41→    '/pipeline logs my-feature',\n  42→    '/pipeline stop my-feature',\n  43→    '/pipeline force-unlock'\n  44→  ],\n  45→  subcommands: [\n  46→    { name: 'run', description: '启动管道' },\n  47→    { name: 'status', description: '查询状态' },\n  48→    { name: 'logs', description: '查看日志' },\n  49→    { name: 'stop', description: '停止管道' },\n  50→    { name: 'force-unlock', description: '强制释放锁' }\n  51→  ],\n  52→  params: [\n  53→    {\n  54→      name: 'target',\n  55→      type: 'string',\n  56→      required: false,\n  57→      description: '目标标识符'\n  58→    },\n  59→    {\n  60→      name: 'type',\n  61→      type: 'enum',\n  62→      enum: ['feature', 'bugfix', 'planner'],\n  63→      required: false,\n  64→      default: 'feature',\n  65→      description: '管道类型'\n  66→    }\n  67→  ],\n  68→  requiresAuth: true,\n  69→  minRole: 'operator',\n  70→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n  71→};\n  72→\n  73→/**\n  74→ * Handle pipeline command.\n  75→ * @param {Object} handlerCtx - Handler context\n  76→ * @param {Object} handlerCtx.ctx - Telegraf context\n  77→ * @param {Object} handlerCtx.parsed - Parsed command\n  78→ * @param {Object} handlerCtx.params - Normalized parameters\n  79→ * @param {Function} handlerCtx.reply - Reply function\n  80→ */\n  81→export async function handlePipeline(handlerCtx) {\n  82→  const { ctx: _ctx, parsed, params: _params, reply } = handlerCtx;\n  83→\n  84→  // Determine action from subcommand or default to status\n  85→  const action = parsed.subcommand || 'status';\n  86→\n  87→  switch (action) {\n  88→    case 'run':\n  89→      // @ts-ignore — handlerCtx shape is validated at runtime\n  90→      return handleRun(handlerCtx);\n  91→    case 'status':\n  92→      // @ts-ignore — handlerCtx shape is validated at runtime\n  93→      return handleStatus(handlerCtx);\n  94→    case 'logs':\n  95→      // @ts-ignore — handlerCtx shape is validated at runtime\n  96→      return handleLogs(handlerCtx);\n  97→    case 'stop':\n  98→      return handlePipelineStop(handlerCtx);\n  99→    case 'force-unlock':\n 100→      return handleForceUnlock(handlerCtx);\n 101→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:23.889Z","_requestId":