valid for a command.\n2060→ * @param {string} subcommand - Subcommand name\n2061→ * @param {SubcommandMeta[]} subcommands - Available subcommands\n2062→ * @returns {{valid: boolean, error?: ValidationError}}\n2063→ */\n2064→export function validateSubcommand(subcommand, subcommands) {\n2065→  if (!subcommand) {\n2066→    return { valid: true };\n2067→  }\n2068→\n2069→  const validNames = (subcommands || []).map((s) => s.name);\n2070→  if (validNames.length === 0) {\n2071→    return { valid: true };\n2072→  }\n2073→\n2074→  if (!validNames.includes(subcommand)) {\n2075→    return {\n2076→      valid: false,\n2077→      error: {\n2078→        param: 'subcommand',\n2079→        message: `未知子命令 '${subcommand}'`,\n2080→        suggestion: `可用子命令: ${validNames.join(', ')}`\n2081→      }\n2082→    };\n2083→  }\n2084→\n2085→  return { valid: true };\n2086→}\n2087→\n2088→```\n2089→\n2090→### src/bot/commands/formatter.js (139 lines)\n2091→\n2092→```js\n2093→/**\n2094→ * Error Formatter\n2095→ * Formats error messages for user-friendly display.\n2096→ */\n2097→\n2098→/**\n2099→ * Error codes for command errors.\n2100→ */\n2101→export const ErrorCodes = {\n2102→  UNKNOWN_COMMAND: 'UNKNOWN_COMMAND',\n2103→  UNKNOWN_SUBCOMMAND: 'UNKNOWN_SUBCOMMAND',\n2104→  MISSING_PARAM: 'MISSING_PARAM',\n2105→  INVALID_PARAM: 'INVALID_PARAM',\n2106→  UNAUTHORIZED: 'UNAUTHORIZED',\n2107→  INTERNAL_ERROR: 'INTERNAL_ERROR'\n2108→};\n2109→\n2110→/**\n2111→ * @typedef {Object} ErrorResponse\n2112→ * @property {string} code - Error code\n2113→ * @property {string} message - User-friendly error message\n2114→ * @property {string} [suggestion] - Correction suggestion\n2115→ * @property {string} [usage] - Correct usage example\n2116→ */\n2117→\n2118→/**\n2119→ * Format an error for display to the user.\n2120→ * @param {string} code - Error code\n2121→ * @param {Object} context - Error context\n2122→ * @param {string} [context.command] - Command name\n2123→ * @param {string} [context.subcommand] - Subcommand name\n2124→ * @param {string} [context.param] - Parameter name\n2125→ * @param {string} [context.value] - Invalid value\n2126→ * @param {string} [context.reason] - Error reason\n2127→ * @param {string} [context.suggestion] - Custom suggestion\n2128→ * @param {string} [context.usage] - Correct usage\n2129→ * @param {string[]} [context.available] - Available options\n2130→ * @returns {ErrorResponse} Formatted error\n2131→ */\n2132→export function formatError(code, context = {}) {\n2133→  switch (code) {\n2134→    case ErrorCodes.UNKNOWN_COMMAND:\n2135→      return {\n2136→        code,\n2137→        message: `未知命令 '${context.command || ''}'。`,\n2138→        suggestion: '输入 /help 查看可用命令。'\n2139→      };\n2140→\n2141→    case ErrorCodes.UNKNOWN_SUBCOMMAND:\n2142→      return {\n2143→        code,\n2144→        message: `未知子命令 '${context.subcommand || ''}'。`,\n2145→        suggestion: context.available ? `可用: ${context.available.join(', ')}` : undefined,\n2146→        usage: context.usage\n2147→      };\n2148→\n2149→    case ErrorCodes.MISSING_PARAM:\n2150→      return {\n2151→        code,\n2152→        message: `缺少参数 '${context.param || ''}'。`,\n2153→        suggestion: context.suggestion || `请提供 ${context.param} 参数`,\n2154→        usage: context.usage\n2155→      };\n2156→\n2157→    case ErrorCodes.INVALID_PARAM:\n2158→      return {\n2159→        code,\n2160→        message: `参数 '${context.param || ''}' 无效: ${context.reason || ''}`,\n2161→        suggestion: context.suggestion,\n2162→        usage: context.usage\n2163→      };\n2164→\n2165→    case ErrorCodes.UNAUTHORIZED:\n2166→      return {\n2167→        code,\n2168→        message: '当前账号未被授权使用该命令。',\n2169→        suggestion: '请联系管理员获取授权。'\n2170→      };\n2171→\n2172→    case ErrorCodes.INTERNAL_ERROR:\n2173→      return {\n2174→        code,\n2175→        message: '内部错误，请稍后重试。',\n2176→        suggestion: context.reason ? `错误: ${context.reason}` : undefined\n2177→      };\n2178→\n2179→    default:\n2180→      return {\n2181→        code: ErrorCodes.INTERNAL_ERROR,\n2182→        message: '未知错误。'\n2183→      };\n2184→  }\n2185→}\n2186→\n2187→/**\n2188→ * Format validation errors into a single message.\n2189→ * @param {import('./validator.js').ValidationError[]} errors - Validation errors\n2190→ * @param {string} [usage] - Usage hint\n2191→ * @returns {string} Formatted error message\n2192→ */\n2193→export function formatValidationErrors(errors, usage) {\n2194→  if (!errors || errors.length === 0) {\n2195→    return '';\n2196→  }\n2197→\n2198→  const lines = [];\n2199→\n2200→  for (const error of errors) {\n2201→    lines.push(`❌ ${error.message}`);\n2202→    if (error.suggestion) {\n2203→      lines.push(`   建议: ${error.suggestion}`);\n2204→    }\n2205→  }\n2206→\n2207→  if (usage) {\n2208→    lines.push(`\\n用法: ${usage}`);\n2209→  }\n2210→\n2211→  return lines.join('\\n');\n2212→}\n2213→\n2214→/**\n2215→ * Format an error response into a display string.\n2216→ * @param {ErrorResponse} error - Error response\n2217→ * @returns {string} Formatted string\n2218→ */\n2219→export function formatErrorResponse(error) {\n2220→  const lines = [`❌ ${error.message}`];\n2221→\n2222→  if (error.suggestion) {\n2223→    lines.push(`💡 ${error.suggestion}`);\n2224→  }\n2225→\n2226→  if (error.usage) {\n2227→    lines.push(`用法: ${error.usage}`);\n2228→  }\n2229→\n2230→  return lines.join('\\n');\n2231→}\n2232→\n2233→```\n2234→\n2235→### src/bot/commands/help.js (130 lines)\n2236→\n2237→```js\n2238→/**\n2239→ * Help Text Generator\n2240→ * Generates help text for commands.\n2241→ */\n2242→\n2243→import { getCommand, getAllCommands } from './registry.js';\n2244→\n2245→/**\n2246→ * Generate help text for all commands or a specific command.\n2247→ * @param {string} [commandName] - Optional command name\n2248→ * @returns {string} Help text\n2249→ */\n2250→export function generateHelp(commandName) {\n2251→  if (commandName) {\n2252→    return generateCommandHelp(commandName);\n2253→  }\n2254→  return generateGeneralHelp();\n2255→}\n2256→\n2257→/**\n2258→ * Generate general help text listing all commands.\n2259→ * @returns {string} Help text\n2260→ */\n2261→function generateGeneralHelp() {\n2262→  const commands = getAllCommands();\n2263→\n2264→  if (commands.length === 0) {\n2265→    return '暂无可用命令。';\n2266→  }\n2267→\n2268→  const lines = ['可用命令：', ''];\n2269→\n2270→  for (const entry of commands) {\n2271→    const { meta } = entry;\n2272→    const aliases = meta.aliases?.length ? ` (${meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n2273→    lines.push(`/${meta.name}${aliases}`);\n2274→    lines.push(`  ${meta.description}`);\n2275→    lines.push('');\n2276→  }\n2277→\n2278→  lines.push('输入 /help <命令> 查看详细用法。');\n2279→\n2280→  return lines.join('\\n');\n2281→}\n2282→\n2283→/**\n2284→ * Generate detailed help text for a specific command.\n2285→ * @param {string} commandName - Command name\n2286→ * @returns {string} Help text\n2287→ */\n2288→function generateCommandHelp(commandName) {\n2289→  const entry = getCommand(commandName);\n2290→\n2291→  if (!entry) {\n2292→    return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n2293→  }\n2294→\n2295→  const { meta } = entry;\n2296→  const lines = [];\n2297→\n2298→  // Command name and description\n2299→  lines.push(`/${meta.name} - ${meta.description}`);\n2300→  lines.push('');\n2301→\n2302→  // Aliases\n2303→  if (meta.aliases?.length) {\n2304→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n2305→    lines.push('');\n2306→  }\n2307→\n2308→  // Usage\n2309→  if (meta.usage) {\n2310→    lines.push(`用法: ${meta.usage}`);\n2311→    lines.push('');\n2312→  }\n2313→\n2314→  // Subcommands\n2315→  if (meta.subcommands?.length) {\n2316→    lines.push('子命令:');\n2317→    for (const sub of meta.subcommands) {\n2318→      lines.push(`  ${sub.name} - ${sub.description}`);\n2319→    }\n2320→    lines.push('');\n2321→  }\n2322→\n2323→  // Parameters\n2324→  if (meta.params?.length) {\n2325→    lines.push('参数:');\n2326→    for (const param of meta.params) {\n2327→      const required = param.required ? '(必填)' : '(可选)';\n2328→      const type = param.type ? ` [${param.type}]` : '';\n2329→      const enumValues = param.enum ? ` {${param.enum.join(', ')}}` : '';\n2330→      const defaultVal = param.default !== undefined ? ` = ${param.default}` : '';\n2331→      lines.push(`  ${param.name}${type}${enumValues}${defaultVal} ${required}`);\n2332→      lines.push(`    ${param.description}`);\n2333→    }\n2334→    lines.push('');\n2335→  }\n2336→\n2337→  // Examples\n2338→  if (meta.examples?.length) {\n2339→    lines.push('示例:');\n2340→    for (const example of meta.examples) {\n2341→      lines.push(`  ${example}`);\n2342→    }\n2343→    lines.push('');\n2344→  }\n2345→\n2346→  return lines.join('\\n').trim();\n2347→}\n2348→\n2349→/**\n2350→ * Generate quick reference for all commands.\n2351→ * @returns {string} Quick reference text\n2352→ */\n2353→export function generateQuickReference() {\n2354→  const commands = getAllCommands();\n2355→\n2356→  if (commands.length === 0) {\n2357→    return '暂无可用命令。';\n2358→  }\n2359→\n2360→  const lines = commands.map((entry) => {\n2361→    const { meta } = entry;\n2362→    const aliases = meta.aliases?.length ? ` /${meta.aliases.join(' /')}` : '';\n2363→    return `/${meta.name}${aliases} - ${meta.description}`;\n2364→  });\n2365→\n2366→  return lines.join('\\n');\n2367→}\n2368→\n2369→```\n2370→\n2371→### src/bot/commands/handlers/pipeline.js (493 lines)\n2372→\n2373→```js\n2374→/**\n2375→ * Pipeline Command Handler\n2376→ * Handles /pipeline command with run/status/logs/stop subcommands.\n2377→ * F-006: Integrated with security guard\n2378→ */\n2379→\n2380→import {\n2381→  startPipeline,\n2382→  stopPipeline,\n2383→  getStatus,\n2384→  getLogs,\n2385→  forceUnlock\n2386→} from '../../../services/pipeline-controller.js';\n2387→import { formatValidationErrors as _formatValidationErrors, formatError as _formatError, ErrorCodes as _ErrorCodes } from '../formatter.js';\n2388→import { logAuditEntry } from '../../../services/audit-log-service.js';\n2389→import { sanitizeParam } from '../../../security/param-sanitizer.js';\n2390→import { isAdmin } from '../../../security/permission-guard.js';\n2391→import {\n2392→  createConfirmation,\n2393→  checkConfirmation as _checkConfirmation,\n2394→  confirmAction,\n2395→  cancelConfirmation\n2396→} from '../../../security/confirmation-manager.js';\n2397→\n2398→// Store pending confirmations for text-based flow\n2399→const pendingConfirmations = new Map();\n2400→\n2401→/**\n2402→ * Pipeline command metadata.\n2403→ * T-102: minRole added\n2404→ */\n2405→export const pipelineMeta = {\n2406→  name: 'pipeline',\n2407→  aliases: ['p'],\n2408→  description: '管理管道任务',\n2409→  usage: '/pipeline <action> [target] [--type=<type>]',\n2410→  examples: [\n2411→    '/pipeline run my-feature',\n2412→    '/pipeline run my-feature --type=bugfix',\n2413→    '/pipeline status',\n2414→    '/pipeline logs my-feature',\n2415→    '/pipeline stop my-feature',\n2416→    '/pipeline force-unlock'\n2417→  ],\n2418→  subcommands: [\n2419→    { name: 'run', description: '启动管道' },\n2420→    { name: 'status', description: '查询状态' },\n2421→    { name: 'logs', description: '查看日志' },\n2422→    { name: 'stop', description: '停止管道' },\n2423→    { name: 'force-unlock', description: '强制释放锁' }\n2424→  ],\n2425→  params: [\n2426→    {\n2427→      name: 'target',\n2428→      type: 'string',\n2429→      required: false,\n2430→      description: '目标标识符'\n2431→    },\n2432→    {\n2433→      name: 'type',\n2434→      type: 'enum',\n2435→      enum: ['feature', 'bugfix', 'planner'],\n2436→      required: false,\n2437→      default: 'feature',\n2438→      description: '管道类型'\n2439→    }\n2440→  ],\n2441→  requiresAuth: true,\n2442→  minRole: 'operator',\n2443→  helpText: '/pipeline <action> [target] [--type=<type>] - 管理管道任务'\n2444→};\n2445→\n2446→/**\n2447→ * Handle pipeline command.\n2448→ * @param {Object} handlerCtx - Handler context\n2449→ * @param {Object} handlerCtx.ctx - Telegraf context\n2450→ * @param {Object} handlerCtx.parsed - Parsed command\n2451→ * @param {Object} handlerCtx.params - Normalized parameters\n2452→ * @param {Function} handlerCtx.reply - Reply function\n2453→ */\n2454→export async function handlePipeline(handlerCtx) {\n2455→  const { ctx: _ctx, parsed, params: _params, reply } = handlerCtx;\n2456→\n2457→  // Determine action from subcommand or default to status\n2458→  const action = parsed.subcommand || 'status';\n2459→\n2460→  switch (action) {\n2461→    case 'run':\n2462→      // @ts-ignore — handlerCtx shape is validated at runtime\n2463→      return handleRun(handlerCtx);\n2464→    case 'status':\n2465→      // @ts-ignore — handlerCtx shape is validated at runtime\n2466→      return handleStatus(handlerCtx);\n2467→    case 'logs':\n2468→      // @ts-ignore — handlerCtx shape is validated at runtime\n2469→      return handleLogs(handlerCtx);\n2470→    case 'stop':\n2471→      return handlePipelineStop(handlerCtx);\n2472→    case 'force-unlock':\n2473→      return handleForceUnlock(handlerCtx);\n2474→    default:\n2475→      await reply(`未知操作 '${action}'。可用: run, status, logs, stop, force-unlock`);\n2476→  }\n2477→}\n2478→\n2479→/**\n2480→ * Handle run subcommand.\n2481→ * T-103: Added parameter sanitization and audit logging\n2482→ */\n2483→async function handleRun({ params, reply, parsed: _parsed, userId, userRole }) {\n2484→  const target = params._args?.[0] || params.target;\n2485→  const pipelineType = params.type || 'feature';\n2486→\n2487→  // T-103: Sanitize target parameter\n2488→  if (target) {\n2489→    const targetResult = sanitizeParam(target, { maxLength: 100 });\n2490→    if (!targetResult.ok) {\n2491→      await reply(`❌ 目标参数无效: ${targetResult.error}`);\n2492→      return;\n2493→    }\n2494→  }\n2495→\n2496→  // T-103: Sanitize type parameter\n2497→  const typeResult = sanitizeParam(pipelineType, { maxLength: 50 });\n2498→  if (!typeResult.ok) {\n2499→    await reply(`❌ 类型参数无效: ${typeResult.error}`);\n2500→    return;\n2501→  }\n2502→\n2503→  try {\n2504→    const result = await startPipeline({\n2505→      type: typeResult.value,\n2506→      targetId: target,\n2507→      daemon: true\n2508→    });\n2509→\n2510→    if (result.ok) {\n2511→      // T-107: Audit logging\n2512→      await logAuditEntry({\n2513→        userId,\n2514→        role: userRole,\n2515→        action: 'pipeline_run',\n2516→        params: { type: typeResult.value, target },\n2517→        result: 'success'\n2518→      });\n2519→\n2520→      const pidInfo = result.pid ? ` (PID: ${result.pid})` : '';\n2521→      await reply(`✅ 已启动 ${typeResult.value} 管道${target ? `: ${target}` : ''}${pidInfo}`);\n2522→    } else {\n2523→      const errorMsg = result.message || result.stderr || '未知错误';\n2524→      const hint = result.hint ? `\\n💡 提示: ${result.hint}` : '';\n2525→\n2526→      await logAuditEntry({\n2527→        userId,\n2528→        role: userRole,\n2529→        action: 'pipeline_run',\n2530→        params: { type: typeResult.value, target },\n2531→        result: 'failed',\n2532→        reason: errorMsg\n2533→      });\n2534→\n2535→      await reply(`❌ 启动失败: ${errorMsg}${hint}`);\n2536→    }\n2537→  } catch (error) {\n2538→    await logAuditEntry({\n2539→      userId,\n2540→      role: userRole,\n2541→      action: 'pipeline_run',\n2542→      params: { type: pipelineType, target },\n2543→      result: 'failed',\n2544→      reason: error.message\n2545→    });\n2546→    await reply(`❌ 启动失败: ${error.message}`);\n2547→  }\n2548→}\n2549→\n2550→/**\n2551→ * Handle status subcommand.\n2552→ */\n2553→async function handleStatus({ params, reply }) {\n2554→  const pipelineType = params.type || 'feature';\n2555→\n2556→  try {\n2557→    const result = await getStatus({ type: pipelineType });\n2558→\n2559→    if (result.ok) {\n2560→      const status = formatStatusOutput(result);\n2561→      await reply(status);\n2562→    } else {\n2563→      const errorMsg = result.message || result.stderr || '未知错误';\n2564→      await reply(`❌ 查询失败: ${errorMsg}`);\n2565→    }\n2566→  } catch (error) {\n2567→    await reply(`❌ 查询失败: ${error.message}`);\n2568→  }\n2569→}\n2570→\n2571→/**\n2572→ * Handle logs subcommand.\n2573→ */\n2574→async function handleLogs({ params, reply, replyFile, parsed: _parsed }) {\n2575→  const target = params._args?.[0] || params.target;\n2576→  const pipelineType = params.type || 'feature';\n2577→\n2578→  try {\n2579→    const result = await getLogs({ type: pipelineType, lines: 100 });\n2580→\n2581→    if (result.ok) {\n2582→      const logs = result.logs || '';\n2583→\n2584→      if (logs.length >= 4000) {\n2585→        await replyFile(logs, `pipeline-logs-${target || 'latest'}.txt`);\n2586→      } else {\n2587→        await reply(logs || '暂无日志');\n2588→      }\n2589→    } else {\n2590→      const errorMsg = result.message || '未知错误';\n2591→      await reply(`❌ 获取日志失败: ${errorMsg}`);\n2592→    }\n2593→  } catch (error) {\n2594→    await reply(`❌ 获取日志失败: ${error.message}`);\n2595→  }\n2596→}\n2597→\n2598→/**\n2599→ * Handle stop subcommand (pipeline stop).\n2600→ * T-104, T-106: Added confirmation flow\n2601→ * T-107: Added audit logging\n2602→ */\n2603→async function handlePipelineStop(handlerCtx) {\n2604→  const { params, reply, parsed, userId, userRole, requiresConfirmation } = handlerCtx;\n2605→\n2606→  // Sanitize type parameter (T-103)\n2607→  const pipelineType = params.type || 'feature';\n2608→  const typeResult = sanitizeParam(pipelineType, { maxLength: 50 });\n2609→  if (!typeResult.ok) {\n2610→    await reply(`❌ 类型参数无效: ${typeResult.error}`);\n2611→    return;\n2612→  }\n2613→\n2614→  // Check if force flag is set\n2615→  const forceFlag = params.force === true || parsed?.flags?.force === true;\n2616→  const canSkipConfirmation = isAdmin(userId) && forceFlag;\n2617→\n2618→  // Handle confirmation flow\n2619→  if (requiresConfirmation && !canSkipConfirmation) {\n2620→    const rawTarget = params._args?.[0] || params.target;\n2621→\n2622→    // Check if this is a CONFIRM response\n2623→    if (rawTarget === 'CONFIRM') {\n2624→      const pendingKey = `pipeline-stop:${userId}`;\n2625→      const confirmId = pendingConfirmations.get(pendingKey);\n2626→\n2627→      if (confirmId) {\n2628→        const result = confirmAction(confirmId, userId);\n2629→        if (result.ok) {\n2630→          pendingConfirmations.delete(pendingKey);\n2631→          await executePipelineStop(handlerCtx, result.params.type, userId, userRole, reply);\n2632→        } else {\n2633→          await reply(`❌ 确认失败: ${result.error}`);\n2634→        }\n2635→        return;\n2636→      } else {\n2637→        await reply('❌ 没有待确认的 stop 操作，或操作已过期。');\n2638→        return;\n2639→      }\n2640→    }\n2641→\n2642→    // Check if this is a CANCEL response\n2643→    if (rawTarget === 'CANCEL') {\n2644→      const pendingKey = `pipeline-stop:${userId}`;\n2645→      const confirmId = pendingConfirmations.get(pendingKey);\n2646→      if (confirmId) {\n2647→        cancelConfirmation(confirmId, userId);\n2648→        pendingConfirmations.delete(pendingKey);\n2649→        await reply('✅ 已取消 stop 操作。');\n2650→      } else {\n2651→        await reply('没有待确认的 stop 操作。');\n2652→      }\n2653→      return;\n2654→    }\n2655→\n2656→    // Create new confirmation\n2657→    const { confirmId, message } = createConfirmation(userId, 'pipeline-stop', { type: typeResult.value });\n2658→    pendingConfirmations.set(`pipeline-stop:${userId}`, confirmId);\n2659→\n2660→    await reply(`⚠️ 高风险操作确认\\n\\n${message}\\n\\n请回复 /pipeline stop CONFIRM 确认，或 /pipeline stop CANCEL 取消。`);\n2661→    return;\n2662→  }\n2663→\n2664→  // Execute directly\n2665→  await executePipelineStop(handlerCtx, typeResult.value, userId, userRole, reply);\n2666→}\n2667→\n2668→/**\n2669→ * Execute pipeline stop operation\n2670→ */\n2671→async function executePipelineStop(handlerCtx, pipelineType, userId, userRole, reply) {\n2672→  try {\n2673→    const result = await stopPipeline({ type: pipelineType });\n2674→\n2675→    if (result.ok) {\n2676→      await logAuditEntry({\n2677→        userId,\n2678→        role: userRole,\n2679→        action: 'pipeline_stop',\n2680→        params: { type: pipelineType },\n2681→        result: 'success'\n2682→      });\n2683→\n2684→      if (result.errorCode === 'ALREADY_STOPPED') {\n2685→        await reply(`⚠️ ${pipelineType} 管道未在运行。`);\n2686→      } else {\n2687→        const pidInfo = result.previousPid ? ` (原 PID: ${result.previousPid})` : '';\n2688→        await reply(`✅ 已停止 ${pipelineType} 管道${pidInfo}`);\n2689→      }\n2690→    } else {\n2691→      const errorMsg = result.message || '未知错误';\n2692→      await logAuditEntry({\n2693→        userId,\n2694→        role: userRole,\n2695→        action: 'pipeline_stop',\n2696→        params: { type: pipelineType },\n2697→        result: 'failed',\n2698→        reason: errorMsg\n2699→      });\n2700→      await reply(`❌ 停止失败: ${errorMsg}`);\n2701→    }\n2702→  } catch (error) {\n2703→    await logAuditEntry({\n2704→      userId,\n2705→      role: userRole,\n2706→      action: 'pipeline_stop',\n2707→      params: { type: pipelineType },\n2708→      result: 'failed',\n2709→      reason: error.message\n2710→    });\n2711→    await reply(`❌ 停止失败: ${error.message}`);\n2712→  }\n2713→}\n2714→\n2715→/**\n2716→ * Handle force-unlock subcommand.\n2717→ * T-105: Force-unlock command handler\n2718→ * T-104: Confirmation flow\n2719→ * T-107: Audit logging\n2720→ */\n2721→async function handleForceUnlock(handlerCtx) {\n2722→  const { params, reply, parsed, userId, userRole, requiresConfirmation } = handlerCtx;\n2723→\n2724→  // Sanitize type parameter (T-103)\n2725→  const pipelineType = params.type || 'feature';\n2726→  const typeResult = sanitizeParam(pipelineType, { maxLength: 50 });\n2727→  if (!typeResult.ok) {\n2728→    await reply(`❌ 类型参数无效: ${typeResult.error}`);\n2729→    return;\n2730→  }\n2731→\n2732→  // Check if force flag is set\n2733→  const forceFlag = params.force === true || parsed?.flags?.force === true;\n2734→  const canSkipConfirmation = isAdmin(userId) && forceFlag;\n2735→\n2736→  // Handle confirmation flow\n2737→  if (requiresConfirmation && !canSkipConfirmation) {\n2738→    const rawTarget = params._args?.[0] || params.target;\n2739→\n2740→    // Check if this is a CONFIRM response\n2741→    if (rawTarget === 'CONFIRM') {\n2742→      const pendingKey = `force-unlock:${userId}`;\n2743→      const confirmId = pendingConfirmations.get(pendingKey);\n2744→\n2745→      if (confirmId) {\n2746→        const result = confirmAction(confirmId, userId);\n2747→        if (result.ok) {\n2748→          pendingConfirmations.delete(pendingKey);\n2749→          await executeForceUnlock(handlerCtx, result.params.type, userId, userRole, reply);\n2750→        } else {\n2751→          await reply(`❌ 确认失败: ${result.error}`);\n2752→        }\n2753→        return;\n2754→      } else {\n2755→        await reply('❌ 没有待确认的 force-unlock 操作，或操作已过期。');\n2756→        return;\n2757→      }\n2758→    }\n2759→\n2760→    // Check if this is a CANCEL response\n2761→    if (rawTarget === 'CANCEL') {\n2762→      const pendingKey = `force-unlock:${userId}`;\n2763→      const confirmId = pendingConfirmations.get(pendingKey);\n2764→      if (confirmId) {\n2765→        cancelConfirmation(confirmId, userId);\n2766→        pendingConfirmations.delete(pendingKey);\n2767→        await reply('✅ 已取消 force-unlock 操作。');\n2768→      } else {\n2769→        await reply('没有待确认的 force-unlock 操作。');\n2770→      }\n2771→      return;\n2772→    }\n2773→\n2774→    // Create new confirmation\n2775→    const { confirmId, message } = createConfirmation(userId, 'force-unlock', { type: typeResult.value });\n2776→    pendingConfirmations.set(`force-unlock:${userId}`, confirmId);\n2777→\n2778→    await reply(`⚠️ 高风险操作确认\\n\\n${message}\\n\\n请回复 /pipeline force-unlock CONFIRM 确认，或 /pipeline force-unlock CANCEL 取消。`);\n2779→    return;\n2780→  }\n2781→\n2782→  // Execute directly\n2783→  await executeForceUnlock(handlerCtx, typeResult.value, userId, userRole, reply);\n2784→}\n2785→\n2786→/**\n2787→ * Execute force-unlock operation\n2788→ */\n2789→async function executeForceUnlock(handlerCtx, pipelineType, userId, userRole, reply) {\n2790→  try {\n2791→    const result = await forceUnlock({ type: pipelineType });\n2792→\n2793→    if (result.ok) {\n2794→      await logAuditEntry({\n2795→        userId,\n2796→        role: userRole,\n2797→        action: 'force-unlock',\n2798→        params: { type: pipelineType },\n2799→        result: 'success'\n2800→      });\n2801→\n2802→      if (result.wasLocked) {\n2803→        await reply(`✅ 已强制释放 ${pipelineType} 管道的锁 (原 PID: ${result.previousPid || '未知'})`);\n2804→      } else {\n2805→        await reply(`⚠️ ${pipelineType} 管道未被锁定。`);\n2806→      }\n2807→    } else {\n2808→      const errorMsg = result.message || '未知错误';\n2809→      await logAuditEntry({\n2810→        userId,\n2811→        role: userRole,\n2812→        action: 'force-unlock',\n2813→        params: { type: pipelineType },\n2814→        result: 'failed',\n2815→        reason: errorMsg\n2816→      });\n2817→      await reply(`❌ 释放锁失败: ${errorMsg}`);\n2818→    }\n2819→  } catch (error) {\n2820→    await logAuditEntry({\n2821→      userId,\n2822→      role: userRole,\n2823→      action: 'force-unlock',\n2824→      params: { type: pipelineType },\n2825→      result: 'failed',\n2826→      reason: error.message\n2827→    });\n2828→    await reply(`❌ 释放锁失败: ${error.message}`);\n2829→  }\n2830→}\n2831→\n2832→/**\n2833→ * Format status output.\n2834→ * @param {Object} result - Status result\n2835→ * @returns {string} Formatted status\n2836→ */\n2837→function formatStatusOutput(result) {\n2838→  if (!result.isRunning) {\n2839→    const lastResultInfo = result.lastResult\n2840→      ? `\\n最后一次运行: ${result.lastResult.status} (${result.lastResult.featuresCompleted}/${result.lastResult.featuresTotal})`\n2841→      : '';\n2842→    return `✅ ${result.message}${lastResultInfo}`;\n2843→  }\n2844→\n2845→  const lines = [`🔄 ${result.message}`, ''];\n2846→\n2847→  if (result.pid) {\n2848→    lines.push(`• PID: ${result.pid}`);\n2849→  }\n2850→\n2851→  if (result.currentFeature) {\n2852→    lines.push(`• 当前目标: ${result.currentFeature}`);\n2853→  }\n2854→\n2855→  if (result.startedAt) {\n2856→    lines.push(`• 开始时间: ${result.startedAt}`);\n2857→  }\n2858→\n2859→  if (result.lockInfo) {\n2860→    lines.push(`• 锁持有者 PID: ${result.lockInfo.pid}`);\n2861→  }\n2862→\n2863→  return lines.join('\\n');\n2864→}\n2865→\n2866→export default handlePipeline;\n2867→\n2868→```\n2869→\n2870→### src/bot/commands/handlers/planner.js (66 lines)\n2871→\n2872→```js\n2873→/**\n2874→ * Planner Command Handler\n2875→ * Handles /planner command for planner-type pipelines.\n2876→ */\n2877→\n2878→import { handlePipeline } from './pipeline.js';\n2879→\n2880→/**\n2881→ * Planner command metadata.\n2882→ */\n2883→export const plannerMeta = {\n2884→  name: 'planner',\n2885→  aliases: [],\n2886→  description: '管理 planner 管道',\n2887→  usage: '/planner <action> [target]',\n2888→  examples: ['/planner run my-feature', '/planner status', '/planner logs'],\n2889→  subcommands: [\n2890→    { name: 'run', description: '启动 planner 管道' },\n2891→    { name: 'status', description: '查询状态' },\n2892→    { name: 'logs', description: '查看日志' }\n2893→  ],\n2894→  params: [\n2895→    {\n2896→      name: 'target',\n2897→      type: 'string',\n2898→      required: false,\n2899→      description: '目标标识符'\n2900→    }\n2901→  ],\n2902→  requiresAuth: true,\n2903→  minRole: 'operator',\n2904→  helpText: '/planner <action> [target] - 管理 planner 管道'\n2905→};\n2906→\n2907→/**\n2908→ * Handle planner command.\n2909→ * Delegates to pipeline handler with type=planner.\n2910→ * @param {Object} handlerCtx - Handler context\n2911→ */\n2912→export async function handlePlanner(handlerCtx) {\n2913→  const { parsed, params } = handlerCtx;\n2914→\n2915→  // Determine action\n2916→  const _action = parsed.subcommand || 'status';\n2917→\n2918→  // For non-run actions, just use pipeline handler with planner type\n2919→  const modifiedCtx = {\n2920→    ...handlerCtx,\n2921→    params: {\n2922→      ...params,\n2923→      type: 'planner'\n2924→    }\n2925→  };\n2926→\n2927→  // If no subcommand and no target, default to status\n2928→  if (!parsed.subcommand) {\n2929→    modifiedCtx.parsed = {\n2930→      ...parsed,\n2931→      subcommand: 'status'\n2932→    };\n2933→  }\n2934→\n2935→  return handlePipeline(modifiedCtx);\n2936→}\n2937→\n2938→export default handlePlanner;\n2939→\n2940→```\n2941→\n2942→### src/bot/commands/handlers/bugfix.js (63 lines)\n2943→\n2944→```js\n2945→/**\n2946→ * Bugfix Command Handler\n2947→ * Handles /bugfix shortcut command.\n2948→ */\n2949→\n2950→import { handlePipeline } from './pipeline.js';\n2951→\n2952→/**\n2953→ * Bugfix command metadata.\n2954→ */\n2955→export const bugfixMeta = {\n2956→  name: 'bugfix',\n2957→  aliases: ['b'],\n2958→  description: '启动 bugfix 管道',\n2959→  usage: '/bugfix <target>',\n2960→  examples: ['/bugfix session-123', '/bugfix F-001-login-bug'],\n2961→  params: [\n2962→    {\n2963→      name: 'target',\n2964→      type: 'string',\n2965→      required: true,\n2966→      description: '目标标识符'\n2967→    }\n2968→  ],\n2969→  requiresAuth: true,\n2970→  minRole: 'operator',\n2971→  helpText: '/bugfix <target> - 快捷启动 bugfix 管道'\n2972→};\n2973→\n2974→/**\n2975→ * Handle bugfix command.\n2976→ * Delegates to pipeline handler with type=bugfix.\n2977→ * @param {Object} handlerCtx - Handler context\n2978→ */\n2979→export async function handleBugfix(handlerCtx) {\n2980→  const { parsed, params } = handlerCtx;\n2981→\n2982→  // Get target from positional args or params\n2983→  const target = params._args?.[0] || params.target;\n2984→\n2985→  if (!target) {\n2986→    await handlerCtx.reply('❌ 缺少参数 \\'target\\'。\\n用法: /bugfix <target>');\n2987→    return;\n2988→  }\n2989→\n2990→  // Delegate to pipeline handler with type=bugfix\n2991→  const modifiedCtx = {\n2992→    ...handlerCtx,\n2993→    parsed: {\n2994→      ...parsed,\n2995→      subcommand: 'run'\n2996→    },\n2997→    params: {\n2998→      ...params,\n2999→      type: 'bugfix',\n3000→      target\n3001→    }\n3002→  };\n3003→\n3004→  return handlePipeline(modifiedCtx);\n3005→}\n3006→\n3007→export default handleBugfix;\n3008→\n3009→```\n3010→\n3011→### src/bot/commands/handlers/ls.js (72 lines)\n3012→\n3013→```js\n3014→/**\n3015→ * LS Command Handler\n3016→ * F-010: File Manager\n3017→ *\n3018→ * Handles the /ls command for listing directory contents.\n3019→ */\n3020→\n3021→import { listDirectory, formatFileInfo } from '../../../services/file-service.js';\n3022→import { paginateOutput, storeOutputPages, hasMorePages } from '../../../services/output-pager-service.js';\n3023→import { sessionStore } from '../../../services/session-store.js';\n3024→\n3025→/**\n3026→ * LS command metadata.\n3027→ */\n3028→export const lsMeta = {\n3029→  name: 'ls',\n3030→  aliases: ['dir'],\n3031→  description: '列出目录内容',\n3032→  usage: '/ls [路径]',\n3033→  examples: ['/ls', '/ls /tmp', '/dir'],\n3034→  params: [],\n3035→  requiresAuth: true,\n3036→  minRole: 'viewer',\n3037→  helpText: '/ls [路径] - 列出目录内容（默认当前目录）'\n3038→};\n3039→\n3040→/**\n3041→ * Handle /ls command.\n3042→ * @param {Object} handlerCtx - Handler context\n3043→ */\n3044→export async function handleLs(handlerCtx) {\n3045→  const { reply, sessionId, args = [] } = handlerCtx;\n3046→\n3047→  // Get the path argument (optional)\n3048→  const dirPath = args[0];\n3049→\n3050→  // List directory\n3051→  const result = await listDirectory(dirPath, sessionId);\n3052→\n3053→  if (result.error) {\n3054→    await reply(`❌ ${result.error}`);\n3055→    return;\n3056→  }\n3057→\n3058→  // Format output\n3059→  const lines = [\n3060→    `📂 目录: ${result.path}`,\n3061→    `共 ${result.totalCount} 项`,\n3062→    ''\n3063→  ];\n3064→\n3065→  // Add each item\n3066→  for (const item of result.items) {\n3067→    lines.push(formatFileInfo(item));\n3068→  }\n3069→\n3070→  const output = lines.join('\\n');\n3071→\n3072→  // Paginate if needed\n3073→  const pages = paginateOutput(output);\n3074→  await reply(pages[0]);\n3075→\n3076→  if (pages.length > 1) {\n3077→    storeOutputPages(sessionId, pages.slice(1));\n3078→    await reply(`📄 输出已截断。使用 /more 查看更多内容。`);\n3079→  }\n3080→}\n3081→\n3082→export default {\n3083→  lsMeta,\n3084→  handleLs\n3085→};\n3086→\n3087→```\n3088→\n3089→### src/bot/commands/handlers/find.js (115 lines)\n3090→\n3091→```js\n3092→/**\n3093→ * Find Command Handler\n3094→ * F-010: File Manager\n3095→ *\n3096→ * Handles the /find command for searching files by glob pattern.\n3097→ */\n3098→\n3099→import { searchFiles, formatFileInfo } from '../../../services/file-service.js';\n3100→import { paginateOutput, storeOutputPages } from '../../../services/output-pager-service.js';\n3101→import { sessionStore } from '../../../services/session-store.js';\n3102→import { config } from '../../../config.js';\n3103→\n3104→/**\n3105→ * Find command metadata.\n3106→ */\n3107→export const findMeta = {\n3108→  name: 'find',\n3109→  aliases: [],\n3110→  description: '搜索文件',\n3111→  usage: '/find <模式> [路径]',\n3112→  examples: ['/find *.txt', '/find *.js /tmp', '/find **/*.test.js'],\n3113→  params: [],\n3114→  requiresAuth: true,\n3115→  minRole: 'viewer',\n3116→  helpText: '/find <模式> [路径] - 按文件名或glob模式搜索文件'\n3117→};\n3118→\n3119→/**\n3120→ * Parse find arguments\n3121→ * @param {string[]} args - Command arguments\n3122→ * @returns {{ pattern: string | null, cwd: string | null }}\n3123→ */\n3124→function parseFindArgs(args) {\n3125→  if (!args || args.length === 0) {\n3126→    return { pattern: null, cwd: null };\n3127→  }\n3128→\n3129→  // First arg is pattern, second is optional directory\n3130→  const pattern = args[0];\n3131→  const cwd = args.length > 1 ? args[1] : null;\n3132→\n3133→  return { pattern, cwd };\n3134→}\n3135→\n3136→/**\n3137→ * Handle /find command.\n3138→ * @param {Object} handlerCtx - Handler context\n3139→ */\n3140→export async function handleFind(handlerCtx) {\n3141→  const { reply, sessionId, args = [] } = handlerCtx;\n3142→\n3143→  // Parse arguments\n3144→  const { pattern, cwd } = parseFindArgs(args);\n3145→\n3146→  if (!pattern) {\n3147→    await reply('❌ 请提供搜索模式，例如: /find *.txt 或 /find **/*.js');\n3148→    return;\n3149→  }\n3150→\n3151→  // Search options\n3152→  const options = {\n3153→    maxDepth: config.fileMaxSearchDepth || 10,\n3154→    maxResults: config.fileMaxSearchResults || 100,\n3155→    cwd\n3156→  };\n3157→\n3158→  // Perform search\n3159→  const result = await searchFiles(pattern, options, sessionId);\n3160→\n3161→  if (result.error) {\n3162→    await reply(`❌ ${result.error}`);\n3163→    return;\n3164→  }\n3165→\n3166→  // Store results in session for pagination\n3167→  if (result.results.length > 0) {\n3168→    sessionStore.setSearchResults(sessionId, result.results);\n3169→  }\n3170→\n3171→  // Format output\n3172→  const lines = [\n3173→    `🔍 搜索: ${pattern}`,\n3174→    `找到 ${result.totalCount} 个结果${result.truncated ? ' (已截断)' : ''}`,\n3175→    ''\n3176→  ];\n3177→\n3178→  // Show first page of results\n3179→  const perPage = config.fileSearchResultsPerPage || 20;\n3180→  const displayResults = result.results.slice(0, perPage);\n3181→\n3182→  for (const item of displayResults) {\n3183→    lines.push(`${item.isDirectory ? '📁' : '📄'} ${item.relativePath} (${item.size} 字节)`);\n3184→  }\n3185→\n3186→  if (result.results.length > perPage) {\n3187→    lines.push('');\n3188→    lines.push(`显示前 ${perPage} 个结果。使用 /more 查看更多。`);\n3189→  }\n3190→\n3191→  const output = lines.join('\\n');\n3192→\n3193→  // Paginate if needed\n3194→  const pages = paginateOutput(output);\n3195→  await reply(pages[0]);\n3196→\n3197→  if (pages.length > 1) {\n3198→    storeOutputPages(sessionId, pages.slice(1));\n3199→    await reply(`📄 输出已截断。使用 /more 查看更多内容。`);\n3200→  }\n3201→}\n3202→\n3203→export default {\n3204→  findMeta,\n3205→  handleFind\n3206→};\n3207→\n3208→```\n3209→\n3210→### src/bot/commands/handlers/ps.js (108 lines)\n3211→\n3212→```js\n3213→/**\n3214→ * /ps Command Handler\n3215→ * F-012: System Monitor\n3216→ *\n3217→ * Returns process list with sorting and filtering options.\n3218→ */\n3219→\n3220→import { systemMonitorService } from '../../../services/system-monitor-service.js';\n3221→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n3222→\n3223→export const psMeta = {\n3224→  name: 'ps',\n3225→  aliases: [],\n3226→  description: '查看进程列表（支持排序和过滤）',\n3227→  usage: '/ps [--sort=cpu|memory] [--limit=N] [filter]',\n3228→  examples: ['/ps', '/ps --sort=memory', '/ps node', '/ps --sort=cpu --limit=10'],\n3229→  params: [],\n3230→  requiresAuth: true,\n3231→  minRole: 'viewer',\n3232→  helpText: '/ps [选项] [关键词] - 查看进程列表\\n选项:\\n  --sort=cpu|memory  按CPU或内存排序\\n  --limit=N          限制显示数量'\n3233→};\n3234→\n3235→const DEFAULT_LIMIT = 20;\n3236→\n3237→/**\n3238→ * Parse command arguments into options\n3239→ * @param {string[]} args\n3240→ * @returns {{sortBy: string, limit: number, filter: string}}\n3241→ */\n3242→export function parseOptions(args) {\n3243→  let sortBy = 'cpu';\n3244→  let limit = DEFAULT_LIMIT;\n3245→  const filterParts = [];\n3246→\n3247→  for (const arg of args) {\n3248→    if (arg.startsWith('--sort=')) {\n3249→      const value = arg.slice(7).toLowerCase();\n3250→      if (['cpu', 'memory'].includes(value)) {\n3251→        sortBy = value;\n3252→      }\n3253→    } else if (arg.startsWith('--limit=')) {\n3254→      const value = parseInt(arg.slice(8), 10);\n3255→      if (!isNaN(value) && value > 0 && value <= 100) {\n3256→        limit = value;\n3257→      }\n3258→    } else {\n3259→      filterParts.push(arg);\n3260→    }\n3261→  }\n3262→\n3263→  return {\n3264→    sortBy,\n3265→    limit,\n3266→    filter: filterParts.join(' ')\n3267→  };\n3268→}\n3269→\n3270→/**\n3271→ * Handle /ps command\n3272→ * @param {Object} handlerCtx - Handler context\n3273→ */\n3274→export async function handlePs(handlerCtx) {\n3275→  const { reply, args = [] } = handlerCtx;\n3276→\n3277→  try {\n3278→    const options = parseOptions(args);\n3279→    const processes = await systemMonitorService.getProcessList(options);\n3280→\n3281→    if (processes.length === 0) {\n3282→      if (options.filter) {\n3283→        await reply(`🔍 未找到匹配 \"${escapeMarkdownV2(options.filter)}\" 的进程。`);\n3284→      } else {\n3285→        await reply('📋 未找到任何进程。');\n3286→      }\n3287→      return;\n3288→    }\n3289→\n3290→    // Format as table\n3291→    const lines = [\n3292→      `📋 *进程列表* ${options.filter ? `\\(过滤: \"${escapeMarkdownV2(options.filter)}\")` : ''}`,\n3293→      `排序: ${options.sortBy === 'cpu' ? 'CPU' : '内存'} | 显示: ${processes.length}`,\n3294→      '',\n3295→      '```\\nPID      CPU%   MEM%   NAME',\n3296→      '-'.repeat(40)\n3297→    ];\n3298→\n3299→    for (const proc of processes) {\n3300→      const pid = String(proc.pid).padEnd(8);\n3301→      const cpu = `${proc.cpu.toFixed(1)}%`.padEnd(6);\n3302→      const mem = `${proc.memory.toFixed(1)}%`.padEnd(6);\n3303→      const name = proc.name.substring(0, 20);\n3304→      lines.push(`${pid}${cpu}${mem}${name}`);\n3305→    }\n3306→\n3307→    lines.push('```');\n3308→\n3309→    await reply(lines.join('\\n'));\n3310→  } catch (error) {\n3311→    const message = error instanceof Error ? error.message : String(error);\n3312→    await reply(`❌ 获取进程列表失败: ${escapeMarkdownV2(message)}`);\n3313→  }\n3314→}\n3315→\n3316→export default {\n3317→  psMeta,\n3318→  handlePs,\n3319→  parseOptions\n3320→};\n3321→\n3322→```\n3323→\n3324→### src/bot/commands/handlers/sysinfo.js (72 lines)\n3325→\n3326→```js\n3327→/**\n3328→ * /sysinfo Command Handler\n3329→ * F-012: System Monitor\n3330→ *\n3331→ * Returns system overview including CPU, memory, disk, and network status.\n3332→ */\n3333→\n3334→import { systemMonitorService } from '../../../services/system-monitor-service.js';\n3335→import { escapeMarkdownV2 } from '../../../utils/markdown-v2-formatter.js';\n3336→\n3337→export const sysinfoMeta = {\n3338→  name: 'sysinfo',\n3339→  aliases: ['si'],\n3340→  description: '查看系统状态概览（CPU、内存、磁盘、网络）',\n3341→  usage: '/sysinfo',\n3342→  examples: ['/sysinfo'],\n3343→  params: [],\n3344→  requiresAuth: true,\n3345→  minRole: 'viewer',\n3346→  helpText: '/sysinfo - 查看系统状态概览（CPU、内存、磁盘、网络）'\n3347→};\n3348→\n3349→/**\n3350→ * Handle /sysinfo command\n3351→ * @param {Object} handlerCtx - Handler context\n3352→ */\n3353→export async function handleSysinfo(handlerCtx) {\n3354→  const { reply } = handlerCtx;\n3355→\n3356→  try {\n3357→    const info = await systemMonitorService.getSystemInfo();\n3358→\n3359→    // Format as table\n3360→    const lines = [\n3361→      '📊 *系统状态概览*',\n3362→      '',\n3363→      `🖥️ *主机*: ${escapeMarkdownV2(info.hostname)}`,\n3364→      `⏱️ *运行时间*: ${systemMonitorService.formatUptime(info.uptime)}`,\n3365→      `💻 *平台*: ${escapeMarkdownV2(info.platform)}`,\n3366→      '',\n3367→      '*CPU*',\n3368→      `├ 型号: ${escapeMarkdownV2(info.cpu.model)}`,\n3369→      `├ 核心数: ${info.cpu.cores}`,\n3370→      `└ 使用率: ${info.cpu.usage.toFixed(1)}%`,\n3371→      '',\n3372→      '*内存*',\n3373→      `├ 总量: ${systemMonitorService.formatBytes(info.memory.total)}`,\n3374→      `├ 已用: ${systemMonitorService.formatBytes(info.memory.used)}`,\n3375→      `├ 空闲: ${systemMonitorService.formatBytes(info.memory.free)}`,\n3376→      `└ 使用率: ${info.memory.usagePercent.toFixed(1)}%`,\n3377→      '',\n3378→      '*磁盘*',\n3379→      `├ 总量: ${systemMonitorService.formatBytes(info.disk.total)}`,\n3380→      `├ 已用: ${systemMonitorService.formatBytes(info.disk.used)}`,\n3381→      `├ 空闲: ${systemMonitorService.formatBytes(info.disk.free)}`,\n3382→      `└ 使用率: ${info.disk.usagePercent.toFixed(1)}%`,\n3383→      '',\n3384→      '*网络*',\n3385→      `└ 接口: ${info.network.interfaces.join(', ') || 'N/A'}`\n3386→    ];\n3387→\n3388→    await reply(lines.join('\\n'));\n3389→  } catch (error) {\n3390→    const message = error instanceof Error ? error.message : String(error);\n3391→    await reply(`❌ 获取系统信息失败: ${escapeMarkdownV2(message)}`);\n3392→  }\n3393→}\n3394→\n3395→export default {\n3396→  sysinfoMeta,\n3397→  handleSysinfo\n3398→};\n3399→\n3400→```\n3401→\n3402→## Section 5 — Existing Tests\n3403→\n3404→### tests/bot/commands/parser.test.js (121 lines)\n3405→\n3406→```js\n3407→import test from 'node:test';\n3408→import assert from 'node:assert/strict';\n3409→import { parseCommand } from '../../../src/bot/commands/parser.js';\n3410→\n3411→test('parseCommand returns null for non-command text', () => {\n3412→  assert.equal(parseCommand('hello world'), null);\n3413→  assert.equal(parseCommand(''), null);\n3414→  assert.equal(parseCommand(null), null);\n3415→  assert.equal(parseCommand(undefined), null);\n3416→});\n3417→\n3418→test('parseCommand parses basic command', () => {\n3419→  const result = parseCommand('/start');\n3420→  assert.deepEqual(result, {\n3421→    command: 'start',\n3422→    subcommand: undefined,\n3423→    args: [],\n3424→    options: {},\n3425→    raw: '/start'\n3426→  });\n3427→});\n3428→\n3429→test('parseCommand parses command with subcommand', () => {\n3430→  const result = parseCommand('/pipeline run');\n3431→  assert.equal(result.command, 'pipeline');\n3432→  assert.equal(result.subcommand, 'run');\n3433→});\n3434→\n3435→test('parseCommand parses command with positional args', () => {\n3436→  const result = parseCommand('/bugfix session-123');\n3437→  assert.equal(result.command, 'bugfix');\n3438→  assert.deepEqual(result.args, []);\n3439→  // First token after command is treated as subcommand if it doesn't start with --\n3440→  assert.equal(result.subcommand, 'session-123');\n3441→});\n3442→\n3443→test('parseCommand parses --key=value options', () => {\n3444→  const result = parseCommand('/pipeline run --type=bugfix');\n3445→  assert.equal(result.command, 'pipeline');\n3446→  assert.equal(result.subcommand, 'run');\n3447→  assert.deepEqual(result.options, { type: 'bugfix' });\n3448→});\n3449→\n3450→test('parseCommand parses multiple options', () => {\n3451→  const result = parseCommand('/pipeline run --type=feature --verbose');\n3452→  assert.deepEqual(result.options, { type: 'feature', verbose: 'true' });\n3453→});\n3454→\n3455→test('parseCommand parses key=value without --', () => {\n3456→  const result = parseCommand('/pipeline run type=bugfix');\n3457→  assert.deepEqual(result.options, { type: 'bugfix' });\n3458→});\n3459→\n3460→test('parseCommand applies alias mapping', () => {\n3461→  const aliasMap = { p: 'pipeline', b: 'bugfix' };\n3462→  const result = parseCommand('/p run', aliasMap);\n3463→  assert.equal(result.command, 'pipeline');\n3464→  assert.equal(result.subcommand, 'run');\n3465→});\n3466→\n3467→test('parseCommand handles @bot suffix', () => {\n3468→  const result = parseCommand('/start@mybot');\n3469→  assert.equal(result.command, 'start');\n3470→});\n3471→\n3472→test('parseCommand normalizes command to lowercase', () => {\n3473→  const result = parseCommand('/PIPELINE RUN');\n3474→  assert.equal(result.command, 'pipeline');\n3475→  assert.equal(result.subcommand, 'run');\n3476→});\n3477→\n3478→test('parseCommand collects positional args after options', () => {\n3479→  const result = parseCommand('/pipeline run my-feature --type=bugfix');\n3480→  assert.equal(result.subcommand, 'run');\n3481→  assert.deepEqual(result.options, { type: 'bugfix' });\n3482→  // Args should be empty since first token after subcommand is captured\n3483→});\n3484→\n3485→test('parseCommand handles complex command', () => {\n3486→  const aliasMap = { p: 'pipeline' };\n3487→  const result = parseCommand('/p run my-feature --type=bugfix --verbose', aliasMap);\n3488→  assert.equal(result.command, 'pipeline');\n3489→  assert.equal(result.subcommand, 'run');\n3490→  assert.deepEqual(result.options, { type: 'bugfix', verbose: 'true' });\n3491→});\n3492→\n3493→test('parseCommand preserves raw text', () => {\n3494→  const text = '/pipeline run --type=bugfix';\n3495→  const result = parseCommand(text);\n3496→  assert.equal(result.raw, text);\n3497→});\n3498→\n3499→test('parseCommand handles empty options gracefully', () => {\n3500→  const result = parseCommand('/status');\n3501→  assert.deepEqual(result.options, {});\n3502→  assert.deepEqual(result.args, []);\n3503→});\n3504→\n3505→test('parseCommand parses /logs with target', () => {\n3506→  const result = parseCommand('/logs session-123');\n3507→  assert.equal(result.command, 'logs');\n3508→  assert.equal(result.subcommand, 'session-123');\n3509→});\n3510→\n3511→test('parseCommand parses /stop with target', () => {\n3512→  const result = parseCommand('/stop my-feature');\n3513→  assert.equal(result.command, 'stop');\n3514→  assert.equal(result.subcommand, 'my-feature');\n3515→});\n3516→\n3517→test('parseCommand handles alias /s for status', () => {\n3518→  const aliasMap = { s: 'status' };\n3519→  const result = parseCommand('/s', aliasMap);\n3520→  assert.equal(result.command, 'status');\n3521→});\n3522→\n3523→test('parseCommand handles alias /l for logs', () => {\n3524→  const aliasMap = { l: 'logs' };\n3525→  const result = parseCommand('/l session-123', aliasMap);\n3526→  assert.equal(result.command, 'logs');\n3527→});\n3528→\n3529→```\n3530→\n3531→### tests/bot/commands/registry.test.js (153 lines)\n3532→\n3533→```js\n3534→import test from 'node:test';\n3535→import assert from 'node:assert/strict';\n3536→import {\n3537→  registerCommand,\n3538→  getCommand,\n3539→  getAllCommands,\n3540→  isAlias,\n3541→  getHelpText,\n3542→  clearRegistry,\n3543→  getAliasMap\n3544→} from '../../../src/bot/commands/registry.js';\n3545→\n3546→test.beforeEach(() => {\n3547→  clearRegistry();\n3548→});\n3549→\n3550→test('registerCommand stores command with metadata', () => {\n3551→  const meta = {\n3552→    name: 'test',\n3553→    