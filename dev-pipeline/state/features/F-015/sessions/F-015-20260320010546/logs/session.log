{"type":"assistant","uuid":"9a1a6384-9283-429f-8e9f-27f96a91c775","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"id":"9a1a6384-9283-429f-8e9f-27f96a91c775","content":[{"type":"tool_use","id":"toolu_bdrk_013JpY2y74RdnG5bFwLDRmbB","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/registry.js"}}],"model":"gpt-5.3-codex","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":39719,"output_tokens":152,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:15.083Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"b0acb4de-cdcb-4eed-b050-ed01562d374f","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_01VamTUdW7zst3xZ8DefQx25","content":[{"type":"text","text":"   1→/**\n   2→ * Command Validator\n   3→ * Validates command parameters and generates error messages.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ValidationError\n   8→ * @property {string} param - Parameter name\n   9→ * @property {string} message - Error message\n  10→ * @property {string} [suggestion] - Correction suggestion\n  11→ */\n  12→\n  13→/**\n  14→ * @typedef {Object} ValidationResult\n  15→ * @property {boolean} valid - Whether validation passed\n  16→ * @property {ValidationError[]} errors - Validation errors\n  17→ * @property {Record<string, *>} [normalized] - Normalized parameters\n  18→ */\n  19→\n  20→/**\n  21→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  22→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  23→ * @typedef {import('./registry.js').ParamMeta} ParamMeta\n  24→ * @typedef {import('./registry.js').SubcommandMeta} SubcommandMeta\n  25→ */\n  26→\n  27→/**\n  28→ * Validate a parsed command against its metadata.\n  29→ * @param {ParsedCommand} parsed - Parsed command\n  30→ * @param {CommandMeta} meta - Command metadata\n  31→ * @returns {ValidationResult} Validation result\n  32→ */\n  33→export function validateCommand(parsed, meta) {\n  34→  const errors = [];\n  35→  /** @type {Record<string, *>} */\n  36→  const normalized = { ...parsed.options };\n  37→\n  38→  // Validate subcommand if command has subcommands\n  39→  if (meta.subcommands?.length) {\n  40→    const validSubcommands = meta.subcommands.map((s) => s.name);\n  41→    if (parsed.subcommand && !validSubcommands.includes(parsed.subcommand)) {\n  42→      errors.push({\n  43→        param: 'subcommand',\n  44→        message: `未知子命令 '${parsed.subcommand}'`,\n  45→        suggestion: `可用子命令: ${validSubcommands.join(', ')}`\n  46→      });\n  47→    }\n  48→  }\n  49→\n  50→  // Get applicable params\n  51→  const params = getParamsForSubcommand(meta, parsed.subcommand);\n  52→\n  53→  // Validate parameters\n  54→  for (let i = 0; i < params.length; i++) {\n  55→    const param = params[i];\n  56→    const value = getParamValue(parsed, param.name, meta, i);\n  57→    const validationResult = validateParam(param, value);\n  58→\n  59→    if (!validationResult.valid) {\n  60→      errors.push(validationResult.error);\n  61→    } else if (validationResult.value !== undefined) {\n  62→      normalized[param.name] = validationResult.value;\n  63→    }\n  64→  }\n  65→\n  66→  // Add positional args to normalized\n  67→  if (parsed.args.length > 0) {\n  68→    normalized._args = parsed.args;\n  69→  }\n  70→\n  71→  return {\n  72→    valid: errors.length === 0,\n  73→    errors,\n  74→    normalized: errors.length === 0 ? normalized : undefined\n  75→  };\n  76→}\n  77→\n  78→/**\n  79→ * Get parameters applicable to a subcommand.\n  80→ * @param {CommandMeta} meta - Command metadata\n  81→ * @param {string|undefined} subcommand - Subcommand name\n  82→ * @returns {ParamMeta[]} Parameters\n  83→ */\n  84→function getParamsForSubcommand(meta, subcommand) {\n  85→  const params = [...(meta.params || [])];\n  86→\n  87→  // Add subcommand-specific params\n  88→  if (subcommand && meta.subcommands) {\n  89→    const subMeta = meta.subcommands.find((s) => s.name === subcommand);\n  90→    if (subMeta?.params) {\n  91→      params.push(...subMeta.params);\n  92→    }\n  93→  }\n  94→\n  95→  return params;\n  96→}\n  97→\n  98→/**\n  99→ * Get parameter value from parsed command.\n 100→ * @param {ParsedCommand} parsed - Parsed command\n 101→ * @param {string} paramName - Parameter name\n 102→ * @param {CommandMeta} meta - Command metadata\n 103→ * @param {number} paramIndex - Index of parameter in params array\n 104→ * @returns {string|undefined} Parameter value\n 105→ */\n 106→function getParamValue(parsed, paramName, meta, paramIndex) {\n 107→  // Check options first (explicit --key=value takes precedence)\n 108→  if (parsed.options[paramName] !== undefined) {\n 109→    return parsed.options[paramName];\n 110→  }\n 111→\n 112→  // Build positional args list\n 113→  // If command has no subcommands, parsed.subcommand should be treated as first positional arg\n 114→  const hasSubcommands = meta.subcommands && meta.subcommands.length > 0;\n 115→  const positionalArgs = [];\n 116→\n 117→  if (!hasSubcommands && parsed.subcommand !== undefined) {\n 118→    // F002-CRIT-001: Treat subcommand as first positional param when command has no subcommands\n 119→    positionalArgs.push(parsed.subcommand);\n 120→  }\n 121→\n 122→  // Add remaining args\n 123→  positionalArgs.push(...parsed.args);\n 124→\n 125→  // Map positional arg by index\n 126→  if (paramIndex !== undefined && positionalArgs[paramIndex] !== undefined) {\n 127→    return positionalArgs[paramIndex];\n 128→  }\n 129→\n 130→  return undefined;\n 131→}\n 132→\n 133→/**\n 134→ * Validate a single parameter.\n 135→ * @param {ParamMeta} param - Parameter metadata\n 136→ * @param {string|undefined} value - Parameter value\n 137→ * @returns {{valid: boolean, error?: ValidationError, value?: *}}\n 138→ */\n 139→function validateParam(param, value) {\n 140→  // Check required\n 141→  if (param.required && (value === undefined || value === '')) {\n 142→    return {\n 143→      valid: false,\n 144→      error: {\n 145→        param: param.name,\n 146→        message: `缺少参数 '${param.name}'`,\n 147→        suggestion: `请提供 ${param.name} 参数`\n 148→      }\n 149→    };\n 150→  }\n 151→\n 152→  // If not provided and has default, use default\n 153→  if (value === undefined && param.default !== undefined) {\n 154→    return { valid: true, value: param.default };\n 155→  }\n 156→\n 157→  // If not provided and not required, OK\n 158→  if (value === undefined) {\n 159→    return { valid: true };\n 160→  }\n 161→\n 162→  // Type validation\n 163→  if (param.type === 'number') {\n 164→    const num = Number(value);\n 165→    if (Number.isNaN(num)) {\n 166→      return {\n 167→        valid: false,\n 168→        error: {\n 169→          param: param.name,\n 170→          message: `参数 '${param.name}' 必须是数字`,\n 171→          suggestion: `请输入有效的数字`\n 172→        }\n 173→      };\n 174→    }\n 175→    return { valid: true, value: num };\n 176→  }\n 177→\n 178→  // Enum validation\n 179→  if (param.type === 'enum' && param.enum?.length) {\n 180→    if (!param.enum.includes(value)) {\n 181→      return {\n 182→        valid: false,\n 183→        error: {\n 184→          param: param.name,\n 185→          message: `参数 '${param.name}' 值无效: ${value}`,\n 186→          suggestion: `可选值: ${param.enum.join(', ')}`\n 187→        }\n 188→      };\n 189→    }\n 190→  }\n 191→\n 192→  return { valid: true, value };\n 193→}\n 194→\n 195→/**\n 196→ * Validate that a subcommand is valid for a command.\n 197→ * @param {string} subcommand - Subcommand name\n 198→ * @param {SubcommandMeta[]} subcommands - Available subcommands\n 199→ * @returns {{valid: boolean, error?: ValidationError}}\n 200→ */\n 201→export function validateSubcommand(subcommand, subcommands) {\n 202→  if (!subcommand) {\n 203→    return { valid: true };\n 204→  }\n 205→\n 206→  const validNames = (subcommands || []).map((s) => s.name);\n 207→  if (validNames.length === 0) {\n 208→    return { valid: true };\n 209→  }\n 210→\n 211→  if (!validNames.includes(subcommand)) {\n 212→    return {\n 213→      valid: false,\n 214→      error: {\n 215→        param: 'subcommand',\n 216→        message: `未知子命令 '${subcommand}'`,\n 217→        suggestion: `可用子命令: ${validNames.join(', ')}`\n 218→      }\n 219→    };\n 220→  }\n 221→\n 222→  return { valid: true };\n 223→}\n 224→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:15.088Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"dc81bbaf-2d5e-4d2c-a340-8ad0b1c81b3f","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_013JpY2y74RdnG5bFwLDRmbB","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  /** @type {Record<string, string>} */\n 215→  const map = {};\n 216→  for (const [alias, command] of aliasToCommand) {\n 217→    map[alias] = command;\n 218→  }\n 219→  return map;\n 220→}\n 221→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:15.090Z","_requestId":"261f0390879c473391691a62bef865bb"}
