'));\n3849→});\n3850→\n3851→test('validateCommand handles subcommand-specific params', () => {\n3852→  const parsed = { command: 'pipeline', subcommand: 'run', args: [], options: { target: 'my-feature' } };\n3853→  const meta = {\n3854→    name: 'pipeline',\n3855→    subcommands: [\n3856→      { name: 'run', description: 'Run', params: [{ name: 'target', required: false, description: 'Target' }] }\n3857→    ],\n3858→    params: [],\n3859→    requiresAuth: true\n3860→  };\n3861→\n3862→  const result = validateCommand(parsed, meta);\n3863→  assert.equal(result.valid, true);\n3864→});\n3865→\n3866→// F002-CRIT-001: Parser incorrectly treats positional arguments as subcommands\n3867→// For commands without subcommands, parsed.subcommand should be used as first positional param\n3868→test('validateCommand uses subcommand as positional param when command has no subcommands (bugfix)', () => {\n3869→  // /bugfix session-123 -> parser sets subcommand: \"session-123\", args: []\n3870→  const parsed = { command: 'bugfix', subcommand: 'session-123', args: [], options: {} };\n3871→  const meta = {\n3872→    name: 'bugfix',\n3873→    params: [{ name: 'target', required: true, description: 'Target ID' }],\n3874→    requiresAuth: true\n3875→    // No subcommands defined\n3876→  };\n3877→\n3878→  const result = validateCommand(parsed, meta);\n3879→  assert.equal(result.valid, true);\n3880→  assert.equal(result.normalized.target, 'session-123');\n3881→});\n3882→\n3883→test('validateCommand uses subcommand as positional param when command has no subcommands (logs)', () => {\n3884→  // /logs my-feature -> parser sets subcommand: \"my-feature\", args: []\n3885→  const parsed = { command: 'logs', subcommand: 'my-feature', args: [], options: {} };\n3886→  const meta = {\n3887→    name: 'logs',\n3888→    params: [{ name: 'target', required: false, description: 'Target ID' }],\n3889→    requiresAuth: true\n3890→    // No subcommands defined\n3891→  };\n3892→\n3893→  const result = validateCommand(parsed, meta);\n3894→  assert.equal(result.valid, true);\n3895→  assert.equal(result.normalized.target, 'my-feature');\n3896→});\n3897→\n3898→test('validateCommand uses subcommand as positional param when command has no subcommands (stop)', () => {\n3899→  // /stop my-feature -> parser sets subcommand: \"my-feature\", args: []\n3900→  const parsed = { command: 'stop', subcommand: 'my-feature', args: [], options: {} };\n3901→  const meta = {\n3902→    name: 'stop',\n3903→    params: [{ name: 'target', required: false, description: 'Target ID' }],\n3904→    requiresAuth: true\n3905→    // No subcommands defined\n3906→  };\n3907→\n3908→  const result = validateCommand(parsed, meta);\n3909→  assert.equal(result.valid, true);\n3910→  assert.equal(result.normalized.target, 'my-feature');\n3911→});\n3912→\n3913→test('validateCommand prioritizes explicit options over positional fallback', () => {\n3914→  // /bugfix session-123 --target=other-target\n3915→  const parsed = { command: 'bugfix', subcommand: 'session-123', args: [], options: { target: 'other-target' } };\n3916→  const meta = {\n3917→    name: 'bugfix',\n3918→    params: [{ name: 'target', required: true, description: 'Target ID' }],\n3919→    requiresAuth: true\n3920→  };\n3921→\n3922→  const result = validateCommand(parsed, meta);\n3923→  assert.equal(result.valid, true);\n3924→  // Explicit option should take precedence\n3925→  assert.equal(result.normalized.target, 'other-target');\n3926→});\n3927→\n3928→test('validateCommand handles second positional param from args', () => {\n3929→  // /command first second -> parser sets subcommand: \"first\", args: [\"second\"]\n3930→  const parsed = { command: 'test', subcommand: 'first', args: ['second'], options: {} };\n3931→  const meta = {\n3932→    name: 'test',\n3933→    params: [\n3934→      { name: 'param1', required: true, description: 'First param' },\n3935→      { name: 'param2', required: false, description: 'Second param' }\n3936→    ],\n3937→    requiresAuth: true\n3938→  };\n3939→\n3940→  const result = validateCommand(parsed, meta);\n3941→  assert.equal(result.valid, true);\n3942→  assert.equal(result.normalized.param1, 'first');\n3943→  assert.equal(result.normalized.param2, 'second');\n3944→});\n3945→\n3946→```\n3947→\n3948→### tests/bot/commands/formatter.test.js (93 lines)\n3949→\n3950→```js\n3951→import test from 'node:test';\n3952→import assert from 'node:assert/strict';\n3953→import { formatError, formatValidationErrors, formatErrorResponse, ErrorCodes } from '../../../src/bot/commands/formatter.js';\n3954→\n3955→test('formatError UNKNOWN_COMMAND', () => {\n3956→  const error = formatError(ErrorCodes.UNKNOWN_COMMAND, { command: 'xyz' });\n3957→  assert.equal(error.code, ErrorCodes.UNKNOWN_COMMAND);\n3958→  assert.ok(error.message.includes('未知命令'));\n3959→  assert.ok(error.message.includes('xyz'));\n3960→  assert.ok(error.suggestion.includes('/help'));\n3961→});\n3962→\n3963→test('formatError UNKNOWN_SUBCOMMAND', () => {\n3964→  const error = formatError(ErrorCodes.UNKNOWN_SUBCOMMAND, {\n3965→    subcommand: 'xyz',\n3966→    available: ['run', 'status']\n3967→  });\n3968→  assert.equal(error.code, ErrorCodes.UNKNOWN_SUBCOMMAND);\n3969→  assert.ok(error.message.includes('未知子命令'));\n3970→  assert.ok(error.suggestion.includes('run'));\n3971→});\n3972→\n3973→test('formatError MISSING_PARAM', () => {\n3974→  const error = formatError(ErrorCodes.MISSING_PARAM, { param: 'target' });\n3975→  assert.equal(error.code, ErrorCodes.MISSING_PARAM);\n3976→  assert.ok(error.message.includes('缺少参数'));\n3977→  assert.ok(error.message.includes('target'));\n3978→});\n3979→\n3980→test('formatError INVALID_PARAM', () => {\n3981→  const error = formatError(ErrorCodes.INVALID_PARAM, {\n3982→    param: 'type',\n3983→    reason: '无效值',\n3984→    suggestion: '可选: feature, bugfix'\n3985→  });\n3986→  assert.equal(error.code, ErrorCodes.INVALID_PARAM);\n3987→  assert.ok(error.message.includes('无效'));\n3988→  assert.ok(error.suggestion.includes('feature'));\n3989→});\n3990→\n3991→test('formatError UNAUTHORIZED', () => {\n3992→  const error = formatError(ErrorCodes.UNAUTHORIZED, {});\n3993→  assert.equal(error.code, ErrorCodes.UNAUTHORIZED);\n3994→  assert.ok(error.message.includes('未被授权'));\n3995→});\n3996→\n3997→test('formatError INTERNAL_ERROR', () => {\n3998→  const error = formatError(ErrorCodes.INTERNAL_ERROR, { reason: 'Connection failed' });\n3999→  assert.equal(error.code, ErrorCodes.INTERNAL_ERROR);\n4000→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ytOeuPPPaoMyUkPYR8DqfePP","__timestamp":"2026-03-19T17:13:00.485Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"2f5876d8-9237-45e6-8b8b-74bb7f2e0228","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_01TEkvSK1mid3UqsFBuzGEhv","content":[{"type":"text","text":"   1→# F-015 Plan — Universal Command Natural-Language Routing\n   2→\n   3→## Scope\n   4→为 Telegram 命令系统增加统一自然语言路由层，覆盖：\n   5→1. `命令 + 自然语言补充`（例如 `/pipeline 帮我看日志`）\n   6→2. `纯自然语言意图`（例如 `帮我看一下当前 pipeline 状态`）\n   7→\n   8→同时保持现有严格协议：显式结构化参数优先；低置信度或语义冲突时返回候选动作和确认提示。\n   9→\n  10→## Architecture\n  11→\n  12→### 1) Intent Router Layer（新增）\n  13→新增独立模块：`src/bot/commands/intent-router.js`\n  14→\n  15→职责：\n  16→- 将文本映射为候选动作（command/subcommand/args）\n  17→- 计算置信度并输出排序后的 candidates\n  18→- 支持两种模式：\n  19→  - **补全模式**（已有命令前缀 `/xxx ...`）\n  20→  - **纯自然语言模式**（无 `/`）\n  21→\n  22→输出结构（建议）：\n  23→- `matched: boolean`\n  24→- `confidence: number`\n  25→- `primary: { command, subcommand?, args?, reason } | null`\n  26→- `candidates: Array<{ command, subcommand?, args?, confidence, reason }>`\n  27→- `needsConfirmation: boolean`\n  28→- `ambiguityReason?: string`\n  29→\n  30→### 2) Route Integration（改造）\n  31→改造 `src/bot/commands/index.js` 的 `routeCommand(ctx)`：\n  32→\n  33→- 在现有流程中插入两段逻辑：\n  34→  1. **Slash Command Enhancement**：当命令存在但子命令无效或文本是自然语言补充时，调用 intent router 做子命令补全/修正\n  35→  2. **Pure NL Routing**：当消息不以 `/` 开头时，先走 intent router，命中高置信度则合成命令并复用现有验证与 handler 链路；低置信度返回候选建议\n  36→\n  37→- 保持既有安全链路不变：\n  38→  - `isAllowedUser` 授权\n  39→  - `checkCommandPermission` 权限\n  40→  - `validateCommand` 参数验证\n  41→\n  42→### 3) Structured-First Policy（优先级策略）\n  43→实现并验证以下优先级：\n  44→1. 显式结构化输入优先（有效 subcommand / 显式 options）\n  45→2. 仅在结构化信息缺失、无效或明显为自然语言补充时启用推断\n  46→3. 冲突时不静默覆盖，返回候选动作 + 确认提示\n  47→\n  48→### 4) UX / Error Feedback（可解释输出）\n  49→在 `src/bot/commands/formatter.js`（或 index.js 内的响应拼装）补充统一提示模板：\n  50→- 低置信度：`我不完全确定你的意图，候选动作如下...`\n  51→- 冲突：`检测到显式参数与语义推断冲突，已按显式参数执行/请确认`（按策略）\n  52→- 不再直接仅返回“未知子命令”作为唯一反馈（对可推断场景）\n  53→\n  54→## Data Flow\n  55→\n  56→### A. Slash + NL\n  57→`/pipeline 帮我看最近日志`\n  58→→ parseCommand\n  59→→ command= pipeline，subcommand= 帮我看最近日志（无效）\n  60→→ intent-router 在 pipeline 作用域内推断为 logs\n  61→→ validateCommand（结构化后）\n  62→→ handler 执行\n  63→\n  64→### B. Pure NL\n  65→`帮我看一下当前 pipeline 状态`\n  66→→ routeCommand 进入 pure NL 分支\n  67→→ intent-router 推断 `pipeline status`\n  68→→ 合成 ParsedCommand（或合成命令文本后复用 parse）\n  69→→ validate + permission + handler\n  70→\n  71→### C. Ambiguous\n  72→`帮我处理一下`\n  73→→ intent-router 多候选且低置信度\n  74→→ 返回 candidates（如 pipeline status / planner status / jobs）\n  75→→ 请求用户确认，不直接报 unknown subcommand\n  76→\n  77→## Files To Modify / Create\n  78→\n  79→### Create\n  80→- `src/bot/commands/intent-router.js`（新）\n  81→- `tests/bot/commands/intent-router.test.js`（新）\n  82→- `tests/integration/f015-nl-routing.integration.test.js`（新，测试矩阵）\n  83→\n  84→### Modify\n  85→- `src/bot/commands/index.js`（接入 NL 路由与候选反馈）\n  86→- `src/bot/commands/formatter.js`（如需新增候选/冲突提示格式）\n  87→- `tests/bot/commands/parser.test.js`（必要时补充命令+NL 输入场景）\n  88→- `tests/integration/f002-command-router.integration.test.js`（保持兼容断言）\n  89→\n  90→## Testing Strategy\n  91→\n  92→1. 单元测试（intent-router）\n  93→- 多命令类别：pipeline/planner/bugfix/file/system\n  94→- 关键词匹配与置信度排序\n  95→- 冲突/歧义检测\n  96→\n  97→2. 路由集成测试（routeCommand）\n  98→- slash + NL 补全\n  99→- pure NL 路由\n 100→- 低置信度候选提示\n 101→- structured-first 不回归\n 102→\n 103→3. 回归测试\n 104→- 现有 `/pipeline run ...`、`/bugfix ...`、`/ls ...`、`/ps ...` 等严格输入行为保持\n 105→\n 106→## Tasks\n 107→\n 108→- [ ] T1: Add intent router module (`src/bot/commands/intent-router.js`) with scoring, candidate ranking, and ambiguity detection\n 109→- [ ] T2: Add unit tests for intent router (`tests/bot/commands/intent-router.test.js`) using command-category matrix and ambiguity cases\n 110→- [ ] T3: Integrate slash-command NL enhancement in `routeCommand` while preserving explicit structured precedence\n 111→- [ ] T4: Integrate pure-NL routing path in `routeCommand` with safe fallback (candidate suggestions + confirmation prompt)\n 112→- [ ] T5: Update/extend formatter and routing error output so low-confidence/semantic-conflict returns candidates instead of only unknown subcommand\n 113→- [ ] T6: Add integration tests (`tests/integration/f015-nl-routing.integration.test.js`) for acceptance criteria matrix (multi-category, ambiguity, fallback)\n 114→- [ ] T7: Run targeted tests for new/changed suites and then project tests; fix regressions until passing\n 115→- [ ] T8: Mark all tasks complete and append Implementation Log to `context-snapshot.md`"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ytOeuPPPaoMyUkPYR8DqfePP","__timestamp":"2026-03-19T17:13:00.504Z","_requestId":"261f0390879c473391691a62bef865bb"}
