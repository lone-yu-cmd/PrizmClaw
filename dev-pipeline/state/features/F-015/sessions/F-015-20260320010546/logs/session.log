{"type":"user","uuid":"68292554-48a0-4385-95d1-e0c1438e0686","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_01WWsHv4kJBMvz3VKkg9FyCu","content":[{"type":"text","text":"   1→/**\n   2→ * F-015 Integration Tests — Universal Command Natural-Language Routing\n   3→ *\n   4→ * Tests the complete routing pipeline:\n   5→ *  - Slash + NL enhancement\n   6→ *  - Pure NL routing\n   7→ *  - Low-confidence candidate suggestions\n   8→ *  - Structured-first non-regression\n   9→ *  - Multi-category command coverage\n  10→ */\n  11→\n  12→import test from 'node:test';\n  13→import assert from 'node:assert/strict';\n  14→import os from 'node:os';\n  15→import path from 'node:path';\n  16→import { routeCommand, registerCommand } from '../../src/bot/commands/index.js';\n  17→import { clearRegistry } from '../../src/bot/commands/registry.js';\n  18→import { aliasStore } from '../../src/services/alias-store.js';\n  19→import { pipelineMeta } from '../../src/bot/commands/handlers/pipeline.js';\n  20→import { plannerMeta } from '../../src/bot/commands/handlers/planner.js';\n  21→import { bugfixMeta } from '../../src/bot/commands/handlers/bugfix.js';\n  22→import { lsMeta } from '../../src/bot/commands/handlers/ls.js';\n  23→import { psMeta } from '../../src/bot/commands/handlers/ps.js';\n  24→import { sysinfoMeta } from '../../src/bot/commands/handlers/sysinfo.js';\n  25→\n  26→// ─── One-time setup: initialize alias store ───────────────────────────────────\n  27→\n  28→const ALIAS_FILE = path.join(os.tmpdir(), `f015-aliases-${process.pid}.json`);\n  29→\n  30→// Initialize alias store once before all tests\n  31→{\n  32→  await aliasStore.initAliasStore({ persistencePath: ALIAS_FILE }).catch(() => {\n  33→    // If already initialized, reset and re-init\n  34→    aliasStore.reset();\n  35→    return aliasStore.initAliasStore({ persistencePath: ALIAS_FILE });\n  36→  });\n  37→}\n  38→\n  39→// ─── Mock helpers ─────────────────────────────────────────────────────────────\n  40→\n  41→/**\n  42→ * Create a minimal Telegraf-like context for testing.\n  43→ * @param {string} text - Message text\n  44→ * @returns {Object} Mock context\n  45→ */\n  46→function createCtx(text) {\n  47→  const replies = [];\n  48→  return {\n  49→    from: { id: 12345 },\n  50→    chat: { id: 999 },\n  51→    message: { text },\n  52→    reply: async (msg) => { replies.push(msg); return msg; },\n  53→    replyWithDocument: async () => {},\n  54→    // Expose collected replies for assertions\n  55→    _replies: replies\n  56→  };\n  57→}\n  58→\n  59→/**\n  60→ * Register a stub handler that records invocations.\n  61→ * @param {Object} meta - Command meta\n  62→ * @returns {{ meta, handler, calls: Array }} Registered entry with call recorder\n  63→ */\n  64→function registerStub(meta) {\n  65→  const calls = [];\n  66→  const handler = async (ctx) => {\n  67→    calls.push({ ...ctx });\n  68→  };\n  69→  registerCommand(meta, handler);\n  70→  return { meta, handler, calls };\n  71→}\n  72→\n  73→// ─── Setup ────────────────────────────────────────────────────────────────────\n  74→\n  75→test.beforeEach(() => {\n  76→  clearRegistry();\n  77→});\n  78→\n  79→// ─── Structured-first: existing slash commands must not regress ───────────────\n  80→\n  81→test('[regression] /pipeline run my-feature routes to pipeline run handler', async () => {\n  82→  const stub = registerStub(pipelineMeta);\n  83→  const ctx = createCtx('/pipeline run my-feature');\n  84→  const handled = await routeCommand(ctx);\n  85→  assert.equal(handled, true);\n  86→  assert.equal(stub.calls.length, 1);\n  87→  assert.equal(stub.calls[0].parsed.command, 'pipeline');\n  88→  assert.equal(stub.calls[0].parsed.subcommand, 'run');\n  89→});\n  90→\n  91→test('[regression] /pipeline status returns true', async () => {\n  92→  const stub = registerStub(pipelineMeta);\n  93→  const ctx = createCtx('/pipeline status');\n  94→  const handled = await routeCommand(ctx);\n  95→  assert.equal(handled, true);\n  96→  assert.equal(stub.calls.length, 1);\n  97→  assert.equal(stub.calls[0].parsed.subcommand, 'status');\n  98→});\n  99→\n 100→test('[regression] /pipeline logs is dispatched correctly', async () => {\n 101→  const stub = registerStub(pipelineMeta);\n 102→  const ctx = createCtx('/pipeline logs');\n 103→  const handled = await routeCommand(ctx);\n 104→  assert.equal(handled, true);\n 105→  assert.equal(stub.calls.length, 1);\n 106→  assert.equal(stub.calls[0].parsed.subcommand, 'logs');\n 107→});\n 108→\n 109→test('[regression] /bugfix session-123 dispatches to bugfix handler', async () => {\n 110→  const stub = registerStub(bugfixMeta);\n 111→  const ctx = createCtx('/bugfix session-123');\n 112→  const handled = await routeCommand(ctx);\n 113→  assert.equal(handled, true);\n 114→  assert.equal(stub.calls.length, 1);\n 115→});\n 116→\n 117→test('[regression] /ls dispatches to ls handler', async () => {\n 118→  const stub = registerStub(lsMeta);\n 119→  const ctx = createCtx('/ls');\n 120→  const handled = await routeCommand(ctx);\n 121→  assert.equal(handled, true);\n 122→  assert.equal(stub.calls.length, 1);\n 123→});\n 124→\n 125→test('[regression] /ps dispatches to ps handler', async () => {\n 126→  const stub = registerStub(psMeta);\n 127→  const ctx = createCtx('/ps');\n 128→  const handled = await routeCommand(ctx);\n 129→  assert.equal(handled, true);\n 130→  assert.equal(stub.calls.length, 1);\n 131→});\n 132→\n 133→// ─── Slash + NL enhancement ───────────────────────────────────────────────────\n 134→\n 135→test('[F-015] /pipeline 帮我看最近日志 → inferred as /pipeline logs', async () => {\n 136→  const stub = registerStub(pipelineMeta);\n 137→  const ctx = createCtx('/pipeline 帮我看最近日志');\n 138→  const handled = await routeCommand(ctx);\n 139→  assert.equal(handled, true);\n 140→  // Should be dispatched to handler with subcommand=logs (high confidence)\n 141→  // OR returned with candidate suggestions (if confidence too low)\n 142→  // Either way, handled = true\n 143→  if (stub.calls.length > 0) {\n 144→    assert.equal(stub.calls[0].parsed.subcommand, 'logs');\n 145→  } else {\n 146→    // Low confidence: suggestion message was sent\n 147→    assert.ok(ctx._replies.length > 0, 'Expected reply with suggestions');\n 148→    assert.ok(\n 149→      ctx._replies.some((r) => typeof r === 'string' && (r.includes('/pipeline') || r.includes('候选') || r.includes('意图'))),\n 150→      `Expected NL suggestion reply, got: ${ctx._replies.join(' | ')}`\n 151→    );\n 152→  }\n 153→});\n 154→\n 155→test('[F-015] /pipeline 查看状态 → inferred as /pipeline status', async () => {\n 156→  const stub = registerStub(pipelineMeta);\n 157→  const ctx = createCtx('/pipeline 查看状态');\n 158→  const handled = await routeCommand(ctx);\n 159→  assert.equal(handled, true);\n 160→  if (stub.calls.length > 0) {\n 161→    assert.equal(stub.calls[0].parsed.subcommand, 'status');\n 162→  } else {\n 163→    assert.ok(ctx._replies.length > 0);\n 164→  }\n 165→});\n 166→\n 167→test('[F-015] /pipeline 启动 → inferred as /pipeline run', async () => {\n 168→  const stub = registerStub(pipelineMeta);\n 169→  const ctx = createCtx('/pipeline 启动');\n 170→  const handled = await routeCommand(ctx);\n 171→  assert.equal(handled, true);\n 172→  if (stub.calls.length > 0) {\n 173→    assert.equal(stub.calls[0].parsed.subcommand, 'run');\n 174→  } else {\n 175→    assert.ok(ctx._replies.length > 0);\n 176→  }\n 177→});\n 178→\n 179→test('[F-015] /planner 查看日志 → inferred as /planner logs', async () => {\n 180→  registerStub(pipelineMeta); // planner delegates to pipeline internally\n 181→  const stub = registerStub(plannerMeta);\n 182→  const ctx = createCtx('/planner 查看日志');\n 183→  const handled = await routeCommand(ctx);\n 184→  assert.equal(handled, true);\n 185→  // Handler is called OR suggestions sent\n 186→  assert.ok(stub.calls.length > 0 || ctx._replies.length > 0);\n 187→});\n 188→\n 189→// ─── Pure NL routing ─────────────────────────────────────────────────────────\n 190→\n 191→test('[F-015] pure NL \"pipeline status\" → dispatches to pipeline handler', async () => {\n 192→  const stub = registerStub(pipelineMeta);\n 193→  const ctx = createCtx('pipeline status');\n 194→  const handled = await routeCommand(ctx);\n 195→  // High confidence pure NL — should dispatch or return suggestions\n 196→  if (handled) {\n 197→    assert.ok(stub.calls.length > 0 || ctx._replies.length > 0);\n 198→  } else {\n 199→    // Unhandled — falls through to chat (acceptable for borderline confidence)\n 200→    assert.equal(handled, false);\n 201→  }\n 202→});\n 203→\n 204→test('[F-015] pure NL \"帮我看一下当前 pipeline 状态\" → dispatches or suggests pipeline status', async () => {\n 205→  const stub = registerStub(pipelineMeta);\n 206→  const ctx = createCtx('帮我看一下当前 pipeline 状态');\n 207→  const handled = await routeCommand(ctx);\n 208→  if (handled) {\n 209→    // Either dispatched or suggestions provided\n 210→    assert.ok(stub.calls.length > 0 || ctx._replies.length > 0);\n 211→  }\n 212→  // Unhandled is also valid (falls through to chat)\n 213→});\n 214→\n 215→test('[F-015] pure NL \"进程列表\" → dispatches to ps handler', async () => {\n 216→  const stub = registerStub(psMeta);\n 217→  const ctx = createCtx('进程列表');\n 218→  const handled = await routeCommand(ctx);\n 219→  if (handled) {\n 220→    assert.ok(stub.calls.length > 0 || ctx._replies.length > 0);\n 221→  }\n 222→});\n 223→\n 224→test('[F-015] pure NL \"系统信息\" → dispatches to sysinfo handler', async () => {\n 225→  const stub = registerStub(sysinfoMeta);\n 226→  const ctx = createCtx('系统信息');\n 227→  const handled = await routeCommand(ctx);\n 228→  if (handled) {\n 229→    assert.ok(stub.calls.length > 0 || ctx._replies.length > 0);\n 230→  }\n 231→});\n 232→\n 233→test('[F-015] pure NL unrelated text \"hello world\" → returns false (falls through to chat)', async () => {\n 234→  const ctx = createCtx('hello world');\n 235→  const handled = await routeCommand(ctx);\n 236→  assert.equal(handled, false);\n 237→});\n 238→\n 239→test('[F-015] pure NL \"你好\" → returns false (falls through to chat)', async () => {\n 240→  const ctx = createCtx('你好');\n 241→  const handled = await routeCommand(ctx);\n 242→  assert.equal(handled, false);\n 243→});\n 244→\n 245→// ─── Low-confidence / ambiguity → candidate suggestions ──────────────────────\n 246→\n 247→test('[F-015] ambiguous pure NL input returns candidates instead of unknown subcommand', async () => {\n 248→  // Register several commands\n 249→  registerStub(pipelineMeta);\n 250→  registerStub(psMeta);\n 251→  registerStub(sysinfoMeta);\n 252→\n 253→  const ctx = createCtx('帮我停止'); // Ambiguous: pipeline stop vs stop command\n 254→  const handled = await routeCommand(ctx);\n 255→\n 256→  if (handled) {\n 257→    // If suggestions were sent, they should list commands\n 258→    if (ctx._replies.length > 0) {\n 259→      const replyText = ctx._replies.join(' ');\n 260→      // Must contain at least one command reference\n 261→      assert.ok(\n 262→        replyText.includes('/') || replyText.includes('候选') || replyText.includes('意图'),\n 263→        `Expected candidate message, got: ${replyText}`\n 264→      );\n 265→    }\n 266→  }\n 267→});\n 268→\n 269→test('[F-015] unknown slash command with NL text returns suggestions, not bare \"unknown command\"', async () => {\n 270→  // Register pipeline to test suggestion routing\n 271→  registerStub(pipelineMeta);\n 272→\n 273→  // Use a command that's not registered but looks like NL\n 274→  const ctx = createCtx('/pipeline 帮我处理一下');\n 275→  const handled = await routeCommand(ctx);\n 276→  assert.equal(handled, true);\n 277→\n 278→  // Should have replied with something (either dispatch or suggestion)\n 279→  const allReplies = ctx._replies.join('\\n');\n 280→  // Should NOT contain bare \"未知子命令\" as the only message\n 281→  // (it's ok if it does contain it as part of a longer suggestion)\n 282→  const hasBareUnknownOnly = allReplies.trim() === '未知子命令';\n 283→  assert.equal(hasBareUnknownOnly, false);\n 284→});\n 285→\n 286→// ─── Structured-first priority ───────────────────────────────────────────────\n 287→\n 288→test('[F-015] explicit subcommand takes priority over NL inference', async () => {\n 289→  const stub = registerStub(pipelineMeta);\n 290→  // Explicit valid subcommand should always be used as-is\n 291→  const ctx = createCtx('/pipeline run my-feature --type=bugfix');\n 292→  await routeCommand(ctx);\n 293→  assert.equal(stub.calls.length, 1);\n 294→  assert.equal(stub.calls[0].parsed.subcommand, 'run');\n 295→  assert.equal(stub.calls[0].params.type, 'bugfix');\n 296→});\n 297→\n 298→test('[F-015] explicit --type option is preserved through NL routing', async () => {\n 299→  const stub = registerStub(pipelineMeta);\n 300→  const ctx = createCtx('/pipeline run my-feature --type=planner');\n 301→  await routeCommand(ctx);\n 302→  assert.equal(stub.calls.length, 1);\n 303→  assert.equal(stub.calls[0].params.type, 'planner');\n 304→});\n 305→\n 306→// ─── Alias support with NL ────────────────────────────────────────────────────\n 307→\n 308→test('[F-015] /p status → resolves alias and dispatches to pipeline status', async () => {\n 309→  const stub = registerStub(pipelineMeta);\n 310→  const ctx = createCtx('/p status');\n 311→  const handled = await routeCommand(ctx);\n 312→  assert.equal(handled, true);\n 313→  assert.equal(stub.calls.length, 1);\n 314→  assert.equal(stub.calls[0].parsed.subcommand, 'status');\n 315→});\n 316→\n 317→// ─── Multi-category coverage ─────────────────────────────────────────────────\n 318→\n 319→test('[F-015] bugfix category: /bugfix target-123 is dispatched correctly', async () => {\n 320→  const stub = registerStub(bugfixMeta);\n 321→  const ctx = createCtx('/bugfix target-123');\n 322→  const handled = await routeCommand(ctx);\n 323→  assert.equal(handled, true);\n 324→  assert.equal(stub.calls.length, 1);\n 325→});\n 326→\n 327→test('[F-015] file category: /ls dispatches correctly', async () => {\n 328→  const stub = registerStub(lsMeta);\n 329→  const ctx = createCtx('/ls /tmp');\n 330→  const handled = await routeCommand(ctx);\n 331→  assert.equal(handled, true);\n 332→  assert.equal(stub.calls.length, 1);\n 333→});\n 334→\n 335→test('[F-015] system category: /ps dispatches correctly', async () => {\n 336→  const stub = registerStub(psMeta);\n 337→  const ctx = createCtx('/ps --sort=cpu');\n 338→  const handled = await routeCommand(ctx);\n 339→  assert.equal(handled, true);\n 340→  assert.equal(stub.calls.length, 1);\n 341→});\n 342→\n 343→// ─── Fallback safety ──────────────────────────────────────────────────────────\n 344→\n 345→test('[F-015] routeCommand does not throw for any NL input', async () => {\n 346→  const inputs = [\n 347→    '你好，请帮我',\n 348→    'pipeline 操作',\n 349→    '帮我修复问题',\n 350→    '查看系统信息',\n 351→    '/pipeline',\n 352→    '/pipeline ',\n 353→    '/pipeline 随便输入一些乱码xyzabc123'\n 354→  ];\n 355→\n 356→  registerStub(pipelineMeta);\n 357→  registerStub(psMeta);\n 358→  registerStub(sysinfoMeta);\n 359→  registerStub(bugfixMeta);\n 360→\n 361→  for (const input of inputs) {\n 362→    const ctx = createCtx(input);\n 363→    try {\n 364→      const result = await routeCommand(ctx);\n 365→      assert.ok(typeof result === 'boolean', `Expected boolean result for input: ${input}`);\n 366→    } catch (err) {\n 367→      assert.fail(`routeCommand threw for input \"${input}\": ${err.message}`);\n 368→    }\n 369→  }\n 370→});\n 371→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ytOeuPPPaoMyUkPYR8DqfePP","__timestamp":"2026-03-19T17:25:49.006Z","_requestId":"261f0390879c473391691a62bef865bb"}
