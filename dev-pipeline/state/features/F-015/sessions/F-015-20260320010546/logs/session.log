() => {\n  50→      const handlerCtx = {\n  51→        reply: (msg) => { replies.push(msg); },\n  52→        userId: 'test-user',\n  53→        sessionId: 'test-session',\n  54→        args: ['--sort=cpu']\n  55→      };\n  56→\n  57→      await psHandler.handlePs(handlerCtx);\n  58→\n  59→      assert.ok(replies.length > 0, 'Should send a reply');\n  60→    });\n  61→\n  62→    test('should support --sort=memory option', async () => {\n  63→      const handlerCtx = {\n  64→        reply: (msg) => { replies.push(msg); },\n  65→        userId: 'test-user',\n  66→        sessionId: 'test-session',\n  67→        args: ['--sort=memory']\n  68→      };\n  69→\n  70→      await psHandler.handlePs(handlerCtx);\n  71→\n  72→      assert.ok(replies.length > 0, 'Should send a reply');\n  73→    });\n  74→\n  75→    test('should support filter keyword', async () => {\n  76→      const handlerCtx = {\n  77→        reply: (msg) => { replies.push(msg); },\n  78→        userId: 'test-user',\n  79→        sessionId: 'test-session',\n  80→        args: ['node']\n  81→      };\n  82→\n  83→      await psHandler.handlePs(handlerCtx);\n  84→\n  85→      assert.ok(replies.length > 0, 'Should send a reply');\n  86→    });\n  87→\n  88→    test('should limit process count by default', async () => {\n  89→      const handlerCtx = {\n  90→        reply: (msg) => { replies.push(msg); },\n  91→        userId: 'test-user',\n  92→        sessionId: 'test-session',\n  93→        args: []\n  94→      };\n  95→\n  96→      await psHandler.handlePs(handlerCtx);\n  97→\n  98→      // Check that we don't get an excessive number of processes\n  99→      const reply = replies[0];\n 100→      const lines = reply.split('\\n').filter(l => l.trim());\n 101→      // Default limit is 20, plus header lines\n 102→      assert.ok(lines.length <= 30, 'Should limit process count');\n 103→    });\n 104→  });\n 105→\n 106→  describe('parseOptions', () => {\n 107→    test('should parse sort option', async () => {\n 