gfix', subcommand: undefined, args: [], options: { target: 'session-123' } };\n3708→  const meta = {\n3709→    name: 'bugfix',\n3710→    params: [{ name: 'target', required: true, description: 'Target ID' }],\n3711→    requiresAuth: true\n3712→  };\n3713→\n3714→  const result = validateCommand(parsed, meta);\n3715→  assert.equal(result.valid, true);\n3716→});\n3717→\n3718→test('validateCommand returns error for missing required param', () => {\n3719→  const parsed = { command: 'bugfix', subcommand: undefined, args: [], options: {} };\n3720→  const meta = {\n3721→    name: 'bugfix',\n3722→    params: [{ name: 'target', required: true, description: 'Target ID' }],\n3723→    requiresAuth: true\n3724→  };\n3725→\n3726→  const result = validateCommand(parsed, meta);\n3727→  assert.equal(result.valid, false);\n3728→  assert.ok(result.errors.length > 0);\n3729→  assert.equal(result.errors[0].param, 'target');\n3730→  assert.ok(result.errors[0].message.includes('缺少参数'));\n3731→});\n3732→\n3733→test('validateCommand validates enum values', () => {\n3734→  const parsed = { command: 'pipeline', subcommand: 'run', args: [], options: { type: 'invalid' } };\n3735→  const meta = {\n3736→    name: 'pipeline',\n3737→    subcommands: [{ name: 'run', description: 'Run pipeline' }],\n3738→    params: [{ name: 'type', type: 'enum', enum: ['feature', 'bugfix', 'planner'], description: 'Type' }],\n3739→    requiresAuth: true\n3740→  };\n3741→\n3742→  const result = validateCommand(parsed, meta);\n3743→  assert.equal(result.valid, false);\n3744→  assert.ok(result.errors[0].suggestion.includes('feature'));\n3745→});\n3746→\n3747→test('validateCommand accepts valid enum value', () => {\n3748→  const parsed = { command: 'pipeline', subcommand: 'run', args: [], options: { type: 'bugfix' } };\n3749→  const meta = {\n3750→    name: 'pipeline',\n3751→    subcommands: [{ name: 'run', description: 'Run pipeline' }],\n3752→    params: [{ name: 'type', type: 'enum', enum: ['feature', 'bugfix', 'planner'], description: 'Type' }],\n3753→    requiresAuth: true\n3754→  };\n3755→\n3756→  const result = validateCommand(parsed, meta);\n3757→  assert.equal(result.valid, true);\n3758→});\n3759→\n3760→test('validateCommand validates number type', () => {\n3761→  const parsed = { command: 'test', subcommand: undefined, args: [], options: { count: 'abc' } };\n3762→  const meta = {\n3763→    name: 'test',\n3764→    params: [{ name: 'count', type: 'number', description: 'Count' }],\n3765→    requiresAuth: true\n3766→  };\n3767→\n3768→  const result = validateCommand(parsed, meta);\n3769→  assert.equal(result.valid, false);\n3770→  assert.ok(result.errors[0].message.includes('数字'));\n3771→});\n3772→\n3773→test('validateCommand accepts valid number', () => {\n3774→  const parsed = { command: 'test', subcommand: undefined, args: [], options: { count: '42' } };\n3775→  const meta = {\n3776→    name: 'test',\n3777→    params: [{ name: 'count', type: 'number', description: 'Count' }],\n3778→    requiresAuth: true\n3779→  };\n3780→\n3781→  const result = validateCommand(parsed, meta);\n3782→  assert.equal(result.valid, true);\n3783→  assert.equal(result.normalized.count, 42);\n3784→});\n3785→\n3786→test('validateCommand uses default value when param not provided', () => {\n3787→  const parsed = { command: 'pipeline', subcommand: 'run', args: [], options: {} };\n3788→  const meta = {\n3789→    name: 'pipeline',\n3790→    subcommands: [{ name: 'run', description: 'Run pipeline' }],\n3791→    params: [{ name: 'type', type: 'string', default: 'feature', description: 'Type' }],\n3792→    requiresAuth: true\n3793→  };\n3794→\n3795→  const result = validateCommand(parsed, meta);\n3796→  assert.equal(result.valid, true);\n3797→  assert.equal(result.normalized.type, 'feature');\n3798→});\n3799→\n3800→test('validateCommand returns error for invalid subcommand', () => {\n3801→  const parsed = { command: 'pipeline', subcommand: 'invalid', args: [], options: {} };\n3802→  const meta = {\n3803→ 