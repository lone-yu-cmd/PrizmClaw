  96→  // Lookup command\n  97→  const entry = getCommand(parsed.command);\n  98→\n  99→  if (!entry) {\n 100→    // F-015: Unknown command — try intent routing on the full text\n 101→    const nlResult = routeIntent(text);\n 102→    if (nlResult.matched && !nlResult.needsConfirmation && nlResult.primary) {\n 103→      // High confidence: synthesize and dispatch\n 104→      return dispatchParsedIntent(ctx, nlResult.primary, userId, sessionId);\n 105→    } else if (nlResult.matched) {\n 106→      // Low confidence: present suggestions instead of bare \"unknown command\"\n 107→      await ctx.reply(formatNLSuggestions(nlResult));\n 108→      return true;\n 109→    }\n 110→\n 111→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n 112→    return true;\n 113→  }\n 114→\n 115→  const { meta, handler } = entry;\n 116→\n 117→  // T-101: Permission check\n 118→  const commandName = meta.name;\n 119→  const permResult = checkCommandPermission(userId, commandName);\n 120→\n 121→  if (!permResult.allowed) {\n 122→    // Log denied access\n 123→    await logAuditEntry({\n 124→      userId,\n 125→      action: commandName,\n 126→      params: {},\n 127→      result: 'denied',\n 128→      reason: permResult.reason\n 129→    });\n 130→\n 131→    await ctx.reply(`⛔ ${permResult.reason}`);\n 132→    return true;\n 133→  }\n 134→\n 135→  // F-015: Slash + NL Enhancement\n 136→  // When the subcommand is present but does not match any declared subcommand,\n 137→  // attempt to infer the intended subcommand via the intent router.\n 138→  let effectiveParsed = parsed;\n 139→  if (\n 140→    meta.subcommands?.length > 0 &&\n 141→    parsed.subcommand &&\n 142→    !meta.subcommands.some((s) => s.name === parsed.subcommand)\n 143→  ) {\n 144→    // The subcommand token appears to be natural language\n 145→    const nlText = `${parsed.subcommand} ${parsed.args.join(' ')}`.trim();\n 146→    const nlResult = enhanceSlashCommand(par