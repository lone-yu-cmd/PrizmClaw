{"type":"assistant","uuid":"f6d12e98-012f-4a9c-8407-bd4efbd0b80b","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"id":"f6d12e98-012f-4a9c-8407-bd4efbd0b80b","content":[{"type":"tool_use","id":"toolu_bdrk_01DSAs2nJTFicZk7ce3cjehn","name":"Read","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/parser.js"}}],"model":"gpt-5.3-codex","role":"assistant","stop_reason":"tool_use","stop_sequence":null,"type":"message","usage":{"input_tokens":36217,"output_tokens":168,"cache_creation_input_tokens":null,"cache_read_input_tokens":null,"cache_creation":null,"server_tool_use":null,"service_tier":null}},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:11.054Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"29184acc-141f-4a13-86b1-b0e7cb1b1720","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_011sEgraYePvgcVNdwKNH1Vu","content":[{"type":"text","text":"   1→/**\n   2→ * Command Router\n   3→ * Main entry point for command routing and dispatch.\n   4→ */\n   5→\n   6→import { parseCommand } from './parser.js';\n   7→import { getCommand, getAliasMap, registerCommand } from './registry.js';\n   8→import { validateCommand } from './validator.js';\n   9→import { formatError, formatValidationErrors, ErrorCodes } from './formatter.js';\n  10→import { isAllowedUser } from '../../security/guard.js';\n  11→import { checkCommandPermission, getUserRole } from '../../security/permission-guard.js';\n  12→import { logAuditEntry } from '../../services/audit-log-service.js';\n  13→import { aliasStore } from '../../services/alias-store.js';\n  14→import { sessionStore } from '../../services/session-store.js';\n  15→\n  16→/**\n  17→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  18→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  19→ * @typedef {import('./registry.js').CommandEntry} CommandEntry\n  20→ */\n  21→\n  22→/**\n  23→ * Build session ID from context.\n  24→ * @param {Object} ctx - Telegraf context\n  25→ * @returns {string} Session ID\n  26→ */\n  27→function buildSessionId(ctx) {\n  28→  return String(ctx.chat.id);\n  29→}\n  30→\n  31→/**\n  32→ * Route and dispatch a command from Telegram context.\n  33→ * @param {Object} ctx - Telegraf context\n  34→ * @returns {Promise<boolean>} True if command was handled\n  35→ */\n  36→export async function routeCommand(ctx) {\n  37→  let text = ctx.message?.text;\n  38→\n  39→  if (!text || !text.startsWith('/')) {\n  40→    return false;\n  41→  }\n  42→\n  43→  // Authorization check\n  44→  const userId = ctx.from?.id;\n  45→  if (!isAuthorized(userId)) {\n  46→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n  47→    return true;\n  48→  }\n  49→\n  50→  const sessionId = buildSessionId(ctx);\n  51→  const userIdStr = String(userId);\n  52→\n  53→  // F-013: Touch session on each command\n  54→  sessionStore.touchSession(sessionId, userIdStr);\n  55→\n  56→  // F-013: Resolve alias if the command name is an alias\n  57→  const commandMatch = text.match(/^\\/(\\S+)/);\n  58→  if (commandMatch) {\n  59→    const potentialAlias = commandMatch[1].toLowerCase();\n  60→    const resolvedCommand = aliasStore.resolveAlias(userIdStr, potentialAlias);\n  61→    if (resolvedCommand) {\n  62→      // Replace the alias with the resolved command\n  63→      const args = text.slice(commandMatch[0].length);\n  64→      text = `/${resolvedCommand}${args}`;\n  65→    }\n  66→  }\n  67→\n  68→  // Parse command\n  69→  const aliasMap = getAliasMap();\n  70→  const parsed = parseCommand(text, aliasMap);\n  71→\n  72→  if (!parsed) {\n  73→    await ctx.reply('无法解析命令。');\n  74→    return true;\n  75→  }\n  76→\n  77→  // Lookup command\n  78→  const entry = getCommand(parsed.command);\n  79→\n  80→  if (!entry) {\n  81→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n  82→    return true;\n  83→  }\n  84→\n  85→  const { meta, handler } = entry;\n  86→\n  87→  // T-101: Permission check\n  88→  const commandName = meta.name;\n  89→  const permResult = checkCommandPermission(userId, commandName);\n  90→\n  91→  if (!permResult.allowed) {\n  92→    // Log denied access\n  93→    await logAuditEntry({\n  94→      userId,\n  95→      action: commandName,\n  96→      params: {},\n  97→      result: 'denied',\n  98→      reason: permResult.reason\n  99→    });\n 100→\n 101→    await ctx.reply(`⛔ ${permResult.reason}`);\n 102→    return true;\n 103→  }\n 104→\n 105→  // Validate command\n 106→  const validation = validateCommand(parsed, meta);\n 107→\n 108→  if (!validation.valid) {\n 109→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n 110→    await ctx.reply(errorMsg);\n 111→    return true;\n 112→  }\n 113→\n 114→  // Create handler context\n 115→  const handlerContext = {\n 116→    ctx,\n 117→    parsed,\n 118→    meta,\n 119→    params: validation.normalized || {},\n 120→    userId,\n 121→    userRole: getUserRole(userId),\n 122→    sessionId,\n 123→    requiresConfirmation: permResult.requiresConfirmation,\n 124→    reply: async (text) => ctx.reply(text),\n 125→    replyFile: async (content, filename) => {\n 126→      // Will be implemented with proper file handling\n 127→      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n 128→    },\n 129→    args: parsed.args || []\n 130→  };\n 131→\n 132→  // Dispatch to handler\n 133→  try {\n 134→    await handler(handlerContext);\n 135→  } catch (error) {\n 136→    const message = error instanceof Error ? error.message : String(error);\n 137→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n 138→  }\n 139→\n 140→  return true;\n 141→}\n 142→\n 143→/**\n 144→ * Check if user is authorized.\n 145→ * @param {number|string|undefined} userId - User ID\n 146→ * @returns {boolean} True if authorized\n 147→ */\n 148→function isAuthorized(userId) {\n 149→  return isAllowedUser(userId);\n 150→}\n 151→\n 152→/**\n 153→ * Format error response for display.\n 154→ * @param {Object} error - Error object\n 155→ * @returns {string} Formatted error\n 156→ */\n 157→function formatErrorResponse(error) {\n 158→  const lines = [`❌ ${error.message}`];\n 159→\n 160→  if (error.suggestion) {\n 161→    lines.push(`💡 ${error.suggestion}`);\n 162→  }\n 163→\n 164→  if (error.usage) {\n 165→    lines.push(`用法: ${error.usage}`);\n 166→  }\n 167→\n 168→  return lines.join('\\n');\n 169→}\n 170→\n 171→/**\n 172→ * Register all default commands.\n 173→ */\n 174→export function registerDefaultCommands() {\n 175→  // Commands will be registered by individual handlers\n 176→  // This is called during initialization\n 177→}\n 178→\n 179→/**\n 180→ * Create middleware for command routing.\n 181→ * @returns {Function} Middleware function\n 182→ */\n 183→export function createCommandMiddleware() {\n 184→  return async (ctx, next) => {\n 185→    const handled = await routeCommand(ctx);\n 186→    if (!handled) {\n 187→      return next();\n 188→    }\n 189→  };\n 190→}\n 191→\n 192→// Re-export for convenience\n 193→export { registerCommand, getCommand, getAliasMap };\n 194→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:11.060Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"e96f915f-4220-4578-97c9-48af2d59670f","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"toolu_bdrk_01DSAs2nJTFicZk7ce3cjehn","content":[{"type":"text","text":"   1→/**\n   2→ * Command Parser\n   3→ * Parses Telegram message text into structured ParsedCommand object.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParsedCommand\n   8→ * @property {string} command - The command name (e.g., \"pipeline\")\n   9→ * @property {string} [subcommand] - Optional subcommand (e.g., \"run\")\n  10→ * @property {string[]} args - Positional arguments\n  11→ * @property {Record<string, string>} options - Key-value options (--key=value)\n  12→ * @property {string} raw - Original message text\n  13→ */\n  14→\n  15→/**\n  16→ * Parse Telegram message text into a structured command object.\n  17→ * @param {string} text - The message text to parse\n  18→ * @param {Object} [aliasMap={}] - Map of aliases to command names\n  19→ * @returns {ParsedCommand | null} Parsed command or null if not a command\n  20→ */\n  21→export function parseCommand(text, aliasMap = {}) {\n  22→  if (!text || typeof text !== 'string') {\n  23→    return null;\n  24→  }\n  25→\n  26→  const trimmed = text.trim();\n  27→\n  28→  // Must start with /\n  29→  if (!trimmed.startsWith('/')) {\n  30→    return null;\n  31→  }\n  32→\n  33→  // Extract command (first token after /)\n  34→  const tokens = trimmed.slice(1).split(/\\s+/);\n  35→  if (tokens.length === 0 || !tokens[0]) {\n  36→    return null;\n  37→  }\n  38→\n  39→  let command = tokens[0].toLowerCase();\n  40→  const rest = tokens.slice(1);\n  41→\n  42→  // Handle @bot suffix (e.g., /command@mybot)\n  43→  const atIndex = command.indexOf('@');\n  44→  if (atIndex !== -1) {\n  45→    command = command.slice(0, atIndex);\n  46→  }\n  47→\n  48→  // Apply alias mapping\n  49→  if (aliasMap[command]) {\n  50→    command = aliasMap[command];\n  51→  }\n  52→\n  53→  const args = [];\n  54→  /** @type {Record<string, string>} */\n  55→  const options = {};\n  56→  let subcommand = undefined;\n  57→\n  58→  for (const token of rest) {\n  59→    // Parse --key=value options\n  60→    if (token.startsWith('--')) {\n  61→      const optionText = token.slice(2);\n  62→      const eqIndex = optionText.indexOf('=');\n  63→      if (eqIndex !== -1) {\n  64→        const key = optionText.slice(0, eqIndex).toLowerCase();\n  65→        const value = optionText.slice(eqIndex + 1);\n  66→        options[key] = value;\n  67→      } else {\n  68→        // Boolean flag --flag\n  69→        options[optionText.toLowerCase()] = 'true';\n  70→      }\n  71→    } else if (token.includes('=')) {\n  72→      // Parse key=value (without --)\n  73→      const eqIndex = token.indexOf('=');\n  74→      const key = token.slice(0, eqIndex).toLowerCase();\n  75→      const value = token.slice(eqIndex + 1);\n  76→      options[key] = value;\n  77→    } else if (subcommand === undefined && !token.startsWith('-') && args.length === 0) {\n  78→      // First non-option token is subcommand if it looks like one\n  79→      // This will be validated by the registry\n  80→      subcommand = token.toLowerCase();\n  81→    } else {\n  82→      // Positional argument\n  83→      args.push(token);\n  84→    }\n  85→  }\n  86→\n  87→  return {\n  88→    command,\n  89→    subcommand,\n  90→    args,\n  91→    options,\n  92→    raw: text\n  93→  };\n  94→}\n  95→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_pRmaLUV6ETZe0r0My8gPv5G8","__timestamp":"2026-03-19T17:07:11.061Z","_requestId":"261f0390879c473391691a62bef865bb"}
