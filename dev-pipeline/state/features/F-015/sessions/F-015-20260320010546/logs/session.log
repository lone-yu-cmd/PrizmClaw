eAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n  92→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n  93→\n  94→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n  95→  const chunks = [];\n  96→  for (let i = 0; i < text.length; i += chunkSize) {\n  97→    chunks.push(text.slice(i, i + chunkSize));\n  98→  }\n  99→  return chunks;\n 100→}\n 101→\n 102→function truncate(text, maxLen) {\n 103→  if (!text) return '';\n 104→  if (text.length <= maxLen) return text;\n 105→  return text.substring(0, maxLen) + '...';\n 106→}\n 107→\n 108→function sanitizeMarkerPath(raw) {\n 109→  return String(raw ?? '')\n 110→    .trim()\n 111→    .replace(/^['\"`]+/, '')\n 112→    .replace(/['\"`]+$/, '');\n 113→}\n 114→\n 115→function extractFileMarkers(text = '') {\n 116→  const fileRefs = [];\n 117→\n 118→  const withSendFileRemoved = text.replace(\n 119→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n 120→    (_full, rawRef) => {\n 121→      const ref = sanitizeMarkerPath(rawRef);\n 122→      if (ref) {\n 123→        fileRefs.push(ref);\n 124→      }\n 125→      return '\\n';\n 126→    }\n 127→  );\n 128→\n 129→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n 130→    const ref = sanitizeMarkerPath(rawRef);\n 131→    if (ref) {\n 132→      fileRefs.push(ref);\n 133→    }\n 134→    return '';\n 135→  });\n 136→\n 137→  const withBacktickPathRemoved = withImageRemoved.replace(\n 138→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n 139→    (_full, rawRef) => {\n 140→      const ref = sanitizeMarkerPath(rawRef);\n 141→      if (ref) {\n 142→        fileRefs.push(ref);\n 143→      }\n 144→      return '';\n 145→    }\n 146→  );\n 147→\n 148→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n 149→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n 150→    (_full, rawRef) => {\n 151→      const ref = sanitizeMarkerPath(rawRef);\n 152→      if (ref) {\n 153→        fileRefs.push(ref);\n 154→      }\n 155→      return '';\n 156→    }\n 157→  );\n 158→\n 159→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n 160→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n 161→    (_full, rawRef) => {\n 162→      const ref = sanitizeMarkerPath(rawRef);\n 163→      if (ref) {\n 164→        fileRefs.push(ref);\n 165→      }\n 166→      return '\\n';\n 167→    }\n 168→  );\n 169→\n 170→  return {\n 171→    fileRefs: [...new Set(fileRefs)],\n 172→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n 173→  };\n 174→}\n 175→\n 176→function isPathWithinRoot(targetPath, rootPath) {\n 177→  const relative = path.relative(rootPath, targetPath);\n 178→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n 179→}\n 180→\n 181→function isAllowedFilePath(filePath) {\n 182→  const resolved = path.resolve(filePath);\n 183→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n 184→}\n 185→\n 186→function buildFileCandidates(normalizedPath) {\n 187→  if (path.isAbsolute(normalizedPath)) {\n 188→    return [normalizedPath];\n 189→  }\n 190→\n 191→  const baseName = path.basename(normalizedPath);\n 192→  const candidates = [\n 193→    path.resolve(process.cwd(), normalizedPath),\n 194→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n 195→  ];\n 196→\n 197→  return [...new Set(candidates)];\n 198→}\n 199→\n 200→async function resolveLocalFilePath(fileRef) {\n 201→  const normalized = sanitizeMarkerPath(fileRef);\n 202→  if (!normalized) {\n 203→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n 204→  }\n 205→\n 206→  if (!path.isAbsolute(normalized)) {\n 207→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n 208→  }\n 209→\n 210→  const candidates = buildFileCandidates(normalized);\n 211→\n 212→  for (const candidate of candidates) {\n 213→    try {\n 214→      await access(candidate);\n 215→      return { filePath: candidate, triedPaths: candidates };\n 216→    } catch {\n 217→      // ignore\n 218→    }\n 219→  }\n 220→\n 221→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n 222→}\n 223→\n 224→async function validateFileForTelegram(filePath) {\n 225→  const resolvedPath = path.resolve(filePath);\n 226→  if (!isAllowedFilePath(resolvedPath)) {\n 227→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n 228→  }\n 229→\n 230→  const ext = path.extname(resolvedPath).toLowerCase();\n 231→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n 232→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n 233→  }\n 234→\n 235→  const fileStat = await stat(resolvedPath);\n 236→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n 237→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n 238→\n 239→  if (fileStat.size > maxSize) {\n 240→    return {\n 241→      ok: false,\n 242→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n 243→    };\n 244→  }\n 245→\n 246→  return { ok: true, isPhoto, resolvedPath };\n 247→}\n 248→\n 249→function isTimeoutLikeError(message = '') {\n 250→  const normalized = String(message).toLowerCase();\n 251→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n 252→}\n 253→\n 254→function sleep(ms) {\n 255→  return new Promise((resolve) => setTimeout(resolve, ms));\n 256→}\n 257→\n 258→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n 259→  if (isPhoto) {\n 260→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n 261→    return;\n 262→  }\n 263→\n 264→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n 265→}\n 266→\n 267→async function replyFiles(ctx, fileRefs = []) {\n 268→  const results = [];\n 269→\n 270→  for (const fileRef of fileRefs) {\n 271→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n 272→    if (!filePath) {\n 273→      const reason = rejectReason || 'not_found';\n 274→      results.push({ fileRef, sent: false, reason, triedPaths });\n 275→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n 276→      continue;\n 277→    }\n 278→\n 279→    try {\n 280→      const validation = await validateFileForTelegram(filePath);\n 281→      if (!validation.ok) {\n 282→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n 283→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n 284→        continue;\n 285→      }\n 286→\n 287→      const actualPath = validation.resolvedPath;\n 288→      let sent = false;\n 289→      let lastReason = '';\n 290→\n 291→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n 292→        try {\n 293→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n 294→          sent = true;\n 295→          logger.info(\n 296→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n 297→            'Telegram file sent'\n 298→          );\n 299→          break;\n 300→        } catch (error) {\n 301→          lastReason = error instanceof Error ? error.message : String(error);\n 302→          logger.warn(\n 303→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n 304→            'Telegram file send attempt failed'\n 305→          );\n 306→\n 307→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n 308→            await sleep(600);\n 309→            continue;\n 310→          }\n 311→\n 312→          break;\n 313→        }\n 314→      }\n 315→\n 316→      if (!sent) {\n 317→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n 318→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n 319→        continue;\n 320→      }\n 321→\n 322→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n 323→    } catch (error) {\n 324→      const reason = error instanceof Error ? error.message : String(error);\n 325→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n 326→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n 327→    }\n 328→  }\n 329→\n 330→  return results;\n 331→}\n 332→\n 333→async function safeReply(ctx, text) {\n 334→  try {\n 335→    await ctx.reply(text);\n 336→    return true;\n 337→  } catch (error) {\n 338→    const reason = error instanceof Error ? error.message : String(error);\n 339→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n 340→    return false;\n 341→  }\n 342→}\n 343→\n 344→async function replyLargeText(ctx, text) {\n 345→  const chunks = splitMessage(text);\n 346→  for (const chunk of chunks) {\n 347→    const ok = await safeReply(ctx, chunk);\n 348→    if (!ok) {\n 349→      break;\n 350→    }\n 351→  }\n 352→}\n 353→\n 354→async function safeEditMessageText(ctx, messageId, text) {\n 355→  const nextText = text && text.trim() ? text : ' ';\n 356→\n 357→  try {\n 358→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n 359→  } catch (error) {\n 360→    const message = error instanceof Error ? error.message : String(error);\n 361→    if (message.includes('message is not modified')) {\n 362→      return;\n 363→    }\n 364→    throw error;\n 365→  }\n 366→}\n 367→\n 368→function createEditableStreamPublisher(ctx) {\n 369→  let fullText = '';\n 370→  let renderedText = '';\n 371→  let pendingChars = 0;\n 372→  let lastFlushAt = 0;\n 373→  let flushChain = Promise.resolve();\n 374→  let activeMessage = null;\n 375→  let activeSegmentIndex = 0;\n 376→  let publishedMessageCount = 0;\n 377→\n 378→  async function ensureActiveMessage() {\n 379→    if (activeMessage) {\n 380→      return;\n 381→    }\n 382→    activeMessage = await ctx.reply('处理中...');\n 383→    activeSegmentIndex = 0;\n 384→    publishedMessageCount += 1;\n 385→  }\n 386→\n 387→  async function render(force = false) {\n 388→    const now = Date.now();\n 389→\n 390→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n 391→      return;\n 392→    }\n 393→\n 394→    if (fullText === renderedText) {\n 395→      pendingChars = 0;\n 396→      return;\n 397→    }\n 398→\n 399→    await ensureActiveMessage();\n 400→\n 401→    const segments = splitMessage(fullText);\n 402→    const targetLastIndex = Math.max(segments.length - 1, 0);\n 403→\n 404→    while (activeSegmentIndex < targetLastIndex) {\n 405→      const text = segments[activeSegmentIndex] ?? ' ';\n 406→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n 407→\n 408→      activeMessage = await ctx.reply('继续输出中...');\n 409→      activeSegmentIndex += 1;\n 410→      publishedMessageCount += 1;\n 411→    }\n 412→\n 413→    const activeText = segments[targetLastIndex] ?? ' ';\n 414→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n 415→\n 416→    renderedText = fullText;\n 417→    pendingChars = 0;\n 418→    lastFlushAt = now;\n 419→  }\n 420→\n 421→  function enqueueRender(force = false) {\n 422→    flushChain = flushChain.then(() => render(force));\n 423→  }\n 424→\n 425→  return {\n 426→    push(text) {\n 427→      const appendText = text ?? '';\n 428→      if (!appendText) {\n 429→        return;\n 430→      }\n 431→      fullText += appendText;\n 432→      pendingChars += appendText.length;\n 433→      enqueueRender(false);\n 434→    },\n 435→    setFinalText(text) {\n 436→      fullText = text ?? '';\n 437→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n 438→      enqueueRender(true);\n 439→    },\n 440→    async finish() {\n 441→      enqueueRender(true);\n 442→      await flushChain;\n 443→      return {\n 444→        outputLength: renderedText.length,\n 445→        messageCount: publishedMessageCount\n 446→      };\n 447→    }\n 448→  };\n 449→}\n 450→\n 451→function buildSessionId(ctx) {\n 452→  return String(ctx.chat.id);\n 453→}\n 454→\n 455→function ensureAllowed(ctx) {\n 456→  const userId = ctx.from?.id;\n 457→  if (!isAllowedUser(userId)) {\n 458→    throw new Error('当前账号未被授权使用该机器人。');\n 459→  }\n 460→}\n 461→\n 462→/**\n 463→ * Register all pipeline-related commands.\n 464→ */\n 465→function registerPipelineCommands() {\n 466→  registerCommand(pipelineMeta, handlePipeline);\n 467→  registerCommand(bugfixMeta, handleBugfix);\n 468→  registerCommand(plannerMeta, handlePlanner);\n 469→  registerCommand(statusMeta, handleStatus);\n 470→  registerCommand(logsMeta, handleLogs);\n 471→  registerCommand(stopMeta, handleStop);\n 472→  registerCommand(planMeta, handlePlan);\n 473→  registerCommand(auditMeta, handleAudit);\n 474→  registerCommand(commitMeta, handleCommit);\n 475→  registerCommand(commitsMeta, handleCommits);\n 476→  // F-009: New commands\n 477→  registerCommand(cdMeta, handleCd);\n 478→  registerCommand(moreMeta, handleMore);\n 479→  // F-010: File Manager commands\n 480→  registerCommand(lsMeta, handleLs);\n 481→  registerCommand(treeMeta, handleTree);\n 482→  registerCommand(catMeta, handleCat);\n 483→  registerCommand(headMeta, handleHead);\n 484→  registerCommand(tailMeta, handleTail);\n 485→  registerCommand(findMeta, handleFind);\n 486→  registerCommand(uploadMeta, handleUpload);\n 487→  registerCommand(downloadMeta, handleDownload);\n 488→  // F-012: System Monitor commands\n 489→  registerCommand(sysinfoMeta, handleSysinfo);\n 490→  registerCommand(psMeta, handlePs);\n 491→  registerCommand(killMeta, handleKill);\n 492→  registerCommand(monitorMeta, handleMonitor);\n 493→  // F-013: Session and Context Manager commands\n 494→  registerCommand(historyMeta, handleHistory);\n 495→  registerCommand(aliasMeta, handleAlias);\n 496→  registerCommand(sessionsMeta, handleSessions);\n 497→  // F-014: Notification and Scheduled Tasks commands\n 498→  registerCommand(cronMeta, handleCron);\n 499→  registerCommand(jobsMeta, handleJobs);\n 500→  registerCommand(watchMeta, handleWatch);\n 501→}\n 502→\n 503→export async function createTelegramBot() {\n 504→  const bot = new Telegraf(config.telegramBotToken, {\n 505→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n 506→  });\n 507→\n 508→  // F-013: Initialize session context service\n 509→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n 510→  await aliasStore.initAliasStore({ persistencePath: config.aliasPersistencePath });\n 511→\n 512→  // F-013: Restore sessions from disk\n 513→  await sessionContextService.restoreSessions();\n 514→\n 515→  // F-013: Set up notification callback for session timeout\n 516→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n 517→    try {\n 518→      // Extract chat ID from session key (format: telegram:123456789)\n 519→      const chatId = sessionKey.replace('telegram:', '');\n 520→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n 521→    } catch (error) {\n 522→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n 523→    }\n 524→  });\n 525→\n 526→  // F-013: Start timeout watcher\n 527→  sessionContextService.startTimeoutWatcher();\n 528→\n 529→  // F-014: Initialize scheduled task service\n 530→  scheduledTaskService.initScheduledTaskService({\n 531→    dataDir: config.systemMonitorDataDir,\n 532→    tasksFile: config.scheduledTasksPath,\n 533→    maxTasks: config.maxScheduledTasks\n 534→  });\n 535→\n 536→  // F-014: Set up task execution callback\n 537→  scheduledTaskService.setExecuteCallback(async ({ command, cwd, sessionId, userId }) => {\n 538→    try {\n 539→      return await executeCommand({\n 540→        command,\n 541→        cwd,\n 542→        sessionId,\n 543→        userId,\n 544→        skipConfirmation: true // Skip confirmation for scheduled tasks\n 545→      });\n 546→    } catch (error) {\n 547→      return {\n 548→        stdout: '',\n 549→        stderr: error.message,\n 550→        exitCode: 1,\n 551→        timedOut: false\n 552→      };\n 553→    }\n 554→  });\n 555→\n 556→  // F-014: Set up task notification callback\n 557→  scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n 558→    try {\n 559→      const result = task.lastResult || {};\n 560→      const lines = [\n 561→        '⏰ *定时任务完成*',\n 562→        '',\n 563→        `任务ID: \\`${task.id.substring(0, 8)}...\\``,\n 564→        `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n 565→        `执行时间: ${new Date(result.executedAt || Date.now()).toLocaleString()}`,\n 566→        '',\n 567→        `exitCode: ${result.exitCode}`,\n 568→        result.stdout ? `stdout:\\n${truncate(result.stdout, 500)}` : 'stdout: (empty)',\n 569→        result.stderr ? `stderr:\\n${escapeMarkdownV2(truncate(result.stderr, 500))}` : 'stderr: (empty)'\n 570→      ];\n 571→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n 572→    } catch (error) {\n 573→      logger.warn({ taskId: task.id, error: error.message }, 'Failed to send task notification');\n 574→    }\n 575→  });\n 576→\n 577→  // F-014: Load and start scheduled tasks\n 578→  await scheduledTaskService.loadTasks();\n 579→  scheduledTaskService.startScheduler();\n 580→\n 581→  // F-014: Initialize file watcher service\n 582→  fileWatcherService.initFileWatcherService({\n 583→    dataDir: config.systemMonitorDataDir,\n 584→    watchersFile: config.fileWatchersPath,\n 585→    maxWatchers: config.maxFileWatchers,\n 586→    debounceMs: config.taskDebounceMs,\n 587→    allowedRoots: config.telegramFileAllowedRoots.length > 0\n 588→      ? config.telegramFileAllowedRoots\n 589→      : [process.cwd()]\n 590→  });\n 591→\n 592→  // F-014: Set up file watcher notification callback\n 593→  fileWatcherService.setNotificationCallback(async (chatId, watcher) => {\n 594→    try {\n 595→      const lines = [\n 596→        '📁 *文件变更检测*',\n 597→        '',\n 598→        `路径: \\`${escapeMarkdownV2(watcher.path)}\\``,\n 599→        `事件: ${watcher.eventType}`,\n 600→        `文件: ${watcher.filename || '(未知)'}`,\n 601→        `时间: ${new Date().toLocaleString()}`\n 602→      ];\n 603→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n 604→    } catch (error) {\n 605→      logger.warn({ watcherId: watcher.id, error: error.message }, 'Failed to send file watcher notification');\n 606→    }\n 607→  });\n 608→\n 609→  // F-014: Restore file watchers\n 610→  await fileWatcherService.restoreWatches();\n 611→\n 612→  // Register pipeline commands\n 613→  registerPipelineCommands();\n 614→\n 615→  bot.catch(async (error, ctx) => {\n 616→    const message = error instanceof Error ? error.message : String(error);\n 617→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n 618→    try {\n 619→      if (ctx?.chat?.id) {\n 620→        await ctx.telegram.sendMessage(ctx.chat.id, '处理请求时出现异常，请重试一次。');\n 621→      }\n 622→    } catch (notifyError) {\n 623→      logger.warn({ err: notifyError instanceof Error ? notifyError.message : String(notifyError) }, 'Failed to notify user after unhandled telegram error');\n 624→    }\n 625→  });\n 626→\n 627→  bot.start(async (ctx) => {\n 628→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n 629→  });\n 630→\n 631→  bot.help(async (ctx) => {\n 632→    const helpText = generateHelp();\n 633→    await ctx.reply(helpText);\n 634→  });\n 635→\n 636→  bot.command('reset', async (ctx) => {\n 637→    try {\n 638→      ensureAllowed(ctx);\n 639→      const sessionId = buildSessionId(ctx);\n 640→\n 641→      // F-011: Interrupt any running AI CLI task\n 642→      if (isAiCliRunning(sessionId)) {\n 643→        interruptAiCli(sessionId);\n 644→      }\n 645→\n 646→      resetSession({ channel: 'telegram', sessionId });\n 647→      await ctx.reply('已清空当前会话上下文。');\n 648→    } catch (error) {\n 649→      await ctx.reply(error instanceof Error ? error.message : String(error));\n 650→    }\n 651→  });\n 652→\n 653→  bot.command('screenshot', async (ctx) => {\n 654→    try {\n 655→      ensureAllowed(ctx);\n 656→      await ctx.reply('正在获取截图。');\n 657→      const { buffer } = await captureScreenshot();\n 658→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n 659→    } catch (error) {\n 660→      const message = error instanceof Error ? error.message : String(error);\n 661→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n 662→      await ctx.reply(`截图失败：${message}`);\n 663→    }\n 664→  });\n 665→\n 666→  bot.command('exec', async (ctx) => {\n 667→    try {\n 668→      ensureAllowed(ctx);\n 669→      const payload = ctx.message.text.replace('/exec', '').trim();\n 670→      if (!payload) {\n 671→        await ctx.reply('请提供命令，例如 /exec pwd');\n 672→        return;\n 673→      }\n 674→\n 675→      const sessionId = buildSessionId(ctx);\n 676→      const userId = ctx.from?.id;\n 677→\n 678→      await ctx.reply('正在执行命令...');\n 679→      const result = await executeCommand({\n 680→        command: payload,\n 681→        sessionId,\n 682→        userId\n 683→      });\n 684→\n 685→      // Handle confirmation required\n 686→      if (result.needsConfirmation) {\n 687→        await ctx.reply(result.confirmationMessage);\n 688→        return;\n 689→      }\n 690→\n 691→      // Send output\n 692→      await replyLargeText(ctx, result.output);\n 693→\n 694→      // Indicate if more pages available\n 695→      if (result.hasMorePages) {\n 696→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 697→      }\n 698→    } catch (error) {\n 699→      const message = error instanceof Error ? error.message : String(error);\n 700→      logger.error({ err: message }, 'Failed to exec command in telegram');\n 701→      await ctx.reply(`执行失败：${message}`);\n 702→    }\n 703→  });\n 704→\n 705→  // F-009: /cd command handler\n 706→  bot.command('cd', async (ctx) => {\n 707→    try {\n 708→      ensureAllowed(ctx);\n 709→      const payload = ctx.message.text.replace('/cd', '').trim();\n 710→      const sessionId = buildSessionId(ctx);\n 711→\n 712→      await handleCd({\n 713→        ctx,\n 714→        reply: (msg) => ctx.reply(msg),\n 715→        params: {},\n 716→        userId: ctx.from?.id,\n 717→        sessionId,\n 718→        args: payload ? [payload] : []\n 719→      });\n 720→    } catch (error) {\n 721→      const message = error instanceof Error ? error.message : String(error);\n 722→      logger.error({ err: message }, 'Failed to cd in telegram');\n 723→      await ctx.reply(`切换目录失败：${message}`);\n 724→    }\n 725→  });\n 726→\n 727→  // F-009: /more command handler\n 728→  bot.command('more', async (ctx) => {\n 729→    try {\n 730→      ensureAllowed(ctx);\n 731→      const sessionId = buildSessionId(ctx);\n 732→\n 733→      await handleMore({\n 734→        ctx,\n 735→        reply: (msg) => ctx.reply(msg),\n 736→        params: {},\n 737→        userId: ctx.from?.id,\n 738→        sessionId\n 739→      });\n 740→    } catch (error) {\n 741→      const message = error instanceof Error ? error.message : String(error);\n 742→      logger.error({ err: message }, 'Failed to get more output in telegram');\n 743→      await ctx.reply(`获取更多输出失败：${message}`);\n 744→    }\n 745→  });\n 746→\n 747→  // T-100: Document upload handler for plan files\n 748→  bot.on('document', async (ctx) => {\n 749→    try {\n 750→      ensureAllowed(ctx);\n 751→\n 752→      const document = ctx.message?.document;\n 753→      if (!document) {\n 754→        return;\n 755→      }\n 756→\n 757→      // Check file extension\n 758→      const fileName = document.file_name || '';\n 759→      const ext = path.extname(fileName).toLowerCase();\n 760→\n 761→      if (ext !== '.json') {\n 762→        // Not a JSON file, ignore silently (other handlers may process it)\n 763→        return;\n 764→      }\n 765→\n 766→      // Check file size\n 767→      const fileSize = document.file_size || 0;\n 768→      if (fileSize > 1024 * 1024) { // 1MB limit\n 769→        await ctx.reply('❌ 文件过大，限制 1MB。');\n 770→        return;\n 771→      }\n 772→\n 773→      await ctx.reply('正在处理上传的计划文件...');\n 774→\n 775→      // Download file content\n 776→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n 777→      const fileUrl = fileLink.href || fileLink.toString();\n 778→\n 779→      const response = await fetch(fileUrl);\n 780→      if (!response.ok) {\n 781→        throw new Error(`下载文件失败: ${response.status}`);\n 782→      }\n 783→\n 784→      const content = await response.text();\n 785→\n 786→      // Validate and save using plan-ingestion-service\n 787→      const infraConfig = loadPipelineInfraConfig();\n 788→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n 789→\n 790→      const validationResult = planService.validate(content);\n 791→\n 792→      if (!validationResult.valid) {\n 793→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n 794→        await ctx.reply(errorMsg);\n 795→        return;\n 796→      }\n 797→\n 798→      // Save the plan\n 799→      const saveResult = await planService.save(\n 800→        validationResult.type,\n 801→        content,\n 802→        { uploadedBy: ctx.from?.id }\n 803→      );\n 804→\n 805→      if (!saveResult.success) {\n 806→        await ctx.reply('❌ 保存失败，请稍后重试。');\n 807→        return;\n 808→      }\n 809→\n 810→      // Set as current version\n 811→      await planService.setCurrent(validationResult.type, saveResult.version);\n 812→\n 813→      // Format success message\n 814→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n 815→      const summary = validationResult.summary;\n 816→\n 817→      await ctx.reply([\n 818→        `✅ ${typeDisplay}已保存并激活`,\n 819→        `版本: ${saveResult.version}`,\n 820→        `名称: ${summary?.name || '未知'}`,\n 821→        `项目数: ${summary?.itemCount || 0}`,\n 822→        '',\n 823→        summary?.statusBreakdown ? '状态分布:' : '',\n 824→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n 825→      ].filter(Boolean).join('\\n'));\n 826→\n 827→    } catch (error) {\n 828→      const message = error instanceof Error ? error.message : String(error);\n 829→      logger.error({ err: message }, 'Failed to process document upload');\n 830→      await ctx.reply(`❌ 处理失败：${message}`);\n 831→    }\n 832→  });\n 833→\n 834→  bot.on('text', async (ctx) => {\n 835→    // Check for pipeline commands first\n 836→    const handled = await routeCommand(ctx);\n 837→    if (handled) {\n 838→      return;\n 839→    }\n 840→\n 841→    const sessionId = buildSessionId(ctx);\n 842→    const userId = ctx.from?.id;\n 843→\n 844→    // F-009: Direct exec mode - treat plain text as command when enabled\n 845→    if (config.directExecMode && config.enableSystemExec) {\n 846→      try {\n 847→        ensureAllowed(ctx);\n 848→        const command = ctx.message.text;\n 849→\n 850→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n 851→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n 852→\n 853→        if (!isLikelyChat) {\n 854→          await ctx.reply('正在执行命令...');\n 855→          const result = await executeCommand({\n 856→            command,\n 857→            sessionId,\n 858→            userId\n 859→          });\n 860→\n 861→          if (result.needsConfirmation) {\n 862→            await ctx.reply(result.confirmationMessage);\n 863→            return;\n 864→          }\n 865→\n 866→          await replyLargeText(ctx, result.output);\n 867→\n 868→          if (result.hasMorePages) {\n 869→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n 870→          }\n 871→          return;\n 872→        }\n 873→      } catch (error) {\n 874→        const message = error instanceof Error ? error.message : String(error);\n 875→        // If exec fails, fall through to chat mode\n 876→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n 877→      }\n 878→    }\n 879→\n 880→    // F-011: Check if AI CLI is already running\n 881→    if (isAiCliRunning(sessionId)) {\n 882→      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n 883→      return;\n 884→    }\n 885→\n 886→    let typingTimer = null;\n 887→\n 888→    try {\n 889→      ensureAllowed(ctx);\n 890→      await ctx.sendChatAction('typing');\n 891→\n 892→      const streamPublisher = createEditableStreamPublisher(ctx);\n 893→      typingTimer = setInterval(() => {\n 894→        ctx.sendChatAction('typing').catch(() => undefined);\n 895→      }, TYPING_INTERVAL_MS);\n 896→\n 897→      // F-011: Use ai-cli-service for execution with process tracking\n 898→      const sessionKey = `telegram:${sessionId}`;\n 899→\n 900→      // Append user message to session history\n 901→      sessionStore.append(sessionKey, 'user', ctx.message.text);\n 902→\n 903→      // Build prompt with context\n 904→      const prompt = sessionStore.toPrompt(sessionKey, 'telegram');\n 905→\n 906→      // Track last heartbeat message for updates\n 907→      /** @type {{ message_id: number } | null} */\n 908→      let lastHeartbeatMsg = null;\n 909→\n 910→      const result = await executeAiCli({\n 911→        sessionId,\n 912→        prompt,\n 913→        hooks: {\n 914→          onChunk: (text) => {\n 915→            streamPublisher.push(text);\n 916→          },\n 917→          onHeartbeat: config.aiCliEnableHeartbeat ? (info) => {\n 918→            // Send/update heartbeat progress message\n 919→            const elapsedSec = Math.floor(info.elapsedMs / 1000);\n 920→            const progressText = `⏳ 任务执行中... (${elapsedSec}s, ${Math.floor(info.stdoutBytes / 1024)}KB)`;\n 921→\n 922→            // Don't await - fire and forget\n 923→            if (lastHeartbeatMsg) {\n 924→              ctx.telegram.editMessageText(ctx.chat.id, lastHeartbeatMsg.message_id, undefined, progressText)\n 925→                .catch(() => {});\n 926→            } else {\n 927→              ctx.reply(progressText)\n 928→                .then((msg) => { lastHeartbeatMsg = msg; })\n 929→                .catch(() => {});\n 930→            }\n 931→          } : undefined,\n 932→          onStatus: (status) => {\n 933→            if (status === 'running') {\n 934→              ctx.sendChatAction('typing').catch(() => undefined);\n 935→            }\n 936→          }\n 937→        }\n 938→      });\n 939→\n 940→      // Delete heartbeat message if exists\n 941→      if (lastHeartbeatMsg) {\n 942→        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n 943→      }\n 944→\n 945→      // Append assistant reply to session history\n 946→      sessionStore.append(sessionKey, 'assistant', result.output);\n 947→\n 948→      // F-011: Format output with MarkdownV2\n 949→      const formattedOutput = convertToMarkdownV2(result.output);\n 950→\n 951→      // Handle result states\n 952→      if (result.interrupted) {\n 953→        await ctx.reply('⏹️ 任务已被中断。');\n 954→      } else if (result.timedOut) {\n 955→        await ctx.reply(`⏰ 任务执行超时。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`);\n 956→      }\n 957→\n 958→      // Extract file markers and send\n 959→      const { fileRefs, cleanedText } = extractFileMarkers(result.output);\n 960→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n 961→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n 962→\n 963→      streamPublisher.setFinalText(finalText);\n 964→      const streamed = await streamPublisher.finish();\n 965→      if (streamed.outputLength === 0) {\n 966→        await replyLargeText(ctx, finalText);\n 967→      }\n 968→\n 969→      if (fileRefs.length > 0) {\n 970→        const fileSendResults = await replyFiles(ctx, fileRefs);\n 971→        const failed = fileSendResults.filter((item) => !item.sent);\n 972→\n 973→        if (failed.length === 0) {\n 974→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n 975→        } else {\n 976→          const failedList = failed\n 977→            .map((item) => {\n 978→              const reason =\n 979→                item.reason === 'relative_path_not_allowed'\n 980→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n 981→                  : item.reason === 'not_found'\n 982→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n 983→                    : item.reason;\n 984→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n 985→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n 986→            })\n 987→            .join('\\n');\n 988→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n 989→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n 990→        }\n 991→      }\n 992→    } catch (error) {\n 993→      const message = error instanceof Error ? error.message : String(error);\n 994→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n 995→      await safeReply(ctx, `处理失败：${message}`);\n 996→    } finally {\n 997→      if (typingTimer) {\n 998→        clearInterval(typingTimer);\n 999→      }\n1000→    }\n1001→  });\n1002→\n1003→  return bot;\n1004→}\n1005→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_iXgcoTlK9kvFZGL66qeSmEfH","__timestamp":"2026-03-19T17:08:50.442Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"feb47147-6128-4114-8138-190df6b02b39","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"call_TuZx96LarSVwShLJCFEmOyzo","content":[{"type":"text","text":"   1→/**\n   2→ * Command Router\n   3→ * Main entry point for command routing and dispatch.\n   4→ */\n   5→\n   6→import { parseCommand } from './parser.js';\n   7→import { getCommand, getAliasMap, registerCommand } from './registry.js';\n   8→import { validateCommand } from './validator.js';\n   9→import { formatError, formatValidationErrors, ErrorCodes } from './formatter.js';\n  10→import { isAllowedUser } from '../../security/guard.js';\n  11→import { checkCommandPermission, getUserRole } from '../../security/permission-guard.js';\n  12→import { logAuditEntry } from '../../services/audit-log-service.js';\n  13→import { aliasStore } from '../../services/alias-store.js';\n  14→import { sessionStore } from '../../services/session-store.js';\n  15→\n  16→/**\n  17→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  18→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  19→ * @typedef {import('./registry.js').CommandEntry} CommandEntry\n  20→ */\n  21→\n  22→/**\n  23→ * Build session ID from context.\n  24→ * @param {Object} ctx - Telegraf context\n  25→ * @returns {string} Session ID\n  26→ */\n  27→function buildSessionId(ctx) {\n  28→  return String(ctx.chat.id);\n  29→}\n  30→\n  31→/**\n  32→ * Route and dispatch a command from Telegram context.\n  33→ * @param {Object} ctx - Telegraf context\n  34→ * @returns {Promise<boolean>} True if command was handled\n  35→ */\n  36→export async function routeCommand(ctx) {\n  37→  let text = ctx.message?.text;\n  38→\n  39→  if (!text || !text.startsWith('/')) {\n  40→    return false;\n  41→  }\n  42→\n  43→  // Authorization check\n  44→  const userId = ctx.from?.id;\n  45→  if (!isAuthorized(userId)) {\n  46→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n  47→    return true;\n  48→  }\n  49→\n  50→  const sessionId = buildSessionId(ctx);\n  51→  const userIdStr = String(userId);\n  52→\n  53→  // F-013: Touch session on each command\n  54→  sessionStore.touchSession(sessionId, userIdStr);\n  55→\n  56→  // F-013: Resolve alias if the command name is an alias\n  57→  const commandMatch = text.match(/^\\/(\\S+)/);\n  58→  if (commandMatch) {\n  59→    const potentialAlias = commandMatch[1].toLowerCase();\n  60→    const resolvedCommand = aliasStore.resolveAlias(userIdStr, potentialAlias);\n  61→    if (resolvedCommand) {\n  62→      // Replace the alias with the resolved command\n  63→      const args = text.slice(commandMatch[0].length);\n  64→      text = `/${resolvedCommand}${args}`;\n  65→    }\n  66→  }\n  67→\n  68→  // Parse command\n  69→  const aliasMap = getAliasMap();\n  70→  const parsed = parseCommand(text, aliasMap);\n  71→\n  72→  if (!parsed) {\n  73→    await ctx.reply('无法解析命令。');\n  74→    return true;\n  75→  }\n  76→\n  77→  // Lookup command\n  78→  const entry = getCommand(parsed.command);\n  79→\n  80→  if (!entry) {\n  81→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n  82→    return true;\n  83→  }\n  84→\n  85→  const { meta, handler } = entry;\n  86→\n  87→  // T-101: Permission check\n  88→  const commandName = meta.name;\n  89→  const permResult = checkCommandPermission(userId, commandName);\n  90→\n  91→  if (!permResult.allowed) {\n  92→    // Log denied access\n  93→    await logAuditEntry({\n  94→      userId,\n  95→      action: commandName,\n  96→      params: {},\n  97→      result: 'denied',\n  98→      reason: permResult.reason\n  99→    });\n 100→\n 101→    await ctx.reply(`⛔ ${permResult.reason}`);\n 102→    return true;\n 103→  }\n 104→\n 105→  // Validate command\n 106→  const validation = validateCommand(parsed, meta);\n 107→\n 108→  if (!validation.valid) {\n 109→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n 110→    await ctx.reply(errorMsg);\n 111→    return true;\n 112→  }\n 113→\n 114→  // Create handler context\n 115→  const handlerContext = {\n 116→    ctx,\n 117→    parsed,\n 118→    meta,\n 119→    params: validation.normalized || {},\n 120→    userId,\n 121→    userRole: getUserRole(userId),\n 122→    sessionId,\n 123→    requiresConfirmation: permResult.requiresConfirmation,\n 124→    reply: async (text) => ctx.reply(text),\n 125→    replyFile: async (content, filename) => {\n 126→      // Will be implemented with proper file handling\n 127→      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n 128→    },\n 129→    args: parsed.args || []\n 130→  };\n 131→\n 132→  // Dispatch to handler\n 133→  try {\n 134→    await handler(handlerContext);\n 135→  } catch (error) {\n 136→    const message = error instanceof Error ? error.message : String(error);\n 137→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n 138→  }\n 139→\n 140→  return true;\n 141→}\n 142→\n 143→/**\n 144→ * Check if user is authorized.\n 145→ * @param {number|string|undefined} userId - User ID\n 146→ * @returns {boolean} True if authorized\n 147→ */\n 148→function isAuthorized(userId) {\n 149→  return isAllowedUser(userId);\n 150→}\n 151→\n 152→/**\n 153→ * Format error response for display.\n 154→ * @param {Object} error - Error object\n 155→ * @returns {string} Formatted error\n 156→ */\n 157→function formatErrorResponse(error) {\n 158→  const lines = [`❌ ${error.message}`];\n 159→\n 160→  if (error.suggestion) {\n 161→    lines.push(`💡 ${error.suggestion}`);\n 162→  }\n 163→\n 164→  if (error.usage) {\n 165→    lines.push(`用法: ${error.usage}`);\n 166→  }\n 167→\n 168→  return lines.join('\\n');\n 169→}\n 170→\n 171→/**\n 172→ * Register all default commands.\n 173→ */\n 174→export function registerDefaultCommands() {\n 175→  // Commands will be registered by individual handlers\n 176→  // This is called during initialization\n 177→}\n 178→\n 179→/**\n 180→ * Create middleware for command routing.\n 181→ * @returns {Function} Middleware function\n 182→ */\n 183→export function createCommandMiddleware() {\n 184→  return async (ctx, next) => {\n 185→    const handled = await routeCommand(ctx);\n 186→    if (!handled) {\n 187→      return next();\n 188→    }\n 189→  };\n 190→}\n 191→\n 192→// Re-export for convenience\n 193→export { registerCommand, getCommand, getAliasMap };\n 194→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_TuZx96LarSVwShLJCFEmOyzo","__timestamp":"2026-03-19T17:08:50.443Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"5400dd44-84ff-4dab-8a7c-9231022c0634","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"call_ROtCruVNy8GtBQDND5hp3AN1","content":[{"type":"text","text":"   1→/**\n   2→ * Command Parser\n   3→ * Parses Telegram message text into structured ParsedCommand object.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParsedCommand\n   8→ * @property {string} command - The command name (e.g., \"pipeline\")\n   9→ * @property {string} [subcommand] - Optional subcommand (e.g., \"run\")\n  10→ * @property {string[]} args - Positional arguments\n  11→ * @property {Record<string, string>} options - Key-value options (--key=value)\n  12→ * @property {string} raw - Original message text\n  13→ */\n  14→\n  15→/**\n  16→ * Parse Telegram message text into a structured command object.\n  17→ * @param {string} text - The message text to parse\n  18→ * @param {Object} [aliasMap={}] - Map of aliases to command names\n  19→ * @returns {ParsedCommand | null} Parsed command or null if not a command\n  20→ */\n  21→export function parseCommand(text, aliasMap = {}) {\n  22→  if (!text || typeof text !== 'string') {\n  23→    return null;\n  24→  }\n  25→\n  26→  const trimmed = text.trim();\n  27→\n  28→  // Must start with /\n  29→  if (!trimmed.startsWith('/')) {\n  30→    return null;\n  31→  }\n  32→\n  33→  // Extract command (first token after /)\n  34→  const tokens = trimmed.slice(1).split(/\\s+/);\n  35→  if (tokens.length === 0 || !tokens[0]) {\n  36→    return null;\n  37→  }\n  38→\n  39→  let command = tokens[0].toLowerCase();\n  40→  const rest = tokens.slice(1);\n  41→\n  42→  // Handle @bot suffix (e.g., /command@mybot)\n  43→  const atIndex = command.indexOf('@');\n  44→  if (atIndex !== -1) {\n  45→    command = command.slice(0, atIndex);\n  46→  }\n  47→\n  48→  // Apply alias mapping\n  49→  if (aliasMap[command]) {\n  50→    command = aliasMap[command];\n  51→  }\n  52→\n  53→  const args = [];\n  54→  /** @type {Record<string, string>} */\n  55→  const options = {};\n  56→  let subcommand = undefined;\n  57→\n  58→  for (const token of rest) {\n  59→    // Parse --key=value options\n  60→    if (token.startsWith('--')) {\n  61→      const optionText = token.slice(2);\n  62→      const eqIndex = optionText.indexOf('=');\n  63→      if (eqIndex !== -1) {\n  64→        const key = optionText.slice(0, eqIndex).toLowerCase();\n  65→        const value = optionText.slice(eqIndex + 1);\n  66→        options[key] = value;\n  67→      } else {\n  68→        // Boolean flag --flag\n  69→        options[optionText.toLowerCase()] = 'true';\n  70→      }\n  71→    } else if (token.includes('=')) {\n  72→      // Parse key=value (without --)\n  73→      const eqIndex = token.indexOf('=');\n  74→      const key = token.slice(0, eqIndex).toLowerCase();\n  75→      const value = token.slice(eqIndex + 1);\n  76→      options[key] = value;\n  77→    } else if (subcommand === undefined && !token.startsWith('-') && args.length === 0) {\n  78→      // First non-option token is subcommand if it looks like one\n  79→      // This will be validated by the registry\n  80→      subcommand = token.toLowerCase();\n  81→    } else {\n  82→      // Positional argument\n  83→      args.push(token);\n  84→    }\n  85→  }\n  86→\n  87→  return {\n  88→    command,\n  89→    subcommand,\n  90→    args,\n  91→    options,\n  92→    raw: text\n  93→  };\n  94→}\n  95→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_ROtCruVNy8GtBQDND5hp3AN1","__timestamp":"2026-03-19T17:08:50.444Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"44018e1f-ebc7-4a26-baa6-d283efcfda4b","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"call_pQQZU6UN8eQQWCHnF9RTsl9V","content":[{"type":"text","text":"   1→/**\n   2→ * Command Registry\n   3→ * Manages command registration, lookup, and metadata.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ParamMeta\n   8→ * @property {string} name - Parameter name\n   9→ * @property {boolean} required - Whether the parameter is required\n  10→ * @property {string} description - Parameter description\n  11→ * @property {string} [type] - Parameter type (string, number, enum)\n  12→ * @property {string[]} [enum] - Allowed values for enum type\n  13→ * @property {*} [default] - Default value\n  14→ */\n  15→\n  16→/**\n  17→ * @typedef {Object} SubcommandMeta\n  18→ * @property {string} name - Subcommand name\n  19→ * @property {string} description - Subcommand description\n  20→ * @property {ParamMeta[]} [params] - Subcommand parameters\n  21→ */\n  22→\n  23→/**\n  24→ * @typedef {Object} CommandMeta\n  25→ * @property {string} name - Command name\n  26→ * @property {string[]} [aliases] - Command aliases\n  27→ * @property {string} description - Command description\n  28→ * @property {string} usage - Usage example\n  29→ * @property {string[]} [examples] - Usage examples\n  30→ * @property {SubcommandMeta[]} [subcommands] - Available subcommands\n  31→ * @property {ParamMeta[]} [params] - Command parameters\n  32→ * @property {boolean} requiresAuth - Whether authorization is required\n  33→ * @property {string} [minRole] - Minimum required role (viewer, operator, admin)\n  34→ * @property {boolean} [requiresConfirmation] - Whether confirmation is required for high-risk commands\n  35→ * @property {string} helpText - Help text for the command\n  36→ */\n  37→\n  38→/**\n  39→ * @typedef {Object} CommandEntry\n  40→ * @property {CommandMeta} meta - Command metadata\n  41→ * @property {Function} handler - Command handler function\n  42→ */\n  43→\n  44→/**\n  45→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  46→ */\n  47→\n  48→// Internal registry storage\n  49→const commands = new Map();\n  50→const aliasToCommand = new Map();\n  51→\n  52→/**\n  53→ * Register a command with its metadata and handler.\n  54→ * @param {CommandMeta} meta - Command metadata\n  55→ * @param {Function} handler - Command handler function\n  56→ * @throws {Error} If command already registered\n  57→ */\n  58→export function registerCommand(meta, handler) {\n  59→  if (!meta || !meta.name) {\n  60→    throw new Error('Command meta must have a name');\n  61→  }\n  62→\n  63→  // Normalize meta with lowercase name\n  64→  const normalizedMeta = {\n  65→    ...meta,\n  66→    name: meta.name.toLowerCase()\n  67→  };\n  68→  const name = normalizedMeta.name;\n  69→\n  70→  if (commands.has(name)) {\n  71→    throw new Error(`Command \"${name}\" is already registered`);\n  72→  }\n  73→\n  74→  // Register command\n  75→  commands.set(name, { meta: normalizedMeta, handler });\n  76→\n  77→  // Register aliases\n  78→  if (meta.aliases && Array.isArray(meta.aliases)) {\n  79→    for (const alias of meta.aliases) {\n  80→      const aliasLower = alias.toLowerCase();\n  81→      if (aliasToCommand.has(aliasLower)) {\n  82→        throw new Error(`Alias \"${alias}\" is already registered`);\n  83→      }\n  84→      aliasToCommand.set(aliasLower, name);\n  85→    }\n  86→  }\n  87→}\n  88→\n  89→/**\n  90→ * Get a command entry by name or alias.\n  91→ * @param {string} name - Command name or alias\n  92→ * @returns {CommandEntry | null} Command entry or null\n  93→ */\n  94→export function getCommand(name) {\n  95→  if (!name || typeof name !== 'string') {\n  96→    return null;\n  97→  }\n  98→\n  99→  const nameLower = name.toLowerCase();\n 100→\n 101→  // Try direct lookup\n 102→  if (commands.has(nameLower)) {\n 103→    return commands.get(nameLower);\n 104→  }\n 105→\n 106→  // Try alias lookup\n 107→  const resolvedName = aliasToCommand.get(nameLower);\n 108→  if (resolvedName && commands.has(resolvedName)) {\n 109→    return commands.get(resolvedName);\n 110→  }\n 111→\n 112→  return null;\n 113→}\n 114→\n 115→/**\n 116→ * Check if a name is a registered alias.\n 117→ * @param {string} name - Name to check\n 118→ * @returns {boolean} True if name is an alias\n 119→ */\n 120→export function isAlias(name) {\n 121→  if (!name || typeof name !== 'string') {\n 122→    return false;\n 123→  }\n 124→  return aliasToCommand.has(name.toLowerCase());\n 125→}\n 126→\n 127→/**\n 128→ * Get all registered commands.\n 129→ * @returns {CommandEntry[]} All command entries\n 130→ */\n 131→export function getAllCommands() {\n 132→  return Array.from(commands.values());\n 133→}\n 134→\n 135→/**\n 136→ * Generate help text for a specific command or all commands.\n 137→ * @param {string} [commandName] - Optional command name for specific help\n 138→ * @returns {string} Help text\n 139→ */\n 140→export function getHelpText(commandName) {\n 141→  if (commandName) {\n 142→    const entry = getCommand(commandName);\n 143→    if (!entry) {\n 144→      return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n 145→    }\n 146→    return formatCommandHelp(entry.meta);\n 147→  }\n 148→\n 149→  // Generate general help\n 150→  const commandList = getAllCommands()\n 151→    .map((entry) => {\n 152→      const aliases = entry.meta.aliases?.length ? ` (${entry.meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n 153→      return `/${entry.meta.name}${aliases} - ${entry.meta.description}`;\n 154→    })\n 155→    .sort();\n 156→\n 157→  return `可用命令：\\n\\n${commandList.join('\\n')}`;\n 158→}\n 159→\n 160→/**\n 161→ * Format detailed help for a single command.\n 162→ * @param {CommandMeta} meta - Command metadata\n 163→ * @returns {string} Formatted help text\n 164→ */\n 165→function formatCommandHelp(meta) {\n 166→  const lines = [`/${meta.name} - ${meta.description}`];\n 167→\n 168→  if (meta.aliases?.length) {\n 169→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n 170→  }\n 171→\n 172→  if (meta.usage) {\n 173→    lines.push(`用法: ${meta.usage}`);\n 174→  }\n 175→\n 176→  if (meta.subcommands?.length) {\n 177→    lines.push('\\n子命令:');\n 178→    for (const sub of meta.subcommands) {\n 179→      lines.push(`  ${sub.name} - ${sub.description}`);\n 180→    }\n 181→  }\n 182→\n 183→  if (meta.params?.length) {\n 184→    lines.push('\\n参数:');\n 185→    for (const param of meta.params) {\n 186→      const required = param.required ? '(必填)' : '(可选)';\n 187→      lines.push(`  ${param.name} ${required} - ${param.description}`);\n 188→    }\n 189→  }\n 190→\n 191→  if (meta.examples?.length) {\n 192→    lines.push('\\n示例:');\n 193→    for (const example of meta.examples) {\n 194→      lines.push(`  ${example}`);\n 195→    }\n 196→  }\n 197→\n 198→  return lines.join('\\n');\n 199→}\n 200→\n 201→/**\n 202→ * Clear the registry (for testing).\n 203→ */\n 204→export function clearRegistry() {\n 205→  commands.clear();\n 206→  aliasToCommand.clear();\n 207→}\n 208→\n 209→/**\n 210→ * Get the alias map for parser usage.\n 211→ * @returns {Record<string, string>} Alias to command name mapping\n 212→ */\n 213→export function getAliasMap() {\n 214→  /** @type {Record<string, string>} */\n 215→  const map = {};\n 216→  for (const [alias, command] of aliasToCommand) {\n 217→    map[alias] = command;\n 218→  }\n 219→  return map;\n 220→}\n 221→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_pQQZU6UN8eQQWCHnF9RTsl9V","__timestamp":"2026-03-19T17:08:50.445Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"1299ac73-bcf6-4b53-b5a6-fa088c1e6266","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"call_7qsefPSY7DyJt8pZKNwc3bZ2","content":[{"type":"text","text":"   1→/**\n   2→ * Command Validator\n   3→ * Validates command parameters and generates error messages.\n   4→ */\n   5→\n   6→/**\n   7→ * @typedef {Object} ValidationError\n   8→ * @property {string} param - Parameter name\n   9→ * @property {string} message - Error message\n  10→ * @property {string} [suggestion] - Correction suggestion\n  11→ */\n  12→\n  13→/**\n  14→ * @typedef {Object} ValidationResult\n  15→ * @property {boolean} valid - Whether validation passed\n  16→ * @property {ValidationError[]} errors - Validation errors\n  17→ * @property {Record<string, *>} [normalized] - Normalized parameters\n  18→ */\n  19→\n  20→/**\n  21→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n  22→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n  23→ * @typedef {import('./registry.js').ParamMeta} ParamMeta\n  24→ * @typedef {import('./registry.js').SubcommandMeta} SubcommandMeta\n  25→ */\n  26→\n  27→/**\n  28→ * Validate a parsed command against its metadata.\n  29→ * @param {ParsedCommand} parsed - Parsed command\n  30→ * @param {CommandMeta} meta - Command metadata\n  31→ * @returns {ValidationResult} Validation result\n  32→ */\n  33→export function validateCommand(parsed, meta) {\n  34→  const errors = [];\n  35→  /** @type {Record<string, *>} */\n  36→  const normalized = { ...parsed.options };\n  37→\n  38→  // Validate subcommand if command has subcommands\n  39→  if (meta.subcommands?.length) {\n  40→    const validSubcommands = meta.subcommands.map((s) => s.name);\n  41→    if (parsed.subcommand && !validSubcommands.includes(parsed.subcommand)) {\n  42→      errors.push({\n  43→        param: 'subcommand',\n  44→        message: `未知子命令 '${parsed.subcommand}'`,\n  45→        suggestion: `可用子命令: ${validSubcommands.join(', ')}`\n  46→      });\n  47→    }\n  48→  }\n  49→\n  50→  // Get applicable params\n  51→  const params = getParamsForSubcommand(meta, parsed.subcommand);\n  52→\n  53→  // Validate parameters\n  54→  for (let i = 0; i < params.length; i++) {\n  55→    const param = params[i];\n  56→    const value = getParamValue(parsed, param.name, meta, i);\n  57→    const validationResult = validateParam(param, value);\n  58→\n  59→    if (!validationResult.valid) {\n  60→      errors.push(validationResult.error);\n  61→    } else if (validationResult.value !== undefined) {\n  62→      normalized[param.name] = validationResult.value;\n  63→    }\n  64→  }\n  65→\n  66→  // Add positional args to normalized\n  67→  if (parsed.args.length > 0) {\n  68→    normalized._args = parsed.args;\n  69→  }\n  70→\n  71→  return {\n  72→    valid: errors.length === 0,\n  73→    errors,\n  74→    normalized: errors.length === 0 ? normalized : undefined\n  75→  };\n  76→}\n  77→\n  78→/**\n  79→ * Get parameters applicable to a subcommand.\n  80→ * @param {CommandMeta} meta - Command metadata\n  81→ * @param {string|undefined} subcommand - Subcommand name\n  82→ * @returns {ParamMeta[]} Parameters\n  83→ */\n  84→function getParamsForSubcommand(meta, subcommand) {\n  85→  const params = [...(meta.params || [])];\n  86→\n  87→  // Add subcommand-specific params\n  88→  if (subcommand && meta.subcommands) {\n  89→    const subMeta = meta.subcommands.find((s) => s.name === subcommand);\n  90→    if (subMeta?.params) {\n  91→      params.push(...subMeta.params);\n  92→    }\n  93→  }\n  94→\n  95→  return params;\n  96→}\n  97→\n  98→/**\n  99→ * Get parameter value from parsed command.\n 100→ * @param {ParsedCommand} parsed - Parsed command\n 101→ * @param {string} paramName - Parameter name\n 102→ * @param {CommandMeta} meta - Command metadata\n 103→ * @param {number} paramIndex - Index of parameter in params array\n 104→ * @returns {string|undefined} Parameter value\n 105→ */\n 106→function getParamValue(parsed, paramName, meta, paramIndex) {\n 107→  // Check options first (explicit --key=value takes precedence)\n 108→  if (parsed.options[paramName] !== undefined) {\n 109→    return parsed.options[paramName];\n 110→  }\n 111→\n 112→  // Build positional args list\n 113→  // If command has no subcommands, parsed.subcommand should be treated as first positional arg\n 114→  const hasSubcommands = meta.subcommands && meta.subcommands.length > 0;\n 115→  const positionalArgs = [];\n 116→\n 117→  if (!hasSubcommands && parsed.subcommand !== undefined) {\n 118→    // F002-CRIT-001: Treat subcommand as first positional param when command has no subcommands\n 119→    positionalArgs.push(parsed.subcommand);\n 120→  }\n 121→\n 122→  // Add remaining args\n 123→  positionalArgs.push(...parsed.args);\n 124→\n 125→  // Map positional arg by index\n 126→  if (paramIndex !== undefined && positionalArgs[paramIndex] !== undefined) {\n 127→    return positionalArgs[paramIndex];\n 128→  }\n 129→\n 130→  return undefined;\n 131→}\n 132→\n 133→/**\n 134→ * Validate a single parameter.\n 135→ * @param {ParamMeta} param - Parameter metadata\n 136→ * @param {string|undefined} value - Parameter value\n 137→ * @returns {{valid: boolean, error?: ValidationError, value?: *}}\n 138→ */\n 139→function validateParam(param, value) {\n 140→  // Check required\n 141→  if (param.required && (value === undefined || value === '')) {\n 142→    return {\n 143→      valid: false,\n 144→      error: {\n 145→        param: param.name,\n 146→        message: `缺少参数 '${param.name}'`,\n 147→        suggestion: `请提供 ${param.name} 参数`\n 148→      }\n 149→    };\n 150→  }\n 151→\n 152→  // If not provided and has default, use default\n 153→  if (value === undefined && param.default !== undefined) {\n 154→    return { valid: true, value: param.default };\n 155→  }\n 156→\n 157→  // If not provided and not required, OK\n 158→  if (value === undefined) {\n 159→    return { valid: true };\n 160→  }\n 161→\n 162→  // Type validation\n 163→  if (param.type === 'number') {\n 164→    const num = Number(value);\n 165→    if (Number.isNaN(num)) {\n 166→      return {\n 167→        valid: false,\n 168→        error: {\n 169→          param: param.name,\n 170→          message: `参数 '${param.name}' 必须是数字`,\n 171→          suggestion: `请输入有效的数字`\n 172→        }\n 173→      };\n 174→    }\n 175→    return { valid: true, value: num };\n 176→  }\n 177→\n 178→  // Enum validation\n 179→  if (param.type === 'enum' && param.enum?.length) {\n 180→    if (!param.enum.includes(value)) {\n 181→      return {\n 182→        valid: false,\n 183→        error: {\n 184→          param: param.name,\n 185→          message: `参数 '${param.name}' 值无效: ${value}`,\n 186→          suggestion: `可选值: ${param.enum.join(', ')}`\n 187→        }\n 188→      };\n 189→    }\n 190→  }\n 191→\n 192→  return { valid: true, value };\n 193→}\n 194→\n 195→/**\n 196→ * Validate that a subcommand is valid for a command.\n 197→ * @param {string} subcommand - Subcommand name\n 198→ * @param {SubcommandMeta[]} subcommands - Available subcommands\n 199→ * @returns {{valid: boolean, error?: ValidationError}}\n 200→ */\n 201→export function validateSubcommand(subcommand, subcommands) {\n 202→  if (!subcommand) {\n 203→    return { valid: true };\n 204→  }\n 205→\n 206→  const validNames = (subcommands || []).map((s) => s.name);\n 207→  if (validNames.length === 0) {\n 208→    return { valid: true };\n 209→  }\n 210→\n 211→  if (!validNames.includes(subcommand)) {\n 212→    return {\n 213→      valid: false,\n 214→      error: {\n 215→        param: 'subcommand',\n 216→        message: `未知子命令 '${subcommand}'`,\n 217→        suggestion: `可用子命令: ${validNames.join(', ')}`\n 218→      }\n 219→    };\n 220→  }\n 221→\n 222→  return { valid: true };\n 223→}\n 224→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_7qsefPSY7DyJt8pZKNwc3bZ2","__timestamp":"2026-03-19T17:08:50.445Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"cddea94c-3038-488e-bf4d-58d5048fd274","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"call_rVYtIDN00qcXpB24N58BMSU4","content":[{"type":"text","text":"   1→/**\n   2→ * Error Formatter\n   3→ * Formats error messages for user-friendly display.\n   4→ */\n   5→\n   6→/**\n   7→ * Error codes for command errors.\n   8→ */\n   9→export const ErrorCodes = {\n  10→  UNKNOWN_COMMAND: 'UNKNOWN_COMMAND',\n  11→  UNKNOWN_SUBCOMMAND: 'UNKNOWN_SUBCOMMAND',\n  12→  MISSING_PARAM: 'MISSING_PARAM',\n  13→  INVALID_PARAM: 'INVALID_PARAM',\n  14→  UNAUTHORIZED: 'UNAUTHORIZED',\n  15→  INTERNAL_ERROR: 'INTERNAL_ERROR'\n  16→};\n  17→\n  18→/**\n  19→ * @typedef {Object} ErrorResponse\n  20→ * @property {string} code - Error code\n  21→ * @property {string} message - User-friendly error message\n  22→ * @property {string} [suggestion] - Correction suggestion\n  23→ * @property {string} [usage] - Correct usage example\n  24→ */\n  25→\n  26→/**\n  27→ * Format an error for display to the user.\n  28→ * @param {string} code - Error code\n  29→ * @param {Object} context - Error context\n  30→ * @param {string} [context.command] - Command name\n  31→ * @param {string} [context.subcommand] - Subcommand name\n  32→ * @param {string} [context.param] - Parameter name\n  33→ * @param {string} [context.value] - Invalid value\n  34→ * @param {string} [context.reason] - Error reason\n  35→ * @param {string} [context.suggestion] - Custom suggestion\n  36→ * @param {string} [context.usage] - Correct usage\n  37→ * @param {string[]} [context.available] - Available options\n  38→ * @returns {ErrorResponse} Formatted error\n  39→ */\n  40→export function formatError(code, context = {}) {\n  41→  switch (code) {\n  42→    case ErrorCodes.UNKNOWN_COMMAND:\n  43→      return {\n  44→        code,\n  45→        message: `未知命令 '${context.command || ''}'。`,\n  46→        suggestion: '输入 /help 查看可用命令。'\n  47→      };\n  48→\n  49→    case ErrorCodes.UNKNOWN_SUBCOMMAND:\n  50→      return {\n  51→        code,\n  52→        message: `未知子命令 '${context.subcommand || ''}'。`,\n  53→        suggestion: context.available ? `可用: ${context.available.join(', ')}` : undefined,\n  54→        usage: context.usage\n  55→      };\n  56→\n  57→    case ErrorCodes.MISSING_PARAM:\n  58→      return {\n  59→        code,\n  60→        message: `缺少参数 '${context.param || ''}'。`,\n  61→        suggestion: context.suggestion || `请提供 ${context.param} 参数`,\n  62→        usage: context.usage\n  63→      };\n  64→\n  65→    case ErrorCodes.INVALID_PARAM:\n  66→      return {\n  67→        code,\n  68→        message: `参数 '${context.param || ''}' 无效: ${context.reason || ''}`,\n  69→        suggestion: context.suggestion,\n  70→        usage: context.usage\n  71→      };\n  72→\n  73→    case ErrorCodes.UNAUTHORIZED:\n  74→      return {\n  75→        code,\n  76→        message: '当前账号未被授权使用该命令。',\n  77→        suggestion: '请联系管理员获取授权。'\n  78→      };\n  79→\n  80→    case ErrorCodes.INTERNAL_ERROR:\n  81→      return {\n  82→        code,\n  83→        message: '内部错误，请稍后重试。',\n  84→        suggestion: context.reason ? `错误: ${context.reason}` : undefined\n  85→      };\n  86→\n  87→    default:\n  88→      return {\n  89→        code: ErrorCodes.INTERNAL_ERROR,\n  90→        message: '未知错误。'\n  91→      };\n  92→  }\n  93→}\n  94→\n  95→/**\n  96→ * Format validation errors into a single message.\n  97→ * @param {import('./validator.js').ValidationError[]} errors - Validation errors\n  98→ * @param {string} [usage] - Usage hint\n  99→ * @returns {string} Formatted error message\n 100→ */\n 101→export function formatValidationErrors(errors, usage) {\n 102→  if (!errors || errors.length === 0) {\n 103→    return '';\n 104→  }\n 105→\n 106→  const lines = [];\n 107→\n 108→  for (const error of errors) {\n 109→    lines.push(`❌ ${error.message}`);\n 110→    if (error.suggestion) {\n 111→      lines.push(`   建议: ${error.suggestion}`);\n 112→    }\n 113→  }\n 114→\n 115→  if (usage) {\n 116→    lines.push(`\\n用法: ${usage}`);\n 117→  }\n 118→\n 119→  return lines.join('\\n');\n 120→}\n 121→\n 122→/**\n 123→ * Format an error response into a display string.\n 124→ * @param {ErrorResponse} error - Error response\n 125→ * @returns {string} Formatted string\n 126→ */\n 127→export function formatErrorResponse(error) {\n 128→  const lines = [`❌ ${error.message}`];\n 129→\n 130→  if (error.suggestion) {\n 131→    lines.push(`💡 ${error.suggestion}`);\n 132→  }\n 133→\n 134→  if (error.usage) {\n 135→    lines.push(`用法: ${error.usage}`);\n 136→  }\n 137→\n 138→  return lines.join('\\n');\n 139→}\n 140→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_rVYtIDN00qcXpB24N58BMSU4","__timestamp":"2026-03-19T17:08:50.446Z","_requestId":"261f0390879c473391691a62bef865bb"}
{"type":"user","uuid":"165964a4-4757-4e4f-811b-7992d8e88051","session_id":"1a92230a-3ee9-442f-b7e5-d91466bab0d9","message":{"content":[{"type":"tool_result","tool_use_id":"call_fXX1cdd1ClPUztp1b5hEEU22","content":[{"type":"text","text":"   1→/**\n   2→ * Help Text Generator\n   3→ * Generates help text for commands.\n   4→ */\n   5→\n   6→import { getCommand, getAllCommands } from './registry.js';\n   7→\n   8→/**\n   9→ * Generate help text for all commands or a specific command.\n  10→ * @param {string} [commandName] - Optional command name\n  11→ * @returns {string} Help text\n  12→ */\n  13→export function generateHelp(commandName) {\n  14→  if (commandName) {\n  15→    return generateCommandHelp(commandName);\n  16→  }\n  17→  return generateGeneralHelp();\n  18→}\n  19→\n  20→/**\n  21→ * Generate general help text listing all commands.\n  22→ * @returns {string} Help text\n  23→ */\n  24→function generateGeneralHelp() {\n  25→  const commands = getAllCommands();\n  26→\n  27→  if (commands.length === 0) {\n  28→    return '暂无可用命令。';\n  29→  }\n  30→\n  31→  const lines = ['可用命令：', ''];\n  32→\n  33→  for (const entry of commands) {\n  34→    const { meta } = entry;\n  35→    const aliases = meta.aliases?.length ? ` (${meta.aliases.map((a) => `/${a}`).join(', ')})` : '';\n  36→    lines.push(`/${meta.name}${aliases}`);\n  37→    lines.push(`  ${meta.description}`);\n  38→    lines.push('');\n  39→  }\n  40→\n  41→  lines.push('输入 /help <命令> 查看详细用法。');\n  42→\n  43→  return lines.join('\\n');\n  44→}\n  45→\n  46→/**\n  47→ * Generate detailed help text for a specific command.\n  48→ * @param {string} commandName - Command name\n  49→ * @returns {string} Help text\n  50→ */\n  51→function generateCommandHelp(commandName) {\n  52→  const entry = getCommand(commandName);\n  53→\n  54→  if (!entry) {\n  55→    return `未知命令 '${commandName}'。输入 /help 查看可用命令。`;\n  56→  }\n  57→\n  58→  const { meta } = entry;\n  59→  const lines = [];\n  60→\n  61→  // Command name and description\n  62→  lines.push(`/${meta.name} - ${meta.description}`);\n  63→  lines.push('');\n  64→\n  65→  // Aliases\n  66→  if (meta.aliases?.length) {\n  67→    lines.push(`别名: ${meta.aliases.map((a) => `/${a}`).join(', ')}`);\n  68→    lines.push('');\n  69→  }\n  70→\n  71→  // Usage\n  72→  if (meta.usage) {\n  73→    lines.push(`用法: ${meta.usage}`);\n  74→    lines.push('');\n  75→  }\n  76→\n  77→  // Subcommands\n  78→  if (meta.subcommands?.length) {\n  79→    lines.push('子命令:');\n  80→    for (const sub of meta.subcommands) {\n  81→      lines.push(`  ${sub.name} - ${sub.description}`);\n  82→    }\n  83→    lines.push('');\n  84→  }\n  85→\n  86→  // Parameters\n  87→  if (meta.params?.length) {\n  88→    lines.push('参数:');\n  89→    for (const param of meta.params) {\n  90→      const required = param.required ? '(必填)' : '(可选)';\n  91→      const type = param.type ? ` [${param.type}]` : '';\n  92→      const enumValues = param.enum ? ` {${param.enum.join(', ')}}` : '';\n  93→      const defaultVal = param.default !== undefined ? ` = ${param.default}` : '';\n  94→      lines.push(`  ${param.name}${type}${enumValues}${defaultVal} ${required}`);\n  95→      lines.push(`    ${param.description}`);\n  96→    }\n  97→    lines.push('');\n  98→  }\n  99→\n 100→  // Examples\n 101→  if (meta.examples?.length) {\n 102→    lines.push('示例:');\n 103→    for (const example of meta.examples) {\n 104→      lines.push(`  ${example}`);\n 105→    }\n 106→    lines.push('');\n 107→  }\n 108→\n 109→  return lines.join('\\n').trim();\n 110→}\n 111→\n 112→/**\n 113→ * Generate quick reference for all commands.\n 114→ * @returns {string} Quick reference text\n 115→ */\n 116→export function generateQuickReference() {\n 117→  const commands = getAllCommands();\n 118→\n 119→  if (commands.length === 0) {\n 120→    return '暂无可用命令。';\n 121→  }\n 122→\n 123→  const lines = commands.map((entry) => {\n 124→    const { meta } = entry;\n 125→    const aliases = meta.aliases?.length ? ` /${meta.aliases.join(' /')}` : '';\n 126→    return `/${meta.name}${aliases} - ${meta.description}`;\n 127→  });\n 128→\n 129→  return lines.join('\\n');\n 130→}\n 131→"}],"is_error":false}],"role":"user"},"parent_tool_use_id":"call_fXX1cdd1ClPUztp1b5hEEU22","__timestamp":"2026-03-19T17:08:50.449Z","_requestId":"261f0390879c473391691a62bef865bb"}
