ctx - Telegraf context\n    41→ * @returns {Promise<boolean>} True if command was handled\n    42→ */\n    43→export async function routeCommand(ctx) {\n    44→  let text = ctx.message?.text;\n    45→\n    46→  if (!text) {\n    47→    return false;\n    48→  }\n    49→\n    50→  const isPureNL = !text.startsWith('/');\n    51→\n    52→  // ── Authorization check (both slash and pure-NL paths) ───────────────────\n    53→  const userId = ctx.from?.id;\n    54→  if (!isAuthorized(userId)) {\n    55→    if (!isPureNL) {\n    56→      // Only block slash commands with auth error; pure NL falls through to chat\n    57→      await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n    58→      return true;\n    59→    }\n    60→    return false;\n    61→  }\n    62→\n    63→  // ── Pure Natural Language path ────────────────────────────────────────────\n    64→  if (isPureNL) {\n    65→    return routePureNL(ctx, text, userId);\n    66→  }\n    67→\n    68→  // ── Slash command path ────────────────────────────────────────────────────\n    69→  const sessionId = buildSessionId(ctx);\n    70→  const userIdStr = String(userId);\n    71→\n    72→  // F-013: Touch session on each command\n    73→  sessionStore.touchSession(sessionId, userIdStr);\n    74→\n    75→  // F-013: Resolve alias if the command name is an alias\n    76→  const commandMatch = text.match(/^\\/(\\S+)/);\n    77→  if (commandMatch) {\n    78→    const potentialAlias = commandMatch[1].toLowerCase();\n    79→    const resolvedCommand = aliasStore.resolveAlias(userIdStr, potentialAlias);\n    80→    if (resolvedCommand) {\n    81→      // Replace the alias with the resolved command\n    82→      const args = text.slice(commandMatch[0].length);\n    83→      text = `/${resolvedCommand}${args}`;\n    84→    }\n    85→  }\n    86→\n    87→  // Parse command\n    88→  const aliasMap = getAliasMap();\n    89→  const parsed = parseCommand(text, aliasMap);\n    90→\n    91→  if (!parsed) {\n   