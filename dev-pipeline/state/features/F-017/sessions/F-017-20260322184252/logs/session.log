alse;\n   242→  }\n   243→\n   244→  const normalizedKey = key.toUpperCase();\n   245→  return SAFE_CONFIG_KEYS.includes(normalizedKey);\n   246→}\n   247→\n   248→/**\n   249→ * Validate configuration value against schema\n   250→ * @param {string} key - Configuration key\n   251→ * @param {string} value - Value to validate\n   252→ * @returns {Promise<{valid: boolean, normalizedValue?: any, error?: string}>}\n   253→ */\n   254→async function validateConfigValue(key, value) {\n   255→  try {\n   256→    // Basic type validation based on key patterns\n   257→    let normalizedValue = value;\n   258→\n   259→    // Handle numeric values\n   260→    if (key.endsWith('_MS') || key.endsWith('_SIZE') || key.includes('TIMEOUT') || key.includes('INTERVAL')) {\n   261→      const numValue = Number(value);\n   262→      if (isNaN(numValue) || numValue < 0) {\n   263→        return {\n   264→          valid: false,\n   265→          error: `配置项 '${key}' 需要有效的数字值`\n   266→        };\n   267→      }\n   268→      normalizedValue = numValue; // Return as number, not string\n   269→    }\n   270→\n   271→    // Handle boolean values\n   272→    if (key.startsWith('ENABLE_') || key.startsWith('ALLOW_') || key.includes('_ENABLE')) {\n   273→      const boolValue = value.toLowerCase();\n   274→      if (!['true', 'false', '1', '0', 'yes', 'no', 'on', 'off'].includes(boolValue)) {\n   275→        return {\n   276→          valid: false,\n   277→          error: `配置项 '${key}' 需要布尔值 (true/false)`\n   278→        };\n   279→      }\n   280→      normalizedValue = boolValue;\n   281→    }\n   282→\n   283→    // Handle enum values\n   284→    if (key === 'LOG_LEVEL') {\n   285→      const validLevels = ['fatal', 'error', 'warn', 'info', 'debug', 'trace', 'silent'];\n   286→      if (!validLevels.includes(value.toLowerCase())) {\n   287→        return {\n   288→          valid: false,\n   289→          error: `LOG_LEVEL 必须是: ${validLevels.join(', ')}`\n   290→        };\n   291→      }\n