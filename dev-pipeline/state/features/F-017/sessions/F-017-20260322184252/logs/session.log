{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_011KymQbvHXfr5KsAfyxZWX8","type":"tool_result","content":"     1→/**\n     2→ * Tests for F-017 Runtime Config Service\n     3→ */\n     4→\n     5→import { describe, test, beforeEach, afterEach } from 'node:test';\n     6→import assert from 'node:assert/strict';\n     7→import { configService } from '../../src/services/config-service.js';\n     8→\n     9→describe('F-017 Config Service', () => {\n    10→  let originalEnv;\n    11→\n    12→  beforeEach(() => {\n    13→    // Save original environment variables\n    14→    originalEnv = { ...process.env };\n    15→\n    16→    // Set up test environment\n    17→    process.env.LOG_LEVEL = 'info';\n    18→    process.env.REQUEST_TIMEOUT_MS = '120000';\n    19→    process.env.AI_CLI_HEARTBEAT_MS = '30000';\n    20→    process.env.MAX_PROMPT_CHARS = '8000';\n    21→    process.env.MAX_HISTORY_TURNS = '10';\n    22→    process.env.SYSTEM_MONITOR_INTERVAL_MS = '60000';\n    23→    process.env.SESSION_TIMEOUT_MS = '1800000';\n    24→    process.env.TASK_DEBOUNCE_MS = '500';\n    25→    process.env.TELEGRAM_BOT_TOKEN = 'test-token-12345';\n    26→    process.env.CODEBUDDY_BIN = 'codebuddy';\n    27→    process.env.WEB_HOST = '0.0.0.0';\n    28→    process.env.WEB_PORT = '8787';\n    29→  });\n    30→\n    31→  afterEach(() => {\n    32→    // Restore original environment\n    33→    process.env = { ...originalEnv };\n    34→  });\n    35→\n    36→  describe('getAllConfig', () => {\n    37→    test('should return all config values with sensitive fields masked', async () => {\n    38→      const result = await configService.getAllConfig();\n    39→\n    40→      assert.ok(result.LOG_LEVEL);\n    41→      assert.ok(result.REQUEST_TIMEOUT_MS);\n    42→      assert.ok(result.AI_CLI_HEARTBEAT_MS);\n    43→\n    44→      // Sensitive fields should be masked\n    45→      assert.equal(result.TELEGRAM_BOT_TOKEN, '***');\n    46→      assert.equal(result.CODEBUDDY_BIN, '***');\n    47→      assert.equal(result.WEB_HOST, '***');\n    48→      assert.equal(result.WEB_PORT, '***');\n    49→    });\n    50→\n    51→    test('should include all config keys from schema', async () => {\n    52→      const result = await configService.getAllConfig();\n    53→\n    54→      // Check that major config categories are present\n    55→      assert.ok('LOG_LEVEL' in result);\n    56→      assert.ok('REQUEST_TIMEOUT_MS' in result);\n    57→      assert.ok('ENABLE_TELEGRAM' in result);\n    58→      assert.ok('CODEBUDDY_BIN' in result);\n    59→      assert.ok('USER_PERMISSIONS' in result);\n    60→    });\n    61→  });\n    62→\n    63→  describe('getConfig', () => {\n    64→    test('should return specific config value', async () => {\n    65→      const result = await configService.getConfig('LOG_LEVEL');\n    66→      assert.equal(result, 'info');\n    67→    });\n    68→\n    69→    test('should mask sensitive config values', async () => {\n    70→      const result = await configService.getConfig('TELEGRAM_BOT_TOKEN');\n    71→      assert.equal(result, '***');\n    72→    });\n    73→\n    74→    test('should return null for unknown config key', async () => {\n    75→      const result = await configService.getConfig('UNKNOWN_KEY');\n    76→      assert.equal(result, null);\n    77→    });\n    78→\n    79→    test('should handle case-insensitive keys', async () => {\n    80→      const result1 = await configService.getConfig('log_level');\n    81→      const result2 = await configService.getConfig('LOG_LEVEL');\n    82→      assert.equal(result1, result2);\n    83→    });\n    84→  });\n    85→\n    86→  describe('setConfig', () => {\n    87→    test('should allow setting safe config values', async () => {\n    88→      const result = await configService.setConfig('LOG_LEVEL', 'debug');\n    89→      assert.ok(result.success);\n    90→      assert.equal(result.newValue, 'debug');\n    91→\n    92→      // Verify the change took effect\n    93→      const currentValue = await configService.getConfig('LOG_LEVEL');\n    94→      assert.equal(currentValue, 'debug');\n    95→    });\n    96→\n    97→    test('should validate config values against schema', async () => {\n    98→      const result = await configService.setConfig('LOG_LEVEL', 'invalid-level');\n    99→      assert.ok(!result.success);\n   100→      assert.ok(result.error.includes('验证失败'));\n   101→    });\n   102→\n   103→    test('should reject setting sensitive config keys', async () => {\n   104→      const result = await configService.setConfig('TELEGRAM_BOT_TOKEN', 'new-token');\n   105→      assert.ok(!result.success);\n   106→      assert.ok(result.error.includes('不允许修改'));\n   107→    });\n   108→\n   109→    test('should reject unknown config keys', async () => {\n   110→      const result = await configService.setConfig('UNKNOWN_KEY', 'value');\n   111→      assert.ok(!result.success);\n   112→      assert.ok(result.error.includes('未知的配置项'));\n   113→    });\n   114→\n   115→    test('should handle numeric conversion for number configs', async () => {\n   116→      const result = await configService.setConfig('REQUEST_TIMEOUT_MS', '150000');\n   117→      assert.ok(result.success);\n   118→      assert.equal(result.newValue, 150000);\n   119→    });\n   120→  });\n   121→\n   122→  describe('resetConfig', () => {\n   123→    test('should reset config to original env value', async () => {\n   124→      // First change the value\n   125→      await configService.setConfig('LOG_LEVEL', 'debug');\n   126→\n   127→      // Then reset it\n   128→      const result = await configService.resetConfig('LOG_LEVEL');\n   129→      assert.ok(result.success);\n   130→      assert.equal(result.newValue, 'info');\n   131→\n   132→      // Verify reset\n   133→      const currentValue = await configService.getConfig('LOG_LEVEL');\n   134→      assert.equal(currentValue, 'info');\n   135→    });\n   136→\n   137→    test('should reject