ions(nlResult));\n   241→  return true;\n   242→}\n   243→\n   244→/**\n   245→ * Synthesize a ParsedCommand from an IntentCandidate and dispatch through the normal chain.\n   246→ *\n   247→ * @param {Object} ctx - Telegraf context\n   248→ * @param {import('./intent-router.js').IntentCandidate} candidate - Intent candidate\n   249→ * @param {number|string|undefined} userId - User ID\n   250→ * @param {string} sessionId - Session ID\n   251→ * @returns {Promise<boolean>} Always true (handled)\n   252→ */\n   253→async function dispatchParsedIntent(ctx, candidate, userId, sessionId) {\n   254→  const entry = getCommand(candidate.command);\n   255→  if (!entry) {\n   256→    // Command not registered — present error\n   257→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: candidate.command })));\n   258→    return true;\n   259→  }\n   260→\n   261→  const { meta, handler } = entry;\n   262→\n   263→  // Permission check\n   264→  const permResult = checkCommandPermission(userId, meta.name);\n   265→  if (!permResult.allowed) {\n   266→    await logAuditEntry({\n   267→      userId,\n   268→      action: meta.name,\n   269→      params: {},\n   270→      result: 'denied',\n   271→      reason: permResult.reason\n   272→    });\n   273→    await ctx.reply(`⛔ ${permResult.reason}`);\n   274→    return true;\n   275→  }\n   276→\n   277→  // Build synthetic parsed command\n   278→  /** @type {import('./parser.js').ParsedCommand} */\n   279→  const syntheticParsed = {\n   280→    command: candidate.command,\n   281→    subcommand: candidate.subcommand,\n   282→    args: candidate.args || [],\n   283→    options: {},\n   284→    raw: ctx.message?.text || ''\n   285→  };\n   286→\n   287→  const validation = validateCommand(syntheticParsed, meta);\n   288→\n   289→  if (!validation.valid) {\n   290→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n   291→    await ctx.reply(errorMsg);\n   292→    return t