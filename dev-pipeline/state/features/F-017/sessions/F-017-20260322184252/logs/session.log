handleSetConfig(args.slice(1).join(' '), reply, userId);\n    55→  } else if (args[0] === 'reset' && args.length >= 2) {\n    56→    await handleResetConfig(args[1], reply, userId);\n    57→  } else {\n    58→    await handleHelp(reply);\n    59→  }\n    60→}\n    61→\n    62→/**\n    63→ * Handle listing all config values.\n    64→ * @param {Function} reply - Reply function\n    65→ */\n    66→async function handleListConfig(reply) {\n    67→  try {\n    68→    const allConfig = await configService.getAllConfig();\n    69→\n    70→    // Format output\n    71→    const lines = ['📋 **当前配置值**', ''];\n    72→\n    73→    // Group configs by category\n    74→    const categories = {\n    75→      '📊 日志设置': ['LOG_LEVEL'],\n    76→      '⏱️ 超时设置': ['REQUEST_TIMEOUT_MS', 'SESSION_TIMEOUT_MS', 'SYSTEM_MONITOR_INTERVAL_MS', 'TASK_DEBOUNCE_MS'],\n    77→      '🤖 AI CLI 设置': ['AI_CLI_HEARTBEAT_MS', 'MAX_PROMPT_CHARS', 'MAX_HISTORY_TURNS'],\n    78→      '🔒 安全设置': ['TELEGRAM_BOT_TOKEN', 'CODEBUDDY_BIN', 'WEB_HOST', 'WEB_PORT']\n    79→    };\n    80→\n    81→    for (const [category, keys] of Object.entries(categories)) {\n    82→      lines.push(`**${category}**`);\n    83→\n    84→      for (const key of keys) {\n    85→        if (allConfig[key] !== undefined) {\n    86→          const value = allConfig[key];\n    87→          lines.push(`  ${key}: \\`${value}\\``);\n    88→        }\n    89→      }\n    90→\n    91→      lines.push('');\n    92→    }\n    93→\n    94→    lines.push('💡 使用 `/config get <KEY>` 查看单个配置值');\n    95→    lines.push('⚙️ 使用 `/config set <KEY>=<VALUE>` 修改安全配置项');\n    96→    lines.push('🔄 使用 `/config reset <KEY>` 重置为原始值');\n    97→\n    98→    await reply(lines.join('\\n'));\n    99→\n   100→  } catch (error) {\n   101→    await reply(`❌ 获取配置失败: ${error.message}`);\n   102→  }\n   103→}\n   104→\n   105→/**\n   106→ * Handle getting specific config value.\n   107→ * @param {string} key - Config key\n   108→ * @param {Function} reply - Reply function\n   109→ */\n   110→async function handleGetConfig(key, reply) {\n   111→  try {\n   112→    const value = await configService.getConfig(key);\n   113→\n   114→    if (value === null) {\n   115→      await reply(`❌ 未知的配置项: \\`${key}\\``);\n   116→      return;\n   117→    }\n   118→\n   119→    await reply(`🔍 **${key}**: \\`${value}\\``);\n   120→\n   121→  } catch (error) {\n   122→    await reply(`❌ 获取配置失败: ${error.message}`);\n   123→  }\n   124→}\n   125→\n   126→/**\n   127→ * Handle setting config value.\n   128→ * @param {string} input - Input string in format \"KEY=VALUE\"\n   129→ * @param {Function} reply - Reply function\n   130→ * @param {string} userId - User ID for audit logging\n   131→ */\n   132→async function handleSetConfig(input, reply, userId) {\n   133→  try {\n   134→    // Parse key=value format\n   135→    const equalsIndex = input.indexOf('=');\n   136→    if (equalsIndex === -1) {\n   137→      await reply('❌ 格式错误。请使用: `/config set KEY=VALUE`');\n   138→      return;\n   139→    }\n   140→\n   141→    const key = input.substring(0, equalsIndex).trim();\n   142→    const value = input.substring(equalsIndex + 1).trim();\n   143→\n   144→    if (!key || !value) {\n   145→      await reply('❌ 配置项和值不能为空。');\n   146→      return;\n   147→    }\n   148→\n   149→    // Check if key is safe to modify\n   150→    const isSafe = await configService.isSafeConfigKey(key);\n   151→    if (!isSafe) {\n   152→      await reply(`❌ 配置项 \\`${key}\\` 不允许在运行时修改。`);\n   153→      return;\n   154→    }\n   155→\n   156→    const result = await configService.setConfig(key, value);\n   157→\n   158→    if (result.success) {\n   159→      const message = [\n   160→        '✅ **配置修改成功**',\n   161→        `**配置项**: \\`${key}\\``,\n   162→        `**新值**: \\`${result.newValue}\\``,\n   163→        `**审计日志**: ${result.auditLog}`,\n   164→        '',\n   165→        '💡 修改已立即生效，无需重启服务。'\n   166→      ].join('\\n');\n   167→\n   168→      await reply(message);\n   169→    } else {\n   170→      await reply(`❌ 配置修改失败: ${result.error}`);\n   171→    }\n   172→\n   173→  } catch (error) {\n   174→    await reply(`❌ 配置修改失败: ${error.message}`);\n   175→  }\n   176→}\n   177→\n   178→/**\n   179→ * Handle resetting config to original value.\n   180→ * @param {string} key - Config key\n   181→ * @param {Function} reply - Reply function\n   182→ * @param {string} userId - User ID for audit logging\n   183→ */\n   184→async function handleResetConfig(key, reply, userId) {\n   185→  try {\n   186→    // Check if key is safe to modify\n   187→    const isSafe = await configService.isSafeConfigKey(key);\n   188→    if (!isSafe) {\n   189→      await reply(`❌ 配置项 \\`${key}\\` 不允许在运行时修改。`);\n   190→      return;\n   191→    }\n   192→\n   193→    const result = await configService.resetConfig(key);\n   194→\n   195→    if (result.success) {\n   196→      const message = [\n   197→        '🔄 **配置重置成功**',\n   198→        `**配置项**: \\`${key}\\``,\n   199→        `**恢复值**: \\`${result.newValue}\\``,\n   200→        `**审计日志**: ${result.auditLog}`\n   201→      ].join('\\n');\n   202→\n   203→      await reply(message);\n   204→    } else {\n   205→      await reply(`❌ 配置重置失败: ${result.error}`);\n   206→    }\n   207→\n   208→  } catch (error) {\n   209→    await reply(`❌ 配置重置失败: ${error.message}`);\n   210→  }\n   211→}\n   212→\n   213→/**\n   214→ * Show command help.\n   215→ * @param {Function} reply - Reply function\n   216→ */\n   217→async function handleHelp(reply) {\n   218→  const helpText = [\n   219→    '📋 **配置管理命令**',\n   220→    '',\n   221→    '**基本用法**:',\n   222→    '• `/config` - 查看所有配置值',\n   223→    '• `/config get <KEY>` - 查看指定配置值',\n   224→    '• `/config set <KEY>=<VALUE>` - 修改配置值',\n   225→    '• `/config reset <KEY>` - 重置为原始值',\n   226→    '',\n   227→    '**安全配置项**（可修改）:',\n   228→    '• `LOG_LEVEL` - 日志级别',\n   229→    '• `REQUEST_TIMEOUT_MS` - 请求超时时间',\n   230→    '• `AI_CLI_HEARTBEAT_MS` - AI CLI 心跳间隔',\n   231→    '• `MAX_PROMPT_CHARS` - 最大提示字符数',\n   232→    '• `MAX_HISTORY_TURNS` - 最大历史轮数',\n   233→    '• `SESSION_TIMEOUT_MS` - 会话超时时间',\n   234→    '• `SYSTEM_MONITOR_INTERVAL_MS` - 系统监控间隔',\n   235→    '• `TASK_DEBOUNCE_MS` - 任务防抖时间',\n   236→    '',\n   237→    '**敏感配置项**（仅查看）:',\n   238→    '• `TELEGRAM_BOT_TOKEN` - Telegram Bot Token',\n   239→    '• `CODEBUDDY_BIN` - CodeBuddy 路径',\n   240→    '• `WEB_HOST`, `WEB_PORT` - Web 服务设置',\n   241→    '',\n   242→    '💡 所有修改立即生效，无需重启服务。'\n   243→  ].join('\\n');\n   244→\n   245→  await reply(helpText);\n   246→}\n   247→\n   248→export default {\n   249→  configMeta,\n   250→  handleConfig\n   251→};\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"e46239e5-8540-42b3-8b45-910022f21a71","uuid":"1423e007-b173-497f-a339-6d56fd428e3b","timestamp":"2026-03-22T10:43:32.810Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/handlers/config.js","content":"/**\n * Config Command Handler\n * F-017: Runtime Config Manager\n *\n * Handles the /config command for viewing and modifying runtime configuration.\n */\n\nimport { configService } from '../../../services/config-service.js';\nimport { isAdmin } from '../../../security/permission-guard.js';\n\n/**\n * Config command metadata.\n */\nexport const configMeta = {\n  name: 'config',\n  aliases: ['cfg', 'settings'],\n  description: '查看和修改运行时配置',\n  usage: '/config [get|set|reset] [key] [value]',\n  examples: [\n    '/config',\n    '/config get LOG_LEVEL',\n    '/config set LOG_LEVEL=debug',\n    '/config reset REQUEST_TIMEOUT_MS'\n  ],\n  subcommands: [\n    { name: 'get', description: '获取指定配置值' },\n    { name: 'set', description: '设置配置值（仅限安全配置项）' },\n    { name: 'reset', description: '重置为原始值' }\n  ],\n  requiresAuth: true,\n  minRole: 'admin',\n  helpText: '/config - 查看和修改运行时配置（需要管理员权限）'\n};\n\n/**\n * Handle /config command.\n * @param {Object} handlerCtx - Handler context\n */\nexport async function handleConfig(handlerCtx) {\n  const { reply, sessionId, args = [], userId } = handlerCtx;\n\n  // Check admin permissions\n  if (!isAdmin(userId)) {\n    await reply('❌ 权限不足。此命令需要管理员权限。');\n    return;\n  }\n\n  // Handle different subcommands\n  if (args.length === 0) {\n    await handleListConfig(reply);\n  } else if (args[0] === 'get' && args.length >= 2) {\n    await handleGetConfig(args[1], reply);\n  } else if (args[0] === 'set' && args.length >= 2) {\n    await handleSetConfig(args.slice(1).join(' '), reply, userId);\n  } else if (args[0] === 'reset' && args.length >= 2) {\n    await handleResetConfig(args[1], reply, userId);\n  } else {\n    await handleHelp(reply);\n  }\n}\n\n/**\n * Handle listing all config values.\n * @param {Function} reply - Reply function\n */\nasync function handleListConfig(reply) {\n  try {\n    const allConfig = await configService.getAllConfig();\n\n    // Format output\n    const lines = ['📋 **当前配置值**', ''];\n\n    // Group configs by category\n    const categories = {\n      '📊 日志设置': ['LOG_LEVEL'],\n      '⏱️ 超时设置': ['REQUEST_TIMEOUT_MS', 'SESSION_TIMEOUT_MS', 'SYSTEM_MONITOR_INTERVAL_MS', 'TASK_DEBOUNCE_MS'],\n      '🤖 AI CLI 设置': ['AI_CLI_HEARTBEAT_MS', 'MAX_PROMPT_CHARS', 'MAX_HISTORY_TURNS'],\n      '🔒 安全设置': ['TELEGRAM_BOT_TOKEN', 'CODEBUDDY_BIN', 'WEB_HOST', 'WEB_PORT']\n    };\n\n    for (const [category, keys] of Object.entries(categories)) {\n      lines.push(`**${category}**`);\n\n      for (const key of keys) {\n        if (allConfig[key] !== undefined) {\n          const value = allConfig[key];\n          lines.push(`  ${key}: \\`${value}\\``);\n        }\n      }\n\n      lines.push('');\n    }\n\n    lines.push('💡 使用 `/config get <KEY>` 查看单个配置值');\n    lines.push('⚙️ 使用 `/config set <KEY>=<VALUE>` 修改安全配置项');\n    lines.push('🔄 使用 `/config reset <KEY>` 重置为原始值');\n\n    await reply(lines.join('\\n'));\n\n  } catch (error) {\n    await reply(`❌ 获取配置失败: ${error.message}`);\n  }\n}\n\n/**\n * Handle getting specific config value.\n * @param {string} key - Config key\n * @param {Function} reply - Reply function\n */\nasync function handleGetConfig(key, reply) {\n  try {\n    const value = await configService.getConfig(key);\n\n    if (value === null) {\n      await reply(`❌ 未知的配置项: \\`${key}\\``);\n      return;\n    }\n\n    await reply(`🔍 **${key}**: \\`${value}\\``);\n\n  } catch (error) {\n    await reply(`❌ 获取配置失败: ${error.message}`);\n  }\n}\n\n/**\n * Handle setting config value.\n * @param {string} input - Input string in format \"KEY=VALUE\"\n * @param {Function} reply - Reply function\n * @param {string} userId - User ID for audit logging\n */\nasync function handleSetConfig(input, reply, userId) {\n  try {\n    // Parse key=value format\n    const equalsIndex = input.indexOf('=');\n    if (equalsIndex === -1) {\n      await reply('❌ 格式错误。请使用: `/config set KEY=VALUE`');\n      return;\n    }\n\n    const key = input.substring(0, equalsIndex).trim();\n    const value = input.substring(equalsIndex + 1).trim();\n\n    if (!key || !value) {\n      await reply('❌ 配置项和值不能为空。');\n      return;\n    }\n\n    // Check if key is safe to modify\n    const isSafe = await configService.isSafeConfigKey(key);\n    if (!isSafe) {\n      await reply(`❌ 配置项 \\`${key}\\` 不允许在运行时修改。`);\n      return;\n    }\n\n    const result = await configService.setConfig(key, value);\n\n    if (result.success) {\n      const message = [\n        '✅ **配置修改成功**',\n        `**配置项**: \\`${key}\\``,\n        `**新值**: \\`${result.newValue}\\``,\n        `**审计日志**: ${result.auditLog}`,\n        '',\n        '💡 修改已立即生效，无需重启服务。'\n      ].join('\\n');\n\n      await reply(message);\n    } else {\n      await reply(`❌ 配置修改失败: ${result.error}`);\n    }\n\n  } catch (error) {\n    await reply(`❌ 配置修改失败: ${error.message}`);\n  }\n}\n\n/**\n * Handle resetting config to original value.\n * @param {string} key - Config key\n * @param {Function} reply - Reply function\n * @param {string} userId - User ID for audit logging\n */\nasync function handleResetConfig(key, reply, userId) {\n  try {\n    // Check if key is safe to modify\n    const isSafe = await configService.isSafeConfigKey(key);\n    if (!isSafe) {\n      await reply(`❌ 配置项 \\`${key}\\` 不允许在运行时修改。`);\n      return;\n    }\n\n    const result = await configService.resetConfig(key);\n\n    if (result.success) {\n      const message = [\n        '🔄 **配置重置成功**',\n        `**配置项**: \\`${key}\\``,\n        `**恢复值**: \\`${result.newValue}\\``,\n        `**审计日志**: ${result.auditLog}`\n      ].join('\\n');\n\n      await reply(message);\n    } else {\n      await reply(`❌ 配置重置失败: ${result.error}`);\n    }\n\n  } catch (error) {\n    await reply(`❌ 配置重置失败: ${error.message}`);\n  }\n}\n\n/**\n * Show command help.\n * @param {Function} reply - Reply function\n */\nasync function handleHelp(reply) {\n  const helpText = [\n    '📋 **配置管理命令**',\n    '',\n    '**基本用法**:',\n    '• `/config` - 查看所有配置值',\n    '• `/config get <KEY>` - 查看指定配置值',\n    '• `/config set <KEY>=<VALUE>` - 修改配置值',\n    '• `/config reset <KEY>` - 重置为原始值',\n    '',\n    '**安全配置项**（可修改）:',\n    '• `LOG_LEVEL` - 日志级别',\n    '• `REQUEST_TIMEOUT_MS` - 请求超时时间',\n    '• `AI_CLI_HEARTBEAT_MS` - AI CLI 心跳间隔',\n    '• `MAX_PROMPT_CHARS` - 最大提示字符数',\n    '• `MAX_HISTORY_TURNS` - 最大历史轮数',\n    '• `SESSION_TIMEOUT_MS` - 会话超时时间',\n    '• `SYSTEM_MONITOR_INTERVAL_MS` - 系统监控间隔',\n    '• `TASK_DEBOUNCE_MS` - 任务防抖时间',\n    '',\n    '**敏感配置项**（仅查看）:',\n    '• `TELEGRAM_BOT_TOKEN` - Telegram Bot Token',\n    '• `CODEBUDDY_BIN` - CodeBuddy 路径',\n    '• `WEB_HOST`, `WEB_PORT` - Web 服务设置',\n    '',\n    '💡 所有修改立即生效，无需重启服务。'\n  ].join('\\n');\n\n  await reply(helpText);\n}\n\nexport default {\n  configMeta,\n  handleConfig\n};","numLines":251,"startLine":1,"totalLines":251}}}
