{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_b2438b091ef84cbd807ebea0","type":"tool_result","content":"     1→/**\n     2→ * Telegram Pusher Service\n     3→ *\n     4→ * F-005: Pipeline Status Aggregation and Log Streaming - US-4: Heartbeat Progress Push, US-5: Error Summary Push\n     5→ *\n     6→ * Manages Telegram message pushing with throttling, chunking, and heartbeat.\n     7→ *\n     8→ * Design Decisions:\n     9→ * - D2: In-memory queue with retry, non-blocking\n    10→ * - D4: Event-driven heartbeat with time throttle\n    11→ * - D7: Retry strategy: max 3, exponential backoff (1s → 2s → 4s)\n    12→ */\n    13→\n    14→import { randomUUID } from 'node:crypto';\n    15→\n    16→import { loadPipelineInfraConfig as _loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n    17→\n    18→const DEFAULT_THROTTLE_INTERVAL = 30 * 1000; // 30 seconds\n    19→const DEFAULT_SEGMENT_INTERVAL = 500; // 500ms between segments\n    20→const DEFAULT_ERROR_LINES_COUNT = 10;\n    21→const MAX_MESSAGE_LENGTH = 4000;\n    22→const MAX_RETRIES = 3;\n    23→\n    24→/**\n    25→ * Create a Telegram pusher instance.\n    26→ * @param {Object} options - Options\n    27→ * @param {Object} options.bot - Telegraf bot instance\n    28→ * @param {number} options.targetChatId - Target chat ID\n    29→ * @param {number} [options.heartbeatInterval] - Heartbeat interval in ms\n    30→ * @param {number} [options.heartbeatFeatureCount] - Features completed before push check\n    31→ * @param {number} [options.errorLinesCount] - Error lines to include\n    32→ * @param {number} [options.throttleInterval] - Throttle interval in ms\n    33→ * @param {number} [options.segmentInterval] - Segment delay in ms\n    34→ * @param {number} [options.maxRetries] - Max retry attempts\n    35→ * @param {Object} [options.heartbeatConfig] - Heartbeat configuration\n    36→ * @returns {Object} Telegram pusher interface\n    37→ */\n    38→// @ts-ignore — options validated at runtime; default {} for destructuring convenience\n    39→export function createTelegramPusher(options = {}) {\n    40→  const bot = options.bot;\n    41→  const targetChatId = options.targetChatId;\n    42→  const heartbeatInterval = options.heartbeatInterval || options.heartbeatConfig?.intervalMs || 30000;\n    43→  const _heartbeatFeatureCount = options.heartbeatFeatureCount || 1;\n    44→  const errorLinesCount = options.errorLinesCount || options.heartbeatConfig?.errorLinesCount || DEFAULT_ERROR_LINES_COUNT;\n    45→  const throttleInterval = options.throttleInterval || DEFAULT_THROTTLE_INTERVAL;\n    46→  const segmentInterval = options.segmentInterval || DEFAULT_SEGMENT_INTERVAL;\n    47→  const maxRetries = options.maxRetries || MAX_RETRIES;\n    48→  const heartbeatConfig = options.heartbeatConfig || {};\n    49→\n    50→  // Internal state\n    51→  const heartbeatTimers = new Map(); // type -> timer\n    52→  const throttleTimestamps = new Map(); // key -> lastExecutionTime\n    53→  const messageQueue = [];\n    54→  let queueProcessing = false;\n    55→\n    56→  /**\n    57→   * Throttle a function call.\n    58→   * @param {string} key - Throttle key\n    59→   * @param {Function} fn - Async function to throttle\n    60→   * @returns {Promise<void>}\n    61→   */\n    62→  async function throttle(key, fn) {\n    63→    const now = Date.now();\n    64→    const lastExecution = throttleTimestamps.get(key) || 0;\n    65→\n    66→    if (now - lastExecution < throttleInterval) {\n    67→      // Throttled, skip execution\n    68→      return;\n    69→    }\n    70→\n    71→    throttleTimestamps.set(key, now);\n    72→    await fn();\n    73→  }\n    74→\n    75→  /**\n    76→   * Split message into chunks respecting Telegram limits.\n    77→   * @param {string} text - Text to split\n    78→   * @returns {Array<string>} Array of chunks\n    79→   */\n    80→  function splitMessage(text) {\n    81→    if (text.length <= MAX_MESSAGE_LENGTH) {\n    82→      return [text];\n    83→    }\n    84→\n    85→    const chunks = [];\n    86→    let remaining = text;\n    87→\n    88→    while (remaining.length > 0) {\n    89→      // Find a good break point\n    90→      let breakPoint = MAX_MESSAGE_LENGTH;\n    91→      if (remaining.length > MAX_MESSAGE_LENGTH) {\n    92→        // Try to break at newline\n    93→        const newlineSearch = remaining.lastIndexOf('\\n', MAX_MESSAGE_LENGTH);\n    94→        if (newlineSearch > MAX_MESSAGE_LENGTH / 2) {\n    95→          breakPoint = newlineSearch + 1;\n    96→        }\n    97→      }\n    98→\n    99→      chunks.push(remaining.slice(0, breakPoint));\n   100→      remaining = remaining.slice(breakPoint);\n   101→    }\n   102→\n   103→    return chunks;\n   104→  }\n   105→\n   106→  /**\n   107→   * Send a message chunked to respect Telegram limits.\n   108→   * @param {number} chatId - Target chat ID\n   109→   * @param {string} text - Message text\n   110→   * @returns {Promise<Array>} Array of message results\n   111→   */\n   112→  async function sendMessageChunked(chatId, text) {\n   113→    const chunks = splitMessage(text);\n   114→    const results = [];\n   115→    const total = chunks.length;\n   116→\n   117→    for (let i = 0; i < chunks.length; i++) {\n   118→      // Add segment numbering for multiple chunks\n   119→      let chunk = chunks[i];\n   120→      if (total > 1) {\n   121→        chunk = `[${i + 1}/${total}] ${chunk}`;\n   122→      }\n   123→\n   124→      try {\n   125→        const result = await bot.telegram.sendMessage(chatId, chunk, {\n   126→          parse_mode: 'Markdown'\n   127→        });\n   128→        results.push(result);\n   129→\n   130→        // Delay between segments\n   131→        if (i < chunks.length - 1 && segmentInterval > 0) {\n   132→          await new Promise(resolve => setTimeout(resolve, segmentInterval));\n   133→        }\n   134→      } catch (error) {\n   135→        // Queue for retry\n   136→        enqueueMessage({\n   137→          id: randomUUID(),\n   138→          chatId,\n   139→          text: chunk,\n   140→          type: 'notification',\n   141→          priority: 10,\n   142→          retryCount: 0\n   143→        });\n   144→        results.push({ error: error.message });\n   145→      }\n   146→    }\n   147→\n   148→    return results;\n   149→  }\n   150→\n   151→  /**\n   152→   * Send a file to chat.\n   153→   * @param {number} chatId - Target chat ID\n   154→   * @param {string} content - File content\n   155→   * @param {string} filename - Filename\n   156→   * @returns {Promise<Object>} Send result\n   157→   */\n   158→  async function sendFile(chatId, content, filename) {\n   159→    try {\n   160→      const { Input } = await import('telegraf');\n   161→      const buffer = Buffer.from(content, 'utf-8');\n   162→      // @ts-ignore — Telegraf Input constructor works at runtime\n   163→      const document = new Input(buffer, filename);\n   164→\n   165→      return await bot.telegram.sendDocument(chatId, document, {\n   166→        filename\n   167→      });\n   168→    } catch (_error) {\n   169→      // Fallback to chunked message if file send fails\n   170→      return sendMessageChunked(chatId, content);\n   171→    }\n   172→  }\n   173→\n   174→  /**\n   175→   * Enqueue a message for async processing.\n   176→   * @param {Object} message - Message object\n   177→   */\n   178→  function enqueueMessage(message) {\n   179→    messageQueue.push(message);\n   180→    processQueue();\n   181→  }\n   182→\n   183→  /**\n   184→   * Process message queue with retry logic.\n   185→   */\n   186→  async function processQueue() {\n   187→    if (queueProcessing) return;\n   188→    queueProcessing = true;\n   189→\n   190→    while (messageQueue.length > 0) {\n   191→      const message = messageQueue.shift();\n   192→\n   193→      try {\n   194→        await bot.telegram.sendMessage(message.chatId, message.text, {\n   195→          parse_mode: 'Markdown'\n   196→        });\n   197→      } catch (_error) {\n   198→        // Retry with exponential backoff\n   199→        if (message.retryCount < maxRetries) {\n   200→          message.retryCount++;\n   201→          const delay = Math.pow(2, message.retryCount - 1) * 1000; // 1s, 2s, 4s\n   202→\n   203→          await new Promise(resolve => setTimeout(resolve, delay));\n   204→          messageQueue.unshift(message); // Re-queue at front\n   205→        }\n   206→        // If max retries exceeded, discard message (non-blocking)\n   207→      }\n   208→    }\n   209→\n   210→    queueProcessing = false;\n   211→  }\n   212→\n   213→  /**\n   214→   * Start heartbeat for a pipeline type.\n   215→   * @param {'feature' | 'bugfix'} type - Pipeline type\n   216→   * @param {Object} aggregator - Status aggregator\n   217→   */\n   218→  function startHeartbeat(type, aggregator) {\n   219→    // Check if heartbeat is enabled\n   220→    if (heartbeatConfig.enabled === false) {\n   221→      return;\n   222→    }\n   223→\n   224→    // Don't start duplicate timers\n   225→    if (heartbeatTimers.has(type)) {\n   226→      return;\n   227→    }\n   228→\n   229→    const timer = setInterval(async () => {\n   230→      await throttle(`heartbeat-${type}`, async () => {\n   231→        try {\n   232→          const status = await aggregator.aggregateStatus(type);\n   233→          const formatted = aggregator.formatStatusForTelegram(status);\n   234→          await sendMessageChunked(targetChatId, formatted);\n   235→        } catch (error) {\n   236→          // Log error but don't block\n   237→          console.error(`Heartbeat error for ${type}:`, error.message);\n   238→        }\n   239→      });\n   240→    }, heartbeatInterval);\n   241→\n   242→    heartbeatTimers.set(type, timer);\n   243→  }\n   244→\n   245→  /**\n   246→   * Stop heartbeat for a pipeline type.\n   247→   * @param {'feature' | 'bugfix'} type - Pipeline type\n   248→   */\n   249→  function stopHeartbeat(type) {\n   250→    const timer = heartbeatTimers.get(type);\n   251→    if (timer) {\n   252→      clearInterval(timer);\n   253→      heartbeatTimers.delete(type);\n   254→    }\n   255→\n   256→    // Process remaining queue\n   257→    processQueue();\n   258→  }\n   259→\n   260→  /**\n   261→   * Handle feature completed event.\n   262→   * @param {'feature' | 'bugfix'} type - Pipeline type\n   263→   * @param {string} featureId - Feature ID\n   264→   * @param {Object} aggregator - Status aggregator\n   265→   */\n   266→  async function onFeatureCompleted(type, featureId, aggregator) {\n   267→    await throttle(`feature-complete-${type}`, async () => {\n   268→      try {\n   269→        const status = await aggregator.aggregateStatus(type);\n   270→        const message = `✅ Feature 完成: ${featureId}\\n\\n` +\n   271→          `📊 进度: ${status.progress.completed}/${status.progress.total} (${status.progress.successRate}%)`;\n   272→        await sendMessageChunked(targetChatId, message);\n   273→      } catch (error) {\n   274→        console.error(`Feature completed notification error:`, error.message);\n   275→      }\n   276→    });\n   277→  }\n   278→\n   279→  /**\n   280→   * Push error summary notification.\n   281→   * @param {'feature' | 'bugfix'} type - Pipeline type\n   282→   * @param {string} featureId - Feature ID\n   283→   * @param {Object} error - Error object\n   284→   * @returns {Promise<Object>} Push result\n   285→   */\n   286→  async function pushErrorSummary(type, featureId, error) {\n   287→    // Check silent mode\n   288→    if (heartbeatConfig.silentMode && error.isExpected) {\n   289→      return { ok: true, skipped: true };\n   290→    }\n   291→\n   292→    const lines = [];\n   293→    lines.push(`❌ **执行失败: ${featureId}**`);\n   294→    lines.push(`类型: ${error.type || 'unknown'}`);\n   295→    lines.push('');\n   296→\n   297→    if (error.message) {\n   298→      lines.push(`**错误信息:**`);\n   299→      lines.push(error.message);\n   300→      lines.push('');\n   301→    }\n   302→\n   303→    // Include execution time/duration\n   304→    if (error.duration) {\n   305→      const mins = Math.floor(error.duration / 60);\n   306→      const secs = error.duration % 60;\n   307→      lines.push(`⏱️ 执行时间: ${mins}m ${secs}s`);\n   308→      lines.push('');\n   309→    }\n   310→\n   311→    // Include error log lines\n   312→    if (error.logLines && error.logLines.length > 0) {\n   313→      lines.push(`**日志片段:** (最后 ${Math.min(errorLinesCount, error.logLines.length)} 行)`);\n   314→      const errorLines = error.logLines.slice(-errorLinesCount);\n   315→      lines.push('```');\n   316→      lines.push(errorLines.join('\\n'));\n   317→      lines.push('```');\n   318→    }\n   319→\n   320→    const message = lines.join('\\n');\n   321→\n   322→    try {\n   323→      const result = await sendMessageChunked(targetChatId, message);\n   324→      return {\n   325→        ok: true,\n   326→        messageId: result[0]?.message_id\n   327→      };\n   328→    } catch (err) {\n   329→      return {\n   330→        ok: false,\n   331→        errorCode: 'SEND_FAILED',\n   332→        message: err.message\n   333→      };\n   334→    }\n   335→  }\n   336→\n   337→  /**\n   338→   * Push startup notification.\n   339→   * @param {'feature' | 'bugfix'} type - Pipeline type\n   340→   * @param {Object} runInfo - Run info object\n   341→   * @returns {Promise<Object>} Push result\n   342→   */\n   343→  async function pushStartupNotification(type, runInfo) {\n   344→    const lines = [];\n   345→    lines.push(`🚀 **Pipeline 启动** (${type})`);\n   346→    lines.push(`Run ID: ${runInfo.runId}`);\n   347→    lines.push(`开始时间: ${runInfo.startedAt}`);\n   348→    lines.push('');\n   349→\n   350→    if (runInfo.targets && runInfo.targets.length > 0) {\n   351→      lines.push(`**目标列表:** (${runInfo.targets.length} 个)`);\n   352→      const displayTargets = runInfo.targets.slice(0, 10);\n   353→      for (const target of displayTargets) {\n   354→        lines.push(`  • ${target}`);\n   355→      }\n   356→      if (runInfo.targets.length > 10) {\n   357→        lines.push(`  ... 及其他 ${runInfo.targets.length - 10} 个`);\n   358→      }\n   359→    }\n   360→\n   361→    const message = lines.join('\\n');\n   362→\n   363→    try {\n   364→      const result = await sendMessageChunked(targetChatId, message);\n   365→      return {\n   366→        ok: true,\n   367→        messageId: result[0]?.message_id\n   368→      };\n   369→    } catch (err) {\n   370→      return {\n   371→        ok: false,\n   372→        errorCode: 'SEND_FAILED',\n   373→        message: err.message\n   374→      };\n   375→    }\n   376→  }\n   377→\n   378→  return {\n   379→    throttle,\n   380→    sendMessageChunked,\n   381→    sendFile,\n   382→    enqueueMessage,\n   383→    processQueue,\n   384→    startHeartbeat,\n   385→    stopHeartbeat,\n   386→    onFeatureCompleted,\n   387→    pushErrorSummary,\n   388→    pushStartupNotification\n   389→  };\n   390→}\n   391→\n   392→export default createTelegramPusher;\n   393→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"b0c21b4a-aab1-46e1-a0e3-84d1bc40e034","uuid":"da3a573d-782b-43e4-826a-506bbd548bb0","timestamp":"2026-03-22T01:38:25.713Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/wylonyu/selfProjects/PrizmClaw/src/services/telegram-pusher.js","content":"/**\n * Telegram Pusher Service\n *\n * F-005: Pipeline Status Aggregation and Log Streaming - US-4: Heartbeat Progress Push, US-5: Error Summary Push\n *\n * Manages Telegram message pushing with throttling, chunking, and heartbeat.\n *\n * Design Decisions:\n * - D2: In-memory queue with retry, non-blocking\n * - D4: Event-driven heartbeat with time throttle\n * - D7: Retry strategy: max 3, exponential backoff (1s → 2s → 4s)\n */\n\nimport { randomUUID } from 'node:crypto';\n\nimport { loadPipelineInfraConfig as _loadPipelineInfraConfig } from '../pipeline-infra/config-loader.js';\n\nconst DEFAULT_THROTTLE_INTERVAL = 30 * 1000; // 30 seconds\nconst DEFAULT_SEGMENT_INTERVAL = 500; // 500ms between segments\nconst DEFAULT_ERROR_LINES_COUNT = 10;\nconst MAX_MESSAGE_LENGTH = 4000;\nconst MAX_RETRIES = 3;\n\n/**\n * Create a Telegram pusher instance.\n * @param {Object} options - Options\n * @param {Object} options.bot - Telegraf bot instance\n * @param {number} options.targetChatId - Target chat ID\n * @param {number} [options.heartbeatInterval] - Heartbeat interval in ms\n * @param {number} [options.heartbeatFeatureCount] - Features completed before push check\n * @param {number} [options.errorLinesCount] - Error lines to include\n * @param {number} [options.throttleInterval] - Throttle interval in ms\n * @param {number} [options.segmentInterval] - Segment delay in ms\n * @param {number} [options.maxRetries] - Max retry attempts\n * @param {Object} [options.heartbeatConfig] - Heartbeat configuration\n * @returns {Object} Telegram pusher interface\n */\n// @ts-ignore — options validated at runtime; default {} for destructuring convenience\nexport function createTelegramPusher(options = {}) {\n  const bot = options.bot;\n  const targetChatId = options.targetChatId;\n  const heartbeatInterval = options.heartbeatInterval || options.heartbeatConfig?.intervalMs || 30000;\n  const _heartbeatFeatureCount = options.heartbeatFeatureCount || 1;\n  const errorLinesCount = options.errorLinesCount || options.heartbeatConfig?.errorLinesCount || DEFAULT_ERROR_LINES_COUNT;\n  const throttleInterval = options.throttleInterval || DEFAULT_THROTTLE_INTERVAL;\n  const segmentInterval = options.segmentInterval || DEFAULT_SEGMENT_INTERVAL;\n  const maxRetries = options.maxRetries || MAX_RETRIES;\n  const heartbeatConfig = options.heartbeatConfig || {};\n\n  // Internal state\n  const heartbeatTimers = new Map(); // type -> timer\n  const throttleTimestamps = new Map(); // key -> lastExecutionTime\n  const messageQueue = [];\n  let queueProcessing = false;\n\n  /**\n   * Throttle a function call.\n   * @param {string} key - Throttle key\n   * @param {Function} fn - Async function to throttle\n   * @returns {Promise<void>}\n   */\n  async function throttle(key, fn) {\n    const now = Date.now();\n    const lastExecution = throttleTimestamps.get(key) || 0;\n\n    if (now - lastExecution < throttleInterval) {\n      // Throttled, skip execution\n      return;\n    }\n\n    throttleTimestamps.set(key, now);\n    await fn();\n  }\n\n  /**\n   * Split message into chunks respecting Telegram limits.\n   * @param {string} text - Text to split\n   * @returns {Array<string>} Array of chunks\n   */\n  function splitMessage(text) {\n    if (text.length <= MAX_MESSAGE_LENGTH) {\n      return [text];\n    }\n\n    const chunks = [];\n    let remaining = text;\n\n    while (remaining.length > 0) {\n      // Find a good break point\n      let breakPoint = MAX_MESSAGE_LENGTH;\n      if (remaining.length > MAX_MESSAGE_LENGTH) {\n        // Try to break at newline\n        const newlineSearch = remaining.lastIndexOf('\\n', MAX_MESSAGE_LENGTH);\n        if (newlineSearch > MAX_MESSAGE_LENGTH / 2) {\n          breakPoint = newlineSearch + 1;\n        }\n      }\n\n      chunks.push(remaining.slice(0, breakPoint));\n      remaining = remaining.slice(breakPoint);\n    }\n\n    return chunks;\n  }\n\n  /**\n   * Send a message chunked to respect Telegram limits.\n   * @param {number} chatId - Target chat ID\n   * @param {string} text - Message text\n   * @returns {Promise<Array>} Array of message results\n   */\n  async function sendMessageChunked(chatId, text) {\n    const chunks = splitMessage(text);\n    const results = [];\n    const total = chunks.length;\n\n    for (let i = 0; i < chunks.length; i++) {\n      // Add segment numbering for multiple chunks\n      let chunk = chunks[i];\n      if (total > 1) {\n        chunk = `[${i + 1}/${total}] ${chunk}`;\n      }\n\n      try {\n        const result = await bot.telegram.sendMessage(chatId, chunk, {\n          parse_mode: 'Markdown'\n        });\n        results.push(result);\n\n        // Delay between segments\n        if (i < chunks.length - 1 && segmentInterval > 0) {\n          await new Promise(resolve => setTimeout(resolve, segmentInterval));\n        }\n      } catch (error) {\n        // Queue for retry\n        enqueueMessage({\n          id: randomUUID(),\n          chatId,\n          text: chunk,\n          type: 'notification',\n          priority: 10,\n          retryCount: 0\n        });\n        results.push({ error: error.message });\n      }\n    }\n\n    return results;\n  }\n\n  /**\n   * Send a file to chat.\n   * @param {number} chatId - Target chat ID\n   * @param {string} content - File content\n   * @param {string} filename - Filename\n   * @returns {Promise<Object>} Send result\n   */\n  async function sendFile(chatId, content, filename) {\n    try {\n      const { Input } = await import('telegraf');\n      const buffer = Buffer.from(content, 'utf-8');\n      // @ts-ignore — Telegraf Input constructor works at runtime\n      const document = new Input(buffer, filename);\n\n      return await bot.telegram.sendDocument(chatId, document, {\n        filename\n      });\n    } catch (_error) {\n      // Fallback to chunked message if file send fails\n      return sendMessageChunked(chatId, content);\n    }\n  }\n\n  /**\n   * Enqueue a message for async processing.\n   * @param {Object} message - Message object\n   */\n  function enqueueMessage(message) {\n    messageQueue.push(message);\n    processQueue();\n  }\n\n  /**\n   * Process message queue with retry logic.\n   */\n  async function processQueue() {\n    if (queueProcessing) return;\n    queueProcessing = true;\n\n    while (messageQueue.length > 0) {\n      const message = messageQueue.shift();\n\n      try {\n        await bot.telegram.sendMessage(message.chatId, message.text, {\n          parse_mode: 'Markdown'\n        });\n      } catch (_error) {\n        // Retry with exponential backoff\n        if (message.retryCount < maxRetries) {\n          message.retryCount++;\n          const delay = Math.pow(2, message.retryCount - 1) * 1000; // 1s, 2s, 4s\n\n          await new Promise(resolve => setTimeout(resolve, delay));\n          messageQueue.unshift(message); // Re-queue at front\n        }\n        // If max retries exceeded, discard message (non-blocking)\n      }\n    }\n\n    queueProcessing = false;\n  }\n\n  /**\n   * Start heartbeat for a pipeline type.\n   * @param {'feature' | 'bugfix'} type - Pipeline type\n   * @param {Object} aggregator - Status aggregator\n   */\n  function startHeartbeat(type, aggregator) {\n    // Check if heartbeat is enabled\n    if (heartbeatConfig.enabled === false) {\n      return;\n    }\n\n    // Don't start duplicate timers\n    if (heartbeatTimers.has(type)) {\n      return;\n    }\n\n    const timer = setInterval(async () => {\n      await throttle(`heartbeat-${type}`, async () => {\n        try {\n          const status = await aggregator.aggregateStatus(type);\n          const formatted = aggregator.formatStatusForTelegram(status);\n          await sendMessageChunked(targetChatId, formatted);\n        } catch (error) {\n          // Log error but don't block\n          console.error(`Heartbeat error for ${type}:`, error.message);\n        }\n      });\n    }, heartbeatInterval);\n\n    heartbeatTimers.set(type, timer);\n  }\n\n  /**\n   * Stop heartbeat for a pipeline type.\n   * @param {'feature' | 'bugfix'} type - Pipeline type\n   */\n  function stopHeartbeat(type) {\n    const timer = heartbeatTimers.get(type);\n    if (timer) {\n      clearInterval(timer);\n      heartbeatTimers.delete(type);\n    }\n\n    // Process remaining queue\n    processQueue();\n  }\n\n  /**\n   * Handle feature completed event.\n   * @param {'feature' | 'bugfix'} type - Pipeline type\n   * @param {string} featureId - Feature ID\n   * @param {Object} aggregator - Status aggregator\n   */\n  async function onFeatureCompleted(type, featureId, aggregator) {\n    await throttle(`feature-complete-${type}`, async () => {\n      try {\n        const status = await aggregator.aggregateStatus(type);\n        const message = `✅ Feature 完成: ${featureId}\\n\\n` +\n          `📊 进度: ${status.progress.completed}/${status.progress.total} (${status.progress.successRate}%)`;\n        await sendMessageChunked(targetChatId, message);\n      } catch (error) {\n        console.error(`Feature completed notification error:`, error.message);\n      }\n    });\n  }\n\n  /**\n   * Push error summary notification.\n   * @param {'feature' | 'bugfix'} type - Pipeline type\n   * @param {string} featureId - Feature ID\n   * @param {Object} error - Error object\n   * @returns {Promise<Object>} Push result\n   */\n  async function pushErrorSummary(type, featureId, error) {\n    // Check silent mode\n    if (heartbeatConfig.silentMode && error.isExpected) {\n      return { ok: true, skipped: true };\n    }\n\n    const lines = [];\n    lines.push(`❌ **执行失败: ${featureId}**`);\n    lines.push(`类型: ${error.type || 'unknown'}`);\n    lines.push('');\n\n    if (error.message) {\n      lines.push(`**错误信息:**`);\n      lines.push(error.message);\n      lines.push('');\n    }\n\n    // Include execution time/duration\n    if (error.duration) {\n      const mins = Math.floor(error.duration / 60);\n      const secs = error.duration % 60;\n      lines.push(`⏱️ 执行时间: ${mins}m ${secs}s`);\n      lines.push('');\n    }\n\n    // Include error log lines\n    if (error.logLines && error.logLines.length > 0) {\n      lines.push(`**日志片段:** (最后 ${Math.min(errorLinesCount, error.logLines.length)} 行)`);\n      const errorLines = error.logLines.slice(-errorLinesCount);\n      lines.push('```');\n      lines.push(errorLines.join('\\n'));\n      lines.push('```');\n    }\n\n    const message = lines.join('\\n');\n\n    try {\n      const result = await sendMessageChunked(targetChatId, message);\n      return {\n        ok: true,\n        messageId: result[0]?.message_id\n      };\n    } catch (err) {\n      return {\n        ok: false,\n        errorCode: 'SEND_FAILED',\n        message: err.message\n      };\n    }\n  }\n\n  /**\n   * Push startup notification.\n   * @param {'feature' | 'bugfix'} type - Pipeline type\n   * @param {Object} runInfo - Run info object\n   * @returns {Promise<Object>} Push result\n   */\n  async function pushStartupNotification(type, runInfo) {\n    const lines = [];\n    lines.push(`🚀 **Pipeline 启动** (${type})`);\n    lines.push(`Run ID: ${runInfo.runId}`);\n    lines.push(`开始时间: ${runInfo.startedAt}`);\n    lines.push('');\n\n    if (runInfo.targets && runInfo.targets.length > 0) {\n      lines.push(`**目标列表:** (${runInfo.targets.length} 个)`);\n      const displayTargets = runInfo.targets.slice(0, 10);\n      for (const target of displayTargets) {\n        lines.push(`  • ${target}`);\n      }\n      if (runInfo.targets.length > 10) {\n        lines.push(`  ... 及其他 ${runInfo.targets.length - 10} 个`);\n      }\n    }\n\n    const message = lines.join('\\n');\n\n    try {\n      const result = await sendMessageChunked(targetChatId, message);\n      return {\n        ok: true,\n        messageId: result[0]?.message_id\n      };\n    } catch (err) {\n      return {\n        ok: false,\n        errorCode: 'SEND_FAILED',\n        message: err.message\n      };\n    }\n  }\n\n  return {\n    throttle,\n    sendMessageChunked,\n    sendFile,\n    enqueueMessage,\n    processQueue,\n    startHeartbeat,\n    stopHeartbeat,\n    onFeatureCompleted,\n    pushErrorSummary,\n    pushStartupNotification\n  };\n}\n\nexport default createTelegramPusher;\n","numLines":393,"startLine":1,"totalLines":393}}}
