{"type":"system","subtype":"task_progress","task_id":"a4a70e333490a8089","tool_use_id":"call_0a68ab29f41c4d6b90dd4982","description":"Writing tests/services/session-bind.test.js","usage":{"total_tokens":45899,"tool_uses":13,"duration_ms":77781},"last_tool_name":"Write","uuid":"653753ee-eafc-428f-977c-bdd1647272d1","session_id":"94710a11-4ada-4b2b-b382-cda110153e6d"}
{"type":"assistant","message":{"id":"msg_1774144738066_dvvb5uppkq","type":"message","role":"assistant","model":"glm-4.7","content":[{"type":"tool_use","id":"call_124b201cca884be88366c44e","name":"Write","input":{"file_path":"/Users/wylonyu/selfProjects/PrizmClaw/tests/services/session-bind.test.js","content":"/**\n * Session Bind Service Unit Tests\n * Tests for src/services/session-bind.js\n *\n * F-018: Web-Telegram Bidirectional Sync\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\n\nimport { createSessionBindService } from '../../src/services/session-bind.js';\n\n/**\n * Helper to create temp directory for test state\n */\nfunction createTempDir() {\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'session-bind-test-'));\n  const dataDir = path.join(tempDir, 'data');\n  fs.mkdirSync(dataDir, { recursive: true });\n  return {\n    tempDir,\n    dataDir,\n    bindingsPath: path.join(dataDir, 'session-bindings.json'),\n    cleanup: () => {\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    }\n  };\n}\n\ntest('session-bind: bindSession creates mapping', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-123', '456');\n\n    const boundChatId = service.getBoundChatId('web-session-123');\n    assert.strictEqual(boundChatId, '456');\n\n    const boundSessions = service.getBoundWebSessions('456');\n    assert.deepEqual(boundSessions, ['web-session-123']);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: bindSession persists to disk', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-123', '456');\n\n    // Verify persistence to disk\n    const raw = fs.readFileSync(bindingsPath, 'utf-8');\n    const data = JSON.parse(raw);\n\n    assert.strictEqual(data.bindings['web-session-123'], '456');\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: bindSession loads from disk on create', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    // Create initial binding\n    const initialData = {\n      bindings: {\n        'web-session-123': '456'\n      }\n    };\n    fs.writeFileSync(bindingsPath, JSON.stringify(initialData));\n\n    // Create new service instance - should load from disk\n    const service = createSessionBindService({ bindingsPath });\n\n    const boundChatId = service.getBoundChatId('web-session-123');\n    assert.strictEqual(boundChatId, '456');\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: unbindSession removes mapping', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-123', '456');\n    service.unbindSession('web-session-123');\n\n    const boundChatId = service.getBoundChatId('web-session-123');\n    assert.strictEqual(boundChatId, null);\n\n    const boundSessions = service.getBoundWebSessions('456');\n    assert.deepEqual(boundSessions, []);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: unbindSession persists to disk', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-123', '456');\n    service.unbindSession('web-session-123');\n\n    // Verify persistence to disk\n    const raw = fs.readFileSync(bindingsPath, 'utf-8');\n    const data = JSON.parse(raw);\n\n    assert.strictEqual(data.bindings['web-session-123'], undefined);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: getBoundChatId returns null for unbound session', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    const boundChatId = service.getBoundChatId('nonexistent-session');\n    assert.strictEqual(boundChatId, null);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: getBoundWebSessions returns empty array for unbound chat', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    const boundSessions = service.getBoundWebSessions('999');\n    assert.deepEqual(boundSessions, []);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: multiple web sessions can bind to same telegram chat', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-1', '456');\n    service.bindSession('web-session-2', '456');\n\n    const boundSessions = service.getBoundWebSessions('456');\n    assert.ok(boundSessions.includes('web-session-1'));\n    assert.ok(boundSessions.includes('web-session-2'));\n    assert.strictEqual(boundSessions.length, 2);\n\n    assert.strictEqual(service.getBoundChatId('web-session-1'), '456');\n    assert.strictEqual(service.getBoundChatId('web-session-2'), '456');\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: web session can rebind to different telegram chat', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-123', '456');\n    service.bindSession('web-session-123', '789');\n\n    assert.strictEqual(service.getBoundChatId('web-session-123'), '789');\n    assert.deepEqual(service.getBoundWebSessions('456'), []);\n    assert.deepEqual(service.getBoundWebSessions('789'), ['web-session-123']);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: getAllBindings returns all bindings', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    service.bindSession('web-session-1', '456');\n    service.bindSession('web-session-2', '456');\n    service.bindSession('web-session-3', '789');\n\n    const allBindings = service.getAllBindings();\n\n    assert.ok(allBindings['web-session-1'] === '456');\n    assert.ok(allBindings['web-session-2'] === '456');\n    assert.ok(allBindings['web-session-3'] === '789');\n    assert.strictEqual(Object.keys(allBindings).length, 3);\n  } finally {\n    cleanup();\n  }\n});\n\ntest('session-bind: bindSession validates inputs', () => {\n  const { dataDir, bindingsPath, cleanup } = createTempDir();\n  try {\n    const service = createSessionBindService({ bindingsPath });\n\n    assert.throws(\n      () => service.bindSession('', '456'),\n      { message: /webSessionId 不能为空/ }\n    );\n\n    assert.throws(\n      () => service.bindSession('web-session-123', ''),\n      { message: /telegramChatId 不能为空/ }\n    );\n  } finally {\n    cleanup();\n  }\n});\n"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":45899,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0},"context_management":null},"parent_tool_use_id":"call_0a68ab29f41c4d6b90dd4982","session_id":"94710a11-4ada-4b2b-b382-cda110153e6d","uuid":"49117d65-a10a-4651-9221-f5ee657a2b3d"}
