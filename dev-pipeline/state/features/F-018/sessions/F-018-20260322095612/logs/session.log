{"type":"system","subtype":"task_progress","task_id":"a4a70e333490a8089","tool_use_id":"call_0a68ab29f41c4d6b90dd4982","description":"Writing src/services/session-bind.js","usage":{"total_tokens":47888,"tool_uses":14,"duration_ms":102647},"last_tool_name":"Write","uuid":"0f0c52ca-f383-4446-9cf1-49c65cfea3d2","session_id":"94710a11-4ada-4b2b-b382-cda110153e6d"}
{"type":"assistant","message":{"id":"msg_1774144768168_y7c4eh86ms9","type":"message","role":"assistant","model":"glm-4.7","content":[{"type":"tool_use","id":"call_be3456dc17254b4faf8de3c1","name":"Write","input":{"file_path":"/Users/wylonyu/selfProjects/PrizmClaw/src/services/session-bind.js","content":"/**\n * Session Bind Service\n *\n * Manages mapping between Web session IDs and Telegram chat IDs.\n * Provides bidirectional lookup and persistence to disk.\n *\n * F-018: Web-Telegram Bidirectional Sync\n */\n\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport { logger } from '../utils/logger.js';\n\n/**\n * @typedef {Object} BindingsData\n * @property {Object.<string, string>} bindings - webSessionId -> telegramChatId mapping\n */\n\n/**\n * Creates a session bind service instance\n * @param {Object} options\n * @param {string} options.bindingsPath - Path to JSON file for persistence\n * @returns {SessionBindService}\n */\nexport function createSessionBindService({ bindingsPath }) {\n  const dir = path.dirname(bindingsPath);\n\n  // Ensure data directory exists\n  if (!fs.existsSync(dir)) {\n    fs.mkdirSync(dir, { recursive: true });\n  }\n\n  /** @type {Map<string, string>} */\n  const bindings = new Map();\n\n  // Load existing bindings from disk\n  function load() {\n    if (fs.existsSync(bindingsPath)) {\n      try {\n        const raw = fs.readFileSync(bindingsPath, 'utf-8');\n        const data = JSON.parse(raw);\n\n        if (data.bindings && typeof data.bindings === 'object') {\n          for (const [webSessionId, telegramChatId] of Object.entries(data.bindings)) {\n            bindings.set(webSessionId, String(telegramChatId));\n          }\n          logger.info({ bindingsPath, count: bindings.size }, 'Loaded session bindings from disk');\n        }\n      } catch (err) {\n        logger.error({ bindingsPath, err: err.message }, 'Failed to load session bindings');\n      }\n    } else {\n      logger.info({ bindingsPath }, 'No existing session bindings file, starting fresh');\n    }\n  }\n\n  /**\n   * Persist bindings to disk\n   */\n  function persist() {\n    /** @type {Record<string, string>} */\n    const data = { bindings: {} };\n\n    for (const [webSessionId, telegramChatId] of bindings.entries()) {\n      data.bindings[webSessionId] = telegramChatId;\n    }\n\n    try {\n      fs.writeFileSync(bindingsPath, JSON.stringify(data, null, 2), 'utf-8');\n    } catch (err) {\n      logger.error({ bindingsPath, err: err.message }, 'Failed to persist session bindings');\n    }\n  }\n\n  // Load initial state\n  load();\n\n  return {\n    /**\n     * Bind a Web session to a Telegram chat\n     * @param {string} webSessionId - Web session ID\n     * @param {string} telegramChatId - Telegram chat ID\n     */\n    bindSession(webSessionId, telegramChatId) {\n      const normalizedWebSessionId = String(webSessionId ?? '').trim();\n      const normalizedTelegramChatId = String(telegramChatId ?? '').trim();\n\n      if (!normalizedWebSessionId) {\n        throw new Error('webSessionId 不能为空。');\n      }\n\n      if (!normalizedTelegramChatId) {\n        throw new Error('telegramChatId 不能为空。');\n      }\n\n      bindings.set(normalizedWebSessionId, normalizedTelegramChatId);\n      persist();\n\n      logger.info({ webSessionId: normalizedWebSessionId, telegramChatId: normalizedTelegramChatId }, 'Session bound');\n    },\n\n    /**\n     * Unbind a Web session from its Telegram chat\n     * @param {string} webSessionId - Web session ID to unbind\n     */\n    unbindSession(webSessionId) {\n      const normalizedWebSessionId = String(webSessionId ?? '').trim();\n\n      if (normalizedWebSessionId && bindings.has(normalizedWebSessionId)) {\n        bindings.delete(normalizedWebSessionId);\n        persist();\n        logger.info({ webSessionId: normalizedWebSessionId }, 'Session unbound');\n      }\n    },\n\n    /**\n     * Get the bound Telegram chat ID for a Web session\n     * @param {string} webSessionId - Web session ID\n     * @returns {string|null} Telegram chat ID or null if not bound\n     */\n    getBoundChatId(webSessionId) {\n      const normalizedWebSessionId = String(webSessionId ?? '').trim();\n      return bindings.get(normalizedWebSessionId) ?? null;\n    },\n\n    /**\n     * Get all Web sessions bound to a Telegram chat\n     * @param {string} telegramChatId - Telegram chat ID\n     * @returns {string[]} Array of Web session IDs\n     */\n    getBoundWebSessions(telegramChatId) {\n      const normalizedTelegramChatId = String(telegramChatId ?? '').trim();\n      const result = [];\n\n      for (const [webSessionId, boundTelegramChatId] of bindings.entries()) {\n        if (boundTelegramChatId === normalizedTelegramChatId) {\n          result.push(webSessionId);\n        }\n      }\n\n      return result;\n    },\n\n    /**\n     * Get all bindings\n     * @returns {Object.<string, string>} webSessionId -> telegramChatId mapping\n     */\n    getAllBindings() {\n      return Object.fromEntries(bindings.entries());\n    }\n  };\n}\n"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":47888,"cache_creation_input_tokens":0,"cache_read_input_tokens":0,"output_tokens":0},"context_management":null},"parent_tool_use_id":"call_0a68ab29f41c4d6b90dd4982","session_id":"94710a11-4ada-4b2b-b382-cda110153e6d","uuid":"19f7f81d-6320-4bec-a1c0-389a5bb7189a"}
