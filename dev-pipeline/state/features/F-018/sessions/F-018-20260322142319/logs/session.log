{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_011sDi4VzDQAkq22wTXmUkL6","type":"tool_result","content":"     1→class RealtimeHub {\n     2→  #listenersBySession = new Map();\n     3→\n     4→  subscribe(sessionKey, listener) {\n     5→    const listeners = this.#listenersBySession.get(sessionKey) ?? new Set();\n     6→    listeners.add(listener);\n     7→    this.#listenersBySession.set(sessionKey, listeners);\n     8→\n     9→    return () => {\n    10→      const current = this.#listenersBySession.get(sessionKey);\n    11→      if (!current) {\n    12→        return;\n    13→      }\n    14→\n    15→      current.delete(listener);\n    16→      if (current.size === 0) {\n    17→        this.#listenersBySession.delete(sessionKey);\n    18→      }\n    19→    };\n    20→  }\n    21→\n    22→  publish(sessionKey, event) {\n    23→    const listeners = this.#listenersBySession.get(sessionKey);\n    24→    if (!listeners || listeners.size === 0) {\n    25→      return;\n    26→    }\n    27→\n    28→    for (const listener of listeners) {\n    29→      listener(event);\n    30→    }\n    31→  }\n    32→}\n    33→\n    34→export const realtimeHub = new RealtimeHub();\n    35→"}]},"parent_tool_use_id":null,"session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"3ddd41ad-0bc2-4468-bcad-826241c55c22","timestamp":"2026-03-22T06:23:56.364Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/realtime-hub.js","content":"class RealtimeHub {\n  #listenersBySession = new Map();\n\n  subscribe(sessionKey, listener) {\n    const listeners = this.#listenersBySession.get(sessionKey) ?? new Set();\n    listeners.add(listener);\n    this.#listenersBySession.set(sessionKey, listeners);\n\n    return () => {\n      const current = this.#listenersBySession.get(sessionKey);\n      if (!current) {\n        return;\n      }\n\n      current.delete(listener);\n      if (current.size === 0) {\n        this.#listenersBySession.delete(sessionKey);\n      }\n    };\n  }\n\n  publish(sessionKey, event) {\n    const listeners = this.#listenersBySession.get(sessionKey);\n    if (!listeners || listeners.size === 0) {\n      return;\n    }\n\n    for (const listener of listeners) {\n      listener(event);\n    }\n  }\n}\n\nexport const realtimeHub = new RealtimeHub();\n","numLines":35,"startLine":1,"totalLines":35}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_014akj6Zs4x1d7NYd9Ewq84k","type":"tool_result","content":"     1→/**\n     2→ * F-011: AI CLI Service\n     3→ *\n     4→ * Encapsulates AI CLI execution logic with process tracking,\n     5→ * heartbeat, and interrupt support.\n     6→ *\n     7→ * T-051: Metrics tracking for monitoring\n     8→ */\n     9→\n    10→import { spawn } from 'node:child_process';\n    11→import { config } from '../config.js';\n    12→import { logger } from '../utils/logger.js';\n    13→import { sessionStore } from './session-store.js';\n    14→import { backendRegistry as defaultBackendRegistry } from './backend-registry.js';\n    15→import { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n    16→\n    17→// Allow dependency injection for testing\n    18→let backendRegistry = defaultBackendRegistry;\n    19→\n    20→/**\n    21→ * Set backend registry for testing purposes.\n    22→ * @param {Object} registry - Backend registry instance\n    23→ */\n    24→export function setBackendRegistry(registry) {\n    25→  backendRegistry = registry;\n    26→}\n    27→\n    28→/**\n    29→ * Metrics for AI CLI execution monitoring.\n    30→ * T-051: Track execution statistics\n    31→ */\n    32→const metrics = {\n    33→  // Execution counts\n    34→  totalExecutions: 0,\n    35→  successCount: 0,\n    36→  failureCount: 0,\n    37→  timeoutCount: 0,\n    38→  interruptCount: 0,\n    39→\n    40→  // Duration tracking (for histogram)\n    41→  durations: [],\n    42→  maxDurations: 100, // Keep last 100 durations\n    43→\n    44→  // Output size tracking\n    45→  outputSizes: [],\n    46→  maxOutputSizes: 100\n    47→};\n    48→\n    49→/**\n    50→ * Get current metrics snapshot.\n    51→ * @returns {Object} Metrics snapshot\n    52→ */\n    53→export function getMetrics() {\n    54→  const durations = [...metrics.durations];\n    55→  const outputSizes = [...metrics.outputSizes];\n    56→\n    57→  return {\n    58→    totalExecutions: metrics.totalExecutions,\n    59→    successCount: metrics.successCount,\n    60→    failureCount: metrics.failureCount,\n    61→    timeoutCount: metrics.timeoutCount,\n    62→    interruptCount: metrics.interruptCount,\n    63→    averageDurationMs: durations.length > 0\n    64→      ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length)\n    65→      : 0,\n    66→    minDurationMs: durations.length > 0 ? Math.min(...durations) : 0,\n    67→    maxDurationMs: durations.length > 0 ? Math.max(...durations) : 0,\n    68→    averageOutputBytes: outputSizes.length > 0\n    69→      ? Math.round(outputSizes.reduce((a, b) => a + b, 0) / outputSizes.length)\n    70→      : 0\n    71→  };\n    72→}\n    73→\n    74→/**\n    75→ * Record execution metrics.\n    76→ * @param {Object} result - Execution result\n    77→ * @param {number} result.elapsedMs - Execution duration\n    78→ * @param {number} result.stdoutBytes - Output size\n    79→ * @param {boolean} result.success - Whether execution succeeded\n    80→ * @param {boolean} result.timedOut - Whether execution timed out\n    81→ * @param {boolean} result.interrupted - Whether execution was interrupted\n    82→ */\n    83→function recordMetrics(result) {\n    84→  metrics.totalExecutions++;\n    85→\n    86→  // Track duration\n    87→  metrics.durations.push(result.elapsedMs);\n    88→  if (metrics.durations.length > metrics.maxDurations) {\n    89→    metrics.durations.shift();\n    90→  }\n    91→\n    92→  // Track output size\n    93→  metrics.outputSizes.push(result.stdoutBytes || 0);\n    94→  if (metrics.outputSizes.length > metrics.maxOutputSizes) {\n    95→    metrics.outputSizes.shift();\n    96→  }\n    97→\n    98→  // Track outcome\n    99→  if (result.interrupted) {\n   100→    metrics.interruptCount++;\n   101→  } else if (result.timedOut) {\n   102→    metrics.timeoutCount++;\n   103→  } else if (result.success) {\n   104→    metrics.successCount++;\n   105→  } else {\n   106→    metrics.failureCount++;\n   107→  }\n   108→\n   109→  // Log metrics at debug level\n   110→  logger.debug(\n   111→    {\n   112→      totalExecutions: metrics.totalExecutions,\n   113→      successRate: `${Math.round((metrics.successCount / metrics.totalExecutions) * 100)}%`,\n   114→      interruptRate: `${Math.round((metrics.interruptCount / metrics.totalExecutions) * 100)}%`,\n   115→      timeoutRate: `${Math.round((metrics.timeoutCount / metrics.totalExecutions) * 100)}%`\n   116→    },\n   117→    'AI CLI metrics updated'\n   118→  );\n   119→}\n   120→\n   121→/**\n   122→ * Reset metrics (useful for testing).\n   123→ */\n   124→export function resetMetrics() {\n   125→  metrics.totalExecutions = 0;\n   126→  metrics.successCount = 0;\n   127→  metrics.failureCount = 0;\n   128→  metrics.timeoutCount = 0;\n   129→  metrics.interruptCount = 0;\n   130→  metrics.durations = [];\n   131→  metrics.outputSizes = [];\n   132→}\n   133→\n   134→/**\n   135→ * @typedef {Object} AiCliExecutionOptions\n   136→ * @property {string} sessionId - Session identifier\n   137→ * @property {string} prompt - User prompt/input\n   138→ * @property {string} [userId] - User ID who initiated the task (for permission checks)\n   139→ * @property {Object} [hooks] - Callback hooks\n   140→ * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n   141→ * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n   142→ * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n   143→ * @property {AbortSignal} [signal] - Optional abort signal\n   144→ * @property {number} [timeoutMs] - Optional timeout override\n   145→ * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n   146→ * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n   147→ * @property {string} [bin] - Optional binary override (for testing)\n   148→ * @property {string[]} [args] - Optional args override (for testing, replaces default args)\n   149→ */\n   150→\n   151→/**\n   152→ * @typedef {Object} AiCliExecutionResult\n   153→ * @property {string} output - Final output text\n   154→ * @property {boolean} timedOut - Whether execution timed out\n   155→ * @property {boolean} interrupted - Whether execution was interrupted\n   156→ * @property {number} elapsedMs - Execution time in milliseconds\n   157→ * @property {number|null} exitCode - Process exit code (if completed)\n   158→ * @property {string} stderr - Error output if any\n   159→ */\n   160→\n   161→/**\n   162→ * @typedef {Object} HeartbeatInfo\n   163→ * @property {number} elapsedMs - Elapsed time in milliseconds\n   164→ * @property {number} stdoutBytes - Bytes received so far\n   165→ * @property {string} status - Current status ('running', 'streaming')\n   166→ */\n   167→\n   168→/**\n   169→ * Write text to echo output for debugging.\n   170→ * @param {string} tag - Tag for the output\n   171→ * @param {string} text - Text to write\n   172→ */\n   173→function writeEcho(tag, text) {\n   174→  const normalized = String(text ?? '');\n   175→  if (!normalized) {\n   176→    return;\n   177→  }\n   178→\n   179→  const lines = normalized.split(/\\r?\\n/);\n   180→  for (const line of lines) {\n   181→    if (!line) {\n   182→      continue;\n   183→    }\n   184→    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n   185→  }\n   186→}\n   187→\n   188→/**\n   189→ * Execute AI CLI with session context and process tracking.\n   190→ * @param {AiCliExecutionOptions} options\n   191→ * @returns {Promise<AiCliExecutionResult>}\n   192→ */\n   193→export async function executeAiCli(options) {\n   194→  const {\n   195→    sessionId,\n   196→    prompt,\n   197→    userId,\n   198→    hooks = {},\n   199→    signal,\n   200→    timeoutMs,\n   201→    heartbeatThresholdMs,\n   202→    heartbeatIntervalMs,\n   203→    bin,\n   204→    args: customArgs\n   205→  } = options;\n   206→\n   207→  // Get session-specific backend or use default\n   208→  const sessionBackendName = sessionStore.getCurrentBackend(sessionId);\n   209→  const sessionBackend = sessionBackendName ? backendRegistry.getBackend(sessionBackendName) : null;\n   210→  const effectiveBin = bin || (sessionBackend?.binPath) || config.codebuddyBin;\n   211→  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n   212→  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n   213→  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n   214→  const enableHeartbeat = config.aiCliEnableHeartbeat;\n   215→\n   216→  // Validate backend binary exists if using session backend\n   217→  if (sessionBackendName && !backendRegistry.validateBackend(sessionBackendName)) {\n   218→    const defaultBackend = backendRegistry.getDefaultBackend();\n   219→    const fallbackBin = defaultBackend?.binPath || config.codebuddyBin;\n   220→\n   221→    logger.warn(`Backend \"${sessionBackendName}\" not accessible, falling back to default`);\n   222→\n   223→    // Reset to default backend for this session\n   224→    sessionStore.resetBackend(sessionId);\n   225→\n   226→    return {\n   227→      output: `⚠️ 后端 \"${sessionBackendName}\" 不可用，已切换回默认后端。\\n建议：检查后端配置或使用 /cli reset 重置。`,\n   228→      timedOut: false,\n   229→      interrupted: false,\n   230→      elapsedMs: 0,\n   231→      exitCode: null,\n   232→      stderr: ''\n   233→    };\n   234→  }\n   235→\n   236→  // Use custom args if provided (for testing), otherwise build default args\n   237→  const args = customArgs ?? (() => {\n   238→    const defaultArgs = ['-p', prompt];\n   239→    // Use session backend's permission flag if available, otherwise fallback to config\n   240→    const permissionFlag = sessionBackend?.permissionFlag || config.codebuddyPermissionFlag;\n   241→    if (permissionFlag) {\n   242→      defaultArgs.push(permissionFlag);\n   243→    }\n   244→    return defaultArgs;\n   245→  })();\n   246→\n   247→  return new Promise((resolve) => {\n   248→    let stdout = '';\n   249→    let stderr = '';\n   250→    let stdoutBytes = 0;\n   251→    let interrupted = false;\n   252→    let timedOut = false;\n   253→    const startedAt = Date.now();\n   254→    const sessionKey = sessionId;\n   255→\n   256→    // Heartbeat manager\n   257→    const heartbeatManager = createHeartbeatManager();\n   258→\n   259→    // Spawn process\n   260→    let child;\n   261→    try {\n   262→      child = spawn(effectiveBin, args, {\n   263→        stdio: ['ignore', 'pipe', 'pipe']\n   264→      });\n   265→    } catch (err) {\n   266→      resolve({\n   267→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n   268→        timedOut: false,\n   269→        interrupted: false,\n   270→        elapsedMs: Date.now() - startedAt,\n   271→        exitCode: null,\n   272→        stderr: ''\n   273→      });\n   274→      return;\n   275→    }\n   276→\n   277→    // Track process in session store\n   278→    sessionStore.setActiveProcess(sessionKey, {\n   279→      pid: child.pid,\n   280→      startedAt,\n   281→      childProcess: child,\n   282→      interrupted: false,\n   283→      timedOut: false,\n   284→      userId\n   285→    });\n   286→\n   287→    logger.info({\n   288→    pid: child.pid,\n   289→    bin: effectiveBin,\n   290→    backend: sessionBackendName || 'default',\n   291→    args,\n   292→    sessionId\n   293→  }, 'AI CLI process started');\n   294→\n   295→    // Handle process error\n   296→    child.on('error', (err) => {\n   297→      cleanup();\n   298→      resolve({\n   299→        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n   300→        timedOut: false,\n   301→        interrupted: false,\n   302→        elapsedMs: Date.now() - startedAt,\n   303→        exitCode: null,\n   304→        stderr\n   305→      });\n   306→    });\n   307→\n   308→    // Handle stdout\n   309→    child.stdout.on('data', (chunk) => {\n   310→      const text = chunk.toString();\n   311→      stdout += text;\n   312→      stdoutBytes += Buffer.byteLength(text);\n   313→\n   314→      // Update session store byte count\n   315→      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n   316→\n   317→      // Echo to console if enabled\n   318→      if (config.codebuddyEchoStdio) {\n   319→        writeEcho('stdout', text);\n   320→      }\n   321→\n   322→      // Call onChunk hook\n   323→      if (typeof hooks.onChunk === 'function') {\n   324→        hooks.onChunk(text);\n   325→      }\n   326→    });\n   327→\n   328→    // Handle stderr\n   329→    child.stderr.on('data', (chunk) => {\n   330→      const text = chunk.toString();\n   331→      stderr += text;\n   332→\n   333→      if (config.codebuddyEchoStdio) {\n   334→        writeEcho('stderr', text);\n   335→      }\n   336→    });\n   337→\n   338→    // Timeout handler\n   339→    const timeout = effectiveTimeoutMs > 0\n   340→      ? setTimeout(() => {\n   341→          timedOut = true;\n   342→          const info = sessionStore.getActiveProcess(sessionKey);\n   343→          if (info) {\n   344→            info.timedOut = true;\n   345→          }\n   346→          child.kill('SIGTERM');\n   347→\n   348→          // Schedule SIGKILL if process doesn't exit\n   349→          setTimeout(() => {\n   350→            if (sessionStore.getActiveProcess(sessionKey)) {\n   351→              child.kill('SIGKILL');\n   352→            }\n   353→          }, 5000);\n   354→        }, effectiveTimeoutMs)\n   355→      : null;\n   356→\n   357→    // Abort signal handler\n   358→    const onAbort = () => {\n   359→      interrupted = true;\n   360→      const info = sessionStore.getActiveProcess(sessionKey);\n   361→      if (info) {\n   362→        info.interrupted = true;\n   363→      }\n   364→      child.kill('SIGTERM');\n   365→\n   366→      // Schedule SIGKILL if process doesn't exit\n   367→      setTimeout(() => {\n   368→        if (sessionStore.getActiveProcess(sessionKey)) {\n   369→          child.kill('SIGKILL');\n   370→        }\n   371→      }, 5000);\n   372→    };\n   373→\n   374→    if (signal) {\n   375→      signal.addEventListener('abort', onAbort);\n   376→    }\n   377→\n   378→    // Heartbeat setup\n   379→    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n   380→      heartbeatManager.start({\n   381→        callback: () => {\n   382→          const elapsedMs = Date.now() - startedAt;\n   383→          hooks.onHeartbeat({\n   384→            elapsedMs,\n   385→            stdoutBytes,\n   386→            status: 'running'\n   387→          });\n   388→        },\n   389→        intervalMs: effectiveHeartbeatIntervalMs,\n   390→        thresholdMs: effectiveHeartbeatThresholdMs\n   391→      });\n   392→    }\n   393→\n   394→    // Cleanup function\n   395→    function cleanup() {\n   396→      if (timeout) {\n   397→        clearTimeout(timeout);\n   398→      }\n   399→      heartbeatManager.stop();\n   400→      sessionStore.clearActiveProcess(sessionKey);\n   401→      if (signal) {\n   402→        signal.removeEventListener('abort', onAbort);\n   403→      }\n   404→    }\n   405→\n   406→    // Handle process close\n   407→    child.on('close', (code) => {\n   408→      const elapsedMs = Date.now() - startedAt;\n   409→\n   410→      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n   411→      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n   412→      if (storedInfo) {\n   413→        if (storedInfo.interrupted) {\n   414→          interrupted = true;\n   415→        }\n   416→        if (storedInfo.timedOut) {\n   417→          timedOut = true;\n   418→        }\n   419→      }\n   420→\n   421→      cleanup();\n   422→\n   423→      logger.info(\n   424→        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n   425→        'AI CLI process closed'\n   426→      );\n   427→\n   428→      // Build output\n   429→      let output = stdout.trim();\n   430→\n   431→      if (interrupted) {\n   432→        output = output || '任务已被用户中断。';\n   433→      } else if (timedOut) {\n   434→        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n   435→      } else if (code !== 0) {\n   436→        output = output || `AI CLI 退出码 ${code}。`;\n   437→        if (stderr.trim()) {\n   438→          output += `\\n错误信息:\\n${stderr.trim()}`;\n   439→        }\n   440→      }\n   441→\n   442→      // Record metrics (T-051)\n   443→      recordMetrics({\n   444→        elapsedMs,\n   445→        stdoutBytes,\n   446→        success: code === 0 && !interrupted && !timedOut,\n   447→        timedOut,\n   448→        interrupted\n   449→      });\n   450→\n   451→      resolve({\n   452→        output: output || 'AI CLI 未返回文本结果。',\n   453→        timedOut,\n   454→        interrupted,\n   455→        elapsedMs,\n   456→        exitCode: code,\n   457→        stderr: stderr.trim()\n   458→      });\n   459→    });\n   460→  });\n   461→}\n   462→\n   463→/**\n   464→ * Interrupt running AI CLI task for a session.\n   465→ * @param {string} sessionId - Session identifier\n   466→ * @returns {{ ok: boolean, pid?: number, error?: string }}\n   467→ */\n   468→export function interruptAiCli(sessionId) {\n   469→  const processInfo = sessionStore.getActiveProcess(sessionId);\n   470→\n   471→  if (!processInfo) {\n   472→    return { ok: false, error: '没有正在执行的任务。' };\n   473→  }\n   474→\n   475→  const { pid, childProcess } = processInfo;\n   476→\n   477→  try {\n   478→    // Mark as interrupted so close handler knows\n   479→    processInfo.interrupted = true;\n   480→\n   481→    // Send SIGTERM first\n   482→    childProcess.kill('SIGTERM');\n   483→\n   484→    // Schedule SIGKILL as backup\n   485→    setTimeout(() => {\n   486→      const stillRunning = sessionStore.getActiveProcess(sessionId);\n   487→      if (stillRunning) {\n   488→        try {\n   489→          childProcess.kill('SIGKILL');\n   490→        } catch {\n   491→          // Process already dead\n   492→        }\n   493→      }\n   494→    }, 5000);\n   495→\n   496→    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n   497→\n   498→    return { ok: true, pid };\n   499→  } catch (err) {\n   500→    return { ok: false, error: `中断失败: ${err.message}` };\n   501→  }\n   502→}\n   503→\n   504→/**\n   505→ * Check if AI CLI is running for a session.\n   506→ * @param {string} sessionId\n   507→ * @returns {boolean}\n   508→ */\n   509→export function isAiCliRunning(sessionId) {\n   510→  return sessionStore.getActiveProcess(sessionId) !== null;\n   511→}\n   512→\n   513→/**\n   514→ * Get active process info for a session.\n   515→ * @param {string} sessionId\n   516→ * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n   517→ */\n   518→export function getActiveProcessInfo(sessionId) {\n   519→  const info = sessionStore.getActiveProcess(sessionId);\n   520→  if (!info) {\n   521→    return null;\n   522→  }\n   523→\n   524→  // Don't expose childProcess to external callers\n   525→  return {\n   526→    pid: info.pid,\n   527→    startedAt: info.startedAt,\n   528→    stdoutBytes: info.stdoutBytes ?? 0,\n   529→    userId: info.userId\n   530→  };\n   531→}\n   532→\n   533→/**\n   534→ * Check if user can interrupt AI CLI task.\n   535→ * @param {string} sessionId - Session identifier\n   536→ * @param {string|number} requestUserId - User requesting interrupt\n   537→ * @param {Function} isAdminFn - Function to check if user is admin\n   538→ * @returns {{ canInterrupt: boolean, reason?: string }}\n   539→ */\n   540→export function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n   541→  const processInfo = sessionStore.getActiveProcess(sessionId);\n   542→\n   543→  if (!processInfo) {\n   544→    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n   545→  }\n   546→\n   547→  // Admin can always interrupt\n   548→  if (isAdminFn && isAdminFn(requestUserId)) {\n   549→    return { canInterrupt: true };\n   550→  }\n   551→\n   552→  // Task owner can interrupt\n   553→  const taskUserId = processInfo.userId;\n   554→  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n   555→    return { canInterrupt: true };\n   556→  }\n   557→\n   558→  // Otherwise, permission denied\n   559→  return {\n   560→    canInterrupt: false,\n   561→    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n   562→  };\n   563→}\n   564→"}]},"parent_tool_use_id":null,"session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"caacfef8-9854-4906-91de-7b4526727029","timestamp":"2026-03-22T06:23:56.367Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/ai-cli-service.js","content":"/**\n * F-011: AI CLI Service\n *\n * Encapsulates AI CLI execution logic with process tracking,\n * heartbeat, and interrupt support.\n *\n * T-051: Metrics tracking for monitoring\n */\n\nimport { spawn } from 'node:child_process';\nimport { config } from '../config.js';\nimport { logger } from '../utils/logger.js';\nimport { sessionStore } from './session-store.js';\nimport { backendRegistry as defaultBackendRegistry } from './backend-registry.js';\nimport { createHeartbeatManager } from '../utils/heartbeat-manager.js';\n\n// Allow dependency injection for testing\nlet backendRegistry = defaultBackendRegistry;\n\n/**\n * Set backend registry for testing purposes.\n * @param {Object} registry - Backend registry instance\n */\nexport function setBackendRegistry(registry) {\n  backendRegistry = registry;\n}\n\n/**\n * Metrics for AI CLI execution monitoring.\n * T-051: Track execution statistics\n */\nconst metrics = {\n  // Execution counts\n  totalExecutions: 0,\n  successCount: 0,\n  failureCount: 0,\n  timeoutCount: 0,\n  interruptCount: 0,\n\n  // Duration tracking (for histogram)\n  durations: [],\n  maxDurations: 100, // Keep last 100 durations\n\n  // Output size tracking\n  outputSizes: [],\n  maxOutputSizes: 100\n};\n\n/**\n * Get current metrics snapshot.\n * @returns {Object} Metrics snapshot\n */\nexport function getMetrics() {\n  const durations = [...metrics.durations];\n  const outputSizes = [...metrics.outputSizes];\n\n  return {\n    totalExecutions: metrics.totalExecutions,\n    successCount: metrics.successCount,\n    failureCount: metrics.failureCount,\n    timeoutCount: metrics.timeoutCount,\n    interruptCount: metrics.interruptCount,\n    averageDurationMs: durations.length > 0\n      ? Math.round(durations.reduce((a, b) => a + b, 0) / durations.length)\n      : 0,\n    minDurationMs: durations.length > 0 ? Math.min(...durations) : 0,\n    maxDurationMs: durations.length > 0 ? Math.max(...durations) : 0,\n    averageOutputBytes: outputSizes.length > 0\n      ? Math.round(outputSizes.reduce((a, b) => a + b, 0) / outputSizes.length)\n      : 0\n  };\n}\n\n/**\n * Record execution metrics.\n * @param {Object} result - Execution result\n * @param {number} result.elapsedMs - Execution duration\n * @param {number} result.stdoutBytes - Output size\n * @param {boolean} result.success - Whether execution succeeded\n * @param {boolean} result.timedOut - Whether execution timed out\n * @param {boolean} result.interrupted - Whether execution was interrupted\n */\nfunction recordMetrics(result) {\n  metrics.totalExecutions++;\n\n  // Track duration\n  metrics.durations.push(result.elapsedMs);\n  if (metrics.durations.length > metrics.maxDurations) {\n    metrics.durations.shift();\n  }\n\n  // Track output size\n  metrics.outputSizes.push(result.stdoutBytes || 0);\n  if (metrics.outputSizes.length > metrics.maxOutputSizes) {\n    metrics.outputSizes.shift();\n  }\n\n  // Track outcome\n  if (result.interrupted) {\n    metrics.interruptCount++;\n  } else if (result.timedOut) {\n    metrics.timeoutCount++;\n  } else if (result.success) {\n    metrics.successCount++;\n  } else {\n    metrics.failureCount++;\n  }\n\n  // Log metrics at debug level\n  logger.debug(\n    {\n      totalExecutions: metrics.totalExecutions,\n      successRate: `${Math.round((metrics.successCount / metrics.totalExecutions) * 100)}%`,\n      interruptRate: `${Math.round((metrics.interruptCount / metrics.totalExecutions) * 100)}%`,\n      timeoutRate: `${Math.round((metrics.timeoutCount / metrics.totalExecutions) * 100)}%`\n    },\n    'AI CLI metrics updated'\n  );\n}\n\n/**\n * Reset metrics (useful for testing).\n */\nexport function resetMetrics() {\n  metrics.totalExecutions = 0;\n  metrics.successCount = 0;\n  metrics.failureCount = 0;\n  metrics.timeoutCount = 0;\n  metrics.interruptCount = 0;\n  metrics.durations = [];\n  metrics.outputSizes = [];\n}\n\n/**\n * @typedef {Object} AiCliExecutionOptions\n * @property {string} sessionId - Session identifier\n * @property {string} prompt - User prompt/input\n * @property {string} [userId] - User ID who initiated the task (for permission checks)\n * @property {Object} [hooks] - Callback hooks\n * @property {Function} [hooks.onChunk] - Stream chunk callback (text: string) => void\n * @property {Function} [hooks.onHeartbeat] - Heartbeat callback (info: HeartbeatInfo) => void\n * @property {Function} [hooks.onStatus] - Status change callback (status: string) => void\n * @property {AbortSignal} [signal] - Optional abort signal\n * @property {number} [timeoutMs] - Optional timeout override\n * @property {number} [heartbeatThresholdMs] - Heartbeat threshold override\n * @property {number} [heartbeatIntervalMs] - Heartbeat interval override\n * @property {string} [bin] - Optional binary override (for testing)\n * @property {string[]} [args] - Optional args override (for testing, replaces default args)\n */\n\n/**\n * @typedef {Object} AiCliExecutionResult\n * @property {string} output - Final output text\n * @property {boolean} timedOut - Whether execution timed out\n * @property {boolean} interrupted - Whether execution was interrupted\n * @property {number} elapsedMs - Execution time in milliseconds\n * @property {number|null} exitCode - Process exit code (if completed)\n * @property {string} stderr - Error output if any\n */\n\n/**\n * @typedef {Object} HeartbeatInfo\n * @property {number} elapsedMs - Elapsed time in milliseconds\n * @property {number} stdoutBytes - Bytes received so far\n * @property {string} status - Current status ('running', 'streaming')\n */\n\n/**\n * Write text to echo output for debugging.\n * @param {string} tag - Tag for the output\n * @param {string} text - Text to write\n */\nfunction writeEcho(tag, text) {\n  const normalized = String(text ?? '');\n  if (!normalized) {\n    return;\n  }\n\n  const lines = normalized.split(/\\r?\\n/);\n  for (const line of lines) {\n    if (!line) {\n      continue;\n    }\n    process.stdout.write(`[CodeBuddy:${tag}] ${line}\\n`);\n  }\n}\n\n/**\n * Execute AI CLI with session context and process tracking.\n * @param {AiCliExecutionOptions} options\n * @returns {Promise<AiCliExecutionResult>}\n */\nexport async function executeAiCli(options) {\n  const {\n    sessionId,\n    prompt,\n    userId,\n    hooks = {},\n    signal,\n    timeoutMs,\n    heartbeatThresholdMs,\n    heartbeatIntervalMs,\n    bin,\n    args: customArgs\n  } = options;\n\n  // Get session-specific backend or use default\n  const sessionBackendName = sessionStore.getCurrentBackend(sessionId);\n  const sessionBackend = sessionBackendName ? backendRegistry.getBackend(sessionBackendName) : null;\n  const effectiveBin = bin || (sessionBackend?.binPath) || config.codebuddyBin;\n  const effectiveTimeoutMs = timeoutMs ?? config.requestTimeoutMs;\n  const effectiveHeartbeatThresholdMs = heartbeatThresholdMs ?? config.aiCliHeartbeatThresholdMs;\n  const effectiveHeartbeatIntervalMs = heartbeatIntervalMs ?? config.aiCliHeartbeatIntervalMs;\n  const enableHeartbeat = config.aiCliEnableHeartbeat;\n\n  // Validate backend binary exists if using session backend\n  if (sessionBackendName && !backendRegistry.validateBackend(sessionBackendName)) {\n    const defaultBackend = backendRegistry.getDefaultBackend();\n    const fallbackBin = defaultBackend?.binPath || config.codebuddyBin;\n\n    logger.warn(`Backend \"${sessionBackendName}\" not accessible, falling back to default`);\n\n    // Reset to default backend for this session\n    sessionStore.resetBackend(sessionId);\n\n    return {\n      output: `⚠️ 后端 \"${sessionBackendName}\" 不可用，已切换回默认后端。\\n建议：检查后端配置或使用 /cli reset 重置。`,\n      timedOut: false,\n      interrupted: false,\n      elapsedMs: 0,\n      exitCode: null,\n      stderr: ''\n    };\n  }\n\n  // Use custom args if provided (for testing), otherwise build default args\n  const args = customArgs ?? (() => {\n    const defaultArgs = ['-p', prompt];\n    // Use session backend's permission flag if available, otherwise fallback to config\n    const permissionFlag = sessionBackend?.permissionFlag || config.codebuddyPermissionFlag;\n    if (permissionFlag) {\n      defaultArgs.push(permissionFlag);\n    }\n    return defaultArgs;\n  })();\n\n  return new Promise((resolve) => {\n    let stdout = '';\n    let stderr = '';\n    let stdoutBytes = 0;\n    let interrupted = false;\n    let timedOut = false;\n    const startedAt = Date.now();\n    const sessionKey = sessionId;\n\n    // Heartbeat manager\n    const heartbeatManager = createHeartbeatManager();\n\n    // Spawn process\n    let child;\n    try {\n      child = spawn(effectiveBin, args, {\n        stdio: ['ignore', 'pipe', 'pipe']\n      });\n    } catch (err) {\n      resolve({\n        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n        timedOut: false,\n        interrupted: false,\n        elapsedMs: Date.now() - startedAt,\n        exitCode: null,\n        stderr: ''\n      });\n      return;\n    }\n\n    // Track process in session store\n    sessionStore.setActiveProcess(sessionKey, {\n      pid: child.pid,\n      startedAt,\n      childProcess: child,\n      interrupted: false,\n      timedOut: false,\n      userId\n    });\n\n    logger.info({\n    pid: child.pid,\n    bin: effectiveBin,\n    backend: sessionBackendName || 'default',\n    args,\n    sessionId\n  }, 'AI CLI process started');\n\n    // Handle process error\n    child.on('error', (err) => {\n      cleanup();\n      resolve({\n        output: `无法启动 AI CLI: ${err.message}\\n建议：检查 CODEBUDDY_BIN 配置是否正确。`,\n        timedOut: false,\n        interrupted: false,\n        elapsedMs: Date.now() - startedAt,\n        exitCode: null,\n        stderr\n      });\n    });\n\n    // Handle stdout\n    child.stdout.on('data', (chunk) => {\n      const text = chunk.toString();\n      stdout += text;\n      stdoutBytes += Buffer.byteLength(text);\n\n      // Update session store byte count\n      sessionStore.updateProcessBytes(sessionKey, Buffer.byteLength(text));\n\n      // Echo to console if enabled\n      if (config.codebuddyEchoStdio) {\n        writeEcho('stdout', text);\n      }\n\n      // Call onChunk hook\n      if (typeof hooks.onChunk === 'function') {\n        hooks.onChunk(text);\n      }\n    });\n\n    // Handle stderr\n    child.stderr.on('data', (chunk) => {\n      const text = chunk.toString();\n      stderr += text;\n\n      if (config.codebuddyEchoStdio) {\n        writeEcho('stderr', text);\n      }\n    });\n\n    // Timeout handler\n    const timeout = effectiveTimeoutMs > 0\n      ? setTimeout(() => {\n          timedOut = true;\n          const info = sessionStore.getActiveProcess(sessionKey);\n          if (info) {\n            info.timedOut = true;\n          }\n          child.kill('SIGTERM');\n\n          // Schedule SIGKILL if process doesn't exit\n          setTimeout(() => {\n            if (sessionStore.getActiveProcess(sessionKey)) {\n              child.kill('SIGKILL');\n            }\n          }, 5000);\n        }, effectiveTimeoutMs)\n      : null;\n\n    // Abort signal handler\n    const onAbort = () => {\n      interrupted = true;\n      const info = sessionStore.getActiveProcess(sessionKey);\n      if (info) {\n        info.interrupted = true;\n      }\n      child.kill('SIGTERM');\n\n      // Schedule SIGKILL if process doesn't exit\n      setTimeout(() => {\n        if (sessionStore.getActiveProcess(sessionKey)) {\n          child.kill('SIGKILL');\n        }\n      }, 5000);\n    };\n\n    if (signal) {\n      signal.addEventListener('abort', onAbort);\n    }\n\n    // Heartbeat setup\n    if (enableHeartbeat && typeof hooks.onHeartbeat === 'function') {\n      heartbeatManager.start({\n        callback: () => {\n          const elapsedMs = Date.now() - startedAt;\n          hooks.onHeartbeat({\n            elapsedMs,\n            stdoutBytes,\n            status: 'running'\n          });\n        },\n        intervalMs: effectiveHeartbeatIntervalMs,\n        thresholdMs: effectiveHeartbeatThresholdMs\n      });\n    }\n\n    // Cleanup function\n    function cleanup() {\n      if (timeout) {\n        clearTimeout(timeout);\n      }\n      heartbeatManager.stop();\n      sessionStore.clearActiveProcess(sessionKey);\n      if (signal) {\n        signal.removeEventListener('abort', onAbort);\n      }\n    }\n\n    // Handle process close\n    child.on('close', (code) => {\n      const elapsedMs = Date.now() - startedAt;\n\n      // Check interrupted/timedOut flags from session store (may be set by interruptAiCli)\n      const storedInfo = sessionStore.getActiveProcess(sessionKey);\n      if (storedInfo) {\n        if (storedInfo.interrupted) {\n          interrupted = true;\n        }\n        if (storedInfo.timedOut) {\n          timedOut = true;\n        }\n      }\n\n      cleanup();\n\n      logger.info(\n        { pid: child.pid, code, elapsedSec: Math.floor(elapsedMs / 1000), sessionId },\n        'AI CLI process closed'\n      );\n\n      // Build output\n      let output = stdout.trim();\n\n      if (interrupted) {\n        output = output || '任务已被用户中断。';\n      } else if (timedOut) {\n        output = output || `任务执行超时（>${effectiveTimeoutMs}ms）。\\n建议：使用 /stop 中断或增加 REQUEST_TIMEOUT_MS 配置。`;\n      } else if (code !== 0) {\n        output = output || `AI CLI 退出码 ${code}。`;\n        if (stderr.trim()) {\n          output += `\\n错误信息:\\n${stderr.trim()}`;\n        }\n      }\n\n      // Record metrics (T-051)\n      recordMetrics({\n        elapsedMs,\n        stdoutBytes,\n        success: code === 0 && !interrupted && !timedOut,\n        timedOut,\n        interrupted\n      });\n\n      resolve({\n        output: output || 'AI CLI 未返回文本结果。',\n        timedOut,\n        interrupted,\n        elapsedMs,\n        exitCode: code,\n        stderr: stderr.trim()\n      });\n    });\n  });\n}\n\n/**\n * Interrupt running AI CLI task for a session.\n * @param {string} sessionId - Session identifier\n * @returns {{ ok: boolean, pid?: number, error?: string }}\n */\nexport function interruptAiCli(sessionId) {\n  const processInfo = sessionStore.getActiveProcess(sessionId);\n\n  if (!processInfo) {\n    return { ok: false, error: '没有正在执行的任务。' };\n  }\n\n  const { pid, childProcess } = processInfo;\n\n  try {\n    // Mark as interrupted so close handler knows\n    processInfo.interrupted = true;\n\n    // Send SIGTERM first\n    childProcess.kill('SIGTERM');\n\n    // Schedule SIGKILL as backup\n    setTimeout(() => {\n      const stillRunning = sessionStore.getActiveProcess(sessionId);\n      if (stillRunning) {\n        try {\n          childProcess.kill('SIGKILL');\n        } catch {\n          // Process already dead\n        }\n      }\n    }, 5000);\n\n    logger.info({ pid, sessionId }, 'AI CLI process interrupted');\n\n    return { ok: true, pid };\n  } catch (err) {\n    return { ok: false, error: `中断失败: ${err.message}` };\n  }\n}\n\n/**\n * Check if AI CLI is running for a session.\n * @param {string} sessionId\n * @returns {boolean}\n */\nexport function isAiCliRunning(sessionId) {\n  return sessionStore.getActiveProcess(sessionId) !== null;\n}\n\n/**\n * Get active process info for a session.\n * @param {string} sessionId\n * @returns {{ pid: number, startedAt: number, stdoutBytes: number, userId?: string } | null}\n */\nexport function getActiveProcessInfo(sessionId) {\n  const info = sessionStore.getActiveProcess(sessionId);\n  if (!info) {\n    return null;\n  }\n\n  // Don't expose childProcess to external callers\n  return {\n    pid: info.pid,\n    startedAt: info.startedAt,\n    stdoutBytes: info.stdoutBytes ?? 0,\n    userId: info.userId\n  };\n}\n\n/**\n * Check if user can interrupt AI CLI task.\n * @param {string} sessionId - Session identifier\n * @param {string|number} requestUserId - User requesting interrupt\n * @param {Function} isAdminFn - Function to check if user is admin\n * @returns {{ canInterrupt: boolean, reason?: string }}\n */\nexport function canInterruptAiCli(sessionId, requestUserId, isAdminFn) {\n  const processInfo = sessionStore.getActiveProcess(sessionId);\n\n  if (!processInfo) {\n    return { canInterrupt: false, reason: '没有正在执行的任务。' };\n  }\n\n  // Admin can always interrupt\n  if (isAdminFn && isAdminFn(requestUserId)) {\n    return { canInterrupt: true };\n  }\n\n  // Task owner can interrupt\n  const taskUserId = processInfo.userId;\n  if (taskUserId && String(taskUserId) === String(requestUserId)) {\n    return { canInterrupt: true };\n  }\n\n  // Otherwise, permission denied\n  return {\n    canInterrupt: false,\n    reason: '权限不足。只有任务发起者或管理员可以中断任务。'\n  };\n}\n","numLines":564,"startLine":1,"totalLines":564}}}
