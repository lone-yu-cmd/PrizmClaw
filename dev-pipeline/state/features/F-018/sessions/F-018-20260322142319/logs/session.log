{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01EEwr4s4bJarM9LkhXu8V3m","type":"tool_result","content":"     1→/**\n     2→ * Session Binding Integration Tests\n     3→ * Tests for F-018 Web-Telegram Bidirectional Sync binding endpoints\n     4→ *\n     5→ * F-018: Web-Telegram Bidirectional Sync\n     6→ */\n     7→\n     8→import test from 'node:test';\n     9→import assert from 'node:assert/strict';\n    10→import fs from 'node:fs';\n    11→import path from 'node:path';\n    12→import os from 'node:os';\n    13→import http from 'node:http';\n    14→\n    15→import { createHttpServer } from '../../src/http/server.js';\n    16→import { config } from '../../src/config.js';\n    17→\n    18→/**\n    19→ * Helper to create temp directory for test state\n    20→ */\n    21→function createTempDir() {\n    22→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f018-binding-test-'));\n    23→  const dataDir = path.join(tempDir, 'data');\n    24→  fs.mkdirSync(dataDir, { recursive: true });\n    25→  return {\n    26→    tempDir,\n    27→    dataDir,\n    28→    cleanup: () => {\n    29→      fs.rmSync(tempDir, { recursive: true, force: true });\n    30→    }\n    31→  };\n    32→}\n    33→\n    34→/**\n    35→ * Helper to make HTTP requests\n    36→ */\n    37→function makeRequest(options, data) {\n    38→  return new Promise((resolve, reject) => {\n    39→    const req = http.request(options, (res) => {\n    40→      let body = '';\n    41→      res.on('data', (chunk) => body += chunk);\n    42→      res.on('end', () => {\n    43→        try {\n    44→          resolve({\n    45→            statusCode: res.statusCode,\n    46→            headers: res.headers,\n    47→            body: JSON.parse(body)\n    48→          });\n    49→        } catch (e) {\n    50→          resolve({\n    51→            statusCode: res.statusCode,\n    52→            headers: res.headers,\n    53→            body\n    54→          });\n    55→        }\n    56→      });\n    57→    });\n    58→\n    59→    req.on('error', reject);\n    60→    if (data) {\n    61→      req.write(JSON.stringify(data));\n    62→    }\n    63→    req.end();\n    64→  });\n    65→}\n    66→\n    67→/**\n    68→ * Helper to start HTTP server\n    69→ */\n    70→function startServer(bindingsPath) {\n    71→  // Override config for testing\n    72→  const originalBindingsPath = config.sessionBindingsPath;\n    73→  const testBindingsPath = bindingsPath;\n    74→\n    75→  // Create a mock config object\n    76→  const mockConfig = {\n    77→    ...config,\n    78→    sessionBindingsPath: testBindingsPath\n    79→  };\n    80→\n    81→  const logger = { info: () => {}, error: () => {} };\n    82→  const app = createHttpServer({ logger });\n    83→\n    84→  return new Promise((resolve) => {\n    85→    const server = http.createServer(app);\n    86→    server.listen(0, () => {\n    87→      const port = server.address().port;\n    88→      resolve({ server, port, cleanup: () => server.close() });\n    89→    });\n    90→  });\n    91→}\n    92→\n    93→test('F-018: POST /api/bind creates session binding', async (t) => {\n    94→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n    95→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n    96→\n    97→  try {\n    98→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    99→    try {\n   100→      const response = await makeRequest({\n   101→        hostname: 'localhost',\n   102→        port,\n   103→        path: '/api/bind',\n   104→        method: 'POST',\n   105→        headers: { 'Content-Type': 'application/json' }\n   106→      },\n   107→      { webSessionId: 'web-session-123', telegramChatId: '456' });\n   108→\n   109→      assert.strictEqual(response.statusCode, 200);\n   110→      assert.strictEqual(response.body.ok, true);\n   111→\n   112→      // Verify binding persisted\n   113→      const raw = fs.readFileSync(bindingsPath, 'utf-8');\n   114→      const data = JSON.parse(raw);\n   115→      assert.strictEqual(data.bindings['web-session-123'], '456');\n   116→    } finally {\n   117→      cleanupServer();\n   118→    }\n   119→  } finally {\n   120→    cleanupTemp();\n   121→  }\n   122→});\n   123→\n   124→test('F-018: POST /api/bind validates required fields', async (t) => {\n   125→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   126→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   127→\n   128→  try {\n   129→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   130→    try {\n   131→      const response = await makeRequest({\n   132→        hostname: 'localhost',\n   133→        port,\n   134→        path: '/api/bind',\n   135→        method: 'POST',\n   136→        headers: { 'Content-Type': 'application/json' }\n   137→      },\n   138→      { webSessionId: 'web-session-123' });\n   139→\n   140→      assert.strictEqual(response.statusCode, 400);\n   141→      assert.strictEqual(response.body.ok, false);\n   142→      assert.ok(response.body.error.includes('required'));\n   143→    } finally {\n   144→      cleanupServer();\n   145→    }\n   146→  } finally {\n   147→    cleanupTemp();\n   148→  }\n   149→});\n   150→\n   151→test('F-018: POST /api/unbind removes session binding', async (t) => {\n   152→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   153→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   154→\n   155→  try {\n   156→    // Create initial binding\n   157→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   158→      bindings: {\n   159→        'web-session-123': '456'\n   160→      }\n   161→    }));\n   162→\n   163→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   164→    try {\n   165→      const response = await makeRequest({\n   166→        hostname: 'localhost',\n   167→        port,\n   168