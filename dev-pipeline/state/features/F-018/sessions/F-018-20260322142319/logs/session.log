onBindingService} An initialized SessionBindingService instance\n   207→ */\n   208→export function createSessionBindService({ bindingsPath, persistenceDir } = {}) {\n   209→  const opts = {};\n   210→  if (bindingsPath) {\n   211→    opts.persistenceDir = path.dirname(bindingsPath);\n   212→  } else if (persistenceDir) {\n   213→    opts.persistenceDir = persistenceDir;\n   214→  }\n   215→\n   216→  const service = new SessionBindingService(opts);\n   217→\n   218→  // Auto-initialize (fire-and-forget; callers who need guaranteed init should await service.init())\n   219→  service.init().catch((err) => {\n   220→    logger.error({ err: err.message }, 'Failed to auto-initialize SessionBindingService');\n   221→  });\n   222→\n   223→  return service;\n   224→}\n   225→\n   226→export const sessionBindingService = new SessionBindingService();\n   227→export { SessionBindingService };\n   228→"}]},"parent_tool_use_id":"toolu_vrtx_01Txe5hZ2YTr8GgXJopyjsT2","session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"533daaa1-7254-4907-ad60-be2abf86801b","timestamp":"2026-03-22T06:33:21.061Z"}
