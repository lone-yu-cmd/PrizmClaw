{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_017SJ1cQcjNQQPLxMGu5FgaF","type":"tool_result","content":"     1→import { readFile, writeFile, mkdir } from 'node:fs/promises';\n     2→import path from 'node:path';\n     3→import { config } from '../config.js';\n     4→import { logger } from '../utils/logger.js';\n     5→\n     6→const BINDINGS_FILE = 'session-bindings.json';\n     7→\n     8→class SessionBindingService {\n     9→  #bindings = null; // Map: webSessionId -> telegramChatId\n    10→  #reverseBindings = null; // Map: telegramChatId -> Set<webSessionId>\n    11→  #initialized = false;\n    12→  #persistencePath;\n    13→\n    14→  constructor({ persistenceDir = config.sessionPersistenceDir } = {}) {\n    15→    this.#persistencePath = path.join(persistenceDir, BINDINGS_FILE);\n    16→  }\n    17→\n    18→  async init() {\n    19→    if (this.#initialized) {\n    20→      return;\n    21→    }\n    22→\n    23→    try {\n    24→      const data = await readFile(this.#persistencePath, 'utf-8');\n    25→      const parsed = JSON.parse(data);\n    26→      this.#bindings = new Map(Object.entries(parsed.bindings || {}));\n    27→      this.#reverseBindings = new Map();\n    28→\n    29→      // Build reverse index\n    30→      for (const [webSessionId, telegramChatId] of this.#bindings.entries()) {\n    31→        if (!this.#reverseBindings.has(telegramChatId)) {\n    32→          this.#reverseBindings.set(telegramChatId, new Set());\n    33→        }\n    34→        this.#reverseBindings.get(telegramChatId).add(webSessionId);\n    35→      }\n    36→\n    37→      logger.info(\n    38→        { bindingsCount: this.#bindings.size },\n    39→        'Session bindings loaded'\n    40→      );\n    41→    } catch (error) {\n    42→      if (error.code === 'ENOENT') {\n    43→        // File doesn't exist, create directory if needed\n    44→        await mkdir(path.dirname(this.#persistencePath), { recursive: true });\n    45→        this.#bindings = new Map();\n    46→        this.#reverseBindings = new Map();\n    47→        await this.#persist();\n    48→        logger.info('Session bindings file created');\n    49→      } else {\n    50→        logger.warn({ err: error.message }, 'Failed to load session bindings, starting empty');\n    51→        this.#bindings = new Map();\n    52→        this.#reverseBindings = new Map();\n    53→      }\n    54→    }\n    55→\n    56→    this.#initialized = true;\n    57→  }\n    58→\n    59→  async #persist() {\n    60→    try {\n    61→      const serialized = {\n    62→        bindings: Object.fromEntries(this.#bindings),\n    63→        updatedAt: new Date().toISOString()\n    64→      };\n    65→      await writeFile(\n    66→        this.#persistencePath,\n    67→        JSON.stringify(serialized, null, 2)\n    68→      );\n    69→    } catch (error) {\n    70→      logger.error({ err: error.message }, 'Failed to persist session bindings');\n    71→    }\n    72→  }\n    73→\n    74→  bindSession(webSessionId, telegramChatId) {\n    75→    if (!this.#initialized) {\n    76→      throw new Error('SessionBindingService not initialized. Call init() first.');\n    77→    }\n    78→\n    79→    const normalizedWebId = String(webSessionId).trim();\n    80→    const normalizedChatId = String(telegramChatId).trim();\n    81→\n    82→    if (!normalizedWebId) {\n    83→      throw new Error('webSessionId cannot be empty');\n    84→    }\n    85→\n    86→    if (!normalizedChatId) {\n    87→      throw new Error('telegramChatId cannot be empty');\n    88→    }\n    89→\n    90→    // Remove any existing binding for this web session\n    91→    if (this.#bindings.has(normalizedWebId)) {\n    92→      const oldChatId = this.#bindings.get(normalizedWebId);\n    93→      this.#reverseBindings.get(oldChatId)?.delete(normalizedWebId);\n    94→    }\n    95→\n    96→    // Create new binding\n    97→    this.#bindings.set(normalizedWebId, normalizedChatId);\n    98→\n    99→    // Update reverse index\n   100→    if (!this.#reverseBindings.has(normalizedChatId)) {\n   101→      this.#reverseBindings.set(normalizedChatId, new Set());\n   102→    }\n   103→    this.#reverseBindings.get(normalizedChatId).add(normalizedWebId);\n   104→\n   105→    this.#persist();\n   106→\n   107→    logger.info(\n   108→      { webSessionId: normalizedWebId, telegramChatId: normalizedChatId },\n   109→      'Session bound to Telegram chat'\n   110→    );\n   111→\n   112→    return { ok: true };\n   113→  }\n   114→\n   115→  unbindSession(webSessionId) {\n   116→    if (!this.#initialized) {\n   117→      throw new Error('SessionBindingService not initialized. Call init() first.');\n   118→    }\n   119→\n   120→    const normalizedWebId = String(webSessionId).trim();\n   121→\n   122→    if (!normalizedWebId) {\n   123→      throw new Error('webSessionId cannot be empty');\n   124→    }\n   125→\n   126→    if (!this.#bindings.has(normalizedWebId)) {\n   127→      return { ok: false, error: 'No binding found for this session' };\n   128→    }\n   129→\n   130→    const telegramChatId = this.#bindings.get(normalizedWebId);\n   131→    this.#bindings.delete(normalizedWebId);\n   132→\n   133→    // Update reverse index\n   134→    this.#reverseBindings.get(telegramChatId)?.delete(normalizedWebId);\n   135→\n   136→    this.#persist();\n   137→\n   138→    logger.info(\n   139→      { webSessionId: normalizedWebId },\n   140→      'Session unbound from Telegram chat'\n   141→    );\n   142→\n   143→    return { ok: true };\n   144→  }\n   145→\n   146→  getBoundChatId(webSessionId) {\n   147→    if (!this.#initialized) {\n   148→      throw new Error('SessionBindingService not initialized. Call init() first.');\n   149→    }\n   150→\n   151→    const normalizedWebId = String(webSessionId).trim();\n   152→    return this.#bindings.get(normalizedWebId) || null;\n   153→  }\n   154→\n   155→  getBoundWebSessions(telegramChatId) {\n   156→    if (!this.#initialized) {\n   157→      throw new Error('SessionBindingService not initialized. Call init() first.');\n   158→    }\n   159→\n   160→    const normalizedChatId = String(telegramChatId).trim();\n   161→    const sessions = this.#reverseBindings.get(normalizedChatId);\n   162→    return sessions ? Array.from(sessions) : [];\n   163→  }\n   164→\n   165→  getAllBindings() {\n   166→    if (!this.#initialized) {\n   167→      throw new Error('SessionBindingService not initialized. Call init() first.');\n   168→    }\n   169→\n   170→    return Object.fromEntries(this.#bindings);\n   171→  }\n   172→\n   173→  clearAllBindings() {\n   174→    if (!this.#initialized) {\n   175→      throw new Error('SessionBindingService not initialized. Call init() first.');\n   176→    }\n   177→\n   178→    this.#bindings.clear();\n   179→    this.#reverseBindings.clear();\n   180→    this.#persist();\n   181→\n   182→    logger.info('All session bindings cleared');\n   183→\n   184→    return { ok: true };\n   185→  }\n   186→}\n   187→\n   188→/**\n   189→ * Factory function to create and auto-initialize a SessionBindingService instance.\n   190→ * Matches the import pattern expected by server.js.\n   191→ *\n   192→ * @param {Object} [options]\n   193→ * @param {string} [options.bindingsPath] - Full path to the bindings JSON file.\n   194→ *   If provided, persistenceDir is derived from its directory.\n   195→ * @param {string} [options.persistenceDir] - Directory for persistence (used if bindingsPath not provided).\n   196→ * @returns {SessionBindingService} An initialized SessionBindingService instance\n   197→ */\n   198→export function createSessionBindService({ bindingsPath, persistenceDir } = {}) {\n   199→  const opts = {};\n   200→  if (bindingsPath) {\n   201→    opts.persistenceDir = path.dirname(bindingsPath);\n   202→  } else if (persistenceDir) {\n   203→    opts.persistenceDir = persistenceDir;\n   204→  }\n   205→\n   206→  const service = new SessionBindingService(opts);\n   207→\n   208→  // Auto-initialize (fire-and-forget; callers who need guaranteed init should await service.init())\n   209→  service.init().catch((err) => {\n   210→    logger.error({ err: err.message }, 'Failed to auto-initialize SessionBindingService');\n   211→  });\n   212→\n   213→  return service;\n   214→}\n   215→\n   216→export const sessionBindingService = new SessionBindingService();\n   217→export { SessionBindingService };\n   218→"}]},"parent_tool_use_id":"toolu_vrtx_01Txe5hZ2YTr8GgXJopyjsT2","session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"27639e77-0a96-45f6-b6d3-c3b2816eca22","timestamp":"2026-03-22T06:29:21.123Z"}
