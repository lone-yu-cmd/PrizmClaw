{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01UQ4LH4cx1t3g6uroU8qVAm","type":"tool_result","content":"     1→import { Router } from 'express';\n     2→import { buildSessionContext, resetSession } from '../services/chat-service.js';\n     3→import { captureScreenshot } from '../services/screenshot-service.js';\n     4→import { executeSystemCommand } from '../services/system-exec-service.js';\n     5→\n     6→function writeSseEvent(res, event, payload) {\n     7→  res.write(`event: ${event}\\n`);\n     8→  res.write(`data: ${JSON.stringify(payload)}\\n\\n`);\n     9→}\n    10→\n    11→export function createApiRouter({ realtimeHub, sessionBind, messageRouter, sessionStore }) {\n    12→  const router = Router();\n    13→\n    14→  // F-018: Session binding endpoints\n    15→  router.post('/bind', (req, res, next) => {\n    16→    try {\n    17→      const { webSessionId, telegramChatId } = req.body ?? {};\n    18→\n    19→      if (!webSessionId || !telegramChatId) {\n    20→        return res.status(400).json({ ok: false, error: 'webSessionId and telegramChatId are required' });\n    21→      }\n    22→\n    23→      sessionBind.bindSession(webSessionId, telegramChatId);\n    24→\n    25→      res.json({ ok: true });\n    26→    } catch (error) {\n    27→      next(error);\n    28→    }\n    29→  });\n    30→\n    31→  router.post('/unbind', (req, res, next) => {\n    32→    try {\n    33→      const { webSessionId } = req.body ?? {};\n    34→\n    35→      if (!webSessionId) {\n    36→        return res.status(400).json({ ok: false, error: 'webSessionId is required' });\n    37→      }\n    38→\n    39→      sessionBind.unbindSession(webSessionId);\n    40→\n    41→      res.json({ ok: true });\n    42→    } catch (error) {\n    43→      next(error);\n    44→    }\n    45→  });\n    46→\n    47→  router.get('/bindings', (req, res, next) => {\n    48→    try {\n    49→      const { webSessionId } = req.query;\n    50→\n    51→      if (webSessionId) {\n    52→        const telegramChatId = sessionBind.getBoundChatId(webSessionId);\n    53→        res.json({ ok: true, telegramChatId });\n    54→      } else {\n    55→        const allBindings = sessionBind.getAllBindings();\n    56→        res.json({ ok: true, bindings: allBindings });\n    57→      }\n    58→    } catch (error) {\n    59→      next(error);\n    60→    }\n    61→  });\n    62→\n    63→  // SSE events endpoint - support Telegram-bound sessions\n    64→  router.get('/events', (req, res, next) => {\n    65→    try {\n    66→      const { channel = 'web', sessionId, telegramChatId } = req.query;\n    67→\n    68→      let sessionKey;\n    69→      if (telegramChatId) {\n    70→        sessionKey = `telegram:${telegramChatId}`;\n    71→      } else {\n    72→        const session = buildSessionContext(channel, sessionId);\n    73→        sessionKey = session.sessionKey;\n    74→      }\n    75→\n    76→      res.setHeader('Content-Type', 'text/event-stream');\n    77→      res.setHeader('Cache-Control', 'no-cache');\n    78→      res.setHeader('Connection', 'keep-alive');\n    79→      res.flushHeaders?.();\n    80→\n    81→      writeSseEvent(res, 'connected', {\n    82→        ok: true,\n    83→        channel,\n    84→        sessionId,\n    85→        sessionKey\n    86→      });\n    87→\n    88→      // F-018: Replay message history for offline clients (T4.2)\n    89→      const existingMessages = sessionStore.get(sessionKey);\n    90→      for (const msg of existingMessages) {\n    91→        writeSseEvent(res, msg.role === 'user' ? 'user_message' : 'assistant_message', {\n    92→          role: msg.role,\n    93→          content: msg.content,\n    94→          replay: true\n    95→        });\n    96→      }\n    97→\n    98→      const unsubscribe = realtimeHub.subscribe(sessionKey, (event) => {\n    99→        writeSseEvent(res, event.type, event.payload);\n   100→      });\n   101→\n   102→      const heartbeat = setInterval(() => {\n   103→        res.write(': ping\\n\\n');\n   104→      }, 20000);\n   105→\n   106→      req.on('close', () => {\n   107→        clearInterval(heartbeat);\n   108→        unsubscribe();\n   109→      });\n   110→    } catch (error) {\n   111→      next(error);\n   112→    }\n   113→  });\n   114→\n   115→  // F-018: Modified /api/chat to use message-router and support Telegram binding\n   116→  router.post('/chat', async (req, res, next) => {\n   117→    try {\n   118→      const { channel = 'web', sessionId, message, telegramChatId } = req.body ?? {};\n   119→\n   120→      let effectiveTelegramChatId = telegramChatId;\n   121→\n   122→      // If no telegramChatId provided but session is bound, use the bound chat ID\n   123→      if (!effectiveTelegramChatId) {\n   124→        effectiveTelegramChatId = sessionBind.getBoundChatId(sessionId);\n   125→      }\n   126→\n   127→      const result = await messageRouter.processMessage({\n   128→        channel,\n   129→        sessionId,\n   130→        message,\n   131→        telegramChatId: effectiveTelegramChatId,\n   132→        hooks: {\n   133→          onStatus: (payload) => {\n   134→            // Status events are already published by message-router\n   135→          },\n   136→          onAssistantChunk: (data) => {\n   137→            // Chunk events are already published by message-router\n   138→          },\n   139→          onAssistantDone: (data) => {\n   140→            // Done events are already published by message-router\n   141→          }\n   142→        }\n   143→      });\n   144→\n   145→      res.json({ ok: true, reply: result.reply });\n   146→    } catch (error) {\n   147→      next(error);\n   148→    }\n   149→  });\n   150→\n   151→  router.post('/chat/reset', async (req, res, next) => {\n   152→    try {\n   153→      const { channel = 'web', sessionId, telegramChatId } = req.body ?? {};\n   154→\n   155→      let sessionKey;\n   156→      let effectiveTelegramChatId;\n   157→\n   158→      if (telegramChatId) {\n   159→        sessionKey = `telegram:${telegramChatId}`;\n   160→      } else if (channel === 'web' && sessionId) {\n   161→        effectiveTelegramChatId = sessionBind.getBoundChatId(sessionId);\n   162→        if (effectiveTelegramChatId) {\n   163→          sessionKey = `telegram:${effectiveTelegramChatId}`;\n   164→        } else {\n   165→          resetSession({ channel, sessionId });\n   166→          return res.json({ ok: true });\n   167→        }\n   168→      } else {\n   169→        resetSession({ channel, sessionId });\n   170→        return res.json({ ok: true });\n   171→      }\n   172→\n   173→      sessionStore.clear(sessionKey);\n   174→      res.json({ ok: true });\n   175→    } catch (error) {\n   176→      next(error);\n   177→    }\n   178→  });\n   179→\n   180→  router.post('/screenshot', async (_req, res, next) => {\n   181→    try {\n   182→      const { mimeType, imageBase64 } = await captureScreenshot();\n   183→      res.json({ ok: true, mimeType, imageBase64 });\n   184→    } catch (error) {\n   185→      next(error);\n   186→    }\n   187→  });\n   188→\n   189→  router.post('/system/exec', async (req, res, next) => {\n   190→    try {\n   191→      const { command } = req.body ?? {};\n   192→      const result = await executeSystemCommand(command);\n   193→      res.json({ ok: true, ...result });\n   194→    } catch (error) {\n   195→      next(error);\n   196→    }\n   197→  });\n   198→\n   199→  return router;\n   200→}\n   201→"}]},"parent_tool_use_id":"toolu_vrtx_01Txe5hZ2YTr8GgXJopyjsT2","session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"9bc5e213-2c24-4ed4-bcf5-964179da79f1","timestamp":"2026-03-22T06:33:59.602Z"}
