{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01CmB53T3RnHpVCCUeZVT9Zz","type":"tool_result","content":"     1→/**\n     2→ * Tests for F-018 Session Binding Service\n     3→ * Task 1.2: Unit tests for session-bind.js\n     4→ */\n     5→\n     6→import { describe, test, beforeEach, afterEach } from 'node:test';\n     7→import assert from 'node:assert/strict';\n     8→import { rm, mkdir, readFile } from 'node:fs/promises';\n     9→import path from 'node:path';\n    10→import { fileURLToPath } from 'node:url';\n    11→\n    12→const __dirname = path.dirname(fileURLToPath(import.meta.url));\n    13→const testFixturesDir = path.join(__dirname, 'fixtures/session-bind-f018');\n    14→\n    15→describe('F-018 Session Binding Service', () => {\n    16→  let sessionBindingService;\n    17→  let SessionBindingService;\n    18→\n    19→  beforeEach(async () => {\n    20→    // Clean up test fixtures directory\n    21→    await rm(testFixturesDir, { recursive: true, force: true });\n    22→    await mkdir(testFixturesDir, { recursive: true });\n    23→\n    24→    // Import module after cleaning\n    25→    const module = await import('../../src/services/session-bind.js');\n    26→    SessionBindingService = module.SessionBindingService;\n    27→\n    28→    // Create new instance with test persistence dir\n    29→    sessionBindingService = new SessionBindingService({\n    30→      persistenceDir: testFixturesDir\n    31→    });\n    32→  });\n    33→\n    34→  afterEach(async () => {\n    35→    // Clean up test directory\n    36→    await rm(testFixturesDir, { recursive: true, force: true });\n    37→  });\n    38→\n    39→  describe('init', () => {\n    40→    test('should initialize and create empty bindings file', async () => {\n    41→      await sessionBindingService.init();\n    42→\n    43→      const bindingsFile = path.join(testFixturesDir, 'session-bindings.json');\n    44→      const data = await readFile(bindingsFile, 'utf-8');\n    45→      const parsed = JSON.parse(data);\n    46→\n    47→      assert.ok(parsed.bindings);\n    48→      assert.strictEqual(Object.keys(parsed.bindings).length, 0);\n    49→      assert.ok(parsed.updatedAt);\n    50→    });\n    51→\n    52→    test('should load existing bindings from persistence', async () => {\n    53→      // Pre-create bindings file\n    54→      const existingData = {\n    55→        bindings: {\n    56→          'web-session-1': '123456789',\n    57→          'web-session-2': '987654321'\n    58→        },\n    59→        updatedAt: new Date().toISOString()\n    60→      };\n    61→      const bindingsFile = path.join(testFixturesDir, 'session-bindings.json');\n    62→      const { writeFile } = await import('node:fs/promises');\n    63→      await writeFile(bindingsFile, JSON.stringify(existingData));\n    64→\n    65→      await sessionBindingService.init();\n    66→\n    67→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '123456789');\n    68→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-2'), '987654321');\n    69→    });\n    70→  });\n    71→\n    72→  describe('bindSession', () => {\n    73→    test('should throw error if not initialized', async () => {\n    74→      assert.rejects(\n    75→        () => sessionBindingService.bindSession('web-1', '123456'),\n    76→        /not initialized/\n    77→      );\n    78→    });\n    79→\n    80→    test('should throw error if webSessionId is empty', async () => {\n    81→      await sessionBindingService.init();\n    82→\n    83→      assert.rejects(\n    84→        () => sessionBindingService.bindSession('', '123456'),\n    85→        /webSessionId cannot be empty/\n    86→      );\n    87→\n    88→      assert.rejects(\n    89→        () => sessionBindingService.bindSession('  ', '123456'),\n    90→        /webSessionId cannot be empty/\n    91→      );\n    92→    });\n    93→\n    94→    test('should throw error if telegramChatId is empty', async () => {\n    95→      await sessionBindingService.init();\n    96→\n    97→      assert.rejects(\n    98→        () => sessionBindingService.bindSession('web-1', ''),\n    99→        /telegramChatId cannot be empty/\n   100→      );\n   101→    });\n   102→\n   103→    test('should bind session to Telegram chat', async () => {\n   104→      await sessionBindingService.init();\n   105→\n   106→      const result = sessionBindingService.bindSession('web-session-1', '123456789');\n   107→\n   108→      assert.strictEqual(result.ok, true);\n   109→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '123456789');\n   110→    });\n   111→\n   112→    test('should persist binding to file', async () => {\n   113→      await sessionBindingService.init();\n   114→      sessionBindingService.bindSession('web-session-1', '123456789');\n   115→\n   116→      // Create new instance to verify persistence\n   117→      const newService = new SessionBindingService({\n   118→        persistenceDir: testFixturesDir\n   119→      });\n   120→      await newService.init();\n   121→\n   122→      assert.strictEqual(newService.getBoundChatId('web-session-1'), '123456789');\n   123→    });\n   124→\n   125→    test('should overwrite existing binding for same web session', async () => {\n   126→      await sessionBindingService.init();\n   127→      sessionBindingService.bindSession('web-session-1', '123456789');\n   128→      sessionBindingService.bindSession('web-session-1', '987654321');\n   129→\n   130→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '987654321');\n   131→      assert.deepStrictEqual(sessionBindingService.getBoundWebSessions('123456789'), []);\n   132→    });\n   133→  });\n   134→\n   135→  describe('unbindSession', () => {\n   136→    test('should throw error if not initialized', async () => {\n   137→      assert.rejects(\n   138→        () => sessionBindingService.unbindSession('web-1'),\n   139→        /not initialized/\n   140→      );\n   141→    });\n   142→\n   143→    test('should return error if no binding exists', async () => {\n   144→      await sessionBindingService.init();\n   145→\n   146→      const result = sessionBindingService.unbindSession('non-existent');\n   147→      assert.strictEqual(result.ok, false);\n   148→      assert.ok(result.error.includes('No binding found'));\n   149→    });\n   150→\n   151→    test('should unbind existing session', async () => {\n   152→      await sessionBindingService.init();\n   153→      sessionBindingService.bindSession('web-session-1', '123456789');\n   154→\n   155→      const result = sessionBindingService.unbindSession('web-session-1');\n   156→\n   157→      assert.strictEqual(result.ok, true);\n   158→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), null);\n   159→    });\n   160→\n   161→    test('should update reverse bindings on unbind', async () => {\n   162→      await sessionBindingService.init();\n   163→      sessionBindingService.bindSession('web-1', '123456');\n   164→      sessionBindingService.bindSession('web-2', '123456');\n   165→\n   166→      assert.deepStrictEqual(\n   167→        new Set(sessionBindingService.getBoundWebSessions('123456')),\n   168→        new Set(['web-1', 'web-2'])\n   169→      );\n   170→\n   171→      sessionBindingService.unbindSession('web-1');\n   172→\n   173→      assert.deepStrictEqual(\n   174→        sessionBindingService.getBoundWebSessions('123456'),\n   175→        ['web-2']\n   176→      );\n   177→    });\n   178→  });\n   179→\n   180→  describe('getBoundChatId', () => {\n   181→    test('should throw error if not initialized', async () => {\n   182→      assert.rejects(\n   183→        () => sessionBindingService.getBoundChatId('web-1'),\n   184→        /not initialized/\n   185→      );\n   186→    });\n   187→\n   188→    test('should return null for non-existent binding', async () => {\n   189→      await sessionBindingService.init();\n   190→\n   191→      assert.strictEqual(sessionBindingService.getBoundChatId('non-existent'), null);\n   192→    });\n   193→\n   194→    test('should return correct chat ID for bound session', async () => {\n   195→      await sessionBindingService.init();\n   196→      sessionBindingService.bindSession('web-1', '123456');\n   197→\n   198→      assert.strictEqual(sessionBindingService.getBoundChatId('web-1'), '123456');\n   199→    });\n   200→  });\n   201→\n   202→  describe('getBoundWebSessions', () => {\n   203→    test('should throw error if not initialized', async () => {\n   204→      assert.rejects(\n   205→        () => sessionBindingService.getBoundWebSessions('123456'),\n   206→        /not initialized/\n   207→      );\n   208→    });\n   209→\n   210→    test('should return empty array for chat with no bindings', async () => {\n   211→      await sessionBindingService.init();\n   212→\n   213→      assert.deepStrictEqual(sessionBindingService.getBoundWebSessions('123456'), []);\n   214→    });\n   215→\n   216→    test('should return all web sessions bound to a chat ID', async () => {\n   217→      await sessionBindingService.init();\n   218→      sessionBindingService.bindSession('web-1', '123456');\n   219→      sessionBindingService.bindSession('web-2', '123456');\n   220→      sessionBindingService.bindSession('web-3', '789012');\n   221→\n   222→      const sessions = sessionBindingService.getBoundWebSessions('123456');\n   223→      assert.ok(sessions.includes('web-1'));\n   224→      assert.ok(sessions.includes('web-2'));\n   225→      assert.strictEqual(sessions.length, 2);\n   226→    });\n   227→  });\n   228→\n   229→  describe('getAllBindings', () => {\n   230→    test('should throw error if not initialized', async () => {\n   231→      assert.rejects(\n   232→        () => sessionBindingService.getAllBindings(),\n   233→        /not initialized/\n   234→      );\n   235→    });\n   236→\n   237→    test('should return all bindings as object', async () => {\n   238→      await sessionBindingService.init();\n   239→      sessionBindingService.bindSession('web-1', '123456');\n   240→      sessionBindingService.bindSession('web-2', '789012');\n   241→\n   242→      const all = sessionBindingService.getAllBindings();\n   243→\n   244→      assert.strictEqual(all['web-1'], '123456');\n   245→      assert.strictEqual(all['web-2'], '789012');\n   246→      assert.strictEqual(Object.keys(all).length, 2);\n   247→    });\n   248→  });\n   249→\n   250→  describe('clearAllBindings', () => {\n   251→    test('should throw error if not initialized', async () => {\n   252→      assert.rejects(\n   253→        () => sessionBindingService.clearAllBindings(),\n   254→        /not initialized/\n   255→      );\n   256→    });\n   257→\n   258→    test('should clear all bindings', async () => {\n   259→      await sessionBindingService.init();\n   260→      sessionBindingService.bindSession('web-1', '123456');\n   261→      sessionBindingService.bindSession('web-2', '789012');\n   262→\n   263→      const result = sessionBindingService.clearAllBindings();\n   264→\n   265→      assert.strictEqual(result.ok, true);\n   266→      assert.strictEqual(sessionBindingService.getBoundChatId('web-1'), null);\n   267→      assert.strictEqual(sessionBindingService.getBoundChatId('web-2'), null);\n   268→    });\n   269→  });\n   270→});\n   271→"}]},"parent_tool_use_id":null,"session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"1a575210-868a-4516-b6b5-1f0724bac861","timestamp":"2026-03-22T06:24:51.249Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/session-bind-f018.test.js","content":"/**\n * Tests for F-018 Session Binding Service\n * Task 1.2: Unit tests for session-bind.js\n */\n\nimport { describe, test, beforeEach, afterEach } from 'node:test';\nimport assert from 'node:assert/strict';\nimport { rm, mkdir, readFile } from 'node:fs/promises';\nimport path from 'node:path';\nimport { fileURLToPath } from 'node:url';\n\nconst __dirname = path.dirname(fileURLToPath(import.meta.url));\nconst testFixturesDir = path.join(__dirname, 'fixtures/session-bind-f018');\n\ndescribe('F-018 Session Binding Service', () => {\n  let sessionBindingService;\n  let SessionBindingService;\n\n  beforeEach(async () => {\n    // Clean up test fixtures directory\n    await rm(testFixturesDir, { recursive: true, force: true });\n    await mkdir(testFixturesDir, { recursive: true });\n\n    // Import module after cleaning\n    const module = await import('../../src/services/session-bind.js');\n    SessionBindingService = module.SessionBindingService;\n\n    // Create new instance with test persistence dir\n    sessionBindingService = new SessionBindingService({\n      persistenceDir: testFixturesDir\n    });\n  });\n\n  afterEach(async () => {\n    // Clean up test directory\n    await rm(testFixturesDir, { recursive: true, force: true });\n  });\n\n  describe('init', () => {\n    test('should initialize and create empty bindings file', async () => {\n      await sessionBindingService.init();\n\n      const bindingsFile = path.join(testFixturesDir, 'session-bindings.json');\n      const data = await readFile(bindingsFile, 'utf-8');\n      const parsed = JSON.parse(data);\n\n      assert.ok(parsed.bindings);\n      assert.strictEqual(Object.keys(parsed.bindings).length, 0);\n      assert.ok(parsed.updatedAt);\n    });\n\n    test('should load existing bindings from persistence', async () => {\n      // Pre-create bindings file\n      const existingData = {\n        bindings: {\n          'web-session-1': '123456789',\n          'web-session-2': '987654321'\n        },\n        updatedAt: new Date().toISOString()\n      };\n      const bindingsFile = path.join(testFixturesDir, 'session-bindings.json');\n      const { writeFile } = await import('node:fs/promises');\n      await writeFile(bindingsFile, JSON.stringify(existingData));\n\n      await sessionBindingService.init();\n\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '123456789');\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-2'), '987654321');\n    });\n  });\n\n  describe('bindSession', () => {\n    test('should throw error if not initialized', async () => {\n      assert.rejects(\n        () => sessionBindingService.bindSession('web-1', '123456'),\n        /not initialized/\n      );\n    });\n\n    test('should throw error if webSessionId is empty', async () => {\n      await sessionBindingService.init();\n\n      assert.rejects(\n        () => sessionBindingService.bindSession('', '123456'),\n        /webSessionId cannot be empty/\n      );\n\n      assert.rejects(\n        () => sessionBindingService.bindSession('  ', '123456'),\n        /webSessionId cannot be empty/\n      );\n    });\n\n    test('should throw error if telegramChatId is empty', async () => {\n      await sessionBindingService.init();\n\n      assert.rejects(\n        () => sessionBindingService.bindSession('web-1', ''),\n        /telegramChatId cannot be empty/\n      );\n    });\n\n    test('should bind session to Telegram chat', async () => {\n      await sessionBindingService.init();\n\n      const result = sessionBindingService.bindSession('web-session-1', '123456789');\n\n      assert.strictEqual(result.ok, true);\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '123456789');\n    });\n\n    test('should persist binding to file', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-session-1', '123456789');\n\n      // Create new instance to verify persistence\n      const newService = new SessionBindingService({\n        persistenceDir: testFixturesDir\n      });\n      await newService.init();\n\n      assert.strictEqual(newService.getBoundChatId('web-session-1'), '123456789');\n    });\n\n    test('should overwrite existing binding for same web session', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-session-1', '123456789');\n      sessionBindingService.bindSession('web-session-1', '987654321');\n\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '987654321');\n      assert.deepStrictEqual(sessionBindingService.getBoundWebSessions('123456789'), []);\n    });\n  });\n\n  describe('unbindSession', () => {\n    test('should throw error if not initialized', async () => {\n      assert.rejects(\n        () => sessionBindingService.unbindSession('web-1'),\n        /not initialized/\n      );\n    });\n\n    test('should return error if no binding exists', async () => {\n      await sessionBindingService.init();\n\n      const result = sessionBindingService.unbindSession('non-existent');\n      assert.strictEqual(result.ok, false);\n      assert.ok(result.error.includes('No binding found'));\n    });\n\n    test('should unbind existing session', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-session-1', '123456789');\n\n      const result = sessionBindingService.unbindSession('web-session-1');\n\n      assert.strictEqual(result.ok, true);\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), null);\n    });\n\n    test('should update reverse bindings on unbind', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-1', '123456');\n      sessionBindingService.bindSession('web-2', '123456');\n\n      assert.deepStrictEqual(\n        new Set(sessionBindingService.getBoundWebSessions('123456')),\n        new Set(['web-1', 'web-2'])\n      );\n\n      sessionBindingService.unbindSession('web-1');\n\n      assert.deepStrictEqual(\n        sessionBindingService.getBoundWebSessions('123456'),\n        ['web-2']\n      );\n    });\n  });\n\n  describe('getBoundChatId', () => {\n    test('should throw error if not initialized', async () => {\n      assert.rejects(\n        () => sessionBindingService.getBoundChatId('web-1'),\n        /not initialized/\n      );\n    });\n\n    test('should return null for non-existent binding', async () => {\n      await sessionBindingService.init();\n\n      assert.strictEqual(sessionBindingService.getBoundChatId('non-existent'), null);\n    });\n\n    test('should return correct chat ID for bound session', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-1', '123456');\n\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-1'), '123456');\n    });\n  });\n\n  describe('getBoundWebSessions', () => {\n    test('should throw error if not initialized', async () => {\n      assert.rejects(\n        () => sessionBindingService.getBoundWebSessions('123456'),\n        /not initialized/\n      );\n    });\n\n    test('should return empty array for chat with no bindings', async () => {\n      await sessionBindingService.init();\n\n      assert.deepStrictEqual(sessionBindingService.getBoundWebSessions('123456'), []);\n    });\n\n    test('should return all web sessions bound to a chat ID', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-1', '123456');\n      sessionBindingService.bindSession('web-2', '123456');\n      sessionBindingService.bindSession('web-3', '789012');\n\n      const sessions = sessionBindingService.getBoundWebSessions('123456');\n      assert.ok(sessions.includes('web-1'));\n      assert.ok(sessions.includes('web-2'));\n      assert.strictEqual(sessions.length, 2);\n    });\n  });\n\n  describe('getAllBindings', () => {\n    test('should throw error if not initialized', async () => {\n      assert.rejects(\n        () => sessionBindingService.getAllBindings(),\n        /not initialized/\n      );\n    });\n\n    test('should return all bindings as object', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-1', '123456');\n      sessionBindingService.bindSession('web-2', '789012');\n\n      const all = sessionBindingService.getAllBindings();\n\n      assert.strictEqual(all['web-1'], '123456');\n      assert.strictEqual(all['web-2'], '789012');\n      assert.strictEqual(Object.keys(all).length, 2);\n    });\n  });\n\n  describe('clearAllBindings', () => {\n    test('should throw error if not initialized', async () => {\n      assert.rejects(\n        () => sessionBindingService.clearAllBindings(),\n        /not initialized/\n      );\n    });\n\n    test('should clear all bindings', async () => {\n      await sessionBindingService.init();\n      sessionBindingService.bindSession('web-1', '123456');\n      sessionBindingService.bindSession('web-2', '789012');\n\n      const result = sessionBindingService.clearAllBindings();\n\n      assert.strictEqual(result.ok, true);\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-1'), null);\n      assert.strictEqual(sessionBindingService.getBoundChatId('web-2'), null);\n    });\n  });\n});\n","numLines":271,"startLine":1,"totalLines":271}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01WkJwiBGTdY21quv1qNHNmX","type":"tool_result","content":"     1→/**\n     2→ * Message Router Unit Tests\n     3→ * Tests for src/services/message-router.js\n     4→ *\n     5→ * F-018: Web-Telegram Bidirectional Sync\n     6→ */\n     7→\n     8→import test from 'node:test';\n     9→import assert from 'node:assert/strict';\n    10→\n    11→import { sessionStore } from '../../src/services/session-store.js';\n    12→import { createMessageRouter } from '../../src/services/message-router.js';\n    13→\n    14→// Mock dependencies\n    15→const mockSessionStore = {\n    16→  append: test.mock.fn(),\n    17→  get: test.mock.fn(() => []),\n    18→  clear: test.mock.fn(),\n    19→  toPrompt: test.mock.fn(() => 'Mock prompt: you are an AI assistant. 用户: hello world\\n助手: previous context\\n')\n    20→};\n    21→\n    22→const mockExecuteAiCli = test.mock.fn(async (options) => {\n    23→  return {\n    24→    output: `AI response to: ${options.prompt}`,\n    25→    timedOut: false,\n    26→    interrupted: false,\n    27→    elapsedMs: 100,\n    28→    exitCode: 0,\n    29→    stderr: ''\n    30→  };\n    31→});\n    32→\n    33→const mockRealtimeHub = {\n    34→  publish: test.mock.fn(),\n    35→  subscribe: test.mock.fn(() => () => {})\n    36→};\n    37→\n    38→/**\n    39→ * Helper to create a message router with mocks\n    40→ */\n    41→function createRouter(options = {}) {\n    42→  return createMessageRouter({\n    43→    aiCliExecutor: options.aiCliExecutor || mockExecuteAiCli,\n    44→    sessionStore: options.sessionStore || mockSessionStore,\n    45→    realtimeHub: options.realtimeHub || mockRealtimeHub\n    46→  });\n    47→}\n    48→\n    49→test('message-router: processMessage uses unified sessionKey when telegramChatId bound', async () => {\n    50→  const router = createRouter();\n    51→\n    52→  await router.processMessage({\n    53→    channel: 'web',\n    54→    sessionId: 'web-session-123',\n    55→    telegramChatId: '456',\n    56→    message: 'test message',\n    57→    userId: 'user-123'\n    58→  });\n    59→\n    60→  // Should use telegram:{chatId} as session key\n    61→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'telegram:456');\n    62→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[1], 'user');\n    63→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[2], 'test message');\n    64→\n    65→  // Should call executeAiCli with telegram session key\n    66→  assert.strictEqual(mockExecuteAiCli.mock.calls[0].arguments[0].sessionId, 'telegram:456');\n    67→});\n    68→\n    69→test('message-router: processMessage uses web sessionKey when no telegramChatId', async () => {\n    70→  const router = createRouter();\n    71→\n    72→  await router.processMessage({\n    73→    channel: 'web',\n    74→    sessionId: 'web-session-123',\n    75→    message: 'test message',\n    76→    userId: 'user-123'\n    77→  });\n    78→\n    79→  // Should use web:{sessionId} as session key for isolated session\n    80→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'web:web-session-123');\n    81→});\n    82→\n    83→test('message-router: processMessage calls executeAiCli with message', async () => {\n    84→  const router = createRouter();\n    85→\n    86→  await router.processMessage({\n    87→    channel: 'web',\n    88→    sessionId: 'web-session-123',\n    89→    message: 'hello world',\n    90→    userId: 'user-123'\n    91→  });\n    92→\n    93→  assert.strictEqual(mockExecuteAiCli.mock.calls.length, 1);\n    94→  const callArgs = mockExecuteAiCli.mock.calls[0].arguments[0];\n    95→  assert.ok(callArgs.prompt.includes('hello world'));\n    96→});\n    97→\n    98→test('message-router: processMessage appends user message to sessionStore', async () => {\n    99→  const router = createRouter();\n   100→\n   101→  await router.processMessage({\n   102→    channel: 'telegram',\n   103→    sessionId: '456',\n   104→    message: 'user question',\n   105→    userId: 'user-123'\n   106→  });\n   107→\n   108→  assert.strictEqual(mockSessionStore.append.mock.calls.length, 2); // user + assistant\n   109→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'telegram:456');\n   110→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[1], 'user');\n   111→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[2], 'user question');\n   112→});\n   113→\n   114→test('message-router: processMessage appends assistant reply to sessionStore', async () => {\n   115→  const router = createRouter();\n   116→\n   117→  const result = await router.processMessage({\n   118→    channel: 'web',\n   119→    sessionId: 'web-session-123',\n   120→    message: 'test',\n   121→    userId: 'user-123'\n   122→  });\n   123→\n   124→  assert.strictEqual(mockSessionStore.append.mock.calls.length, 2);\n   125→  const assistantCall = mockSessionStore.append.mock.calls[1].arguments;\n   126→  assert.strictEqual(assistantCall[0], 'web:web-session-123');\n   127→  assert.strictEqual(assistantCall[1], 'assistant');\n   128→  assert.ok(assistantCall[2].includes('AI response'));\n   129→});\n   130→\n   131→test('message-router: processMessage publishes status events', async () => {\n   132→  const router = createRouter();\n   133→\n   134→  await router.processMessage({\n   135→    channel: 'web',\n   136→    sessionId: 'web-session-123',\n   137→    message: 'test',\n   138→    userId: 'user-123'\n   139→  });\n   140→\n   141→  assert.ok(mockRealtimeHub.publish.mock.calls.length > 0);\n   142→\n   143→  // Find 'accepted' status event\n   144→  const acceptedEvent = mockRealtimeHub.publish.mock.calls.find(\n   145→    (call) => call.arguments[1]?.type === 'status' &&\n   146→              call.arguments[1]?.payload?.stage === 'accepted'\n   147→  );\n   148→  assert.ok(acceptedEvent, 'Should publish accepted status event');\n   149→});\n   150→\n   151→test('message-router: processMessage publishes assistant events', async () => {\n   152→  const router = createRouter();\n   153→\n   154→  await router.processMessage({\n   155→    channel: 'web',\n   156→    sessionId: 'web-session-123',\n   157→    message: 'test',\n   158→    userId: 'user-123'\n   159→  });\n   160→\n   161→  // Find 'assistant_done' event\n   162→  const doneEvent = mockRealtimeHub.publish.mock.calls.find(\n   163→    (call) => call.arguments[1]?.type === 'assistant_done'\n   164→  );\n   165→  assert.ok(doneEvent, 'Should publish assistant_done event');\n   166→\n   167→  assert.ok(doneEvent.arguments[1].payload.reply.includes('AI response'));\n   168→  assert.strictEqual(doneEvent.arguments[1].payload.channel, 'web');\n   169→});\n   170→\n   171→test('message-router: processMessage passes userId to executeAiCli', async () => {\n   172→  const router = createRouter();\n   173→\n   174→  await router.processMessage({\n   175→    channel: 'telgram',\n   176→    sessionId: '456',\n   177→    message: 'test',\n   178→    userId: 'test-user-789'\n   179→  });\n   180→\n   181→  const callArgs = mockExecuteAiCli.mock.calls[0].arguments[0];\n   182→  assert.strictEqual(callArgs.userId, 'test-user-789');\n   183→});\n   184→\n   185→test('message-router: processMessage calls onChunk hook', async () => {\n   186→  let chunkReceived = false;\n   187→  const customMockExecute = test.mock.fn(async (options) => {\n   188→    if (options.hooks?.onChunk) {\n   189→      options.hooks.onChunk('partial output');\n   190→    }\n   191→    return {\n   192→      output: 'complete output',\n   193→      timedOut: false,\n   194→      interrupted: false,\n   195→      elapsedMs: 10,\n   196→      exitCode: 0,\n   197→      stderr: ''\n   198→    };\n   199→  });\n   200→\n   201→  const router = createRouter({ aiCliExecutor: customMockExecute });\n   202→\n   203→  await router.processMessage({\n   204→    channel: 'web',\n   205→    sessionId: 'web-session-123',\n   206→    message: 'test',\n   207→    userId: 'user-123',\n   208→    hooks: {\n   209→      onAssistantChunk: (data) => {\n   210→        chunkReceived = true;\n   211→        assert.strictEqual(data.text, 'partial output');\n   212→      }\n   213→    }\n   214→  });\n   215→\n   216→  assert.strictEqual(chunkReceived, true);\n   217→});\n   218→\n   219→test('message-router: processMessage validates required fields', async () => {\n   220→  const router = createRouter();\n   221→\n   222→  await assert.rejects(\n   223→    router.processMessage({\n   224→      channel: 'web',\n   225→      // missing sessionId\n   226→      message: 'test',\n   227→      userId: 'user-123'\n   228→    }),\n   229→    { message: /sessionId 不能为空/ }\n   230→  );\n   231→\n   232→  await assert.rejects(\n   233→    router.processMessage({\n   234→      channel: 'web',\n   235→      sessionId: 'web-session-123',\n   236→      // missing message\n   237→      userId: 'user-123'\n   238→    }),\n   239→    { message: /message 不能为空/ }\n   240→  );\n   241→});\n   242→\n   243→test('message-router: processMessage returns the AI response', async () => {\n   244→  const router = createRouter();\n   245→\n   246→  const result = await router.processMessage({\n   247→    channel: 'web',\n   248→    sessionId: 'web-session-123',\n   249→    message: 'test',\n   250→    userId: 'user-123'\n   251→  });\n   252→\n   253→  assert.ok(result.reply);\n   254→  assert.ok(result.reply.includes('AI response'));\n   255→});\n   256→\n   257→test.beforeEach(() => {\n   258→  mockSessionStore.append.mock.resetCalls();\n   259→  mockExecuteAiCli.mock.resetCalls();\n   260→  mockRealtimeHub.publish.mock.resetCalls();\n   261→});\n   262→"}]},"parent_tool_use_id":null,"session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"c225c23c-ef11-43a2-9f34-d171e62657a0","timestamp":"2026-03-22T06:24:51.251Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/tests/services/message-router.test.js","content":"/**\n * Message Router Unit Tests\n * Tests for src/services/message-router.js\n *\n * F-018: Web-Telegram Bidirectional Sync\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\n\nimport { sessionStore } from '../../src/services/session-store.js';\nimport { createMessageRouter } from '../../src/services/message-router.js';\n\n// Mock dependencies\nconst mockSessionStore = {\n  append: test.mock.fn(),\n  get: test.mock.fn(() => []),\n  clear: test.mock.fn(),\n  toPrompt: test.mock.fn(() => 'Mock prompt: you are an AI assistant. 用户: hello world\\n助手: previous context\\n')\n};\n\nconst mockExecuteAiCli = test.mock.fn(async (options) => {\n  return {\n    output: `AI response to: ${options.prompt}`,\n    timedOut: false,\n    interrupted: false,\n    elapsedMs: 100,\n    exitCode: 0,\n    stderr: ''\n  };\n});\n\nconst mockRealtimeHub = {\n  publish: test.mock.fn(),\n  subscribe: test.mock.fn(() => () => {})\n};\n\n/**\n * Helper to create a message router with mocks\n */\nfunction createRouter(options = {}) {\n  return createMessageRouter({\n    aiCliExecutor: options.aiCliExecutor || mockExecuteAiCli,\n    sessionStore: options.sessionStore || mockSessionStore,\n    realtimeHub: options.realtimeHub || mockRealtimeHub\n  });\n}\n\ntest('message-router: processMessage uses unified sessionKey when telegramChatId bound', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    telegramChatId: '456',\n    message: 'test message',\n    userId: 'user-123'\n  });\n\n  // Should use telegram:{chatId} as session key\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'telegram:456');\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[1], 'user');\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[2], 'test message');\n\n  // Should call executeAiCli with telegram session key\n  assert.strictEqual(mockExecuteAiCli.mock.calls[0].arguments[0].sessionId, 'telegram:456');\n});\n\ntest('message-router: processMessage uses web sessionKey when no telegramChatId', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'test message',\n    userId: 'user-123'\n  });\n\n  // Should use web:{sessionId} as session key for isolated session\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'web:web-session-123');\n});\n\ntest('message-router: processMessage calls executeAiCli with message', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'hello world',\n    userId: 'user-123'\n  });\n\n  assert.strictEqual(mockExecuteAiCli.mock.calls.length, 1);\n  const callArgs = mockExecuteAiCli.mock.calls[0].arguments[0];\n  assert.ok(callArgs.prompt.includes('hello world'));\n});\n\ntest('message-router: processMessage appends user message to sessionStore', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'telegram',\n    sessionId: '456',\n    message: 'user question',\n    userId: 'user-123'\n  });\n\n  assert.strictEqual(mockSessionStore.append.mock.calls.length, 2); // user + assistant\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'telegram:456');\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[1], 'user');\n  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[2], 'user question');\n});\n\ntest('message-router: processMessage appends assistant reply to sessionStore', async () => {\n  const router = createRouter();\n\n  const result = await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'test',\n    userId: 'user-123'\n  });\n\n  assert.strictEqual(mockSessionStore.append.mock.calls.length, 2);\n  const assistantCall = mockSessionStore.append.mock.calls[1].arguments;\n  assert.strictEqual(assistantCall[0], 'web:web-session-123');\n  assert.strictEqual(assistantCall[1], 'assistant');\n  assert.ok(assistantCall[2].includes('AI response'));\n});\n\ntest('message-router: processMessage publishes status events', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'test',\n    userId: 'user-123'\n  });\n\n  assert.ok(mockRealtimeHub.publish.mock.calls.length > 0);\n\n  // Find 'accepted' status event\n  const acceptedEvent = mockRealtimeHub.publish.mock.calls.find(\n    (call) => call.arguments[1]?.type === 'status' &&\n              call.arguments[1]?.payload?.stage === 'accepted'\n  );\n  assert.ok(acceptedEvent, 'Should publish accepted status event');\n});\n\ntest('message-router: processMessage publishes assistant events', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'test',\n    userId: 'user-123'\n  });\n\n  // Find 'assistant_done' event\n  const doneEvent = mockRealtimeHub.publish.mock.calls.find(\n    (call) => call.arguments[1]?.type === 'assistant_done'\n  );\n  assert.ok(doneEvent, 'Should publish assistant_done event');\n\n  assert.ok(doneEvent.arguments[1].payload.reply.includes('AI response'));\n  assert.strictEqual(doneEvent.arguments[1].payload.channel, 'web');\n});\n\ntest('message-router: processMessage passes userId to executeAiCli', async () => {\n  const router = createRouter();\n\n  await router.processMessage({\n    channel: 'telgram',\n    sessionId: '456',\n    message: 'test',\n    userId: 'test-user-789'\n  });\n\n  const callArgs = mockExecuteAiCli.mock.calls[0].arguments[0];\n  assert.strictEqual(callArgs.userId, 'test-user-789');\n});\n\ntest('message-router: processMessage calls onChunk hook', async () => {\n  let chunkReceived = false;\n  const customMockExecute = test.mock.fn(async (options) => {\n    if (options.hooks?.onChunk) {\n      options.hooks.onChunk('partial output');\n    }\n    return {\n      output: 'complete output',\n      timedOut: false,\n      interrupted: false,\n      elapsedMs: 10,\n      exitCode: 0,\n      stderr: ''\n    };\n  });\n\n  const router = createRouter({ aiCliExecutor: customMockExecute });\n\n  await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'test',\n    userId: 'user-123',\n    hooks: {\n      onAssistantChunk: (data) => {\n        chunkReceived = true;\n        assert.strictEqual(data.text, 'partial output');\n      }\n    }\n  });\n\n  assert.strictEqual(chunkReceived, true);\n});\n\ntest('message-router: processMessage validates required fields', async () => {\n  const router = createRouter();\n\n  await assert.rejects(\n    router.processMessage({\n      channel: 'web',\n      // missing sessionId\n      message: 'test',\n      userId: 'user-123'\n    }),\n    { message: /sessionId 不能为空/ }\n  );\n\n  await assert.rejects(\n    router.processMessage({\n      channel: 'web',\n      sessionId: 'web-session-123',\n      // missing message\n      userId: 'user-123'\n    }),\n    { message: /message 不能为空/ }\n  );\n});\n\ntest('message-router: processMessage returns the AI response', async () => {\n  const router = createRouter();\n\n  const result = await router.processMessage({\n    channel: 'web',\n    sessionId: 'web-session-123',\n    message: 'test',\n    userId: 'user-123'\n  });\n\n  assert.ok(result.reply);\n  assert.ok(result.reply.includes('AI response'));\n});\n\ntest.beforeEach(() => {\n  mockSessionStore.append.mock.resetCalls();\n  mockExecuteAiCli.mock.resetCalls();\n  mockRealtimeHub.publish.mock.resetCalls();\n});\n","numLines":262,"startLine":1,"totalLines":262}}}
