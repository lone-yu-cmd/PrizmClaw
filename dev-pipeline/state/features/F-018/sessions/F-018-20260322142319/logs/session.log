 Manager command handler\n    55→import { configMeta, handleConfig } from './commands/handlers/config.js';\n    56→import { generateHelp } from './commands/help.js';\n    57→import { sessionStore } from '../services/session-store.js';\n    58→import { sessionContextService } from '../services/session-context-service.js';\n    59→import { aliasStore } from '../services/alias-store.js';\n    60→import { scheduledTaskService } from '../services/scheduled-task-service.js';\n    61→import { fileWatcherService } from '../services/file-watcher-service.js';\n    62→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n    63→import { escapeMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n    64→\n    65→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n    66→const STREAM_MIN_CHARS = 220;\n    67→const STREAM_FLUSH_INTERVAL_MS = 1200;\n    68→const TYPING_INTERVAL_MS = 3500;\n    69→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n    70→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n    71→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n    72→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n    73→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n    74→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n    75→const TMP_DIR = path.resolve(os.tmpdir());\n    76→const HOME_DIR = path.resolve(os.homedir());\n    77→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n    78→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n    79→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n    80→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n    81→\n    82→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n    83→  const normalized = configuredDirs\n    84→    .map((dir) => String(dir ?? '').trim())\n    85→    .filter(Boolean)\n    86→    .map((dir) => path.resolve(dir));\n    87→\n    88→  if (normalized.length > 0) {\n    89→    return [...new Set(normalized)];\n    90→  }\n    91→\n    92→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n    93→}\n    94→\n    95→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n    96→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n    97→\n    98→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n    99→  const chunks = [];\n   100→  for (let i = 0; i < text.length; i += chunkSize) {\n   101→    chunks.push(text.slice(i, i + chunkSize));\n   102→  }\n   103→  return chunks;\n   104→}\n   105→\n   106→function truncate(text, maxLen) {\n   107→  if (!text) return '';\n   108→  if (text.length <= maxLen) return text;\n   109→  return text.substring(0, maxLen) + '...';\n   110→}\n   111→\n   112→function sanitizeMarkerPath(raw) {\n   113→  return String(raw ?? '')\n   114→    .trim()\n   115→    .replace(/^['\"`]+/, '')\n   116→    .replace(/['\"`]+$/, '');\n   117→}\n   118→\n   119→function extractFileMarkers(text = '') {\n   120→  const fileRefs = [];\n   121→\n   122→  const withSendFileRemoved = text.replace(\n   123→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n   124→    (_full, rawRef) => {\n   125→      const ref = sanitizeMarkerPath(rawRef);\n   126→      if (ref) {\n   127→        fileRefs.push(ref);\n   128→      }\n   129→      return '\\n';\n   130→    }\n   131→  );\n   132→\n   133→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n   134→    const ref = sanitizeMarkerPath(rawRef);\n   135→    if (ref) {\n   136→      fileRefs.push(ref);\n   137→    }\n   138→    return '';\n   139→  });\n   140→\n   141→  const withBacktickPathRemoved = withImageRemoved.replace(\n   142→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n   143→    (_full, rawRef) => {\n   144→      const ref = sanitizeMarkerPath(rawRef);\n   145→      if (ref) {\n   146→        fileRefs.push(ref);\n   147→      }\n   148→      return '';\n   149→    }\n   150→  );\n   151→\n   152→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n   153→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n   154→    (_full, rawRef) => {\n   155→      const ref = sanitizeMarkerPath(rawRef);\n   156→      if (ref) {\n   157→        fileRefs.push(ref);\n   158→      }\n   159→      return '';\n   160→    }\n   161→  );\n   162→\n   163→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n   164→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n   165→    (_full, rawRef) => {\n   166→      const ref = sanitizeMarkerPath(rawRef);\n   167→      if (ref) {\n   168→        fileRefs.push(ref);\n   169→      }\n   170→      return '\\n';\n   171→    }\n   172→  );\n   173→\n   174→  return {\n   175→    fileRefs: [...new Set(fileRefs)],\n   176→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n   177→  };\n   178→}\n   179→\n   180→function isPathWithinRoot(targetPath, rootPath) {\n   181→  const relative = path.relative(rootPath, targetPath);\n   182→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n   183→}\n   184→\n   185→function isAllowedFilePath(filePath) {\n   186→  const resolved = path.resolve(filePath);\n   187→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n   188→}\n   189→\n   190→function buildFileCandidates(normalizedPath) {\n   191→  if (path.isAbsolute(normalizedPath)) {\n   192→    return [normalizedPath];\n   193→  }\n   194→\n   195→  const baseName = path.basename(normalizedPath);\n   196→  const candidates = [\n   197→    path.resolve(process.cwd(), normalizedPath),\n   198→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n   199→  ];\n   200→\n   201→  return [...new Set(candidates)];\n   202→}\n   203→\n   204→async function resolveLocalFilePath(fileRef) {\n   205→  const normalized = sanitizeMarkerPath(fileRef);\n   206→  if (!normalized) {\n   207→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n   208→  }\n   209→\n   210→  if (!path.isAbsolute(normalized)) {\n   211→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n   212→  }\n   213→\n   214→  const candidates = buildFileCandidates(normalized);\n   215→\n   216→  for (const candidate of candidates) {\n   217→    try {\n   218→      await access(candidate);\n   219→      return { filePath: candidate, triedPaths: candidates };\n   220→    } catch {\n   221→      // ignore\n   222→    }\n   223→  }\n   224→\n   225→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n   226→}\n   227→\n   228→async function validateFileForTelegram(filePath) {\n   229→  const resolvedPath = path.resolve(filePath);\n   230→  if (!isAllowedFilePath(resolvedPath)) {\n   231→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n   232→  }\n   233→\n   234→  const ext = path.extname(resolvedPath).toLowerCase();\n   235→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n   236→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n   237→  }\n   238→\n   239→  const fileStat = await stat(resolvedPath);\n   240→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n   241→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n   242→\n   243→  if (fileStat.size > maxSize) {\n   244→    return {\n   245→      ok: false,\n   246→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n   247→    };\n   248→  }\n   249→\n   250→  return { ok: true, isPhoto, resolvedPath };\n   251→}\n   252→\n   253→function isTimeoutLikeError(message = '') {\n   254→  const normalized = String(message).toLowerCase();\n   255→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n   256→}\n   257→\n   258→function sleep(ms) {\n   259→  return new Promise((resolve) => setTimeout(resolve, ms));\n   260→}\n   261→\n   262→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n   263→  if (isPhoto) {\n   264→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n   265→    return;\n   266→  }\n   267→\n   268→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n   269→}\n   270→\n   271→async function replyFiles(ctx, fileRefs = []) {\n   272→  const results = [];\n   273→\n   274→  for (const fileRef of fileRefs) {\n   275→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n   276→    if (!filePath) {\n   277→      const reason = rejectReason || 'not_found';\n   278→      results.push({ fileRef, sent: false, reason, triedPaths });\n   279→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n   280→      continue;\n   281→    }\n   282→\n   283→    try {\n   284→      const validation = await validateFileForTelegram(filePath);\n   285→      if (!validation.ok) {\n   286→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n   287→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n   288→        continue;\n   289→      }\n   290→\n   291→      const actualPath = validation.resolvedPath;\n   292→      let sent = false;\n   293→      let lastReason = '';\n   294→\n   295→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n   296→        try {\n   297→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n   298→          sent = true;\n   299→          logger.info(\n   300→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n   301→            'Telegram file sent'\n   302→          );\n   303→          break;\n   304→        } catch (error) {\n   305→          lastReason = error instanceof Error ? error.message : String(error);\n   306→          logger.warn(\n   307→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n   308→            'Telegram file send attempt failed'\n   309→          );\n   310→\n   311→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n   312→            await sleep(600);\n   313→            continue;\n   314→          }\n   315→\n   316→          break;\n   317→        }\n   318→      }\n   319→\n   320→      if (!sent) {\n   321→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n   322→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n   323→        continue;\n   324→      }\n   325→\n   326→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n   327→    } catch (error) {\n   328→      const reason = error instanceof Error ? error.message : String(error);\n   329→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n   330→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n   331→    }\n   332→  }\n   333→\n   334→  return results;\n   335→}\n   336→\n   337→async function safeReply(ctx, text) {\n   338→  try {\n   339→    await ctx.reply(text);\n   340→    return true;\n   341→  } catch (error) {\n   342→    const reason = error instanceof Error ? error.message : String(error);\n   343→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n   344→    return false;\n   345→  }\n   346→}\n   347→\n   348→async function replyLargeText(ctx, text) {\n   349→  const chunks = splitMessage(text);\n   350→  for (const chunk of chunks) {\n   351→    const ok = await safeReply(ctx, chunk);\n   352→    if (!ok) {\n   353→      break;\n   354→    }\n   355→  }\n   356→}\n   357→\n   358→async function safeEditMessageText(ctx, messageId, text) {\n   359→  const nextText = text && text.trim() ? text : ' ';\n   360→\n   361→  try {\n   362→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n   363→  } catch (error) {\n   364→    const message = error instanceof Error ? error.message : String(error);\n   365→    if (message.includes('message is not modified')) {\n   366→      return;\n   367→    }\n   368→    throw error;\n   369→  }\n   370→}\n   371→\n   372→function createEditableStreamPublisher(ctx) {\n   373→  let fullText = '';\n   374→  let renderedText = '';\n   375→  let pendingChars = 0;\n   376→  let lastFlushAt = 0;\n   377→  let flushChain = Promise.resolve();\n   378→  let activeMessage = null;\n   379→  let activeSegmentIndex = 0;\n   380→  let publishedMessageCount = 0;\n   381→\n   382→  async function ensureActiveMessage() {\n   383→    if (activeMessage) {\n   384→      return;\n   385→    }\n   386→    activeMessage = await ctx.reply('处理中...');\n   387→    activeSegmentIndex = 0;\n   388→    publishedMessageCount += 1;\n   389→  }\n   390→\n   391→  async function render(force = false) {\n   392→    const now = Date.now();\n   393→\n   394→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n   395→      return;\n   396→    }\n   397→\n   398→    if (fullText === renderedText) {\n   399→      pendingChars = 0;\n   400→      return;\n   401→    }\n   402→\n   403→    await ensureActiveMessage();\n   404→\n   405→    const segments = splitMessage(fullText);\n   406→    const targetLastIndex = Math.max(segments.length - 1, 0);\n   407→\n   408→    while (activeSegmentIndex < targetLastIndex) {\n   409→      const text = segments[activeSegmentIndex] ?? ' ';\n   410→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n   411→\n   412→      activeMessage = await ctx.reply('继续输出中...');\n   413→      activeSegmentIndex += 1;\n   414→      publishedMessageCount += 1;\n   415→    }\n   416→\n   417→    const activeText = segments[targetLastIndex] ?? ' ';\n   418→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n   419→\n   420→    renderedText = fullText;\n   421→    pendingChars = 0;\n   422→    lastFlushAt = now;\n   423→  }\n   424→\n   425→  function enqueueRender(force = false) {\n   426→    flushChain = flushChain.then(() => render(force));\n   427→  }\n   428→\n   429→  return {\n   430→    push(text) {\n   431→      const appendText = text ?? '';\n   432→      if (!appendText) {\n   433→        return;\n   434→      }\n   435→      fullText += appendText;\n   436→      pendingChars += appendText.length;\n   437→      enqueueRender(false);\n   438→    },\n   439→    setFinalText(text) {\n   440→      fullText = text ?? '';\n   441→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n   442→      enqueueRender(true);\n   443→    },\n   444→    async finish() {\n   445→      enqueueRender(true);\n   446→      await flushChain;\n   447→      return {\n   448→        outputLength: renderedText.length,\n   449→        messageCount: publishedMessageCount\n   450→      };\n   451→    }\n   452→  };\n   453→}\n   454→\n   455→function buildSessionId(ctx) {\n   456→  return String(ctx.chat.id);\n   457→}\n   458→\n   459→function ensureAllowed(ctx) {\n   460→  const userId = ctx.from?.id;\n   461→  if (!isAllowedUser(userId)) {\n   462→    throw new Error('当前账号未被授权使用该机器人。');\n   463→  }\n   464→}\n   465→\n   466→/**\n   467→ * Register all pipeline-related commands.\n   468→ */\n   469→function registerPipelineCommands() {\n   470→  registerCommand(pipelineMeta, handlePipeline);\n   471→  registerCommand(bugfixMeta, handleBugfix);\n   472→  registerCommand(plannerMeta, handlePlanner);\n   473→  registerCommand(statusMeta, handleStatus);\n   474→  registerCommand(logsMeta, handleLogs);\n   475→  registerCommand(stopMeta, handleStop);\n   476→  registerCommand(planMeta, handlePlan);\n   477→  registerCommand(auditMeta, handleAudit);\n   478→  registerCommand(commitMeta, handleCommit);\n   479→  registerCommand(commitsMeta, handleCommits);\n   480→  // F-009: New commands\n   481→  registerCommand(cdMeta, handleCd);\n   482→  registerCommand(moreMeta, handleMore);\n   483→  // F-010: File Manager commands\n   484→  registerCommand(lsMeta, handleLs);\n   485→  registerCommand(treeMeta, handleTree);\n   486→  registerCommand(catMeta, handleCat);\n   487→  registerCommand(headMeta, handleHead);\n   488→  registerCommand(tailMeta, handleTail);\n   489→  registerCommand(findMeta, handleFind);\n   490→  registerCommand(uploadMeta, handleUpload);\n   491→  registerCommand(downloadMeta, handleDownload);\n   492→  // F-012: System Monitor commands\n   493→  registerCommand(sysinfoMeta, handleSysinfo);\n   494→  registerCommand(psMeta, handlePs);\n   495→  registerCommand(killMeta, handleKill);\n   496→  registerCommand(monitorMeta, handleMonitor);\n   497→  // F-013: Session and Context Manager commands\n   498→  registerCommand(historyMeta, handleHistory);\n   499→  registerCommand(aliasMeta, handleAlias);\n   500→  registerCommand(sessionsMeta, handleSessions);\n   501→  // F-014: Notification and Scheduled Tasks commands\n   502→  registerCommand(cronMeta, handleCron);\n   503→  registerCommand(jobsMeta, handleJobs);\n   504→  registerCommand(watchMeta, handleWatch);\n   505→  // F-015: AI CLI Backend Switcher command\n   506→  registerCommand(cliMeta, handleCli);\n   507→  // F-017: Runtime Config Manager command\n   508→  registerCommand(configMeta, handleConfig);\n   509→}\n   510→\n   511→export async function createTelegramBot() {\n   512→  const bot = new Telegraf(config.telegramBotToken, {\n   513→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n   514→  });\n   515→\n   516→  // F-013: Initialize session context service\n   517→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n   518→  await aliasStore.initAliasStore({ persistencePath: config.aliasPersistencePath });\n   519→\n   520→  // F-013: Restore sessions from disk\n   521→  await sessionContextService.restoreSessions();\n   522→\n   523→  // F-013: Set up notification callback for session timeout\n   524→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n   525→    try {\n   526→      // Extract chat ID from session key (format: telegram:123456789)\n   527→      const chatId = sessionKey.replace('telegram:', '');\n   528→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n   529→    } catch (error) {\n   530→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n   531→    }\n   532→  });\n   533→\n   534→  // F-013: Start timeout watcher\n   535→  sessionContextService.startTimeoutWatcher();\n   536→\n   537→  // F-014: Initialize scheduled task service\n   538→  scheduledTaskService.initScheduledTaskService({\n   539→    dataDir: config.systemMonitorDataDir,\n   540→    tasksFile: config.scheduledTasksPath,\n   541→    maxTasks: config.maxScheduledTasks\n   542→  });\n   543→\n   544→  // F-014: Set up task execution callback\n   545→  scheduledTaskService.setExecuteCallback(async ({ command, cwd, sessionId, userId }) => {\n   546→    try {\n   547→      return await executeCommand({\n   548→        command,\n   549→        cwd,\n   550→        sessionId,\n   551→        userId,\n   552→        skipConfirmation: true // Skip confirmation for scheduled tasks\n   553→      });\n   554→    } catch (error) {\n   555→      return {\n   556→        stdout: '',\n   557→        stderr: error.message,\n   558→        exitCode: 1,\n   559→        timedOut: false\n   560→      };\n   561→    }\n   562→  });\n   563→\n   564→  // F-014: Set up task notification callback\n   565→  scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n   566→    try {\n   567→      const result = task.lastResult || {};\n   568→      const lines = [\n   569→        '⏰ *定时任务完成*',\n   570→        '',\n   571→        `任务ID: \\`${task.id.substring(0, 8)}...\\``,\n   572→        `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n   573→        `执行时间: ${new Date(result.executedAt || Date.now()).toLocaleString()}`,\n   574→        '',\n   575→        `exitCode: ${result.exitCode}`,\n   576→        result.stdout ? `stdout:\\n${truncate(result.stdout, 500)}` : 'stdout: (empty)',\n   577→        result.stderr ? `stderr:\\n${escapeMarkdownV2(truncate(result.stderr, 500))}` : 'stderr: (empty)'\n   578→      ];\n   579→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n   580→    } catch (error) {\n   581→      logger.warn({ taskId: task.id, error: error.message }, 'Failed to send task notification');\n   582→    }\n   583→  });\n   584→\n   585→  // F-014: Load and start scheduled tasks\n   586→  await scheduledTaskService.loadTasks();\n   587→  scheduledTaskService.startScheduler();\n   588→\n   589→  // F-014: Initialize file watcher service\n   590→  fileWatcherService.initFileWatcherService({\n   591→    dataDir: config.systemMonitorDataDir,\n   592→    watchersFile: config.fileWatchersPath,\n   593→    maxWatchers: config.maxFileWatchers,\n   594→    debounceMs: config.taskDebounceMs,\n   595→    allowedRoots: config.telegramFileAllowedRoots.length > 0\n   596→      ? config.telegramFileAllowedRoots\n   597→      : [process.cwd()]\n   598→  });\n   599→\n   600→  // F-014: Set up file watcher notification callback\n   601→  fileWatcherService.setNotificationCallback(async (chatId, watcher) => {\n   602→    try {\n   603→      const lines = [\n   604→        '📁 *文件变更检测*',\n   605→        '',\n   606→        `路径: \\`${escapeMarkdownV2(watcher.path)}\\``,\n   607→        `事件: ${watcher.eventType}`,\n   608→        `文件: ${watcher.filename || '(未知)'}`,\n   609→        `时间: ${new Date().toLocaleString()}`\n   610→      ];\n   611→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n   612→    } catch (error) {\n   613→      logger.warn({ watcherId: watcher.id, error: error.message }, 'Failed to send file watcher notification');\n   614→    }\n   615→  });\n   616→\n   617→  // F-014: Restore file watchers\n   618→  await fileWatcherService.restoreWatches();\n   619→\n   620→  // Register pipeline commands\n   621→  registerPipelineCommands();\n   622→\n   623→  bot.catch(async (error, ctx) => {\n   624→    const message = error instanceof Error ? error.message : String(error);\n   625→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n   626→    try {\n   627→      if (ctx?.chat?.id) {\n   628→        await ctx.telegram.sendMessage(ctx.chat.id, '处理请求时出现异常，请重试一次。');\n   629→      }\n   630→    } catch (notifyError) {\n   631→      logger.warn({ err: notifyError instanceof Error ? notifyError.message : String(notifyError) }, 'Failed to notify user after unhandled telegram error');\n   632→    }\n   633→  });\n   634→\n   635→  bot.start(async (ctx) => {\n   636→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n   637→  });\n   638→\n   639→  bot.help(async (ctx) => {\n   640→    const helpText = generateHelp();\n   641→    await ctx.reply(helpText);\n   642→  });\n   643→\n   644→  bot.command('reset', async (ctx) => {\n   645→    try {\n   646→      ensureAllowed(ctx);\n   647→      const sessionId = buildSessionId(ctx);\n   648→\n   649→      // F-011: Interrupt any running AI CLI task\n   650→      if (isAiCliRunning(sessionId)) {\n   651→        interruptAiCli(sessionId);\n   652→      }\n   653→\n   654→      resetSession({ channel: 'telegram', sessionId });\n   655→      await ctx.reply('已清空当前会话上下文。');\n   656→    } catch (error) {\n   657→      await ctx.reply(error instanceof Error ? error.message : String(error));\n   658→    }\n   659→  });\n   660→\n   661→  bot.command('screenshot', async (ctx) => {\n   662→    try {\n   663→      ensureAllowed(ctx);\n   664→      await ctx.reply('正在获取截图。');\n   665→      const { buffer } = await captureScreenshot();\n   666→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n   667→    } catch (error) {\n   668→      const message = error instanceof Error ? error.message : String(error);\n   669→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n   670→      await ctx.reply(`截图失败：${message}`);\n   671→    }\n   672→  });\n   673→\n   674→  bot.command('exec', async (ctx) => {\n   675→    try {\n   676→      ensureAllowed(ctx);\n   677→      const payload = ctx.message.text.replace('/exec', '').trim();\n   678→      if (!payload) {\n   679→        await ctx.reply('请提供命令，例如 /exec pwd');\n   680→        return;\n   681→      }\n   682→\n   683→      const sessionId = buildSessionId(ctx);\n   684→      const userId = ctx.from?.id;\n   685→\n   686→      await ctx.reply('正在执行命令...');\n   687→      const result = await executeCommand({\n   688→        command: payload,\n   689→        sessionId,\n   690→        userId\n   691→      });\n   692→\n   693→      // Handle confirmation required\n   694→      if (result.needsConfirmation) {\n   695→        await ctx.reply(result.confirmationMessage);\n   696→        return;\n   697→      }\n   698→\n   699→      // Send output\n   700→      await replyLargeText(ctx, result.output);\n   701→\n   702→      // Indicate if more pages available\n   703→      if (result.hasMorePages) {\n   704→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容