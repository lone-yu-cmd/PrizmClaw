{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_0182Q8ZbtL7aAUeCxCmgkp7n","type":"tool_result","content":"     1→/**\n     2→ * Session Binding Integration Tests\n     3→ * Tests for F-018 Web-Telegram Bidirectional Sync binding endpoints\n     4→ *\n     5→ * F-018: Web-Telegram Bidirectional Sync\n     6→ */\n     7→\n     8→import test from 'node:test';\n     9→import assert from 'node:assert/strict';\n    10→import fs from 'node:fs';\n    11→import path from 'node:path';\n    12→import os from 'node:os';\n    13→import http from 'node:http';\n    14→\n    15→import { createHttpServer } from '../../src/http/server.js';\n    16→import { config } from '../../src/config.js';\n    17→\n    18→/**\n    19→ * Helper to create temp directory for test state\n    20→ */\n    21→function createTempDir() {\n    22→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f018-binding-test-'));\n    23→  const dataDir = path.join(tempDir, 'data');\n    24→  fs.mkdirSync(dataDir, { recursive: true });\n    25→  return {\n    26→    tempDir,\n    27→    dataDir,\n    28→    cleanup: () => {\n    29→      fs.rmSync(tempDir, { recursive: true, force: true });\n    30→    }\n    31→  };\n    32→}\n    33→\n    34→/**\n    35→ * Helper to make HTTP requests\n    36→ */\n    37→function makeRequest(options, data) {\n    38→  return new Promise((resolve, reject) => {\n    39→    const req = http.request(options, (res) => {\n    40→      let body = '';\n    41→      res.on('data', (chunk) => body += chunk);\n    42→      res.on('end', () => {\n    43→        try {\n    44→          resolve({\n    45→            statusCode: res.statusCode,\n    46→            headers: res.headers,\n    47→            body: JSON.parse(body)\n    48→          });\n    49→        } catch (e) {\n    50→          resolve({\n    51→            statusCode: res.statusCode,\n    52→            headers: res.headers,\n    53→            body\n    54→          });\n    55→        }\n    56→      });\n    57→    });\n    58→\n    59→    req.on('error', reject);\n    60→    if (data) {\n    61→      req.write(JSON.stringify(data));\n    62→    }\n    63→    req.end();\n    64→  });\n    65→}\n    66→\n    67→/**\n    68→ * Helper to start HTTP server\n    69→ */\n    70→function startServer(bindingsPath) {\n    71→  // Override config for testing\n    72→  const originalBindingsPath = config.sessionBindingsPath;\n    73→  const testBindingsPath = bindingsPath;\n    74→\n    75→  // Create a mock config object\n    76→  const mockConfig = {\n    77→    ...config,\n    78→    sessionBindingsPath: testBindingsPath\n    79→  };\n    80→\n    81→  const logger = { info: () => {}, error: () => {} };\n    82→  const app = createHttpServer({ logger });\n    83→\n    84→  return new Promise((resolve) => {\n    85→    const server = http.createServer(app);\n    86→    server.listen(0, () => {\n    87→      const port = server.address().port;\n    88→      resolve({ server, port, cleanup: () => server.close() });\n    89→    });\n    90→  });\n    91→}\n    92→\n    93→test('F-018: POST /api/bind creates session binding', async (t) => {\n    94→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n    95→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n    96→\n    97→  try {\n    98→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    99→    try {\n   100→      const response = await makeRequest({\n   101→        hostname: 'localhost',\n   102→        port,\n   103→        path: '/api/bind',\n   104→        method: 'POST',\n   105→        headers: { 'Content-Type': 'application/json' }\n   106→      },\n   107→      { webSessionId: 'web-session-123', telegramChatId: '456' });\n   108→\n   109→      assert.strictEqual(response.statusCode, 200);\n   110→      assert.strictEqual(response.body.ok, true);\n   111→\n   112→      // Verify binding persisted\n   113→      const raw = fs.readFileSync(bindingsPath, 'utf-8');\n   114→      const data = JSON.parse(raw);\n   115→      assert.strictEqual(data.bindings['web-session-123'], '456');\n   116→    } finally {\n   117→      cleanupServer();\n   118→    }\n   119→  } finally {\n   120→    cleanupTemp();\n   121→  }\n   122→});\n   123→\n   124→test('F-018: POST /api/bind validates required fields', async (t) => {\n   125→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   126→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   127→\n   128→  try {\n   129→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   130→    try {\n   131→      const response = await makeRequest({\n   132→        hostname: 'localhost',\n   133→        port,\n   134→        path: '/api/bind',\n   135→        method: 'POST',\n   136→        headers: { 'Content-Type': 'application/json' }\n   137→      },\n   138→      { webSessionId: 'web-session-123' });\n   139→\n   140→      assert.strictEqual(response.statusCode, 400);\n   141→      assert.strictEqual(response.body.ok, false);\n   142→      assert.ok(response.body.error.includes('required'));\n   143→    } finally {\n   144→      cleanupServer();\n   145→    }\n   146→  } finally {\n   147→    cleanupTemp();\n   148→  }\n   149→});\n   150→\n   151→test('F-018: POST /api/unbind removes session binding', async (t) => {\n   152→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   153→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   154→\n   155→  try {\n   156→    // Create initial binding\n   157→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   158→      bindings: {\n   159→        'web-session-123': '456'\n   160→      }\n   161→    }));\n   162→\n   163→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   164→    try {\n   165→      const response = await makeRequest({\n   166→        hostname: 'localhost',\n   167→        port,\n   168→        path: '/api/unbind',\n   169→        method: 'POST',\n   170→        headers: { 'Content-Type': 'application/json' }\n   171→      },\n   172→      { webSessionId: 'web-session-123' });\n   173→\n   174→      assert.strictEqual(response.statusCode, 200);\n   175→      assert.strictEqual(response.body.ok, true);\n   176→\n   177→      // Verify binding removed\n   178→      const raw = fs.readFileSync(bindingsPath, 'utf-8');\n   179→      const data = JSON.parse(raw);\n   180→      assert.strictEqual(data.bindings['web-session-123'], undefined);\n   181→    } finally {\n   182→      cleanupServer();\n   183→    }\n   184→  } finally {\n   185→    cleanupTemp();\n   186→  }\n   187→});\n   188→\n   189→test('F-018: GET /api/bindings returns all bindings', async (t) => {\n   190→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   191→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   192→\n   193→  try {\n   194→    // Create initial bindings\n   195→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   196→      bindings: {\n   197→        'web-session-1': '456',\n   198→        'web-session-2': '456',\n   199→        'web-session-3': '789'\n   200→      }\n   201→    }));\n   202→\n   203→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   204→    try {\n   205→      const response = await makeRequest({\n   206→        hostname: 'localhost',\n   207→        port,\n   208→        path: '/api/bindings',\n   209→        method: 'GET'\n   210→      });\n   211→\n   212→      assert.strictEqual(response.statusCode, 200);\n   213→      assert.strictEqual(response.body.ok, true);\n   214→      assert.strictEqual(response.body.bindings['web-session-1'], '456');\n   215→      assert.strictEqual(response.body.bindings['web-session-2'], '456');\n   216→      assert.strictEqual(response.body.bindings['web-session-3'], '789');\n   217→      assert.strictEqual(Object.keys(response.body.bindings).length, 3);\n   218→    } finally {\n   219→      cleanupServer();\n   220→    }\n   221→  } finally {\n   222→    cleanupTemp();\n   223→  }\n   224→});\n   225→\n   226→test('F-018: GET /api/bindings?webSessionId returns specific binding', async (t) => {\n   227→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   228→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   229→\n   230→  try {\n   231→    // Create initial bindings\n   232→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   233→      bindings: {\n   234→        'web-session-1': '456',\n   235→        'web-session-2': '789'\n   236→      }\n   237→    }));\n   238→\n   239→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   240→    try {\n   241→      const response = await makeRequest({\n   242→        hostname: 'localhost',\n   243→        port,\n   244→        path: '/api/bindings?webSessionId=web-session-2',\n   245→        method: 'GET'\n   246→      });\n   247→\n   248→      assert.strictEqual(response.statusCode, 200);\n   249→      assert.strictEqual(response.body.ok, true);\n   250→      assert.strictEqual(response.body.telegramChatId, '789');\n   251→    } finally {\n   252→      cleanupServer();\n   253→    }\n   254→  } finally {\n   255→    cleanupTemp();\n   256→  }\n   257→});\n   258→\n   259→test('F-018: GET /api/bindings returns null for non-existent session', async (t) => {\n   260→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   261→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   262→\n   263→  try {\n   264→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   265→    try {\n   266→      const response = await makeRequest({\n   267→        hostname: 'localhost',\n   268→        port,\n   269→        path: '/api/bindings?webSessionId=non-existent',\n   270→        method: 'GET'\n   271→      });\n   272→\n   273→      assert.strictEqual(response.statusCode, 200);\n   274→      assert.strictEqual(response.body.ok, true);\n   275→      assert.strictEqual(response.body.telegramChatId, null);\n   276→    } finally {\n   277→      cleanupServer();\n   278→    }\n   279→  } finally {\n   280→    cleanupTemp();\n   281→  }\n   282→});\n   283→"}]},"parent_tool_use_id":null,"session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"8927658d-cd5f-4dae-a0e4-43067be881ce","timestamp":"2026-03-22T06:25:01.675Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/tests/integration/f018-web-telegram-sync.integration.test.js","content":"/**\n * Session Binding Integration Tests\n * Tests for F-018 Web-Telegram Bidirectional Sync binding endpoints\n *\n * F-018: Web-Telegram Bidirectional Sync\n */\n\nimport test from 'node:test';\nimport assert from 'node:assert/strict';\nimport fs from 'node:fs';\nimport path from 'node:path';\nimport os from 'node:os';\nimport http from 'node:http';\n\nimport { createHttpServer } from '../../src/http/server.js';\nimport { config } from '../../src/config.js';\n\n/**\n * Helper to create temp directory for test state\n */\nfunction createTempDir() {\n  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f018-binding-test-'));\n  const dataDir = path.join(tempDir, 'data');\n  fs.mkdirSync(dataDir, { recursive: true });\n  return {\n    tempDir,\n    dataDir,\n    cleanup: () => {\n      fs.rmSync(tempDir, { recursive: true, force: true });\n    }\n  };\n}\n\n/**\n * Helper to make HTTP requests\n */\nfunction makeRequest(options, data) {\n  return new Promise((resolve, reject) => {\n    const req = http.request(options, (res) => {\n      let body = '';\n      res.on('data', (chunk) => body += chunk);\n      res.on('end', () => {\n        try {\n          resolve({\n            statusCode: res.statusCode,\n            headers: res.headers,\n            body: JSON.parse(body)\n          });\n        } catch (e) {\n          resolve({\n            statusCode: res.statusCode,\n            headers: res.headers,\n            body\n          });\n        }\n      });\n    });\n\n    req.on('error', reject);\n    if (data) {\n      req.write(JSON.stringify(data));\n    }\n    req.end();\n  });\n}\n\n/**\n * Helper to start HTTP server\n */\nfunction startServer(bindingsPath) {\n  // Override config for testing\n  const originalBindingsPath = config.sessionBindingsPath;\n  const testBindingsPath = bindingsPath;\n\n  // Create a mock config object\n  const mockConfig = {\n    ...config,\n    sessionBindingsPath: testBindingsPath\n  };\n\n  const logger = { info: () => {}, error: () => {} };\n  const app = createHttpServer({ logger });\n\n  return new Promise((resolve) => {\n    const server = http.createServer(app);\n    server.listen(0, () => {\n      const port = server.address().port;\n      resolve({ server, port, cleanup: () => server.close() });\n    });\n  });\n}\n\ntest('F-018: POST /api/bind creates session binding', async (t) => {\n  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n\n  try {\n    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    try {\n      const response = await makeRequest({\n        hostname: 'localhost',\n        port,\n        path: '/api/bind',\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' }\n      },\n      { webSessionId: 'web-session-123', telegramChatId: '456' });\n\n      assert.strictEqual(response.statusCode, 200);\n      assert.strictEqual(response.body.ok, true);\n\n      // Verify binding persisted\n      const raw = fs.readFileSync(bindingsPath, 'utf-8');\n      const data = JSON.parse(raw);\n      assert.strictEqual(data.bindings['web-session-123'], '456');\n    } finally {\n      cleanupServer();\n    }\n  } finally {\n    cleanupTemp();\n  }\n});\n\ntest('F-018: POST /api/bind validates required fields', async (t) => {\n  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n\n  try {\n    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    try {\n      const response = await makeRequest({\n        hostname: 'localhost',\n        port,\n        path: '/api/bind',\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' }\n      },\n      { webSessionId: 'web-session-123' });\n\n      assert.strictEqual(response.statusCode, 400);\n      assert.strictEqual(response.body.ok, false);\n      assert.ok(response.body.error.includes('required'));\n    } finally {\n      cleanupServer();\n    }\n  } finally {\n    cleanupTemp();\n  }\n});\n\ntest('F-018: POST /api/unbind removes session binding', async (t) => {\n  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n\n  try {\n    // Create initial binding\n    fs.writeFileSync(bindingsPath, JSON.stringify({\n      bindings: {\n        'web-session-123': '456'\n      }\n    }));\n\n    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    try {\n      const response = await makeRequest({\n        hostname: 'localhost',\n        port,\n        path: '/api/unbind',\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' }\n      },\n      { webSessionId: 'web-session-123' });\n\n      assert.strictEqual(response.statusCode, 200);\n      assert.strictEqual(response.body.ok, true);\n\n      // Verify binding removed\n      const raw = fs.readFileSync(bindingsPath, 'utf-8');\n      const data = JSON.parse(raw);\n      assert.strictEqual(data.bindings['web-session-123'], undefined);\n    } finally {\n      cleanupServer();\n    }\n  } finally {\n    cleanupTemp();\n  }\n});\n\ntest('F-018: GET /api/bindings returns all bindings', async (t) => {\n  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n\n  try {\n    // Create initial bindings\n    fs.writeFileSync(bindingsPath, JSON.stringify({\n      bindings: {\n        'web-session-1': '456',\n        'web-session-2': '456',\n        'web-session-3': '789'\n      }\n    }));\n\n    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    try {\n      const response = await makeRequest({\n        hostname: 'localhost',\n        port,\n        path: '/api/bindings',\n        method: 'GET'\n      });\n\n      assert.strictEqual(response.statusCode, 200);\n      assert.strictEqual(response.body.ok, true);\n      assert.strictEqual(response.body.bindings['web-session-1'], '456');\n      assert.strictEqual(response.body.bindings['web-session-2'], '456');\n      assert.strictEqual(response.body.bindings['web-session-3'], '789');\n      assert.strictEqual(Object.keys(response.body.bindings).length, 3);\n    } finally {\n      cleanupServer();\n    }\n  } finally {\n    cleanupTemp();\n  }\n});\n\ntest('F-018: GET /api/bindings?webSessionId returns specific binding', async (t) => {\n  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n\n  try {\n    // Create initial bindings\n    fs.writeFileSync(bindingsPath, JSON.stringify({\n      bindings: {\n        'web-session-1': '456',\n        'web-session-2': '789'\n      }\n    }));\n\n    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    try {\n      const response = await makeRequest({\n        hostname: 'localhost',\n        port,\n        path: '/api/bindings?webSessionId=web-session-2',\n        method: 'GET'\n      });\n\n      assert.strictEqual(response.statusCode, 200);\n      assert.strictEqual(response.body.ok, true);\n      assert.strictEqual(response.body.telegramChatId, '789');\n    } finally {\n      cleanupServer();\n    }\n  } finally {\n    cleanupTemp();\n  }\n});\n\ntest('F-018: GET /api/bindings returns null for non-existent session', async (t) => {\n  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n\n  try {\n    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    try {\n      const response = await makeRequest({\n        hostname: 'localhost',\n        port,\n        path: '/api/bindings?webSessionId=non-existent',\n        method: 'GET'\n      });\n\n      assert.strictEqual(response.statusCode, 200);\n      assert.strictEqual(response.body.ok, true);\n      assert.strictEqual(response.body.telegramChatId, null);\n    } finally {\n      cleanupServer();\n    }\n  } finally {\n    cleanupTemp();\n  }\n});\n","numLines":283,"startLine":1,"totalLines":283}}}
