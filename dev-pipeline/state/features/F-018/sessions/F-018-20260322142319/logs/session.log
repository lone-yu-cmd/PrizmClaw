{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01VmenMrhL9H3iwZ8hKsHJzx","type":"tool_result","content":"     1→/**\n     2→ * Session Binding Integration Tests\n     3→ * Tests for F-018 Web-Telegram Bidirectional Sync binding endpoints\n     4→ *\n     5→ * F-018: Web-Telegram Bidirectional Sync\n     6→ */\n     7→\n     8→import test from 'node:test';\n     9→import assert from 'node:assert/strict';\n    10→import fs from 'node:fs';\n    11→import path from 'node:path';\n    12→import os from 'node:os';\n    13→import http from 'node:http';\n    14→\n    15→import { createHttpServer } from '../../src/http/server.js';\n    16→\n    17→/**\n    18→ * Helper to create temp directory for test state\n    19→ */\n    20→function createTempDir() {\n    21→  const tempDir = fs.mkdtempSync(path.join(os.tmpdir(), 'f018-binding-test-'));\n    22→  const dataDir = path.join(tempDir, 'data');\n    23→  fs.mkdirSync(dataDir, { recursive: true });\n    24→  return {\n    25→    tempDir,\n    26→    dataDir,\n    27→    cleanup: () => {\n    28→      fs.rmSync(tempDir, { recursive: true, force: true });\n    29→    }\n    30→  };\n    31→}\n    32→\n    33→/**\n    34→ * Helper to make HTTP requests\n    35→ */\n    36→function makeRequest(options, data) {\n    37→  return new Promise((resolve, reject) => {\n    38→    const req = http.request(options, (res) => {\n    39→      let body = '';\n    40→      res.on('data', (chunk) => body += chunk);\n    41→      res.on('end', () => {\n    42→        try {\n    43→          resolve({\n    44→            statusCode: res.statusCode,\n    45→            headers: res.headers,\n    46→            body: JSON.parse(body)\n    47→          });\n    48→        } catch (e) {\n    49→          resolve({\n    50→            statusCode: res.statusCode,\n    51→            headers: res.headers,\n    52→            body\n    53→          });\n    54→        }\n    55→      });\n    56→    });\n    57→\n    58→    req.on('error', reject);\n    59→    if (data) {\n    60→      req.write(JSON.stringify(data));\n    61→    }\n    62→    req.end();\n    63→  });\n    64→}\n    65→\n    66→/**\n    67→ * Helper to start HTTP server\n    68→ */\n    69→function startServer(bindingsPath) {\n    70→  const logger = { info: () => {}, error: () => {} };\n    71→  const app = createHttpServer({ logger, sessionBindingsPath: bindingsPath });\n    72→\n    73→  return new Promise((resolve) => {\n    74→    const server = http.createServer(app);\n    75→    server.listen(0, () => {\n    76→      const port = server.address().port;\n    77→      resolve({ server, port, cleanup: () => server.close() });\n    78→    });\n    79→  });\n    80→}\n    81→\n    82→test('F-018: POST /api/bind creates session binding', async (t) => {\n    83→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n    84→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n    85→\n    86→  try {\n    87→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n    88→    try {\n    89→      const response = await makeRequest({\n    90→        hostname: 'localhost',\n    91→        port,\n    92→        path: '/api/bind',\n    93→        method: 'POST',\n    94→        headers: { 'Content-Type': 'application/json' }\n    95→      },\n    96→      { webSessionId: 'web-session-123', telegramChatId: '456' });\n    97→\n    98→      assert.strictEqual(response.statusCode, 200);\n    99→      assert.strictEqual(response.body.ok, true);\n   100→\n   101→      // Verify binding via GET /api/bindings (more reliable than file read)\n   102→      const verifyResponse = await makeRequest({\n   103→        hostname: 'localhost',\n   104→        port,\n   105→        path: '/api/bindings?webSessionId=web-session-123',\n   106→        method: 'GET'\n   107→      });\n   108→\n   109→      assert.strictEqual(verifyResponse.statusCode, 200);\n   110→      assert.strictEqual(verifyResponse.body.ok, true);\n   111→      assert.strictEqual(verifyResponse.body.telegramChatId, '456');\n   112→    } finally {\n   113→      cleanupServer();\n   114→    }\n   115→  } finally {\n   116→    cleanupTemp();\n   117→  }\n   118→});\n   119→\n   120→test('F-018: POST /api/bind validates required fields', async (t) => {\n   121→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   122→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   123→\n   124→  try {\n   125→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   126→    try {\n   127→      const response = await makeRequest({\n   128→        hostname: 'localhost',\n   129→        port,\n   130→        path: '/api/bind',\n   131→        method: 'POST',\n   132→        headers: { 'Content-Type': 'application/json' }\n   133→      },\n   134→      { webSessionId: 'web-session-123' });\n   135→\n   136→      assert.strictEqual(response.statusCode, 400);\n   137→      assert.strictEqual(response.body.ok, false);\n   138→      assert.ok(response.body.error.includes('required'));\n   139→    } finally {\n   140→      cleanupServer();\n   141→    }\n   142→  } finally {\n   143→    cleanupTemp();\n   144→  }\n   145→});\n   146→\n   147→test('F-018: POST /api/unbind removes session binding', async (t) => {\n   148→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   149→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   150→\n   151→  try {\n   152→    // Create initial binding\n   153→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   154→      bindings: {\n   155→        'web-session-123': '456'\n   156→      }\n   157→    }));\n   158→\n   159→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   160→    try {\n   161→      // First verify the binding exists\n   162→      const beforeResponse = await makeRequest({\n   163→        hostname: 'localhost',\n   164→        port,\n   165→        path: '/api/bindings?webSessionId=web-session-123',\n   166→        method: 'GET'\n   167→      });\n   168→      assert.strictEqual(beforeResponse.body.telegramChatId, '456');\n   169→\n   170→      // Unbind\n   171→      const response = await makeRequest({\n   172→        hostname: 'localhost',\n   173→        port,\n   174→        path: '/api/unbind',\n   175→        method: 'POST',\n   176→        headers: { 'Content-Type': 'application/json' }\n   177→      },\n   178→      { webSessionId: 'web-session-123' });\n   179→\n   180→      assert.strictEqual(response.statusCode, 200);\n   181→      assert.strictEqual(response.body.ok, true);\n   182→\n   183→      // Verify binding removed via API\n   184→      const afterResponse = await makeRequest({\n   185→        hostname: 'localhost',\n   186→        port,\n   187→        path: '/api/bindings?webSessionId=web-session-123',\n   188→        method: 'GET'\n   189→      });\n   190→      assert.strictEqual(afterResponse.body.telegramChatId, null);\n   191→    } finally {\n   192→      cleanupServer();\n   193→    }\n   194→  } finally {\n   195→    cleanupTemp();\n   196→  }\n   197→});\n   198→\n   199→test('F-018: GET /api/bindings returns all bindings', async (t) => {\n   200→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   201→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   202→\n   203→  try {\n   204→    // Create initial bindings\n   205→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   206→      bindings: {\n   207→        'web-session-1': '456',\n   208→        'web-session-2': '456',\n   209→        'web-session-3': '789'\n   210→      }\n   211→    }));\n   212→\n   213→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   214→    try {\n   215→      const response = await makeRequest({\n   216→        hostname: 'localhost',\n   217→        port,\n   218→        path: '/api/bindings',\n   219→        method: 'GET'\n   220→      });\n   221→\n   222→      assert.strictEqual(response.statusCode, 200);\n   223→      assert.strictEqual(response.body.ok, true);\n   224→      assert.strictEqual(response.body.bindings['web-session-1'], '456');\n   225→      assert.strictEqual(response.body.bindings['web-session-2'], '456');\n   226→      assert.strictEqual(response.body.bindings['web-session-3'], '789');\n   227→      assert.strictEqual(Object.keys(response.body.bindings).length, 3);\n   228→    } finally {\n   229→      cleanupServer();\n   230→    }\n   231→  } finally {\n   232→    cleanupTemp();\n   233→  }\n   234→});\n   235→\n   236→test('F-018: GET /api/bindings?webSessionId returns specific binding', async (t) => {\n   237→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   238→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   239→\n   240→  try {\n   241→    // Create initial bindings\n   242→    fs.writeFileSync(bindingsPath, JSON.stringify({\n   243→      bindings: {\n   244→        'web-session-1': '456',\n   245→        'web-session-2': '789'\n   246→      }\n   247→    }));\n   248→\n   249→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   250→    try {\n   251→      const response = await makeRequest({\n   252→        hostname: 'localhost',\n   253→        port,\n   254→        path: '/api/bindings?webSessionId=web-session-2',\n   255→        method: 'GET'\n   256→      });\n   257→\n   258→      assert.strictEqual(response.statusCode, 200);\n   259→      assert.strictEqual(response.body.ok, true);\n   260→      assert.strictEqual(response.body.telegramChatId, '789');\n   261→    } finally {\n   262→      cleanupServer();\n   263→    }\n   264→  } finally {\n   265→    cleanupTemp();\n   266→  }\n   267→});\n   268→\n   269→test('F-018: GET /api/bindings returns null for non-existent session', async (t) => {\n   270→  const { dataDir, cleanup: cleanupTemp } = createTempDir();\n   271→  const bindingsPath = path.join(dataDir, 'session-bindings.json');\n   272→\n   273→  try {\n   274→    const { server, port, cleanup: cleanupServer } = await startServer(bindingsPath);\n   275→    try {\n   276→      const response = await makeRequest({\n   277→        hostname: 'localhost',\n   278→        port,\n   279→        path: '/api/bindings?webSessionId=non-existent',\n   280→        method: 'GET'\n   281→      });\n   282→\n   283→      assert.strictEqual(response.statusCode, 200);\n   284→      assert.strictEqual(response.body.ok, true);\n   285→      assert.strictEqual(response.body.telegramChatId, null);\n   286→    } finally {\n   287→      cleanupServer();\n   288→    }\n   289→  } finally {\n   290→    cleanupTemp();\n   291→  }\n   292→});\n   293→"}]},"parent_tool_use_id":"toolu_vrtx_01YQWojDuu9hhr9G6EMSopGA","session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"4b2b3483-a65f-4a74-befc-af45f879bfc4","timestamp":"2026-03-22T06:45:32.637Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01LaqNs4s2xhk2gKJJ172Zgp","type":"tool_result","content":"     1→/**\n     2→ * Tests for F-018 Session Binding Service\n     3→ * Task 1.2: Unit tests for session-bind.js\n     4→ */\n     5→\n     6→import { describe, test, beforeEach, afterEach } from 'node:test';\n     7→import assert from 'node:assert/strict';\n     8→import { rm, mkdir, readFile } from 'node:fs/promises';\n     9→import path from 'node:path';\n    10→import { fileURLToPath } from 'node:url';\n    11→\n    12→const __dirname = path.dirname(fileURLToPath(import.meta.url));\n    13→const testFixturesDir = path.join(__dirname, 'fixtures/session-bind-f018');\n    14→\n    15→describe('F-018 Session Binding Service', () => {\n    16→  let sessionBindingService;\n    17→  let SessionBindingService;\n    18→  let createSessionBindService;\n    19→\n    20→  beforeEach(async () => {\n    21→    // Clean up test fixtures directory\n    22→    await rm(testFixturesDir, { recursive: true, force: true });\n    23→    await mkdir(testFixturesDir, { recursive: true });\n    24→\n    25→    // Import module after cleaning\n    26→    const module = await import('../../src/services/session-bind.js');\n    27→    SessionBindingService = module.SessionBindingService;\n    28→    createSessionBindService = module.createSessionBindService;\n    29→\n    30→    // Create new instance with test persistence dir\n    31→    sessionBindingService = new SessionBindingService({\n    32→      persistenceDir: testFixturesDir\n    33→    });\n    34→  });\n    35→\n    36→  afterEach(async () => {\n    37→    // Clean up test directory\n    38→    await rm(testFixturesDir, { recursive: true, force: true });\n    39→  });\n    40→\n    41→  describe('init', () => {\n    42→    test('should initialize and create empty bindings file', async () => {\n    43→      await sessionBindingService.init();\n    44→\n    45→      const bindingsFile = path.join(testFixturesDir, 'session-bindings.json');\n    46→      const data = await readFile(bindingsFile, 'utf-8');\n    47→      const parsed = JSON.parse(data);\n    48→\n    49→      assert.ok(parsed.bindings);\n    50→      assert.strictEqual(Object.keys(parsed.bindings).length, 0);\n    51→      assert.ok(parsed.updatedAt);\n    52→    });\n    53→\n    54→    test('should load existing bindings from persistence', async () => {\n    55→      // Pre-create bindings file\n    56→      const existingData = {\n    57→        bindings: {\n    58→          'web-session-1': '123456789',\n    59→          'web-session-2': '987654321'\n    60→        },\n    61→        updatedAt: new Date().toISOString()\n    62→      };\n    63→      const bindingsFile = path.join(testFixturesDir, 'session-bindings.json');\n    64→      const { writeFile } = await import('node:fs/promises');\n    65→      await writeFile(bindingsFile, JSON.stringify(existingData));\n    66→\n    67→      await sessionBindingService.init();\n    68→\n    69→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '123456789');\n    70→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-2'), '987654321');\n    71→    });\n    72→  });\n    73→\n    74→  describe('bindSession', () => {\n    75→    test('should throw error if not initialized', () => {\n    76→      assert.throws(\n    77→        () => sessionBindingService.bindSession('web-1', '123456'),\n    78→        /not initialized/\n    79→      );\n    80→    });\n    81→\n    82→    test('should throw error if webSessionId is empty', async () => {\n    83→      await sessionBindingService.init();\n    84→\n    85→      assert.throws(\n    86→        () => sessionBindingService.bindSession('', '123456'),\n    87→        /webSessionId cannot be empty/\n    88→      );\n    89→\n    90→      assert.throws(\n    91→        () => sessionBindingService.bindSession('  ', '123456'),\n    92→        /webSessionId cannot be empty/\n    93→      );\n    94→    });\n    95→\n    96→    test('should throw error if telegramChatId is empty', async () => {\n    97→      await sessionBindingService.init();\n    98→\n    99→      assert.throws(\n   100→        () => sessionBindingService.bindSession('web-1', ''),\n   101→        /telegramChatId cannot be empty/\n   102→      );\n   103→    });\n   104→\n   105→    test('should bind session to Telegram chat', async () => {\n   106→      await sessionBindingService.init();\n   107→\n   108→      const result = sessionBindingService.bindSession('web-session-1', '123456789');\n   109→\n   110→      assert.strictEqual(result.ok, true);\n   111→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '123456789');\n   112→    });\n   113→\n   114→    test('should persist binding to file', async () => {\n   115→      await sessionBindingService.init();\n   116→      sessionBindingService.bindSession('web-session-1', '123456789');\n   117→      await sessionBindingService.flush();\n   118→\n   119→      // Create new instance to verify persistence\n   120→      const newService = new SessionBindingService({\n   121→        persistenceDir: testFixturesDir\n   122→      });\n   123→      await newService.init();\n   124→\n   125→      assert.strictEqual(newService.getBoundChatId('web-session-1'), '123456789');\n   126→    });\n   127→\n   128→    test('should overwrite existing binding for same web session', async () => {\n   129→      await sessionBindingService.init();\n   130→      sessionBindingService.bindSession('web-session-1', '123456789');\n   131→      sessionBindingService.bindSession('web-session-1', '987654321');\n   132→\n   133→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), '987654321');\n   134→      assert.deepStrictEqual(sessionBindingService.getBoundWebSessions('123456789'), []);\n   135→    });\n   136→  });\n   137→\n   138→  describe('unbindSession', () => {\n   139→    test('should throw error if not initialized', () => {\n   140→      assert.throws(\n   141→        () => sessionBindingService.unbindSession('web-1'),\n   142→        /not initialized/\n   143→      );\n   144→    });\n   145→\n   146→    test('should return error if no binding exists', async () => {\n   147→      await sessionBindingService.init();\n   148→\n   149→      const result = sessionBindingService.unbindSession('non-existent');\n   150→      assert.strictEqual(result.ok, false);\n   151→      assert.ok(result.error.includes('No binding found'));\n   152→    });\n   153→\n   154→    test('should unbind existing session', async () => {\n   155→      await sessionBindingService.init();\n   156→      sessionBindingService.bindSession('web-session-1', '123456789');\n   157→\n   158→      const result = sessionBindingService.unbindSession('web-session-1');\n   159→\n   160→      assert.strictEqual(result.ok, true);\n   161→      assert.strictEqual(sessionBindingService.getBoundChatId('web-session-1'), null);\n   162→    });\n   163→\n   164→    test('should update reverse bindings on unbind', async () => {\n   165→      await sessionBindingService.init();\n   166→      sessionBindingService.bindSession('web-1', '123456');\n   167→      sessionBindingService.bindSession('web-2', '123456');\n   168→\n   169→      assert.deepStrictEqual(\n   170→        new Set(sessionBindingService.getBoundWebSessions('123456')),\n   171→        new Set(['web-1', 'web-2'])\n   172→      );\n   173→\n   174→      sessionBindingService.unbindSession('web-1');\n   175→\n   176→      assert.deepStrictEqual(\n   177→        sessionBindingService.getBoundWebSessions('123456'),\n   178→        ['web-2']\n   179→      );\n   180→    });\n   181→  });\n   182→\n   183→  describe('getBoundChatId', () => {\n   184→    test('should throw error if not initialized', () => {\n   185→      assert.throws(\n   186→        () => sessionBindingService.getBoundChatId('web-1'),\n   187→        /not initialized/\n   188→      );\n   189→    });\n   190→\n   191→    test('should return null for non-existent binding', async () => {\n   192→      await sessionBindingService.init();\n   193→\n   194→      assert.strictEqual(sessionBindingService.getBoundChatId('non-existent'), null);\n   195→    });\n   196→\n   197→    test('should return correct chat ID for bound session', async () => {\n   198→      await sessionBindingService.init();\n   199→      sessionBindingService.bindSession('web-1', '123456');\n   200→\n   201→      assert.strictEqual(sessionBindingService.getBoundChatId('web-1'), '123456');\n   202→    });\n   203→  });\n   204→\n   205→  describe('getBoundWebSessions', () => {\n   206→    test('should throw error if not initialized', () => {\n   207→      assert.throws(\n   208→        () => sessionBindingService.getBoundWebSessions('123456'),\n   209→        /not initialized/\n   210→      );\n   211→    });\n   212→\n   213→    test('should return empty array for chat with no bindings', async () => {\n   214→      await sessionBindingService.init();\n   215→\n   216→      assert.deepStrictEqual(sessionBindingService.getBoundWebSessions('123456'), []);\n   217→    });\n   218→\n   219→    test('should return all web sessions bound to a chat ID', async () => {\n   220→      await sessionBindingService.init();\n   221→      sessionBindingService.bindSession('web-1', '123456');\n   222→      sessionBindingService.bindSession('web-2', '123456');\n   223→      sessionBindingService.bindSession('web-3', '789012');\n   224→\n   225→      const sessions = sessionBindingService.getBoundWebSessions('123456');\n   226→      assert.ok(sessions.includes('web-1'));\n   227→      assert.ok(sessions.includes('web-2'));\n   228→      assert.strictEqual(sessions.length, 2);\n   229→    });\n   230→  });\n   231→\n   232→  describe('getAllBindings', () => {\n   233→    test('should throw error if not initialized', () => {\n   234→      assert.throws(\n   235→        () => sessionBindingService.getAllBindings(),\n   236→        /not initialized/\n   237→      );\n   238→    });\n   239→\n   240→    test('should return all bindings as object', async () => {\n   241→      await sessionBindingService.init();\n   242→      sessionBindingService.bindSession('web-1', '123456');\n   243→      sessionBindingService.bindSession('web-2', '789012');\n   244→\n   245→      const all = sessionBindingService.getAllBindings();\n   246→\n   247→      assert.strictEqual(all['web-1'], '123456');\n   248→      assert.strictEqual(all['web-2'], '789012');\n   249→      assert.strictEqual(Object.keys(all).length, 2);\n   250→    });\n   251→  });\n   252→\n   253→  describe('clearAllBindings', () => {\n   254→    test('should throw error if not initialized', () => {\n   255→      assert.throws(\n   256→        () => sessionBindingService.clearAllBindings(),\n   257→        /not initialized/\n   258→      );\n   259→    });\n   260→\n   261→    test('should clear all bindings', async () => {\n   262→      await sessionBindingService.init();\n   263→      sessionBindingService.bindSession('web-1', '123456');\n   264→      sessionBindingService.bindSession('web-2', '789012');\n   265→\n   266→      const result = sessionBindingService.clearAllBindings();\n   267→\n   268→      assert.strictEqual(result.ok, true);\n   269→      assert.strictEqual(sessionBindingService.getBoundChatId('web-1'), null);\n   270→      assert.strictEqual(sessionBindingService.getBoundChatId('web-2'), null);\n   271→    });\n   272→  });\n   273→\n   274→  describe('createSessionBindService factory', () => {\n   275→    test('should create an instance with bindingsPath option', async () => {\n   276→      const bindingsPath = path.join(testFixturesDir, 'session-bindings.json');\n   277→      const service = createSessionBindService({ bindingsPath });\n   278→\n   279→      // Wait for auto-init to complete\n   280→      await service.flush();\n   281→      await service.init(); // safe to call again (idempotent)\n   282→\n   283→      // Should work after init\n   284→      const result = service.bindSession('web-1', '123456');\n   285→      assert.strictEqual(result.ok, true);\n   286→      assert.strictEqual(service.getBoundChatId('web-1'), '123456');\n   287→    });\n   288→\n   289→    test('should create an instance with persistenceDir option', async () => {\n   290→      const service = createSessionBindService({ persistenceDir: testFixturesDir });\n   291→\n   292→      // Wait for auto-init to complete\n   293→      await service.flush();\n   294→      await service.init();\n   295→\n   296→      const result = service.bindSession('web-2', '789012');\n   297→      assert.strictEqual(result.ok, true);\n   298→      assert.strictEqual(service.getBoundChatId('web-2'), '789012');\n   299→    });\n   300→  });\n   301→});\n   302→"}]},"parent_tool_use_id":"toolu_vrtx_01YQWojDuu9hhr9G6EMSopGA","session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"16ad333e-921b-4865-861c-57c756cd536f","timestamp":"2026-03-22T06:45:32.638Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01LNkpVqapmGndPJ3vBmsvNw","type":"tool_result","content":"     1→/**\n     2→ * Message Router Unit Tests\n     3→ * Tests for src/services/message-router.js\n     4→ *\n     5→ * F-018: Web-Telegram Bidirectional Sync\n     6→ */\n     7→\n     8→import test from 'node:test';\n     9→import assert from 'node:assert/strict';\n    10→\n    11→import { sessionStore } from '../../src/services/session-store.js';\n    12→import { createMessageRouter } from '../../src/services/message-router.js';\n    13→\n    14→// Mock dependencies\n    15→const mockSessionStore = {\n    16→  append: test.mock.fn(),\n    17→  get: test.mock.fn(() => []),\n    18→  clear: test.mock.fn(),\n    19→  toPrompt: test.mock.fn(() => 'Mock prompt: you are an AI assistant. 用户: hello world\\n助手: previous context\\n')\n    20→};\n    21→\n    22→const mockExecuteAiCli = test.mock.fn(async (options) => {\n    23→  return {\n    24→    output: `AI response to: ${options.prompt}`,\n    25→    timedOut: false,\n    26→    interrupted: false,\n    27→    elapsedMs: 100,\n    28→    exitCode: 0,\n    29→    stderr: ''\n    30→  };\n    31→});\n    32→\n    33→const mockRealtimeHub = {\n    34→  publish: test.mock.fn(),\n    35→  subscribe: test.mock.fn(() => () => {})\n    36→};\n    37→\n    38→/**\n    39→ * Helper to create a message router with mocks\n    40→ */\n    41→function createRouter(options = {}) {\n    42→  return createMessageRouter({\n    43→    aiCliExecutor: options.aiCliExecutor || mockExecuteAiCli,\n    44→    sessionStore: options.sessionStore || mockSessionStore,\n    45→    realtimeHub: options.realtimeHub || mockRealtimeHub\n    46→  });\n    47→}\n    48→\n    49→test('message-router: processMessage uses unified sessionKey when telegramChatId bound', async () => {\n    50→  const router = createRouter();\n    51→\n    52→  await router.processMessage({\n    53→    channel: 'web',\n    54→    sessionId: 'web-session-123',\n    55→    telegramChatId: '456',\n    56→    message: 'test message',\n    57→    userId: 'user-123'\n    58→  });\n    59→\n    60→  // Should use telegram:{chatId} as session key\n    61→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'telegram:456');\n    62→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[1], 'user');\n    63→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[2], 'test message');\n    64→\n    65→  // Should call executeAiCli with telegram session key\n    66→  assert.strictEqual(mockExecuteAiCli.mock.calls[0].arguments[0].sessionId, 'telegram:456');\n    67→});\n    68→\n    69→test('message-router: processMessage uses web sessionKey when no telegramChatId', async () => {\n    70→  const router = createRouter();\n    71→\n    72→  await router.processMessage({\n    73→    channel: 'web',\n    74→    sessionId: 'web-session-123',\n    75→    message: 'test message',\n    76→    userId: 'user-123'\n    77→  });\n    78→\n    79→  // Should use web:{sessionId} as session key for isolated session\n    80→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'web:web-session-123');\n    81→});\n    82→\n    83→test('message-router: processMessage calls executeAiCli with message', async () => {\n    84→  const router = createRouter();\n    85→\n    86→  await router.processMessage({\n    87→    channel: 'web',\n    88→    sessionId: 'web-session-123',\n    89→    message: 'hello world',\n    90→    userId: 'user-123'\n    91→  });\n    92→\n    93→  assert.strictEqual(mockExecuteAiCli.mock.calls.length, 1);\n    94→  const callArgs = mockExecuteAiCli.mock.calls[0].arguments[0];\n    95→  assert.ok(callArgs.prompt.includes('hello world'));\n    96→});\n    97→\n    98→test('message-router: processMessage appends user message to sessionStore', async () => {\n    99→  const router = createRouter();\n   100→\n   101→  await router.processMessage({\n   102→    channel: 'telegram',\n   103→    sessionId: '456',\n   104→    message: 'user question',\n   105→    userId: 'user-123'\n   106→  });\n   107→\n   108→  assert.strictEqual(mockSessionStore.append.mock.calls.length, 2); // user + assistant\n   109→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[0], 'telegram:456');\n   110→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[1], 'user');\n   111→  assert.strictEqual(mockSessionStore.append.mock.calls[0].arguments[2], 'user question');\n   112→});\n   113→\n   114→test('message-router: processMessage appends assistant reply to sessionStore', async () => {\n   115→  const router = createRouter();\n   116→\n   117→  const result = await router.processMessage({\n   118→    channel: 'web',\n   119→    sessionId: 'web-session-123',\n   120→    message: 'test',\n   121→    userId: 'user-123'\n   122→  });\n   123→\n   124→  assert.strictEqual(mockSessionStore.append.mock.calls.length, 2);\n   125→  const assistantCall = mockSessionStore.append.mock.calls[1].arguments;\n   126→  assert.strictEqual(assistantCall[0], 'web:web-session-123');\n   127→  assert.strictEqual(assistantCall[1], 'assistant');\n   128→  assert.ok(assistantCall[2].includes('AI response'));\n   129→});\n   130→\n   131→test('message-router: processMessage publishes status events', async () => {\n   132→  const router = createRouter();\n   133→\n   134→  await router.processMessage({\n   135→    channel: 'web',\n   136→    sessionId: 'web-session-123',\n   137→    message: 'test',\n   138→    userId: 'user-123'\n   139→  });\n   140→\n   141→  assert.ok(mockRealtimeHub.publish.mock.calls.length > 0);\n   142→\n   143→  // Find 'accepted' status event\n   144→  const acceptedEvent = mockRealtimeHub.publish.mock.calls.find(\n   145→    (call) => call.arguments[1]?.type === 'status' &&\n   146→              call.arguments[1]?.payload?.stage === 'accepted'\n   147→  );\n   148→  assert.ok(acceptedEvent, 'Should publish accepted status event');\n   149→});\n   150→\n   151→test('message-router: processMessage publishes assistant events', async () => {\n   152→  const router = createRouter();\n   153→\n   154→  await router.processMessage({\n   155→    channel: 'web',\n   156→    sessionId: 'web-session-123',\n   157→    message: 'test',\n   158→    userId: 'user-123'\n   159→  });\n   160→\n   161→  // Find 'assistant_done' event\n   162→  const doneEvent = mockRealtimeHub.publish.mock.calls.find(\n   163→    (call) => call.arguments[1]?.type === 'assistant_done'\n   164→  );\n   165→  assert.ok(doneEvent, 'Should publish assistant_done event');\n   166→\n   167→  assert.ok(doneEvent.arguments[1].payload.reply.includes('AI response'));\n   168→  assert.strictEqual(doneEvent.arguments[1].payload.channel, 'web');\n   169→});\n   170→\n   171→test('message-router: processMessage passes userId to executeAiCli', async () => {\n   172→  const router = createRouter();\n   173→\n   174→  await router.processMessage({\n   175→    channel: 'telgram',\n   176→    sessionId: '456',\n   177→    message: 'test',\n   178→    userId: 'test-user-789'\n   179→  });\n   180→\n   181→  const callArgs = mockExecuteAiCli.mock.calls[0].arguments[0];\n   182→  assert.strictEqual(callArgs.userId, 'test-user-789');\n   183→});\n   184→\n   185→test('message-router: processMessage calls onChunk hook', async () => {\n   186→  let chunkReceived = false;\n   187→  const customMockExecute = test.mock.fn(async (options) => {\n   188→    if (options.hooks?.onChunk) {\n   189→      options.hooks.onChunk('partial output');\n   190→    }\n   191→    return {\n   192→      output: 'complete output',\n   193→      timedOut: false,\n   194→      interrupted: false,\n   195→      elapsedMs: 10,\n   196→      exitCode: 0,\n   197→      stderr: ''\n   198→    };\n   199→  });\n   200→\n   201→  const router = createRouter({ aiCliExecutor: customMockExecute });\n   202→\n   203→  await router.processMessage({\n   204→    channel: 'web',\n   205→    sessionId: 'web-session-123',\n   206→    message: 'test',\n   207→    userId: 'user-123',\n   208→    hooks: {\n   209→      onAssistantChunk: (data) => {\n   210→        chunkReceived = true;\n   211→        assert.strictEqual(data.text, 'partial output');\n   212→      }\n   213→    }\n   214→  });\n   215→\n   216→  assert.strictEqual(chunkReceived, true);\n   217→});\n   218→\n   219→test('message-router: processMessage validates required fields', async () => {\n   220→  const router = createRouter();\n   221→\n   222→  await assert.rejects(\n   223→    router.processMessage({\n   224→      channel: 'web',\n   225→      // missing sessionId\n   226→      message: 'test',\n   227→      userId: 'user-123'\n   228→    }),\n   229→    { message: /sessionId 不能为空/ }\n   230→  );\n   231→\n   232→  await assert.rejects(\n   233→    router.processMessage({\n   234→      channel: 'web',\n   235→      sessionId: 'web-session-123',\n   236→      // missing message\n   237→      userId: 'user-123'\n   238→    }),\n   239→    { message: /message 不能为空/ }\n   240→  );\n   241→});\n   242→\n   243→test('message-router: processMessage returns the AI response', async () => {\n   244→  const router = createRouter();\n   245→\n   246→  const result = await router.processMessage({\n   247→    channel: 'web',\n   248→    sessionId: 'web-session-123',\n   249→    message: 'test',\n   250→    userId: 'user-123'\n   251→  });\n   252→\n   253→  assert.ok(result.reply);\n   254→  assert.ok(result.reply.includes('AI response'));\n   255→});\n   256→\n   257→test.beforeEach(() => {\n   258→  mockSessionStore.append.mock.resetCalls();\n   259→  mockExecuteAiCli.mock.resetCalls();\n   260→  mockRealtimeHub.publish.mock.resetCalls();\n   261→});\n   262→"}]},"parent_tool_use_id":"toolu_vrtx_01YQWojDuu9hhr9G6EMSopGA","session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"7b7d8a6d-9623-40fc-ac34-f2938a880c8c","timestamp":"2026-03-22T06:45:32.641Z"}
