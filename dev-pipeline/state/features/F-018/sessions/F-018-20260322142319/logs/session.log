{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01LJruc6wHoBXY3yAR9z1VTf","type":"tool_result","content":"     1→/**\n     2→ * Message Router Service\n     3→ *\n     4→ * Unified message processor for both Web and Telegram channels.\n     5→ * Routes messages through ai-cli-service and publishes events via realtime-hub.\n     6→ *\n     7→ * F-018: Web-Telegram Bidirectional Sync\n     8→ */\n     9→\n    10→import { sanitizeInput } from '../security/guard.js';\n    11→import { logger } from '../utils/logger.js';\n    12→import { chatQueue } from './chat-queue.js';\n    13→\n    14→/**\n    15→ * @typedef {Object} MessageProcessOptions\n    16→ * @property {string} channel - Channel name ('web' or 'telegram')\n    17→ * @property {string} sessionId - Session ID (web session ID or Telegram chat ID)\n    18→ * @property {string} message - User message\n    19→ * @property {string} [telegramChatId] - Bound Telegram chat ID (optional)\n    20→ * @property {string} [userId] - User ID who initiated the message\n    21→ * @property {Object} [hooks] - Callback hooks\n    22→ * @property {Function} [hooks.onStatus] - Status change callback (payload) => void\n    23→ * @property {Function} [hooks.onAssistantChunk] - Chunk callback (data) => void\n    24→ * @property {Function} [hooks.onAssistantDone] - Done callback (data) => void\n    25→ */\n    26→\n    27→/**\n    28→ * Creates a message router instance\n    29→ * @param {Object} dependencies\n    30→ * @param {Function} dependencies.aiCliExecutor - AI CLI executor (executeAiCli function)\n    31→ * @param {Object} dependencies.sessionStore - Session store instance\n    32→ * @param {Object} dependencies.realtimeHub - Realtime hub instance\n    33→ * @returns {MessageRouter}\n    34→ */\n    35→export function createMessageRouter({ aiCliExecutor, sessionStore, realtimeHub }) {\n    36→  return {\n    37→    /**\n    38→     * Process a message from any channel\n    39→     * @param {MessageProcessOptions} options\n    40→     * @returns {Promise<{reply: string}>}\n    41→     */\n    42→    async processMessage(options) {\n    43→      const {\n    44→        channel,\n    45→        sessionId,\n    46→        message,\n    47→        telegramChatId,\n    48→        userId,\n    49→        hooks = {}\n    50→      } = options;\n    51→\n    52→      // Validate required fields\n    53→      const normalizedChannel = String(channel ?? '').trim();\n    54→      const normalizedSessionId = String(sessionId ?? '').trim();\n    55→      const normalizedMessage = String(message ?? '').trim();\n    56→\n    57→      if (!normalizedSessionId) {\n    58→        throw new Error('sessionId 不能为空。');\n    59→      }\n    60→\n    61→      if (!normalizedMessage) {\n    62→        throw new Error('message 不能为空。');\n    63→      }\n    64→\n    65→      // Determine session key based on binding\n    66→      let sessionKey;\n    67→      if (telegramChatId) {\n    68→        sessionKey = `telegram:${telegramChatId}`;\n    69→      } else {\n    70→        sessionKey = `${normalizedChannel}:${normalizedSessionId}`;\n    71→      }\n    72→\n    73→      // Use chat queue to ensure sequential processing per session\n    74→      return chatQueue.run(sessionKey, async () => {\n    75→        const sanitized = sanitizeInput(normalizedMessage);\n    76→\n    77→        // Publish accepted status\n    78→        hooks.onStatus?.({ stage: 'accepted', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n    79→        realtimeHub.publish(sessionKey, { type: 'status', payload: { stage: 'accepted', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n    80→\n    81→        // Append user message to session store\n    82→        sessionStore.append(sessionKey, 'user', sanitized);\n    83→\n    84→        // Publish user message event for cross-channel sync\n    85→        realtimeHub.publish(sessionKey, { type: 'user_message', payload: { channel: normalizedChannel, sessionId: normalizedSessionId, message: sanitized, timestamp: Date.now() } });\n    86→\n    87→        // Build prompt for AI CLI\n    88→        const prompt = sessionStore.toPrompt(sessionKey, normalizedChannel);\n    89→\n    90→        // Publish running status\n    91→        hooks.onStatus?.({ stage: 'running', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n    92→        realtimeHub.publish(sessionKey, { type: 'status', payload: { stage: 'running', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n    93→\n    94→        logger.info({ sessionKey, channel: normalizedChannel, userId }, 'Processing message');\n    95→\n    96→        // Execute via AI CLI service\n    97→        const result = await aiCliExecutor({\n    98→          sessionId: sessionKey,\n    99→          prompt,\n   100→          userId,\n   101→          hooks: {\n   102→            onChunk: (text) => {\n   103→              // Forward chunks to caller and realtime hub\n   104→              hooks.onAssistantChunk?.({ text, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n   105→              realtimeHub.publish(sessionKey, { type: 'assistant_chunk', payload: { text, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n   106→            },\n   107→            onStatus: (status) => {\n   108→              logger.debug({ sessionKey, status }, 'AI CLI status changed');\n   109→            }\n   110→          }\n   111→        });\n   112→\n   113→        // Append assistant reply to session store\n   114→        sessionStore.append(sessionKey, 'assistant', result.output);\n   115→\n   116→        // Publish assistant done event\n   117→        const donePayload = { reply: result.output, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId };\n   118→        hooks.onAssistantDone?.(donePayload);\n   119→        realtimeHub.publish(sessionKey, { type: 'assistant_done', payload: { ...donePayload, timestamp: Date.now() } });\n   120→\n   121→        logger.info({ sessionKey, elapsedMs: result.elapsedMs }, 'Message processed');\n   122→\n   123→        return { reply: result.output };\n   124→      });\n   125→    }\n   126→  };\n   127→}\n   128→"}]},"parent_tool_use_id":null,"session_id":"1825d45b-0e87-4048-aee3-8c65afe6c801","uuid":"57faad15-7bd8-4936-ad17-b526b86f0418","timestamp":"2026-03-22T06:24:04.468Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/services/message-router.js","content":"/**\n * Message Router Service\n *\n * Unified message processor for both Web and Telegram channels.\n * Routes messages through ai-cli-service and publishes events via realtime-hub.\n *\n * F-018: Web-Telegram Bidirectional Sync\n */\n\nimport { sanitizeInput } from '../security/guard.js';\nimport { logger } from '../utils/logger.js';\nimport { chatQueue } from './chat-queue.js';\n\n/**\n * @typedef {Object} MessageProcessOptions\n * @property {string} channel - Channel name ('web' or 'telegram')\n * @property {string} sessionId - Session ID (web session ID or Telegram chat ID)\n * @property {string} message - User message\n * @property {string} [telegramChatId] - Bound Telegram chat ID (optional)\n * @property {string} [userId] - User ID who initiated the message\n * @property {Object} [hooks] - Callback hooks\n * @property {Function} [hooks.onStatus] - Status change callback (payload) => void\n * @property {Function} [hooks.onAssistantChunk] - Chunk callback (data) => void\n * @property {Function} [hooks.onAssistantDone] - Done callback (data) => void\n */\n\n/**\n * Creates a message router instance\n * @param {Object} dependencies\n * @param {Function} dependencies.aiCliExecutor - AI CLI executor (executeAiCli function)\n * @param {Object} dependencies.sessionStore - Session store instance\n * @param {Object} dependencies.realtimeHub - Realtime hub instance\n * @returns {MessageRouter}\n */\nexport function createMessageRouter({ aiCliExecutor, sessionStore, realtimeHub }) {\n  return {\n    /**\n     * Process a message from any channel\n     * @param {MessageProcessOptions} options\n     * @returns {Promise<{reply: string}>}\n     */\n    async processMessage(options) {\n      const {\n        channel,\n        sessionId,\n        message,\n        telegramChatId,\n        userId,\n        hooks = {}\n      } = options;\n\n      // Validate required fields\n      const normalizedChannel = String(channel ?? '').trim();\n      const normalizedSessionId = String(sessionId ?? '').trim();\n      const normalizedMessage = String(message ?? '').trim();\n\n      if (!normalizedSessionId) {\n        throw new Error('sessionId 不能为空。');\n      }\n\n      if (!normalizedMessage) {\n        throw new Error('message 不能为空。');\n      }\n\n      // Determine session key based on binding\n      let sessionKey;\n      if (telegramChatId) {\n        sessionKey = `telegram:${telegramChatId}`;\n      } else {\n        sessionKey = `${normalizedChannel}:${normalizedSessionId}`;\n      }\n\n      // Use chat queue to ensure sequential processing per session\n      return chatQueue.run(sessionKey, async () => {\n        const sanitized = sanitizeInput(normalizedMessage);\n\n        // Publish accepted status\n        hooks.onStatus?.({ stage: 'accepted', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n        realtimeHub.publish(sessionKey, { type: 'status', payload: { stage: 'accepted', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n\n        // Append user message to session store\n        sessionStore.append(sessionKey, 'user', sanitized);\n\n        // Publish user message event for cross-channel sync\n        realtimeHub.publish(sessionKey, { type: 'user_message', payload: { channel: normalizedChannel, sessionId: normalizedSessionId, message: sanitized, timestamp: Date.now() } });\n\n        // Build prompt for AI CLI\n        const prompt = sessionStore.toPrompt(sessionKey, normalizedChannel);\n\n        // Publish running status\n        hooks.onStatus?.({ stage: 'running', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n        realtimeHub.publish(sessionKey, { type: 'status', payload: { stage: 'running', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n\n        logger.info({ sessionKey, channel: normalizedChannel, userId }, 'Processing message');\n\n        // Execute via AI CLI service\n        const result = await aiCliExecutor({\n          sessionId: sessionKey,\n          prompt,\n          userId,\n          hooks: {\n            onChunk: (text) => {\n              // Forward chunks to caller and realtime hub\n              hooks.onAssistantChunk?.({ text, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n              realtimeHub.publish(sessionKey, { type: 'assistant_chunk', payload: { text, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n            },\n            onStatus: (status) => {\n              logger.debug({ sessionKey, status }, 'AI CLI status changed');\n            }\n          }\n        });\n\n        // Append assistant reply to session store\n        sessionStore.append(sessionKey, 'assistant', result.output);\n\n        // Publish assistant done event\n        const donePayload = { reply: result.output, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId };\n        hooks.onAssistantDone?.(donePayload);\n        realtimeHub.publish(sessionKey, { type: 'assistant_done', payload: { ...donePayload, timestamp: Date.now() } });\n\n        logger.info({ sessionKey, elapsedMs: result.elapsedMs }, 'Message processed');\n\n        return { reply: result.output };\n      });\n    }\n  };\n}\n","numLines":128,"startLine":1,"totalLines":128}}}
