{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01HTcBmv2strk7JSPKDskaQ6","type":"tool_result","content":"     1→/**\n     2→ * Web Command Router\n     3→ * F-019: Routes slash commands from Web chat to existing command handlers.\n     4→ * Adapts the Telegram-centric handler context for web usage.\n     5→ */\n     6→\n     7→import { parseCommand } from '../bot/commands/parser.js';\n     8→import { getCommand, getAllCommands, getAliasMap } from '../bot/commands/registry.js';\n     9→import { validateCommand } from '../bot/commands/validator.js';\n    10→import { executeSystemCommand } from '../services/system-exec-service.js';\n    11→\n    12→/**\n    13→ * Escape HTML special characters for safe web display.\n    14→ * @param {string} text\n    15→ * @returns {string}\n    16→ */\n    17→function escapeHtml(text) {\n    18→  return String(text)\n    19→    .replace(/&/g, '&amp;')\n    20→    .replace(/</g, '&lt;')\n    21→    .replace(/>/g, '&gt;')\n    22→    .replace(/\"/g, '&quot;');\n    23→}\n    24→\n    25→/**\n    26→ * Format command output for web display.\n    27→ * Wraps multi-line output in <pre> blocks.\n    28→ * @param {string} text\n    29→ * @returns {string}\n    30→ */\n    31→function formatForWeb(text) {\n    32→  if (!text) return '';\n    33→  const escaped = escapeHtml(text);\n    34→  // If multi-line or looks like code output, wrap in pre\n    35→  if (text.includes('\\n') || text.includes('\\t')) {\n    36→    return `<pre>${escaped}</pre>`;\n    37→  }\n    38→  return escaped;\n    39→}\n    40→\n    41→/**\n    42→ * Handle the /exec command for web — executes a system command.\n    43→ * @param {string[]} args - Command arguments (rest after /exec)\n    44→ * @returns {Promise<string>} HTML-formatted output\n    45→ */\n    46→async function handleExecCommand(args) {\n    47→  if (!args || args.length === 0) {\n    48→    return escapeHtml('用法: /exec <command>');\n    49→  }\n    50→\n    51→  const command = args.join(' ');\n    52→\n    53→  try {\n    54→    const result = await executeSystemCommand(command);\n    55→    const parts = [];\n    56→\n    57→    if (result.stdout?.trim()) {\n    58→      parts.push(`<pre>${escapeHtml(result.stdout)}</pre>`);\n    59→    }\n    60→    if (result.stderr?.trim()) {\n    61→      parts.push(`<pre class=\"stderr\">${escapeHtml(result.stderr)}</pre>`);\n    62→    }\n    63→\n    64→    const exitInfo = `<span class=\"exit-code\">Exit: ${result.exitCode}</span>`;\n    65→    parts.push(exitInfo);\n    66→\n    67→    return parts.join('\\n') || escapeHtml('(no output)');\n    68→  } catch (error) {\n    69→    return escapeHtml(`❌ 执行失败: ${error.message}`);\n    70→  }\n    71→}\n    72→\n    73→/**\n    74→ * Route and dispatch a web slash command.\n    75→ * Returns HTML-formatted result string, or null if not a slash command.\n    76→ *\n    77→ * @param {string} message - User message text\n    78→ * @param {string} sessionId - Web session ID\n    79→ * @returns {Promise<string|null>} HTML result or null if not a command\n    80→ */\n    81→export async function routeWebCommand(message, sessionId) {\n    82→  if (!message || !message.startsWith('/')) {\n    83→    return null;\n    84→  }\n    85→\n    86→  const text = message.trim();\n    87→  const aliasMap = getAliasMap();\n    88→  const parsed = parseCommand(text, aliasMap);\n    89→\n    90→  if (!parsed) {\n    91→    return null;\n    92→  }\n    93→\n    94→  // Handle /exec specially — maps to system exec service\n    95→  if (parsed.command === 'exec') {\n    96→    const args = [\n    97→      ...(parsed.subcommand ? [parsed.subcommand] : []),\n    98→      ...parsed.args\n    99→    ];\n   100→    return handleExecCommand(args);\n   101→  }\n   102→\n   103→  // Look up registered command\n   104→  const entry = getCommand(parsed.command);\n   105→\n   106→  if (!entry) {\n   107→    return escapeHtml(`❌ 未知命令: /${parsed.command}。输入 / 查看可用命令。`);\n   108→  }\n   109→\n   110→  const { meta, handler } = entry;\n   111→\n   112→  // Validate command\n   113→  const validation = validateCommand(parsed, meta);\n   114→  if (!validation.valid) {\n   115→    const errors = validation.errors.map((e) => e.message || e.param).join(', ');\n   116→    return escapeHtml(`❌ 命令参数错误: ${errors}\\n用法: ${meta.usage}`);\n   117→  }\n   118→\n   119→  // Collect output via reply collector\n   120→  const outputParts = [];\n   121→\n   122→  const webHandlerCtx = {\n   123→    ctx: null, // No Telegram context for web\n   124→    parsed,\n   125→    meta,\n   126→    params: validation.normalized || {},\n   127→    userId: null, // No Telegram user for web\n   128→    userRole: 'operator', // Default role for web users\n   129→    sessionId,\n   130→    requiresConfirmation: false,\n   131→    reply: async (text) => {\n   132→      outputParts.push(formatForWeb(text));\n   133→    },\n   134→    replyFile: async (content, filename) => {\n   135→      outputParts.push(escapeHtml(`[文件: ${filename}]`));\n   136→    },\n   137→    args: parsed.args || []\n   138→  };\n   139→\n   140→  try {\n   141→    await handler(webHandlerCtx);\n   142→  } catch (error) {\n   143→    return escapeHtml(`❌ 命令执行错误: ${error.message}`);\n   144→  }\n   145→\n   146→  return outputParts.join('\\n') || escapeHtml('(命令已执行，无输出)');\n   147→}\n   148→\n   149→/**\n   150→ * Get the list of available commands for autocomplete.\n   151→ * @returns {Array<{name: string, aliases: string[], description: string, usage: string}>}\n   152→ */\n   153→export function getAvailableCommands() {\n   154→  const registered = getAllCommands().map((entry) => ({\n   155→    name: entry.meta.name,\n   156→    aliases: entry.meta.aliases || [],\n   157→    description: entry.meta.description || '',\n   158→    usage: entry.meta.usage || `/${entry.meta.name}`\n   159→  }));\n   160→\n   161→  // Add /exec which is handled directly (not in registry)\n   162→  const execCommand = {\n   163→    name: 'exec',\n   164→    aliases: [],\n   165→    description: '执行系统命令',\n   166→    usage: '/exec <command>'\n   167→  };\n   168→\n   169→  return [execCommand, ...registered];\n   170→}\n   171→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7831a64a-70c3-467a-b2e5-6975a875912b","uuid":"b84bd5ab-729d-4ff9-8234-cabb4c2b7209","timestamp":"2026-03-22T08:21:58.023Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/routes/web-command-router.js","content":"/**\n * Web Command Router\n * F-019: Routes slash commands from Web chat to existing command handlers.\n * Adapts the Telegram-centric handler context for web usage.\n */\n\nimport { parseCommand } from '../bot/commands/parser.js';\nimport { getCommand, getAllCommands, getAliasMap } from '../bot/commands/registry.js';\nimport { validateCommand } from '../bot/commands/validator.js';\nimport { executeSystemCommand } from '../services/system-exec-service.js';\n\n/**\n * Escape HTML special characters for safe web display.\n * @param {string} text\n * @returns {string}\n */\nfunction escapeHtml(text) {\n  return String(text)\n    .replace(/&/g, '&amp;')\n    .replace(/</g, '&lt;')\n    .replace(/>/g, '&gt;')\n    .replace(/\"/g, '&quot;');\n}\n\n/**\n * Format command output for web display.\n * Wraps multi-line output in <pre> blocks.\n * @param {string} text\n * @returns {string}\n */\nfunction formatForWeb(text) {\n  if (!text) return '';\n  const escaped = escapeHtml(text);\n  // If multi-line or looks like code output, wrap in pre\n  if (text.includes('\\n') || text.includes('\\t')) {\n    return `<pre>${escaped}</pre>`;\n  }\n  return escaped;\n}\n\n/**\n * Handle the /exec command for web — executes a system command.\n * @param {string[]} args - Command arguments (rest after /exec)\n * @returns {Promise<string>} HTML-formatted output\n */\nasync function handleExecCommand(args) {\n  if (!args || args.length === 0) {\n    return escapeHtml('用法: /exec <command>');\n  }\n\n  const command = args.join(' ');\n\n  try {\n    const result = await executeSystemCommand(command);\n    const parts = [];\n\n    if (result.stdout?.trim()) {\n      parts.push(`<pre>${escapeHtml(result.stdout)}</pre>`);\n    }\n    if (result.stderr?.trim()) {\n      parts.push(`<pre class=\"stderr\">${escapeHtml(result.stderr)}</pre>`);\n    }\n\n    const exitInfo = `<span class=\"exit-code\">Exit: ${result.exitCode}</span>`;\n    parts.push(exitInfo);\n\n    return parts.join('\\n') || escapeHtml('(no output)');\n  } catch (error) {\n    return escapeHtml(`❌ 执行失败: ${error.message}`);\n  }\n}\n\n/**\n * Route and dispatch a web slash command.\n * Returns HTML-formatted result string, or null if not a slash command.\n *\n * @param {string} message - User message text\n * @param {string} sessionId - Web session ID\n * @returns {Promise<string|null>} HTML result or null if not a command\n */\nexport async function routeWebCommand(message, sessionId) {\n  if (!message || !message.startsWith('/')) {\n    return null;\n  }\n\n  const text = message.trim();\n  const aliasMap = getAliasMap();\n  const parsed = parseCommand(text, aliasMap);\n\n  if (!parsed) {\n    return null;\n  }\n\n  // Handle /exec specially — maps to system exec service\n  if (parsed.command === 'exec') {\n    const args = [\n      ...(parsed.subcommand ? [parsed.subcommand] : []),\n      ...parsed.args\n    ];\n    return handleExecCommand(args);\n  }\n\n  // Look up registered command\n  const entry = getCommand(parsed.command);\n\n  if (!entry) {\n    return escapeHtml(`❌ 未知命令: /${parsed.command}。输入 / 查看可用命令。`);\n  }\n\n  const { meta, handler } = entry;\n\n  // Validate command\n  const validation = validateCommand(parsed, meta);\n  if (!validation.valid) {\n    const errors = validation.errors.map((e) => e.message || e.param).join(', ');\n    return escapeHtml(`❌ 命令参数错误: ${errors}\\n用法: ${meta.usage}`);\n  }\n\n  // Collect output via reply collector\n  const outputParts = [];\n\n  const webHandlerCtx = {\n    ctx: null, // No Telegram context for web\n    parsed,\n    meta,\n    params: validation.normalized || {},\n    userId: null, // No Telegram user for web\n    userRole: 'operator', // Default role for web users\n    sessionId,\n    requiresConfirmation: false,\n    reply: async (text) => {\n      outputParts.push(formatForWeb(text));\n    },\n    replyFile: async (content, filename) => {\n      outputParts.push(escapeHtml(`[文件: ${filename}]`));\n    },\n    args: parsed.args || []\n  };\n\n  try {\n    await handler(webHandlerCtx);\n  } catch (error) {\n    return escapeHtml(`❌ 命令执行错误: ${error.message}`);\n  }\n\n  return outputParts.join('\\n') || escapeHtml('(命令已执行，无输出)');\n}\n\n/**\n * Get the list of available commands for autocomplete.\n * @returns {Array<{name: string, aliases: string[], description: string, usage: string}>}\n */\nexport function getAvailableCommands() {\n  const registered = getAllCommands().map((entry) => ({\n    name: entry.meta.name,\n    aliases: entry.meta.aliases || [],\n    description: entry.meta.description || '',\n    usage: entry.meta.usage || `/${entry.meta.name}`\n  }));\n\n  // Add /exec which is handled directly (not in registry)\n  const execCommand = {\n    name: 'exec',\n    aliases: [],\n    description: '执行系统命令',\n    usage: '/exec <command>'\n  };\n\n  return [execCommand, ...registered];\n}\n","numLines":171,"startLine":1,"totalLines":171}}}
