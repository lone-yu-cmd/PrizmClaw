meType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  try {\n    setBusy(true, '正在执行命令...');\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    els.exitCodeOutput.textContent = 'error';\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ninit();\n","structuredPatch":[{"oldStart":77,"oldLines":7,"newStart":77,"newLines":7,"lines":["   }"," }"," ","-function createMessageElement(role, text, isError = false) {","+function createMessageElement(role, text, isError = false, isHtml = false) {","   const item = document.createElement('div');","   item.className = `message ${role} ${isError ? 'error' : ''}`.trim();"," "]},{"oldStart":87,"oldLines":14,"newStart":87,"newLines":18,"lines":[" ","   const body = document.createElement('div');","   body.className = 'body';","-  body.textContent = text;","+  if (isHtml) {","+    body.innerHTML = text;","+  } else {","+    body.textContent = text;","+  }"," ","   item.append(roleEl, body);","   return { item, body };"," }"," ","-function appendMessage(role, text, isError = false) {","-  const node = createMessageElement(role, text, 