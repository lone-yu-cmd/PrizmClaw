  46→  setStatus(text);\n    47→}\n    48→\n    49→function saveSessionConfig() {\n    50→  localStorage.setItem(\n    51→    STORAGE_KEY,\n    52→    JSON.stringify({\n    53→      baseUrl: state.baseUrl,\n    54→      sessionId: state.sessionId\n    55→    })\n    56→  );\n    57→}\n    58→\n    59→function loadSessionConfig() {\n    60→  try {\n    61→    const raw = localStorage.getItem(STORAGE_KEY);\n    62→    if (!raw) {\n    63→      return;\n    64→    }\n    65→\n    66→    const parsed = JSON.parse(raw);\n    67→    if (typeof parsed.baseUrl === 'string') {\n    68→      state.baseUrl = parsed.baseUrl;\n    69→    }\n    70→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n    71→      state.sessionId = parsed.sessionId;\n    72→    }\n    73→  } catch {\n    74→    // ignore\n    75→  }\n    76→}\n    77→\n    78→function createMessageElement(role, text, isError = false) {\n    79→  const item = document.createElement('div');\n    80→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n    81→\n    82→  const roleEl = document.createElement('span');\n    83→  roleEl.className = 'role';\n    84→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n    85→\n    86→  const body = document.createElement('div');\n    87→  body.className = 'body';\n    88→  body.textContent = text;\n    89→\n    90→  item.append(roleEl, body);\n    91→  return { item, body };\n    92→}\n    93→\n    94→function appendMessage(role, text, isError = false) {\n    95→  const node = createMessageElement(role, text, isError);\n    96→  els.chatMessages.appendChild(node.item);\n    97→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n    98→  return node;\n    99→}\n   100→\n   101→function getApiUrl(path) {\n   102→  const base = state.baseUrl.trim();\n   103→  if (!base) {\n   104→    return path;\n   105→  }\n   106→  return `${base.replace(/\\/$/, '')}${path}`;\n   107→}\n   108→\n   109→function getEventsUrl() {\n   110→  const query = new URLSearchParams({\n   111→    channel: 'web',\n   112→    sessionId: state.sessionId\n   113→  }).toString();\n   114→\n   115→  return `${getApiUrl('/api/events')}?${query}`;\n   116→}\n   117→\n   118→function closeRealtime() {\n   119→  if (state.eventSource) {\n   120→    state.eventSource.close();\n   121→    state.eventSource = null;\n   122→  }\n   123→}\n   124→\n   125→function connectRealtime() {\n   126→  closeRealtime();\n   127→\n   128→  if (typeof EventSource === 'undefined') {\n   129→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   130→    return;\n   131→  }\n   132→\n   133→  const es = new EventSource(getEventsUrl());\n   134→  state.eventSource = es;\n   135→\n   136→  es.addEventListener('connected', () => {\n   137→    setStatus('实时通道已连接');\n   138→  });\n   139→\n   140→  es.addEventListener('status', (event) => {\n   141→    const payload = JSON.parse(event.data);\n   142→    if (payload.stage === 'running') {\n   143→      setStatus('助手处理中...');\n   144→      return;\n   145→    }\n   146→\n   147→    if (payload.stage === 'accepted') {\n   148→      setStatus('已接收请求');\n   149→      return;\n   150→    }\n   151→\n   152→    setStatus('实时通道在线');\n   153→  });\n   154→\n   155→  es.addEventListener('assistant_chunk', (event) => {\n   156→    const payload = JSON.parse(event.data);\n   157→\n   158→    if (!state.streamingMessageBody) {\n   159→      const node = appendMessage('assistant', '');\n   160→      state.streamingMessageBody = node.body;\n   161→      state.streamedText = '';\n   162→    }\n   163→\n   164→    state.streamedText += payload.text ?? '';\n   165→    state.streamingMessageBody.textContent = state.streamedText;\n   166→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   167→  });\n   168→\n   169→  es.addEventListener('assistant_done', (event) => {\n   170→    const payload = JSON.parse(event.data);\n   171→    if (state.streamingMessageBody) {\n   172→    