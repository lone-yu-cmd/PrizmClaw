{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Uru3a7hbxWUnyVvJUCsm2i","type":"tool_result","content":"     1→/**\n     2→ * Command Parser\n     3→ * Parses Telegram message text into structured ParsedCommand object.\n     4→ */\n     5→\n     6→/**\n     7→ * @typedef {Object} ParsedCommand\n     8→ * @property {string} command - The command name (e.g., \"pipeline\")\n     9→ * @property {string} [subcommand] - Optional subcommand (e.g., \"run\")\n    10→ * @property {string[]} args - Positional arguments\n    11→ * @property {Record<string, string>} options - Key-value options (--key=value)\n    12→ * @property {string} raw - Original message text\n    13→ */\n    14→\n    15→/**\n    16→ * Parse Telegram message text into a structured command object.\n    17→ * @param {string} text - The message text to parse\n    18→ * @param {Object} [aliasMap={}] - Map of aliases to command names\n    19→ * @returns {ParsedCommand | null} Parsed command or null if not a command\n    20→ */\n    21→export function parseCommand(text, aliasMap = {}) {\n    22→  if (!text || typeof text !== 'string') {\n    23→    return null;\n    24→  }\n    25→\n    26→  const trimmed = text.trim();\n    27→\n    28→  // Must start with /\n    29→  if (!trimmed.startsWith('/')) {\n    30→    return null;\n    31→  }\n    32→\n    33→  // Extract command (first token after /)\n    34→  const tokens = trimmed.slice(1).split(/\\s+/);\n    35→  if (tokens.length === 0 || !tokens[0]) {\n    36→    return null;\n    37→  }\n    38→\n    39→  let command = tokens[0].toLowerCase();\n    40→  const rest = tokens.slice(1);\n    41→\n    42→  // Handle @bot suffix (e.g., /command@mybot)\n    43→  const atIndex = command.indexOf('@');\n    44→  if (atIndex !== -1) {\n    45→    command = command.slice(0, atIndex);\n    46→  }\n    47→\n    48→  // Apply alias mapping\n    49→  if (aliasMap[command]) {\n    50→    command = aliasMap[command];\n    51→  }\n    52→\n    53→  const args = [];\n    54→  /** @type {Record<string, string>} */\n    55→  const options = {};\n    56→  let subcommand = undefined;\n    57→\n    58→  for (const token of rest) {\n    59→    // Parse --key=value options\n    60→    if (token.startsWith('--')) {\n    61→      const optionText = token.slice(2);\n    62→      const eqIndex = optionText.indexOf('=');\n    63→      if (eqIndex !== -1) {\n    64→        const key = optionText.slice(0, eqIndex).toLowerCase();\n    65→        const value = optionText.slice(eqIndex + 1);\n    66→        options[key] = value;\n    67→      } else {\n    68→        // Boolean flag --flag\n    69→        options[optionText.toLowerCase()] = 'true';\n    70→      }\n    71→    } else if (token.includes('=')) {\n    72→      // Parse key=value (without --)\n    73→      const eqIndex = token.indexOf('=');\n    74→      const key = token.slice(0, eqIndex).toLowerCase();\n    75→      const value = token.slice(eqIndex + 1);\n    76→      options[key] = value;\n    77→    } else if (subcommand === undefined && !token.startsWith('-') && args.length === 0) {\n    78→      // First non-option token is subcommand if it looks like one\n    79→      // This will be validated by the registry\n    80→      subcommand = token.toLowerCase();\n    81→    } else {\n    82→      // Positional argument\n    83→      args.push(token);\n    84→    }\n    85→  }\n    86→\n    87→  return {\n    88→    command,\n    89→    subcommand,\n    90→    args,\n    91→    options,\n    92→    raw: text\n    93→  };\n    94→}\n    95→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7831a64a-70c3-467a-b2e5-6975a875912b","uuid":"feaf1f11-e18f-4a78-9899-f86f2df13470","timestamp":"2026-03-22T08:06:03.552Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/parser.js","content":"/**\n * Command Parser\n * Parses Telegram message text into structured ParsedCommand object.\n */\n\n/**\n * @typedef {Object} ParsedCommand\n * @property {string} command - The command name (e.g., \"pipeline\")\n * @property {string} [subcommand] - Optional subcommand (e.g., \"run\")\n * @property {string[]} args - Positional arguments\n * @property {Record<string, string>} options - Key-value options (--key=value)\n * @property {string} raw - Original message text\n */\n\n/**\n * Parse Telegram message text into a structured command object.\n * @param {string} text - The message text to parse\n * @param {Object} [aliasMap={}] - Map of aliases to command names\n * @returns {ParsedCommand | null} Parsed command or null if not a command\n */\nexport function parseCommand(text, aliasMap = {}) {\n  if (!text || typeof text !== 'string') {\n    return null;\n  }\n\n  const trimmed = text.trim();\n\n  // Must start with /\n  if (!trimmed.startsWith('/')) {\n    return null;\n  }\n\n  // Extract command (first token after /)\n  const tokens = trimmed.slice(1).split(/\\s+/);\n  if (tokens.length === 0 || !tokens[0]) {\n    return null;\n  }\n\n  let command = tokens[0].toLowerCase();\n  const rest = tokens.slice(1);\n\n  // Handle @bot suffix (e.g., /command@mybot)\n  const atIndex = command.indexOf('@');\n  if (atIndex !== -1) {\n    command = command.slice(0, atIndex);\n  }\n\n  // Apply alias mapping\n  if (aliasMap[command]) {\n    command = aliasMap[command];\n  }\n\n  const args = [];\n  /** @type {Record<string, string>} */\n  const options = {};\n  let subcommand = undefined;\n\n  for (const token of rest) {\n    // Parse --key=value options\n    if (token.startsWith('--')) {\n      const optionText = token.slice(2);\n      const eqIndex = optionText.indexOf('=');\n      if (eqIndex !== -1) {\n        const key = optionText.slice(0, eqIndex).toLowerCase();\n        const value = optionText.slice(eqIndex + 1);\n        options[key] = value;\n      } else {\n        // Boolean flag --flag\n        options[optionText.toLowerCase()] = 'true';\n      }\n    } else if (token.includes('=')) {\n      // Parse key=value (without --)\n      const eqIndex = token.indexOf('=');\n      const key = token.slice(0, eqIndex).toLowerCase();\n      const value = token.slice(eqIndex + 1);\n      options[key] = value;\n    } else if (subcommand === undefined && !token.startsWith('-') && args.length === 0) {\n      // First non-option token is subcommand if it looks like one\n      // This will be validated by the registry\n      subcommand = token.toLowerCase();\n    } else {\n      // Positional argument\n      args.push(token);\n    }\n  }\n\n  return {\n    command,\n    subcommand,\n    args,\n    options,\n    raw: text\n  };\n}\n","numLines":95,"startLine":1,"totalLines":95}}}
