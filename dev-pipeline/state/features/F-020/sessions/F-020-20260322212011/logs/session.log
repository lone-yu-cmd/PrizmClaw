{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01Xgv8nHwFS3bmoEb9y8jP6d","type":"tool_result","content":"     1→/**\n     2→ * Tests for F-020 ANSI Adapter\n     3→ * src/utils/ansi-adapter.js\n     4→ */\n     5→\n     6→import { describe, test } from 'node:test';\n     7→import assert from 'node:assert/strict';\n     8→import { stripAnsi, collapseCarriageReturns, processChunk } from '../../src/utils/ansi-adapter.js';\n     9→\n    10→describe('ansi-adapter', () => {\n    11→  describe('stripAnsi', () => {\n    12→    test('should remove basic color codes', () => {\n    13→      const input = '\\u001b[31mRed text\\u001b[0m';\n    14→      assert.equal(stripAnsi(input), 'Red text');\n    15→    });\n    16→\n    17→    test('should remove bold/italic escape codes', () => {\n    18→      const input = '\\u001b[1mBold\\u001b[0m and \\u001b[3mitalic\\u001b[0m';\n    19→      assert.equal(stripAnsi(input), 'Bold and italic');\n    20→    });\n    21→\n    22→    test('should remove cursor movement codes', () => {\n    23→      const input = '\\u001b[2J\\u001b[1;1H Hello';\n    24→      assert.equal(stripAnsi(input), ' Hello');\n    25→    });\n    26→\n    27→    test('should remove 256-color codes', () => {\n    28→      const input = '\\u001b[38;5;196mRed\\u001b[0m';\n    29→      assert.equal(stripAnsi(input), 'Red');\n    30→    });\n    31→\n    32→    test('should remove RGB color codes', () => {\n    33→      const input = '\\u001b[38;2;255;0;0mRed\\u001b[0m';\n    34→      assert.equal(stripAnsi(input), 'Red');\n    35→    });\n    36→\n    37→    test('should handle text with no ANSI codes', () => {\n    38→      const input = 'Plain text without any codes';\n    39→      assert.equal(stripAnsi(input), input);\n    40→    });\n    41→\n    42→    test('should handle empty string', () => {\n    43→      assert.equal(stripAnsi(''), '');\n    44→    });\n    45→\n    46→    test('should handle null/undefined gracefully', () => {\n    47→      assert.equal(stripAnsi(null), '');\n    48→      assert.equal(stripAnsi(undefined), '');\n    49→    });\n    50→\n    51→    test('should strip multiple consecutive escape codes', () => {\n    52→      const input = '\\u001b[1m\\u001b[31m\\u001b[4mStyled text\\u001b[0m';\n    53→      assert.equal(stripAnsi(input), 'Styled text');\n    54→    });\n    55→\n    56→    test('should preserve newlines', () => {\n    57→      const input = '\\u001b[32mLine 1\\u001b[0m\\nLine 2\\n\\u001b[33mLine 3\\u001b[0m';\n    58→      assert.equal(stripAnsi(input), 'Line 1\\nLine 2\\nLine 3');\n    59→    });\n    60→\n    61→    test('should handle OSC sequences', () => {\n    62→      const input = '\\u001b]0;Window Title\\u0007Some text';\n    63→      assert.equal(stripAnsi(input), 'Some text');\n    64→    });\n    65→  });\n    66→\n    67→  describe('collapseCarriageReturns', () => {\n    68→    test('should collapse simple carriage return progress lines', () => {\n    69→      // Simulate a progress bar that overwrites itself\n    70→      const input = 'Progress: 10%\\rProgress: 50%\\rProgress: 100%';\n    71→      assert.equal(collapseCarriageReturns(input), 'Progress: 100%');\n    72→    });\n    73→\n    74→    test('should keep newline-terminated lines', () => {\n    75→      const input = 'Line 1\\nLine 2\\nLine 3';\n    76→      assert.equal(collapseCarriageReturns(input), 'Line 1\\nLine 2\\nLine 3');\n    77→    });\n    78→\n    79→    test('should handle mixed CR and CRLF', () => {\n    80→      // Some terminals use \\r\\n\n    81→      const input = 'Step 1\\r\\nStep 2\\r\\nStep 3';\n    82→      const result = collapseCarriageReturns(input);\n    83→      assert.ok(result.includes('Step 1'));\n    84→      assert.ok(result.includes('Step 2'));\n    85→      assert.ok(result.includes('Step 3'));\n    86→    });\n    87→\n    88→    test('should collapse multiple \\\\r overwrites within a logical line', () => {\n    89→      // e.g. \"Downloading... 0%\\rDownloading... 50%\\rDownloading... 100%\\n\"\n    90→      const input = 'Downloading... 0%\\rDownloading... 50%\\rDownloading... 100%\\nDone.';\n    91→      const result = collapseCarriageReturns(input);\n    92→      assert.ok(result.includes('Downloading... 100%'));\n    93→      assert.ok(result.includes('Done.'));\n    94→      // Should not include the intermediate states\n    95→      assert.ok(!result.includes('Downloading... 0%'));\n    96→      assert.ok(!result.includes('Downloading... 50%'));\n    97→    });\n    98→\n    99→    test('should handle empty string', () => {\n   100→      assert.equal(collapseCarriageReturns(''), '');\n   101→    });\n   102→\n   103→    test('should handle text with no carriage returns', () => {\n   104→      const input = 'Normal\\nMultiline\\nText';\n   105→      assert.equal(collapseCarriageReturns(input), 'Normal\\nMultiline\\nText');\n   106→    });\n   107→\n   108→    test('should handle string ending with \\\\r', () => {\n   109→      const input = 'Loading...\\rDone\\r';\n   110→      const result = collapseCarriageReturns(input);\n   111→      // The last \\r with empty after it means the last state is 'Done'\n   112→      // Result should keep 'Done' as it's the last content before \\r\n   113→      assert.ok(result === 'Done' || result === 'Done\\r');\n   114→    });\n   115→  });\n   116→\n   117→  describe('processChunk', () => {\n   118→    test('should strip ANSI codes from a chunk', () => {\n   119→      const input = '\\u001b[32m[ OK ]\\u001b[0m Service started';\n   120→      const result = processChunk(input);\n   121→      assert.ok(!result.includes('\\u001b['));\n   122→      assert.ok(result.includes('[ OK ]'));\n   123→      assert.ok(result.includes('Service started'));\n   124→    });\n   125→\n   126→    test('should collapse carriage returns in a chunk', () => {\n   127→      const input = '\\u001b[34mProgress\\u001b[0m: 10%\\rProgress: 100%';\n   128→      const result = processChunk(input);\n   129→      assert.ok(!result.includes('\\u001b['));\n   130→      assert.ok(result.includes('Progress: 100%'));\n   131→      assert.ok(!result.includes('Progress: 10%'));\n   132→    });\n   133→\n   134→    test('should handle empty string', () => {\n   135→      assert.equal(processChunk(''), '');\n   136→    });\n   137→\n   138→    test('should handle null/undefined', () => {\n   139→      assert.equal(processChunk(null), '');\n   140→      assert.equal(processChunk(undefined), '');\n   141→    });\n   142→\n   143→    test('should handle plain text unchanged', () => {\n   144→      const input = 'Normal text output\\nSecond line';\n   145→      assert.equal(processChunk(input), input);\n   146→    });\n   147→\n   148→    test('should handle real-world ANSI colored output', () => {\n   149→      // Simulates npm install output style\n   150→      const input = '\\u001b[32m+\\u001b[0m lodash@4.17.21\\n\\u001b[33mwarning\\u001b[0m: peer dep issue';\n   151→      const result = processChunk(input);\n   152→      assert.ok(!result.includes('\\u001b['));\n   153→      assert.ok(result.includes('+ lodash@4.17.21'));\n   154→      assert.ok(result.includes('warning: peer dep issue'));\n   155→    });\n   156→  });\n   157→});\n   158→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_vrtx_018ui2JaLFAdK8jTBEzEzMKD","session_id":"ac44fc5c-0407-4bd5-95fd-57d4b24826fc","uuid":"79c5a789-5190-4a76-a83c-6fe331977984","timestamp":"2026-03-22T13:52:37.914Z"}
