{ auditMeta, handleAudit } from './commands/handlers/audit.js';\n    28→import { commitMeta, handleCommit } from './commands/handlers/commit.js';\n    29→import { commitsMeta, handleCommits } from './commands/handlers/commits.js';\n    30→// F-009: New command handlers\n    31→import { cdMeta, handleCd } from './commands/handlers/cd.js';\n    32→import { moreMeta, handleMore } from './commands/handlers/more.js';\n    33→// F-010: File Manager command handlers\n    34→import { lsMeta, handleLs } from './commands/handlers/ls.js';\n    35→import { treeMeta, handleTree } from './commands/handlers/tree.js';\n    36→import { catMeta, handleCat } from './commands/handlers/cat.js';\n    37→import { headMeta, handleHead } from './commands/handlers/head.js';\n    38→import { tailMeta, handleTail } from './commands/handlers/tail.js';\n    39→import { findMeta, handleFind } from './commands/handlers/find.js';\n    40→import { uploadMeta, handleUpload } from './commands/handlers/upload.js';\n    41→import { downloadMeta, handleDownload } from './commands/handlers/download.js';\n    42→// F-012: System Monitor command handlers\n    43→import { sysinfoMeta, handleSysinfo } from './commands/handlers/sysinfo.js';\n    44→import { psMeta, handlePs } from './commands/handlers/ps.js';\n    45→import { killMeta, handleKill } from './commands/handlers/kill.js';\n    46→import { monitorMeta, handleMonitor } from './commands/handlers/monitor.js';\n    47→// F-013: Session and Context Manager command handlers\n    48→import { historyMeta, handleHistory } from './commands/handlers/history.js';\n    49→import { aliasMeta, handleAlias } from './commands/handlers/alias.js';\n    50→import { sessionsMeta, handleSessions } from './commands/handlers/sessions.js';\n    51→// F-014: Notification and Scheduled Tasks command handlers\n    52→import { cronMeta, handleCron } from './commands/handlers/cron.js';\n    53→import { jobsMeta, handleJobs } from './commands/handlers/jobs.js';\n    54→import { watchMeta, handleWatch } from './commands/handlers/watch.js';\n    55→// F-015: AI CLI Backend Switcher command handler\n    56→import { cliMeta, handleCli } from './commands/handlers/cli.js';\n    57→// F-017: Runtime Config Manager command handler\n    58→import { configMeta, handleConfig } from './commands/handlers/config.js';\n    59→import { generateHelp } from './commands/help.js';\n    60→import { sessionStore } from '../services/session-store.js';\n    61→import { sessionContextService } from '../services/session-context-service.js';\n    62→import { aliasStore } from '../services/alias-store.js';\n    63→import { scheduledTaskService } from '../services/scheduled-task-service.js';\n    64→import { fileWatcherService } from '../services/file-watcher-service.js';\n    65→import { convertToMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n    66→import { escapeMarkdownV2 } from '../utils/markdown-v2-formatter.js';\n    67→\n    68→const TELEGRAM_MSG_CHUNK_SIZE = 3800;\n    69→const STREAM_MIN_CHARS = 220;\n    70→const STREAM_FLUSH_INTERVAL_MS = 1200;\n    71→const TYPING_INTERVAL_MS = 3500;\n    72→const PHOTO_EXTENSIONS = new Set(['.png', '.jpg', '.jpeg', '.webp']);\n    73→const DOCUMENT_EXTENSIONS = new Set(['.pdf', '.txt', '.json', '.md', '.csv', '.log']);\n    74→const ALLOWED_FILE_EXTENSIONS = new Set([...PHOTO_EXTENSIONS, ...DOCUMENT_EXTENSIONS]);\n    75→const TELEGRAM_MAX_PHOTO_BYTES = 10 * 1024 * 1024;\n    76→const TELEGRAM_MAX_DOCUMENT_BYTES = 45 * 1024 * 1024;\n    77→const TELEGRAM_HANDLER_TIMEOUT_MS = 10 * 60 * 1000;\n    78→const TMP_DIR = path.resolve(os.tmpdir());\n    79→const HOME_DIR = path.resolve(os.homedir());\n    80→const DESKTOP_DIR = path.join(HOME_DIR, 'Desktop');\n    81→const DOWNLOADS_DIR = path.join(HOME_DIR, 'Downloads');\n    82→const DEFAULT_ALLOWED_FILE_ROOTS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n    83→const DEFAULT_FILE_CANDIDATE_DIRS = [path.resolve(process.cwd()), DESKTOP_DIR, DOWNLOADS_DIR, TMP_DIR];\n    84→\n    85→function resolveConfiguredDirs(configuredDirs = [], fallbackDirs = []) {\n    86→  const normalized = configuredDirs\n    87→    .map((dir) => String(dir ?? '').trim())\n    88→    .filter(Boolean)\n    89→    .map((dir) => path.resolve(dir));\n    90→\n    91→  if (normalized.length > 0) {\n    92→    return [...new Set(normalized)];\n    93→  }\n    94→\n    95→  return [...new Set(fallbackDirs.map((dir) => path.resolve(String(dir))))];\n    96→}\n    97→\n    98→const ALLOWED_FILE_ROOTS = resolveConfiguredDirs(config.telegramFileAllowedRoots, DEFAULT_ALLOWED_FILE_ROOTS);\n    99→const FILE_CANDIDATE_DIRS = resolveConfiguredDirs(config.telegramFileCandidateDirs, DEFAULT_FILE_CANDIDATE_DIRS);\n   100→\n   101→function splitMessage(text, chunkSize = TELEGRAM_MSG_CHUNK_SIZE) {\n   102→  const chunks = [];\n   103→  for (let i = 0; i < text.length; i += chunkSize) {\n   104→    chunks.push(text.slice(i, i + chunkSize));\n   105→  }\n   106→  return chunks;\n   107→}\n   108→\n   109→function truncate(text, maxLen) {\n   110→  if (!text) return '';\n   111→  if (text.length <= maxLen) return text;\n   112→  return text.substring(0, maxLen) + '...';\n   113→}\n   114→\n   115→function sanitizeMarkerPath(raw) {\n   116→  return String(raw ?? '')\n   117→    .trim()\n   118→    .replace(/^['\"`]+/, '')\n   119→    .replace(/['\"`]+$/, '');\n   120→}\n   121→\n   122→function extractFileMarkers(text = '') {\n   123→  const fileRefs = [];\n   124→\n   125→  const withSendFileRemoved = text.replace(\n   126→    /(?:^|\\n)\\s*(?:[-*]\\s*)?`?SEND_FILE:([^\\n`]+)`?\\s*(?=\\n|$)/g,\n   127→    (_full, rawRef) => {\n   128→      const ref = sanitizeMarkerPath(rawRef);\n   129→      if (ref) {\n   130→        fileRefs.push(ref);\n   131→      }\n   132→      return '\\n';\n   133→    }\n   134→  );\n   135→\n   136→  const withImageRemoved = withSendFileRemoved.replace(/@image:([^\\s`]+)/g, (_full, rawRef) => {\n   137→    const ref = sanitizeMarkerPath(rawRef);\n   138→    if (ref) {\n   139→      fileRefs.push(ref);\n   140→    }\n   141→    return '';\n   142→  });\n   143→\n   144→  const withBacktickPathRemoved = withImageRemoved.replace(\n   145→    /`((?:\\/[^`\\n\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))`/gi,\n   146→    (_full, rawRef) => {\n   147→      const ref = sanitizeMarkerPath(rawRef);\n   148→      if (ref) {\n   149→        fileRefs.push(ref);\n   150→      }\n   151→      return '';\n   152→    }\n   153→  );\n   154→\n   155→  const withLabeledPathRemoved = withBacktickPathRemoved.replace(\n   156→    /(?:文件路径|path)\\s*[:：]\\s*((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))/gi,\n   157→    (_full, rawRef) => {\n   158→      const ref = sanitizeMarkerPath(rawRef);\n   159→      if (ref) {\n   160→        fileRefs.push(ref);\n   161→      }\n   162→      return '';\n   163→    }\n   164→  );\n   165→\n   166→  const withAbsolutePathLineRemoved = withLabeledPathRemoved.replace(\n   167→    /(?:^|\\n)\\s*(?:[-*]\\s*)?((?:\\/[^\\n`\\r]+)+\\.(?:png|jpg|jpeg|webp|pdf|txt|json|md|csv|log))\\s*(?=\\n|$)/gi,\n   168→    (_full, rawRef) => {\n   169→      const ref = sanitizeMarkerPath(rawRef);\n   170→      if (ref) {\n   171→        fileRefs.push(ref);\n   172→      }\n   173→      return '\\n';\n   174→    }\n   175→  );\n   176→\n   177→  return {\n   178→    fileRefs: [...new Set(fileRefs)],\n   179→    cleanedText: withAbsolutePathLineRemoved.replace(/\\n{3,}/g, '\\n\\n').trim()\n   180→  };\n   181→}\n   182→\n   183→function isPathWithinRoot(targetPath, rootPath) {\n   184→  const relative = path.relative(rootPath, targetPath);\n   185→  return relative === '' || (!relative.startsWith('..') && !path.isAbsolute(relative));\n   186→}\n   187→\n   188→function isAllowedFilePath(filePath) {\n   189→  const resolved = path.resolve(filePath);\n   190→  return ALLOWED_FILE_ROOTS.some((root) => isPathWithinRoot(resolved, root));\n   191→}\n   192→\n   193→function buildFileCandidates(normalizedPath) {\n   194→  if (path.isAbsolute(normalizedPath)) {\n   195→    return [normalizedPath];\n   196→  }\n   197→\n   198→  const baseName = path.basename(normalizedPath);\n   199→  const candidates = [\n   200→    path.resolve(process.cwd(), normalizedPath),\n   201→    ...FILE_CANDIDATE_DIRS.map((dir) => path.resolve(dir, baseName))\n   202→  ];\n   203→\n   204→  return [...new Set(candidates)];\n   205→}\n   206→\n   207→async function resolveLocalFilePath(fileRef) {\n   208→  const normalized = sanitizeMarkerPath(fileRef);\n   209→  if (!normalized) {\n   210→    return { filePath: null, triedPaths: [], rejectReason: 'empty_path' };\n   211→  }\n   212→\n   213→  if (!path.isAbsolute(normalized)) {\n   214→    return { filePath: null, triedPaths: [], rejectReason: 'relative_path_not_allowed' };\n   215→  }\n   216→\n   217→  const candidates = buildFileCandidates(normalized);\n   218→\n   219→  for (const candidate of candidates) {\n   220→    try {\n   221→      await access(candidate);\n   222→      return { filePath: candidate, triedPaths: candidates };\n   223→    } catch {\n   224→      // ignore\n   225→    }\n   226→  }\n   227→\n   228→  return { filePath: null, triedPaths: candidates, rejectReason: 'not_found' };\n   229→}\n   230→\n   231→async function validateFileForTelegram(filePath) {\n   232→  const resolvedPath = path.resolve(filePath);\n   233→  if (!isAllowedFilePath(resolvedPath)) {\n   234→    return { ok: false, reason: `路径不在允许范围：${resolvedPath}` };\n   235→  }\n   236→\n   237→  const ext = path.extname(resolvedPath).toLowerCase();\n   238→  if (!ALLOWED_FILE_EXTENSIONS.has(ext)) {\n   239→    return { ok: false, reason: `不支持的文件类型：${ext || '(unknown)'}` };\n   240→  }\n   241→\n   242→  const fileStat = await stat(resolvedPath);\n   243→  const isPhoto = PHOTO_EXTENSIONS.has(ext);\n   244→  const maxSize = isPhoto ? TELEGRAM_MAX_PHOTO_BYTES : TELEGRAM_MAX_DOCUMENT_BYTES;\n   245→\n   246→  if (fileStat.size > maxSize) {\n   247→    return {\n   248→      ok: false,\n   249→      reason: `文件过大：${Math.ceil(fileStat.size / 1024 / 1024)}MB，限制 ${Math.floor(maxSize / 1024 / 1024)}MB`\n   250→    };\n   251→  }\n   252→\n   253→  return { ok: true, isPhoto, resolvedPath };\n   254→}\n   255→\n   256→function isTimeoutLikeError(message = '') {\n   257→  const normalized = String(message).toLowerCase();\n   258→  return normalized.includes('timed out') || normalized.includes('etimedout') || normalized.includes('timeout');\n   259→}\n   260→\n   261→function sleep(ms) {\n   262→  return new Promise((resolve) => setTimeout(resolve, ms));\n   263→}\n   264→\n   265→async function sendTelegramFileByType(ctx, filePath, isPhoto) {\n   266→  if (isPhoto) {\n   267→    await ctx.replyWithPhoto({ source: createReadStream(filePath) }, { caption: path.basename(filePath) });\n   268→    return;\n   269→  }\n   270→\n   271→  await ctx.replyWithDocument({ source: createReadStream(filePath), filename: path.basename(filePath) });\n   272→}\n   273→\n   274→async function replyFiles(ctx, fileRefs = []) {\n   275→  const results = [];\n   276→\n   277→  for (const fileRef of fileRefs) {\n   278→    const { filePath, triedPaths, rejectReason } = await resolveLocalFilePath(fileRef);\n   279→    if (!filePath) {\n   280→      const reason = rejectReason || 'not_found';\n   281→      results.push({ fileRef, sent: false, reason, triedPaths });\n   282→      logger.warn({ fileRef, reason, triedPaths }, 'File unavailable for telegram upload');\n   283→      continue;\n   284→    }\n   285→\n   286→    try {\n   287→      const validation = await validateFileForTelegram(filePath);\n   288→      if (!validation.ok) {\n   289→        results.push({ fileRef, sent: false, reason: validation.reason, filePath, triedPaths });\n   290→        logger.warn({ fileRef, filePath, reason: validation.reason }, 'File validation failed for telegram upload');\n   291→        continue;\n   292→      }\n   293→\n   294→      const actualPath = validation.resolvedPath;\n   295→      let sent = false;\n   296→      let lastReason = '';\n   297→\n   298→      for (let attempt = 1; attempt <= 2; attempt += 1) {\n   299→        try {\n   300→          await sendTelegramFileByType(ctx, actualPath, validation.isPhoto);\n   301→          sent = true;\n   302→          logger.info(\n   303→            { fileRef, filePath: actualPath, as: validation.isPhoto ? 'photo' : 'document', attempt },\n   304→            'Telegram file sent'\n   305→          );\n   306→          break;\n   307→        } catch (error) {\n   308→          lastReason = error instanceof Error ? error.message : String(error);\n   309→          logger.warn(\n   310→            { fileRef, filePath: actualPath, err: lastReason, attempt },\n   311→            'Telegram file send attempt failed'\n   312→          );\n   313→\n   314→          if (attempt < 2 && isTimeoutLikeError(lastReason)) {\n   315→            await sleep(600);\n   316→            continue;\n   317→          }\n   318→\n   319→          break;\n   320→        }\n   321→      }\n   322→\n   323→      if (!sent) {\n   324→        results.push({ fileRef, sent: false, reason: lastReason || 'unknown_error', filePath: actualPath, triedPaths });\n   325→        logger.error({ fileRef, filePath: actualPath, err: lastReason }, 'Failed to send file to telegram');\n   326→        continue;\n   327→      }\n   328→\n   329→      results.push({ fileRef, sent: true, filePath: actualPath, triedPaths });\n   330→    } catch (error) {\n   331→      const reason = error instanceof Error ? error.message : String(error);\n   332→      results.push({ fileRef, sent: false, reason, filePath, triedPaths });\n   333→      logger.error({ fileRef, filePath, err: reason }, 'Failed to send file to telegram');\n   334→    }\n   335→  }\n   336→\n   337→  return results;\n   338→}\n   339→\n   340→async function safeReply(ctx, text) {\n   341→  try {\n   342→    await ctx.reply(text);\n   343→    return true;\n   344→  } catch (error) {\n   345→    const reason = error instanceof Error ? error.message : String(error);\n   346→    logger.error({ err: reason }, 'Failed to send telegram text reply');\n   347→    return false;\n   348→  }\n   349→}\n   350→\n   351→async function replyLargeText(ctx, text) {\n   352→  const chunks = splitMessage(text);\n   353→  for (const chunk of chunks) {\n   354→    const ok = await safeReply(ctx, chunk);\n   355→    if (!ok) {\n   356→      break;\n   357→    }\n   358→  }\n   359→}\n   360→\n   361→async function safeEditMessageText(ctx, messageId, text) {\n   362→  const nextText = text && text.trim() ? text : ' ';\n   363→\n   364→  try {\n   365→    await ctx.telegram.editMessageText(ctx.chat.id, messageId, undefined, nextText);\n   366→  } catch (error) {\n   367→    const message = error instanceof Error ? error.message : String(error);\n   368→    if (message.includes('message is not modified')) {\n   369→      return;\n   370→    }\n   371→    throw error;\n   372→  }\n   373→}\n   374→\n   375→function createEditableStreamPublisher(ctx) {\n   376→  let fullText = '';\n   377→  let renderedText = '';\n   378→  let pendingChars = 0;\n   379→  let lastFlushAt = 0;\n   380→  let flushChain = Promise.resolve();\n   381→  let activeMessage = null;\n   382→  let activeSegmentIndex = 0;\n   383→  let publishedMessageCount = 0;\n   384→\n   385→  async function ensureActiveMessage() {\n   386→    if (activeMessage) {\n   387→      return;\n   388→    }\n   389→    activeMessage = await ctx.reply('处理中...');\n   390→    activeSegmentIndex = 0;\n   391→    publishedMessageCount += 1;\n   392→  }\n   393→\n   394→  async function render(force = false) {\n   395→    const now = Date.now();\n   396→\n   397→    if (!force && pendingChars < STREAM_MIN_CHARS && now - lastFlushAt < STREAM_FLUSH_INTERVAL_MS) {\n   398→      return;\n   399→    }\n   400→\n   401→    if (fullText === renderedText) {\n   402→      pendingChars = 0;\n   403→      return;\n   404→    }\n   405→\n   406→    await ensureActiveMessage();\n   407→\n   408→    const segments = splitMessage(fullText);\n   409→    const targetLastIndex = Math.max(segments.length - 1, 0);\n   410→\n   411→    while (activeSegmentIndex < targetLastIndex) {\n   412→      const text = segments[activeSegmentIndex] ?? ' ';\n   413→      await safeEditMessageText(ctx, activeMessage.message_id, text);\n   414→\n   415→      activeMessage = await ctx.reply('继续输出中...');\n   416→      activeSegmentIndex += 1;\n   417→      publishedMessageCount += 1;\n   418→    }\n   419→\n   420→    const activeText = segments[targetLastIndex] ?? ' ';\n   421→    await safeEditMessageText(ctx, activeMessage.message_id, activeText);\n   422→\n   423→    renderedText = fullText;\n   424→    pendingChars = 0;\n   425→    lastFlushAt = now;\n   426→  }\n   427→\n   428→  function enqueueRender(force = false) {\n   429→    flushChain = flushChain.then(() => render(force));\n   430→  }\n   431→\n   432→  return {\n   433→    push(text) {\n   434→      const appendText = text ?? '';\n   435→      if (!appendText) {\n   436→        return;\n   437→      }\n   438→      fullText += appendText;\n   439→      pendingChars += appendText.length;\n   440→      enqueueRender(false);\n   441→    },\n   442→    setFinalText(text) {\n   443→      fullText = text ?? '';\n   444→      pendingChars = Math.max(pendingChars, STREAM_MIN_CHARS);\n   445→      enqueueRender(true);\n   446→    },\n   447→    async finish() {\n   448→      enqueueRender(true);\n   449→      await flushChain;\n   450→      return {\n   451→        outputLength: renderedText.length,\n   452→        messageCount: publishedMessageCount\n   453→      };\n   454→    }\n   455→  };\n   456→}\n   457→\n   458→function buildSessionId(ctx) {\n   459→  return String(ctx.chat.id);\n   460→}\n   461→\n   462→function ensureAllowed(ctx) {\n   463→  const userId = ctx.from?.id;\n   464→  if (!isAllowedUser(userId)) {\n   465→    throw new Error('当前账号未被授权使用该机器人。');\n   466→  }\n   467→}\n   468→\n   469→/**\n   470→ * Register all pipeline-related commands.\n   471→ */\n   472→function registerPipelineCommands() {\n   473→  registerCommand(pipelineMeta, handlePipeline);\n   474→  registerCommand(bugfixMeta, handleBugfix);\n   475→  registerCommand(plannerMeta, handlePlanner);\n   476→  registerCommand(statusMeta, handleStatus);\n   477→  registerCommand(logsMeta, handleLogs);\n   478→  registerCommand(stopMeta, handleStop);\n   479→  registerCommand(planMeta, handlePlan);\n   480→  registerCommand(auditMeta, handleAudit);\n   481→  registerCommand(commitMeta, handleCommit);\n   482→  registerCommand(commitsMeta, handleCommits);\n   483→  // F-009: New commands\n   484→  registerCommand(cdMeta, handleCd);\n   485→  registerCommand(moreMeta, handleMore);\n   486→  // F-010: File Manager commands\n   487→  registerCommand(lsMeta, handleLs);\n   488→  registerCommand(treeMeta, handleTree);\n   489→  registerCommand(catMeta, handleCat);\n   490→  registerCommand(headMeta, handleHead);\n   491→  registerCommand(tailMeta, handleTail);\n   492→  registerCommand(findMeta, handleFind);\n   493→  registerCommand(uploadMeta, handleUpload);\n   494→  registerCommand(downloadMeta, handleDownload);\n   495→  // F-012: System Monitor commands\n   496→  registerCommand(sysinfoMeta, handleSysinfo);\n   497→  registerCommand(psMeta, handlePs);\n   498→  registerCommand(killMeta, handleKill);\n   499→  registerCommand(monitorMeta, handleMonitor);\n   500→  // F-013: Session and Context Manager commands\n   501→  registerCommand(historyMeta, handleHistory);\n   502→  registerCommand(aliasMeta, handleAlias);\n   503→  registerCommand(sessionsMeta, handleSessions);\n   504→  // F-014: Notification and Scheduled Tasks commands\n   505→  registerCommand(cronMeta, handleCron);\n   506→  registerCommand(jobsMeta, handleJobs);\n   507→  registerCommand(watchMeta, handleWatch);\n   508→  // F-015: AI CLI Backend Switcher command\n   509→  registerCommand(cliMeta, handleCli);\n   510→  // F-017: Runtime Config Manager command\n   511→  registerCommand(configMeta, handleConfig);\n   512→}\n   513→\n   514→export async function createTelegramBot() {\n   515→  const bot = new Telegraf(config.telegramBotToken, {\n   516→    handlerTimeout: TELEGRAM_HANDLER_TIMEOUT_MS\n   517→  });\n   518→\n   519→  // F-013: Initialize session context service\n   520→  await sessionContextService.initSessionContext({ dataDir: config.sessionPersistenceDir });\n   521→  await aliasStore.initAliasStore({ persistencePath: config.aliasPersistencePath });\n   522→\n   523→  // F-013: Restore sessions from disk\n   524→  await sessionContextService.restoreSessions();\n   525→\n   526→  // F-013: Set up notification callback for session timeout\n   527→  sessionContextService.setNotificationCallback(async (sessionKey, userId) => {\n   528→    try {\n   529→      // Extract chat ID from session key (format: telegram:123456789)\n   530→      const chatId = sessionKey.replace('telegram:', '');\n   531→      await bot.telegram.sendMessage(chatId, '⏰ 会话因长时间未活动已超时，相关状态已清理。');\n   532→    } catch (error) {\n   533→      logger.warn({ sessionKey, userId, error: error.message }, 'Failed to send session timeout notification');\n   534→    }\n   535→  });\n   536→\n   537→  // F-013: Start timeout watcher\n   538→  sessionContextService.startTimeoutWatcher();\n   539→\n   540→  // F-014: Initialize scheduled task service\n   541→  scheduledTaskService.initScheduledTaskService({\n   542→    dataDir: config.systemMonitorDataDir,\n   543→    tasksFile: config.scheduledTasksPath,\n   544→    maxTasks: config.maxScheduledTasks\n   545→  });\n   546→\n   547→  // F-014: Set up task execution callback\n   548→  scheduledTaskService.setExecuteCallback(async ({ command, cwd, sessionId, userId }) => {\n   549→    try {\n   550→      return await executeCommand({\n   551→        command,\n   552→        cwd,\n   553→        sessionId,\n   554→        userId,\n   555→        skipConfirmation: true // Skip confirmation for scheduled tasks\n   556→      });\n   557→    } catch (error) {\n   558→      return {\n   559→        stdout: '',\n   560→        stderr: error.message,\n   561→        exitCode: 1,\n   562→        timedOut: false\n   563→      };\n   564→    }\n   565→  });\n   566→\n   567→  // F-014: Set up task notification callback\n   568→  scheduledTaskService.setNotificationCallback(async (chatId, task) => {\n   569→    try {\n   570→      const result = task.lastResult || {};\n   571→      const lines = [\n   572→        '⏰ *定时任务完成*',\n   573→        '',\n   574→        `任务ID: \\`${task.id.substring(0, 8)}...\\``,\n   575→        `命令: \\`${escapeMarkdownV2(task.command)}\\``,\n   576→        `执行时间: ${new Date(result.executedAt || Date.now()).toLocaleString()}`,\n   577→        '',\n   578→        `exitCode: ${result.exitCode}`,\n   579→        result.stdout ? `stdout:\\n${truncate(result.stdout, 500)}` : 'stdout: (empty)',\n   580→        result.stderr ? `stderr:\\n${escapeMarkdownV2(truncate(result.stderr, 500))}` : 'stderr: (empty)'\n   581→      ];\n   582→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n   583→    } catch (error) {\n   584→      logger.warn({ taskId: task.id, error: error.message }, 'Failed to send task notification');\n   585→    }\n   586→  });\n   587→\n   588→  // F-014: Load and start scheduled tasks\n   589→  await scheduledTaskService.loadTasks();\n   590→  scheduledTaskService.startScheduler();\n   591→\n   592→  // F-014: Initialize file watcher service\n   593→  fileWatcherService.initFileWatcherService({\n   594→    dataDir: config.systemMonitorDataDir,\n   595→    watchersFile: config.fileWatchersPath,\n   596→    maxWatchers: config.maxFileWatchers,\n   597→    debounceMs: config.taskDebounceMs,\n   598→    allowedRoots: config.telegramFileAllowedRoots.length > 0\n   599→      ? config.telegramFileAllowedRoots\n   600→      : [process.cwd()]\n   601→  });\n   602→\n   603→  // F-014: Set up file watcher notification callback\n   604→  fileWatcherService.setNotificationCallback(async (chatId, watcher) => {\n   605→    try {\n   606→      const lines = [\n   607→        '📁 *文件变更检测*',\n   608→        '',\n   609→        `路径: \\`${escapeMarkdownV2(watcher.path)}\\``,\n   610→        `事件: ${watcher.eventType}`,\n   611→        `文件: ${watcher.filename || '(未知)'}`,\n   612→        `时间: ${new Date().toLocaleString()}`\n   613→      ];\n   614→      await bot.telegram.sendMessage(chatId, lines.join('\\n'), { parse_mode: 'MarkdownV2' });\n   615→    } catch (error) {\n   616→      logger.warn({ watcherId: watcher.id, error: error.message }, 'Failed to send file watcher notification');\n   617→    }\n   618→  });\n   619→\n   620→  // F-014: Restore file watchers\n   621→  await fileWatcherService.restoreWatches();\n   622→\n   623→  // Register pipeline commands\n   624→  registerPipelineCommands();\n   625→\n   626→  // F-018: Create unified message router for bidirectional sync\n   627→  const messageRouter = createMessageRouter({\n   628→    aiCliExecutor: executeAiCli,\n   629→    sessionStore,\n   630→    realtimeHub\n   631→  });\n   632→\n   633→  // F-018: Initialize session bind service for cross-channel push\n   634→  const sessionBind = createSessionBindService({\n   635→    bindingsPath: config.sessionBindingsPath\n   636→  });\n   637→\n   638→  // F-018: Cross-channel push — forward web-originated AI replies to bound Telegram chats.\n   639→  // Track active subscriptions to avoid duplicates.\n   640→  const crossChannelSubs = new Map(); // sessionKey -> unsubscribe fn\n   641→\n   642→  /**\n   643→   * Subscribe to realtimeHub for a specific Telegram chat session key.\n   644→   * When a web-originated assistant_done event arrives, push the reply to Telegram.\n   645→   */\n   646→  function subscribeCrossChannel(telegramChatId) {\n   647→    const sessionKey = `telegram:${telegramChatId}`;\n   648→    if (crossChannelSubs.has(sessionKey)) {\n   649→      return; // already subscribed\n   650→    }\n   651→\n   652→    const unsubscribe = realtimeHub.subscribe(sessionKey, (event) => {\n   653→      // Only forward assistant_done events from web channel\n   654→      if (event.type === 'assistant_done' && event.payload?.channel === 'web') {\n   655→        const reply = event.payload.reply;\n   656→        if (reply) {\n   657→          const chunks = splitMessage(reply);\n   658→          for (const chunk of chunks) {\n   659→            bot.telegram.sendMessage(telegramChatId, chunk).catch((err) => {\n   660→              logger.warn(\n   661→                { telegramChatId, err: err.message },\n   662→                'F-018: Failed to push web-originated reply to Telegram'\n   663→              );\n   664→            });\n   665→          }\n   666→        }\n   667→      }\n   668→\n   669→      // Forward user_message events from web channel to notify Telegram\n   670→      if (event.type === 'user_message' && event.payload?.channel === 'web') {\n   671→        const msg = event.payload.message;\n   672→        if (msg) {\n   673→          bot.telegram.sendMessage(\n   674→            telegramChatId,\n   675→            `[Web] ${msg.length > 200 ? msg.substring(0, 200) + '...' : msg}`\n   676→          ).catch((err) => {\n   677→            logger.warn(\n   678→              { telegramChatId, err: err.message },\n   679→              'F-018: Failed to push web user message notification to Telegram'\n   680→            );\n   681→          });\n   682→        }\n   683→      }\n   684→    });\n   685→\n   686→    crossChannelSubs.set(sessionKey, unsubscribe);\n   687→    logger.info({ sessionKey }, 'F-018: Cross-channel push subscription active');\n   688→  }\n   689→\n   690→  // Subscribe for all existing bindings on startup\n   691→  // Wait for sessionBind to initialize before reading bindings\n   692→  sessionBind.init().then(() => {\n   693→    const allBindings = sessionBind.getAllBindings();\n   694→    for (const telegramChatId of new Set(Object.values(allBindings))) {\n   695→      subscribeCrossChannel(telegramChatId);\n   696→    }\n   697→    logger.info(\n   698→      { boundChats: Object.keys(allBindings).length },\n   699→      'F-018: Cross-channel push initialized for existing bindings'\n   700→    );\n   701→  }).catch((err) => {\n   702→    logger.error({ err: err.message }, 'F-018: Failed to initialize cross-channel push');\n   703→  });\n   704→\n   705→  // Expose subscribeCrossChannel for dynamic binding (called when new bindings are created)\n   706→  bot._f018 = { subscribeCrossChannel, sessionBind, messageRouter };\n   707→\n   708→  bot.catch(async (error, ctx) => {\n   709→    const message = error instanceof Error ? error.message : String(error);\n   710→    logger.error({ err: message, chatId: ctx?.chat?.id, updateType: ctx?.updateType }, 'Unhandled error while processing telegram update');\n   711→    try {\n   712→      if (ctx?.chat?.id) {\n   713→        await ctx.telegram.sendMessage(ctx.chat.id, '处理请求时出现异常，请重试一次。');\n   714→      }\n   715→    } catch (notifyError) {\n   716→      logger.warn({ err: notifyError instanceof Error ? notifyError.message : String(notifyError) }, 'Failed to notify user after unhandled telegram error');\n   717→    }\n   718→  });\n   719→\n   720→  bot.start(async (ctx) => {\n   721→    await ctx.reply('PrizmClaw 已启动。可直接聊天，也可用 /help 查看可用命令。');\n   722→  });\n   723→\n   724→  bot.help(async (ctx) => {\n   725→    const helpText = generateHelp();\n   726→    await ctx.reply(helpText);\n   727→  });\n   728→\n   729→  bot.command('reset', async (ctx) => {\n   730→    try {\n   731→      ensureAllowed(ctx);\n   732→      const sessionId = buildSessionId(ctx);\n   733→\n   734→      // F-011: Interrupt any running AI CLI task\n   735→      if (isAiCliRunning(sessionId)) {\n   736→        interruptAiCli(sessionId);\n   737→      }\n   738→\n   739→      resetSession({ channel: 'telegram', sessionId });\n   740→      await ctx.reply('已清空当前会话上下文。');\n   741→    } catch (error) {\n   742→      await ctx.reply(error instanceof Error ? error.message : String(error));\n   743→    }\n   744→  });\n   745→\n   746→  bot.command('screenshot', async (ctx) => {\n   747→    try {\n   748→      ensureAllowed(ctx);\n   749→      await ctx.reply('正在获取截图。');\n   750→      const { buffer } = await captureScreenshot();\n   751→      await ctx.replyWithPhoto({ source: buffer }, { caption: '当前本地屏幕截图' });\n   752→    } catch (error) {\n   753→      const message = error instanceof Error ? error.message : String(error);\n   754→      logger.error({ err: message }, 'Failed to capture screenshot in telegram');\n   755→      await ctx.reply(`截图失败：${message}`);\n   756→    }\n   757→  });\n   758→\n   759→  bot.command('exec', async (ctx) => {\n   760→    try {\n   761→      ensureAllowed(ctx);\n   762→      const payload = ctx.message.text.replace('/exec', '').trim();\n   763→      if (!payload) {\n   764→        await ctx.reply('请提供命令，例如 /exec pwd');\n   765→        return;\n   766→      }\n   767→\n   768→      const sessionId = buildSessionId(ctx);\n   769→      const userId = ctx.from?.id;\n   770→\n   771→      await ctx.reply('正在执行命令...');\n   772→      const result = await executeCommand({\n   773→        command: payload,\n   774→        sessionId,\n   775→        userId\n   776→      });\n   777→\n   778→      // Handle confirmation required\n   779→      if (result.needsConfirmation) {\n   780→        await ctx.reply(result.confirmationMessage);\n   781→        return;\n   782→      }\n   783→\n   784→      // Send output\n   785→      await replyLargeText(ctx, result.output);\n   786→\n   787→      // Indicate if more pages available\n   788→      if (result.hasMorePages) {\n   789→        await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n   790→      }\n   791→    } catch (error) {\n   792→      const message = error instanceof Error ? error.message : String(error);\n   793→      logger.error({ err: message }, 'Failed to exec command in telegram');\n   794→      await ctx.reply(`执行失败：${message}`);\n   795→    }\n   796→  });\n   797→\n   798→  // F-009: /cd command handler\n   799→  bot.command('cd', async (ctx) => {\n   800→    try {\n   801→      ensureAllowed(ctx);\n   802→      const payload = ctx.message.text.replace('/cd', '').trim();\n   803→      const sessionId = buildSessionId(ctx);\n   804→\n   805→      await handleCd({\n   806→        ctx,\n   807→        reply: (msg) => ctx.reply(msg),\n   808→        params: {},\n   809→        userId: ctx.from?.id,\n   810→        sessionId,\n   811→        args: payload ? [payload] : []\n   812→      });\n   813→    } catch (error) {\n   814→      const message = error instanceof Error ? error.message : String(error);\n   815→      logger.error({ err: message }, 'Failed to cd in telegram');\n   816→      await ctx.reply(`切换目录失败：${message}`);\n   817→    }\n   818→  });\n   819→\n   820→  // F-009: /more command handler\n   821→  bot.command('more', async (ctx) => {\n   822→    try {\n   823→      ensureAllowed(ctx);\n   824→      const sessionId = buildSessionId(ctx);\n   825→\n   826→      await handleMore({\n   827→        ctx,\n   828→        reply: (msg) => ctx.reply(msg),\n   829→        params: {},\n   830→        userId: ctx.from?.id,\n   831→        sessionId\n   832→      });\n   833→    } catch (error) {\n   834→      const message = error instanceof Error ? error.message : String(error);\n   835→      logger.error({ err: message }, 'Failed to get more output in telegram');\n   836→      await ctx.reply(`获取更多输出失败：${message}`);\n   837→    }\n   838→  });\n   839→\n   840→  // T-100: Document upload handler for plan files\n   841→  bot.on('document', async (ctx) => {\n   842→    try {\n   843→      ensureAllowed(ctx);\n   844→\n   845→      const document = ctx.message?.document;\n   846→      if (!document) {\n   847→        return;\n   848→      }\n   849→\n   850→      // Check file extension\n   851→      const fileName = document.file_name || '';\n   852→      const ext = path.extname(fileName).toLowerCase();\n   853→\n   854→      if (ext !== '.json') {\n   855→        // Not a JSON file, ignore silently (other handlers may process it)\n   856→        return;\n   857→      }\n   858→\n   859→      // Check file size\n   860→      const fileSize = document.file_size || 0;\n   861→      if (fileSize > 1024 * 1024) { // 1MB limit\n   862→        await ctx.reply('❌ 文件过大，限制 1MB。');\n   863→        return;\n   864→      }\n   865→\n   866→      await ctx.reply('正在处理上传的计划文件...');\n   867→\n   868→      // Download file content\n   869→      const fileLink = await ctx.telegram.getFileLink(document.file_id);\n   870→      const fileUrl = fileLink.href || fileLink.toString();\n   871→\n   872→      const response = await fetch(fileUrl);\n   873→      if (!response.ok) {\n   874→        throw new Error(`下载文件失败: ${response.status}`);\n   875→      }\n   876→\n   877→      const content = await response.text();\n   878→\n   879→      // Validate and save using plan-ingestion-service\n   880→      const infraConfig = loadPipelineInfraConfig();\n   881→      const planService = createPlanIngestionService({ plansDir: infraConfig.plansDir });\n   882→\n   883→      const validationResult = planService.validate(content);\n   884→\n   885→      if (!validationResult.valid) {\n   886→        const errorMsg = planService.formatValidationErrors(validationResult.errors);\n   887→        await ctx.reply(errorMsg);\n   888→        return;\n   889→      }\n   890→\n   891→      // Save the plan\n   892→      const saveResult = await planService.save(\n   893→        validationResult.type,\n   894→        content,\n   895→        { uploadedBy: ctx.from?.id }\n   896→      );\n   897→\n   898→      if (!saveResult.success) {\n   899→        await ctx.reply('❌ 保存失败，请稍后重试。');\n   900→        return;\n   901→      }\n   902→\n   903→      // Set as current version\n   904→      await planService.setCurrent(validationResult.type, saveResult.version);\n   905→\n   906→      // Format success message\n   907→      const typeDisplay = validationResult.type === 'feature-list' ? '特性列表' : 'Bug修复列表';\n   908→      const summary = validationResult.summary;\n   909→\n   910→      await ctx.reply([\n   911→        `✅ ${typeDisplay}已保存并激活`,\n   912→        `版本: ${saveResult.version}`,\n   913→        `名称: ${summary?.name || '未知'}`,\n   914→        `项目数: ${summary?.itemCount || 0}`,\n   915→        '',\n   916→        summary?.statusBreakdown ? '状态分布:' : '',\n   917→        ...Object.entries(summary?.statusBreakdown || {}).map(([status, count]) => `  ${status}: ${count}`)\n   918→      ].filter(Boolean).join('\\n'));\n   919→\n   920→    } catch (error) {\n   921→      const message = error instanceof Error ? error.message : String(error);\n   922→      logger.error({ err: message }, 'Failed to process document upload');\n   923→      await ctx.reply(`❌ 处理失败：${message}`);\n   924→    }\n   925→  });\n   926→\n   927→  bot.on('text', async (ctx) => {\n   928→    // Check for pipeline commands first\n   929→    const handled = await routeCommand(ctx);\n   930→    if (handled) {\n   931→      return;\n   932→    }\n   933→\n   934→    const sessionId = buildSessionId(ctx);\n   935→    const userId = ctx.from?.id;\n   936→\n   937→    // F-009: Direct exec mode - treat plain text as command when enabled\n   938→    if (config.directExecMode && config.enableSystemExec) {\n   939→      try {\n   940→        ensureAllowed(ctx);\n   941→        const command = ctx.message.text;\n   942→\n   943→        // Skip if it looks like a chat message (contains Chinese or Japanese characters, etc.)\n   944→        const isLikelyChat = /[\\u4e00-\\u9fff\\u3040-\\u309f\\u30a0-\\u30ff]/.test(command);\n   945→\n   946→        if (!isLikelyChat) {\n   947→          await ctx.reply('正在执行命令...');\n   948→          const result = await executeCommand({\n   949→            command,\n   950→            sessionId,\n   951→            userId\n   952→          });\n   953→\n   954→          if (result.needsConfirmation) {\n   955→            await ctx.reply(result.confirmationMessage);\n   956→            return;\n   957→          }\n   958→\n   959→          await replyLargeText(ctx, result.output);\n   960→\n   961→          if (result.hasMorePages) {\n   962→            await ctx.reply('📄 输出已截断。使用 /more 查看更多内容。');\n   963→          }\n   964→          return;\n   965→        }\n   966→      } catch (error) {\n   967→        const message = error instanceof Error ? error.message : String(error);\n   968→        // If exec fails, fall through to chat mode\n   969→        logger.warn({ err: message }, 'Direct exec mode failed, falling back to chat');\n   970→      }\n   971→    }\n   972→\n   973→    // F-011: Check if AI CLI is already running\n   974→    if (isAiCliRunning(sessionId)) {\n   975→      await ctx.reply('⏳ 有任务正在执行，请等待完成或使用 /stop 中断。');\n   976→      return;\n   977→    }\n   978→\n   979→    let typingTimer = null;\n   980→\n   981→    try {\n   982→      ensureAllowed(ctx);\n   983→      await ctx.sendChatAction('typing');\n   984→\n   985→      const streamPublisher = createEditableStreamPublisher(ctx);\n   986→      typingTimer = setInterval(() => {\n   987→        ctx.sendChatAction('typing').catch(() => undefined);\n   988→      }, TYPING_INTERVAL_MS);\n   989→\n   990→      // F-018: Use message-router for unified processing\n   991→      const sessionKey = `telegram:${sessionId}`;\n   992→\n   993→      // Track last heartbeat message for updates\n   994→      /** @type {{ message_id: number } | null} */\n   995→      let lastHeartbeatMsg = null;\n   996→\n   997→      const routerResult = await messageRouter.processMessage({\n   998→        channel: 'telegram',\n   999→        sessionId,\n  1000→        message: ctx.message.text,\n  1001→        telegramChatId: sessionId,\n  1002→        userId,\n  1003→        hooks: {\n  1004→          onStatus: (payload) => {\n  1005→            if (payload.stage === 'running') {\n  1006→              ctx.sendChatAction('typing').catch(() => undefined);\n  1007→            }\n  1008→          },\n  1009→          onAssistantChunk: (data) => {\n  1010→            streamPublisher.push(data.text);\n  1011→          },\n  1012→          onAssistantDone: (data) => {\n  1013→            // Done event handled below after processMessage resolves\n  1014→          }\n  1015→        }\n  1016→      });\n  1017→\n  1018→      // Delete heartbeat message if exists\n  1019→      if (lastHeartbeatMsg) {\n  1020→        ctx.telegram.deleteMessage(ctx.chat.id, lastHeartbeatMsg.message_id).catch(() => {});\n  1021→      }\n  1022→\n  1023→      const replyText = routerResult.reply;\n  1024→\n  1025→      // Extract file markers and send\n  1026→      const { fileRefs, cleanedText } = extractFileMarkers(replyText);\n  1027→      logger.info({ sessionId, fileRefsCount: fileRefs.length, fileRefs }, 'Parsed file markers from assistant reply');\n  1028→      const finalText = cleanedText || (fileRefs.length > 0 ? '已执行，正在发送文件。' : '已执行。');\n  1029→\n  1030→      streamPublisher.setFinalText(finalText);\n  1031→      const streamed = await streamPublisher.finish();\n  1032→      if (streamed.outputLength === 0) {\n  1033→        await replyLargeText(ctx, finalText);\n  1034→      }\n  1035→\n  1036→      if (fileRefs.length > 0) {\n  1037→        const fileSendResults = await replyFiles(ctx, fileRefs);\n  1038→        const failed = fileSendResults.filter((item) => !item.sent);\n  1039→\n  1040→        if (failed.length === 0) {\n  1041→          await safeReply(ctx, `已发送 ${fileSendResults.length} 个文件。`);\n  1042→        } else {\n  1043→          const failedList = failed\n  1044→            .map((item) => {\n  1045→              const reason =\n  1046→                item.reason === 'relative_path_not_allowed'\n  1047→                  ? '仅允许绝对路径，拒绝相对路径（请使用 SEND_FILE:/var/folders/.../xxx.png）'\n  1048→                  : item.reason === 'not_found'\n  1049→                    ? '文件不存在或不可访问（建议返回绝对路径，例如 SEND_FILE:/var/folders/.../xxx.png）'\n  1050→                    : item.reason;\n  1051→              const tried = Array.isArray(item.triedPaths) && item.triedPaths.length > 0 ? `；尝试路径：${item.triedPaths.join(' | ')}` : '';\n  1052→              return `- SEND_FILE:${item.fileRef}${reason ? `（${reason}）` : ''}${tried}`;\n  1053→            })\n  1054→            .join('\\n');\n  1055→          await safeReply(ctx, `以下文件发送失败，已附回原始引用：\\n${failedList}`);\n  1056→          logger.warn({ sessionId, failed }, 'Some files failed to send to telegram');\n  1057→        }\n  1058→      }\n  1059→    } catch (error) {\n  1060→      const message = error instanceof Error ? error.message : String(error);\n  1061→      logger.error({ err: message, sessionId }, 'Failed to process telegram message');\n  1062→      await safeReply(ctx, `处理失败：${message}`);\n  1063→    } finally {\n  1064→      if (typingTimer) {\n  1065→        clearInterval(typingTimer);\n  1066→      }\n  1067→    }\n  1068→  });\n  1069→\n  1070→  return bot;\n  1071→}\n  1072→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_vrtx_01AxNdFx22AqEXAnNaTghU15","session_id":"ac44fc5c-0407-4bd5-95fd-57d4b24826fc","uuid":"530df5be-cbdb-4187-b04c-11027dce0cbd","timestamp":"2026-03-22T13:25:37.984Z"}
