{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_013L1ciFY3iEL7i1A8PSbazW","type":"tool_result","content":"     1→/**\n     2→ * Message Router Service\n     3→ *\n     4→ * Unified message processor for both Web and Telegram channels.\n     5→ * Routes messages through ai-cli-service and publishes events via realtime-hub.\n     6→ *\n     7→ * F-018: Web-Telegram Bidirectional Sync\n     8→ */\n     9→\n    10→import { sanitizeInput } from '../security/guard.js';\n    11→import { logger } from '../utils/logger.js';\n    12→import { chatQueue } from './chat-queue.js';\n    13→\n    14→/**\n    15→ * @typedef {Object} MessageProcessOptions\n    16→ * @property {string} channel - Channel name ('web' or 'telegram')\n    17→ * @property {string} sessionId - Session ID (web session ID or Telegram chat ID)\n    18→ * @property {string} message - User message\n    19→ * @property {string} [telegramChatId] - Bound Telegram chat ID (optional)\n    20→ * @property {string} [userId] - User ID who initiated the message\n    21→ * @property {Object} [hooks] - Callback hooks\n    22→ * @property {Function} [hooks.onStatus] - Status change callback (payload) => void\n    23→ * @property {Function} [hooks.onAssistantChunk] - Chunk callback (data) => void\n    24→ * @property {Function} [hooks.onAssistantDone] - Done callback (data) => void\n    25→ */\n    26→\n    27→/**\n    28→ * Creates a message router instance\n    29→ * @param {Object} dependencies\n    30→ * @param {Function} dependencies.aiCliExecutor - AI CLI executor (executeAiCli function)\n    31→ * @param {Object} dependencies.sessionStore - Session store instance\n    32→ * @param {Object} dependencies.realtimeHub - Realtime hub instance\n    33→ * @returns {MessageRouter}\n    34→ */\n    35→export function createMessageRouter({ aiCliExecutor, sessionStore, realtimeHub }) {\n    36→  return {\n    37→    /**\n    38→     * Process a message from any channel\n    39→     * @param {MessageProcessOptions} options\n    40→     * @returns {Promise<{reply: string}>}\n    41→     */\n    42→    async processMessage(options) {\n    43→      const {\n    44→        channel,\n    45→        sessionId,\n    46→        message,\n    47→        telegramChatId,\n    48→        userId,\n    49→        hooks = {}\n    50→      } = options;\n    51→\n    52→      // Validate required fields\n    53→      const normalizedChannel = String(channel ?? '').trim();\n    54→      const normalizedSessionId = String(sessionId ?? '').trim();\n    55→      const normalizedMessage = String(message ?? '').trim();\n    56→\n    57→      if (!normalizedSessionId) {\n    58→        throw new Error('sessionId 不能为空。');\n    59→      }\n    60→\n    61→      if (!normalizedMessage) {\n    62→        throw new Error('message 不能为空。');\n    63→      }\n    64→\n    65→      // Determine session key based on binding\n    66→      let sessionKey;\n    67→      if (telegramChatId) {\n    68→        sessionKey = `telegram:${telegramChatId}`;\n    69→      } else {\n    70→        sessionKey = `${normalizedChannel}:${normalizedSessionId}`;\n    71→      }\n    72→\n    73→      // Use chat queue to ensure sequential processing per session\n    74→      return chatQueue.run(sessionKey, async () => {\n    75→        const sanitized = sanitizeInput(normalizedMessage);\n    76→\n    77→        // Publish accepted status\n    78→        hooks.onStatus?.({ stage: 'accepted', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n    79→        realtimeHub.publish(sessionKey, { type: 'status', payload: { stage: 'accepted', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n    80→\n    81→        // Append user message to session store\n    82→        sessionStore.append(sessionKey, 'user', sanitized);\n    83→\n    84→        // Publish user message event for cross-channel sync\n    85→        realtimeHub.publish(sessionKey, { type: 'user_message', payload: { channel: normalizedChannel, sessionId: normalizedSessionId, message: sanitized, timestamp: Date.now() } });\n    86→\n    87→        // Build prompt for AI CLI\n    88→        const prompt = sessionStore.toPrompt(sessionKey, normalizedChannel);\n    89→\n    90→        // Publish running status\n    91→        hooks.onStatus?.({ stage: 'running', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n    92→        realtimeHub.publish(sessionKey, { type: 'status', payload: { stage: 'running', channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n    93→\n    94→        logger.info({ sessionKey, channel: normalizedChannel, userId }, 'Processing message');\n    95→\n    96→        // Execute via AI CLI service\n    97→        const result = await aiCliExecutor({\n    98→          sessionId: sessionKey,\n    99→          prompt,\n   100→          userId,\n   101→          hooks: {\n   102→            onChunk: (text) => {\n   103→              // Forward chunks to caller and realtime hub\n   104→              hooks.onAssistantChunk?.({ text, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId });\n   105→              realtimeHub.publish(sessionKey, { type: 'assistant_chunk', payload: { text, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId } });\n   106→            },\n   107→            onStatus: (status) => {\n   108→              logger.debug({ sessionKey, status }, 'AI CLI status changed');\n   109→            }\n   110→          }\n   111→        });\n   112→\n   113→        // Append assistant reply to session store\n   114→        sessionStore.append(sessionKey, 'assistant', result.output);\n   115→\n   116→        // Publish assistant done event\n   117→        const donePayload = { reply: result.output, channel: normalizedChannel, sessionId: normalizedSessionId, telegramChatId };\n   118→        hooks.onAssistantDone?.(donePayload);\n   119→        realtimeHub.publish(sessionKey, { type: 'assistant_done', payload: { ...donePayload, timestamp: Date.now() } });\n   120→\n   121→        logger.info({ sessionKey, elapsedMs: result.elapsedMs }, 'Message processed');\n   122→\n   123→        return { reply: result.output };\n   124→      });\n   125→    }\n   126→  };\n   127→}\n   128→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_vrtx_01AxNdFx22AqEXAnNaTghU15","session_id":"ac44fc5c-0407-4bd5-95fd-57d4b24826fc","uuid":"cae6316f-fc75-49f4-ace0-fc34f62e3dec","timestamp":"2026-03-22T13:25:51.732Z"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_0187udnZ928tGL68KRaamtHT","type":"tool_result","content":"     1→/**\n     2→ * F-011: MarkdownV2 Formatter for Telegram\n     3→ *\n     4→ * Telegram MarkdownV2 requires escaping specific characters.\n     5→ * This module provides utilities for converting common Markdown\n     6→ * to Telegram's MarkdownV2 format.\n     7→ *\n     8→ * Reference: https://core.telegram.org/bots/api#markdownv2-style\n     9→ */\n    10→\n    11→/**\n    12→ * Characters that need escaping in MarkdownV2.\n    13→ * All these characters must be escaped with a backslash.\n    14→ */\n    15→const ESCAPE_CHARS = ['_', '*', '[', ']', '(', ')', '~', '`', '>', '#', '+', '-', '=', '|', '{', '}', '.', '!'];\n    16→\n    17→/**\n    18→ * Escape text for Telegram MarkdownV2 format.\n    19→ * In MarkdownV2, all special characters must be escaped.\n    20→ * @param {string} text - Text to escape\n    21→ * @returns {string} Escaped text\n    22→ */\n    23→export function escapeMarkdownV2(text) {\n    24→  if (!text) return '';\n    25→\n    26→  let result = text;\n    27→  for (const char of ESCAPE_CHARS) {\n    28→    result = result.split(char).join('\\\\' + char);\n    29→  }\n    30→  return result;\n    31→}\n    32→\n    33→/**\n    34→ * Escape text inside code blocks.\n    35→ * Inside code blocks, only ` and \\ need escaping.\n    36→ * @param {string} code - Code content\n    37→ * @returns {string} Escaped code\n    38→ */\n    39→function escapeCodeContent(code) {\n    40→  if (!code) return '';\n    41→  return code\n    42→    .split('\\\\').join('\\\\\\\\')\n    43→    .split('`').join('\\\\`');\n    44→}\n    45→\n    46→/**\n    47→ * Format code block for Telegram MarkdownV2.\n    48→ * @param {string} code - Code content\n    49→ * @param {string} [language=''] - Optional language identifier\n    50→ * @returns {string} Formatted code block\n    51→ */\n    52→export function formatCodeBlock(code, language = '') {\n    53→  const escapedCode = escapeCodeContent(code ?? '');\n    54→  // Handle empty code case\n    55→  if (!escapedCode) {\n    56→    return '```' + language + '\\n```';\n    57→  }\n    58→  return '```' + language + '\\n' + escapedCode + '\\n```';\n    59→}\n    60→\n    61→/**\n    62→ * Format inline code for Telegram MarkdownV2.\n    63→ * @param {string} code - Code content\n    64→ * @returns {string} Formatted inline code\n    65→ */\n    66→export function formatInlineCode(code) {\n    67→  const escapedCode = escapeCodeContent(code ?? '');\n    68→  return '`' + escapedCode + '`';\n    69→}\n    70→\n    71→/**\n    72→ * Convert common Markdown to Telegram MarkdownV2.\n    73→ * Handles: code blocks, inline code, bold, italic, links.\n    74→ * @param {string} markdown - Input markdown\n    75→ * @returns {string} MarkdownV2 formatted text\n    76→ */\n    77→export function convertToMarkdownV2(markdown) {\n    78→  if (!markdown) return '';\n    79→\n    80→  let result = markdown;\n    81→\n    82→  // Process code blocks first (to protect their content)\n    83→  const codeBlocks = [];\n    84→  result = result.replace(/```(\\w*)\\n([\\s\\S]*?)```/g, (match, lang, code) => {\n    85→    const placeholder = `\\x00CB${codeBlocks.length}\\x00`;\n    86→    codeBlocks.push(formatCodeBlock(code, lang));\n    87→    return placeholder;\n    88→  });\n    89→\n    90→  // Process inline code\n    91→  const inlineCodes = [];\n    92→  result = result.replace(/`([^`]+)`/g, (match, code) => {\n    93→    const placeholder = `\\x00IC${inlineCodes.length}\\x00`;\n    94→    inlineCodes.push(formatInlineCode(code));\n    95→    return placeholder;\n    96→  });\n    97→\n    98→  // Process links [text](url)\n    99→  const links = [];\n   100→  result = result.replace(/\\[([^\\]]+)\\]\\(([^)]+)\\)/g, (match, text, url) => {\n   101→    const placeholder = `\\x00LK${links.length}\\x00`;\n   102→    // In MarkdownV2, escape the URL but keep the link format\n   103→    links.push(`[${escapeMarkdownV2(text)}](${escapeMarkdownV2(url)})`);\n   104→    return placeholder;\n   105→  });\n   106→\n   107→  // Process bold **text** - use placeholders to prevent double-escaping\n   108→  const bolds = [];\n   109→  result = result.replace(/\\*\\*([^*]+)\\*\\*/g, (match, text) => {\n   110→    const placeholder = `\\x00BD${bolds.length}\\x00`;\n   111→    bolds.push('*' + escapeMarkdownV2(text) + '*');\n   112→    return placeholder;\n   113→  });\n   114→\n   115→  // Process italic _text_ - use placeholders to prevent double-escaping\n   116→  const italics = [];\n   117→  result = result.replace(/_([^_]+)_/g, (match, text) => {\n   118→    const placeholder = `\\x00IT${italics.length}\\x00`;\n   119→    italics.push('_' + escapeMarkdownV2(text) + '_');\n   120→    return placeholder;\n   121→  });\n   122→\n   123→  // Escape remaining special characters\n   124→  result = escapeMarkdownV2(result);\n   125→\n   126→  // Restore protected content (placeholders contain no special chars so they won't be escaped)\n   127→  for (let i = 0; i < codeBlocks.length; i++) {\n   128→    result = result.split(`\\\\x00CB${i}\\\\x00`).join(codeBlocks[i]);\n   129→    result = result.split(`\\x00CB${i}\\x00`).join(codeBlocks[i]);\n   130→  }\n   131→  for (let i = 0; i < inlineCodes.length; i++) {\n   132→    result = result.split(`\\\\x00IC${i}\\\\x00`).join(inlineCodes[i]);\n   133→    result = result.split(`\\x00IC${i}\\x00`).join(inlineCodes[i]);\n   134→  }\n   135→  for (let i = 0; i < links.length; i++) {\n   136→    result = result.split(`\\\\x00LK${i}\\\\x00`).join(links[i]);\n   137→    result = result.split(`\\x00LK${i}\\x00`).join(links[i]);\n   138→  }\n   139→  for (let i = 0; i < bolds.length; i++) {\n   140→    result = result.split(`\\\\x00BD${i}\\\\x00`).join(bolds[i]);\n   141→    result = result.split(`\\x00BD${i}\\x00`).join(bolds[i]);\n   142→  }\n   143→  for (let i = 0; i < italics.length; i++) {\n   144→    result = result.split(`\\\\x00IT${i}\\\\x00`).join(italics[i]);\n   145→    result = result.split(`\\x00IT${i}\\x00`).join(italics[i]);\n   146→  }\n   147→\n   148→  // Remove any remaining null placeholders (for safety)\n   149→  result = result.replace(/\\\\x00[A-Z]+\\d+\\\\x00/g, '');\n   150→  result = result.replace(/\\x00[A-Z]+\\d+\\x00/g, '');\n   151→\n   152→  return result;\n   153→}\n   154→\n   155→/**\n   156→ * Split text into segments respecting code block boundaries.\n   157→ * Useful for splitting long messages without breaking code blocks.\n   158→ * @param {string} text - Text to split\n   159→ * @param {number} maxLength - Maximum length per segment (default 4000)\n   160→ * @returns {string[]} Array of segments\n   161→ */\n   162→export function splitRespectingCodeBlocks(text, maxLength = 4000) {\n   163→  if (!text) return [''];\n   164→  if (text.length <= maxLength) return [text];\n   165→\n   166→  const segments = [];\n   167→  let currentSegment = '';\n   168→\n   169→  // Split text into chunks: code blocks and non-code parts\n   170→  const parts = text.split(/(```[\\s\\S]*?```)/g);\n   171→\n   172→  for (const part of parts) {\n   173→    // If adding this part would exceed maxLength\n   174→    if (currentSegment.length + part.length > maxLength) {\n   175→      // If it's a code block, we need to keep it whole\n   176→      if (part.startsWith('```') && part.endsWith('```')) {\n   177→        // If current segment has content, push it\n   178→        if (currentSegment.trim()) {\n   179→          segments.push(currentSegment);\n   180→          currentSegment = '';\n   181→        }\n   182→        // Check if code block itself exceeds maxLength\n   183→        if (part.length > maxLength) {\n   184→          // We have to split it - but try at a reasonable point\n   185→          // For now, just push it as a single segment (Telegram will truncate)\n   186→          segments.push(part);\n   187→        } else {\n   188→          currentSegment = part;\n   189→        }\n   190→      } else {\n   191→        // Regular text - try to split at paragraph or newline\n   192→        const remaining = maxLength - currentSegment.length;\n   193→        if (remaining > 0) {\n   194→          // Take what we can from this part\n   195→          const chunk = part.slice(0, remaining);\n   196→          const breakPoint = Math.max(\n   197→            chunk.lastIndexOf('\\n\\n'),\n   198→            chunk.lastIndexOf('\\n'),\n   199→            chunk.lastIndexOf(' ')\n   200→          );\n   201→\n   202→          if (breakPoint > 0) {\n   203→            currentSegment += chunk.slice(0, breakPoint + 1);\n   204→            segments.push(currentSegment);\n   205→            currentSegment = part.slice(breakPoint + 1);\n   206→          } else {\n   207→            currentSegment += chunk;\n   208→            segments.push(currentSegment);\n   209→            currentSegment = part.slice(remaining);\n   210→          }\n   211→        } else {\n   212→          if (currentSegment.trim()) {\n   213→            segments.push(currentSegment);\n   214→          }\n   215→          currentSegment = part;\n   216→        }\n   217→\n   218→        // If current segment still exceeds, we need to keep splitting\n   219→        while (currentSegment.length > maxLength) {\n   220→          const chunk = currentSegment.slice(0, maxLength);\n   221→          const breakPoint = Math.max(\n   222→            chunk.lastIndexOf('\\n\\n'),\n   223→            chunk.lastIndexOf('\\n'),\n   224→            chunk.lastIndexOf(' ')\n   225→          );\n   226→\n   227→          if (breakPoint > 0) {\n   228→            segments.push(chunk.slice(0, breakPoint + 1));\n   229→            currentSegment = currentSegment.slice(breakPoint + 1);\n   230→          } else {\n   231→            segments.push(chunk);\n   232→            currentSegment = currentSegment.slice(maxLength);\n   233→          }\n   234→        }\n   235→      }\n   236→    } else {\n   237→      currentSegment += part;\n   238→    }\n   239→  }\n   240→\n   241→  if (currentSegment.trim()) {\n   242→    segments.push(currentSegment);\n   243→  }\n   244→\n   245→  return segments.length > 0 ? segments : [''];\n   246→}\n   247→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":"toolu_vrtx_01AxNdFx22AqEXAnNaTghU15","session_id":"ac44fc5c-0407-4bd5-95fd-57d4b24826fc","uuid":"65ff24d9-7f08-414b-b41f-593a1e4dafca","timestamp":"2026-03-22T13:25:51.734Z"}
