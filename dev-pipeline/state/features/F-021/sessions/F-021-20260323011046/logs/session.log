{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_013v6dwbhegPDbgUBaiogz9W","type":"tool_result","content":"     1→/**\n     2→ * Command Router\n     3→ * Main entry point for command routing and dispatch.\n     4→ */\n     5→\n     6→import { parseCommand } from './parser.js';\n     7→import { getCommand, getAliasMap, registerCommand } from './registry.js';\n     8→import { validateCommand } from './validator.js';\n     9→import { formatError, formatValidationErrors, formatNLSuggestions, ErrorCodes } from './formatter.js';\n    10→import { routeIntent, enhanceSlashCommand } from './intent-router.js';\n    11→import { isAllowedUser } from '../../security/guard.js';\n    12→import { checkCommandPermission, getUserRole } from '../../security/permission-guard.js';\n    13→import { logAuditEntry } from '../../services/audit-log-service.js';\n    14→import { aliasStore } from '../../services/alias-store.js';\n    15→import { sessionStore } from '../../services/session-store.js';\n    16→\n    17→/**\n    18→ * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n    19→ * @typedef {import('./registry.js').CommandMeta} CommandMeta\n    20→ * @typedef {import('./registry.js').CommandEntry} CommandEntry\n    21→ */\n    22→\n    23→/**\n    24→ * Build session ID from context.\n    25→ * @param {Object} ctx - Telegraf context\n    26→ * @returns {string} Session ID\n    27→ */\n    28→function buildSessionId(ctx) {\n    29→  return String(ctx.chat.id);\n    30→}\n    31→\n    32→/**\n    33→ * Route and dispatch a command from Telegram context.\n    34→ *\n    35→ * Supports three input modes:\n    36→ *  1. Structured slash command:      /pipeline run my-feature  → parse + validate + dispatch\n    37→ *  2. Slash + NL supplement:         /pipeline 帮我看日志         → intent-router enhances subcommand\n    38→ *  3. Pure natural language (no /):  帮我看看 pipeline 状态       → intent-router routes + dispatch\n    39→ *\n    40→ * @param {Object} ctx - Telegraf context\n    41→ * @returns {Promise<boolean>} True if command was handled\n    42→ */\n    43→export async function routeCommand(ctx) {\n    44→  let text = ctx.message?.text;\n    45→\n    46→  if (!text) {\n    47→    return false;\n    48→  }\n    49→\n    50→  const isPureNL = !text.startsWith('/');\n    51→\n    52→  // ── Authorization check (both slash and pure-NL paths) ───────────────────\n    53→  const userId = ctx.from?.id;\n    54→  if (!isAuthorized(userId)) {\n    55→    if (!isPureNL) {\n    56→      // Only block slash commands with auth error; pure NL falls through to chat\n    57→      await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n    58→      return true;\n    59→    }\n    60→    return false;\n    61→  }\n    62→\n    63→  // ── Pure Natural Language path ────────────────────────────────────────────\n    64→  if (isPureNL) {\n    65→    return routePureNL(ctx, text, userId);\n    66→  }\n    67→\n    68→  // ── Slash command path ────────────────────────────────────────────────────\n    69→  const sessionId = buildSessionId(ctx);\n    70→  const userIdStr = String(userId);\n    71→\n    72→  // F-013: Touch session on each command\n    73→  sessionStore.touchSession(sessionId, userIdStr);\n    74→\n    75→  // F-013: Resolve alias if the command name is an alias\n    76→  const commandMatch = text.match(/^\\/(\\S+)/);\n    77→  if (commandMatch) {\n    78→    const potentialAlias = commandMatch[1].toLowerCase();\n    79→    const resolvedCommand = aliasStore.resolveAlias(userIdStr, potentialAlias);\n    80→    if (resolvedCommand) {\n    81→      // Replace the alias with the resolved command\n    82→      const args = text.slice(commandMatch[0].length);\n    83→      text = `/${resolvedCommand}${args}`;\n    84→    }\n    85→  }\n    86→\n    87→  // Parse command\n    88→  const aliasMap = getAliasMap();\n    89→  const parsed = parseCommand(text, aliasMap);\n    90→\n    91→  if (!parsed) {\n    92→    await ctx.reply('无法解析命令。');\n    93→    return true;\n    94→  }\n    95→\n    96→  // Lookup command\n    97→  const entry = getCommand(parsed.command);\n    98→\n    99→  if (!entry) {\n   100→    // F-015: Unknown command — try intent routing on the full text\n   101→    const nlResult = routeIntent(text);\n   102→    if (nlResult.matched && !nlResult.needsConfirmation && nlResult.primary) {\n   103→      // High confidence: synthesize and dispatch\n   104→      return dispatchParsedIntent(ctx, nlResult.primary, userId, sessionId);\n   105→    } else if (nlResult.matched) {\n   106→      // Low confidence: present suggestions instead of bare \"unknown command\"\n   107→      await ctx.reply(formatNLSuggestions(nlResult));\n   108→      return true;\n   109→    }\n   110→\n   111→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n   112→    return true;\n   113→  }\n   114→\n   115→  const { meta, handler } = entry;\n   116→\n   117→  // T-101: Permission check\n   118→  const commandName = meta.name;\n   119→  const permResult = checkCommandPermission(userId, commandName);\n   120→\n   121→  if (!permResult.allowed) {\n   122→    // Log denied access\n   123→    await logAuditEntry({\n   124→      userId,\n   125→      action: commandName,\n   126→      params: {},\n   127→      result: 'denied',\n   128→      reason: permResult.reason\n   129→    });\n   130→\n   131→    await ctx.reply(`⛔ ${permResult.reason}`);\n   132→    return true;\n   133→  }\n   134→\n   135→  // F-015: Slash + NL Enhancement\n   136→  // When the subcommand is present but does not match any declared subcommand,\n   137→  // attempt to infer the intended subcommand via the intent router.\n   138→  let effectiveParsed = parsed;\n   139→  if (\n   140→    meta.subcommands?.length > 0 &&\n   141→    parsed.subcommand &&\n   142→    !meta.subcommands.some((s) => s.name === parsed.subcommand)\n   143→  ) {\n   144→    // The subcommand token appears to be natural language\n   145→    const nlText = `${parsed.subcommand} ${parsed.args.join(' ')}`.trim();\n   146→    const nlResult = enhanceSlashCommand(parsed.command, nlText);\n   147→\n   148→    if (nlResult.matched && nlResult.primary?.subcommand) {\n   149→      if (!nlResult.needsConfirmation) {\n   150→        // High confidence: silently correct the subcommand\n   151→        effectiveParsed = {\n   152→          ...parsed,\n   153→          subcommand: nlResult.primary.subcommand,\n   154→          args: nlResult.primary.args || parsed.args\n   155→        };\n   156→      } else {\n   157→        // Low confidence: show candidates and let user decide\n   158→        await ctx.reply(formatNLSuggestions(nlResult));\n   159→        return true;\n   160→      }\n   161→    }\n   162→    // If no match, fall through to normal validation (which will produce an error)\n   163→  }\n   164→\n   165→  // Validate command\n   166→  const validation = validateCommand(effectiveParsed, meta);\n   167→\n   168→  if (!validation.valid) {\n   169→    // F-015: If validation fails due to invalid subcommand and we haven't tried NL yet,\n   170→    // try enhancing and give suggestion\n   171→    const hasSubcommandError = validation.errors.some((e) => e.param === 'subcommand');\n   172→    if (hasSubcommandError && meta.subcommands?.length > 0 && parsed.subcommand) {\n   173→      const nlText = `${parsed.subcommand} ${parsed.args.join(' ')}`.trim();\n   174→      const nlResult = enhanceSlashCommand(parsed.command, nlText);\n   175→      if (nlResult.matched) {\n   176→        await ctx.reply(formatNLSuggestions(nlResult));\n   177→        return true;\n   178→      }\n   179→    }\n   180→\n   181→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n   182→    await ctx.reply(errorMsg);\n   183→    return true;\n   184→  }\n   185→\n   186→  // Create handler context\n   187→  const handlerContext = {\n   188→    ctx,\n   189→    parsed: effectiveParsed,\n   190→    meta,\n   191→    params: validation.normalized || {},\n   192→    userId,\n   193→    userRole: getUserRole(userId),\n   194→    sessionId,\n   195→    requiresConfirmation: permResult.requiresConfirmation,\n   196→    reply: async (text) => ctx.reply(text),\n   197→    replyFile: async (content, filename) => {\n   198→      // Will be implemented with proper file handling\n   199→      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n   200→    },\n   201→    args: effectiveParsed.args || []\n   202→  };\n   203→\n   204→  // Dispatch to handler\n   205→  try {\n   206→    await handler(handlerContext);\n   207→  } catch (error) {\n   208→    const message = error instanceof Error ? error.message : String(error);\n   209→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n   210→  }\n   211→\n   212→  return true;\n   213→}\n   214→\n   215→/**\n   216→ * Handle pure natural language input (no leading slash).\n   217→ * Routes via intent-router and dispatches if confidence is high enough.\n   218→ *\n   219→ * @param {Object} ctx - Telegraf context\n   220→ * @param {string} text - Message text\n   221→ * @param {number|string|undefined} userId - User ID\n   222→ * @returns {Promise<boolean>} True if handled\n   223→ */\n   224→async function routePureNL(ctx, text, userId) {\n   225→  const nlResult = routeIntent(text);\n   226→\n   227→  if (!nlResult.matched) {\n   228→    // No recognizable intent — fall through to chat\n   229→    return false;\n   230→  }\n   231→\n   232→  const sessionId = buildSessionId(ctx);\n   233→\n   234→  if (!nlResult.needsConfirmation && nlResult.primary) {\n   235→    // High confidence: dispatch directly\n   236→    return dispatchParsedIntent(ctx, nlResult.primary, userId, sessionId);\n   237→  }\n   238→\n   239→  // Low confidence or ambiguous: present candidates\n   240→  await ctx.reply(formatNLSuggestions(nlResult));\n   241→  return true;\n   242→}\n   243→\n   244→/**\n   245→ * Synthesize a ParsedCommand from an IntentCandidate and dispatch through the normal chain.\n   246→ *\n   247→ * @param {Object} ctx - Telegraf context\n   248→ * @param {import('./intent-router.js').IntentCandidate} candidate - Intent candidate\n   249→ * @param {number|string|undefined} userId - User ID\n   250→ * @param {string} sessionId - Session ID\n   251→ * @returns {Promise<boolean>} Always true (handled)\n   252→ */\n   253→async function dispatchParsedIntent(ctx, candidate, userId, sessionId) {\n   254→  const entry = getCommand(candidate.command);\n   255→  if (!entry) {\n   256→    // Command not registered — present error\n   257→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: candidate.command })));\n   258→    return true;\n   259→  }\n   260→\n   261→  const { meta, handler } = entry;\n   262→\n   263→  // Permission check\n   264→  const permResult = checkCommandPermission(userId, meta.name);\n   265→  if (!permResult.allowed) {\n   266→    await logAuditEntry({\n   267→      userId,\n   268→      action: meta.name,\n   269→      params: {},\n   270→      result: 'denied',\n   271→      reason: permResult.reason\n   272→    });\n   273→    await ctx.reply(`⛔ ${permResult.reason}`);\n   274→    return true;\n   275→  }\n   276→\n   277→  // Build synthetic parsed command\n   278→  /** @type {import('./parser.js').ParsedCommand} */\n   279→  const syntheticParsed = {\n   280→    command: candidate.command,\n   281→    subcommand: candidate.subcommand,\n   282→    args: candidate.args || [],\n   283→    options: {},\n   284→    raw: ctx.message?.text || ''\n   285→  };\n   286→\n   287→  const validation = validateCommand(syntheticParsed, meta);\n   288→\n   289→  if (!validation.valid) {\n   290→    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n   291→    await ctx.reply(errorMsg);\n   292→    return true;\n   293→  }\n   294→\n   295→  const handlerContext = {\n   296→    ctx,\n   297→    parsed: syntheticParsed,\n   298→    meta,\n   299→    params: validation.normalized || {},\n   300→    userId,\n   301→    userRole: getUserRole(userId),\n   302→    sessionId,\n   303→    requiresConfirmation: permResult.requiresConfirmation,\n   304→    reply: async (text) => ctx.reply(text),\n   305→    replyFile: async (content, filename) => {\n   306→      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n   307→    },\n   308→    args: syntheticParsed.args || []\n   309→  };\n   310→\n   311→  try {\n   312→    await handler(handlerContext);\n   313→  } catch (error) {\n   314→    const message = error instanceof Error ? error.message : String(error);\n   315→    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n   316→  }\n   317→\n   318→  return true;\n   319→}\n   320→\n   321→/**\n   322→ * Check if user is authorized.\n   323→ * @param {number|string|undefined} userId - User ID\n   324→ * @returns {boolean} True if authorized\n   325→ */\n   326→function isAuthorized(userId) {\n   327→  return isAllowedUser(userId);\n   328→}\n   329→\n   330→/**\n   331→ * Format error response for display.\n   332→ * @param {Object} error - Error object\n   333→ * @returns {string} Formatted error\n   334→ */\n   335→function formatErrorResponse(error) {\n   336→  const lines = [`❌ ${error.message}`];\n   337→\n   338→  if (error.suggestion) {\n   339→    lines.push(`💡 ${error.suggestion}`);\n   340→  }\n   341→\n   342→  if (error.usage) {\n   343→    lines.push(`用法: ${error.usage}`);\n   344→  }\n   345→\n   346→  return lines.join('\\n');\n   347→}\n   348→\n   349→/**\n   350→ * Register all default commands.\n   351→ */\n   352→export function registerDefaultCommands() {\n   353→  // Commands will be registered by individual handlers\n   354→  // This is called during initialization\n   355→}\n   356→\n   357→/**\n   358→ * Create middleware for command routing.\n   359→ * @returns {Function} Middleware function\n   360→ */\n   361→export function createCommandMiddleware() {\n   362→  return async (ctx, next) => {\n   363→    const handled = await routeCommand(ctx);\n   364→    if (!handled) {\n   365→      return next();\n   366→    }\n   367→  };\n   368→}\n   369→\n   370→// Re-export for convenience\n   371→export { registerCommand, getCommand, getAliasMap };\n   372→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"ec3f85f9-8701-4b0b-90d5-41b254af0c38","uuid":"4ec3610a-691e-46f2-8455-cb18786d1f00","timestamp":"2026-03-22T17:11:42.539Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/src/bot/commands/index.js","content":"/**\n * Command Router\n * Main entry point for command routing and dispatch.\n */\n\nimport { parseCommand } from './parser.js';\nimport { getCommand, getAliasMap, registerCommand } from './registry.js';\nimport { validateCommand } from './validator.js';\nimport { formatError, formatValidationErrors, formatNLSuggestions, ErrorCodes } from './formatter.js';\nimport { routeIntent, enhanceSlashCommand } from './intent-router.js';\nimport { isAllowedUser } from '../../security/guard.js';\nimport { checkCommandPermission, getUserRole } from '../../security/permission-guard.js';\nimport { logAuditEntry } from '../../services/audit-log-service.js';\nimport { aliasStore } from '../../services/alias-store.js';\nimport { sessionStore } from '../../services/session-store.js';\n\n/**\n * @typedef {import('./parser.js').ParsedCommand} ParsedCommand\n * @typedef {import('./registry.js').CommandMeta} CommandMeta\n * @typedef {import('./registry.js').CommandEntry} CommandEntry\n */\n\n/**\n * Build session ID from context.\n * @param {Object} ctx - Telegraf context\n * @returns {string} Session ID\n */\nfunction buildSessionId(ctx) {\n  return String(ctx.chat.id);\n}\n\n/**\n * Route and dispatch a command from Telegram context.\n *\n * Supports three input modes:\n *  1. Structured slash command:      /pipeline run my-feature  → parse + validate + dispatch\n *  2. Slash + NL supplement:         /pipeline 帮我看日志         → intent-router enhances subcommand\n *  3. Pure natural language (no /):  帮我看看 pipeline 状态       → intent-router routes + dispatch\n *\n * @param {Object} ctx - Telegraf context\n * @returns {Promise<boolean>} True if command was handled\n */\nexport async function routeCommand(ctx) {\n  let text = ctx.message?.text;\n\n  if (!text) {\n    return false;\n  }\n\n  const isPureNL = !text.startsWith('/');\n\n  // ── Authorization check (both slash and pure-NL paths) ───────────────────\n  const userId = ctx.from?.id;\n  if (!isAuthorized(userId)) {\n    if (!isPureNL) {\n      // Only block slash commands with auth error; pure NL falls through to chat\n      await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNAUTHORIZED)));\n      return true;\n    }\n    return false;\n  }\n\n  // ── Pure Natural Language path ────────────────────────────────────────────\n  if (isPureNL) {\n    return routePureNL(ctx, text, userId);\n  }\n\n  // ── Slash command path ────────────────────────────────────────────────────\n  const sessionId = buildSessionId(ctx);\n  const userIdStr = String(userId);\n\n  // F-013: Touch session on each command\n  sessionStore.touchSession(sessionId, userIdStr);\n\n  // F-013: Resolve alias if the command name is an alias\n  const commandMatch = text.match(/^\\/(\\S+)/);\n  if (commandMatch) {\n    const potentialAlias = commandMatch[1].toLowerCase();\n    const resolvedCommand = aliasStore.resolveAlias(userIdStr, potentialAlias);\n    if (resolvedCommand) {\n      // Replace the alias with the resolved command\n      const args = text.slice(commandMatch[0].length);\n      text = `/${resolvedCommand}${args}`;\n    }\n  }\n\n  // Parse command\n  const aliasMap = getAliasMap();\n  const parsed = parseCommand(text, aliasMap);\n\n  if (!parsed) {\n    await ctx.reply('无法解析命令。');\n    return true;\n  }\n\n  // Lookup command\n  const entry = getCommand(parsed.command);\n\n  if (!entry) {\n    // F-015: Unknown command — try intent routing on the full text\n    const nlResult = routeIntent(text);\n    if (nlResult.matched && !nlResult.needsConfirmation && nlResult.primary) {\n      // High confidence: synthesize and dispatch\n      return dispatchParsedIntent(ctx, nlResult.primary, userId, sessionId);\n    } else if (nlResult.matched) {\n      // Low confidence: present suggestions instead of bare \"unknown command\"\n      await ctx.reply(formatNLSuggestions(nlResult));\n      return true;\n    }\n\n    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: parsed.command })));\n    return true;\n  }\n\n  const { meta, handler } = entry;\n\n  // T-101: Permission check\n  const commandName = meta.name;\n  const permResult = checkCommandPermission(userId, commandName);\n\n  if (!permResult.allowed) {\n    // Log denied access\n    await logAuditEntry({\n      userId,\n      action: commandName,\n      params: {},\n      result: 'denied',\n      reason: permResult.reason\n    });\n\n    await ctx.reply(`⛔ ${permResult.reason}`);\n    return true;\n  }\n\n  // F-015: Slash + NL Enhancement\n  // When the subcommand is present but does not match any declared subcommand,\n  // attempt to infer the intended subcommand via the intent router.\n  let effectiveParsed = parsed;\n  if (\n    meta.subcommands?.length > 0 &&\n    parsed.subcommand &&\n    !meta.subcommands.some((s) => s.name === parsed.subcommand)\n  ) {\n    // The subcommand token appears to be natural language\n    const nlText = `${parsed.subcommand} ${parsed.args.join(' ')}`.trim();\n    const nlResult = enhanceSlashCommand(parsed.command, nlText);\n\n    if (nlResult.matched && nlResult.primary?.subcommand) {\n      if (!nlResult.needsConfirmation) {\n        // High confidence: silently correct the subcommand\n        effectiveParsed = {\n          ...parsed,\n          subcommand: nlResult.primary.subcommand,\n          args: nlResult.primary.args || parsed.args\n        };\n      } else {\n        // Low confidence: show candidates and let user decide\n        await ctx.reply(formatNLSuggestions(nlResult));\n        return true;\n      }\n    }\n    // If no match, fall through to normal validation (which will produce an error)\n  }\n\n  // Validate command\n  const validation = validateCommand(effectiveParsed, meta);\n\n  if (!validation.valid) {\n    // F-015: If validation fails due to invalid subcommand and we haven't tried NL yet,\n    // try enhancing and give suggestion\n    const hasSubcommandError = validation.errors.some((e) => e.param === 'subcommand');\n    if (hasSubcommandError && meta.subcommands?.length > 0 && parsed.subcommand) {\n      const nlText = `${parsed.subcommand} ${parsed.args.join(' ')}`.trim();\n      const nlResult = enhanceSlashCommand(parsed.command, nlText);\n      if (nlResult.matched) {\n        await ctx.reply(formatNLSuggestions(nlResult));\n        return true;\n      }\n    }\n\n    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n    await ctx.reply(errorMsg);\n    return true;\n  }\n\n  // Create handler context\n  const handlerContext = {\n    ctx,\n    parsed: effectiveParsed,\n    meta,\n    params: validation.normalized || {},\n    userId,\n    userRole: getUserRole(userId),\n    sessionId,\n    requiresConfirmation: permResult.requiresConfirmation,\n    reply: async (text) => ctx.reply(text),\n    replyFile: async (content, filename) => {\n      // Will be implemented with proper file handling\n      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n    },\n    args: effectiveParsed.args || []\n  };\n\n  // Dispatch to handler\n  try {\n    await handler(handlerContext);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n  }\n\n  return true;\n}\n\n/**\n * Handle pure natural language input (no leading slash).\n * Routes via intent-router and dispatches if confidence is high enough.\n *\n * @param {Object} ctx - Telegraf context\n * @param {string} text - Message text\n * @param {number|string|undefined} userId - User ID\n * @returns {Promise<boolean>} True if handled\n */\nasync function routePureNL(ctx, text, userId) {\n  const nlResult = routeIntent(text);\n\n  if (!nlResult.matched) {\n    // No recognizable intent — fall through to chat\n    return false;\n  }\n\n  const sessionId = buildSessionId(ctx);\n\n  if (!nlResult.needsConfirmation && nlResult.primary) {\n    // High confidence: dispatch directly\n    return dispatchParsedIntent(ctx, nlResult.primary, userId, sessionId);\n  }\n\n  // Low confidence or ambiguous: present candidates\n  await ctx.reply(formatNLSuggestions(nlResult));\n  return true;\n}\n\n/**\n * Synthesize a ParsedCommand from an IntentCandidate and dispatch through the normal chain.\n *\n * @param {Object} ctx - Telegraf context\n * @param {import('./intent-router.js').IntentCandidate} candidate - Intent candidate\n * @param {number|string|undefined} userId - User ID\n * @param {string} sessionId - Session ID\n * @returns {Promise<boolean>} Always true (handled)\n */\nasync function dispatchParsedIntent(ctx, candidate, userId, sessionId) {\n  const entry = getCommand(candidate.command);\n  if (!entry) {\n    // Command not registered — present error\n    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.UNKNOWN_COMMAND, { command: candidate.command })));\n    return true;\n  }\n\n  const { meta, handler } = entry;\n\n  // Permission check\n  const permResult = checkCommandPermission(userId, meta.name);\n  if (!permResult.allowed) {\n    await logAuditEntry({\n      userId,\n      action: meta.name,\n      params: {},\n      result: 'denied',\n      reason: permResult.reason\n    });\n    await ctx.reply(`⛔ ${permResult.reason}`);\n    return true;\n  }\n\n  // Build synthetic parsed command\n  /** @type {import('./parser.js').ParsedCommand} */\n  const syntheticParsed = {\n    command: candidate.command,\n    subcommand: candidate.subcommand,\n    args: candidate.args || [],\n    options: {},\n    raw: ctx.message?.text || ''\n  };\n\n  const validation = validateCommand(syntheticParsed, meta);\n\n  if (!validation.valid) {\n    const errorMsg = formatValidationErrors(validation.errors, meta.usage);\n    await ctx.reply(errorMsg);\n    return true;\n  }\n\n  const handlerContext = {\n    ctx,\n    parsed: syntheticParsed,\n    meta,\n    params: validation.normalized || {},\n    userId,\n    userRole: getUserRole(userId),\n    sessionId,\n    requiresConfirmation: permResult.requiresConfirmation,\n    reply: async (text) => ctx.reply(text),\n    replyFile: async (content, filename) => {\n      await ctx.replyWithDocument({ source: Buffer.from(content), filename });\n    },\n    args: syntheticParsed.args || []\n  };\n\n  try {\n    await handler(handlerContext);\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    await ctx.reply(formatErrorResponse(formatError(ErrorCodes.INTERNAL_ERROR, { reason: message })));\n  }\n\n  return true;\n}\n\n/**\n * Check if user is authorized.\n * @param {number|string|undefined} userId - User ID\n * @returns {boolean} True if authorized\n */\nfunction isAuthorized(userId) {\n  return isAllowedUser(userId);\n}\n\n/**\n * Format error response for display.\n * @param {Object} error - Error object\n * @returns {string} Formatted error\n */\nfunction formatErrorResponse(error) {\n  const lines = [`❌ ${error.message}`];\n\n  if (error.suggestion) {\n    lines.push(`💡 ${error.suggestion}`);\n  }\n\n  if (error.usage) {\n    lines.push(`用法: ${error.usage}`);\n  }\n\n  return lines.join('\\n');\n}\n\n/**\n * Register all default commands.\n */\nexport function registerDefaultCommands() {\n  // Commands will be registered by individual handlers\n  // This is called during initialization\n}\n\n/**\n * Create middleware for command routing.\n * @returns {Function} Middleware function\n */\nexport function createCommandMiddleware() {\n  return async (ctx, next) => {\n    const handled = await routeCommand(ctx);\n    if (!handled) {\n      return next();\n    }\n  };\n}\n\n// Re-export for convenience\nexport { registerCommand, getCommand, getAliasMap };\n","numLines":372,"startLine":1,"totalLines":372}}}
