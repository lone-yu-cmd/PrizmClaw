ith `transform` and `filter`","-- [ ] Ensure `.btn:disabled` overrides hover (pointer-events: none)","+- [x] Add `transition` property to `.btn` base rule","+- [x] Add `.btn:hover` rule with `transform` and `filter`","+- [x] Ensure `.btn:disabled` overrides hover (pointer-events: none)"]}],"userModified":false,"replaceAll":false}}
