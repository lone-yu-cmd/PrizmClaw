{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_015xD51uPyATJa6K752GNHvD","type":"tool_result","content":"     1→const STORAGE_KEY = 'prizmclaw-web-session';\n     2→\n     3→const state = {\n     4→  baseUrl: '',\n     5→  sessionId: '',\n     6→  busy: false,\n     7→  eventSource: null,\n     8→  streamingMessageBody: null,\n     9→  streamedText: '',\n    10→  availableCommands: [],\n    11→  commandDropdownVisible: false\n    12→};\n    13→\n    14→const els = {\n    15→  status: document.getElementById('status'),\n    16→  baseUrlInput: document.getElementById('baseUrlInput'),\n    17→  sessionIdInput: document.getElementById('sessionIdInput'),\n    18→  chatMessages: document.getElementById('chatMessages'),\n    19→  chatForm: document.getElementById('chatForm'),\n    20→  chatInput: document.getElementById('chatInput'),\n    21→  sendChatBtn: document.getElementById('sendChatBtn'),\n    22→  clearChatBtn: document.getElementById('clearChatBtn'),\n    23→  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n    24→  screenshotImage: document.getElementById('screenshotImage'),\n    25→  screenshotMeta: document.getElementById('screenshotMeta'),\n    26→  execForm: document.getElementById('execForm'),\n    27→  execInput: document.getElementById('execInput'),\n    28→  runExecBtn: document.getElementById('runExecBtn'),\n    29→  exitCodeOutput: document.getElementById('exitCodeOutput'),\n    30→  stdoutOutput: document.getElementById('stdoutOutput'),\n    31→  stderrOutput: document.getElementById('stderrOutput')\n    32→};\n    33→\n    34→function randomSessionId() {\n    35→  const rand = Math.random().toString(36).slice(2, 10);\n    36→  return `web-${Date.now()}-${rand}`;\n    37→}\n    38→\n    39→function setStatus(text, state) {\n    40→  els.status.textContent = text;\n    41→  els.status.classList.remove('connected', 'error');\n    42→  if (state) els.status.classList.add(state);\n    43→}\n    44→\n    45→function setBusy(busy, text) {\n    46→  state.busy = busy;\n    47→  els.sendChatBtn.disabled = busy;\n    48→  els.takeScreenshotBtn.disabled = busy;\n    49→  els.runExecBtn.disabled = busy;\n    50→  setStatus(text);\n    51→}\n    52→\n    53→function saveSessionConfig() {\n    54→  localStorage.setItem(\n    55→    STORAGE_KEY,\n    56→    JSON.stringify({\n    57→      baseUrl: state.baseUrl,\n    58→      sessionId: state.sessionId\n    59→    })\n    60→  );\n    61→}\n    62→\n    63→function loadSessionConfig() {\n    64→  try {\n    65→    const raw = localStorage.getItem(STORAGE_KEY);\n    66→    if (!raw) {\n    67→      return;\n    68→    }\n    69→\n    70→    const parsed = JSON.parse(raw);\n    71→    if (typeof parsed.baseUrl === 'string') {\n    72→      state.baseUrl = parsed.baseUrl;\n    73→    }\n    74→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n    75→      state.sessionId = parsed.sessionId;\n    76→    }\n    77→  } catch {\n    78→    // ignore\n    79→  }\n    80→}\n    81→\n    82→function createMessageElement(role, text, isError = false, isHtml = false) {\n    83→  const item = document.createElement('div');\n    84→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n    85→\n    86→  const roleEl = document.createElement('span');\n    87→  roleEl.className = 'role';\n    88→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n    89→\n    90→  const body = document.createElement('div');\n    91→  body.className = 'body';\n    92→  if (isHtml) {\n    93→    body.innerHTML = text;\n    94→  } else {\n    95→    body.textContent = text;\n    96→  }\n    97→\n    98→  item.append(roleEl, body);\n    99→  return { item, body };\n   100→}\n   101→\n   102→function appendMessage(role, text, isError = false, isHtml = false) {\n   103→  const node = createMessageElement(role, text, isError, isHtml);\n   104→  els.chatMessages.appendChild(node.item);\n   105→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   106→  return node;\n   107→}\n   108→\n   109→function getApiUrl(path) {\n   110→  const base = state.baseUrl.trim();\n   111→  if (!base) {\n   112→    return path;\n   113→  }\n   114→  return `${base.replace(/\\/$/, '')}${path}`;\n   115→}\n   116→\n   117→function getEventsUrl() {\n   118→  const query = new URLSearchParams({\n   119→    channel: 'web',\n   120→    sessionId: state.sessionId\n   121→  }).toString();\n   122→\n   123→  return `${getApiUrl('/api/events')}?${query}`;\n   124→}\n   125→\n   126→function closeRealtime() {\n   127→  if (state.eventSource) {\n   128→    state.eventSource.close();\n   129→    state.eventSource = null;\n   130→  }\n   131→}\n   132→\n   133→// ── Command Autocomplete ──────────────────────────────────────────────────────\n   134→\n   135→let commandDropdown = null;\n   136→\n   137→function createCommandDropdown() {\n   138→  commandDropdown = document.createElement('div');\n   139→  commandDropdown.className = 'command-dropdown';\n   140→  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n   141→  els.chatForm.style.position = 'relative';\n   142→  els.chatForm.appendChild(commandDropdown);\n   143→}\n   144→\n   145→function showCommandDropdown(commands) {\n   146→  if (!commandDropdown) createCommandDropdown();\n   147→  commandDropdown.innerHTML = '';\n   148→\n   149→  if (commands.length === 0) {\n   150→    commandDropdown.style.display = 'none';\n   151→    state.commandDropdownVisible = false;\n   152→    return;\n   153→  }\n   154→\n   155→  commands.forEach((cmd) => {\n   156→    const item = document.createElement('div');\n   157→    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n   158→    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n   159→    item.addEventListener('mousedown', (e) => {\n   160→      e.preventDefault();\n   161→      els.chatInput.value = `/${cmd.name} `;\n   162→      hideCommandDropdown();\n   163→      els.chatInput.focus();\n   164→    });\n   165→    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n   166→    item.addEventListener('mouseout', () => { item.style.background = ''; });\n   167→    commandDropdown.appendChild(item);\n   168→  });\n   169→\n   170→  commandDropdown.style.display = 'block';\n   171→  state.commandDropdownVisible = true;\n   172→}\n   173→\n   174→function hideCommandDropdown() {\n   175→  if (commandDropdown) commandDropdown.style.display = 'none';\n   176→  state.commandDropdownVisible = false;\n   177→}\n   178→\n   179→function filterCommands(prefix) {\n   180→  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n   181→  return state.availableCommands.filter((cmd) => {\n   182→    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n   183→  });\n   184→}\n   185→\n   186→async function loadAvailableCommands() {\n   187→  try {\n   188→    const response = await fetch(getApiUrl('/api/commands'));\n   189→    const data = await response.json();\n   190→    if (data.ok && Array.isArray(data.commands)) {\n   191→      state.availableCommands = data.commands;\n   192→    }\n   193→  } catch {\n   194→    // Non-critical — autocomplete just won't work\n   195→  }\n   196→}\n   197→\n   198→function connectRealtime() {\n   199→  closeRealtime();\n   200→\n   201→  if (typeof EventSource === 'undefined') {\n   202→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   203→    return;\n   204→  }\n   205→\n   206→  const es = new EventSource(getEventsUrl());\n   207→  state.eventSource = es;\n   208→\n   209→  es.addEventListener('connected', () => {\n   210→    setStatus('实时通道已连接', 'connected');\n   211→  });\n   212→\n   213→  es.addEventListener('status', (event) => {\n   214→    const payload = JSON.parse(event.data);\n   215→    if (payload.stage === 'running') {\n   216→      setStatus('助手处理中...');\n   217→      return;\n   218→    }\n   219→\n   220→    if (payload.stage === 'accepted') {\n   221→      setStatus('已接收请求');\n   222→      return;\n   223→    }\n   224→\n   225→    setStatus('实时通道在线', 'connected');\n   226→  });\n   227→\n   228→  es.addEventListener('assistant_chunk', (event) => {\n   229→    const payload = JSON.parse(event.data);\n   230→\n   231→    if (!state.streamingMessageBody) {\n   232→      const node = appendMessage('assistant', '');\n   233→      state.streamingMessageBody = node.body;\n   234→      state.streamedText = '';\n   235→    }\n   236→\n   237→    state.streamedText += payload.text ?? '';\n   238→    state.streamingMessageBody.textContent = state.streamedText;\n   239→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   240→  });\n   241→\n   242→  es.addEventListener('assistant_done', (event) => {\n   243→    const payload = JSON.parse(event.data);\n   244→    if (state.streamingMessageBody) {\n   245→      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n   246→    } else if (payload.isCommand) {\n   247→      // Command result came via SSE (not via HTTP response) — render as HTML\n   248→      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n   249→    }\n   250→    setStatus('就绪');\n   251→  });\n   252→\n   253→  es.onerror = () => {\n   254→    setStatus('实时通道重连中...', 'error');\n   255→  };\n   256→}\n   257→\n   258→async function callJson(path, payload) {\n   259→  const response = await fetch(getApiUrl(path), {\n   260→    method: 'POST',\n   261→    headers: { 'Content-Type': 'application/json' },\n   262→    body: JSON.stringify(payload)\n   263→  });\n   264→\n   265→  const data = await response.json();\n   266→  if (!response.ok || !data.ok) {\n   267→    throw new Error(data.error || `请求失败: ${response.status}`);\n   268→  }\n   269→  return data;\n   270→}\n   271→\n   272→function normalizeZeroHost() {\n   273→  if (window.location.hostname !== '0.0.0.0') {\n   274→    return false;\n   275→  }\n   276→\n   277→  const nextUrl = new URL(window.location.href);\n   278→  nextUrl.hostname = '127.0.0.1';\n   279→  window.location.replace(nextUrl.toString());\n   280→  return true;\n   281→}\n   282→\n   283→function init() {\n   284→  if (normalizeZeroHost()) {\n   285→    return;\n   286→  }\n   287→\n   288→  loadSessionConfig();\n   289→\n   290→  if (!state.sessionId) {\n   291→    state.sessionId = randomSessionId();\n   292→  }\n   293→\n   294→  els.baseUrlInput.value = state.baseUrl;\n   295→  els.sessionIdInput.value = state.sessionId;\n   296→\n   297→  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n   298→  connectRealtime();\n   299→  loadAvailableCommands();\n   300→}\n   301→\n   302→els.baseUrlInput.addEventListener('change', () => {\n   303→  state.baseUrl = els.baseUrlInput.value.trim();\n   304→  saveSessionConfig();\n   305→  connectRealtime();\n   306→});\n   307→\n   308→els.sessionIdInput.addEventListener('change', () => {\n   309→  const value = els.sessionIdInput.value.trim();\n   310→  state.sessionId = value || randomSessionId();\n   311→  els.sessionIdInput.value = state.sessionId;\n   312→  saveSessionConfig();\n   313→  connectRealtime();\n   314→});\n   315→\n   316→els.clearChatBtn.addEventListener('click', () => {\n   317→  els.chatMessages.innerHTML = '';\n   318→  appendMessage('system', '界面消息已清空。');\n   319→});\n   320→\n   321→els.chatForm.addEventListener('submit', async (event) => {\n   322→  event.preventDefault();\n   323→  if (state.busy) return;\n   324→\n   325→  const message = els.chatInput.value.trim();\n   326→  if (!message) return;\n   327→\n   328→  appendMessage('user', message);\n   329→  els.chatInput.value = '';\n   330→\n   331→  state.streamingMessageBody = null;\n   332→  state.streamedText = '';\n   333→\n   334→  try {\n   335→    setBusy(true, '聊天处理中...');\n   336→    const data = await callJson('/api/chat', {\n   337→      channel: 'web',\n   338→      sessionId: state.sessionId,\n   339→      message\n   340→    });\n   341→\n   342→    if (!state.streamedText) {\n   343→      const isHtml = data.isCommand === true;\n   344→      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n   345→    }\n   346→  } catch (error) {\n   347→    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n   348→  } finally {\n   349→    state.streamingMessageBody = null;\n   350→    setBusy(false, '就绪');\n   351→  }\n   352→});\n   353→\n   354→els.chatInput.addEventListener('keydown', (event) => {\n   355→  if (event.key === 'Escape' && state.commandDropdownVisible) {\n   356→    hideCommandDropdown();\n   357→    return;\n   358→  }\n   359→  if (event.key === 'Enter' && !event.shiftKey) {\n   360→    event.preventDefault();\n   361→    hideCommandDropdown();\n   362→    els.chatForm.requestSubmit();\n   363→  }\n   364→});\n   365→\n   366→els.chatInput.addEventListener('input', () => {\n   367→  const value = els.chatInput.value;\n   368→  const firstWord = value.split(/\\s/)[0];\n   369→  if (firstWord.startsWith('/') && value === firstWord) {\n   370→    // User is still typing the command name (no space yet)\n   371→    const matches = filterCommands(firstWord);\n   372→    showCommandDropdown(matches);\n   373→  } else {\n   374→    hideCommandDropdown();\n   375→  }\n   376→});\n   377→\n   378→els.chatInput.addEventListener('blur', () => {\n   379→  // Delay hide to allow mousedown on dropdown item to fire first\n   380→  setTimeout(hideCommandDropdown, 150);\n   381→});\n   382→\n   383→els.takeScreenshotBtn.addEventListener('click', async () => {\n   384→  if (state.busy) return;\n   385→\n   386→  try {\n   387→    setBusy(true, '正在获取截图...');\n   388→    const data = await callJson('/api/screenshot', {\n   389→      channel: 'web',\n   390→      sessionId: state.sessionId\n   391→    });\n   392→\n   393→    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n   394→    els.screenshotImage.classList.remove('hidden');\n   395→    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n   396→  } catch (error) {\n   397→    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n   398→  } finally {\n   399→    setBusy(false, '就绪');\n   400→  }\n   401→});\n   402→\n   403→els.execForm.addEventListener('submit', async (event) => {\n   404→  event.preventDefault();\n   405→  if (state.busy) return;\n   406→\n   407→  const command = els.execInput.value.trim();\n   408→  if (!command) return;\n   409→\n   410→  try {\n   411→    setBusy(true, '正在执行命令...');\n   412→    const data = await callJson('/api/system/exec', {\n   413→      channel: 'web',\n   414→      sessionId: state.sessionId,\n   415→      command\n   416→    });\n   417→\n   418→    els.exitCodeOutput.textContent = String(data.exitCode);\n   419→    els.stdoutOutput.textContent = data.stdout || '(empty)';\n   420→    els.stderrOutput.textContent = data.stderr || '(empty)';\n   421→  } catch (error) {\n   422→    const message = error instanceof Error ? error.message : String(error);\n   423→    els.exitCodeOutput.textContent = 'error';\n   424→    els.stdoutOutput.textContent = '';\n   425→    els.stderrOutput.textContent = message;\n   426→  } finally {\n   427→    setBusy(false, '就绪');\n   428→  }\n   429→});\n   430→\n   431→window.addEventListener('beforeunload', () => {\n   432→  closeRealtime();\n   433→});\n   434→\n   435→init();\n   436→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"98537608-2ff0-4143-81a2-60a093ccd611","uuid":"e750af14-f758-44cb-9184-2f41192ff696","timestamp":"2026-03-22T17:31:15.661Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js","content":"const STORAGE_KEY = 'prizmclaw-web-session';\n\nconst state = {\n  baseUrl: '',\n  sessionId: '',\n  busy: false,\n  eventSource: null,\n  streamingMessageBody: null,\n  streamedText: '',\n  availableCommands: [],\n  commandDropdownVisible: false\n};\n\nconst els = {\n  status: document.getElementById('status'),\n  baseUrlInput: document.getElementById('baseUrlInput'),\n  sessionIdInput: document.getElementById('sessionIdInput'),\n  chatMessages: document.getElementById('chatMessages'),\n  chatForm: document.getElementById('chatForm'),\n  chatInput: document.getElementById('chatInput'),\n  sendChatBtn: document.getElementById('sendChatBtn'),\n  clearChatBtn: document.getElementById('clearChatBtn'),\n  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n  screenshotImage: document.getElementById('screenshotImage'),\n  screenshotMeta: document.getElementById('screenshotMeta'),\n  execForm: document.getElementById('execForm'),\n  execInput: document.getElementById('execInput'),\n  runExecBtn: document.getElementById('runExecBtn'),\n  exitCodeOutput: document.getElementById('exitCodeOutput'),\n  stdoutOutput: document.getElementById('stdoutOutput'),\n  stderrOutput: document.getElementById('stderrOutput')\n};\n\nfunction randomSessionId() {\n  const rand = Math.random().toString(36).slice(2, 10);\n  return `web-${Date.now()}-${rand}`;\n}\n\nfunction setStatus(text, state) {\n  els.status.textContent = text;\n  els.status.classList.remove('connected', 'error');\n  if (state) els.status.classList.add(state);\n}\n\nfunction setBusy(busy, text) {\n  state.busy = busy;\n  els.sendChatBtn.disabled = busy;\n  els.takeScreenshotBtn.disabled = busy;\n  els.runExecBtn.disabled = busy;\n  setStatus(text);\n}\n\nfunction saveSessionConfig() {\n  localStorage.setItem(\n    STORAGE_KEY,\n    JSON.stringify({\n      baseUrl: state.baseUrl,\n      sessionId: state.sessionId\n    })\n  );\n}\n\nfunction loadSessionConfig() {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) {\n      return;\n    }\n\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.baseUrl === 'string') {\n      state.baseUrl = parsed.baseUrl;\n    }\n    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n      state.sessionId = parsed.sessionId;\n    }\n  } catch {\n    // ignore\n  }\n}\n\nfunction createMessageElement(role, text, isError = false, isHtml = false) {\n  const item = document.createElement('div');\n  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n\n  const roleEl = document.createElement('span');\n  roleEl.className = 'role';\n  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n\n  const body = document.createElement('div');\n  body.className = 'body';\n  if (isHtml) {\n    body.innerHTML = text;\n  } else {\n    body.textContent = text;\n  }\n\n  item.append(roleEl, body);\n  return { item, body };\n}\n\nfunction appendMessage(role, text, isError = false, isHtml = false) {\n  const node = createMessageElement(role, text, isError, isHtml);\n  els.chatMessages.appendChild(node.item);\n  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  return node;\n}\n\nfunction getApiUrl(path) {\n  const base = state.baseUrl.trim();\n  if (!base) {\n    return path;\n  }\n  return `${base.replace(/\\/$/, '')}${path}`;\n}\n\nfunction getEventsUrl() {\n  const query = new URLSearchParams({\n    channel: 'web',\n    sessionId: state.sessionId\n  }).toString();\n\n  return `${getApiUrl('/api/events')}?${query}`;\n}\n\nfunction closeRealtime() {\n  if (state.eventSource) {\n    state.eventSource.close();\n    state.eventSource = null;\n  }\n}\n\n// ── Command Autocomplete ──────────────────────────────────────────────────────\n\nlet commandDropdown = null;\n\nfunction createCommandDropdown() {\n  commandDropdown = document.createElement('div');\n  commandDropdown.className = 'command-dropdown';\n  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n  els.chatForm.style.position = 'relative';\n  els.chatForm.appendChild(commandDropdown);\n}\n\nfunction showCommandDropdown(commands) {\n  if (!commandDropdown) createCommandDropdown();\n  commandDropdown.innerHTML = '';\n\n  if (commands.length === 0) {\n    commandDropdown.style.display = 'none';\n    state.commandDropdownVisible = false;\n    return;\n  }\n\n  commands.forEach((cmd) => {\n    const item = document.createElement('div');\n    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n    item.addEventListener('mousedown', (e) => {\n      e.preventDefault();\n      els.chatInput.value = `/${cmd.name} `;\n      hideCommandDropdown();\n      els.chatInput.focus();\n    });\n    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n    item.addEventListener('mouseout', () => { item.style.background = ''; });\n    commandDropdown.appendChild(item);\n  });\n\n  commandDropdown.style.display = 'block';\n  state.commandDropdownVisible = true;\n}\n\nfunction hideCommandDropdown() {\n  if (commandDropdown) commandDropdown.style.display = 'none';\n  state.commandDropdownVisible = false;\n}\n\nfunction filterCommands(prefix) {\n  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n  return state.availableCommands.filter((cmd) => {\n    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n  });\n}\n\nasync function loadAvailableCommands() {\n  try {\n    const response = await fetch(getApiUrl('/api/commands'));\n    const data = await response.json();\n    if (data.ok && Array.isArray(data.commands)) {\n      state.availableCommands = data.commands;\n    }\n  } catch {\n    // Non-critical — autocomplete just won't work\n  }\n}\n\nfunction connectRealtime() {\n  closeRealtime();\n\n  if (typeof EventSource === 'undefined') {\n    setStatus('当前浏览器不支持实时推送（EventSource）');\n    return;\n  }\n\n  const es = new EventSource(getEventsUrl());\n  state.eventSource = es;\n\n  es.addEventListener('connected', () => {\n    setStatus('实时通道已连接', 'connected');\n  });\n\n  es.addEventListener('status', (event) => {\n    const payload = JSON.parse(event.data);\n    if (payload.stage === 'running') {\n      setStatus('助手处理中...');\n      return;\n    }\n\n    if (payload.stage === 'accepted') {\n      setStatus('已接收请求');\n      return;\n    }\n\n    setStatus('实时通道在线', 'connected');\n  });\n\n  es.addEventListener('assistant_chunk', (event) => {\n    const payload = JSON.parse(event.data);\n\n    if (!state.streamingMessageBody) {\n      const node = appendMessage('assistant', '');\n      state.streamingMessageBody = node.body;\n      state.streamedText = '';\n    }\n\n    state.streamedText += payload.text ?? '';\n    state.streamingMessageBody.textContent = state.streamedText;\n    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  });\n\n  es.addEventListener('assistant_done', (event) => {\n    const payload = JSON.parse(event.data);\n    if (state.streamingMessageBody) {\n      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n    } else if (payload.isCommand) {\n      // Command result came via SSE (not via HTTP response) — render as HTML\n      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n    }\n    setStatus('就绪');\n  });\n\n  es.onerror = () => {\n    setStatus('实时通道重连中...', 'error');\n  };\n}\n\nasync function callJson(path, payload) {\n  const response = await fetch(getApiUrl(path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n\n  const data = await response.json();\n  if (!response.ok || !data.ok) {\n    throw new Error(data.error || `请求失败: ${response.status}`);\n  }\n  return data;\n}\n\nfunction normalizeZeroHost() {\n  if (window.location.hostname !== '0.0.0.0') {\n    return false;\n  }\n\n  const nextUrl = new URL(window.location.href);\n  nextUrl.hostname = '127.0.0.1';\n  window.location.replace(nextUrl.toString());\n  return true;\n}\n\nfunction init() {\n  if (normalizeZeroHost()) {\n    return;\n  }\n\n  loadSessionConfig();\n\n  if (!state.sessionId) {\n    state.sessionId = randomSessionId();\n  }\n\n  els.baseUrlInput.value = state.baseUrl;\n  els.sessionIdInput.value = state.sessionId;\n\n  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n  connectRealtime();\n  loadAvailableCommands();\n}\n\nels.baseUrlInput.addEventListener('change', () => {\n  state.baseUrl = els.baseUrlInput.value.trim();\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.sessionIdInput.addEventListener('change', () => {\n  const value = els.sessionIdInput.value.trim();\n  state.sessionId = value || randomSessionId();\n  els.sessionIdInput.value = state.sessionId;\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.clearChatBtn.addEventListener('click', () => {\n  els.chatMessages.innerHTML = '';\n  appendMessage('system', '界面消息已清空。');\n});\n\nels.chatForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const message = els.chatInput.value.trim();\n  if (!message) return;\n\n  appendMessage('user', message);\n  els.chatInput.value = '';\n\n  state.streamingMessageBody = null;\n  state.streamedText = '';\n\n  try {\n    setBusy(true, '聊天处理中...');\n    const data = await callJson('/api/chat', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      message\n    });\n\n    if (!state.streamedText) {\n      const isHtml = data.isCommand === true;\n      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n    }\n  } catch (error) {\n    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n  } finally {\n    state.streamingMessageBody = null;\n    setBusy(false, '就绪');\n  }\n});\n\nels.chatInput.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && state.commandDropdownVisible) {\n    hideCommandDropdown();\n    return;\n  }\n  if (event.key === 'Enter' && !event.shiftKey) {\n    event.preventDefault();\n    hideCommandDropdown();\n    els.chatForm.requestSubmit();\n  }\n});\n\nels.chatInput.addEventListener('input', () => {\n  const value = els.chatInput.value;\n  const firstWord = value.split(/\\s/)[0];\n  if (firstWord.startsWith('/') && value === firstWord) {\n    // User is still typing the command name (no space yet)\n    const matches = filterCommands(firstWord);\n    showCommandDropdown(matches);\n  } else {\n    hideCommandDropdown();\n  }\n});\n\nels.chatInput.addEventListener('blur', () => {\n  // Delay hide to allow mousedown on dropdown item to fire first\n  setTimeout(hideCommandDropdown, 150);\n});\n\nels.takeScreenshotBtn.addEventListener('click', async () => {\n  if (state.busy) return;\n\n  try {\n    setBusy(true, '正在获取截图...');\n    const data = await callJson('/api/screenshot', {\n      channel: 'web',\n      sessionId: state.sessionId\n    });\n\n    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n    els.screenshotImage.classList.remove('hidden');\n    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  try {\n    setBusy(true, '正在执行命令...');\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    els.exitCodeOutput.textContent = 'error';\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ninit();\n","numLines":436,"startLine":1,"totalLines":436}}}
