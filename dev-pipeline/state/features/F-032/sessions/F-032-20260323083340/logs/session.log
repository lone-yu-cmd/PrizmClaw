\n}\n\n.subtitle {\n  margin-top: 6px;\n  color: var(--muted);\n}\n\n.status {\n  border: 1px solid var(--line);\n  background: var(--panel);\n  border-radius: 999px;\n  padding: 6px 12px;\n  font-size: 13px;\n  color: var(--muted);\n}\n\n.status.connected {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.status.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.08), 0 1px 2px rgba(31, 38, 51, 0.04);\n}\n\n.sub-panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 1px 4px rgba(31, 38, 51, 0.06);\n}\n\n.form-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 12px;\n}\n\nlabel {\n  display: grid;\n  gap: 6px;\n  font-size: 14px;\n}\n\ninput,\ntextarea,\nbutton {\n  font: inherit;\n}\n\ninput,\ntextarea {\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 9px 10px;\n  width: 100%;\n  color: inherit;\n  background: #fff;\n}\n\ntextarea {\n  resize: vertical;\n  min-height: 82px;\n}\n\ninput:focus,\ntextarea:focus {\n  outline: none;\n  border-color: var(--primary);\n  box-shadow: 0 0 0 3px rgba(58, 111, 247, 0.18);\n}\n\n.btn {\n  border: 0;\n  border-radius: 10px;\n  padding: 9px 14px;\n  cursor: pointer;\n  transition: transform 0.15s ease, filter 0.15s ease;\n}\n\n.btn:hover {\n  transform: translateY(-1px);\n  filter: brightness(1.08);\n}\n\n.btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n  pointer-events: none;\n}\n\n.btn.primary {\n  background: var(--primary);\n  color: var(--primary-contrast);\n}\n\n.btn.warning {\n  background: var(--warning);\n  color: #fff;\n}\n\n.btn.ghost {\n  border: 1px solid var(--line);\n  background: transparent;\n}\n\n.dashboard-grid {\n  display: grid;\n  grid-template-columns: 2fr 1fr;\n  gap: 16px;\n}\n\n.chat-panel {\n  display: grid;\n  gap: 12px;\n}\n\n.panel-head {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 10px;\n}\n\n.chat-messages {\n  border: 1px solid var(--line);\n  border-radius: 12px;\n  padding: 10px;\n  min-height: 360px;\n  max-height: 62vh;\n  overflow: auto;\n  display: grid;\n  gap: 10px;\n  background: #fff;\n}\n\n@keyframes fade-in {\n  from {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.message {\n  padding: 10px;\n  border-radius: 10px;\n  line-height: 1.5;\n  white-space: pre-wrap;\n  word-break: break-word;\n  animation: fade-in 0.25s ease-out both;\n}\n\n.message.user {\n  background: var(--chat-user);\n}\n\n.message.assistant {\n  background: var(--chat-assistant);\n}\n\n.message.error {\n  border: 1px solid #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.message .role {\n  display: block;\n  font-size: 12px;\n  color: var(--muted);\n  margin-bottom: 4px;\n}\n\n.chat-form {\n  display: grid;\n  gap: 8px;\n}\n\n.char-counter {\n  font-size: 12px;\n  color: var(--muted);\n  text-align: right;\n  margin-top: -4px;\n}\n\n.char-counter.warning {\n  color: var(--warning);\n}\n\n.side-panel {\n  display: grid;\n  gap: 14px;\n  align-content: start;\n}\n\n.hint {\n  font-size: 13px;\n  color: var(--muted);\n  margin: 6px 0 10px;\n}\n\n.output-box {\n  margin: 0;\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 10px;\n  min-height: 44px;\n  background: #fff;\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-x: auto;\n}\n\n.output-box.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.output-box.exit-error {\n  border-color: #fde8bb;\n  background: #fffbf0;\n  color: var(--warning);\n}\n\n.screenshot-image {\n  width: 100%;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  margin-top: 10px;\n  background: #fff;\n}\n\n.exec-form {\n  display: grid;\n  grid-template-columns: 1fr auto;\n  gap: 8px;\n  margin-bottom: 10px;\n}\n\n.exec-result {\n  display: grid;\n  gap: 8px;\n}\n\n.hidden {\n  display: none;\n}\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n@media (max-width: 900px) {\n  .dashboard-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .form-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 600px) {\n  .app-shell {\n    padding: 12px;\n    gap: 10px;\n  }\n\n  .app-header {\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n\n  .app-header h1 {\n    font-size: 1.1rem;\n  }\n\n  .app-header .subtitle {\n    font-size: 12px;\n  }\n\n  .status {\n    max-width: 140px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .panel,\n  .sub-panel {\n    padding: 10px;\n  }\n\n  .chat-messages {\n    max-height: 50vh;\n  }\n\n  .exec-form {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg: #111827;\n    --panel: #1f2937;\n    --line: #374151;\n    --text: #f9fafb;\n    --muted: #9ca3af;\n    --primary: #5b8df8;\n    --primary-contrast: #ffffff;\n    --warning: #f59e0b;\n    --danger: #f87171;\n    --chat-user: #1e3a5f;\n    --chat-assistant: #263144;\n  }\n\n  input,\n  textarea {\n    background: var(--panel);\n    color: var(--text);\n  }\n\n  .chat-messages {\n    background: var(--panel);\n  }\n\n  .output-box {\n    background: var(--panel);\n  }\n\n  .screenshot-image {\n    background: var(--panel);\n  }\n\n  .status.connected {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .status.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .message.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.exit-error {\n    border-color: #78350f;\n    background: #431407;\n    color: var(--warning);\n  }\n}\n","numLines":445,"startLine":1,"totalLines":445}}}
{"type":"assistant","message":{"content":[{"id":"toolu_vrtx_01M8ibpNCDVeZc7ZzjKiinH3","input":{"file_path":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js"},"name":"Read","type":"tool_use"}],"id":"req_vrtx_011CZK5AUu8C8tozAcY9hvWy","model":"claude-sonnet-4-6","role":"assistant","stop_reason":null,"stop_sequence":null,"type":"message","usage":{"input_tokens":7170,"output_tokens":18,"cache_read_input_tokens":36962},"context_management":null},"parent_tool_use_id":null,"session_id":"85c34a08-b147-4c48-a390-21615341a959","uuid":"20936282-b7d7-486e-b0e8-9326c8ba0006"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01M8ibpNCDVeZc7ZzjKiinH3","type":"tool_result","content":"     1→const STORAGE_KEY = 'prizmclaw-web-session';\n     2→\n     3→const state = {\n     4→  baseUrl: '',\n     5→  sessionId: '',\n     6→  busy: false,\n     7→  eventSource: null,\n     8→  streamingMessageBody: null,\n     9→  streamedText: '',\n    10→  availableCommands: [],\n    11→  commandDropdownVisible: false\n    12→};\n    13→\n    14→const els = {\n    15→  status: document.getElementById('status'),\n    16→  baseUrlInput: document.getElementById('baseUrlInput'),\n    17→  sessionIdInput: document.getElementById('sessionIdInput'),\n    18→  chatMessages: document.getElementById('chatMessages'),\n    19→  chatForm: document.getElementById('chatForm'),\n    20→  chatInput: document.getElementById('chatInput'),\n    21→  charCounter: document.getElementById('charCounter'),\n    22→  sendChatBtn: document.getElementById('sendChatBtn'),\n    23→  clearChatBtn: document.getElementById('clearChatBtn'),\n    24→  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n    25→  screenshotImage: document.getElementById('screenshotImage'),\n    26→  screenshotMeta: document.getElementById('screenshotMeta'),\n    27→  execForm: document.getElementById('execForm'),\n    28→  execInput: document.getElementById('execInput'),\n    29→  runExecBtn: document.getElementById('runExecBtn'),\n    30→  exitCodeOutput: document.getElementById('exitCodeOutput'),\n    31→  stdoutOutput: document.getElementById('stdoutOutput'),\n    32→  stderrOutput: document.getElementById('stderrOutput')\n    33→};\n    34→\n    35→function randomSessionId() {\n    36→  const rand = Math.random().toString(36).slice(2, 10);\n    37→  return `web-${Date.now()}-${rand}`;\n    38→}\n    39→\n    40→function setStatus(text, state) {\n    41→  els.status.textContent = text;\n    42→  els.status.classList.remove('connected', 'error');\n    43→  if (state) els.status.classList.add(state);\n    44→}\n    45→\n    46→const CHAR_LIMIT = 8000;\n    47→const CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n    48→\n    49→function updateCharCounter() {\n    50→  const len = els.chatInput.value.length;\n    51→  els.charCounter.textContent = len;\n    52→  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n    53→}\n    54→\n    55→function setBusy(busy, text) {\n    56→  state.busy = busy;\n    57→  els.sendChatBtn.disabled = busy;\n    58→  els.takeScreenshotBtn.disabled = busy;\n    59→  els.runExecBtn.disabled = busy;\n    60→  setStatus(text);\n    61→}\n    62→\n    63→function saveSessionConfig() {\n    64→  localStorage.setItem(\n    65→    STORAGE_KEY,\n    66→    JSON.stringify({\n    67→      baseUrl: state.baseUrl,\n    68→      sessionId: state.sessionId\n    69→    })\n    70→  );\n    71→}\n    72→\n    73→function loadSessionConfig() {\n    74→  try {\n    75→    const raw = localStorage.getItem(STORAGE_KEY);\n    76→    if (!raw) {\n    77→      return;\n    78→    }\n    79→\n    80→    const parsed = JSON.parse(raw);\n    81→    if (typeof parsed.baseUrl === 'string') {\n    82→      state.baseUrl = parsed.baseUrl;\n    83→    }\n    84→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n    85→      state.sessionId = parsed.sessionId;\n    86→    }\n    87→  } catch {\n    88→    // ignore\n    89→  }\n    90→}\n    91→\n    92→function createMessageElement(role, text, isError = false, isHtml = false) {\n    93→  const item = document.createElement('div');\n    94→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n    95→\n    96→  const roleEl = document.createElement('span');\n    97→  roleEl.className = 'role';\n    98→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n    99→\n   100→  const body = document.createElement('div');\n   101→  body.className = 'body';\n   102→  if (isHtml) {\n   103→    body.innerHTML = text;\n   104→  } else {\n   105→    body.textContent = text;\n   106→  }\n   107→\n   108→  item.append(roleEl, body);\n   109→  return { item, body };\n   110→}\n   111→\n   112→function appendMessage(role, text, isError = false, isHtml = false) {\n   113→  const node = createMessageElement(role, text, isError, isHtml);\n   114→  els.chatMessages.appendChild(node.item);\n   115→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   116→  return node;\n   117→}\n   118→\n   119→function getApiUrl(path) {\n   120→  const base = state.baseUrl.trim();\n   121→  if (!base) {\n   122→    return path;\n   123→  }\n   124→  return `${base.replace(/\\/$/, '')}${path}`;\n   125→}\n   126→\n   127→function getEventsUrl() {\n   128→  const query = new URLSearchParams({\n   129→    channel: 'web',\n   130→    sessionId: state.sessionId\n   131→  }).toString();\n   132→\n   133→  return `${getApiUrl('/api/events')}?${query}`;\n   134→}\n   135→\n   136→function closeRealtime() {\n   137→  if (state.eventSource) {\n   138→    state.eventSource.close();\n   139→    state.eventSource = null;\n   140→  }\n   141→}\n   142→\n   143→// ── Command Autocomplete ──────────────────────────────────────────────────────\n   144→\n   145→let commandDropdown = null;\n   146→\n   147→function createCommandDropdown() {\n   148→  commandDropdown = document.createElement('div');\n   149→  commandDropdown.className = 'command-dropdown';\n   150→  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n   151→  els.chatForm.style.position = 'relative';\n   152→  els.chatForm.appendChild(commandDropdown);\n   153→}\n   154→\n   155→function showCommandDropdown(commands) {\n   156→  if (!commandDropdown) createCommandDropdown();\n   157→  commandDropdown.innerHTML = '';\n   158→\n   159→  if (commands.length === 0) {\n   160→    commandDropdown.style.display = 'none';\n   161→    state.commandDropdownVisible = false;\n   162→    return;\n   163→  }\n   164→\n   165→  commands.forEach((cmd) => {\n   166→    const item = document.createElement('div');\n   167→    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n   168→    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n   169→    item.addEventListener('mousedown', (e) => {\n   170→      e.preventDefault();\n   171→      els.chatInput.value = `/${cmd.name} `;\n   172→      hideCommandDropdown();\n   173→      els.chatInput.focus();\n   174→    });\n   175→    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n   176→    item.addEventListener('mouseout', () => { item.style.background = ''; });\n   177→    commandDropdown.appendChild(item);\n   178→  });\n   179→\n   180→  commandDropdown.style.display = 'block';\n   181→  state.commandDropdownVisible = true;\n   182→}\n   183→\n   184→function hideCommandDropdown() {\n   185→  if (commandDropdown) commandDropdown.style.display = 'none';\n   186→  state.commandDropdownVisible = false;\n   187→}\n   188→\n   189→function filterCommands(prefix) {\n   190→  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n   191→  return state.availableCommands.filter((cmd) => {\n   192→    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n   193→  });\n   194→}\n   195→\n   196→async function loadAvailableCommands() {\n   197→  try {\n   198→    const response = await fetch(getApiUrl('/api/commands'));\n   199→    const data = await response.json();\n   200→    if (data.ok && Array.isArray(data.commands)) {\n   201→      state.availableCommands = data.commands;\n   202→    }\n   203→  } catch {\n   204→    // Non-critical — autocomplete just won't work\n   205→  }\n   206→}\n   207→\n   208→function connectRealtime() {\n   209→  closeRealtime();\n   210→\n   211→  if (typeof EventSource === 'undefined') {\n   212→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   213→    return;\n   214→  }\n   215→\n   216→  const es = new EventSource(getEventsUrl());\n   217→  state.eventSource = es;\n   218→\n   219→  es.addEventListener('connected', () => {\n   220→    setStatus('实时通道已连接', 'connected');\n   221→  });\n   222→\n   223→  es.addEventListener('status', (event) => {\n   224→    const payload = JSON.parse(event.data);\n   225→    if (payload.stage === 'running') {\n   226→      setStatus('助手处理中...');\n   227→      return;\n   228→    }\n   229→\n   230→    if (payload.stage === 'accepted') {\n   231→      setStatus('已接收请求');\n   232→      return;\n   233→    }\n   234→\n   235→    setStatus('实时通道在线', 'connected');\n   236→  });\n   237→\n   238→  es.addEventListener('assistant_chunk', (event) => {\n   239→    const payload = JSON.parse(event.data);\n   240→\n   241→    if (!state.streamingMessageBody) {\n   242→      const node = appendMessage('assistant', '');\n   243→      state.streamingMessageBody = node.body;\n   244→      state.streamedText = '';\n   245→    }\n   246→\n   247→    state.streamedText += payload.text ?? '';\n   248→    state.streamingMessageBody.textContent = state.streamedText;\n   249→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   250→  });\n   251→\n   252→  es.addEventListener('assistant_done', (event) => {\n   253→    const payload = JSON.parse(event.data);\n   254→    if (state.streamingMessageBody) {\n   255→      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n   256→    } else if (payload.isCommand) {\n   257→      // Command result came via SSE (not via HTTP response) — render as HTML\n   258→      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n   259→    }\n   260→    setStatus('就绪');\n   261→  });\n   262→\n   263→  es.onerror = () => {\n   264→    setStatus('实时通道重连中...', 'error');\n   265→  };\n   266→}\n   267→\n   268→async function callJson(path, payload) {\n   269→  const response = await fetch(getApiUrl(path), {\n   270→    method: 'POST',\n   271→    headers: { 'Content-Type': 'application/json' },\n   272→    body: JSON.stringify(payload)\n   273→  });\n   274→\n   275→  const data = await response.json();\n   276→  if (!response.ok || !data.ok) {\n   277→    throw new Error(data.error || `请求失败: ${response.status}`);\n   278→  }\n   279→  return data;\n   280→}\n   281→\n   282→function normalizeZeroHost() {\n   283→  if (window.location.hostname !== '0.0.0.0') {\n   284→    return false;\n   285→  }\n   286→\n   287→  const nextUrl = new URL(window.location.href);\n   288→  nextUrl.hostname = '127.0.0.1';\n   289→  window.location.replace(nextUrl.toString());\n   290→  return true;\n   291→}\n   292→\n   293→function init() {\n   294→  if (normalizeZeroHost()) {\n   295→    return;\n   296→  }\n   297→\n   298→  loadSessionConfig();\n   299→\n   300→  if (!state.sessionId) {\n   301→    state.sessionId = randomSessionId();\n   302→  }\n   303→\n   304→  els.baseUrlInput.value = state.baseUrl;\n   305→  els.sessionIdInput.value = state.sessionId;\n   306→\n   307→  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n   308→  connectRealtime();\n   309→  loadAvailableCommands();\n   310→}\n   311→\n   312→els.baseUrlInput.addEventListener('change', () => {\n   313→  state.baseUrl = els.baseUrlInput.value.trim();\n   314→  saveSessionConfig();\n   315→  connectRealtime();\n   316→});\n   317→\n   318→els.sessionIdInput.addEventListener('change', () => {\n   319→  const value = els.sessionIdInput.value.trim();\n   320→  state.sessionId = value || randomSessionId();\n   321→  els.sessionIdInput.value = state.sessionId;\n   322→  saveSessionConfig();\n   323→  connectRealtime();\n   324→});\n   325→\n   326→els.clearChatBtn.addEventListener('click', () => {\n   327→  els.chatMessages.innerHTML = '';\n   328→  appendMessage('system', '界面消息已清空。');\n   329→});\n   330→\n   331→els.chatForm.addEventListener('submit', async (event) => {\n   332→  event.preventDefault();\n   333→  if (state.busy) return;\n   334→\n   335→  const message = els.chatInput.value.trim();\n   336→  if (!message) return;\n   337→\n   338→  appendMessage('user', message);\n   339→  els.chatInput.value = '';\n   340→  updateCharCounter();\n   341→\n   342→  state.streamingMessageBody = null;\n   343→  state.streamedText = '';\n   344→\n   345→  try {\n   346→    setBusy(true, '聊天处理中...');\n   347→    const data = await callJson('/api/chat', {\n   348→      channel: 'web',\n   349→      sessionId: state.sessionId,\n   350→      message\n   351→    });\n   352→\n   353→    if (!state.streamedText) {\n   354→      const isHtml = data.isCommand === true;\n   355→      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n   356→    }\n   357→  } catch (error) {\n   358→    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n   359→  } finally {\n   360→    state.streamingMessageBody = null;\n   361→    setBusy(false, '就绪');\n   362→  }\n   363→});\n   364→\n   365→els.chatInput.addEventListener('keydown', (event) => {\n   366→  if (event.key === 'Escape' && state.commandDropdownVisible) {\n   367→    hideCommandDropdown();\n   368→    return;\n   369→  }\n   370→  if (event.key === 'Enter' && !event.shiftKey) {\n   371→    event.preventDefault();\n   372→    hideCommandDropdown();\n   373→    els.chatForm.requestSubmit();\n   374→  }\n   375→});\n   376→\n   377→els.chatInput.addEventListener('input', () => {\n   378→  updateCharCounter();\n   379→  const value = els.chatInput.value;\n   380→  const firstWord = value.split(/\\s/)[0];\n   381→  if (firstWord.startsWith('/') && value === firstWord) {\n   382→    // User is still typing the command name (no space yet)\n   383→    const matches = filterCommands(firstWord);\n   384→    showCommandDropdown(matches);\n   385→  } else {\n   386→    hideCommandDropdown();\n   387→  }\n   388→});\n   389→\n   390→els.chatInput.addEventListener('blur', () => {\n   391→  // Delay hide to allow mousedown on dropdown item to fire first\n   392→  setTimeout(hideCommandDropdown, 150);\n   393→});\n   394→\n   395→els.takeScreenshotBtn.addEventListener('click', async () => {\n   396→  if (state.busy) return;\n   397→\n   398→  try {\n   399→    setBusy(true, '正在获取截图...');\n   400→    const data = await callJson('/api/screenshot', {\n   401→      channel: 'web',\n   402→      sessionId: state.sessionId\n   403→    });\n   404→\n   405→    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n   406→    els.screenshotImage.classList.remove('hidden');\n   407→    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n   408→  } catch (error) {\n   409→    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n   410→  } finally {\n   411→    setBusy(false, '就绪');\n   412→  }\n   413→});\n   414→\n   415→els.execForm.addEventListener('submit', async (event) => {\n   416→  event.preventDefault();\n   417→  if (state.busy) return;\n   418→\n   419→  const command = els.execInput.value.trim();\n   420→  if (!command) return;\n   421→\n   422→  els.exitCodeOutput.classList.remove('exit-error');\n   423→  els.stderrOutput.classList.remove('error');\n   424→\n   425→  try {\n   426→    setBusy(true, '正在执行命令...');\n   427→    const data = await callJson('/api/system/exec', {\n   428→      channel: 'web',\n   429→      sessionId: state.sessionId,\n   430→      command\n   431→    });\n   432→\n   433→    els.exitCodeOutput.textContent = String(data.exitCode);\n   434→    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n   435→    els.stdoutOutput.textContent = data.stdout || '(empty)';\n   436→    els.stderrOutput.textContent = data.stderr || '(empty)';\n   437→    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n   438→  } catch (error) {\n   439→    const message = error instanceof Error ? error.message : String(error);\n   440→    els.exitCodeOutput.textContent = 'error';\n   441→    els.exitCodeOutput.classList.add('exit-error');\n   442→    els.stdoutOutput.textContent = '';\n   443→    els.stderrOutput.textContent = message;\n   444→    els.stderrOutput.classList.add('error');\n   445→  } finally {\n   446→    setBusy(false, '就绪');\n   447→  }\n   448→});\n   449→\n   450→window.addEventListener('beforeunload', () => {\n   451→  closeRealtime();\n   452→});\n   453→\n   454→init();\n   455→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"85c34a08-b147-4c48-a390-21615341a959","uuid":"3af8a7ee-640d-431c-b5a1-236254c0b18b","timestamp":"2026-03-23T00:34:00.143Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js","content":"const STORAGE_KEY = 'prizmclaw-web-session';\n\nconst state = {\n  baseUrl: '',\n  sessionId: '',\n  busy: false,\n  eventSource: null,\n  streamingMessageBody: null,\n  streamedText: '',\n  availableCommands: [],\n  commandDropdownVisible: false\n};\n\nconst els = {\n  status: document.getElementById('status'),\n  baseUrlInput: document.getElementById('baseUrlInput'),\n  sessionIdInput: document.getElementById('sessionIdInput'),\n  chatMessages: document.getElementById('chatMessages'),\n  chatForm: document.getElementById('chatForm'),\n  chatInput: document.getElementById('chatInput'),\n  charCounter: document.getElementById('charCounter'),\n  sendChatBtn: document.getElementById('sendChatBtn'),\n  clearChatBtn: document.getElementById('clearChatBtn'),\n  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n  screenshotImage: document.getElementById('screenshotImage'),\n  screenshotMeta: document.getElementById('screenshotMeta'),\n  execForm: document.getElementById('execForm'),\n  execInput: document.getElementById('execInput'),\n  runExecBtn: document.getElementById('runExecBtn'),\n  exitCodeOutput: document.getElementById('exitCodeOutput'),\n  stdoutOutput: document.getElementById('stdoutOutput'),\n  stderrOutput: document.getElementById('stderrOutput')\n};\n\nfunction randomSessionId() {\n  const rand = Math.random().toString(36).slice(2, 10);\n  return `web-${Date.now()}-${rand}`;\n}\n\nfunction setStatus(text, state) {\n  els.status.textContent = text;\n  els.status.classList.remove('connected', 'error');\n  if (state) els.status.classList.add(state);\n}\n\nconst CHAR_LIMIT = 8000;\nconst CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n\nfunction updateCharCounter() {\n  const len = els.chatInput.value.length;\n  els.charCounter.textContent = len;\n  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n}\n\nfunction setBusy(busy, text) {\n  state.busy = busy;\n  els.sendChatBtn.disabled = busy;\n  els.takeScreenshotBtn.disabled = busy;\n  els.runExecBtn.disabled = busy;\n  setStatus(text);\n}\n\nfunction saveSessionConfig() {\n  localStorage.setItem(\n    STORAGE_KEY,\n    JSON.stringify({\n      baseUrl: state.baseUrl,\n      sessionId: state.sessionId\n    })\n  );\n}\n\nfunction loadSessionConfig() {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) {\n      return;\n    }\n\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.baseUrl === 'string') {\n      state.baseUrl = parsed.baseUrl;\n    }\n    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n      state.sessionId = parsed.sessionId;\n    }\n  } catch {\n    // ignore\n  }\n}\n\nfunction createMessageElement(role, text, isError = false, isHtml = false) {\n  const item = document.createElement('div');\n  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n\n  const roleEl = document.createElement('span');\n  roleEl.className = 'role';\n  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n\n  const body = document.createElement('div');\n  body.className = 'body';\n  if (isHtml) {\n    body.innerHTML = text;\n  } else {\n    body.textContent = text;\n  }\n\n  item.append(roleEl, body);\n  return { item, body };\n}\n\nfunction appendMessage(role, text, isError = false, isHtml = false) {\n  const node = createMessageElement(role, text, isError, isHtml);\n  els.chatMessages.appendChild(node.item);\n  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  return node;\n}\n\nfunction getApiUrl(path) {\n  const base = state.baseUrl.trim();\n  if (!base) {\n    return path;\n  }\n  return `${base.replace(/\\/$/, '')}${path}`;\n}\n\nfunction getEventsUrl() {\n  const query = new URLSearchParams({\n    channel: 'web',\n    sessionId: state.sessionId\n  }).toString();\n\n  return `${getApiUrl('/api/events')}?${query}`;\n}\n\nfunction closeRealtime() {\n  if (state.eventSource) {\n    state.eventSource.close();\n    state.eventSource = null;\n  }\n}\n\n// ── Command Autocomplete ──────────────────────────────────────────────────────\n\nlet commandDropdown = null;\n\nfunction createCommandDropdown() {\n  commandDropdown = document.createElement('div');\n  commandDropdown.className = 'command-dropdown';\n  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n  els.chatForm.style.position = 'relative';\n  els.chatForm.appendChild(commandDropdown);\n}\n\nfunction showCommandDropdown(commands) {\n  if (!commandDropdown) createCommandDropdown();\n  commandDropdown.innerHTML = '';\n\n  if (commands.length === 0) {\n    commandDropdown.style.display = 'none';\n    state.commandDropdownVisible = false;\n    return;\n  }\n\n  commands.forEach((cmd) => {\n    const item = document.createElement('div');\n    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n    item.addEventListener('mousedown', (e) => {\n      e.preventDefault();\n      els.chatInput.value = `/${cmd.name} `;\n      hideCommandDropdown();\n      els.chatInput.focus();\n    });\n    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n    item.addEventListener('mouseout', () => { item.style.background = ''; });\n    commandDropdown.appendChild(item);\n  });\n\n  commandDropdown.style.display = 'block';\n  state.commandDropdownVisible = true;\n}\n\nfunction hideCommandDropdown() {\n  if (commandDropdown) commandDropdown.style.display = 'none';\n  state.commandDropdownVisible = false;\n}\n\nfunction filterCommands(prefix) {\n  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n  return state.availableCommands.filter((cmd) => {\n    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n  });\n}\n\nasync function loadAvailableCommands() {\n  try {\n    const response = await fetch(getApiUrl('/api/commands'));\n    const data = await response.json();\n    if (data.ok && Array.isArray(data.commands)) {\n      state.availableCommands = data.commands;\n    }\n  } catch {\n    // Non-critical — autocomplete just won't work\n  }\n}\n\nfunction connectRealtime() {\n  closeRealtime();\n\n  if (typeof EventSource === 'undefined') {\n    setStatus('当前浏览器不支持实时推送（EventSource）');\n    return;\n  }\n\n  const es = new EventSource(getEventsUrl());\n  state.eventSource = es;\n\n  es.addEventListener('connected', () => {\n    setStatus('实时通道已连接', 'connected');\n  });\n\n  es.addEventListener('status', (event) => {\n    const payload = JSON.parse(event.data);\n    if (payload.stage === 'running') {\n      setStatus('助手处理中...');\n      return;\n    }\n\n    if (payload.stage === 'accepted') {\n      setStatus('已接收请求');\n      return;\n    }\n\n    setStatus('实时通道在线', 'connected');\n  });\n\n  es.addEventListener('assistant_chunk', (event) => {\n    const payload = JSON.parse(event.data);\n\n    if (!state.streamingMessageBody) {\n      const node = appendMessage('assistant', '');\n      state.streamingMessageBody = node.body;\n      state.streamedText = '';\n    }\n\n    state.streamedText += payload.text ?? '';\n    state.streamingMessageBody.textContent = state.streamedText;\n    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  });\n\n  es.addEventListener('assistant_done', (event) => {\n    const payload = JSON.parse(event.data);\n    if (state.streamingMessageBody) {\n      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n    } else if (payload.isCommand) {\n      // Command result came via SSE (not via HTTP response) — render as HTML\n      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n    }\n    setStatus('就绪');\n  });\n\n  es.onerror = () => {\n    setStatus('实时通道重连中...', 'error');\n  };\n}\n\nasync function callJson(path, payload) {\n  const response = await fetch(getApiUrl(path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n\n  const data = await response.json();\n  if (!response.ok || !data.ok) {\n    throw new Error(data.error || `请求失败: ${response.status}`);\n  }\n  return data;\n}\n\nfunction normalizeZeroHost() {\n  if (window.location.hostname !== '0.0.0.0') {\n    return false;\n  }\n\n  const nextUrl = new URL(window.location.href);\n  nextUrl.hostname = '127.0.0.1';\n  window.location.replace(nextUrl.toString());\n  return true;\n}\n\nfunction init() {\n  if (normalizeZeroHost()) {\n    return;\n  }\n\n  loadSessionConfig();\n\n  if (!state.sessionId) {\n    state.sessionId = randomSessionId();\n  }\n\n  els.baseUrlInput.value = state.baseUrl;\n  els.sessionIdInput.value = state.sessionId;\n\n  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n  connectRealtime();\n  loadAvailableCommands();\n}\n\nels.baseUrlInput.addEventListener('change', () => {\n  state.baseUrl = els.baseUrlInput.value.trim();\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.sessionIdInput.addEventListener('change', () => {\n  const value = els.sessionIdInput.value.trim();\n  state.sessionId = value || randomSessionId();\n  els.sessionIdInput.value = state.sessionId;\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.clearChatBtn.addEventListener('click', () => {\n  els.chatMessages.innerHTML = '';\n  appendMessage('system', '界面消息已清空。');\n});\n\nels.chatForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const message = els.chatInput.value.trim();\n  if (!message) return;\n\n  appendMessage('user', message);\n  els.chatInput.value = '';\n  updateCharCounter();\n\n  state.streamingMessageBody = null;\n  state.streamedText = '';\n\n  try {\n    setBusy(true, '聊天处理中...');\n    const data = await callJson('/api/chat', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      message\n    });\n\n    if (!state.streamedText) {\n      const isHtml = data.isCommand === true;\n      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n    }\n  } catch (error) {\n    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n  } finally {\n    state.streamingMessageBody = null;\n    setBusy(false, '就绪');\n  }\n});\n\nels.chatInput.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && state.commandDropdownVisible) {\n    hideCommandDropdown();\n    return;\n  }\n  if (event.key === 'Enter' && !event.shiftKey) {\n    event.preventDefault();\n    hideCommandDropdown();\n    els.chatForm.requestSubmit();\n  }\n});\n\nels.chatInput.addEventListener('input', () => {\n  updateCharCounter();\n  const value = els.chatInput.value;\n  const firstWord = value.split(/\\s/)[0];\n  if (firstWord.startsWith('/') && value === firstWord) {\n    // User is still typing the command name (no space yet)\n    const matches = filterCommands(firstWord);\n    showCommandDropdown(matches);\n  } else {\n    hideCommandDropdown();\n  }\n});\n\nels.chatInput.addEventListener('blur', () => {\n  // Delay hide to allow mousedown on dropdown item to fire first\n  setTimeout(hideCommandDropdown, 150);\n});\n\nels.takeScreenshotBtn.addEventListener('click', async () => {\n  if (state.busy) return;\n\n  try {\n    setBusy(true, '正在获取截图...');\n    const data = await callJson('/api/screenshot', {\n      channel: 'web',\n      sessionId: state.sessionId\n    });\n\n    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n    els.screenshotImage.classList.remove('hidden');\n    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  els.exitCodeOutput.classList.remove('exit-error');\n  els.stderrOutput.classList.remove('error');\n\n  try {\n    setBusy(true, '正在执行命令...');\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    els.exitCodeOutput.textContent = 'error';\n    els.exitCodeOutput.classList.add('exit-error');\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n    els.stderrOutput.classList.add('error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ninit();\n","numLines":455,"startLine":1,"totalLines":455}}}
