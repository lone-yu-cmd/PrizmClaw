{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01XHacREt6L8EC5y8cUAufmj","type":"tool_result","content":"     1→const STORAGE_KEY = 'prizmclaw-web-session';\n     2→\n     3→const state = {\n     4→  baseUrl: '',\n     5→  sessionId: '',\n     6→  busy: false,\n     7→  eventSource: null,\n     8→  streamingMessageBody: null,\n     9→  streamedText: '',\n    10→  availableCommands: [],\n    11→  commandDropdownVisible: false\n    12→};\n    13→\n    14→const els = {\n    15→  status: document.getElementById('status'),\n    16→  baseUrlInput: document.getElementById('baseUrlInput'),\n    17→  sessionIdInput: document.getElementById('sessionIdInput'),\n    18→  chatMessages: document.getElementById('chatMessages'),\n    19→  chatForm: document.getElementById('chatForm'),\n    20→  chatInput: document.getElementById('chatInput'),\n    21→  charCounter: document.getElementById('charCounter'),\n    22→  sendChatBtn: document.getElementById('sendChatBtn'),\n    23→  clearChatBtn: document.getElementById('clearChatBtn'),\n    24→  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n    25→  screenshotImage: document.getElementById('screenshotImage'),\n    26→  screenshotMeta: document.getElementById('screenshotMeta'),\n    27→  lightbox: document.getElementById('lightbox'),\n    28→  lightboxImg: document.getElementById('lightboxImg'),\n    29→  execForm: document.getElementById('execForm'),\n    30→  execInput: document.getElementById('execInput'),\n    31→  runExecBtn: document.getElementById('runExecBtn'),\n    32→  exitCodeOutput: document.getElementById('exitCodeOutput'),\n    33→  stdoutOutput: document.getElementById('stdoutOutput'),\n    34→  stderrOutput: document.getElementById('stderrOutput')\n    35→};\n    36→\n    37→function randomSessionId() {\n    38→  const rand = Math.random().toString(36).slice(2, 10);\n    39→  return `web-${Date.now()}-${rand}`;\n    40→}\n    41→\n    42→function setStatus(text, state) {\n    43→  els.status.textContent = text;\n    44→  els.status.classList.remove('connected', 'error');\n    45→  if (state) els.status.classList.add(state);\n    46→}\n    47→\n    48→const CHAR_LIMIT = 8000;\n    49→const CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n    50→\n    51→function updateCharCounter() {\n    52→  const len = els.chatInput.value.length;\n    53→  els.charCounter.textContent = len;\n    54→  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n    55→}\n    56→\n    57→function setBusy(busy, text) {\n    58→  state.busy = busy;\n    59→  els.sendChatBtn.disabled = busy;\n    60→  els.takeScreenshotBtn.disabled = busy;\n    61→  els.runExecBtn.disabled = busy;\n    62→  setStatus(text);\n    63→}\n    64→\n    65→function saveSessionConfig() {\n    66→  localStorage.setItem(\n    67→    STORAGE_KEY,\n    68→    JSON.stringify({\n    69→      baseUrl: state.baseUrl,\n    70→      sessionId: state.sessionId\n    71→    })\n    72→  );\n    73→}\n    74→\n    75→function loadSessionConfig() {\n    76→  try {\n    77→    const raw = localStorage.getItem(STORAGE_KEY);\n    78→    if (!raw) {\n    79→      return;\n    80→    }\n    81→\n    82→    const parsed = JSON.parse(raw);\n    83→    if (typeof parsed.baseUrl === 'string') {\n    84→      state.baseUrl = parsed.baseUrl;\n    85→    }\n    86→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n    87→      state.sessionId = parsed.sessionId;\n    88→    }\n    89→  } catch {\n    90→    // ignore\n    91→  }\n    92→}\n    93→\n    94→function createMessageElement(role, text, isError = false, isHtml = false) {\n    95→  const item = document.createElement('div');\n    96→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n    97→\n    98→  const roleEl = document.createElement('span');\n    99→  roleEl.className = 'role';\n   100→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n   101→\n   102→  const body = document.createElement('div');\n   103→  body.className = 'body';\n   104→  if (isHtml) {\n   105→    body.innerHTML = text;\n   106→  } else {\n   107→    body.textContent = text;\n   108→  }\n   109→\n   110→  item.append(roleEl, body);\n   111→  return { item, body };\n   112→}\n   113→\n   114→function appendMessage(role, text, isError = false, isHtml = false) {\n   115→  const node = createMessageElement(role, text, isError, isHtml);\n   116→  els.chatMessages.appendChild(node.item);\n   117→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   118→  return node;\n   119→}\n   120→\n   121→function getApiUrl(path) {\n   122→  const base = state.baseUrl.trim();\n   123→  if (!base) {\n   124→    return path;\n   125→  }\n   126→  return `${base.replace(/\\/$/, '')}${path}`;\n   127→}\n   128→\n   129→function getEventsUrl() {\n   130→  const query = new URLSearchParams({\n   131→    channel: 'web',\n   132→    sessionId: state.sessionId\n   133→  }).toString();\n   134→\n   135→  return `${getApiUrl('/api/events')}?${query}`;\n   136→}\n   137→\n   138→function closeRealtime() {\n   139→  if (state.eventSource) {\n   140→    state.eventSource.close();\n   141→    state.eventSource = null;\n   142→  }\n   143→}\n   144→\n   145→// ── Command Autocomplete ──────────────────────────────────────────────────────\n   146→\n   147→let commandDropdown = null;\n   148→\n   149→function createCommandDropdown() {\n   150→  commandDropdown = document.createElement('div');\n   151→  commandDropdown.className = 'command-dropdown';\n   152→  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n   153→  els.chatForm.style.position = 'relative';\n   154→  els.chatForm.appendChild(commandDropdown);\n   155→}\n   156→\n   157→function showCommandDropdown(commands) {\n   158→  if (!commandDropdown) createCommandDropdown();\n   159→  commandDropdown.innerHTML = '';\n   160→\n   161→  if (commands.length === 0) {\n   162→    commandDropdown.style.display = 'none';\n   163→    state.commandDropdownVisible = false;\n   164→    return;\n   165→  }\n   166→\n   167→  commands.forEach((cmd) => {\n   168→    const item = document.createElement('div');\n   169→    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n   170→    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n   171→    item.addEventListener('mousedown', (e) => {\n   172→      e.preventDefault();\n   173→      els.chatInput.value = `/${cmd.name} `;\n   174→      hideCommandDropdown();\n   175→      els.chatInput.focus();\n   176→    });\n   177→    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n   178→    item.addEventListener('mouseout', () => { item.style.background = ''; });\n   179→    commandDropdown.appendChild(item);\n   180→  });\n   181→\n   182→  commandDropdown.style.display = 'block';\n   183→  state.commandDropdownVisible = true;\n   184→}\n   185→\n   186→function hideCommandDropdown() {\n   187→  if (commandDropdown) commandDropdown.style.display = 'none';\n   188→  state.commandDropdownVisible = false;\n   189→}\n   190→\n   191→function filterCommands(prefix) {\n   192→  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n   193→  return state.availableCommands.filter((cmd) => {\n   194→    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n   195→  });\n   196→}\n   197→\n   198→async function loadAvailableCommands() {\n   199→  try {\n   200→    const response = await fetch(getApiUrl('/api/commands'));\n   201→    const data = await response.json();\n   202→    if (data.ok && Array.isArray(data.commands)) {\n   203→      state.availableCommands = data.commands;\n   204→    }\n   205→  } catch {\n   206→    // Non-critical — autocomplete just won't work\n   207→  }\n   208→}\n   209→\n   210→function connectRealtime() {\n   211→  closeRealtime();\n   212→\n   213→  if (typeof EventSource === 'undefined') {\n   214→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   215→    return;\n   216→  }\n   217→\n   218→  const es = new EventSource(getEventsUrl());\n   219→  state.eventSource = es;\n   220→\n   221→  es.addEventListener('connected', () => {\n   222→    setStatus('实时通道已连接', 'connected');\n   223→  });\n   224→\n   225→  es.addEventListener('status', (event) => {\n   226→    const payload = JSON.parse(event.data);\n   227→    if (payload.stage === 'running') {\n   228→      setStatus('助手处理中...');\n   229→      return;\n   230→    }\n   231→\n   232→    if (payload.stage === 'accepted') {\n   233→      setStatus('已接收请求');\n   234→      return;\n   235→    }\n   236→\n   237→    setStatus('实时通道在线', 'connected');\n   238→  });\n   239→\n   240→  es.addEventListener('assistant_chunk', (event) => {\n   241→    const payload = JSON.parse(event.data);\n   242→\n   243→    if (!state.streamingMessageBody) {\n   244→      const node = appendMessage('assistant', '');\n   245→      state.streamingMessageBody = node.body;\n   246→      state.streamedText = '';\n   247→    }\n   248→\n   249→    state.streamedText += payload.text ?? '';\n   250→    state.streamingMessageBody.textContent = state.streamedText;\n   251→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   252→  });\n   253→\n   254→  es.addEventListener('assistant_done', (event) => {\n   255→    const payload = JSON.parse(event.data);\n   256→    if (state.streamingMessageBody) {\n   257→      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n   258→    } else if (payload.isCommand) {\n   259→      // Command result came via SSE (not via HTTP response) — render as HTML\n   260→      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n   261→    }\n   262→    setStatus('就绪');\n   263→  });\n   264→\n   265→  es.onerror = () => {\n   266→    setStatus('实时通道重连中...', 'error');\n   267→  };\n   268→}\n   269→\n   270→async function callJson(path, payload) {\n   271→  const response = await fetch(getApiUrl(path), {\n   272→    method: 'POST',\n   273→    headers: { 'Content-Type': 'application/json' },\n   274→    body: JSON.stringify(payload)\n   275→  });\n   276→\n   277→  const data = await response.json();\n   278→  if (!response.ok || !data.ok) {\n   279→    throw new Error(data.error || `请求失败: ${response.status}`);\n   280→  }\n   281→  return data;\n   282→}\n   283→\n   284→function normalizeZeroHost() {\n   285→  if (window.location.hostname !== '0.0.0.0') {\n   286→    return false;\n   287→  }\n   288→\n   289→  const nextUrl = new URL(window.location.href);\n   290→  nextUrl.hostname = '127.0.0.1';\n   291→  window.location.replace(nextUrl.toString());\n   292→  return true;\n   293→}\n   294→\n   295→function init() {\n   296→  if (normalizeZeroHost()) {\n   297→    return;\n   298→  }\n   299→\n   300→  loadSessionConfig();\n   301→\n   302→  if (!state.sessionId) {\n   303→    state.sessionId = randomSessionId();\n   304→  }\n   305→\n   306→  els.baseUrlInput.value = state.baseUrl;\n   307→  els.sessionIdInput.value = state.sessionId;\n   308→\n   309→  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n   310→  connectRealtime();\n   311→  loadAvailableCommands();\n   312→}\n   313→\n   314→els.baseUrlInput.addEventListener('change', () => {\n   315→  state.baseUrl = els.baseUrlInput.value.trim();\n   316→  saveSessionConfig();\n   317→  connectRealtime();\n   318→});\n   319→\n   320→els.sessionIdInput.addEventListener('change', () => {\n   321→  const value = els.sessionIdInput.value.trim();\n   322→  state.sessionId = value || randomSessionId();\n   323→  els.sessionIdInput.value = state.sessionId;\n   324→  saveSessionConfig();\n   325→  connectRealtime();\n   326→});\n   327→\n   328→els.clearChatBtn.addEventListener('click', () => {\n   329→  els.chatMessages.innerHTML = '';\n   330→  appendMessage('system', '界面消息已清空。');\n   331→});\n   332→\n   333→els.chatForm.addEventListener('submit', async (event) => {\n   334→  event.preventDefault();\n   335→  if (state.busy) return;\n   336→\n   337→  const message = els.chatInput.value.trim();\n   338→  if (!message) return;\n   339→\n   340→  appendMessage('user', message);\n   341→  els.chatInput.value = '';\n   342→  updateCharCounter();\n   343→\n   344→  state.streamingMessageBody = null;\n   345→  state.streamedText = '';\n   346→\n   347→  try {\n   348→    setBusy(true, '聊天处理中...');\n   349→    const data = await callJson('/api/chat', {\n   350→      channel: 'web',\n   351→      sessionId: state.sessionId,\n   352→      message\n   353→    });\n   354→\n   355→    if (!state.streamedText) {\n   356→      const isHtml = data.isCommand === true;\n   357→      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n   358→    }\n   359→  } catch (error) {\n   360→    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n   361→  } finally {\n   362→    state.streamingMessageBody = null;\n   363→    setBusy(false, '就绪');\n   364→  }\n   365→});\n   366→\n   367→els.chatInput.addEventListener('keydown', (event) => {\n   368→  if (event.key === 'Escape' && state.commandDropdownVisible) {\n   369→    hideCommandDropdown();\n   370→    return;\n   371→  }\n   372→  if (event.key === 'Enter' && !event.shiftKey) {\n   373→    event.preventDefault();\n   374→    hideCommandDropdown();\n   375→    els.chatForm.requestSubmit();\n   376→  }\n   377→});\n   378→\n   379→els.chatInput.addEventListener('input', () => {\n   380→  updateCharCounter();\n   381→  const value = els.chatInput.value;\n   382→  const firstWord = value.split(/\\s/)[0];\n   383→  if (firstWord.startsWith('/') && value === firstWord) {\n   384→    // User is still typing the command name (no space yet)\n   385→    const matches = filterCommands(firstWord);\n   386→    showCommandDropdown(matches);\n   387→  } else {\n   388→    hideCommandDropdown();\n   389→  }\n   390→});\n   391→\n   392→els.chatInput.addEventListener('blur', () => {\n   393→  // Delay hide to allow mousedown on dropdown item to fire first\n   394→  setTimeout(hideCommandDropdown, 150);\n   395→});\n   396→\n   397→function openLightbox(src) {\n   398→  els.lightboxImg.src = src;\n   399→  els.lightbox.classList.remove('hidden');\n   400→}\n   401→\n   402→function closeLightbox() {\n   403→  els.lightbox.classList.add('hidden');\n   404→  els.lightboxImg.src = '';\n   405→}\n   406→\n   407→els.screenshotImage.addEventListener('click', () => {\n   408→  if (!els.screenshotImage.classList.contains('hidden')) {\n   409→    openLightbox(els.screenshotImage.src);\n   410→  }\n   411→});\n   412→\n   413→els.lightbox.addEventListener('click', (event) => {\n   414→  if (event.target !== els.lightboxImg) {\n   415→    closeLightbox();\n   416→  }\n   417→});\n   418→\n   419→els.takeScreenshotBtn.addEventListener('click', async () => {\n   420→  if (state.busy) return;\n   421→\n   422→  try {\n   423→    setBusy(true, '正在获取截图...');\n   424→    const data = await callJson('/api/screenshot', {\n   425→      channel: 'web',\n   426→      sessionId: state.sessionId\n   427→    });\n   428→\n   429→    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n   430→    els.screenshotImage.classList.remove('hidden');\n   431→    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n   432→  } catch (error) {\n   433→    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n   434→  } finally {\n   435→    setBusy(false, '就绪');\n   436→  }\n   437→});\n   438→\n   439→els.execForm.addEventListener('submit', async (event) => {\n   440→  event.preventDefault();\n   441→  if (state.busy) return;\n   442→\n   443→  const command = els.execInput.value.trim();\n   444→  if (!command) return;\n   445→\n   446→  els.exitCodeOutput.classList.remove('exit-error');\n   447→  els.stderrOutput.classList.remove('error');\n   448→\n   449→  try {\n   450→    setBusy(true, '正在执行命令...');\n   451→    const data = await callJson('/api/system/exec', {\n   452→      channel: 'web',\n   453→      sessionId: state.sessionId,\n   454→      command\n   455→    });\n   456→\n   457→    els.exitCodeOutput.textContent = String(data.exitCode);\n   458→    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n   459→    els.stdoutOutput.textContent = data.stdout || '(empty)';\n   460→    els.stderrOutput.textContent = data.stderr || '(empty)';\n   461→    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n   462→  } catch (error) {\n   463→    const message = error instanceof Error ? error.message : String(error);\n   464→    els.exitCodeOutput.textContent = 'error';\n   465→    els.exitCodeOutput.classList.add('exit-error');\n   466→    els.stdoutOutput.textContent = '';\n   467→    els.stderrOutput.textContent = message;\n   468→    els.stderrOutput.classList.add('error');\n   469→  } finally {\n   470→    setBusy(false, '就绪');\n   471→  }\n   472→});\n   473→\n   474→window.addEventListener('beforeunload', () => {\n   475→  closeRealtime();\n   476→});\n   477→\n   478→document.addEventListener('keydown', (event) => {\n   479→  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n   480→    closeLightbox();\n   481→  }\n   482→});\n   483→\n   484→init();\n   485→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f1d676c0-7c91-4ba9-abec-b5cfaa8d95c1","uuid":"0a05eb3d-60a7-453f-9bfa-5b921b766789","timestamp":"2026-03-23T00:42:09.012Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js","content":"const STORAGE_KEY = 'prizmclaw-web-session';\n\nconst state = {\n  baseUrl: '',\n  sessionId: '',\n  busy: false,\n  eventSource: null,\n  streamingMessageBody: null,\n  streamedText: '',\n  availableCommands: [],\n  commandDropdownVisible: false\n};\n\nconst els = {\n  status: document.getElementById('status'),\n  baseUrlInput: document.getElementById('baseUrlInput'),\n  sessionIdInput: document.getElementById('sessionIdInput'),\n  chatMessages: document.getElementById('chatMessages'),\n  chatForm: document.getElementById('chatForm'),\n  chatInput: document.getElementById('chatInput'),\n  charCounter: document.getElementById('charCounter'),\n  sendChatBtn: document.getElementById('sendChatBtn'),\n  clearChatBtn: document.getElementById('clearChatBtn'),\n  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n  screenshotImage: document.getElementById('screenshotImage'),\n  screenshotMeta: document.getElementById('screenshotMeta'),\n  lightbox: document.getElementById('lightbox'),\n  lightboxImg: document.getElementById('lightboxImg'),\n  execForm: document.getElementById('execForm'),\n  execInput: document.getElementById('execInput'),\n  runExecBtn: document.getElementById('runExecBtn'),\n  exitCodeOutput: document.getElementById('exitCodeOutput'),\n  stdoutOutput: document.getElementById('stdoutOutput'),\n  stderrOutput: document.getElementById('stderrOutput')\n};\n\nfunction randomSessionId() {\n  const rand = Math.random().toString(36).slice(2, 10);\n  return `web-${Date.now()}-${rand}`;\n}\n\nfunction setStatus(text, state) {\n  els.status.textContent = text;\n  els.status.classList.remove('connected', 'error');\n  if (state) els.status.classList.add(state);\n}\n\nconst CHAR_LIMIT = 8000;\nconst CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n\nfunction updateCharCounter() {\n  const len = els.chatInput.value.length;\n  els.charCounter.textContent = len;\n  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n}\n\nfunction setBusy(busy, text) {\n  state.busy = busy;\n  els.sendChatBtn.disabled = busy;\n  els.takeScreenshotBtn.disabled = busy;\n  els.runExecBtn.disabled = busy;\n  setStatus(text);\n}\n\nfunction saveSessionConfig() {\n  localStorage.setItem(\n    STORAGE_KEY,\n    JSON.stringify({\n      baseUrl: state.baseUrl,\n      sessionId: state.sessionId\n    })\n  );\n}\n\nfunction loadSessionConfig() {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) {\n      return;\n    }\n\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.baseUrl === 'string') {\n      state.baseUrl = parsed.baseUrl;\n    }\n    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n      state.sessionId = parsed.sessionId;\n    }\n  } catch {\n    // ignore\n  }\n}\n\nfunction createMessageElement(role, text, isError = false, isHtml = false) {\n  const item = document.createElement('div');\n  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n\n  const roleEl = document.createElement('span');\n  roleEl.className = 'role';\n  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n\n  const body = document.createElement('div');\n  body.className = 'body';\n  if (isHtml) {\n    body.innerHTML = text;\n  } else {\n    body.textContent = text;\n  }\n\n  item.append(roleEl, body);\n  return { item, body };\n}\n\nfunction appendMessage(role, text, isError = false, isHtml = false) {\n  const node = createMessageElement(role, text, isError, isHtml);\n  els.chatMessages.appendChild(node.item);\n  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  return node;\n}\n\nfunction getApiUrl(path) {\n  const base = state.baseUrl.trim();\n  if (!base) {\n    return path;\n  }\n  return `${base.replace(/\\/$/, '')}${path}`;\n}\n\nfunction getEventsUrl() {\n  const query = new URLSearchParams({\n    channel: 'web',\n    sessionId: state.sessionId\n  }).toString();\n\n  return `${getApiUrl('/api/events')}?${query}`;\n}\n\nfunction closeRealtime() {\n  if (state.eventSource) {\n    state.eventSource.close();\n    state.eventSource = null;\n  }\n}\n\n// ── Command Autocomplete ──────────────────────────────────────────────────────\n\nlet commandDropdown = null;\n\nfunction createCommandDropdown() {\n  commandDropdown = document.createElement('div');\n  commandDropdown.className = 'command-dropdown';\n  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n  els.chatForm.style.position = 'relative';\n  els.chatForm.appendChild(commandDropdown);\n}\n\nfunction showCommandDropdown(commands) {\n  if (!commandDropdown) createCommandDropdown();\n  commandDropdown.innerHTML = '';\n\n  if (commands.length === 0) {\n    commandDropdown.style.display = 'none';\n    state.commandDropdownVisible = false;\n    return;\n  }\n\n  commands.forEach((cmd) => {\n    const item = document.createElement('div');\n    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n    item.addEventListener('mousedown', (e) => {\n      e.preventDefault();\n      els.chatInput.value = `/${cmd.name} `;\n      hideCommandDropdown();\n      els.chatInput.focus();\n    });\n    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n    item.addEventListener('mouseout', () => { item.style.background = ''; });\n    commandDropdown.appendChild(item);\n  });\n\n  commandDropdown.style.display = 'block';\n  state.commandDropdownVisible = true;\n}\n\nfunction hideCommandDropdown() {\n  if (commandDropdown) commandDropdown.style.display = 'none';\n  state.commandDropdownVisible = false;\n}\n\nfunction filterCommands(prefix) {\n  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n  return state.availableCommands.filter((cmd) => {\n    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n  });\n}\n\nasync function loadAvailableCommands() {\n  try {\n    const response = await fetch(getApiUrl('/api/commands'));\n    const data = await response.json();\n    if (data.ok && Array.isArray(data.commands)) {\n      state.availableCommands = data.commands;\n    }\n  } catch {\n    // Non-critical — autocomplete just won't work\n  }\n}\n\nfunction connectRealtime() {\n  closeRealtime();\n\n  if (typeof EventSource === 'undefined') {\n    setStatus('当前浏览器不支持实时推送（EventSource）');\n    return;\n  }\n\n  const es = new EventSource(getEventsUrl());\n  state.eventSource = es;\n\n  es.addEventListener('connected', () => {\n    setStatus('实时通道已连接', 'connected');\n  });\n\n  es.addEventListener('status', (event) => {\n    const payload = JSON.parse(event.data);\n    if (payload.stage === 'running') {\n      setStatus('助手处理中...');\n      return;\n    }\n\n    if (payload.stage === 'accepted') {\n      setStatus('已接收请求');\n      return;\n    }\n\n    setStatus('实时通道在线', 'connected');\n  });\n\n  es.addEventListener('assistant_chunk', (event) => {\n    const payload = JSON.parse(event.data);\n\n    if (!state.streamingMessageBody) {\n      const node = appendMessage('assistant', '');\n      state.streamingMessageBody = node.body;\n      state.streamedText = '';\n    }\n\n    state.streamedText += payload.text ?? '';\n    state.streamingMessageBody.textContent = state.streamedText;\n    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  });\n\n  es.addEventListener('assistant_done', (event) => {\n    const payload = JSON.parse(event.data);\n    if (state.streamingMessageBody) {\n      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n    } else if (payload.isCommand) {\n      // Command result came via SSE (not via HTTP response) — render as HTML\n      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n    }\n    setStatus('就绪');\n  });\n\n  es.onerror = () => {\n    setStatus('实时通道重连中...', 'error');\n  };\n}\n\nasync function callJson(path, payload) {\n  const response = await fetch(getApiUrl(path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n\n  const data = await response.json();\n  if (!response.ok || !data.ok) {\n    throw new Error(data.error || `请求失败: ${response.status}`);\n  }\n  return data;\n}\n\nfunction normalizeZeroHost() {\n  if (window.location.hostname !== '0.0.0.0') {\n    return false;\n  }\n\n  const nextUrl = new URL(window.location.href);\n  nextUrl.hostname = '127.0.0.1';\n  window.location.replace(nextUrl.toString());\n  return true;\n}\n\nfunction init() {\n  if (normalizeZeroHost()) {\n    return;\n  }\n\n  loadSessionConfig();\n\n  if (!state.sessionId) {\n    state.sessionId = randomSessionId();\n  }\n\n  els.baseUrlInput.value = state.baseUrl;\n  els.sessionIdInput.value = state.sessionId;\n\n  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n  connectRealtime();\n  loadAvailableCommands();\n}\n\nels.baseUrlInput.addEventListener('change', () => {\n  state.baseUrl = els.baseUrlInput.value.trim();\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.sessionIdInput.addEventListener('change', () => {\n  const value = els.sessionIdInput.value.trim();\n  state.sessionId = value || randomSessionId();\n  els.sessionIdInput.value = state.sessionId;\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.clearChatBtn.addEventListener('click', () => {\n  els.chatMessages.innerHTML = '';\n  appendMessage('system', '界面消息已清空。');\n});\n\nels.chatForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const message = els.chatInput.value.trim();\n  if (!message) return;\n\n  appendMessage('user', message);\n  els.chatInput.value = '';\n  updateCharCounter();\n\n  state.streamingMessageBody = null;\n  state.streamedText = '';\n\n  try {\n    setBusy(true, '聊天处理中...');\n    const data = await callJson('/api/chat', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      message\n    });\n\n    if (!state.streamedText) {\n      const isHtml = data.isCommand === true;\n      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n    }\n  } catch (error) {\n    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n  } finally {\n    state.streamingMessageBody = null;\n    setBusy(false, '就绪');\n  }\n});\n\nels.chatInput.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && state.commandDropdownVisible) {\n    hideCommandDropdown();\n    return;\n  }\n  if (event.key === 'Enter' && !event.shiftKey) {\n    event.preventDefault();\n    hideCommandDropdown();\n    els.chatForm.requestSubmit();\n  }\n});\n\nels.chatInput.addEventListener('input', () => {\n  updateCharCounter();\n  const value = els.chatInput.value;\n  const firstWord = value.split(/\\s/)[0];\n  if (firstWord.startsWith('/') && value === firstWord) {\n    // User is still typing the command name (no space yet)\n    const matches = filterCommands(firstWord);\n    showCommandDropdown(matches);\n  } else {\n    hideCommandDropdown();\n  }\n});\n\nels.chatInput.addEventListener('blur', () => {\n  // Delay hide to allow mousedown on dropdown item to fire first\n  setTimeout(hideCommandDropdown, 150);\n});\n\nfunction openLightbox(src) {\n  els.lightboxImg.src = src;\n  els.lightbox.classList.remove('hidden');\n}\n\nfunction closeLightbox() {\n  els.lightbox.classList.add('hidden');\n  els.lightboxImg.src = '';\n}\n\nels.screenshotImage.addEventListener('click', () => {\n  if (!els.screenshotImage.classList.contains('hidden')) {\n    openLightbox(els.screenshotImage.src);\n  }\n});\n\nels.lightbox.addEventListener('click', (event) => {\n  if (event.target !== els.lightboxImg) {\n    closeLightbox();\n  }\n});\n\nels.takeScreenshotBtn.addEventListener('click', async () => {\n  if (state.busy) return;\n\n  try {\n    setBusy(true, '正在获取截图...');\n    const data = await callJson('/api/screenshot', {\n      channel: 'web',\n      sessionId: state.sessionId\n    });\n\n    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n    els.screenshotImage.classList.remove('hidden');\n    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  els.exitCodeOutput.classList.remove('exit-error');\n  els.stderrOutput.classList.remove('error');\n\n  try {\n    setBusy(true, '正在执行命令...');\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    els.exitCodeOutput.textContent = 'error';\n    els.exitCodeOutput.classList.add('exit-error');\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n    els.stderrOutput.classList.add('error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ndocument.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n    closeLightbox();\n  }\n});\n\ninit();\n","numLines":485,"startLine":1,"totalLines":485}}}
