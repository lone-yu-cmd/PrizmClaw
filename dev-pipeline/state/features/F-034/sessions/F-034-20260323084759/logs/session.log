n: auto;\n  width: 16px;\n  height: 16px;\n  border: 2px solid currentColor;\n  border-top-color: transparent;\n  border-radius: 50%;\n  animation: btn-spin 0.7s linear infinite;\n  color: var(--primary-contrast);\n}\n\n.btn.primary {\n  background: var(--primary);\n  color: var(--primary-contrast);\n}\n\n.btn.warning {\n  background: var(--warning);\n  color: #fff;\n}\n\n.btn.ghost {\n  border: 1px solid var(--line);\n  background: transparent;\n}\n\n.dashboard-grid {\n  display: grid;\n  grid-template-columns: 2fr 1fr;\n  gap: 16px;\n}\n\n.chat-panel {\n  display: grid;\n  gap: 12px;\n}\n\n.panel-head {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 10px;\n}\n\n.chat-messages {\n  border: 1px solid var(--line);\n  border-radius: 12px;\n  padding: 10px;\n  min-height: 360px;\n  max-height: 62vh;\n  overflow: auto;\n  display: grid;\n  gap: 10px;\n  background: #fff;\n}\n\n@keyframes fade-in {\n  from {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.message {\n  padding: 10px;\n  border-radius: 10px;\n  line-height: 1.5;\n  white-space: pre-wrap;\n  word-break: break-word;\n  animation: fade-in 0.25s ease-out both;\n}\n\n.message.user {\n  background: var(--chat-user);\n}\n\n.message.assistant {\n  background: var(--chat-assistant);\n}\n\n.message.error {\n  border: 1px solid #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.message .role {\n  display: block;\n  font-size: 12px;\n  color: var(--muted);\n  margin-bottom: 4px;\n}\n\n.chat-form {\n  display: grid;\n  gap: 8px;\n}\n\n.char-counter {\n  font-size: 12px;\n  color: var(--muted);\n  text-align: right;\n  margin-top: -4px;\n}\n\n.char-counter.warning {\n  color: var(--warning);\n}\n\n.side-panel {\n  display: grid;\n  gap: 14px;\n  align-content: start;\n}\n\n.hint {\n  font-size: 13px;\n  color: var(--muted);\n  margin: 6px 0 10px;\n}\n\n.output-box {\n  margin: 0;\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 10px;\n  min-height: 44px;\n  background: #fff;\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-x: auto;\n}\n\n.output-box.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.output-box.exit-error {\n  border-color: #fde8bb;\n  background: #fffbf0;\n  color: var(--warning);\n}\n\n.screenshot-image {\n  width: 100%;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  margin-top: 10px;\n  background: #fff;\n}\n\n.screenshot-image:not(.hidden) {\n  cursor: pointer;\n}\n\n.lightbox {\n  position: fixed;\n  inset: 0;\n  z-index: 200;\n  background: rgba(0, 0, 0, 0.8);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: zoom-out;\n}\n\n.lightbox.hidden {\n  display: none;\n}\n\n.lightbox-img {\n  max-width: 95vw;\n  max-height: 95vh;\n  object-fit: contain;\n  border-radius: 6px;\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n  cursor: default;\n}\n\n.exec-form {\n  display: grid;\n  grid-template-columns: 1fr auto;\n  gap: 8px;\n  margin-bottom: 10px;\n}\n\n.exec-result {\n  display: grid;\n  gap: 8px;\n}\n\n.hidden {\n  display: none;\n}\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n@media (max-width: 900px) {\n  .dashboard-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .form-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 600px) {\n  .app-shell {\n    padding: 12px;\n    gap: 10px;\n  }\n\n  .app-header {\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n\n  .app-header h1 {\n    font-size: 1.1rem;\n  }\n\n  .app-header .subtitle {\n    font-size: 12px;\n  }\n\n  .status {\n    max-width: 140px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .panel,\n  .sub-panel {\n    padding: 10px;\n  }\n\n  .chat-messages {\n    max-height: 50vh;\n  }\n\n  .exec-form {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg: #111827;\n    --panel: #1f2937;\n    --line: #374151;\n    --text: #f9fafb;\n    --muted: #9ca3af;\n    --primary: #5b8df8;\n    --primary-contrast: #ffffff;\n    --warning: #f59e0b;\n    --danger: #f87171;\n    --chat-user: #1e3a5f;\n    --chat-assistant: #263144;\n  }\n\n  input,\n  textarea {\n    background: var(--panel);\n    color: var(--text);\n  }\n\n  .chat-messages {\n    background: var(--panel);\n  }\n\n  .output-box {\n    background: var(--panel);\n  }\n\n  .screenshot-image {\n    background: var(--panel);\n  }\n\n  .status.connected {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .status.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .message.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.exit-error {\n    border-color: #78350f;\n    background: #431407;\n    color: var(--warning);\n  }\n}\n\n/* ── Toast Notification System ─────────────────────────────────────────────── */\n\n.toast-container {\n  position: fixed;\n  bottom: 20px;\n  right: 20px;\n  z-index: 300;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  pointer-events: none;\n}\n\n@keyframes toast-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(8px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes toast-fade-out {\n  from {\n    opacity: 1;\n    transform: translateY(0);\n  }\n  to {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n}\n\n.toast {\n  padding: 10px 16px;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  background: var(--panel);\n  color: var(--text);\n  font-size: 14px;\n  line-height: 1.4;\n  max-width: 320px;\n  box-shadow: 0 4px 12px rgba(31, 38, 51, 0.12);\n  animation: toast-slide-in 0.2s ease-out both;\n  pointer-events: auto;\n}\n\n.toast.success {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.toast.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.toast.info {\n  border-color: var(--line);\n  background: var(--panel);\n  color: var(--text);\n}\n\n.toast.toast-fade-out {\n  animation: toast-fade-out 0.3s ease-in both;\n}\n\n@media (prefers-color-scheme: dark) {\n  .toast.success {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .toast.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n}\n","structuredPatch":[{"oldStart":174,"oldLines":11,"newStart":174,"newLines":10,"lines":["   margin: auto;","   width: 16px;","   height: 16px;","-  border: 2px solid currentColor;","-  border-top-color: transparent;","+  border: 2px solid rgba(255, 255, 255, 0.5);","+  border-top-color: #fff;","   border-radius: 50%;","   animation: btn-spin 0.7s linear infinite;","-  color: var(--primary-contrast);"," }"," "," .btn.primary {"]}],"userModified":false,"replaceAll":false}}
