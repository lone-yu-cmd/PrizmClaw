{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01JJygKWJAXePiLQf3Fvy83p","type":"tool_result","content":"     1→const STORAGE_KEY = 'prizmclaw-web-session';\n     2→\n     3→const state = {\n     4→  baseUrl: '',\n     5→  sessionId: '',\n     6→  busy: false,\n     7→  eventSource: null,\n     8→  streamingMessageBody: null,\n     9→  streamedText: '',\n    10→  availableCommands: [],\n    11→  commandDropdownVisible: false\n    12→};\n    13→\n    14→const els = {\n    15→  status: document.getElementById('status'),\n    16→  baseUrlInput: document.getElementById('baseUrlInput'),\n    17→  sessionIdInput: document.getElementById('sessionIdInput'),\n    18→  chatMessages: document.getElementById('chatMessages'),\n    19→  chatForm: document.getElementById('chatForm'),\n    20→  chatInput: document.getElementById('chatInput'),\n    21→  charCounter: document.getElementById('charCounter'),\n    22→  sendChatBtn: document.getElementById('sendChatBtn'),\n    23→  clearChatBtn: document.getElementById('clearChatBtn'),\n    24→  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n    25→  screenshotImage: document.getElementById('screenshotImage'),\n    26→  screenshotMeta: document.getElementById('screenshotMeta'),\n    27→  lightbox: document.getElementById('lightbox'),\n    28→  lightboxImg: document.getElementById('lightboxImg'),\n    29→  execForm: document.getElementById('execForm'),\n    30→  execInput: document.getElementById('execInput'),\n    31→  runExecBtn: document.getElementById('runExecBtn'),\n    32→  exitCodeOutput: document.getElementById('exitCodeOutput'),\n    33→  stdoutOutput: document.getElementById('stdoutOutput'),\n    34→  stderrOutput: document.getElementById('stderrOutput'),\n    35→  toastContainer: document.getElementById('toast-container')\n    36→};\n    37→\n    38→function randomSessionId() {\n    39→  const rand = Math.random().toString(36).slice(2, 10);\n    40→  return `web-${Date.now()}-${rand}`;\n    41→}\n    42→\n    43→function setStatus(text, state) {\n    44→  els.status.textContent = text;\n    45→  els.status.classList.remove('connected', 'error');\n    46→  if (state) els.status.classList.add(state);\n    47→}\n    48→\n    49→const CHAR_LIMIT = 8000;\n    50→const CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n    51→\n    52→function updateCharCounter() {\n    53→  const len = els.chatInput.value.length;\n    54→  els.charCounter.textContent = len;\n    55→  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n    56→}\n    57→\n    58→function setBusy(busy, text) {\n    59→  state.busy = busy;\n    60→  els.sendChatBtn.disabled = busy;\n    61→  els.takeScreenshotBtn.disabled = busy;\n    62→  els.runExecBtn.disabled = busy;\n    63→  setStatus(text);\n    64→}\n    65→\n    66→const TOAST_DURATION_MS = 3000;\n    67→const TOAST_FADE_MS = 300;\n    68→\n    69→function showToast(msg, type = 'info') {\n    70→  const toast = document.createElement('div');\n    71→  toast.className = `toast ${type}`;\n    72→  toast.textContent = msg;\n    73→  els.toastContainer.appendChild(toast);\n    74→\n    75→  setTimeout(() => {\n    76→    toast.classList.add('toast-fade-out');\n    77→    setTimeout(() => toast.remove(), TOAST_FADE_MS);\n    78→  }, TOAST_DURATION_MS);\n    79→}\n    80→\n    81→function saveSessionConfig() {\n    82→  localStorage.setItem(\n    83→    STORAGE_KEY,\n    84→    JSON.stringify({\n    85→      baseUrl: state.baseUrl,\n    86→      sessionId: state.sessionId\n    87→    })\n    88→  );\n    89→}\n    90→\n    91→function loadSessionConfig() {\n    92→  try {\n    93→    const raw = localStorage.getItem(STORAGE_KEY);\n    94→    if (!raw) {\n    95→      return;\n    96→    }\n    97→\n    98→    const parsed = JSON.parse(raw);\n    99→    if (typeof parsed.baseUrl === 'string') {\n   100→      state.baseUrl = parsed.baseUrl;\n   101→    }\n   102→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n   103→      state.sessionId = parsed.sessionId;\n   104→    }\n   105→  } catch {\n   106→    // ignore\n   107→  }\n   108→}\n   109→\n   110→function createMessageElement(role, text, isError = false, isHtml = false) {\n   111→  const item = document.createElement('div');\n   112→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n   113→\n   114→  const roleEl = document.createElement('span');\n   115→  roleEl.className = 'role';\n   116→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n   117→\n   118→  const body = document.createElement('div');\n   119→  body.className = 'body';\n   120→  if (isHtml) {\n   121→    body.innerHTML = text;\n   122→  } else {\n   123→    body.textContent = text;\n   124→  }\n   125→\n   126→  item.append(roleEl, body);\n   127→  return { item, body };\n   128→}\n   129→\n   130→function appendMessage(role, text, isError = false, isHtml = false) {\n   131→  const node = createMessageElement(role, text, isError, isHtml);\n   132→  els.chatMessages.appendChild(node.item);\n   133→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   134→  return node;\n   135→}\n   136→\n   137→function getApiUrl(path) {\n   138→  const base = state.baseUrl.trim();\n   139→  if (!base) {\n   140→    return path;\n   141→  }\n   142→  return `${base.replace(/\\/$/, '')}${path}`;\n   143→}\n   144→\n   145→function getEventsUrl() {\n   146→  const query = new URLSearchParams({\n   147→    channel: 'web',\n   148→    sessionId: state.sessionId\n   149→  }).toString();\n   150→\n   151→  return `${getApiUrl('/api/events')}?${query}`;\n   152→}\n   153→\n   154→function closeRealtime() {\n   155→  if (state.eventSource) {\n   156→    state.eventSource.close();\n   157→    state.eventSource = null;\n   158→  }\n   159→}\n   160→\n   161→// ── Command Autocomplete ──────────────────────────────────────────────────────\n   162→\n   163→let commandDropdown = null;\n   164→\n   165→function createCommandDropdown() {\n   166→  commandDropdown = document.createElement('div');\n   167→  commandDropdown.className = 'command-dropdown';\n   168→  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n   169→  els.chatForm.style.position = 'relative';\n   170→  els.chatForm.appendChild(commandDropdown);\n   171→}\n   172→\n   173→function showCommandDropdown(commands) {\n   174→  if (!commandDropdown) createCommandDropdown();\n   175→  commandDropdown.innerHTML = '';\n   176→\n   177→  if (commands.length === 0) {\n   178→    commandDropdown.style.display = 'none';\n   179→    state.commandDropdownVisible = false;\n   180→    return;\n   181→  }\n   182→\n   183→  commands.forEach((cmd) => {\n   184→    const item = document.createElement('div');\n   185→    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n   186→    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n   187→    item.addEventListener('mousedown', (e) => {\n   188→      e.preventDefault();\n   189→      els.chatInput.value = `/${cmd.name} `;\n   190→      hideCommandDropdown();\n   191→      els.chatInput.focus();\n   192→    });\n   193→    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n   194→    item.addEventListener('mouseout', () => { item.style.background = ''; });\n   195→    commandDropdown.appendChild(item);\n   196→  });\n   197→\n   198→  commandDropdown.style.display = 'block';\n   199→  state.commandDropdownVisible = true;\n   200→}\n   201→\n   202→function hideCommandDropdown() {\n   203→  if (commandDropdown) commandDropdown.style.display = 'none';\n   204→  state.commandDropdownVisible = false;\n   205→}\n   206→\n   207→function filterCommands(prefix) {\n   208→  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n   209→  return state.availableCommands.filter((cmd) => {\n   210→    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n   211→  });\n   212→}\n   213→\n   214→async function loadAvailableCommands() {\n   215→  try {\n   216→    const response = await fetch(getApiUrl('/api/commands'));\n   217→    const data = await response.json();\n   218→    if (data.ok && Array.isArray(data.commands)) {\n   219→      state.availableCommands = data.commands;\n   220→    }\n   221→  } catch {\n   222→    // Non-critical — autocomplete just won't work\n   223→  }\n   224→}\n   225→\n   226→function connectRealtime() {\n   227→  closeRealtime();\n   228→\n   229→  if (typeof EventSource === 'undefined') {\n   230→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   231→    return;\n   232→  }\n   233→\n   234→  const es = new EventSource(getEventsUrl());\n   235→  state.eventSource = es;\n   236→\n   237→  es.addEventListener('connected', () => {\n   238→    setStatus('实时通道已连接', 'connected');\n   239→  });\n   240→\n   241→  es.addEventListener('status', (event) => {\n   242→    const payload = JSON.parse(event.data);\n   243→    if (payload.stage === 'running') {\n   244→      setStatus('助手处理中...');\n   245→      return;\n   246→    }\n   247→\n   248→    if (payload.stage === 'accepted') {\n   249→      setStatus('已接收请求');\n   250→      return;\n   251→    }\n   252→\n   253→    setStatus('实时通道在线', 'connected');\n   254→  });\n   255→\n   256→  es.addEventListener('assistant_chunk', (event) => {\n   257→    const payload = JSON.parse(event.data);\n   258→\n   259→    if (!state.streamingMessageBody) {\n   260→      const node = appendMessage('assistant', '');\n   261→      state.streamingMessageBody = node.body;\n   262→      state.streamedText = '';\n   263→    }\n   264→\n   265→    state.streamedText += payload.text ?? '';\n   266→    state.streamingMessageBody.textContent = state.streamedText;\n   267→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   268→  });\n   269→\n   270→  es.addEventListener('assistant_done', (event) => {\n   271→    const payload = JSON.parse(event.data);\n   272→    if (state.streamingMessageBody) {\n   273→      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n   274→    } else if (payload.isCommand) {\n   275→      // Command result came via SSE (not via HTTP response) — render as HTML\n   276→      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n   277→    }\n   278→    setStatus('就绪');\n   279→  });\n   280→\n   281→  es.onerror = () => {\n   282→    setStatus('实时通道重连中...', 'error');\n   283→  };\n   284→}\n   285→\n   286→async function callJson(path, payload) {\n   287→  const response = await fetch(getApiUrl(path), {\n   288→    method: 'POST',\n   289→    headers: { 'Content-Type': 'application/json' },\n   290→    body: JSON.stringify(payload)\n   291→  });\n   292→\n   293→  const data = await response.json();\n   294→  if (!response.ok || !data.ok) {\n   295→    throw new Error(data.error || `请求失败: ${response.status}`);\n   296→  }\n   297→  return data;\n   298→}\n   299→\n   300→function normalizeZeroHost() {\n   301→  if (window.location.hostname !== '0.0.0.0') {\n   302→    return false;\n   303→  }\n   304→\n   305→  const nextUrl = new URL(window.location.href);\n   306→  nextUrl.hostname = '127.0.0.1';\n   307→  window.location.replace(nextUrl.toString());\n   308→  return true;\n   309→}\n   310→\n   311→function init() {\n   312→  if (normalizeZeroHost()) {\n   313→    return;\n   314→  }\n   315→\n   316→  loadSessionConfig();\n   317→\n   318→  if (!state.sessionId) {\n   319→    state.sessionId = randomSessionId();\n   320→  }\n   321→\n   322→  els.baseUrlInput.value = state.baseUrl;\n   323→  els.sessionIdInput.value = state.sessionId;\n   324→\n   325→  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n   326→  connectRealtime();\n   327→  loadAvailableCommands();\n   328→}\n   329→\n   330→els.baseUrlInput.addEventListener('change', () => {\n   331→  state.baseUrl = els.baseUrlInput.value.trim();\n   332→  saveSessionConfig();\n   333→  connectRealtime();\n   334→});\n   335→\n   336→els.sessionIdInput.addEventListener('change', () => {\n   337→  const value = els.sessionIdInput.value.trim();\n   338→  state.sessionId = value || randomSessionId();\n   339→  els.sessionIdInput.value = state.sessionId;\n   340→  saveSessionConfig();\n   341→  connectRealtime();\n   342→});\n   343→\n   344→els.clearChatBtn.addEventListener('click', () => {\n   345→  els.chatMessages.innerHTML = '';\n   346→  appendMessage('system', '界面消息已清空。');\n   347→});\n   348→\n   349→els.chatForm.addEventListener('submit', async (event) => {\n   350→  event.preventDefault();\n   351→  if (state.busy) return;\n   352→\n   353→  const message = els.chatInput.value.trim();\n   354→  if (!message) return;\n   355→\n   356→  appendMessage('user', message);\n   357→  els.chatInput.value = '';\n   358→  updateCharCounter();\n   359→\n   360→  state.streamingMessageBody = null;\n   361→  state.streamedText = '';\n   362→\n   363→  try {\n   364→    setBusy(true, '聊天处理中...');\n   365→    const data = await callJson('/api/chat', {\n   366→      channel: 'web',\n   367→      sessionId: state.sessionId,\n   368→      message\n   369→    });\n   370→\n   371→    if (!state.streamedText) {\n   372→      const isHtml = data.isCommand === true;\n   373→      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n   374→    }\n   375→    showToast('消息发送成功', 'success');\n   376→  } catch (error) {\n   377→    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n   378→    showToast(error instanceof Error ? error.message : String(error), 'error');\n   379→  } finally {\n   380→    state.streamingMessageBody = null;\n   381→    setBusy(false, '就绪');\n   382→  }\n   383→});\n   384→\n   385→els.chatInput.addEventListener('keydown', (event) => {\n   386→  if (event.key === 'Escape' && state.commandDropdownVisible) {\n   387→    hideCommandDropdown();\n   388→    return;\n   389→  }\n   390→  if (event.key === 'Enter' && !event.shiftKey) {\n   391→    event.preventDefault();\n   392→    hideCommandDropdown();\n   393→    els.chatForm.requestSubmit();\n   394→  }\n   395→});\n   396→\n   397→els.chatInput.addEventListener('input', () => {\n   398→  updateCharCounter();\n   399→  const value = els.chatInput.value;\n   400→  const firstWord = value.split(/\\s/)[0];\n   401→  if (firstWord.startsWith('/') && value === firstWord) {\n   402→    // User is still typing the command name (no space yet)\n   403→    const matches = filterCommands(firstWord);\n   404→    showCommandDropdown(matches);\n   405→  } else {\n   406→    hideCommandDropdown();\n   407→  }\n   408→});\n   409→\n   410→els.chatInput.addEventListener('blur', () => {\n   411→  // Delay hide to allow mousedown on dropdown item to fire first\n   412→  setTimeout(hideCommandDropdown, 150);\n   413→});\n   414→\n   415→function openLightbox(src) {\n   416→  els.lightboxImg.src = src;\n   417→  els.lightbox.classList.remove('hidden');\n   418→}\n   419→\n   420→function closeLightbox() {\n   421→  els.lightbox.classList.add('hidden');\n   422→  els.lightboxImg.src = '';\n   423→}\n   424→\n   425→els.screenshotImage.addEventListener('click', () => {\n   426→  if (!els.screenshotImage.classList.contains('hidden')) {\n   427→    openLightbox(els.screenshotImage.src);\n   428→  }\n   429→});\n   430→\n   431→els.lightbox.addEventListener('click', (event) => {\n   432→  if (event.target !== els.lightboxImg) {\n   433→    closeLightbox();\n   434→  }\n   435→});\n   436→\n   437→els.takeScreenshotBtn.addEventListener('click', async () => {\n   438→  if (state.busy) return;\n   439→\n   440→  try {\n   441→    setBusy(true, '正在获取截图...');\n   442→    const data = await callJson('/api/screenshot', {\n   443→      channel: 'web',\n   444→      sessionId: state.sessionId\n   445→    });\n   446→\n   447→    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n   448→    els.screenshotImage.classList.remove('hidden');\n   449→    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n   450→    showToast('截图获取成功', 'success');\n   451→  } catch (error) {\n   452→    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n   453→    showToast(error instanceof Error ? error.message : String(error), 'error');\n   454→  } finally {\n   455→    setBusy(false, '就绪');\n   456→  }\n   457→});\n   458→\n   459→els.execForm.addEventListener('submit', async (event) => {\n   460→  event.preventDefault();\n   461→  if (state.busy) return;\n   462→\n   463→  const command = els.execInput.value.trim();\n   464→  if (!command) return;\n   465→\n   466→  els.exitCodeOutput.classList.remove('exit-error');\n   467→  els.stderrOutput.classList.remove('error');\n   468→\n   469→  try {\n   470→    setBusy(true, '正在执行命令...');\n   471→    const data = await callJson('/api/system/exec', {\n   472→      channel: 'web',\n   473→      sessionId: state.sessionId,\n   474→      command\n   475→    });\n   476→\n   477→    els.exitCodeOutput.textContent = String(data.exitCode);\n   478→    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n   479→    els.stdoutOutput.textContent = data.stdout || '(empty)';\n   480→    els.stderrOutput.textContent = data.stderr || '(empty)';\n   481→    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n   482→    if (data.exitCode === 0) {\n   483→      showToast('命令执行成功', 'success');\n   484→    } else {\n   485→      showToast(`命令退出码: ${data.exitCode}`, 'error');\n   486→    }\n   487→  } catch (error) {\n   488→    const message = error instanceof Error ? error.message : String(error);\n   489→    els.exitCodeOutput.textContent = 'error';\n   490→    els.exitCodeOutput.classList.add('exit-error');\n   491→    els.stdoutOutput.textContent = '';\n   492→    els.stderrOutput.textContent = message;\n   493→    els.stderrOutput.classList.add('error');\n   494→    showToast(message, 'error');\n   495→  } finally {\n   496→    setBusy(false, '就绪');\n   497→  }\n   498→});\n   499→\n   500→window.addEventListener('beforeunload', () => {\n   501→  closeRealtime();\n   502→});\n   503→\n   504→document.addEventListener('keydown', (event) => {\n   505→  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n   506→    closeLightbox();\n   507→  }\n   508→});\n   509→\n   510→init();\n   511→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"6bb5196b-75e1-472a-b110-cdfea59927b4","uuid":"58a719bd-dfca-4efc-865d-0fd19db4163e","timestamp":"2026-03-23T00:48:23.235Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js","content":"const STORAGE_KEY = 'prizmclaw-web-session';\n\nconst state = {\n  baseUrl: '',\n  sessionId: '',\n  busy: false,\n  eventSource: null,\n  streamingMessageBody: null,\n  streamedText: '',\n  availableCommands: [],\n  commandDropdownVisible: false\n};\n\nconst els = {\n  status: document.getElementById('status'),\n  baseUrlInput: document.getElementById('baseUrlInput'),\n  sessionIdInput: document.getElementById('sessionIdInput'),\n  chatMessages: document.getElementById('chatMessages'),\n  chatForm: document.getElementById('chatForm'),\n  chatInput: document.getElementById('chatInput'),\n  charCounter: document.getElementById('charCounter'),\n  sendChatBtn: document.getElementById('sendChatBtn'),\n  clearChatBtn: document.getElementById('clearChatBtn'),\n  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n  screenshotImage: document.getElementById('screenshotImage'),\n  screenshotMeta: document.getElementById('screenshotMeta'),\n  lightbox: document.getElementById('lightbox'),\n  lightboxImg: document.getElementById('lightboxImg'),\n  execForm: document.getElementById('execForm'),\n  execInput: document.getElementById('execInput'),\n  runExecBtn: document.getElementById('runExecBtn'),\n  exitCodeOutput: document.getElementById('exitCodeOutput'),\n  stdoutOutput: document.getElementById('stdoutOutput'),\n  stderrOutput: document.getElementById('stderrOutput'),\n  toastContainer: document.getElementById('toast-container')\n};\n\nfunction randomSessionId() {\n  const rand = Math.random().toString(36).slice(2, 10);\n  return `web-${Date.now()}-${rand}`;\n}\n\nfunction setStatus(text, state) {\n  els.status.textContent = text;\n  els.status.classList.remove('connected', 'error');\n  if (state) els.status.classList.add(state);\n}\n\nconst CHAR_LIMIT = 8000;\nconst CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n\nfunction updateCharCounter() {\n  const len = els.chatInput.value.length;\n  els.charCounter.textContent = len;\n  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n}\n\nfunction setBusy(busy, text) {\n  state.busy = busy;\n  els.sendChatBtn.disabled = busy;\n  els.takeScreenshotBtn.disabled = busy;\n  els.runExecBtn.disabled = busy;\n  setStatus(text);\n}\n\nconst TOAST_DURATION_MS = 3000;\nconst TOAST_FADE_MS = 300;\n\nfunction showToast(msg, type = 'info') {\n  const toast = document.createElement('div');\n  toast.className = `toast ${type}`;\n  toast.textContent = msg;\n  els.toastContainer.appendChild(toast);\n\n  setTimeout(() => {\n    toast.classList.add('toast-fade-out');\n    setTimeout(() => toast.remove(), TOAST_FADE_MS);\n  }, TOAST_DURATION_MS);\n}\n\nfunction saveSessionConfig() {\n  localStorage.setItem(\n    STORAGE_KEY,\n    JSON.stringify({\n      baseUrl: state.baseUrl,\n      sessionId: state.sessionId\n    })\n  );\n}\n\nfunction loadSessionConfig() {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) {\n      return;\n    }\n\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.baseUrl === 'string') {\n      state.baseUrl = parsed.baseUrl;\n    }\n    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n      state.sessionId = parsed.sessionId;\n    }\n  } catch {\n    // ignore\n  }\n}\n\nfunction createMessageElement(role, text, isError = false, isHtml = false) {\n  const item = document.createElement('div');\n  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n\n  const roleEl = document.createElement('span');\n  roleEl.className = 'role';\n  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n\n  const body = document.createElement('div');\n  body.className = 'body';\n  if (isHtml) {\n    body.innerHTML = text;\n  } else {\n    body.textContent = text;\n  }\n\n  item.append(roleEl, body);\n  return { item, body };\n}\n\nfunction appendMessage(role, text, isError = false, isHtml = false) {\n  const node = createMessageElement(role, text, isError, isHtml);\n  els.chatMessages.appendChild(node.item);\n  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  return node;\n}\n\nfunction getApiUrl(path) {\n  const base = state.baseUrl.trim();\n  if (!base) {\n    return path;\n  }\n  return `${base.replace(/\\/$/, '')}${path}`;\n}\n\nfunction getEventsUrl() {\n  const query = new URLSearchParams({\n    channel: 'web',\n    sessionId: state.sessionId\n  }).toString();\n\n  return `${getApiUrl('/api/events')}?${query}`;\n}\n\nfunction closeRealtime() {\n  if (state.eventSource) {\n    state.eventSource.close();\n    state.eventSource = null;\n  }\n}\n\n// ── Command Autocomplete ──────────────────────────────────────────────────────\n\nlet commandDropdown = null;\n\nfunction createCommandDropdown() {\n  commandDropdown = document.createElement('div');\n  commandDropdown.className = 'command-dropdown';\n  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n  els.chatForm.style.position = 'relative';\n  els.chatForm.appendChild(commandDropdown);\n}\n\nfunction showCommandDropdown(commands) {\n  if (!commandDropdown) createCommandDropdown();\n  commandDropdown.innerHTML = '';\n\n  if (commands.length === 0) {\n    commandDropdown.style.display = 'none';\n    state.commandDropdownVisible = false;\n    return;\n  }\n\n  commands.forEach((cmd) => {\n    const item = document.createElement('div');\n    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n    item.addEventListener('mousedown', (e) => {\n      e.preventDefault();\n      els.chatInput.value = `/${cmd.name} `;\n      hideCommandDropdown();\n      els.chatInput.focus();\n    });\n    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n    item.addEventListener('mouseout', () => { item.style.background = ''; });\n    commandDropdown.appendChild(item);\n  });\n\n  commandDropdown.style.display = 'block';\n  state.commandDropdownVisible = true;\n}\n\nfunction hideCommandDropdown() {\n  if (commandDropdown) commandDropdown.style.display = 'none';\n  state.commandDropdownVisible = false;\n}\n\nfunction filterCommands(prefix) {\n  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n  return state.availableCommands.filter((cmd) => {\n    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n  });\n}\n\nasync function loadAvailableCommands() {\n  try {\n    const response = await fetch(getApiUrl('/api/commands'));\n    const data = await response.json();\n    if (data.ok && Array.isArray(data.commands)) {\n      state.availableCommands = data.commands;\n    }\n  } catch {\n    // Non-critical — autocomplete just won't work\n  }\n}\n\nfunction connectRealtime() {\n  closeRealtime();\n\n  if (typeof EventSource === 'undefined') {\n    setStatus('当前浏览器不支持实时推送（EventSource）');\n    return;\n  }\n\n  const es = new EventSource(getEventsUrl());\n  state.eventSource = es;\n\n  es.addEventListener('connected', () => {\n    setStatus('实时通道已连接', 'connected');\n  });\n\n  es.addEventListener('status', (event) => {\n    const payload = JSON.parse(event.data);\n    if (payload.stage === 'running') {\n      setStatus('助手处理中...');\n      return;\n    }\n\n    if (payload.stage === 'accepted') {\n      setStatus('已接收请求');\n      return;\n    }\n\n    setStatus('实时通道在线', 'connected');\n  });\n\n  es.addEventListener('assistant_chunk', (event) => {\n    const payload = JSON.parse(event.data);\n\n    if (!state.streamingMessageBody) {\n      const node = appendMessage('assistant', '');\n      state.streamingMessageBody = node.body;\n      state.streamedText = '';\n    }\n\n    state.streamedText += payload.text ?? '';\n    state.streamingMessageBody.textContent = state.streamedText;\n    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  });\n\n  es.addEventListener('assistant_done', (event) => {\n    const payload = JSON.parse(event.data);\n    if (state.streamingMessageBody) {\n      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n    } else if (payload.isCommand) {\n      // Command result came via SSE (not via HTTP response) — render as HTML\n      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n    }\n    setStatus('就绪');\n  });\n\n  es.onerror = () => {\n    setStatus('实时通道重连中...', 'error');\n  };\n}\n\nasync function callJson(path, payload) {\n  const response = await fetch(getApiUrl(path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n\n  const data = await response.json();\n  if (!response.ok || !data.ok) {\n    throw new Error(data.error || `请求失败: ${response.status}`);\n  }\n  return data;\n}\n\nfunction normalizeZeroHost() {\n  if (window.location.hostname !== '0.0.0.0') {\n    return false;\n  }\n\n  const nextUrl = new URL(window.location.href);\n  nextUrl.hostname = '127.0.0.1';\n  window.location.replace(nextUrl.toString());\n  return true;\n}\n\nfunction init() {\n  if (normalizeZeroHost()) {\n    return;\n  }\n\n  loadSessionConfig();\n\n  if (!state.sessionId) {\n    state.sessionId = randomSessionId();\n  }\n\n  els.baseUrlInput.value = state.baseUrl;\n  els.sessionIdInput.value = state.sessionId;\n\n  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n  connectRealtime();\n  loadAvailableCommands();\n}\n\nels.baseUrlInput.addEventListener('change', () => {\n  state.baseUrl = els.baseUrlInput.value.trim();\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.sessionIdInput.addEventListener('change', () => {\n  const value = els.sessionIdInput.value.trim();\n  state.sessionId = value || randomSessionId();\n  els.sessionIdInput.value = state.sessionId;\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.clearChatBtn.addEventListener('click', () => {\n  els.chatMessages.innerHTML = '';\n  appendMessage('system', '界面消息已清空。');\n});\n\nels.chatForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const message = els.chatInput.value.trim();\n  if (!message) return;\n\n  appendMessage('user', message);\n  els.chatInput.value = '';\n  updateCharCounter();\n\n  state.streamingMessageBody = null;\n  state.streamedText = '';\n\n  try {\n    setBusy(true, '聊天处理中...');\n    const data = await callJson('/api/chat', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      message\n    });\n\n    if (!state.streamedText) {\n      const isHtml = data.isCommand === true;\n      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n    }\n    showToast('消息发送成功', 'success');\n  } catch (error) {\n    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n    showToast(error instanceof Error ? error.message : String(error), 'error');\n  } finally {\n    state.streamingMessageBody = null;\n    setBusy(false, '就绪');\n  }\n});\n\nels.chatInput.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && state.commandDropdownVisible) {\n    hideCommandDropdown();\n    return;\n  }\n  if (event.key === 'Enter' && !event.shiftKey) {\n    event.preventDefault();\n    hideCommandDropdown();\n    els.chatForm.requestSubmit();\n  }\n});\n\nels.chatInput.addEventListener('input', () => {\n  updateCharCounter();\n  const value = els.chatInput.value;\n  const firstWord = value.split(/\\s/)[0];\n  if (firstWord.startsWith('/') && value === firstWord) {\n    // User is still typing the command name (no space yet)\n    const matches = filterCommands(firstWord);\n    showCommandDropdown(matches);\n  } else {\n    hideCommandDropdown();\n  }\n});\n\nels.chatInput.addEventListener('blur', () => {\n  // Delay hide to allow mousedown on dropdown item to fire first\n  setTimeout(hideCommandDropdown, 150);\n});\n\nfunction openLightbox(src) {\n  els.lightboxImg.src = src;\n  els.lightbox.classList.remove('hidden');\n}\n\nfunction closeLightbox() {\n  els.lightbox.classList.add('hidden');\n  els.lightboxImg.src = '';\n}\n\nels.screenshotImage.addEventListener('click', () => {\n  if (!els.screenshotImage.classList.contains('hidden')) {\n    openLightbox(els.screenshotImage.src);\n  }\n});\n\nels.lightbox.addEventListener('click', (event) => {\n  if (event.target !== els.lightboxImg) {\n    closeLightbox();\n  }\n});\n\nels.takeScreenshotBtn.addEventListener('click', async () => {\n  if (state.busy) return;\n\n  try {\n    setBusy(true, '正在获取截图...');\n    const data = await callJson('/api/screenshot', {\n      channel: 'web',\n      sessionId: state.sessionId\n    });\n\n    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n    els.screenshotImage.classList.remove('hidden');\n    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n    showToast('截图获取成功', 'success');\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n    showToast(error instanceof Error ? error.message : String(error), 'error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  els.exitCodeOutput.classList.remove('exit-error');\n  els.stderrOutput.classList.remove('error');\n\n  try {\n    setBusy(true, '正在执行命令...');\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n    if (data.exitCode === 0) {\n      showToast('命令执行成功', 'success');\n    } else {\n      showToast(`命令退出码: ${data.exitCode}`, 'error');\n    }\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    els.exitCodeOutput.textContent = 'error';\n    els.exitCodeOutput.classList.add('exit-error');\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n    els.stderrOutput.classList.add('error');\n    showToast(message, 'error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ndocument.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n    closeLightbox();\n  }\n});\n\ninit();\n","numLines":511,"startLine":1,"totalLines":511}}}
