{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01U9AAvRqKzzUGZidDAEvv9n","type":"tool_result","content":"     1→const STORAGE_KEY = 'prizmclaw-web-session';\n     2→\n     3→const state = {\n     4→  baseUrl: '',\n     5→  sessionId: '',\n     6→  busy: false,\n     7→  eventSource: null,\n     8→  streamingMessageBody: null,\n     9→  streamedText: '',\n    10→  availableCommands: [],\n    11→  commandDropdownVisible: false\n    12→};\n    13→\n    14→const els = {\n    15→  status: document.getElementById('status'),\n    16→  baseUrlInput: document.getElementById('baseUrlInput'),\n    17→  sessionIdInput: document.getElementById('sessionIdInput'),\n    18→  chatMessages: document.getElementById('chatMessages'),\n    19→  chatForm: document.getElementById('chatForm'),\n    20→  chatInput: document.getElementById('chatInput'),\n    21→  charCounter: document.getElementById('charCounter'),\n    22→  sendChatBtn: document.getElementById('sendChatBtn'),\n    23→  clearChatBtn: document.getElementById('clearChatBtn'),\n    24→  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n    25→  screenshotImage: document.getElementById('screenshotImage'),\n    26→  screenshotMeta: document.getElementById('screenshotMeta'),\n    27→  lightbox: document.getElementById('lightbox'),\n    28→  lightboxImg: document.getElementById('lightboxImg'),\n    29→  execForm: document.getElementById('execForm'),\n    30→  execInput: document.getElementById('execInput'),\n    31→  runExecBtn: document.getElementById('runExecBtn'),\n    32→  exitCodeOutput: document.getElementById('exitCodeOutput'),\n    33→  stdoutOutput: document.getElementById('stdoutOutput'),\n    34→  stderrOutput: document.getElementById('stderrOutput'),\n    35→  toastContainer: document.getElementById('toast-container')\n    36→};\n    37→\n    38→function randomSessionId() {\n    39→  const rand = Math.random().toString(36).slice(2, 10);\n    40→  return `web-${Date.now()}-${rand}`;\n    41→}\n    42→\n    43→function setStatus(text, state) {\n    44→  els.status.textContent = text;\n    45→  els.status.classList.remove('connected', 'error');\n    46→  if (state) els.status.classList.add(state);\n    47→}\n    48→\n    49→const CHAR_LIMIT = 8000;\n    50→const CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n    51→\n    52→function updateCharCounter() {\n    53→  const len = els.chatInput.value.length;\n    54→  els.charCounter.textContent = len;\n    55→  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n    56→}\n    57→\n    58→function setBusy(busy, text, activeBtn = null) {\n    59→  state.busy = busy;\n    60→  els.sendChatBtn.disabled = busy;\n    61→  els.takeScreenshotBtn.disabled = busy;\n    62→  els.runExecBtn.disabled = busy;\n    63→  if (busy && activeBtn) {\n    64→    activeBtn.classList.add('loading');\n    65→  } else if (!busy) {\n    66→    els.sendChatBtn.classList.remove('loading');\n    67→    els.takeScreenshotBtn.classList.remove('loading');\n    68→    els.runExecBtn.classList.remove('loading');\n    69→  }\n    70→  setStatus(text);\n    71→}\n    72→\n    73→const TOAST_DURATION_MS = 3000;\n    74→const TOAST_FADE_MS = 300;\n    75→\n    76→function showToast(msg, type = 'info') {\n    77→  const toast = document.createElement('div');\n    78→  toast.className = `toast ${type}`;\n    79→  toast.textContent = msg;\n    80→  els.toastContainer.appendChild(toast);\n    81→\n    82→  setTimeout(() => {\n    83→    toast.classList.add('toast-fade-out');\n    84→    setTimeout(() => toast.remove(), TOAST_FADE_MS);\n    85→  }, TOAST_DURATION_MS);\n    86→}\n    87→\n    88→function saveSessionConfig() {\n    89→  localStorage.setItem(\n    90→    STORAGE_KEY,\n    91→    JSON.stringify({\n    92→      baseUrl: state.baseUrl,\n    93→      sessionId: state.sessionId\n    94→    })\n    95→  );\n    96→}\n    97→\n    98→function loadSessionConfig() {\n    99→  try {\n   100→    const raw = localStorage.getItem(STORAGE_KEY);\n   101→    if (!raw) {\n   102→      return;\n   103→    }\n   104→\n   105→    const parsed = JSON.parse(raw);\n   106→    if (typeof parsed.baseUrl === 'string') {\n   107→      state.baseUrl = parsed.baseUrl;\n   108→    }\n   109→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n   110→      state.sessionId = parsed.sessionId;\n   111→    }\n   112→  } catch {\n   113→    // ignore\n   114→  }\n   115→}\n   116→\n   117→function createMessageElement(role, text, isError = false, isHtml = false) {\n   118→  const item = document.createElement('div');\n   119→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n   120→\n   121→  const roleEl = document.createElement('span');\n   122→  roleEl.className = 'role';\n   123→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n   124→\n   125→  const body = document.createElement('div');\n   126→  body.className = 'body';\n   127→  if (isHtml) {\n   128→    body.innerHTML = text;\n   129→  } else {\n   130→    body.textContent = text;\n   131→  }\n   132→\n   133→  item.append(roleEl, body);\n   134→  return { item, body };\n   135→}\n   136→\n   137→function appendMessage(role, text, isError = false, isHtml = false) {\n   138→  const node = createMessageElement(role, text, isError, isHtml);\n   139→  els.chatMessages.appendChild(node.item);\n   140→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   141→  return node;\n   142→}\n   143→\n   144→function getApiUrl(path) {\n   145→  const base = state.baseUrl.trim();\n   146→  if (!base) {\n   147→    return path;\n   148→  }\n   149→  return `${base.replace(/\\/$/, '')}${path}`;\n   150→}\n   151→\n   152→function getEventsUrl() {\n   153→  const query = new URLSearchParams({\n   154→    channel: 'web',\n   155→    sessionId: state.sessionId\n   156→  }).toString();\n   157→\n   158→  return `${getApiUrl('/api/events')}?${query}`;\n   159→}\n   160→\n   161→function closeRealtime() {\n   162→  if (state.eventSource) {\n   163→    state.eventSource.close();\n   164→    state.eventSource = null;\n   165→  }\n   166→}\n   167→\n   168→// ── Command Autocomplete ──────────────────────────────────────────────────────\n   169→\n   170→let commandDropdown = null;\n   171→\n   172→function createCommandDropdown() {\n   173→  commandDropdown = document.createElement('div');\n   174→  commandDropdown.className = 'command-dropdown';\n   175→  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n   176→  els.chatForm.style.position = 'relative';\n   177→  els.chatForm.appendChild(commandDropdown);\n   178→}\n   179→\n   180→function showCommandDropdown(commands) {\n   181→  if (!commandDropdown) createCommandDropdown();\n   182→  commandDropdown.innerHTML = '';\n   183→\n   184→  if (commands.length === 0) {\n   185→    commandDropdown.style.display = 'none';\n   186→    state.commandDropdownVisible = false;\n   187→    return;\n   188→  }\n   189→\n   190→  commands.forEach((cmd) => {\n   191→    const item = document.createElement('div');\n   192→    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n   193→    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n   194→    item.addEventListener('mousedown', (e) => {\n   195→      e.preventDefault();\n   196→      els.chatInput.value = `/${cmd.name} `;\n   197→      hideCommandDropdown();\n   198→      els.chatInput.focus();\n   199→    });\n   200→    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n   201→    item.addEventListener('mouseout', () => { item.style.background = ''; });\n   202→    commandDropdown.appendChild(item);\n   203→  });\n   204→\n   205→  commandDropdown.style.display = 'block';\n   206→  state.commandDropdownVisible = true;\n   207→}\n   208→\n   209→function hideCommandDropdown() {\n   210→  if (commandDropdown) commandDropdown.style.display = 'none';\n   211→  state.commandDropdownVisible = false;\n   212→}\n   213→\n   214→function filterCommands(prefix) {\n   215→  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n   216→  return state.availableCommands.filter((cmd) => {\n   217→    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n   218→  });\n   219→}\n   220→\n   221→async function loadAvailableCommands() {\n   222→  try {\n   223→    const response = await fetch(getApiUrl('/api/commands'));\n   224→    const data = await response.json();\n   225→    if (data.ok && Array.isArray(data.commands)) {\n   226→      state.availableCommands = data.commands;\n   227→    }\n   228→  } catch {\n   229→    // Non-critical — autocomplete just won't work\n   230→  }\n   231→}\n   232→\n   233→function connectRealtime() {\n   234→  closeRealtime();\n   235→\n   236→  if (typeof EventSource === 'undefined') {\n   237→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   238→    return;\n   239→  }\n   240→\n   241→  const es = new EventSource(getEventsUrl());\n   242→  state.eventSource = es;\n   243→\n   244→  es.addEventListener('connected', () => {\n   245→    setStatus('实时通道已连接', 'connected');\n   246→  });\n   247→\n   248→  es.addEventListener('status', (event) => {\n   249→    const payload = JSON.parse(event.data);\n   250→    if (payload.stage === 'running') {\n   251→      setStatus('助手处理中...');\n   252→      return;\n   253→    }\n   254→\n   255→    if (payload.stage === 'accepted') {\n   256→      setStatus('已接收请求');\n   257→      return;\n   258→    }\n   259→\n   260→    setStatus('实时通道在线', 'connected');\n   261→  });\n   262→\n   263→  es.addEventListener('assistant_chunk', (event) => {\n   264→    const payload = JSON.parse(event.data);\n   265→\n   266→    if (!state.streamingMessageBody) {\n   267→      const node = appendMessage('assistant', '');\n   268→      state.streamingMessageBody = node.body;\n   269→      state.streamedText = '';\n   270→    }\n   271→\n   272→    state.streamedText += payload.text ?? '';\n   273→    state.streamingMessageBody.textContent = state.streamedText;\n   274→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   275→  });\n   276→\n   277→  es.addEventListener('assistant_done', (event) => {\n   278→    const payload = JSON.parse(event.data);\n   279→    if (state.streamingMessageBody) {\n   280→      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n   281→    } else if (payload.isCommand) {\n   282→      // Command result came via SSE (not via HTTP response) — render as HTML\n   283→      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n   284→    }\n   285→    setStatus('就绪');\n   286→  });\n   287→\n   288→  es.onerror = () => {\n   289→    setStatus('实时通道重连中...', 'error');\n   290→  };\n   291→}\n   292→\n   293→async function callJson(path, payload) {\n   294→  const response = await fetch(getApiUrl(path), {\n   295→    method: 'POST',\n   296→    headers: { 'Content-Type': 'application/json' },\n   297→    body: JSON.stringify(payload)\n   298→  });\n   299→\n   300→  const data = await response.json();\n   301→  if (!response.ok || !data.ok) {\n   302→    throw new Error(data.error || `请求失败: ${response.status}`);\n   303→  }\n   304→  return data;\n   305→}\n   306→\n   307→function normalizeZeroHost() {\n   308→  if (window.location.hostname !== '0.0.0.0') {\n   309→    return false;\n   310→  }\n   311→\n   312→  const nextUrl = new URL(window.location.href);\n   313→  nextUrl.hostname = '127.0.0.1';\n   314→  window.location.replace(nextUrl.toString());\n   315→  return true;\n   316→}\n   317→\n   318→function init() {\n   319→  if (normalizeZeroHost()) {\n   320→    return;\n   321→  }\n   322→\n   323→  loadSessionConfig();\n   324→\n   325→  if (!state.sessionId) {\n   326→    state.sessionId = randomSessionId();\n   327→  }\n   328→\n   329→  els.baseUrlInput.value = state.baseUrl;\n   330→  els.sessionIdInput.value = state.sessionId;\n   331→\n   332→  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n   333→  connectRealtime();\n   334→  loadAvailableCommands();\n   335→}\n   336→\n   337→els.baseUrlInput.addEventListener('change', () => {\n   338→  state.baseUrl = els.baseUrlInput.value.trim();\n   339→  saveSessionConfig();\n   340→  connectRealtime();\n   341→});\n   342→\n   343→els.sessionIdInput.addEventListener('change', () => {\n   344→  const value = els.sessionIdInput.value.trim();\n   345→  state.sessionId = value || randomSessionId();\n   346→  els.sessionIdInput.value = state.sessionId;\n   347→  saveSessionConfig();\n   348→  connectRealtime();\n   349→});\n   350→\n   351→els.clearChatBtn.addEventListener('click', () => {\n   352→  els.chatMessages.innerHTML = '';\n   353→  appendMessage('system', '界面消息已清空。');\n   354→});\n   355→\n   356→els.chatForm.addEventListener('submit', async (event) => {\n   357→  event.preventDefault();\n   358→  if (state.busy) return;\n   359→\n   360→  const message = els.chatInput.value.trim();\n   361→  if (!message) return;\n   362→\n   363→  appendMessage('user', message);\n   364→  els.chatInput.value = '';\n   365→  updateCharCounter();\n   366→\n   367→  state.streamingMessageBody = null;\n   368→  state.streamedText = '';\n   369→\n   370→  try {\n   371→    setBusy(true, '聊天处理中...', els.sendChatBtn);\n   372→    const data = await callJson('/api/chat', {\n   373→      channel: 'web',\n   374→      sessionId: state.sessionId,\n   375→      message\n   376→    });\n   377→\n   378→    if (!state.streamedText) {\n   379→      const isHtml = data.isCommand === true;\n   380→      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n   381→    }\n   382→    showToast('消息发送成功', 'success');\n   383→  } catch (error) {\n   384→    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n   385→    showToast(error instanceof Error ? error.message : String(error), 'error');\n   386→  } finally {\n   387→    state.streamingMessageBody = null;\n   388→    setBusy(false, '就绪');\n   389→  }\n   390→});\n   391→\n   392→els.chatInput.addEventListener('keydown', (event) => {\n   393→  if (event.key === 'Escape' && state.commandDropdownVisible) {\n   394→    hideCommandDropdown();\n   395→    return;\n   396→  }\n   397→  if (event.key === 'Enter' && !event.shiftKey) {\n   398→    event.preventDefault();\n   399→    hideCommandDropdown();\n   400→    els.chatForm.requestSubmit();\n   401→  }\n   402→});\n   403→\n   404→els.chatInput.addEventListener('input', () => {\n   405→  updateCharCounter();\n   406→  const value = els.chatInput.value;\n   407→  const firstWord = value.split(/\\s/)[0];\n   408→  if (firstWord.startsWith('/') && value === firstWord) {\n   409→    // User is still typing the command name (no space yet)\n   410→    const matches = filterCommands(firstWord);\n   411→    showCommandDropdown(matches);\n   412→  } else {\n   413→    hideCommandDropdown();\n   414→  }\n   415→});\n   416→\n   417→els.chatInput.addEventListener('blur', () => {\n   418→  // Delay hide to allow mousedown on dropdown item to fire first\n   419→  setTimeout(hideCommandDropdown, 150);\n   420→});\n   421→\n   422→function openLightbox(src) {\n   423→  els.lightboxImg.src = src;\n   424→  els.lightbox.classList.remove('hidden');\n   425→}\n   426→\n   427→function closeLightbox() {\n   428→  els.lightbox.classList.add('hidden');\n   429→  els.lightboxImg.src = '';\n   430→}\n   431→\n   432→els.screenshotImage.addEventListener('click', () => {\n   433→  if (!els.screenshotImage.classList.contains('hidden')) {\n   434→    openLightbox(els.screenshotImage.src);\n   435→  }\n   436→});\n   437→\n   438→els.lightbox.addEventListener('click', (event) => {\n   439→  if (event.target !== els.lightboxImg) {\n   440→    closeLightbox();\n   441→  }\n   442→});\n   443→\n   444→els.takeScreenshotBtn.addEventListener('click', async () => {\n   445→  if (state.busy) return;\n   446→\n   447→  try {\n   448→    setBusy(true, '正在获取截图...', els.takeScreenshotBtn);\n   449→    const data = await callJson('/api/screenshot', {\n   450→      channel: 'web',\n   451→      sessionId: state.sessionId\n   452→    });\n   453→\n   454→    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n   455→    els.screenshotImage.classList.remove('hidden');\n   456→    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n   457→    showToast('截图获取成功', 'success');\n   458→  } catch (error) {\n   459→    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n   460→    showToast(error instanceof Error ? error.message : String(error), 'error');\n   461→  } finally {\n   462→    setBusy(false, '就绪');\n   463→  }\n   464→});\n   465→\n   466→els.execForm.addEventListener('submit', async (event) => {\n   467→  event.preventDefault();\n   468→  if (state.busy) return;\n   469→\n   470→  const command = els.execInput.value.trim();\n   471→  if (!command) return;\n   472→\n   473→  els.exitCodeOutput.classList.remove('exit-error');\n   474→  els.stderrOutput.classList.remove('error');\n   475→\n   476→  try {\n   477→    setBusy(true, '正在执行命令...', els.runExecBtn);\n   478→    const data = await callJson('/api/system/exec', {\n   479→      channel: 'web',\n   480→      sessionId: state.sessionId,\n   481→      command\n   482→    });\n   483→\n   484→    els.exitCodeOutput.textContent = String(data.exitCode);\n   485→    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n   486→    els.stdoutOutput.textContent = data.stdout || '(empty)';\n   487→    els.stderrOutput.textContent = data.stderr || '(empty)';\n   488→    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n   489→    if (data.exitCode === 0) {\n   490→      showToast('命令执行成功', 'success');\n   491→    } else {\n   492→      showToast(`命令退出码: ${data.exitCode}`, 'error');\n   493→    }\n   494→  } catch (error) {\n   495→    const message = error instanceof Error ? error.message : String(error);\n   496→    els.exitCodeOutput.textContent = 'error';\n   497→    els.exitCodeOutput.classList.add('exit-error');\n   498→    els.stdoutOutput.textContent = '';\n   499→    els.stderrOutput.textContent = message;\n   500→    els.stderrOutput.classList.add('error');\n   501→    showToast(message, 'error');\n   502→  } finally {\n   503→    setBusy(false, '就绪');\n   504→  }\n   505→});\n   506→\n   507→window.addEventListener('beforeunload', () => {\n   508→  closeRealtime();\n   509→});\n   510→\n   511→document.addEventListener('keydown', (event) => {\n   512→  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n   513→    closeLightbox();\n   514→  }\n   515→});\n   516→\n   517→init();\n   518→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"f6f738e2-f5e7-49d7-b2b4-a9da541bb42b","uuid":"8c6bcb05-1868-4755-9912-e236ec635327","timestamp":"2026-03-23T01:00:47.679Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js","content":"const STORAGE_KEY = 'prizmclaw-web-session';\n\nconst state = {\n  baseUrl: '',\n  sessionId: '',\n  busy: false,\n  eventSource: null,\n  streamingMessageBody: null,\n  streamedText: '',\n  availableCommands: [],\n  commandDropdownVisible: false\n};\n\nconst els = {\n  status: document.getElementById('status'),\n  baseUrlInput: document.getElementById('baseUrlInput'),\n  sessionIdInput: document.getElementById('sessionIdInput'),\n  chatMessages: document.getElementById('chatMessages'),\n  chatForm: document.getElementById('chatForm'),\n  chatInput: document.getElementById('chatInput'),\n  charCounter: document.getElementById('charCounter'),\n  sendChatBtn: document.getElementById('sendChatBtn'),\n  clearChatBtn: document.getElementById('clearChatBtn'),\n  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n  screenshotImage: document.getElementById('screenshotImage'),\n  screenshotMeta: document.getElementById('screenshotMeta'),\n  lightbox: document.getElementById('lightbox'),\n  lightboxImg: document.getElementById('lightboxImg'),\n  execForm: document.getElementById('execForm'),\n  execInput: document.getElementById('execInput'),\n  runExecBtn: document.getElementById('runExecBtn'),\n  exitCodeOutput: document.getElementById('exitCodeOutput'),\n  stdoutOutput: document.getElementById('stdoutOutput'),\n  stderrOutput: document.getElementById('stderrOutput'),\n  toastContainer: document.getElementById('toast-container')\n};\n\nfunction randomSessionId() {\n  const rand = Math.random().toString(36).slice(2, 10);\n  return `web-${Date.now()}-${rand}`;\n}\n\nfunction setStatus(text, state) {\n  els.status.textContent = text;\n  els.status.classList.remove('connected', 'error');\n  if (state) els.status.classList.add(state);\n}\n\nconst CHAR_LIMIT = 8000;\nconst CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n\nfunction updateCharCounter() {\n  const len = els.chatInput.value.length;\n  els.charCounter.textContent = len;\n  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n}\n\nfunction setBusy(busy, text, activeBtn = null) {\n  state.busy = busy;\n  els.sendChatBtn.disabled = busy;\n  els.takeScreenshotBtn.disabled = busy;\n  els.runExecBtn.disabled = busy;\n  if (busy && activeBtn) {\n    activeBtn.classList.add('loading');\n  } else if (!busy) {\n    els.sendChatBtn.classList.remove('loading');\n    els.takeScreenshotBtn.classList.remove('loading');\n    els.runExecBtn.classList.remove('loading');\n  }\n  setStatus(text);\n}\n\nconst TOAST_DURATION_MS = 3000;\nconst TOAST_FADE_MS = 300;\n\nfunction showToast(msg, type = 'info') {\n  const toast = document.createElement('div');\n  toast.className = `toast ${type}`;\n  toast.textContent = msg;\n  els.toastContainer.appendChild(toast);\n\n  setTimeout(() => {\n    toast.classList.add('toast-fade-out');\n    setTimeout(() => toast.remove(), TOAST_FADE_MS);\n  }, TOAST_DURATION_MS);\n}\n\nfunction saveSessionConfig() {\n  localStorage.setItem(\n    STORAGE_KEY,\n    JSON.stringify({\n      baseUrl: state.baseUrl,\n      sessionId: state.sessionId\n    })\n  );\n}\n\nfunction loadSessionConfig() {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) {\n      return;\n    }\n\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.baseUrl === 'string') {\n      state.baseUrl = parsed.baseUrl;\n    }\n    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n      state.sessionId = parsed.sessionId;\n    }\n  } catch {\n    // ignore\n  }\n}\n\nfunction createMessageElement(role, text, isError = false, isHtml = false) {\n  const item = document.createElement('div');\n  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n\n  const roleEl = document.createElement('span');\n  roleEl.className = 'role';\n  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n\n  const body = document.createElement('div');\n  body.className = 'body';\n  if (isHtml) {\n    body.innerHTML = text;\n  } else {\n    body.textContent = text;\n  }\n\n  item.append(roleEl, body);\n  return { item, body };\n}\n\nfunction appendMessage(role, text, isError = false, isHtml = false) {\n  const node = createMessageElement(role, text, isError, isHtml);\n  els.chatMessages.appendChild(node.item);\n  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  return node;\n}\n\nfunction getApiUrl(path) {\n  const base = state.baseUrl.trim();\n  if (!base) {\n    return path;\n  }\n  return `${base.replace(/\\/$/, '')}${path}`;\n}\n\nfunction getEventsUrl() {\n  const query = new URLSearchParams({\n    channel: 'web',\n    sessionId: state.sessionId\n  }).toString();\n\n  return `${getApiUrl('/api/events')}?${query}`;\n}\n\nfunction closeRealtime() {\n  if (state.eventSource) {\n    state.eventSource.close();\n    state.eventSource = null;\n  }\n}\n\n// ── Command Autocomplete ──────────────────────────────────────────────────────\n\nlet commandDropdown = null;\n\nfunction createCommandDropdown() {\n  commandDropdown = document.createElement('div');\n  commandDropdown.className = 'command-dropdown';\n  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n  els.chatForm.style.position = 'relative';\n  els.chatForm.appendChild(commandDropdown);\n}\n\nfunction showCommandDropdown(commands) {\n  if (!commandDropdown) createCommandDropdown();\n  commandDropdown.innerHTML = '';\n\n  if (commands.length === 0) {\n    commandDropdown.style.display = 'none';\n    state.commandDropdownVisible = false;\n    return;\n  }\n\n  commands.forEach((cmd) => {\n    const item = document.createElement('div');\n    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n    item.addEventListener('mousedown', (e) => {\n      e.preventDefault();\n      els.chatInput.value = `/${cmd.name} `;\n      hideCommandDropdown();\n      els.chatInput.focus();\n    });\n    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n    item.addEventListener('mouseout', () => { item.style.background = ''; });\n    commandDropdown.appendChild(item);\n  });\n\n  commandDropdown.style.display = 'block';\n  state.commandDropdownVisible = true;\n}\n\nfunction hideCommandDropdown() {\n  if (commandDropdown) commandDropdown.style.display = 'none';\n  state.commandDropdownVisible = false;\n}\n\nfunction filterCommands(prefix) {\n  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n  return state.availableCommands.filter((cmd) => {\n    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n  });\n}\n\nasync function loadAvailableCommands() {\n  try {\n    const response = await fetch(getApiUrl('/api/commands'));\n    const data = await response.json();\n    if (data.ok && Array.isArray(data.commands)) {\n      state.availableCommands = data.commands;\n    }\n  } catch {\n    // Non-critical — autocomplete just won't work\n  }\n}\n\nfunction connectRealtime() {\n  closeRealtime();\n\n  if (typeof EventSource === 'undefined') {\n    setStatus('当前浏览器不支持实时推送（EventSource）');\n    return;\n  }\n\n  const es = new EventSource(getEventsUrl());\n  state.eventSource = es;\n\n  es.addEventListener('connected', () => {\n    setStatus('实时通道已连接', 'connected');\n  });\n\n  es.addEventListener('status', (event) => {\n    const payload = JSON.parse(event.data);\n    if (payload.stage === 'running') {\n      setStatus('助手处理中...');\n      return;\n    }\n\n    if (payload.stage === 'accepted') {\n      setStatus('已接收请求');\n      return;\n    }\n\n    setStatus('实时通道在线', 'connected');\n  });\n\n  es.addEventListener('assistant_chunk', (event) => {\n    const payload = JSON.parse(event.data);\n\n    if (!state.streamingMessageBody) {\n      const node = appendMessage('assistant', '');\n      state.streamingMessageBody = node.body;\n      state.streamedText = '';\n    }\n\n    state.streamedText += payload.text ?? '';\n    state.streamingMessageBody.textContent = state.streamedText;\n    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  });\n\n  es.addEventListener('assistant_done', (event) => {\n    const payload = JSON.parse(event.data);\n    if (state.streamingMessageBody) {\n      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n    } else if (payload.isCommand) {\n      // Command result came via SSE (not via HTTP response) — render as HTML\n      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n    }\n    setStatus('就绪');\n  });\n\n  es.onerror = () => {\n    setStatus('实时通道重连中...', 'error');\n  };\n}\n\nasync function callJson(path, payload) {\n  const response = await fetch(getApiUrl(path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n\n  const data = await response.json();\n  if (!response.ok || !data.ok) {\n    throw new Error(data.error || `请求失败: ${response.status}`);\n  }\n  return data;\n}\n\nfunction normalizeZeroHost() {\n  if (window.location.hostname !== '0.0.0.0') {\n    return false;\n  }\n\n  const nextUrl = new URL(window.location.href);\n  nextUrl.hostname = '127.0.0.1';\n  window.location.replace(nextUrl.toString());\n  return true;\n}\n\nfunction init() {\n  if (normalizeZeroHost()) {\n    return;\n  }\n\n  loadSessionConfig();\n\n  if (!state.sessionId) {\n    state.sessionId = randomSessionId();\n  }\n\n  els.baseUrlInput.value = state.baseUrl;\n  els.sessionIdInput.value = state.sessionId;\n\n  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n  connectRealtime();\n  loadAvailableCommands();\n}\n\nels.baseUrlInput.addEventListener('change', () => {\n  state.baseUrl = els.baseUrlInput.value.trim();\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.sessionIdInput.addEventListener('change', () => {\n  const value = els.sessionIdInput.value.trim();\n  state.sessionId = value || randomSessionId();\n  els.sessionIdInput.value = state.sessionId;\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.clearChatBtn.addEventListener('click', () => {\n  els.chatMessages.innerHTML = '';\n  appendMessage('system', '界面消息已清空。');\n});\n\nels.chatForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const message = els.chatInput.value.trim();\n  if (!message) return;\n\n  appendMessage('user', message);\n  els.chatInput.value = '';\n  updateCharCounter();\n\n  state.streamingMessageBody = null;\n  state.streamedText = '';\n\n  try {\n    setBusy(true, '聊天处理中...', els.sendChatBtn);\n    const data = await callJson('/api/chat', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      message\n    });\n\n    if (!state.streamedText) {\n      const isHtml = data.isCommand === true;\n      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n    }\n    showToast('消息发送成功', 'success');\n  } catch (error) {\n    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n    showToast(error instanceof Error ? error.message : String(error), 'error');\n  } finally {\n    state.streamingMessageBody = null;\n    setBusy(false, '就绪');\n  }\n});\n\nels.chatInput.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && state.commandDropdownVisible) {\n    hideCommandDropdown();\n    return;\n  }\n  if (event.key === 'Enter' && !event.shiftKey) {\n    event.preventDefault();\n    hideCommandDropdown();\n    els.chatForm.requestSubmit();\n  }\n});\n\nels.chatInput.addEventListener('input', () => {\n  updateCharCounter();\n  const value = els.chatInput.value;\n  const firstWord = value.split(/\\s/)[0];\n  if (firstWord.startsWith('/') && value === firstWord) {\n    // User is still typing the command name (no space yet)\n    const matches = filterCommands(firstWord);\n    showCommandDropdown(matches);\n  } else {\n    hideCommandDropdown();\n  }\n});\n\nels.chatInput.addEventListener('blur', () => {\n  // Delay hide to allow mousedown on dropdown item to fire first\n  setTimeout(hideCommandDropdown, 150);\n});\n\nfunction openLightbox(src) {\n  els.lightboxImg.src = src;\n  els.lightbox.classList.remove('hidden');\n}\n\nfunction closeLightbox() {\n  els.lightbox.classList.add('hidden');\n  els.lightboxImg.src = '';\n}\n\nels.screenshotImage.addEventListener('click', () => {\n  if (!els.screenshotImage.classList.contains('hidden')) {\n    openLightbox(els.screenshotImage.src);\n  }\n});\n\nels.lightbox.addEventListener('click', (event) => {\n  if (event.target !== els.lightboxImg) {\n    closeLightbox();\n  }\n});\n\nels.takeScreenshotBtn.addEventListener('click', async () => {\n  if (state.busy) return;\n\n  try {\n    setBusy(true, '正在获取截图...', els.takeScreenshotBtn);\n    const data = await callJson('/api/screenshot', {\n      channel: 'web',\n      sessionId: state.sessionId\n    });\n\n    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n    els.screenshotImage.classList.remove('hidden');\n    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n    showToast('截图获取成功', 'success');\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n    showToast(error instanceof Error ? error.message : String(error), 'error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  els.exitCodeOutput.classList.remove('exit-error');\n  els.stderrOutput.classList.remove('error');\n\n  try {\n    setBusy(true, '正在执行命令...', els.runExecBtn);\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n    if (data.exitCode === 0) {\n      showToast('命令执行成功', 'success');\n    } else {\n      showToast(`命令退出码: ${data.exitCode}`, 'error');\n    }\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    els.exitCodeOutput.textContent = 'error';\n    els.exitCodeOutput.classList.add('exit-error');\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n    els.stderrOutput.classList.add('error');\n    showToast(message, 'error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ndocument.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n    closeLightbox();\n  }\n});\n\ninit();\n","numLines":518,"startLine":1,"totalLines":518}}}
