\"chatForm\" class=\"chat-form\">","originalFile":"<!doctype html>\n<html lang=\"zh-CN\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>PrizmClaw 管理台</title>\n    <link rel=\"stylesheet\" href=\"./styles.css\" />\n  </head>\n  <body>\n    <div class=\"app-shell\">\n      <header class=\"app-header\">\n        <div>\n          <h1>PrizmClaw 管理台</h1>\n          <p class=\"subtitle\">聊天、截图、系统命令执行</p>\n        </div>\n        <div id=\"status\" class=\"status\" role=\"status\" aria-live=\"polite\">就绪</div>\n      </header>\n\n      <section class=\"panel config-panel\">\n        <h2>连接设置</h2>\n        <div class=\"form-grid\">\n          <label>\n            API Base URL（可选）\n            <input id=\"baseUrlInput\" type=\"text\" placeholder=\"留空表示同源，例如 http://127.0.0.1:3000\" />\n          </label>\n          <label>\n            Session ID\n            <input id=\"sessionIdInput\" type=\"text\" placeholder=\"默认自动生成，可手动修改\" />\n          </label>\n        </div>\n      </section>\n\n      <main class=\"dashboard-grid\">\n        <section class=\"panel chat-panel\">\n          <div class=\"panel-head\">\n            <h2>双向聊天</h2>\n            <button id=\"clearChatBtn\" type=\"button\" class=\"btn ghost\">清空界面消息</button>\n          </div>\n\n          <div id=\"chatMessages\" class=\"chat-messages\" aria-live=\"polite\">\n            <div id=\"chatEmptyState\" class=\"empty-state\">\n              <span class=\"empty-state-icon\">💬</span>\n              <span class=\"empty-state-title\">还没有消息</span>\n              <span class=\"empty-state-hint\">在下方输入内容，开始与助手对话</span>\n            </div>\n          </div>\n\n          <form id=\"chatForm\" class=\"chat-form\">\n            <label class=\"sr-only\" for=\"chatInput\">输入消息</label>\n            <textarea id=\"chatInput\" rows=\"3\" placeholder=\"请输入对话\"></textarea>\n            <div class=\"char-counter\"><span id=\"charCounter\">0</span> / 8000</div>\n            <div class=\"chat-form-actions\">\n              <button id=\"sendChatBtn\" type=\"submit\" class=\"btn primary\">发送</button>\n              <kbd class=\"kbd\">Ctrl+Enter</kbd>\n            </div>\n          </form>\n        </section>\n\n        <section class=\"panel side-panel\">\n          <section class=\"sub-panel\">\n            <h2>一键截图</h2>\n            <p class=\"hint\">调用 <code>POST /api/screenshot</code> 并展示图片结果。</p>\n            <button id=\"takeScreenshotBtn\" type=\"button\" class=\"btn primary\">获取截图</button>\n            <img id=\"screenshotImage\" class=\"screenshot-image hidden\" alt=\"截图预览\" />\n            <pre id=\"screenshotMeta\" class=\"output-box\"></pre>\n          </section>\n\n          <section class=\"sub-panel\">\n            <h2>系统命令</h2>\n            <p class=\"hint\">调用 <code>POST /api/system/exec</code>，展示 stdout/stderr/exit code。</p>\n            <form id=\"execForm\" class=\"exec-form\">\n              <label class=\"sr-only\" for=\"execInput\">输入系统命令</label>\n              <input id=\"execInput\" type=\"text\" placeholder=\"例如：pwd\" />\n              <div class=\"exec-form-actions\">\n                <button id=\"runExecBtn\" type=\"submit\" class=\"btn warning\">执行</button>\n                <kbd class=\"kbd\">Enter</kbd>\n              </div>\n            </form>\n            <div class=\"exec-result\">\n              <div id=\"execEmptyState\" class=\"empty-state\">\n                <span class=\"empty-state-icon\">⚡</span>\n                <span class=\"empty-state-title\">尚未执行命令</span>\n                <span class=\"empty-state-hint\">在上方输入命令并点击执行</span>\n              </div>\n              <div id=\"execOutput\" class=\"hidden\">\n                <div>\n                  <h3>Exit Code</h3>\n                  <pre id=\"exitCodeOutput\" class=\"output-box\">-</pre>\n                </div>\n                <div>\n                  <h3>Stdout</h3>\n                  <pre id=\"stdoutOutput\" class=\"output-box\"></pre>\n                </div>\n                <div>\n                  <h3>Stderr</h3>\n                  <pre id=\"stderrOutput\" class=\"output-box\"></pre>\n                </div>\n              </div>\n            </div>\n          </section>\n        </section>\n      </main>\n    </div>\n\n    <div id=\"lightbox\" class=\"lightbox hidden\" role=\"dialog\" aria-modal=\"true\" aria-label=\"截图放大预览\">\n      <img id=\"lightboxImg\" class=\"lightbox-img\" alt=\"截图放大预览\" />\n    </div>\n\n    <div id=\"toast-container\" class=\"toast-container\" role=\"status\" aria-live=\"polite\"></div>\n\n    <script type=\"module\" src=\"./js/main.js\"></script>\n  </body>\n</html>\n","structuredPatch":[{"oldStart":37,"oldLines":12,"newStart":37,"newLines":15,"lines":["             <button id=\"clearChatBtn\" type=\"button\" class=\"btn ghost\">清空界面消息</button>","           </div>"," ","-          <div id=\"chatMessages\" class=\"chat-messages\" aria-live=\"polite\">","-            <div id=\"chatEmptyState\" class=\"empty-state\">","-              <span class=\"empty-state-icon\">💬</span>","-              <span class=\"empty-state-title\">还没有消息</span>","-              <span class=\"empty-state-hint\">在下方输入内容，开始与助手对话</span>","+          <div class=\"chat-messages-wrapper\">","+            <div id=\"chatMessages\" class=\"chat-messages\" aria-live=\"polite\">","+              <div id=\"chatEmptyState\" class=\"empty-state\">","+                <span class=\"empty-state-icon\">💬</span>","+                <span class=\"empty-state-title\">还没有消息</span>","+                <span class=\"empty-state-hint\">在下方输入内容，开始与助手对话</span>","+              </div>","             </div>","+            <button id=\"scrollToBottomBtn\" type=\"button\" class=\"scroll-to-bottom\" aria-label=\"滚动到底部\" title=\"滚动到底部\">↓</button>","           </div>"," ","           <form id=\"chatForm\" class=\"chat-form\">"]}],"userModified":false,"replaceAll":false}}
