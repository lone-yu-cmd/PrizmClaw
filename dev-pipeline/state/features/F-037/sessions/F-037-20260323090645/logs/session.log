{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_vrtx_01SqwZxdVqSHMeTpeBMrjgcf","type":"tool_result","content":"     1→const STORAGE_KEY = 'prizmclaw-web-session';\n     2→\n     3→const state = {\n     4→  baseUrl: '',\n     5→  sessionId: '',\n     6→  busy: false,\n     7→  eventSource: null,\n     8→  streamingMessageBody: null,\n     9→  streamedText: '',\n    10→  availableCommands: [],\n    11→  commandDropdownVisible: false\n    12→};\n    13→\n    14→const els = {\n    15→  status: document.getElementById('status'),\n    16→  baseUrlInput: document.getElementById('baseUrlInput'),\n    17→  sessionIdInput: document.getElementById('sessionIdInput'),\n    18→  chatMessages: document.getElementById('chatMessages'),\n    19→  chatEmptyState: document.getElementById('chatEmptyState'),\n    20→  chatForm: document.getElementById('chatForm'),\n    21→  chatInput: document.getElementById('chatInput'),\n    22→  charCounter: document.getElementById('charCounter'),\n    23→  sendChatBtn: document.getElementById('sendChatBtn'),\n    24→  clearChatBtn: document.getElementById('clearChatBtn'),\n    25→  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n    26→  screenshotImage: document.getElementById('screenshotImage'),\n    27→  screenshotMeta: document.getElementById('screenshotMeta'),\n    28→  lightbox: document.getElementById('lightbox'),\n    29→  lightboxImg: document.getElementById('lightboxImg'),\n    30→  execForm: document.getElementById('execForm'),\n    31→  execInput: document.getElementById('execInput'),\n    32→  runExecBtn: document.getElementById('runExecBtn'),\n    33→  execEmptyState: document.getElementById('execEmptyState'),\n    34→  execOutput: document.getElementById('execOutput'),\n    35→  exitCodeOutput: document.getElementById('exitCodeOutput'),\n    36→  stdoutOutput: document.getElementById('stdoutOutput'),\n    37→  stderrOutput: document.getElementById('stderrOutput'),\n    38→  toastContainer: document.getElementById('toast-container')\n    39→};\n    40→\n    41→function randomSessionId() {\n    42→  const rand = Math.random().toString(36).slice(2, 10);\n    43→  return `web-${Date.now()}-${rand}`;\n    44→}\n    45→\n    46→function setStatus(text, state) {\n    47→  els.status.textContent = text;\n    48→  els.status.classList.remove('connected', 'error');\n    49→  if (state) els.status.classList.add(state);\n    50→}\n    51→\n    52→const CHAR_LIMIT = 8000;\n    53→const CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n    54→\n    55→function updateCharCounter() {\n    56→  const len = els.chatInput.value.length;\n    57→  els.charCounter.textContent = len;\n    58→  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n    59→}\n    60→\n    61→function setBusy(busy, text, activeBtn = null) {\n    62→  state.busy = busy;\n    63→  els.sendChatBtn.disabled = busy;\n    64→  els.takeScreenshotBtn.disabled = busy;\n    65→  els.runExecBtn.disabled = busy;\n    66→  if (busy && activeBtn) {\n    67→    activeBtn.classList.add('loading');\n    68→  } else if (!busy) {\n    69→    els.sendChatBtn.classList.remove('loading');\n    70→    els.takeScreenshotBtn.classList.remove('loading');\n    71→    els.runExecBtn.classList.remove('loading');\n    72→  }\n    73→  setStatus(text);\n    74→}\n    75→\n    76→const TOAST_DURATION_MS = 3000;\n    77→const TOAST_FADE_MS = 300;\n    78→\n    79→function updateChatEmptyState() {\n    80→  // Only hide empty state when user or assistant messages are present\n    81→  const hasMessages =\n    82→    els.chatMessages.querySelector('.message.user, .message.assistant') !== null;\n    83→  els.chatEmptyState.classList.toggle('hidden', hasMessages);\n    84→}\n    85→\n    86→function updateExecEmptyState(hasResult) {\n    87→  els.execEmptyState.classList.toggle('hidden', hasResult);\n    88→  els.execOutput.classList.toggle('hidden', !hasResult);\n    89→}\n    90→\n    91→function showToast(msg, type = 'info') {\n    92→  const toast = document.createElement('div');\n    93→  toast.className = `toast ${type}`;\n    94→  toast.textContent = msg;\n    95→  els.toastContainer.appendChild(toast);\n    96→\n    97→  setTimeout(() => {\n    98→    toast.classList.add('toast-fade-out');\n    99→    setTimeout(() => toast.remove(), TOAST_FADE_MS);\n   100→  }, TOAST_DURATION_MS);\n   101→}\n   102→\n   103→function saveSessionConfig() {\n   104→  localStorage.setItem(\n   105→    STORAGE_KEY,\n   106→    JSON.stringify({\n   107→      baseUrl: state.baseUrl,\n   108→      sessionId: state.sessionId\n   109→    })\n   110→  );\n   111→}\n   112→\n   113→function loadSessionConfig() {\n   114→  try {\n   115→    const raw = localStorage.getItem(STORAGE_KEY);\n   116→    if (!raw) {\n   117→      return;\n   118→    }\n   119→\n   120→    const parsed = JSON.parse(raw);\n   121→    if (typeof parsed.baseUrl === 'string') {\n   122→      state.baseUrl = parsed.baseUrl;\n   123→    }\n   124→    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n   125→      state.sessionId = parsed.sessionId;\n   126→    }\n   127→  } catch {\n   128→    // ignore\n   129→  }\n   130→}\n   131→\n   132→function createMessageElement(role, text, isError = false, isHtml = false) {\n   133→  const item = document.createElement('div');\n   134→  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n   135→\n   136→  const roleEl = document.createElement('span');\n   137→  roleEl.className = 'role';\n   138→  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n   139→\n   140→  const body = document.createElement('div');\n   141→  body.className = 'body';\n   142→  if (isHtml) {\n   143→    body.innerHTML = text;\n   144→  } else {\n   145→    body.textContent = text;\n   146→  }\n   147→\n   148→  item.append(roleEl, body);\n   149→  return { item, body };\n   150→}\n   151→\n   152→function appendMessage(role, text, isError = false, isHtml = false) {\n   153→  const node = createMessageElement(role, text, isError, isHtml);\n   154→  els.chatMessages.appendChild(node.item);\n   155→  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   156→  updateChatEmptyState();\n   157→  return node;\n   158→}\n   159→\n   160→function getApiUrl(path) {\n   161→  const base = state.baseUrl.trim();\n   162→  if (!base) {\n   163→    return path;\n   164→  }\n   165→  return `${base.replace(/\\/$/, '')}${path}`;\n   166→}\n   167→\n   168→function getEventsUrl() {\n   169→  const query = new URLSearchParams({\n   170→    channel: 'web',\n   171→    sessionId: state.sessionId\n   172→  }).toString();\n   173→\n   174→  return `${getApiUrl('/api/events')}?${query}`;\n   175→}\n   176→\n   177→function closeRealtime() {\n   178→  if (state.eventSource) {\n   179→    state.eventSource.close();\n   180→    state.eventSource = null;\n   181→  }\n   182→}\n   183→\n   184→// ── Command Autocomplete ──────────────────────────────────────────────────────\n   185→\n   186→let commandDropdown = null;\n   187→\n   188→function createCommandDropdown() {\n   189→  commandDropdown = document.createElement('div');\n   190→  commandDropdown.className = 'command-dropdown';\n   191→  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n   192→  els.chatForm.style.position = 'relative';\n   193→  els.chatForm.appendChild(commandDropdown);\n   194→}\n   195→\n   196→function showCommandDropdown(commands) {\n   197→  if (!commandDropdown) createCommandDropdown();\n   198→  commandDropdown.innerHTML = '';\n   199→\n   200→  if (commands.length === 0) {\n   201→    commandDropdown.style.display = 'none';\n   202→    state.commandDropdownVisible = false;\n   203→    return;\n   204→  }\n   205→\n   206→  commands.forEach((cmd) => {\n   207→    const item = document.createElement('div');\n   208→    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n   209→    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n   210→    item.addEventListener('mousedown', (e) => {\n   211→      e.preventDefault();\n   212→      els.chatInput.value = `/${cmd.name} `;\n   213→      hideCommandDropdown();\n   214→      els.chatInput.focus();\n   215→    });\n   216→    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n   217→    item.addEventListener('mouseout', () => { item.style.background = ''; });\n   218→    commandDropdown.appendChild(item);\n   219→  });\n   220→\n   221→  commandDropdown.style.display = 'block';\n   222→  state.commandDropdownVisible = true;\n   223→}\n   224→\n   225→function hideCommandDropdown() {\n   226→  if (commandDropdown) commandDropdown.style.display = 'none';\n   227→  state.commandDropdownVisible = false;\n   228→}\n   229→\n   230→function filterCommands(prefix) {\n   231→  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n   232→  return state.availableCommands.filter((cmd) => {\n   233→    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n   234→  });\n   235→}\n   236→\n   237→async function loadAvailableCommands() {\n   238→  try {\n   239→    const response = await fetch(getApiUrl('/api/commands'));\n   240→    const data = await response.json();\n   241→    if (data.ok && Array.isArray(data.commands)) {\n   242→      state.availableCommands = data.commands;\n   243→    }\n   244→  } catch {\n   245→    // Non-critical — autocomplete just won't work\n   246→  }\n   247→}\n   248→\n   249→function connectRealtime() {\n   250→  closeRealtime();\n   251→\n   252→  if (typeof EventSource === 'undefined') {\n   253→    setStatus('当前浏览器不支持实时推送（EventSource）');\n   254→    return;\n   255→  }\n   256→\n   257→  const es = new EventSource(getEventsUrl());\n   258→  state.eventSource = es;\n   259→\n   260→  es.addEventListener('connected', () => {\n   261→    setStatus('实时通道已连接', 'connected');\n   262→  });\n   263→\n   264→  es.addEventListener('status', (event) => {\n   265→    const payload = JSON.parse(event.data);\n   266→    if (payload.stage === 'running') {\n   267→      setStatus('助手处理中...');\n   268→      return;\n   269→    }\n   270→\n   271→    if (payload.stage === 'accepted') {\n   272→      setStatus('已接收请求');\n   273→      return;\n   274→    }\n   275→\n   276→    setStatus('实时通道在线', 'connected');\n   277→  });\n   278→\n   279→  es.addEventListener('assistant_chunk', (event) => {\n   280→    const payload = JSON.parse(event.data);\n   281→\n   282→    if (!state.streamingMessageBody) {\n   283→      const node = appendMessage('assistant', '');\n   284→      state.streamingMessageBody = node.body;\n   285→      state.streamedText = '';\n   286→    }\n   287→\n   288→    state.streamedText += payload.text ?? '';\n   289→    state.streamingMessageBody.textContent = state.streamedText;\n   290→    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n   291→  });\n   292→\n   293→  es.addEventListener('assistant_done', (event) => {\n   294→    const payload = JSON.parse(event.data);\n   295→    if (state.streamingMessageBody) {\n   296→      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n   297→    } else if (payload.isCommand) {\n   298→      // Command result came via SSE (not via HTTP response) — render as HTML\n   299→      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n   300→    }\n   301→    setStatus('就绪');\n   302→  });\n   303→\n   304→  es.onerror = () => {\n   305→    setStatus('实时通道重连中...', 'error');\n   306→  };\n   307→}\n   308→\n   309→async function callJson(path, payload) {\n   310→  const response = await fetch(getApiUrl(path), {\n   311→    method: 'POST',\n   312→    headers: { 'Content-Type': 'application/json' },\n   313→    body: JSON.stringify(payload)\n   314→  });\n   315→\n   316→  const data = await response.json();\n   317→  if (!response.ok || !data.ok) {\n   318→    throw new Error(data.error || `请求失败: ${response.status}`);\n   319→  }\n   320→  return data;\n   321→}\n   322→\n   323→function normalizeZeroHost() {\n   324→  if (window.location.hostname !== '0.0.0.0') {\n   325→    return false;\n   326→  }\n   327→\n   328→  const nextUrl = new URL(window.location.href);\n   329→  nextUrl.hostname = '127.0.0.1';\n   330→  window.location.replace(nextUrl.toString());\n   331→  return true;\n   332→}\n   333→\n   334→function init() {\n   335→  if (normalizeZeroHost()) {\n   336→    return;\n   337→  }\n   338→\n   339→  loadSessionConfig();\n   340→\n   341→  if (!state.sessionId) {\n   342→    state.sessionId = randomSessionId();\n   343→  }\n   344→\n   345→  els.baseUrlInput.value = state.baseUrl;\n   346→  els.sessionIdInput.value = state.sessionId;\n   347→\n   348→  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n   349→  connectRealtime();\n   350→  loadAvailableCommands();\n   351→}\n   352→\n   353→els.baseUrlInput.addEventListener('change', () => {\n   354→  state.baseUrl = els.baseUrlInput.value.trim();\n   355→  saveSessionConfig();\n   356→  connectRealtime();\n   357→});\n   358→\n   359→els.sessionIdInput.addEventListener('change', () => {\n   360→  const value = els.sessionIdInput.value.trim();\n   361→  state.sessionId = value || randomSessionId();\n   362→  els.sessionIdInput.value = state.sessionId;\n   363→  saveSessionConfig();\n   364→  connectRealtime();\n   365→});\n   366→\n   367→els.clearChatBtn.addEventListener('click', () => {\n   368→  els.chatMessages.innerHTML = '';\n   369→  els.chatMessages.appendChild(els.chatEmptyState);\n   370→  appendMessage('system', '界面消息已清空。');\n   371→});\n   372→\n   373→els.chatForm.addEventListener('submit', async (event) => {\n   374→  event.preventDefault();\n   375→  if (state.busy) return;\n   376→\n   377→  const message = els.chatInput.value.trim();\n   378→  if (!message) return;\n   379→\n   380→  appendMessage('user', message);\n   381→  els.chatInput.value = '';\n   382→  updateCharCounter();\n   383→\n   384→  state.streamingMessageBody = null;\n   385→  state.streamedText = '';\n   386→\n   387→  try {\n   388→    setBusy(true, '聊天处理中...', els.sendChatBtn);\n   389→    const data = await callJson('/api/chat', {\n   390→      channel: 'web',\n   391→      sessionId: state.sessionId,\n   392→      message\n   393→    });\n   394→\n   395→    if (!state.streamedText) {\n   396→      const isHtml = data.isCommand === true;\n   397→      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n   398→    }\n   399→    showToast('消息发送成功', 'success');\n   400→  } catch (error) {\n   401→    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n   402→    showToast(error instanceof Error ? error.message : String(error), 'error');\n   403→  } finally {\n   404→    state.streamingMessageBody = null;\n   405→    setBusy(false, '就绪');\n   406→  }\n   407→});\n   408→\n   409→els.chatInput.addEventListener('keydown', (event) => {\n   410→  if (event.key === 'Escape' && state.commandDropdownVisible) {\n   411→    hideCommandDropdown();\n   412→    return;\n   413→  }\n   414→  if (event.key === 'Enter' && !event.shiftKey) {\n   415→    event.preventDefault();\n   416→    hideCommandDropdown();\n   417→    els.chatForm.requestSubmit();\n   418→  }\n   419→});\n   420→\n   421→els.chatInput.addEventListener('input', () => {\n   422→  updateCharCounter();\n   423→  const value = els.chatInput.value;\n   424→  const firstWord = value.split(/\\s/)[0];\n   425→  if (firstWord.startsWith('/') && value === firstWord) {\n   426→    // User is still typing the command name (no space yet)\n   427→    const matches = filterCommands(firstWord);\n   428→    showCommandDropdown(matches);\n   429→  } else {\n   430→    hideCommandDropdown();\n   431→  }\n   432→});\n   433→\n   434→els.chatInput.addEventListener('blur', () => {\n   435→  // Delay hide to allow mousedown on dropdown item to fire first\n   436→  setTimeout(hideCommandDropdown, 150);\n   437→});\n   438→\n   439→function openLightbox(src) {\n   440→  els.lightboxImg.src = src;\n   441→  els.lightbox.classList.remove('hidden');\n   442→}\n   443→\n   444→function closeLightbox() {\n   445→  els.lightbox.classList.add('hidden');\n   446→  els.lightboxImg.src = '';\n   447→}\n   448→\n   449→els.screenshotImage.addEventListener('click', () => {\n   450→  if (!els.screenshotImage.classList.contains('hidden')) {\n   451→    openLightbox(els.screenshotImage.src);\n   452→  }\n   453→});\n   454→\n   455→els.lightbox.addEventListener('click', (event) => {\n   456→  if (event.target !== els.lightboxImg) {\n   457→    closeLightbox();\n   458→  }\n   459→});\n   460→\n   461→els.takeScreenshotBtn.addEventListener('click', async () => {\n   462→  if (state.busy) return;\n   463→\n   464→  try {\n   465→    setBusy(true, '正在获取截图...', els.takeScreenshotBtn);\n   466→    const data = await callJson('/api/screenshot', {\n   467→      channel: 'web',\n   468→      sessionId: state.sessionId\n   469→    });\n   470→\n   471→    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n   472→    els.screenshotImage.classList.remove('hidden');\n   473→    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n   474→    showToast('截图获取成功', 'success');\n   475→  } catch (error) {\n   476→    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n   477→    showToast(error instanceof Error ? error.message : String(error), 'error');\n   478→  } finally {\n   479→    setBusy(false, '就绪');\n   480→  }\n   481→});\n   482→\n   483→els.execForm.addEventListener('submit', async (event) => {\n   484→  event.preventDefault();\n   485→  if (state.busy) return;\n   486→\n   487→  const command = els.execInput.value.trim();\n   488→  if (!command) return;\n   489→\n   490→  els.exitCodeOutput.classList.remove('exit-error');\n   491→  els.stderrOutput.classList.remove('error');\n   492→\n   493→  try {\n   494→    setBusy(true, '正在执行命令...', els.runExecBtn);\n   495→    const data = await callJson('/api/system/exec', {\n   496→      channel: 'web',\n   497→      sessionId: state.sessionId,\n   498→      command\n   499→    });\n   500→\n   501→    updateExecEmptyState(true);\n   502→    els.exitCodeOutput.textContent = String(data.exitCode);\n   503→    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n   504→    els.stdoutOutput.textContent = data.stdout || '(empty)';\n   505→    els.stderrOutput.textContent = data.stderr || '(empty)';\n   506→    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n   507→    if (data.exitCode === 0) {\n   508→      showToast('命令执行成功', 'success');\n   509→    } else {\n   510→      showToast(`命令退出码: ${data.exitCode}`, 'error');\n   511→    }\n   512→  } catch (error) {\n   513→    const message = error instanceof Error ? error.message : String(error);\n   514→    updateExecEmptyState(true);\n   515→    els.exitCodeOutput.textContent = 'error';\n   516→    els.exitCodeOutput.classList.add('exit-error');\n   517→    els.stdoutOutput.textContent = '';\n   518→    els.stderrOutput.textContent = message;\n   519→    els.stderrOutput.classList.add('error');\n   520→    showToast(message, 'error');\n   521→  } finally {\n   522→    setBusy(false, '就绪');\n   523→  }\n   524→});\n   525→\n   526→window.addEventListener('beforeunload', () => {\n   527→  closeRealtime();\n   528→});\n   529→\n   530→document.addEventListener('keydown', (event) => {\n   531→  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n   532→    closeLightbox();\n   533→  }\n   534→});\n   535→\n   536→init();\n   537→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"78c8041e-009b-4fab-9cfe-213bac7e54d7","uuid":"7f539294-5a60-4567-9ecf-e2919605d880","timestamp":"2026-03-23T01:07:13.582Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/js/main.js","content":"const STORAGE_KEY = 'prizmclaw-web-session';\n\nconst state = {\n  baseUrl: '',\n  sessionId: '',\n  busy: false,\n  eventSource: null,\n  streamingMessageBody: null,\n  streamedText: '',\n  availableCommands: [],\n  commandDropdownVisible: false\n};\n\nconst els = {\n  status: document.getElementById('status'),\n  baseUrlInput: document.getElementById('baseUrlInput'),\n  sessionIdInput: document.getElementById('sessionIdInput'),\n  chatMessages: document.getElementById('chatMessages'),\n  chatEmptyState: document.getElementById('chatEmptyState'),\n  chatForm: document.getElementById('chatForm'),\n  chatInput: document.getElementById('chatInput'),\n  charCounter: document.getElementById('charCounter'),\n  sendChatBtn: document.getElementById('sendChatBtn'),\n  clearChatBtn: document.getElementById('clearChatBtn'),\n  takeScreenshotBtn: document.getElementById('takeScreenshotBtn'),\n  screenshotImage: document.getElementById('screenshotImage'),\n  screenshotMeta: document.getElementById('screenshotMeta'),\n  lightbox: document.getElementById('lightbox'),\n  lightboxImg: document.getElementById('lightboxImg'),\n  execForm: document.getElementById('execForm'),\n  execInput: document.getElementById('execInput'),\n  runExecBtn: document.getElementById('runExecBtn'),\n  execEmptyState: document.getElementById('execEmptyState'),\n  execOutput: document.getElementById('execOutput'),\n  exitCodeOutput: document.getElementById('exitCodeOutput'),\n  stdoutOutput: document.getElementById('stdoutOutput'),\n  stderrOutput: document.getElementById('stderrOutput'),\n  toastContainer: document.getElementById('toast-container')\n};\n\nfunction randomSessionId() {\n  const rand = Math.random().toString(36).slice(2, 10);\n  return `web-${Date.now()}-${rand}`;\n}\n\nfunction setStatus(text, state) {\n  els.status.textContent = text;\n  els.status.classList.remove('connected', 'error');\n  if (state) els.status.classList.add(state);\n}\n\nconst CHAR_LIMIT = 8000;\nconst CHAR_WARN_THRESHOLD = CHAR_LIMIT * 0.8;\n\nfunction updateCharCounter() {\n  const len = els.chatInput.value.length;\n  els.charCounter.textContent = len;\n  els.charCounter.parentElement.classList.toggle('warning', len >= CHAR_WARN_THRESHOLD);\n}\n\nfunction setBusy(busy, text, activeBtn = null) {\n  state.busy = busy;\n  els.sendChatBtn.disabled = busy;\n  els.takeScreenshotBtn.disabled = busy;\n  els.runExecBtn.disabled = busy;\n  if (busy && activeBtn) {\n    activeBtn.classList.add('loading');\n  } else if (!busy) {\n    els.sendChatBtn.classList.remove('loading');\n    els.takeScreenshotBtn.classList.remove('loading');\n    els.runExecBtn.classList.remove('loading');\n  }\n  setStatus(text);\n}\n\nconst TOAST_DURATION_MS = 3000;\nconst TOAST_FADE_MS = 300;\n\nfunction updateChatEmptyState() {\n  // Only hide empty state when user or assistant messages are present\n  const hasMessages =\n    els.chatMessages.querySelector('.message.user, .message.assistant') !== null;\n  els.chatEmptyState.classList.toggle('hidden', hasMessages);\n}\n\nfunction updateExecEmptyState(hasResult) {\n  els.execEmptyState.classList.toggle('hidden', hasResult);\n  els.execOutput.classList.toggle('hidden', !hasResult);\n}\n\nfunction showToast(msg, type = 'info') {\n  const toast = document.createElement('div');\n  toast.className = `toast ${type}`;\n  toast.textContent = msg;\n  els.toastContainer.appendChild(toast);\n\n  setTimeout(() => {\n    toast.classList.add('toast-fade-out');\n    setTimeout(() => toast.remove(), TOAST_FADE_MS);\n  }, TOAST_DURATION_MS);\n}\n\nfunction saveSessionConfig() {\n  localStorage.setItem(\n    STORAGE_KEY,\n    JSON.stringify({\n      baseUrl: state.baseUrl,\n      sessionId: state.sessionId\n    })\n  );\n}\n\nfunction loadSessionConfig() {\n  try {\n    const raw = localStorage.getItem(STORAGE_KEY);\n    if (!raw) {\n      return;\n    }\n\n    const parsed = JSON.parse(raw);\n    if (typeof parsed.baseUrl === 'string') {\n      state.baseUrl = parsed.baseUrl;\n    }\n    if (typeof parsed.sessionId === 'string' && parsed.sessionId.trim()) {\n      state.sessionId = parsed.sessionId;\n    }\n  } catch {\n    // ignore\n  }\n}\n\nfunction createMessageElement(role, text, isError = false, isHtml = false) {\n  const item = document.createElement('div');\n  item.className = `message ${role} ${isError ? 'error' : ''}`.trim();\n\n  const roleEl = document.createElement('span');\n  roleEl.className = 'role';\n  roleEl.textContent = role === 'user' ? '你' : role === 'assistant' ? '助手' : '系统';\n\n  const body = document.createElement('div');\n  body.className = 'body';\n  if (isHtml) {\n    body.innerHTML = text;\n  } else {\n    body.textContent = text;\n  }\n\n  item.append(roleEl, body);\n  return { item, body };\n}\n\nfunction appendMessage(role, text, isError = false, isHtml = false) {\n  const node = createMessageElement(role, text, isError, isHtml);\n  els.chatMessages.appendChild(node.item);\n  els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  updateChatEmptyState();\n  return node;\n}\n\nfunction getApiUrl(path) {\n  const base = state.baseUrl.trim();\n  if (!base) {\n    return path;\n  }\n  return `${base.replace(/\\/$/, '')}${path}`;\n}\n\nfunction getEventsUrl() {\n  const query = new URLSearchParams({\n    channel: 'web',\n    sessionId: state.sessionId\n  }).toString();\n\n  return `${getApiUrl('/api/events')}?${query}`;\n}\n\nfunction closeRealtime() {\n  if (state.eventSource) {\n    state.eventSource.close();\n    state.eventSource = null;\n  }\n}\n\n// ── Command Autocomplete ──────────────────────────────────────────────────────\n\nlet commandDropdown = null;\n\nfunction createCommandDropdown() {\n  commandDropdown = document.createElement('div');\n  commandDropdown.className = 'command-dropdown';\n  commandDropdown.style.cssText = 'position:absolute;background:#1e1e2e;border:1px solid #444;border-radius:4px;max-height:200px;overflow-y:auto;z-index:100;width:100%;box-sizing:border-box;display:none;';\n  els.chatForm.style.position = 'relative';\n  els.chatForm.appendChild(commandDropdown);\n}\n\nfunction showCommandDropdown(commands) {\n  if (!commandDropdown) createCommandDropdown();\n  commandDropdown.innerHTML = '';\n\n  if (commands.length === 0) {\n    commandDropdown.style.display = 'none';\n    state.commandDropdownVisible = false;\n    return;\n  }\n\n  commands.forEach((cmd) => {\n    const item = document.createElement('div');\n    item.style.cssText = 'padding:6px 10px;cursor:pointer;font-family:monospace;font-size:13px;';\n    item.innerHTML = `<strong>/${cmd.name}</strong> — ${cmd.description}`;\n    item.addEventListener('mousedown', (e) => {\n      e.preventDefault();\n      els.chatInput.value = `/${cmd.name} `;\n      hideCommandDropdown();\n      els.chatInput.focus();\n    });\n    item.addEventListener('mouseover', () => { item.style.background = '#313244'; });\n    item.addEventListener('mouseout', () => { item.style.background = ''; });\n    commandDropdown.appendChild(item);\n  });\n\n  commandDropdown.style.display = 'block';\n  state.commandDropdownVisible = true;\n}\n\nfunction hideCommandDropdown() {\n  if (commandDropdown) commandDropdown.style.display = 'none';\n  state.commandDropdownVisible = false;\n}\n\nfunction filterCommands(prefix) {\n  const query = prefix.slice(1).toLowerCase(); // Remove leading /\n  return state.availableCommands.filter((cmd) => {\n    return cmd.name.startsWith(query) || (cmd.aliases || []).some((a) => a.startsWith(query));\n  });\n}\n\nasync function loadAvailableCommands() {\n  try {\n    const response = await fetch(getApiUrl('/api/commands'));\n    const data = await response.json();\n    if (data.ok && Array.isArray(data.commands)) {\n      state.availableCommands = data.commands;\n    }\n  } catch {\n    // Non-critical — autocomplete just won't work\n  }\n}\n\nfunction connectRealtime() {\n  closeRealtime();\n\n  if (typeof EventSource === 'undefined') {\n    setStatus('当前浏览器不支持实时推送（EventSource）');\n    return;\n  }\n\n  const es = new EventSource(getEventsUrl());\n  state.eventSource = es;\n\n  es.addEventListener('connected', () => {\n    setStatus('实时通道已连接', 'connected');\n  });\n\n  es.addEventListener('status', (event) => {\n    const payload = JSON.parse(event.data);\n    if (payload.stage === 'running') {\n      setStatus('助手处理中...');\n      return;\n    }\n\n    if (payload.stage === 'accepted') {\n      setStatus('已接收请求');\n      return;\n    }\n\n    setStatus('实时通道在线', 'connected');\n  });\n\n  es.addEventListener('assistant_chunk', (event) => {\n    const payload = JSON.parse(event.data);\n\n    if (!state.streamingMessageBody) {\n      const node = appendMessage('assistant', '');\n      state.streamingMessageBody = node.body;\n      state.streamedText = '';\n    }\n\n    state.streamedText += payload.text ?? '';\n    state.streamingMessageBody.textContent = state.streamedText;\n    els.chatMessages.scrollTop = els.chatMessages.scrollHeight;\n  });\n\n  es.addEventListener('assistant_done', (event) => {\n    const payload = JSON.parse(event.data);\n    if (state.streamingMessageBody) {\n      state.streamingMessageBody.textContent = payload.reply ?? state.streamedText;\n    } else if (payload.isCommand) {\n      // Command result came via SSE (not via HTTP response) — render as HTML\n      appendMessage('assistant', payload.reply || '(命令已执行)', false, true);\n    }\n    setStatus('就绪');\n  });\n\n  es.onerror = () => {\n    setStatus('实时通道重连中...', 'error');\n  };\n}\n\nasync function callJson(path, payload) {\n  const response = await fetch(getApiUrl(path), {\n    method: 'POST',\n    headers: { 'Content-Type': 'application/json' },\n    body: JSON.stringify(payload)\n  });\n\n  const data = await response.json();\n  if (!response.ok || !data.ok) {\n    throw new Error(data.error || `请求失败: ${response.status}`);\n  }\n  return data;\n}\n\nfunction normalizeZeroHost() {\n  if (window.location.hostname !== '0.0.0.0') {\n    return false;\n  }\n\n  const nextUrl = new URL(window.location.href);\n  nextUrl.hostname = '127.0.0.1';\n  window.location.replace(nextUrl.toString());\n  return true;\n}\n\nfunction init() {\n  if (normalizeZeroHost()) {\n    return;\n  }\n\n  loadSessionConfig();\n\n  if (!state.sessionId) {\n    state.sessionId = randomSessionId();\n  }\n\n  els.baseUrlInput.value = state.baseUrl;\n  els.sessionIdInput.value = state.sessionId;\n\n  appendMessage('system', '欢迎使用 PrizmClaw。你可以聊天、抓取截图、执行受控系统命令。输入 / 查看可用命令。');\n  connectRealtime();\n  loadAvailableCommands();\n}\n\nels.baseUrlInput.addEventListener('change', () => {\n  state.baseUrl = els.baseUrlInput.value.trim();\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.sessionIdInput.addEventListener('change', () => {\n  const value = els.sessionIdInput.value.trim();\n  state.sessionId = value || randomSessionId();\n  els.sessionIdInput.value = state.sessionId;\n  saveSessionConfig();\n  connectRealtime();\n});\n\nels.clearChatBtn.addEventListener('click', () => {\n  els.chatMessages.innerHTML = '';\n  els.chatMessages.appendChild(els.chatEmptyState);\n  appendMessage('system', '界面消息已清空。');\n});\n\nels.chatForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const message = els.chatInput.value.trim();\n  if (!message) return;\n\n  appendMessage('user', message);\n  els.chatInput.value = '';\n  updateCharCounter();\n\n  state.streamingMessageBody = null;\n  state.streamedText = '';\n\n  try {\n    setBusy(true, '聊天处理中...', els.sendChatBtn);\n    const data = await callJson('/api/chat', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      message\n    });\n\n    if (!state.streamedText) {\n      const isHtml = data.isCommand === true;\n      appendMessage('assistant', data.reply || '(空响应)', false, isHtml);\n    }\n    showToast('消息发送成功', 'success');\n  } catch (error) {\n    appendMessage('system', error instanceof Error ? error.message : String(error), true);\n    showToast(error instanceof Error ? error.message : String(error), 'error');\n  } finally {\n    state.streamingMessageBody = null;\n    setBusy(false, '就绪');\n  }\n});\n\nels.chatInput.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && state.commandDropdownVisible) {\n    hideCommandDropdown();\n    return;\n  }\n  if (event.key === 'Enter' && !event.shiftKey) {\n    event.preventDefault();\n    hideCommandDropdown();\n    els.chatForm.requestSubmit();\n  }\n});\n\nels.chatInput.addEventListener('input', () => {\n  updateCharCounter();\n  const value = els.chatInput.value;\n  const firstWord = value.split(/\\s/)[0];\n  if (firstWord.startsWith('/') && value === firstWord) {\n    // User is still typing the command name (no space yet)\n    const matches = filterCommands(firstWord);\n    showCommandDropdown(matches);\n  } else {\n    hideCommandDropdown();\n  }\n});\n\nels.chatInput.addEventListener('blur', () => {\n  // Delay hide to allow mousedown on dropdown item to fire first\n  setTimeout(hideCommandDropdown, 150);\n});\n\nfunction openLightbox(src) {\n  els.lightboxImg.src = src;\n  els.lightbox.classList.remove('hidden');\n}\n\nfunction closeLightbox() {\n  els.lightbox.classList.add('hidden');\n  els.lightboxImg.src = '';\n}\n\nels.screenshotImage.addEventListener('click', () => {\n  if (!els.screenshotImage.classList.contains('hidden')) {\n    openLightbox(els.screenshotImage.src);\n  }\n});\n\nels.lightbox.addEventListener('click', (event) => {\n  if (event.target !== els.lightboxImg) {\n    closeLightbox();\n  }\n});\n\nels.takeScreenshotBtn.addEventListener('click', async () => {\n  if (state.busy) return;\n\n  try {\n    setBusy(true, '正在获取截图...', els.takeScreenshotBtn);\n    const data = await callJson('/api/screenshot', {\n      channel: 'web',\n      sessionId: state.sessionId\n    });\n\n    els.screenshotImage.src = `data:${data.mimeType};base64,${data.imageBase64}`;\n    els.screenshotImage.classList.remove('hidden');\n    els.screenshotMeta.textContent = `mimeType: ${data.mimeType}\\nsize(base64): ${data.imageBase64.length}`;\n    showToast('截图获取成功', 'success');\n  } catch (error) {\n    els.screenshotMeta.textContent = error instanceof Error ? error.message : String(error);\n    showToast(error instanceof Error ? error.message : String(error), 'error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nels.execForm.addEventListener('submit', async (event) => {\n  event.preventDefault();\n  if (state.busy) return;\n\n  const command = els.execInput.value.trim();\n  if (!command) return;\n\n  els.exitCodeOutput.classList.remove('exit-error');\n  els.stderrOutput.classList.remove('error');\n\n  try {\n    setBusy(true, '正在执行命令...', els.runExecBtn);\n    const data = await callJson('/api/system/exec', {\n      channel: 'web',\n      sessionId: state.sessionId,\n      command\n    });\n\n    updateExecEmptyState(true);\n    els.exitCodeOutput.textContent = String(data.exitCode);\n    els.exitCodeOutput.classList.toggle('exit-error', data.exitCode !== 0);\n    els.stdoutOutput.textContent = data.stdout || '(empty)';\n    els.stderrOutput.textContent = data.stderr || '(empty)';\n    els.stderrOutput.classList.toggle('error', Boolean(data.stderr));\n    if (data.exitCode === 0) {\n      showToast('命令执行成功', 'success');\n    } else {\n      showToast(`命令退出码: ${data.exitCode}`, 'error');\n    }\n  } catch (error) {\n    const message = error instanceof Error ? error.message : String(error);\n    updateExecEmptyState(true);\n    els.exitCodeOutput.textContent = 'error';\n    els.exitCodeOutput.classList.add('exit-error');\n    els.stdoutOutput.textContent = '';\n    els.stderrOutput.textContent = message;\n    els.stderrOutput.classList.add('error');\n    showToast(message, 'error');\n  } finally {\n    setBusy(false, '就绪');\n  }\n});\n\nwindow.addEventListener('beforeunload', () => {\n  closeRealtime();\n});\n\ndocument.addEventListener('keydown', (event) => {\n  if (event.key === 'Escape' && !els.lightbox.classList.contains('hidden')) {\n    closeLightbox();\n  }\n});\n\ninit();\n","numLines":537,"startLine":1,"totalLines":537}}}
