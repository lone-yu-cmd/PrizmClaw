n   336→  cursor: pointer;\n   337→}\n   338→\n   339→.lightbox {\n   340→  position: fixed;\n   341→  inset: 0;\n   342→  z-index: 200;\n   343→  background: rgba(0, 0, 0, 0.8);\n   344→  display: flex;\n   345→  align-items: center;\n   346→  justify-content: center;\n   347→  cursor: zoom-out;\n   348→}\n   349→\n   350→.lightbox.hidden {\n   351→  display: none;\n   352→}\n   353→\n   354→.lightbox-img {\n   355→  max-width: 95vw;\n   356→  max-height: 95vh;\n   357→  object-fit: contain;\n   358→  border-radius: 6px;\n   359→  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n   360→  cursor: default;\n   361→}\n   362→\n   363→.exec-form {\n   364→  display: grid;\n   365→  grid-template-columns: 1fr auto;\n   366→  gap: 8px;\n   367→  margin-bottom: 10px;\n   368→}\n   369→\n   370→.exec-form-actions {\n   371→  display: flex;\n   372→  align-items: center;\n   373→  gap: 8px;\n   374→}\n   375→\n   376→.exec-result {\n   377→  display: grid;\n   378→  gap: 8px;\n   379→}\n   380→\n   381→#execOutput {\n   382→  display: grid;\n   383→  gap: 8px;\n   384→}\n   385→\n   386→.hidden {\n   387→  display: none;\n   388→}\n   389→\n   390→.sr-only {\n   391→  position: absolute;\n   392→  width: 1px;\n   393→  height: 1px;\n   394→  padding: 0;\n   395→  margin: -1px;\n   396→  overflow: hidden;\n   397→  clip: rect(0, 0, 0, 0);\n   398→  white-space: nowrap;\n   399→  border: 0;\n   400→}\n   401→\n   402→@media (max-width: 900px) {\n   403→  .dashboard-grid {\n   404→    grid-template-columns: 1fr;\n   405→  }\n   406→\n   407→  .form-grid {\n   408→    grid-template-columns: 1fr;\n   409→  }\n   410→}\n   411→\n   412→@media (max-width: 600px) {\n   413→  .app-shell {\n   414→    padding: 12px;\n   415→    gap: 10px;\n   416→  }\n   417→\n   418→  .app-header {\n   419→    flex-wrap: wrap;\n   420→    gap: 8px;\n   421→  }\n   422→\n   423→  .app-header h1 {\n   424→    font-size: 1.1rem;\n   425→  }\n   426→\n   427→  .app-header .subtitle {\n   428→    font-size: 1