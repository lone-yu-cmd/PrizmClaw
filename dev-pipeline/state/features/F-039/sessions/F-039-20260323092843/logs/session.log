eme: light dark;\n  --bg: #f4f6fb;\n  --panel: #ffffff;\n  --line: #dfe3ef;\n  --text: #1f2633;\n  --muted: #667085;\n  --primary: #3a6ff7;\n  --primary-contrast: #ffffff;\n  --warning: #d97706;\n  --danger: #b42318;\n  --chat-user: #e9f0ff;\n  --chat-assistant: #f5f7fa;\n  --radius: 12px;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  color: var(--text);\n  background: var(--bg);\n}\n\n.app-shell {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 20px;\n  display: grid;\n  gap: 16px;\n}\n\n.app-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  position: sticky;\n  top: 0;\n  z-index: 10;\n  background: var(--bg);\n  border-bottom: 1px solid var(--line);\n  padding-bottom: 12px;\n  margin-bottom: -12px;\n}\n\nh1,\nh2,\nh3,\np {\n  margin: 0;\n}\n\n.subtitle {\n  margin-top: 6px;\n  color: var(--muted);\n}\n\n.status {\n  border: 1px solid var(--line);\n  background: var(--panel);\n  border-radius: 999px;\n  padding: 6px 12px;\n  font-size: 13px;\n  color: var(--muted);\n}\n\n.status.connected {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.status.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.08), 0 1px 2px rgba(31, 38, 51, 0.04);\n}\n\n.sub-panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 1px 4px rgba(31, 38, 51, 0.06);\n}\n\n.form-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 12px;\n}\n\nlabel {\n  display: grid;\n  gap: 6px;\n  font-size: 14px;\n}\n\ninput,\ntextarea,\nbutton {\n  font: inherit;\n}\n\ninput,\ntextarea {\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 9px 10px;\n  width: 100%;\n  color: inherit;\n  background: #fff;\n}\n\ntextarea {\n  resize: vertical;\n  min-height: 82px;\n}\n\ninput:focus,\ntextarea:focus {\n  outline: none;\n  border-color: var(--primary);\n  box-shadow: 0 0 0 3px rgba(58, 111, 247, 0.18);\n}\n\n.btn {\n  border: 0;\n  border-radius: 10px;\n  padding: 9px 14px;\n  cursor: pointer;\n  transition: transform 0.15s ease, filter 0.15s ease;\n}\n\n.btn:hover {\n  transform: translateY(-1px);\n  filter: brightness(1.08);\n}\n\n.btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n  pointer-events: none;\n}\n\n@keyframes btn-spin {\n  to {\n    transform: rotate(360deg);\n  }\n}\n\n.btn.loading {\n  position: relative;\n  color: transparent;\n  pointer-events: none;\n}\n\n.btn.loading::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  margin: auto;\n  width: 16px;\n  height: 16px;\n  border: 2px solid rgba(255, 255, 255, 0.5);\n  border-top-color: #fff;\n  border-radius: 50%;\n  animation: btn-spin 0.7s linear infinite;\n}\n\n.btn.primary {\n  background: var(--primary);\n  color: var(--primary-contrast);\n}\n\n.btn.warning {\n  background: var(--warning);\n  color: #fff;\n}\n\n.btn.ghost {\n  border: 1px solid var(--line);\n  background: transparent;\n}\n\n.dashboard-grid {\n  display: grid;\n  grid-template-columns: 2fr 1fr;\n  gap: 16px;\n}\n\n.chat-panel {\n  display: grid;\n  gap: 12px;\n}\n\n.panel-head {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 10px;\n}\n\n.chat-messages {\n  border: 1px solid var(--line);\n  border-radius: 12px;\n  padding: 10px;\n  min-height: 360px;\n  max-height: 62vh;\n  overflow: auto;\n  display: grid;\n  gap: 10px;\n  background: #fff;\n}\n\n@keyframes fade-in {\n  from {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.message {\n  padding: 10px;\n  border-radius: 10px;\n  line-height: 1.5;\n  white-space: pre-wrap;\n  word-break: break-word;\n  animation: fade-in 0.25s ease-out both;\n}\n\n.message.user {\n  background: var(--chat-user);\n}\n\n.message.assistant {\n  background: var(--chat-assistant);\n}\n\n.message.error {\n  border: 1px solid #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.message .role {\n  display: block;\n  font-size: 12px;\n  color: var(--muted);\n  margin-bottom: 4px;\n}\n\n.chat-form {\n  display: grid;\n  gap: 8px;\n}\n\n.chat-form-actions {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.char-counter {\n  font-size: 12px;\n  color: var(--muted);\n  text-align: right;\n  margin-top: -4px;\n}\n\n.char-counter.warning {\n  color: var(--warning);\n}\n\n.side-panel {\n  display: grid;\n  gap: 14px;\n  align-content: start;\n}\n\n.hint {\n  font-size: 13px;\n  color: var(--muted);\n  margin: 6px 0 10px;\n}\n\n.output-box {\n  margin: 0;\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 10px;\n  min-height: 44px;\n  background: #fff;\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-x: auto;\n}\n\n.output-box.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.output-box.exit-error {\n  border-color: #fde8bb;\n  background: #fffbf0;\n  color: var(--warning);\n}\n\n.screenshot-image {\n  width: 100%;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  margin-top: 10px;\n  background: #fff;\n}\n\n.screenshot-image:not(.hidden) {\n  cursor: pointer;\n}\n\n.lightbox {\n  position: fixed;\n  inset: 0;\n  z-index: 200;\n  background: rgba(0, 0, 0, 0.8);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: zoom-out;\n}\n\n.lightbox.hidden {\n  display: none;\n}\n\n.lightbox-img {\n  max-width: 95vw;\n  max-height: 95vh;\n  object-fit: contain;\n  border-radius: 6px;\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n  cursor: default;\n}\n\n.exec-form {\n  display: grid;\n  grid-template-columns: 1fr auto;\n  gap: 8px;\n  margin-bottom: 10px;\n}\n\n.exec-form-actions {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.exec-result {\n  display: grid;\n  gap: 8px;\n}\n\n#execOutput {\n  display: grid;\n  gap: 8px;\n}\n\n.hidden {\n  display: none;\n}\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n@media (max-width: 900px) {\n  .dashboard-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .form-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 600px) {\n  .app-shell {\n    padding: 12px;\n    gap: 10px;\n  }\n\n  .app-header {\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n\n  .app-header h1 {\n    font-size: 1.1rem;\n  }\n\n  .app-header .subtitle {\n    font-size: 12px;\n  }\n\n  .status {\n    max-width: 140px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .panel,\n  .sub-panel {\n    padding: 10px;\n  }\n\n  .chat-messages {\n    max-height: 50vh;\n  }\n\n  .exec-form {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg: #111827;\n    --panel: #1f2937;\n    --line: #374151;\n    --text: #f9fafb;\n    --muted: #9ca3af;\n    --primary: #5b8df8;\n    --primary-contrast: #ffffff;\n    --warning: #f59e0b;\n    --danger: #f87171;\n    --chat-user: #1e3a5f;\n    --chat-assistant: #263144;\n  }\n\n  input,\n  textarea {\n    background: var(--panel);\n    color: var(--text);\n  }\n\n  .chat-messages {\n    background: var(--panel);\n  }\n\n  .output-box {\n    background: var(--panel);\n  }\n\n  .screenshot-image {\n    background: var(--panel);\n  }\n\n  .status.connected {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .status.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .message.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.exit-error {\n    border-color: #78350f;\n    background: #431407;\n    color: var(--warning);\n  }\n}\n\n/* ── Copy To Clipboard Button ───────────────────────────────────────────────── */\n\n.output-box-wrapper {\n  position: relative;\n}\n\n.copy-btn {\n  position: absolute;\n  top: 6px;\n  right: 6px;\n  width: 28px;\n  height: 28px;\n  border: 1px solid var(--line);\n  border-radius: 6px;\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 14px;\n  line-height: 1;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0.6;\n  transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease;\n  padding: 0;\n}\n\n.copy-btn:hover {\n  opacity: 1;\n  background: var(--primary);\n  color: var(--primary-contrast);\n  border-color: var(--primary);\n}\n\n.output-box-wrapper:hover .copy-btn {\n  opacity: 1;\n}\n\n\n\n.chat-messages-wrapper {\n  position: relative;\n}\n\n.scroll-to-bottom {\n  position: absolute;\n  bottom: 12px;\n  right: 12px;\n  z-index: 50;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  border: 1px solid var(--line);\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 16px;\n  line-height: 1;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.12);\n  transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;\n  opacity: 0;\n  pointer-events: none;\n}\n\n.scroll-to-bottom.visible {\n  opacity: 1;\n  pointer-events: auto;\n}\n\n.scroll-to-bottom:hover {\n  background: var(--primary);\n  color: var(--primary-contrast);\n  border-color: var(--primary);\n  transform: translateY(-1px);\n}\n\n/* ── Empty State Illustrations ──────────────────────────────────────────────── */\n\n.empty-state {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  padding: 32px 16px;\n  color: var(--muted);\n  text-align: center;\n  user-select: none;\n  pointer-events: none;\n}\n\n.empty-state-icon {\n  font-size: 36px;\n  line-height: 1;\n  opacity: 0.6;\n}\n\n.empty-state-title {\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--text);\n  opacity: 0.5;\n}\n\n.empty-state-hint {\n  font-size: 12px;\n  color: var(--muted);\n}\n\n/* ── Keyboard Shortcut Hints ────────────────────────────────────────────────── */\n\n.kbd {\n  display: inline-block;\n  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;\n  font-size: 11px;\n  line-height: 1;\n  padding: 3px 6px;\n  border: 1px solid var(--line);\n  border-bottom-width: 2px;\n  border-radius: 5px;\n  background: var(--panel);\n  color: var(--muted);\n  white-space: nowrap;\n}\n\n/* ── Toast Notification System ─────────────────────────────────────────────── */\n\n.toast-container {\n  position: fixed;\n  bottom: 20px;\n  right: 20px;\n  z-index: 300;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  pointer-events: none;\n}\n\n@keyframes toast-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(8px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes toast-fade-out {\n  from {\n    opacity: 1;\n    transform: translateY(0);\n  }\n  to {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n}\n\n.toast {\n  padding: 10px 16px;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  background: var(--panel);\n  color: var(--text);\n  font-size: 14px;\n  line-height: 1.4;\n  max-width: 320px;\n  box-shadow: 0 4px 12px rgba(31, 38, 51, 0.12);\n  animation: toast-slide-in 0.2s ease-out both;\n  pointer-events: auto;\n}\n\n.toast.success {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.toast.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.toast.info {\n  border-color: var(--line);\n  background: var(--panel);\n  color: var(--text);\n}\n\n.toast.toast-fade-out {\n  animation: toast-fade-out 0.3s ease-in both;\n}\n\n@media (prefers-color-scheme: dark) {\n  .toast.success {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .toast.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n}\n","structuredPatch":[{"oldStart":96,"oldLines":6,"newStart":96,"newLines":66,"lines":["   box-shadow: 0 1px 4px rgba(31, 38, 51, 0.06);"," }"," ","+/* ── Session Info Panel ─────────────────────────────────────────────────────── */","+","+.session-info-panel h2 {","+  margin-bottom: 10px;","+}","+","+.info-grid {","+  display: grid;","+  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));","+  gap: 8px;","+  margin: 0;","+}","+","+.info-row {","+  display: flex;","+  flex-direction: column;","+  gap: 2px;","+  padding: 8px 10px;","+  border: 1px solid var(--line);","+  border-radius: 8px;","+  background: var(--bg);","+}","+","+.info-label {","+  font-size: 11px;","+  font-weight: 600;","+  color: var(--muted);","+  text-transform: uppercase;","+  letter-spacing: 0.04em;","+  margin: 0;","+}","+","+.info-value {","+  font-size: 13px;","+  color: var(--text);","+  word-break: break-all;","+  margin: 0;","+  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;","+}","+","+.info-value.muted {","+  color: var(--muted);","+  font-style: italic;","+  font-family: inherit;","+}","+","+.info-value.connected {","+  color: #027a48;","+}","+","+.info-value.error {","+  color: var(--danger);","+}","+","+@media (prefers-color-scheme: dark) {","+  .info-value.connected {","+    color: #4ade80;","+  }","+}","+"," .form-grid {","   display: grid;","   grid-template-columns: repeat(2, minmax(0, 1fr));"]}],"userModified":false,"replaceAll":false}}
