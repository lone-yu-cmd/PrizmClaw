: contain;\n   418→  border-radius: 6px;\n   419→  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n   420→  cursor: default;\n   421→}\n   422→\n   423→.exec-form {\n   424→  display: grid;\n   425→  grid-template-columns: 1fr auto;\n   426→  gap: 8px;\n   427→  margin-bottom: 10px;\n   428→}\n   429→\n   430→.exec-form-actions {\n   431→  display: flex;\n   432→  align-items: center;\n   433→  gap: 8px;\n   434→}\n   435→\n   436→.exec-result {\n   437→  display: grid;\n   438→  gap: 8px;\n   439→}\n   440→\n   441→#execOutput {\n   442→  display: grid;\n   443→  gap: 8px;\n   444→}\n   445→\n   446→.hidden {\n   447→  display: none;\n   448→}\n   449→\n   450→.sr-only {\n   451→  position: absolute;\n   452→  width: 1px;\n   453→  height: 1px;\n   454→  padding: 0;\n   455→  margin: -1px;\n   456→  overflow: hidden;\n   457→  clip: rect(0, 0, 0, 0);\n   458→  white-space: nowrap;\n   459→  border: 0;\n   460→}\n   461→\n   462→@media (max-width: 900px) {\n   463→  .dashboard-grid {\n   464→    grid-template-columns: 1fr;\n   465→  }\n   466→\n   467→  .form-grid {\n   468→    grid-template-columns: 1fr;\n   469→  }\n   470→}\n   471→\n   472→@media (max-width: 600px) {\n   473→  .app-shell {\n   474→    padding: 12px;\n   475→    gap: 10px;\n   476→  }\n   477→\n   478→  .app-header {\n   479→    flex-wrap: wrap;\n   480→    gap: 8px;\n   481→  }\n   482→\n   483→  .app-header h1 {\n   484→    font-size: 1.1rem;\n   485→  }\n   486→\n   487→  .app-header .subtitle {\n   488→    font-size: 12px;\n   489→  }\n   490→\n   491→  .status {\n   492→    max-width: 140px;\n   493→    overflow: hidden;\n   494→    text-overflow: ellipsis;\n   495→    white-space: nowrap;\n   496→  }\n   497→\n   498→  .panel,\n   499→  .sub-panel {\n   500→    padding: 10px;\n   501→  }\n   502→\n   503→  .chat-messages {\n   504→    max-height: 50vh;\n   505→  }\n   506→\n   507→  .exec-form {\n   508→    grid-template-columns: 1fr;\n   509→  }\n   510→}\n   511→\n   512→@media (prefers-color-scheme: dark) {\n   513→  :root {\n   514→    --bg: #111827;\n   515→    --panel: #1f2937;\n   516→    --line: #374151;\n   517→    --text: #f9fafb;\n   518→    --muted: #9ca3af;\n   519→    --primary: #5b8df8;\n   520→    --primary-contrast: #ffffff;\n   521→    --warning: #f59e0b;\n   522→    --danger: #f87171;\n   523→    --chat-user: #1e3a5f;\n   524→    --chat-assistant: #263144;\n   525→  }\n   526→\n   527→  input,\n   528→  textarea {\n   529→    background: var(--panel);\n   530→    color: var(--text);\n   531→  }\n   532→\n   533→  .chat-messages {\n   534→    background: var(--panel);\n   535→  }\n   536→\n   537→  .output-box {\n   538→    background: var(--panel);\n   539→  }\n   540→\n   541→  .screenshot-image {\n   542→    background: var(--panel);\n   543→  }\n   544→\n   545→  .status.connected {\n   546→    border-color: #166534;\n   547→    background: #14532d;\n   548→    color: #4ade80;\n   549→  }\n   550→\n   551→  .status.error {\n   552→    border-color: #7f1d1d;\n   553→    background: #450a0a;\n   554→    color: var(--danger);\n   555→  }\n   556→\n   557→  .message.error {\n   558→    border-color: #7f1d1d;\n   559→    background: #450a0a;\n   560→    color: var(--danger);\n   561→  }\n   562→\n   563→  .output-box.error {\n   564→    border-color: #7f1d1d;\n   565→    background: #450a0a;\n   566→    color: var(--danger);\n   567→  }\n   568→\n   569→  .output-box.exit-error {\n   570→    border-color: #78350f;\n   571→    background: #431407;\n   572→    color: var(--warning);\n   573→  }\n   574→}\n   575→\n   576→/* ── Copy To Clipboard Button ───────────────────────────────────────────────── */\n   577→\n   578→.output-box-wrapper {\n   579→  position: relative;\n   580→}\n   581→\n   582→.copy-btn {\n   583→  position: absolute;\n   584→  top: 6px;\n   585→  right: 6px;\n   586→  width: 28px;\n   587→  height: 28px;\n   588→  border: 1px solid var(--line);\n   589→  border-radius: 6px;\n   590→  background: var(--panel);\n   591→  color: var(--muted);\n   592→  font-size: 14px;\n   593→  line-height: 1;\n   594→  cursor: pointer;\n   595→  display: flex;\n   596→  align-items: center;\n   597→  justify-content: center;\n   598→  opacity: 0.6;\n   599→  transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease;\n   600→  padding: 0;\n   601→}\n   602→\n   603→.copy-btn:hover {\n   604→  opacity: 1;\n   605→  background: var(--primary);\n   606→  color: var(--primary-contrast);\n   607→  border-color: var(--primary);\n   608→}\n   609→\n   610→.output-box-wrapper:hover .copy-btn {\n   611→  opacity: 1;\n   612→}\n   613→\n   614→\n   615→\n   616→.chat-messages-wrapper {\n   617→  position: relative;\n   618→}\n   619→\n   620→.scroll-to-bottom {\n   621→  position: absolute;\n   622→  bottom: 12px;\n   623→  right: 12px;\n   624→  z-index: 50;\n   625→  width: 36px;\n   626→  height: 36px;\n   627→  border-radius: 50%;\n   628→  border: 1px solid var(--line);\n   629→  background: var(--panel);\n   630→  color: var(--muted);\n   631→  font-size: 16px;\n   632→  line-height: 1;\n   633→  cursor: pointer;\n   634→  display: flex;\n   635→  align-items: center;\n   636→  justify-content: center;\n   637→  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.12);\n   638→  transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;\n   639→  opacity: 0;\n   640→  pointer-events: none;\n   641→}\n   642→\n   643→.scroll-to-bottom.visible {\n   644→  opacity: 1;\n   645→  pointer-events: auto;\n   646→}\n   647→\n   648→.scroll-to-bottom:hover {\n   649→  background: var(--primary);\n   650→  color: var(--primary-contrast);\n   651→  border-color: var(--primary);\n   652→  transform: translateY(-1px);\n   653→}\n   654→\n   655→/* ── Empty State Illustrations ──────────────────────────────────────────────── */\n   656→\n   657→.empty-state {\n   658→  display: flex;\n   659→  flex-direction: column;\n   660→  align-items: center;\n   661→  justify-content: center;\n   662→  gap: 10px;\n   663→  padding: 32px 16px;\n   664→  color: var(--muted);\n   665→  text-align: center;\n   666→  user-select: none;\n   667→  pointer-events: none;\n   668→}\n   669→\n   670→.empty-state-icon {\n   671→  font-size: 36px;\n   672→  line-height: 1;\n   673→  opacity: 0.6;\n   674→}\n   675→\n   676→.empty-state-title {\n   677→  font-size: 14px;\n   678→  font-weight: 600;\n   679→  color: var(--text);\n   680→  opacity: 0.5;\n   681→}\n   682→\n   683→.empty-state-hint {\n   684→  font-size: 12px;\n   685→  color: var(--muted);\n   686→}\n   687→\n   688→/* ── Keyboard Shortcut Hints ────────────────────────────────────────────────── */\n   689→\n   690→.kbd {\n   691→  display: inline-block;\n   692→  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;\n   693→  font-size: 11px;\n   694→  line-height: 1;\n   695→  padding: 3px 6px;\n   696→  border: 1px solid var(--line);\n   697→  border-bottom-width: 2px;\n   698→  border-radius: 5px;\n   699→  background: var(--panel);\n   700→  color: var(--muted);\n   701→  white-space: nowrap;\n   702→}\n   703→\n   704→/* ── Toast Notification System ─────────────────────────────────────────────── */\n   705→\n   706→.toast-container {\n   707→  position: fixed;\n   708→  bottom: 20px;\n   709→  right: 20px;\n   710→  z-index: 300;\n   711→  display: flex;\n   712→  flex-direction: column;\n   713→  gap: 8px;\n   714→  pointer-events: none;\n   715→}\n   716→\n   717→@keyframes toast-slide-in {\n   718→  from {\n   719→    opacity: 0;\n   720→    transform: translateY(8px);\n   721→  }\n   722→  to {\n   723→    opacity: 1;\n   724→    transform: translateY(0);\n   725→  }\n   726→}\n   727→\n   728→@keyframes toast-fade-out {\n   729→  from {\n   730→    opacity: 1;\n   731→    transform: translateY(0);\n   732→  }\n   733→  to {\n   734→    opacity: 0;\n   735→    transform: translateY(4px);\n   736→  }\n   737→}\n   738→\n   739→.toast {\n   740→  padding: 10px 16px;\n   741→  bord