01→.sr-only {\n   502→  position: absolute;\n   503→  width: 1px;\n   504→  height: 1px;\n   505→  padding: 0;\n   506→  margin: -1px;\n   507→  overflow: hidden;\n   508→  clip: rect(0, 0, 0, 0);\n   509→  white-space: nowrap;\n   510→  border: 0;\n   511→}\n   512→\n   513→@media (max-width: 900px) {\n   514→  .dashboard-grid {\n   515→    grid-template-columns: 1fr;\n   516→  }\n   517→\n   518→  .form-grid {\n   519→    grid-template-columns: 1fr;\n   520→  }\n   521→}\n   522→\n   523→@media (max-width: 600px) {\n   524→  .app-shell {\n   525→    padding: 12px;\n   526→    gap: 10px;\n   527→  }\n   528→\n   529→  .app-header {\n   530→    flex-wrap: wrap;\n   531→    gap: 8px;\n   532→  }\n   533→\n   534→  .app-header h1 {\n   535→    font-size: 1.1rem;\n   536→  }\n   537→\n   538→  .app-header .subtitle {\n   539→    font-size: 12px;\n   540→  }\n   541→\n   542→  .status {\n   543→    max-width: 140px;\n   544→    overflow: hidden;\n   545→    text-overflow: ellipsis;\n   546→    white-space: nowrap;\n   547→  }\n   548→\n   549→  .panel,\n   550→  .sub-panel {\n   551→    padding: 10px;\n   552→  }\n   553→\n   554→  .chat-messages {\n   555→    max-height: 50vh;\n   556→  }\n   557→\n   558→  .exec-form {\n   559→    grid-template-columns: 1fr;\n   560→  }\n   561→}\n   562→\n   563→@media (prefers-color-scheme: dark) {\n   564→  :root {\n   565→    --bg: #111827;\n   566→    --panel: #1f2937;\n   567→    --line: #374151;\n   568→    --text: #f9fafb;\n   569→    --muted: #9ca3af;\n   570→    --primary: #5b8df8;\n   571→    --primary-contrast: #ffffff;\n   572→    --warning: #f59e0b;\n   573→    --danger: #f87171;\n   574→    --chat-user: #1e3a5f;\n   575→    --chat-assistant: #263144;\n   576→  }\n   577→\n   578→  input,\n   579→  textarea {\n   580→    background: var(--panel);\n   581→    color: var(--text);\n   582→  }\n   583→\n   584→  .chat-messages {\n   585→    background: var(--panel);\n   586→  }\n   587→\n   588→  .output-box {\n   589→    background: var(--panel);\n   590→  }\n   591→\n   592→  .screenshot-image {\n   593→    background: var(--panel);\n   594→  }\n   595→\n   596→  .status.connected {\n   597→    border-color: #166534;\n   598→    background: #14532d;\n   599→    color: #4ade80;\n   600→  }\n   601→\n   602→  .status.error {\n   603→    border-color: #7f1d1d;\n   604→    background: #450a0a;\n   605→    color: var(--danger);\n   606→  }\n   607→\n   608→  .message.error {\n   609→    border-color: #7f1d1d;\n   610→    background: #450a0a;\n   611→    color: var(--danger);\n   612→  }\n   613→\n   614→  .output-box.error {\n   615→    border-color: #7f1d1d;\n   616→    background: #450a0a;\n   617→    color: var(--danger);\n   618→  }\n   619→\n   620→  .output-box.exit-error {\n   621→    border-color: #78350f;\n   622→    background: #431407;\n   623→    color: var(--warning);\n   624→  }\n   625→}\n   626→\n   627→/* ── Copy To Clipboard Button ───────────────────────────────────────────────── */\n   628→\n   629→.output-box-wrapper {\n   630→  position: relative;\n   631→}\n   632→\n   633→.copy-btn {\n   634→  position: absolute;\n   635→  top: 6px;\n   636→  right: 6px;\n   637→  width: 28px;\n   638→  height: 28px;\n   639→  border: 1px solid var(--line);\n   640→  border-radius: 6px;\n   641→  background: var(--panel);\n   642→  color: var(--muted);\n   643→  font-size: 14px;\n   644→  line-height: 1;\n   645→  cursor: pointer;\n   646→  display: flex;\n   647→  align-items: center;\n   648→  justify-content: center;\n   649→  opacity: 0.6;\n   650→  transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease;\n   651→  padding: 0;\n   652→}\n   653→\n   654→.copy-btn:hover {\n   655→  opacity: 1;\n   656→  background: var(--primary);\n   657→  color: var(--primary-contrast);\n   658→  border-color: var(--primary);\n   659→}\n   660→\n   661→.output-box-wrapper:hover .copy-btn {\n   662→  opacity: 1;\n   663→}\n   664→\n   665→\n   666→\n   667→.chat-messages-wrapper {\n   668→  position: relative;\n   669→}\n   670→\n   671→.scroll-to-bottom {\n   672→  position: absolute;\n   673→  bottom: 12px;\n   674→  right: 12px;\n   675→  z-index: 50;\n   676→  width: 36px;\n   677→  height: 36px;\n   678→  border-radius: 50%;\n   679→  border: 1px solid var(--line);\n   680→  background: var(--panel);\n   681→  color: var(--muted);\n   682→  font-size: 16px;\n   683→  line-height: 1;\n   684→  cursor: pointer;\n   685→  display: flex;\n   686→  align-items: center;\n   687→  justify-content: center;\n   688→  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.12);\n   689→  transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;\n   690→  opacity: 0;\n   691→  pointer-events: none;\n   692→}\n   693→\n   694→.scroll-to-bottom.visible {\n   695→  opacity: 1;\n   696→  pointer-events: auto;\n   697→}\n   698→\n   699→.scroll-to-bottom:hover {\n   700→  background: var(--primary);\n   701→  color: var(--primary-contrast);\n   702→  border-color: var(--primary);\n   703→  transform: translateY(-1px);\n   704→}\n   705→\n   706→/* ── Empty State Illustrations ──────────────────────────────────────────────── */\n   707→\n   708→.empty-state {\n   709→  display: flex;\n   710→  flex-direction: column;\n   711→  align-items: center;\n   712→  justify-content: center;\n   713→  gap: 10px;\n   714→  padding: 32px 16px;\n   715→  color: var(--muted);\n   716→  text-align: center;\n   717→  user-select: none;\n   718→  pointer-events: none;\n   719→}\n   720→\n   721→.empty-state-icon {\n   722→  font-size: 36px;\n   723→  line-height: 1;\n   724→  opacity: 0.6;\n   725→}\n   726→\n   727→.empty-state-title {\n   728→  font-size: 14px;\n   729→  font-weight: 600;\n   730→  color: var(--text);\n   731→  opacity: 0.5;\n   732→}\n   733→\n   734→.empty-state-hint {\n   735→  font-size: 12px;\n   736→  color: var(--muted);\n   737→}\n   738→\n   739→/* ── Keyboard Shortcut Hints ────────────────────────────────────────────────── */\n   740→\n   741→.kbd {\n   742→  display: inline-block;\n   743→  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;\n   744→  font-size: 11px;\n   745→  line-height: 1;\n   746→  padding: 3px 6px;\n   747→  border: 1px solid var(--line);\n   748→  border-bottom-width: 2px;\n   749→  border-radius: 5px;\n   750→  background: var(--panel);\n   751→  color: var(--muted);\n   752→  white-space: nowrap;\n   753→}\n   754→\n   755→/* ── Toast Notification System ─────────────────────────────────────────────── */\n   756→\n   757→.toast-container {\n   758→  position: fixed;\n   759→  bottom: 20px;\n   760→  right: 20px;\n   761→  z-index: 300;\n   762→  display: flex;\n   763→  flex-direction: column;\n   764→  gap: 8px;\n   765→  pointer-events: none;\n   766→}\n   767→\n   768→@keyframes toast-slide-in {\n   769→  from {\n   770→    opacity: 0;\n   771→    transform: translateY(8px);\n   772→  }\n   773→  to {\n   774→    opacity: 1;\n   775→    transform: translateY(0);\n   776→  }\n   777→}\n   778→\n   779→@keyframes toast-fade-out {\n   780→  from {\n   781→    opacity: 1;\n   782→    transform: translateY(0);\n   783→  }\n   784→  to {\n   785→    opacity: 0;\n   786→    transform: translateY(4px);\n   787→  }\n   788→}\n   789→\n   790→.toast {\n   791→  padding: 10px 16px;\n   792→  border-radius: 10px;\n   793→  border: 1px solid var(--line);\n   794→  background: var(--panel);\n   795→  color: var(--text);\n   796→  font-size: 14px;\n   797→  line-height: 1.4;\n   798→  max-width: 320px;\n   799→  box-shadow: 0 4px 12px rgba(31, 38, 51, 0.12);\n   800→  animation: toast-slide-in 0.2s ease-out both;\n   801→  pointer-events: auto;\n   802→}\n   803→\n   804→.toast.success {\n   805→  border-color: #a6f4c5;\n   806→  background: #ecfdf3;\n   807→  color: #027a48;\n   808→}\n   809→\n   810→.toast.error {\n   811→  border-color: #f9d3d0;\n   812→  background: #fef3f2;\n   813→  color: var(--danger);\n   814→}\n   815→\n   816→.toast.info {\n   817→  border-color: var(--line);\n   818→  background: var(--panel);\n   819→  color: var(--text);\n   820→}\n   821→\n   822→.toast.toast-fade-out {\n   823→  animation: toast-fade-out 0.3s ease-in both;\n   824→}\n   825→\n   826→@media (prefers-color-scheme: dark) {\n   827→  .toast.success {\n   828→    border-color: #166534;\n   829→    background: #14532d;\n   830→    color: #4ade80;\n   831→  }\n   832→\n   833→  .toast.error {\n   834→    border-color: #7f1d1d;\n   835→    background: #450a0a;\n   836→    color: var(--danger);\n   837→  }\n   838→}\n   839→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"5162696b-eb1f-43c4-9e42-4383048021a9","uuid":"9b7c834a-c060-4244-b9e1-e483c4f20b6d","timestamp":"2026-03-23T08:23:17.690Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/loneyu/SelfProjects/PrizmClaw/public/styles.css","content":":root {\n  color-scheme: light dark;\n  --bg: #f4f6fb;\n  --panel: #ffffff;\n  --line: #dfe3ef;\n  --text: #1f2633;\n  --muted: #667085;\n  --primary: #3a6ff7;\n  --primary-contrast: #ffffff;\n  --warning: #d97706;\n  --danger: #b42318;\n  --chat-user: #e9f0ff;\n  --chat-assistant: #f5f7fa;\n  --radius: 12px;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;\n  color: var(--text);\n  background: var(--bg);\n}\n\n.app-shell {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 20px;\n  display: grid;\n  gap: 16px;\n}\n\n.app-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  position: sticky;\n  top: 0;\n  z-index: 10;\n  background: var(--bg);\n  border-bottom: 1px solid var(--line);\n  padding-bottom: 12px;\n  margin-bottom: -12px;\n}\n\nh1,\nh2,\nh3,\np {\n  margin: 0;\n}\n\n.subtitle {\n  margin-top: 6px;\n  color: var(--muted);\n}\n\n.status {\n  border: 1px solid var(--line);\n  background: var(--panel);\n  border-radius: 999px;\n  padding: 6px 12px;\n  font-size: 13px;\n  color: var(--muted);\n}\n\n.status.connected {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.status.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.08), 0 1px 2px rgba(31, 38, 51, 0.04);\n}\n\n.sub-panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 1px 4px rgba(31, 38, 51, 0.06);\n}\n\n/* ── Collapsible Config Panel ───────────────────────────────────────────────── */\n\ndetails.config-panel > summary {\n  list-style: none;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  font-size: 1rem;\n  font-weight: 600;\n  color: var(--text);\n  user-select: none;\n  padding-bottom: 0;\n  margin-bottom: 0;\n}\n\ndetails.config-panel > summary::-webkit-details-marker {\n  display: none;\n}\n\ndetails.config-panel > summary::before {\n  content: '▶';\n  font-size: 10px;\n  color: var(--muted);\n  transition: transform 0.2s ease;\n  flex-shrink: 0;\n}\n\ndetails.config-panel[open] > summary::before {\n  transform: rotate(90deg);\n}\n\ndetails.config-panel[open] > summary {\n  margin-bottom: 12px;\n}\n\n/* ── Session Info Panel ─────────────────────────────────────────────────────── */\n\n.session-info-panel h2 {\n  margin-bottom: 10px;\n}\n\n.info-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\n  gap: 8px;\n  margin: 0;\n}\n\n.info-row {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n  padding: 8px 10px;\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  background: var(--bg);\n}\n\n.info-label {\n  font-size: 11px;\n  font-weight: 600;\n  color: var(--muted);\n  text-transform: uppercase;\n  letter-spacing: 0.04em;\n  margin: 0;\n}\n\n.info-value {\n  font-size: 13px;\n  color: var(--text);\n  word-break: break-all;\n  margin: 0;\n  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;\n}\n\n.info-value.muted {\n  color: var(--muted);\n  font-style: italic;\n  font-family: inherit;\n}\n\n.info-value.connected {\n  color: #027a48;\n}\n\n.info-value.error {\n  color: var(--danger);\n}\n\n@media (prefers-color-scheme: dark) {\n  .info-value.connected {\n    color: #4ade80;\n  }\n}\n\n.form-grid {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 12px;\n}\n\nlabel {\n  display: grid;\n  gap: 6px;\n  font-size: 14px;\n}\n\ninput,\ntextarea,\nbutton {\n  font: inherit;\n}\n\ninput,\ntextarea {\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 9px 10px;\n  width: 100%;\n  color: inherit;\n  background: #fff;\n}\n\ntextarea {\n  resize: vertical;\n  min-height: 82px;\n}\n\ninput:focus,\ntextarea:focus {\n  outline: none;\n  border-color: var(--primary);\n  box-shadow: 0 0 0 3px rgba(58, 111, 247, 0.18);\n}\n\n.btn {\n  border: 0;\n  border-radius: 10px;\n  padding: 9px 14px;\n  cursor: pointer;\n  transition: transform 0.15s ease, filter 0.15s ease;\n}\n\n.btn:hover {\n  transform: translateY(-1px);\n  filter: brightness(1.08);\n}\n\n.btn:disabled {\n  opacity: 0.6;\n  cursor: not-allowed;\n  pointer-events: none;\n}\n\n@keyframes btn-spin {\n  to {\n    transform: rotate(360deg);\n  }\n}\n\n.btn.loading {\n  position: relative;\n  color: transparent;\n  pointer-events: none;\n}\n\n.btn.loading::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  margin: auto;\n  width: 16px;\n  height: 16px;\n  border: 2px solid rgba(255, 255, 255, 0.5);\n  border-top-color: #fff;\n  border-radius: 50%;\n  animation: btn-spin 0.7s linear infinite;\n}\n\n.btn.primary {\n  background: var(--primary);\n  color: var(--primary-contrast);\n}\n\n.btn.warning {\n  background: var(--warning);\n  color: #fff;\n}\n\n.btn.ghost {\n  border: 1px solid var(--line);\n  background: transparent;\n}\n\n.dashboard-grid {\n  display: grid;\n  grid-template-columns: 2fr 1fr;\n  gap: 16px;\n}\n\n.chat-panel {\n  display: grid;\n  gap: 12px;\n}\n\n.panel-head {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 10px;\n}\n\n.chat-messages {\n  border: 1px solid var(--line);\n  border-radius: 12px;\n  padding: 10px;\n  min-height: 360px;\n  max-height: 62vh;\n  overflow: auto;\n  display: grid;\n  gap: 10px;\n  background: #fff;\n}\n\n@keyframes fade-in {\n  from {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n.message {\n  padding: 10px;\n  border-radius: 10px;\n  line-height: 1.5;\n  animation: fade-in 0.25s ease-out both;\n  display: flex;\n  flex-direction: column;\n}\n\n.message .body {\n  white-space: pre-wrap;\n  word-break: break-word;\n  flex: 1;\n}\n\n.message-timestamp {\n  display: block;\n  font-size: 11px;\n  color: var(--muted);\n  text-align: right;\n  margin-top: 4px;\n  user-select: none;\n}\n\n.message.user {\n  background: var(--chat-user);\n}\n\n.message.assistant {\n  background: var(--chat-assistant);\n}\n\n.message.error {\n  border: 1px solid #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.message .role {\n  display: block;\n  font-size: 12px;\n  color: var(--muted);\n  margin-bottom: 4px;\n}\n\n.chat-form {\n  display: grid;\n  gap: 8px;\n}\n\n.chat-form-actions {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.char-counter {\n  font-size: 12px;\n  color: var(--muted);\n  text-align: right;\n  margin-top: -4px;\n}\n\n.char-counter.warning {\n  color: var(--warning);\n}\n\n.side-panel {\n  display: grid;\n  gap: 14px;\n  align-content: start;\n}\n\n.hint {\n  font-size: 13px;\n  color: var(--muted);\n  margin: 6px 0 10px;\n}\n\n.output-box {\n  margin: 0;\n  border: 1px solid var(--line);\n  border-radius: 10px;\n  padding: 10px;\n  min-height: 44px;\n  background: #fff;\n  white-space: pre-wrap;\n  word-break: break-word;\n  overflow-x: auto;\n}\n\n.output-box.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.output-box.exit-error {\n  border-color: #fde8bb;\n  background: #fffbf0;\n  color: var(--warning);\n}\n\n.screenshot-image {\n  width: 100%;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  margin-top: 10px;\n  background: #fff;\n}\n\n.screenshot-image:not(.hidden) {\n  cursor: pointer;\n}\n\n.lightbox {\n  position: fixed;\n  inset: 0;\n  z-index: 200;\n  background: rgba(0, 0, 0, 0.8);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: zoom-out;\n}\n\n.lightbox.hidden {\n  display: none;\n}\n\n.lightbox-img {\n  max-width: 95vw;\n  max-height: 95vh;\n  object-fit: contain;\n  border-radius: 6px;\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6);\n  cursor: default;\n}\n\n.exec-form {\n  display: grid;\n  grid-template-columns: 1fr auto;\n  gap: 8px;\n  margin-bottom: 10px;\n}\n\n.exec-form-actions {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n}\n\n.exec-result {\n  display: grid;\n  gap: 8px;\n}\n\n#execOutput {\n  display: grid;\n  gap: 8px;\n}\n\n.hidden {\n  display: none;\n}\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border: 0;\n}\n\n@media (max-width: 900px) {\n  .dashboard-grid {\n    grid-template-columns: 1fr;\n  }\n\n  .form-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 600px) {\n  .app-shell {\n    padding: 12px;\n    gap: 10px;\n  }\n\n  .app-header {\n    flex-wrap: wrap;\n    gap: 8px;\n  }\n\n  .app-header h1 {\n    font-size: 1.1rem;\n  }\n\n  .app-header .subtitle {\n    font-size: 12px;\n  }\n\n  .status {\n    max-width: 140px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n    white-space: nowrap;\n  }\n\n  .panel,\n  .sub-panel {\n    padding: 10px;\n  }\n\n  .chat-messages {\n    max-height: 50vh;\n  }\n\n  .exec-form {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (prefers-color-scheme: dark) {\n  :root {\n    --bg: #111827;\n    --panel: #1f2937;\n    --line: #374151;\n    --text: #f9fafb;\n    --muted: #9ca3af;\n    --primary: #5b8df8;\n    --primary-contrast: #ffffff;\n    --warning: #f59e0b;\n    --danger: #f87171;\n    --chat-user: #1e3a5f;\n    --chat-assistant: #263144;\n  }\n\n  input,\n  textarea {\n    background: var(--panel);\n    color: var(--text);\n  }\n\n  .chat-messages {\n    background: var(--panel);\n  }\n\n  .output-box {\n    background: var(--panel);\n  }\n\n  .screenshot-image {\n    background: var(--panel);\n  }\n\n  .status.connected {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .status.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .message.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n\n  .output-box.exit-error {\n    border-color: #78350f;\n    background: #431407;\n    color: var(--warning);\n  }\n}\n\n/* ── Copy To Clipboard Button ───────────────────────────────────────────────── */\n\n.output-box-wrapper {\n  position: relative;\n}\n\n.copy-btn {\n  position: absolute;\n  top: 6px;\n  right: 6px;\n  width: 28px;\n  height: 28px;\n  border: 1px solid var(--line);\n  border-radius: 6px;\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 14px;\n  line-height: 1;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0.6;\n  transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease;\n  padding: 0;\n}\n\n.copy-btn:hover {\n  opacity: 1;\n  background: var(--primary);\n  color: var(--primary-contrast);\n  border-color: var(--primary);\n}\n\n.output-box-wrapper:hover .copy-btn {\n  opacity: 1;\n}\n\n\n\n.chat-messages-wrapper {\n  position: relative;\n}\n\n.scroll-to-bottom {\n  position: absolute;\n  bottom: 12px;\n  right: 12px;\n  z-index: 50;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  border: 1px solid var(--line);\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 16px;\n  line-height: 1;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.12);\n  transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;\n  opacity: 0;\n  pointer-events: none;\n}\n\n.scroll-to-bottom.visible {\n  opacity: 1;\n  pointer-events: auto;\n}\n\n.scroll-to-bottom:hover {\n  background: var(--primary);\n  color: var(--primary-contrast);\n  border-color: var(--primary);\n  transform: translateY(-1px);\n}\n\n/* ── Empty State Illustrations ──────────────────────────────────────────────── */\n\n.empty-state {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  padding: 32px 16px;\n  color: var(--muted);\n  text-align: center;\n  user-select: none;\n  pointer-events: none;\n}\n\n.empty-state-icon {\n  font-size: 36px;\n  line-height: 1;\n  opacity: 0.6;\n}\n\n.empty-state-title {\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--text);\n  opacity: 0.5;\n}\n\n.empty-state-hint {\n  font-size: 12px;\n  color: var(--muted);\n}\n\n/* ── Keyboard Shortcut Hints ────────────────────────────────────────────────── */\n\n.kbd {\n  display: inline-block;\n  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;\n  font-size: 11px;\n  line-height: 1;\n  padding: 3px 6px;\n  border: 1px solid var(--line);\n  border-bottom-width: 2px;\n  border-radius: 5px;\n  background: var(--panel);\n  color: var(--muted);\n  white-space: nowrap;\n}\n\n/* ── Toast Notification System ─────────────────────────────────────────────── */\n\n.toast-container {\n  position: fixed;\n  bottom: 20px;\n  right: 20px;\n  z-index: 300;\n  display: flex;\n  flex-direction: column;\n  gap: 8px;\n  pointer-events: none;\n}\n\n@keyframes toast-slide-in {\n  from {\n    opacity: 0;\n    transform: translateY(8px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n@keyframes toast-fade-out {\n  from {\n    opacity: 1;\n    transform: translateY(0);\n  }\n  to {\n    opacity: 0;\n    transform: translateY(4px);\n  }\n}\n\n.toast {\n  padding: 10px 16px;\n  border-radius: 10px;\n  border: 1px solid var(--line);\n  background: var(--panel);\n  color: var(--text);\n  font-size: 14px;\n  line-height: 1.4;\n  max-width: 320px;\n  box-shadow: 0 4px 12px rgba(31, 38, 51, 0.12);\n  animation: toast-slide-in 0.2s ease-out both;\n  pointer-events: auto;\n}\n\n.toast.success {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.toast.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n.toast.info {\n  border-color: var(--line);\n  background: var(--panel);\n  color: var(--text);\n}\n\n.toast.toast-fade-out {\n  animation: toast-fade-out 0.3s ease-in both;\n}\n\n@media (prefers-color-scheme: dark) {\n  .toast.success {\n    border-color: #166534;\n    background: #14532d;\n    color: #4ade80;\n  }\n\n  .toast.error {\n    border-color: #7f1d1d;\n    background: #450a0a;\n    color: var(--danger);\n  }\n}\n","numLines":839,"startLine":1,"totalLines":839}}}
