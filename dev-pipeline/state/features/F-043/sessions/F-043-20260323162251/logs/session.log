enter;\n  justify-content: center;\n  opacity: 0.6;\n  transition: opacity 0.15s ease, background 0.15s ease, color 0.15s ease;\n  padding: 0;\n}\n\n.copy-btn:hover {\n  opacity: 1;\n  background: var(--primary);\n  color: var(--primary-contrast);\n  border-color: var(--primary);\n}\n\n.output-box-wrapper:hover .copy-btn {\n  opacity: 1;\n}\n\n\n\n.chat-messages-wrapper {\n  position: relative;\n}\n\n.scroll-to-bottom {\n  position: absolute;\n  bottom: 12px;\n  right: 12px;\n  z-index: 50;\n  width: 36px;\n  height: 36px;\n  border-radius: 50%;\n  border: 1px solid var(--line);\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 16px;\n  line-height: 1;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.12);\n  transition: opacity 0.2s ease, transform 0.2s ease, background 0.15s ease;\n  opacity: 0;\n  pointer-events: none;\n}\n\n.scroll-to-bottom.visible {\n  opacity: 1;\n  pointer-events: auto;\n}\n\n.scroll-to-bottom:hover {\n  background: var(--primary);\n  color: var(--primary-contrast);\n  border-color: var(--primary);\n  transform: translateY(-1px);\n}\n\n/* ── Empty State Illustrations ──────────────────────────────────────────────── */\n\n.empty-state {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 10px;\n  padding: 32px 16px;\n  color: var(--muted);\n  text-align: center;\n  user-select: none;\n  pointer-events: none;\n}\n\n.empty-state-icon {\n  font-size: 36px;\n  line-height: 1;\n  opacity: 0.6;\n}\n\n.empty-state-title {\n  font-size: 14px;\n  font-weight: 600;\n  color: var(--text);\n  opacity: 0.5;\n}\n\n.empty-state-hint {\n  font-size: 12px;\n  color: var(--muted);\n}\n\n/* ── Keyboard Shortcut Hints ────────────────────────────────────────────────── */\n\n.kbd {\n  display: inline-block;\n  font-family: ui-monospace, 'SFMono-Regular', Consolas, 'Liberation Mono', monospace;\n  font-size: 11px