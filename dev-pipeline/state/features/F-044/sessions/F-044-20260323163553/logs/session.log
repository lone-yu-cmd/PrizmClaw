0px;\n  margin: 0 auto;\n  padding: 20px;\n  display: grid;\n  gap: 16px;\n}\n\n.app-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 12px;\n  position: sticky;\n  top: 0;\n  z-index: 10;\n  background: var(--bg);\n  border-bottom: 1px solid var(--line);\n  padding-bottom: 12px;\n  margin-bottom: -12px;\n}\n\nh1,\nh2,\nh3,\np {\n  margin: 0;\n}\n\n.subtitle {\n  margin-top: 6px;\n  color: var(--muted);\n}\n\n.status {\n  border: 1px solid var(--line);\n  background: var(--panel);\n  border-radius: 999px;\n  padding: 6px 12px;\n  font-size: 13px;\n  color: var(--muted);\n}\n\n.status.connected {\n  border-color: #a6f4c5;\n  background: #ecfdf3;\n  color: #027a48;\n}\n\n.status.error {\n  border-color: #f9d3d0;\n  background: #fef3f2;\n  color: var(--danger);\n}\n\n/* ── Font Size Toggle ───────────────────────────────────────────────────────── */\n\n.font-toggle {\n  display: flex;\n  gap: 2px;\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  padding: 2px;\n  background: var(--panel);\n}\n\n.font-toggle-btn {\n  border: 0;\n  border-radius: 6px;\n  padding: 4px 8px;\n  cursor: pointer;\n  font-family: inherit;\n  font-size: 12px;\n  color: var(--muted);\n  background: transparent;\n  line-height: 1;\n  transition: background 0.15s ease, color 0.15s ease;\n  white-space: nowrap;\n}\n\n.font-toggle-btn:hover {\n  color: var(--text);\n  background: var(--bg);\n}\n\n.font-toggle-btn.active {\n  background: var(--primary);\n  color: var(--primary-contrast);\n}\n\n.panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 2px 8px rgba(31, 38, 51, 0.08), 0 1px 2px rgba(31, 38, 51, 0.04);\n}\n\n.sub-panel {\n  background: var(--panel);\n  border: 1px solid var(--line);\n  border-radius: var(--radius);\n  padding: 14px;\n  box-shadow: 0 1px 4px rgba(31, 38, 51, 0.06);\n}\n\n/* ── Collapsible Config Panel ─────────────────────────────────────