le ~, relative paths)\n  let resolvedPath = targetPath;\n\n  // Handle home directory expansion\n  if (resolvedPath.startsWith('~')) {\n    resolvedPath = path.join(process.env.HOME || process.env.USERPROFILE || '', resolvedPath.slice(1));\n  }\n\n  // Make absolute path if relative\n  if (!path.isAbsolute(resolvedPath)) {\n    const currentCwd = sessionStore.getCwd(sessionId) || process.cwd();\n    resolvedPath = path.resolve(currentCwd, resolvedPath);\n  }\n\n  // Normalize the path\n  resolvedPath = path.normalize(resolvedPath);\n\n  // Check if directory exists\n  try {\n    await access(resolvedPath);\n  } catch {\n    await reply(`❌ 目录不存在或无法访问: ${resolvedPath}`);\n    return;\n  }\n\n  // Update session cwd\n  sessionStore.setCwd(sessionId, resolvedPath);\n\n  await reply(`✅ 工作目录已切换至: ${resolvedPath}`);\n}\n\nexport default {\n  cdMeta,\n  handleCd\n};\n","structuredPatch":[{"oldStart":8,"oldLines":6,"newStart":8,"newLines":7,"lines":[" import { access } from 'node:fs/promises';"," import path from 'node:path';"," import { sessionStore } from '../../../services/session-store.js';","+import { isAiCliRunning, restartAiCli } from '../../../services/ai-cli-service.js';"," "," /**","  * CD command metadata."]}],"userModified":false,"replaceAll":false}}
