{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Dev-Pipeline Feature List",
  "description": "Schema for .dev-pipeline/feature-list.json",
  "type": "object",
  "required": ["$schema", "app_name", "features"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "dev-pipeline-feature-list-v1"
    },
    "app_name": {
      "type": "string",
      "minLength": 1
    },
    "app_description": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "created_by": {
      "type": "string"
    },
    "source_spec": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "description", "priority", "dependencies", "acceptance_criteria", "status"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^F-\\d{3}(-[A-Z])?$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "estimated_complexity": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^F-\\d{3}(-[A-Z])?$"
            }
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "failed", "skipped", "split"]
          },
          "session_granularity": {
            "type": "string",
            "enum": ["feature", "sub_feature", "auto"],
            "default": "feature"
          },
          "sub_features": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title", "description"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^F-\\d{3}-[A-Z]$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "model": {
            "type": "string",
            "description": "AI model ID for this feature. Overrides $MODEL env var. See .prizmkit/available-models.json for valid IDs."
          }
        }
      }
    },
    "global_context": {
      "type": "object",
      "properties": {
        "tech_stack": { "type": "string" },
        "design_system": { "type": "string" },
        "testing_strategy": { "type": "string" }
      }
    }
  }
}
