{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "src/pipeline-infra/**/*.js",
    "src/services/pipeline-control-service.js"
  ],
  "exclude": [
    "node_modules",
    "dev-pipeline/state",
    "dev-pipeline/bugfix-state"
  ]
}
